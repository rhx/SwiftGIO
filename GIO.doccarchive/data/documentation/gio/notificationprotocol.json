ce-Methods","title":"Instance Methods"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/NotificationProtocol"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/gio\/notificationprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"type":"inheritsFrom","title":"Inherits From"},{"title":"Conforming Types","identifiers":["doc:\/\/GIO\/documentation\/GIO\/Notification","doc:\/\/GIO\/documentation\/GIO\/NotificationRef"],"kind":"relationships","type":"conformingTypes"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"NotificationProtocol","kind":"identifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B8ProtocolP","text":"ObjectProtocol"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"The key difference between "},{"type":"codeVoice","code":"GNotification"},{"type":"text","text":" and other similar APIs is"},{"text":" ","type":"text"},{"type":"text","text":"that, if supported by the desktop environment, notifications sent"},{"type":"text","text":" "},{"type":"text","text":"with "},{"code":"GNotification","type":"codeVoice"},{"type":"text","text":" will persist after the application has exited,"},{"type":"text","text":" "},{"type":"text","text":"and even across system reboots."}],"type":"paragraph"},{"inlineContent":[{"text":"Since the user may click on a notification while the application is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not running, applications using 