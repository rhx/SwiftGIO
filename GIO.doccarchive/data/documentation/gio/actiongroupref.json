ctionGroup":{"role":"symbol","title":"ActionGroup","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ActionGroup"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","navigatorTitle":[{"text":"ActionGroup","kind":"identifier"}],"type":"topic","url":"\/documentation\/gio\/actiongroup","abstract":[{"type":"codeVoice","code":"GActionGroup"},{"type":"text","text":" represents a group of actions."}]},"doc://GIO/documentation/GIO/ActionGroupRef/init(gpointer:)":{"type":"topic","title":"init(gpointer:)","kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroupRef\/init(gpointer:)","url":"\/documentation\/gio\/actiongroupref\/init(gpointer:)","abstract":[{"type":"text","text":"Conditional initialiser from an optional "},{"type":"codeVoice","code":"gpointer"}],"fragments":[{"kind":"identifier","text":"init"},{"text":"!(","kind":"text"},{"text":"gpointer","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}]},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/ActionGroupRef/init(cPointer:)":{"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"kind":"text","text":">("},{"text":"cPointer","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":">)"}],"title":"init(cPointer:)","kind":"symbol","abstract":[{"text":"Unsafe typed initialiser.","type":"text"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"Do not use unless you know the underlying data type the pointer points to conforms to "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroupProtocol","isActive":true},{"text":".","type":"text"}]}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroupRef\/init(cPointer:)","url":"\/documentation\/gio\/actiongroupref\/init(cpointer:)"},"doc://GIO/documentation/GIO/ActionGroupRef/PointerWrapper-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroupRef\/PointerWrapper-Implementations","title":"PointerWrapper Implementations","abstract":[],"kind":"article","type":"topic","role":"collectionGroup","url":"\/documentation\/gio\/actiongroupref\/pointerwrapper-implementations"}}}