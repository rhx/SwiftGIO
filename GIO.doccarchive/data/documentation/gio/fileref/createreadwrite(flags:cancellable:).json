{"abstract":[{"text":"Creates a new file and returns a stream for reading and","type":"text"},{"type":"text","text":" "},{"text":"writing to it. The file must not already exist.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"createReadwrite","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags","text":"FileCreateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileCreateFlagsV"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:3GIO15FileIOStreamRefV","text":"FileIOStreamRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"By default files created are generally readable by everyone,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but if you pass "},{"code":"private","type":"codeVoice"},{"text":" in ","type":"text"},{"code":"flags","type":"codeVoice"},{"text":" the file","type":"text"},{"type":"text","text":" "},{"text":"will be made readable only to the current user, to the level","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that is supported on the target filesystem."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled"},{"type":"text","text":" "},{"type":"text","text":"by triggering the cancellable object from another thread. If the"},{"text":" ","type":"text"},{"type":"text","text":"operation was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"type":"text","text":"returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If a file or directory with this name already exists, the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"exists"},{"text":" error will be returned. Some file systems don’t","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allow all file names, and may return an "},{"type":"codeVoice","code":"invalidFilename"},{"text":" ","type":"text"},{"type":"text","text":"error, and if the name is too long, "},{"code":"filenameTooLong","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"will be returned. Other errors are possible too, and depend on what"},{"text":" ","type":"text"},{"type":"text","text":"kind of filesystem the file is on."}]},{"inlineContent":[{"type":"text","text":"Note that in many non-local file cases read and write streams are"},{"type":"text","text":" "},{"text":"not supported, so make sure you really need to do read and write","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"streaming, rather than just opening for reading or writing."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileref\/createreadwrite(flags:cancellable:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileRef","doc:\/\/GIO\/documentation\/GIO\/FileRef\/FileProtocol-Implementations"]]},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"createReadwrite","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileIOStreamRefV","text":"FileIOStreamRef"},{"kind":"text","text":"!"}],"roleHeading":"Instance Method","modules":[{"name":"GIO"}],"extendedModule":"GIO","title":"createReadwrite(flags:cancellable:)","externalID":"s:3GIO12FileProtocolPAAE15createReadwrite5flags11cancellableAA0B11IOStreamRefVSgAA0B11CreateFlagsV_AA011CancellableI0VSgtKF::SYNTHESIZED::s:3GIO7FileRefV","role":"symbol","symbolKind":"method"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileRef\/createReadwrite(flags:cancellable:)"},"kind":"symbol","references":{"doc://GIO/documentation/GIO/FileRef/createReadwrite(flags:cancellable:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileRef\/createReadwrite(flags:cancellable:)","url":"\/documentation\/gio\/fileref\/createreadwrite(flags:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"createReadwrite"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileCreateFlags","preciseIdentifier":"s:3GIO15FileCreateFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:3GIO15FileIOStreamRefV","text":"FileIOStreamRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Creates a new file and returns a stream for reading and"},{"type":"text","text":" "},{"text":"writing to it. The file must not already exist.","type":"text"}],"title":"createReadwrite(flags:cancellable:)","type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/FileRef/FileProtocol-Implementations":{"title":"FileProtocol Implementations","type":"topic","abstract":[],"kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileRef\/FileProtocol-Implementations","url":"\/documentation\/gio\/fileref\/fileprotocol-implementations"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileCreateFlags":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags","navigatorTitle":[{"text":"FileCreateFlags","kind":"identifier"}],"abstract":[{"text":"Flags used when an operation may create a file.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileCreateFlags"}],"url":"\/documentation\/gio\/filecreateflags","type":"topic","kind":"symbol","title":"FileCreateFlags"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/FileIOStreamRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef","title":"FileIOStreamRef","url":"\/documentation\/gio\/fileiostreamref","abstract":[{"type":"codeVoice","code":"GFileIOStream"},{"text":" provides I\/O streams that both read and write to the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file handle."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileIOStreamRef"}],"kind":"symbol","navigatorTitle":[{"text":"FileIOStreamRef","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/FileRef":{"navigatorTitle":[{"kind":"identifier","text":"FileRef"}],"title":"FileRef","abstract":[{"code":"GFile","type":"codeVoice"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"code":"GFile","type":"codeVoice"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"text":"that do no I\/O upon creation. It is necessary to understand that","type":"text"},{"text":" ","type":"text"},{"code":"GFile","type":"codeVoice"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"type":"text","text":" "},{"text":"file. All file content I\/O is implemented as streaming operations","type":"text"},{"text":" ","type":"text"},{"text":"(see [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream"},{"text":"] and [class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"FileRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileRef","url":"\/documentation\/gio\/fileref"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]}}}