{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileRef\/appendTo(flags:cancellable:)"},"abstract":[{"text":"Gets an output stream for appending data to the file.","type":"text"},{"text":" ","type":"text"},{"text":"If the file doesn’t already exist it is created.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileref\/appendto(flags:cancellable:)"]}],"metadata":{"externalID":"s:3GIO12FileProtocolPAAE8appendTo5flags11cancellableAA0B15OutputStreamRefVSgAA0B11CreateFlagsV_AA011CancellableJ0VSgtKF::SYNTHESIZED::s:3GIO7FileRefV","roleHeading":"Instance Method","role":"symbol","title":"appendTo(flags:cancellable:)","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"appendTo"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO19FileOutputStreamRefV","text":"FileOutputStreamRef"},{"kind":"text","text":"!"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileRef","doc:\/\/GIO\/documentation\/GIO\/FileRef\/FileProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"appendTo","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"extern