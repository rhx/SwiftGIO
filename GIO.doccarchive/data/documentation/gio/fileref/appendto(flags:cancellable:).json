xt":" "},{"text":"that do no I\/O upon creation. It is necessary to understand that","type":"text"},{"text":" ","type":"text"},{"code":"GFile","type":"codeVoice"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"type":"text","text":" "},{"text":"file. All file content I\/O is implemented as streaming operations","type":"text"},{"text":" ","type":"text"},{"text":"(see [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream"},{"text":"] and [class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"FileRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileRef","url":"\/documentation\/gio\/fileref"},"doc://GIO/documentation/GIO/FileOutputStreamRef":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileOutputStreamRef"}],"url":"\/documentation\/gio\/fileoutputstreamref","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileOutputStreamRef"}],"title":"FileOutputStreamRef","kind":"symbol","abstract":[{"type":"codeVoice","code":"GFileOutputStream"},{"text":" provides output streams that write their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"content to a file."}]},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text