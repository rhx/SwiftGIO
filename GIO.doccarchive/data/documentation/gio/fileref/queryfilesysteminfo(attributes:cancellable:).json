pe":"codeVoice","code":"attributes"},{"type":"text","text":" should be a comma-separated list of"},{"text":" ","type":"text"},{"type":"text","text":"attributes or attribute wildcards. The wildcard “*” means all"},{"type":"text","text":" "},{"type":"text","text":"attributes, and a wildcard like “filesystem"},{"code":"*\" means all attributes in the filesystem namespace. The standard namespace for filesystem attributes is \"filesystem\". Common attributes of interest are ","type":"codeVoice"},{"text":"fileAttributeFilesystemSize","type":"text"},{"type":"codeVoice","code":"(the total size of the filesystem in bytes),"},{"type":"text","text":"fileAttributeFilesystemFree"},{"type":"codeVoice","code":"(number of bytes available), and"},{"type":"text","text":"fileAttributeFilesystemType`` (type of the filesystem)."}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled","type":"text"},{"type":"text","text":" "},{"text":"by triggering the cancellable object from another thread. If the","type":"text"},{"type":"text","text":" "},{"text":"operation was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be","type":"text"},{"text":" ","type":"text"},{"text":"returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the file does not exist, the ","type":"text"},{"type":"codeVoice","code":"notFound"},{"type":"text","text":" error will"},{"type":"text","text":" "},{"type":"text","text":"be returned. Other errors are possible too, and depend on what"},{"type":"text","text":" "},{"text":"kind of filesystem the file is on.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileref\/queryfilesysteminfo(attributes:cancellable:)"]}],"kind":"symbol","sections":[],"abstract":[{"text":"Similar to ","type":"t