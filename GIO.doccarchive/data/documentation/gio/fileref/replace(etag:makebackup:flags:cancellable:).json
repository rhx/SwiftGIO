{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileRef","doc:\/\/GIO\/documentation\/GIO\/FileRef\/FileProtocol-Implementations"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileref\/replace(etag:makebackup:flags:cancellable:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"replace","kind":"identifier"},{"text":"(","kind":"text"},{"text":"etag","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"kind":"text","text":">? = nil, "},{"kind":"externalParam","text":"makeBackup"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"FileOutputStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19FileOutputStreamRefV"},{"kind":"text","text":"!"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will try to replace the file in the safest way possible so"},{"text":" ","type":"text"},{"text":"that any errors during the writing will not affect an already","type":"text"},{"type":"text","text":" "},{"text":"existing copy of the file. For instance, for local files it","type":"text"},{"text":" ","type":"text"},{"text":"may write to a temporary file and then atomically rename over","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the destination when the stream is closed."}]},{"type":"paragraph","inlineContent":[{"text":"By default files created are generally readable by everyone,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but if you pass "},{"type":"codeVoice","code":"private"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"flags"},{"text":" the file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be made readable only to the current user, to the level that"},{"text":" ","type":"text"},{"text":"is supported on the target filesystem.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled"},{"text":" ","type":"text"},{"type":"text","text":"by triggering the cancellable object from another thread. If the"},{"text":" ","type":"text"},{"type":"text","text":"operation was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"type":"text","text":"returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you pass in a non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" ","type":"text"},{"type":"codeVoice","code":"etag"},{"text":" value and ","type":"text"},{"type":"codeVoice","code":"file"},{"text":" already exists, then","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this value is compared to the current entity tag of the file, and if"},{"text":" ","type":"text"},{"text":"they differ an ","type":"text"},{"code":"wrongEtag","type":"codeVoice"},{"text":" error is returned. This","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"generally means that the file has been changed since you last read"},{"text":" ","type":"text"},{"text":"it. You can get the new etag from ","type":"text"},{"type":"codeVoice","code":"g_file_output_stream_get_etag()"},{"text":" ","type":"text"},{"text":"after you’ve finished writing and closed the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStream","isActive":true,"type":"reference"},{"type":"text","text":". When"},{"text":" ","type":"text"},{"text":"you load a new file you can use ","type":"text"},{"code":"g_file_input_stream_query_info()","type":"codeVoice"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"text":"get the etag of the file.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"makeBackup"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":", this function will attempt to make a","type":"text"},{"text":" ","type":"text"},{"text":"backup of the current file before overwriting it. If this fails","type":"text"},{"type":"text","text":" "},{"text":"a ","type":"text"},{"type":"codeVoice","code":"cantCreateBackup"},{"text":" error will be returned. If you","type":"text"},{"type":"text","text":" "},{"text":"want to replace anyway, try again with ","type":"text"},{"code":"makeBackup","type":"codeVoice"},{"type":"text","text":" set to "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the file is a directory the "},{"type":"codeVoice","code":"isDirectory"},{"text":" error will","type":"text"},{"type":"text","text":" "},{"text":"be returned, and if the file is some other form of non-regular file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then a "},{"type":"codeVoice","code":"notRegularFile"},{"type":"text","text":" error will be returned. Some"},{"type":"text","text":" "},{"type":"text","text":"file systems don’t allow all file names, and may return an"},{"text":" ","type":"text"},{"type":"codeVoice","code":"invalidFilename"},{"text":" error, and if the name is to long","type":"text"},{"type":"text","text":" "},{"code":"filenameTooLong","type":"codeVoice"},{"type":"text","text":" will be returned. Other errors are"},{"text":" ","type":"text"},{"type":"text","text":"possible too, and depend on what kind of filesystem the file is on."}]}]}],"abstract":[{"type":"text","text":"Returns an output stream for overwriting the file, possibly"},{"type":"text","text":" "},{"type":"text","text":"creating a backup copy of the file first. If the file doesn’t exist,"},{"text":" ","type":"text"},{"type":"text","text":"it will be created."}],"metadata":{"modules":[{"name":"GIO"}],"symbolKind":"method","externalID":"s:3GIO12FileProtocolPAAE7replace4etag10makeBackup5flags11cancellableAA0B15OutputStreamRefVSgSPys4Int8VGSg_SbAA0B11CreateFlagsVAA011CancellableL0VSgtKF::SYNTHESIZED::s:3GIO7FileRefV","roleHeading":"Instance Method","title":"replace(etag:makeBackup:flags:cancellable:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"replace"},{"text":"(","kind":"text"},{"text":"etag","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"text":">?, ","kind":"text"},{"text":"makeBackup","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:3GIO19FileOutputStreamRefV","text":"FileOutputStreamRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"role":"symbol","extendedModule":"GIO"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileRef\/replace(etag:makeBackup:flags:cancellable:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO/FileRef":{"navigatorTitle":[{"kind":"identifier","text":"FileRef"}],"title":"FileRef","abstract":[{"code":"GFile","type":"codeVoice"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"code":"GFile","type":"codeVoice"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"text":"that do no I\/O upon creation. It is necessary to understand that","type":"text"},{"text":" ","type":"text"},{"code":"GFile","type":"codeVoice"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"type":"text","text":" "},{"text":"file. All file content I\/O is implemented as streaming operations","type":"text"},{"text":" ","type":"text"},{"text":"(see [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream"},{"text":"] and [class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"FileRef","kind":"identifier"}],"i