:"text"},{"kind":"externalParam","text":"makeBackup"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO19FileOutputStreamRefV","text":"FileOutputStreamRef"},{"text":"!","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileRef\/replace(etag:makeBackup:flags:cancellable:)","kind":"symbol","url":"\/documentation\/gio\/fileref\/replace(etag:makebackup:flags:cancellable:)","abstract":[{"type":"text","text":"Returns an output stream for overwriting the file, possibly"},{"type":"text","text":" "},{"type":"text","text":"creating a backup copy of the file first. If the file doesn’t exist,"},{"text":" ","type":"text"},{"type":"text","text":"it will be created."}],"role":"symbol"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]}}}