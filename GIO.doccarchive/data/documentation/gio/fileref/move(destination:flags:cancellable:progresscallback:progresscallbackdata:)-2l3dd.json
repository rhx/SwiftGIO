ernalParam","text":"progressCallbackData"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier","text":"CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP"},{"text":", ","kind":"text"},{"text":"FileT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"FileProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO12FileProtocolP"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"If the flag ","type":"text"},{"type":"codeVoice","code":"overwrite"},{"text":" is specified an already","type":"text"},{"type":"text","text":" "},{"text":"existing ","type":"text"},{"code":"destination","type":"codeVoice"},{"type":"text","text":" file is overwritten."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"progressCallback"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be monitored"},{"type":"text","text":" "},{"text":"by setting this to a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProgressCallback","isActive":true},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"codeVoice","code":"progressCallbackData"},{"text":" will be passed to this function. It is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"guaranteed that this callback will be called after all data has been"},{"type":"text","text":" "},{"type":"text","text":"transferred with the total number of bytes copied during the operation."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the "},{"code":"source","type":"codeVoice"},{"type":"text","text":" file does not exist, then the "},{"type":"codeVoice","code":"notFound"},{"type":"text","text":" "},{"text":"error is returned, independent on the status of the ","type":"text"},{"type":"codeVoice","code":"destination"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"overwrite"},{"type":"text","text":" is not specified and the target exists,"},{"type":"text","text":" "},{"type":"text","text":"then the error "},{"type":"codeVoice","code":"exists"},{"text":" is returned.","type":"text"}]},{"inlineContent":[{"text":"If trying to overwrite a file over a directory, the ","type":"text"},{"type":"codeVoice","code":"isDirectory"},{"text":" ","type":"text"},{"type":"text","text":"error is returned. If trying to overwrite a directory with a directory the"},{"text":" ","type":"text"},{"code":"wouldMerge","type":"codeVoice"},{"type":"text","text":" error is returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the source is a directory and the target does not exist, or","type":"text"},{"text":" ","type":"text"},{"code":"overwrite","type":"codeVoice"},{"type":"text","text":" is specified and the target is a file, then"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"wouldRecurse"},{"type":"text","text":" error may be returned (if the native"},{"text":" ","type":"text"},{"type":"text","text":"move operation isn’t available)."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/fileref\/move(destination:flags:cancellable:progresscallback:progresscallbackdata:)-2l3dd"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/FileProgressCallback":{"type":"topic","role":"symbol","title":"FileProgressCallback","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileProgressCallback"}],"navigatorTitle":[{"kind":"identifier","text":"FileProgressCallback"}],"url":"\/documentation\/gio\/fileprogresscallback","abstract":[{"text":"When doing file operations that may take a while, such as moving","type":"text"},{"type":"text","text":" "},{"text":"a file or copying a file, a progress callback is used to pass how","type":"text"},{"type":"text","text":" "},{"type":"text","text":"far along that operation is to the application."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProgressCallback","kind":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileCopyFlags":{"kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileCopyFlags"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileCopyFlags"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCopyFlags","abstract":[{"type":"text","text":"Flags used when copying or moving files."}],"url":"\/documentation\/gio\/filecopyflags","role":"symbol","title":"F