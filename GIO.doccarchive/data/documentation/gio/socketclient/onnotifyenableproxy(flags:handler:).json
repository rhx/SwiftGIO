d. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::enable-proxy","type":"codeVoice"},{"text":" signal","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"references":{"doc://GIO/documentation/GIO/SocketClient/SocketClientProtocol-Implementations":{"type":"topic","role":"collectionGroup","url":"\/documentation\/gio\/socketclient\/socketclientprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient\/SocketClientProtocol-Implementations","abstract":[],"title":"SocketClientProtocol Implementations","kind":"article"},"#class@GObject.ParamSpec#parameter-names":{"url":"#class@GObject.ParamSpec#parameter-names","title":"canonical parameter names","type":"link","titleInlineContent":[{"text":"canonical parameter names","type":"text"}],"identifier":"#class@GObject.ParamSpec#parameter-names"},"doc://GIO/documentation/GIO/SocketClientRef":{"title":"SocketClientRef","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClientRef"}],"navigatorTitle":[{"kind":"identifier","text":"SocketClientRef"}],"url":"\/documentation\/gio\/socketclientref","type":"topic","abstract":[{"code":"GSocketClient","type":"codeVoice"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientRef","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fr