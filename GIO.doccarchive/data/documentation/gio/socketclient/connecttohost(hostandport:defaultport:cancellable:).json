colon.  Ports may be given as decimal numbers or symbolic names (in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which case an \/etc\/services lookup is performed)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If no port override is given in "},{"type":"codeVoice","code":"hostAndPort"},{"type":"text","text":" then "},{"type":"codeVoice","code":"defaultPort"},{"text":" will be","type":"text"},{"text":" ","type":"text"},{"text":"used as the port number to connect to.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In general, "},{"code":"hostAndPort","type":"codeVoice"},{"text":" is expected to be provided by the user (allowing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"them to give the hostname, and a port override if necessary) and"},{"type":"text","text":" "},{"type":"codeVoice","code":"defaultPort"},{"type":"text","text":" is expected to be provided by the application."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the case that an IP address is given, a single connection"},{"type":"text","text":" "},{"type":"text","text":"attempt is made.  In the case that a name is given, multiple"},{"text":" ","type":"text"},{"text":"connection attempts may be made, in turn and according to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"number of address records in DNS, until a connection succeeds."}]},{"type":"paragraph","inlineContent":[{"text":"Upon a successful connection, a new ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference","isActive":true},{"type":"text","text":" is constructed"},{"text":" ","type":"text"},{"type":"text","text":"and returned.  The caller owns this new object and must drop their"},{"type":"text","text":" "},{"text":"reference to it when finished with it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In the event of any failure (DNS error, service not found, no hosts","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"connectable) "},{"code":"nil","type":"codeVoice"},{"text":" is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" (if non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":") is set"},{"type":"text","text":" "},{"text":"accordingly.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketclient\/connecttohost(hostandport:defaultport:cancellable:)"]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/SocketConnectionRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef","type":"topic","url":"\/documentation\/gio\/socketconnectionref","kind":"symbol","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"text":" is a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","type":"reference","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be created either by [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"type":"text","text":"or by [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnectionRef","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketConnectionRef"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SocketConnectionRef"}]},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifie