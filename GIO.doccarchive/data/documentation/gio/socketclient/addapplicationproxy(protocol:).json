{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketClient\/addApplicationProxy(protocol:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","externalID":"s:3GIO20SocketClientProtocolPAAE19addApplicationProxy8protocolySPys4Int8VGSg_tF::SYNTHESIZED::s:3GIO12SocketClientC","title":"addApplicationProxy(protocol:)","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addApplicationProxy","kind":"identifier"},{"text":"(","kind":"text"},{"text":"protocol","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">!)"}],"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","symbolKind":"method"},"sections":[],"abstract":[{"text":"Enable proxy protocols to be handled by the application. When the","type":"text"},{"type":"text","text":" "},{"text":"indicated proxy protocol is returned by the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyResolver","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":" will consider this protocol as supported but will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not try to find a "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Proxy","isActive":true},{"text":" instance to handle handshaking. The","type":"text"},{"type":"text","text":" "},{"text":"application must check for this case by calling","type":"text"},{"type":"text","text":" "},{"code":"g_socket_connection_get_remote_address()","type":"codeVoice"},{"text":" on the returned","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true},{"text":", and seeing if it’s a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyAddress"},{"type":"text","text":" of the"},{"type":"text","text":" "},{"type":"text","text":"appropriate type, to determine whether or not it needs to handle"},{"type":"text","text":" "},{"type":"text","text":"the proxy handshaking itself."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketclient\/addapplicationproxy(protocol:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketClient","doc:\/\/GIO\/documentation\/GIO\/SocketClient\/SocketClientProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addApplicationProxy","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"protocol"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!)","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This should be used for proxy protocols that are dialects of"},{"type":"text","text":" "},{"text":"another protocol such as HTTP proxy. It also allows cohabitation of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"proxy protocols that are reused between protocols. A good example"},{"text":" ","type":"text"},{"text":"is HTTP. It can be used to proxy HTTP, FTP and Gopher and can also","type":"text"},{"type":"text","text":" "},{"text":"be use as generic socket proxy through the HTTP CONNECT method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When the proxy is detected as being an application proxy, TLS handshake","type":"text"},{"text":" ","type":"text"},{"text":"will be skipped. This is required to let the application do the proxy","type":"text"},{"text":" ","type":"text"},{"text":"specific handshake.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/InetSocketAddress":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InetSocketAddress"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress","abstract":[{"text":"An IPv4 or IPv6 socket address. That is, the combination of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddress","isActive":true,"type":"reference"},{"type":"text","text":"] and a port number."}],"url":"\/documentation\/gio\/inetsocketaddress","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"InetSocketAddress","kind":"identifier"}],"type":"topic","title":"InetSocketAddress"},"doc://GIO/documentation/GIO/SocketClient/SocketClientProtocol-Implementations":{"type":"topic","role":"collectionGroup","url":"\/documentation\/gio\/socketclient\/socketclientprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient\/SocketClientProtocol-Implementations","abstract":[],"title":"SocketClientProtocol Implementations","kind":"article"},"doc://GIO/documentation/GIO/SocketClient/addApplicationProxy(protocol:)":{"role":"symbol","abstract":[{"type":"text","text":"Enable proxy protocols to be handled by the application. When the"},{"type":"text","text":" "},{"text":"indicated proxy protocol is returned by the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyResolver"},{"text":",","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"type":"text","text":" will consider this protocol as supported but will"},{"text":" ","type":"text"},{"type":"text","text":"not try to find a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Proxy","isActive":true,"type":"reference"},{"text":" instance to handle handshaking. The","type":"text"},{"type":"text","text":" "},{"text":"application must check for this case by calling","type":"text"},{"text":" ","type":"text"},{"code":"g_socket_connection_get_remote_address()","type":"codeVoice"},{"type":"text","text":" on the returned"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true,"type":"reference"},{"text":", and seeing if it’s a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyAddress","isActive":true},{"text":" of the","type":"text"},{"type":"text","text":" "},{"text":"appropriate type, to determine whether or not it needs to handle","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the proxy handshaking itself."}],"title":"addApplicationProxy(protocol:)","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient\/addApplicationProxy(protocol:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addApplicationProxy"},{"text":"(","kind":"text"},{"text":"protocol","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!)","kind":"text"}],"url":"\/documentation\/gio\/socketclient\/addapplicationproxy(protocol:)","type":"topic"},"doc://GIO/documentation/GIO/ProxyResolver":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyResolver","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"ProxyResolver","kind":"identifier"}],"title":"ProxyResolver","url":"\/documentation\/gio\/proxyresolver","type":"topic","abstract":[{"code":"GProxyResolver","type":"codeVoice"},{"text":" provides synchronous and asynchronous network proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resolution. "},{"type":"codeVoice","code":"GProxyResolver"},{"type":"text","text":" is used within [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":"] through","type":"text"},{"type":"text","text":" "},{"text":"the method [method","type":"text"},{"code":"Gio.SocketConnectable.proxy_enumerate","type":"codeVoice"},{"type":"text","text":"]."}],"navigatorTitle":[{"kind":"identifier","text":"ProxyResolver"}],"role":"symbol"},"doc://GIO/documentation/GIO/ProxyAddress":{"type":"topic","title":"ProxyAddress","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProxyAddress","kind":"identifier"}],"abstract":[{"text":"A [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress"},{"text":"] representing a connection via a proxy server.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"ProxyAddress"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyAddress","url":"\/documentation\/gio\/proxyaddress","role":"symbol"},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","url":"\/documentation\/gio\/socketconnection","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"type":"text","text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/SocketListener":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"topic","url":"\/documentation\/gio\/socketlistener","kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GSocketListener","type":"codeVoice"},{"text":" is an object that keeps track of a set","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of server sockets and helps you accept sockets from any of the"},{"text":" ","type":"text"},{"type":"text","text":"socket, either sync or async."}],"title":"SocketListener","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketListener"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketListener"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Proxy":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Proxy","url":"\/documentation\/gio\/proxy","kind":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Proxy"}],"title":"Proxy","navigatorTitle":[{"kind":"identifier","text":"Proxy"}],"role":"symbol","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GProxy"},{"type":"text","text":" handles connecting to a remote host via a given type of"},{"text":" ","type":"text"},{"text":"proxy server. It is implemented by the ","type":"text"},{"code":"gio-proxy","type":"codeVoice"},{"type":"text","text":" extension point."},{"text":" ","type":"text"},{"type":"text","text":"The extensions are named after their proxy protocol name. As an"},{"text":" ","type":"text"},{"type":"text","text":"example, a SOCKS5 proxy implementation can be retrieved with the"},{"type":"text","text":" "},{"type":"text","text":"name "},{"code":"socks5","type":"codeVoice"},{"type":"text","text":" using the function"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.IOExtensionPoint.get_extension_by_name"},{"text":"].","type":"text"}]},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClient"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","abstract":[{"type":"codeVoice","code":"GSocketClient"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"title":"SocketClient","role":"symbol","url":"\/documentation\/gio\/socketclient","navigatorTitle":[{"kind":"identifier","text":"SocketClient"}]},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"}}}