{"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/documentation\/GIO\/ResourceProtocol"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"abstract":[{"text":"Applications and libraries often contain binary or textual data that is","type":"text"},{"type":"text","text":" "},{"text":"really part of the application, rather than user data. For instance","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Builder.html"},{"type":"text","text":" "},{"type":"codeVoice","code":".ui"},{"text":" files,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"splashscreen images, [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu","isActive":true},{"type":"text","text":"] markup XML, CSS files, icons, etc."},{"text":" ","type":"text"},{"text":"These are often shipped as files in ","type":"text"},{"type":"codeVoice","code":"$datadir\/appname"},{"type":"text","text":", or manually"},{"text":" ","type":"text"},{"type":"text","text":"included as literal strings in the code."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/gio\/resourceref"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"ResourceRef","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"The "},{"code":"GResource","type":"codeVoice"},{"type":"text","text":" API and the"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"glib-compile-resources.html"},{"type":"text","text":" program provide a"},{"type":"text","text":" "},{"type":"text","text":"convenient and efficient alternative to this which has some nice properties."},{"type":"text","text":" "},{"type":"text","text":"You maintain the files as normal files, so it’s easy to edit them, but during"},{"text":" ","type":"text"},{"text":"the build the files are combined into a binary bundle that is linked into the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"executable. This means that loading the resource files are efficient (as they"},{"text":" ","type":"text"},{"text":"are already in memory, shared with other instances) and simple (no need to","type":"text"},{"text":" ","type":"text"},{"text":"check for things like I\/O errors or locate the files in the filesystem). It","type":"text"},{"type":"text","text":" "},{"text":"also makes it easier to create relocatable applications.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Resource files can also be marked as compressed. Such files will be included","type":"text"},{"text":" ","type":"text"},{"text":"in the resource bundle in a compressed form, but will be automatically","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"uncompressed when the resource is used. This is very useful e.g. for larger"},{"type":"text","text":" "},{"text":"text files that are parsed once (or rarely) and then thrown away.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Resource files can also be marked to be preprocessed, by setting the value of the"},{"text":" ","type":"text"},{"code":"preprocess","type":"codeVoice"},{"type":"text","text":" attribute to a comma-separated list of preprocessing options."},{"type":"text","text":" "},{"type":"text","text":"The only options currently supported are:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"xml-stripblanks","type":"codeVoice"},{"type":"text","text":" which will use the "},{"type":"reference","isActive":true,"identifier":"man:xmllint(1)"},{"text":" command","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to strip ignorable whitespace from the XML file. For this to work,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"XMLLINT"},{"type":"text","text":" environment variable must be set to the full path to"},{"type":"text","text":" "},{"text":"the xmllint executable, or xmllint must be in the ","type":"text"},{"code":"PATH","type":"codeVoice"},{"text":"; otherwise","type":"text"},{"type":"text","text":" "},{"text":"the preprocessing step is skipped.","type":"text"}]}]},{"content":[{"inlineContent":[{"code":"to-pixdata","type":"codeVoice"},{"text":" (deprecated since gdk-pixbuf 2.32) which will use the","type":"text"},{"text":" ","type":"text"},{"code":"gdk-pixbuf-pixdata","type":"codeVoice"},{"text":" command to convert images to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.gtk.org\/gdk-pixbuf\/class.Pixdata.html"},{"type":"text","text":" "},{"type":"text","text":"format, which allows you to create pixbufs directly using the data inside"},{"type":"text","text":" "},{"text":"the resource file, rather than an (uncompressed) copy of it. For this, the","type":"text"},{"type":"text","text":" "},{"code":"gdk-pixbuf-pixdata","type":"codeVoice"},{"text":" program must be in the ","type":"text"},{"type":"codeVoice","code":"PATH"},{"type":"text","text":", or the"},{"text":" ","type":"text"},{"code":"GDK_PIXBUF_PIXDATA","type":"codeVoice"},{"type":"text","text":" environment variable must be set to the full path to"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"gdk-pixbuf-pixdata"},{"text":" executable; otherwise the resource compiler will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"abort. "},{"code":"to-pixdata","type":"codeVoice"},{"text":" has been deprecated since gdk-pixbuf 2.32, as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GResource"},{"type":"text","text":" supports embedding modern image formats just as well. Instead"},{"type":"text","text":" "},{"type":"text","text":"of using it, embed a PNG or SVG file in your "},{"code":"GResource","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"json-stripblanks"},{"type":"text","text":" which will use the"},{"type":"text","text":" "},{"identifier":"man:json-glib-format(1)","isActive":true,"type":"reference"},{"text":" command to strip ignorable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whitespace from the JSON file. For this to work, the "},{"type":"codeVoice","code":"JSON_GLIB_FORMAT"},{"type":"text","text":" "},{"type":"text","text":"environment variable must be set to the full path to the"},{"type":"text","text":" "},{"code":"json-glib-format","type":"codeVoice"},{"type":"text","text":" executable, or it must be in the "},{"code":"PATH","type":"codeVoice"},{"type":"text","text":"; otherwise the"},{"type":"text","text":" "},{"text":"preprocessing step is skipped. In addition, at least version 1.6 of","type":"text"},{"text":" ","type":"text"},{"code":"json-glib-format","type":"codeVoice"},{"type":"text","text":" is required."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Resource files will be exported in the "},{"type":"codeVoice","code":"GResource"},{"text":" namespace using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"combination of the given "},{"code":"prefix","type":"codeVoice"},{"text":" and the filename from the ","type":"text"},{"type":"codeVoice","code":"file"},{"text":" element.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"type":"codeVoice","code":"alias"},{"type":"text","text":" attribute can be used to alter the filename to expose them at a"},{"type":"text","text":" "},{"text":"different location in the resource namespace. Typically, this is used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"include files from a different source directory without exposing the source"},{"text":" ","type":"text"},{"text":"directory in the resource namespace, as in the example below.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Resource bundles are created by the"},{"type":"text","text":" "},{"identifier":"glib-compile-resources.html","overridingTitle":"glib-compile-resources","overridingTitleInlineContent":[{"type":"codeVoice","code":"glib-compile-resources"}],"isActive":true,"type":"reference"},{"text":" program","type":"text"},{"text":" ","type":"text"},{"text":"which takes an XML file that describes the bundle, and a set of files that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the XML references. These are combined into a binary resource bundle."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"An example resource description:"}]},{"type":"codeListing","code":["<?xml version=\"1.0\" encoding=\"UTF-8\"?>","<gresources>","  <gresource prefix=\"\/org\/gtk\/Example\">","    <file>data\/splashscreen.png<\/file>","    <file compressed=\"true\">dialog.ui<\/file>","    <file preprocess=\"xml-stripblanks\">menumarkup.xml<\/file>","    <file alias=\"example.css\">data\/example.css<\/file>","  <\/gresource>","<\/gresources>"],"syntax":"xml"},{"type":"paragraph","inlineContent":[{"text":"This will create a resource bundle with the following files:","type":"text"}]},{"code":["\/org\/gtk\/Example\/data\/splashscreen.png","\/org\/gtk\/Example\/dialog.ui","\/org\/gtk\/Example\/menumarkup.xml","\/org\/gtk\/Example\/example.css"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Note that all resources in the process share the same namespace, so use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Java-style path prefixes (like in the above example) to avoid conflicts."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then use "},{"isActive":true,"identifier":"glib-compile-resources.html","overridingTitle":"glib-compile-resources","overridingTitleInlineContent":[{"type":"codeVoice","code":"glib-compile-resources"}],"type":"reference"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"type":"text","text":"compile the XML to a binary bundle that you can load with"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"Gio.Resource.load","type":"codeVoice"},{"text":"]. However, it’s more common to use the","type":"text"},{"text":" ","type":"text"},{"code":"--generate-source","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"--generate-header"},{"type":"text","text":" arguments to create a source file"},{"type":"text","text":" "},{"type":"text","text":"and header to link directly into your application."},{"type":"text","text":" "},{"type":"text","text":"This will generate "},{"code":"get_resource()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"register_resource()"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"unregister_resource()","type":"codeVoice"},{"text":" functions, prefixed by the ","type":"text"},{"type":"codeVoice","code":"--c-name"},{"type":"text","text":" argument passed"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"reference","isActive":true,"overridingTitle":"glib-compile-resources","identifier":"glib-compile-resources.html","overridingTitleInlineContent":[{"type":"codeVoice","code":"glib-compile-resources"}]},{"type":"text","text":". "},{"code":"get_resource()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"returns the generated ","type":"text"},{"type":"codeVoice","code":"GResource"},{"text":" object. The register and unregister","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"functions register the resource so its files can be accessed using"},{"type":"text","text":" "},{"text":"[func","type":"text"},{"code":"Gio.resources_lookup_data","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once a "},{"code":"GResource","type":"codeVoice"},{"type":"text","text":" has been created and registered all the data in it can be"},{"text":" ","type":"text"},{"type":"text","text":"accessed globally in the process by using API calls like"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"Gio.resources_open_stream","type":"codeVoice"},{"text":"] to stream the data or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"Gio.resources_lookup_data","type":"codeVoice"},{"type":"text","text":"] to get a direct pointer to the data. You can"},{"text":" ","type":"text"},{"type":"text","text":"also use URIs like "},{"type":"codeVoice","code":"resource:\/\/\/org\/gtk\/Example\/data\/splashscreen.png"},{"type":"text","text":" with"},{"type":"text","text":" "},{"text":"[iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"] to access the resource data."}]},{"type":"paragraph","inlineContent":[{"text":"Some higher-level APIs, such as ","type":"text"},{"type":"reference","identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Application.html","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"text":"will automatically load resources from certain well-known paths in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resource namespace as a convenience. See the documentation for those APIs"},{"text":" ","type":"text"},{"type":"text","text":"for details."}]},{"inlineContent":[{"type":"text","text":"There are two forms of the generated source, the default version uses the"},{"type":"text","text":" "},{"type":"text","text":"compiler support for constructor and destructor functions (where available)"},{"text":" ","type":"text"},{"type":"text","text":"to automatically create and register the "},{"code":"GResource","type":"codeVoice"},{"type":"text","text":" on startup or library"},{"type":"text","text":" "},{"text":"load time. If you pass ","type":"text"},{"type":"codeVoice","code":"--manual-register"},{"text":", two functions to","type":"text"},{"type":"text","text":" "},{"text":"register\/unregister the resource are created instead. This requires an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"explicit initialization call in your application\/library, but it works on all"},{"type":"text","text":" "},{"text":"platforms, even on the minor ones where constructors are not supported.","type":"text"},{"text":" ","type":"text"},{"text":"(Constructor support is available for at least Win32, Mac OS and Linux.)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that resource data can point directly into the data segment of e.g. a"},{"type":"text","text":" "},{"text":"library, so if you are unloading libraries during runtime you need to be very","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"careful with keeping around pointers to data from a resource, as this goes"},{"text":" ","type":"text"},{"text":"away when the library is unloaded. However, in practice this is not generally","type":"text"},{"text":" ","type":"text"},{"text":"a problem, since most resource accesses are for your own resources, and","type":"text"},{"text":" ","type":"text"},{"text":"resource data is often used once, during parsing, and then released.","type":"text"}],"type":"paragraph"},{"anchor":"Overlays","text":"Overlays","type":"heading","level":1},{"inlineContent":[{"text":"When debugging a program or testing a change to an installed version, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"often useful to be able to replace resources in the program or library,"},{"type":"text","text":" "},{"type":"text","text":"without recompiling, for debugging or quick hacking and testing purposes."},{"type":"text","text":" "},{"type":"text","text":"Since GLib 2.50, it is possible to use the "},{"code":"G_RESOURCE_OVERLAYS","type":"codeVoice"},{"text":" environment","type":"text"},{"type":"text","text":" "},{"text":"variable to selectively overlay resources with replacements from the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"filesystem.  It is a "},{"code":"G_SEARCHPATH_SEPARATOR","type":"codeVoice"},{"text":"-separated list of substitutions","type":"text"},{"text":" ","type":"text"},{"text":"to perform during resource lookups. It is ignored when running in a setuid","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A substitution has the form"}],"type":"paragraph"},{"syntax":null,"code":["\/org\/gtk\/libgtk=\/home\/desrt\/gtk-overlay"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The part before the ","type":"text"},{"code":"=","type":"codeVoice"},{"text":" is the resource subpath for which the overlay","type":"text"},{"type":"text","text":" "},{"text":"applies.  The part after is a filesystem path which contains files and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"subdirectories as you would like to be loaded as resources with the"},{"text":" ","type":"text"},{"text":"equivalent names.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the example above, if an application tried to load a resource with the"},{"type":"text","text":" "},{"text":"resource path ","type":"text"},{"type":"codeVoice","code":"\/org\/gtk\/libgtk\/ui\/gtkdialog.ui"},{"type":"text","text":" then "},{"type":"codeVoice","code":"GResource"},{"type":"text","text":" would check"},{"type":"text","text":" "},{"type":"text","text":"the filesystem path "},{"type":"codeVoice","code":"\/home\/desrt\/gtk-overlay\/ui\/gtkdialog.ui"},{"text":".  If a file was","type":"text"},{"type":"text","text":" "},{"text":"found there, it would be used instead.  This is an overlay, not an outright","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"replacement, which means that if a file is not found at that path, the"},{"text":" ","type":"text"},{"text":"built-in version will be used instead.  Whiteouts are not currently","type":"text"},{"type":"text","text":" "},{"type":"text","text":"supported."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Substitutions must start with a slash, and must not contain a trailing slash"},{"text":" ","type":"text"},{"text":"before the ","type":"text"},{"code":"=","type":"codeVoice"},{"text":".  The path after the slash should ideally be absolute, but","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this is not strictly required.  It is possible to overlay the location of a"},{"text":" ","type":"text"},{"text":"single resource with an individual file.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ResourceRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GResource"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ResourceProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ResourceRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GResource"},{"type":"text","text":" instance."}]},{"content":[{"inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Resource","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ResourceRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GResource"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(_:)-3fwfh","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(_:)-3qzwk","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(_:)-5r8ok","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(_:)-7f3jg","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(_:)-i185","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(data:)","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/init(opaquePointer:)"],"generated":true,"title":"Initializers","anchor":"Initializers"},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/ptr"]},{"title":"Type Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/load(filename:)","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/newFrom(data:)"],"anchor":"Type-Methods","generated":true},{"anchor":"Default-Implementations","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/PointerWrapper-Implementations","doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/ResourceProtocol-Implementations"],"generated":true,"title":"Default Implementations"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ResourceRef"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"metadata":{"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ResourceRef"}],"title":"ResourceRef","modules":[{"name":"GIO"}],"symbolKind":"struct","role":"symbol","externalID":"s:3GIO11ResourceRefV","navigatorTitle":[{"kind":"identifier","text":"ResourceRef"}]},"references":{"man:json-glib-format(1)":{"identifier":"man:json-glib-format(1)","title":"json-glib-format","type":"link","titleInlineContent":[{"type":"codeVoice","code":"json-glib-format"}],"url":"man:json-glib-format(1)"},"doc://GIO/documentation/GIO/ResourceRef/ptr":{"type":"topic","abstract":[{"type":"text","text":"Untyped pointer to the underlying "},{"type":"codeVoice","code":"GResource"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"For type-safe access, use the generated, typed pointer "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ResourceProtocol\/resource_ptr-718oi","isActive":true,"type":"reference"},{"type":"text","text":" property instead."}],"title":"ptr","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"ptr","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ResourceRef\/ptr","role":"symbol","kind":"symbol","url":"\/documentation\/gio\/resourceref\/ptr"},"doc://GIO/4GLib14PointerWrapperP":{"type":"unresolvable","title":"GLib.PointerWrapper","identifier":"doc:\/\/GIO\/4GLib14PointerWrapperP"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/doc