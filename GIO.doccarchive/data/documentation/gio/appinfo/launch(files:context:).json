eIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"To launch the application without arguments pass a "},{"code":"NULL","type":"codeVoice"},{"text":" ","type":"text"},{"code":"files","type":"codeVoice"},{"text":" list.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that even if the launch is successful the application launched"},{"type":"text","text":" "},{"type":"text","text":"can fail to start if it runs into problems during startup. There is"},{"type":"text","text":" "},{"type":"text","text":"no way to detect this."}],"type":"paragraph"},{"inlineContent":[{"text":"Some URIs can be changed when passed through a GFile (for instance","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unsupported URIs with strange formats like mailto:), so if you have"},{"text":" ","type":"text"},{"type":"text","text":"a textual URI you want to pass in as argument, consider using"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.AppInfo.launch_uris","type":"codeVoice"},{"type":"text","text":"] instead."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The launched application inherits the environment of the launching","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"process, but it can be modified with [method"},{"type":"codeVoice","code":"Gio.AppLaunchContext.setenv"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"and [method"},{"type":"codeVoice","code":"Gio.AppLaunchContext.unsetenv"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On UNIX, this function sets the "},{"type":"codeVoice","code":"GIO_LAUNCHED_DESKTOP_FILE"},{"type":"text","text":" "},{"type":"text","text":"environment variable with the path of the launched desktop file and"},{"type":"text","text":" "},{"type":"codeVoice","code":"GIO_LAUNCHED_DESKTOP_FILE_PID"},{"text":" to the process id of the launched","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process. This can be used to ignore "},{"type":"codeVoice","code":"GIO_LAUNCHED_DESKTOP_FILE"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"should it be inherited by further processes. The "},{"type":"codeVoice","code":"DISPLAY"},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"XDG_ACTIVATION_TOKEN","type":"codeVoice"},{"type":"text","text":" and "},{"code":"DESKTOP_STARTUP_ID","type":"codeVoice"},{"text":" environment","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"variables are also set, based on information provided in "},{"type":"codeVoice","code":"context"},{"type":"text","text":"."}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AppInfo","doc:\/\/GIO\/documentation\/GIO\/AppInfo\/AppInfoProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Launches the application. Passes "},{"type":"codeVoice","code":"files"},{"type":"text","text":" to the launched application"},{"text":" ","type":"text"},{"text":"as arguments, using the optional ","type":"text"},{"code":"context","type":"codeVoice"},{"type":"text","text":" to get information"},{"type":"text","text":" "},{"text":"about the details of the launcher (like what screen it is on).","type":"text"},{"type":"text","text":" "},{"text":"On error, ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" will be set accordingly.","type":"text"}],"references":{"doc://GIO/documentation/GIO/AppInfo/launch(files:context:)":{"url":"\/documentation\/gio\/appinfo\/launch(files:context:)","kind":"symbol","type":"topic","title":"launch(files:context:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfo\/launch(files:context:)","abstract":[{"type":"text","text":