xt":"system that is used to address several logical volumes. In this"},{"type":"text","text":" "},{"text":"situation, a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/VolumeMonitor","isActive":true},{"text":" implementation would create two","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Volume","isActive":true},{"type":"text","text":" objects (for example, one for the camera functionality of"},{"text":" ","type":"text"},{"type":"text","text":"the device and one for a SD card reader on the device) with"},{"text":" ","type":"text"},{"type":"text","text":"activation URIs "},{"code":"gphoto2:\/\/[usb:001,002]\/store1\/","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"and "},{"code":"gphoto2:\/\/[usb:001,002]\/store2\/","type":"codeVoice"},{"type":"text","text":". When the"},{"text":" ","type":"text"},{"type":"text","text":"underlying mount (with root"},{"type":"text","text":" "},{"type":"codeVoice","code":"gphoto2:\/\/[usb:001,002]\/"},{"text":") is mounted, said","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/VolumeMonitor","isActive":true,"type":"reference"},{"type":"text","text":" implementation would create two "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Mount"},{"type":"text","text":" objects"},{"text":" ","type":"text"},{"text":"(each with their root matching the corresponding volume activation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"root) that would shadow the original mount."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The proxy monitor in GVfs 2.26 and later, automatically creates and"},{"text":" ","type":"text"},{"text":"manage shadow mounts (and shadows the underlying mount) if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"activation root on a "},{"type":"reference","id