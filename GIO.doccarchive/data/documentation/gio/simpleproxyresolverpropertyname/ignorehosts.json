{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SimpleProxyResolverPropertyName\/ignoreHosts"},"sections":[],"abstract":[{"text":"A list of hostnames and IP addresses that the resolver should","type":"text"},{"text":" ","type":"text"},{"text":"allow direct connections to.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ignoreHosts","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"Entries can be in one of 4 formats:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"A hostname, such as “example.com”, “.example.com”, or"},{"type":"text","text":" "},{"text":"“*.example.com”, any of which match “example.com” or","type":"text"},{"text":" ","type":"text"},{"text":"any subdomain of it.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An IPv4 or IPv6 address, such as “192.168.1.1”,","type":"text"},{"type":"text","text":" "},{"text":"which matches only that address.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A hostname or IP address followed by a port, such as"},{"type":"text","text":" "},{"type":"text","text":"“example.com:80”, which matches whatever the hostname or IP"},{"type":"text","text":" "},{"type":"text","text":"address would match, but only for URLs with the (explicitly)"},{"type":"text","text":" "},{"type":"text","text":"indicated port. In the case of an IPv6 address, the address"},{"type":"text","text":" "},{"type":"text","text":"part must appear in brackets: “["},{"type":"codeVoice","code":"1"},{"type":"text","text":"]:443”"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An IP address range, given by a base address and prefix length,"},{"text":" ","type":"text"},{"text":"such as “fe80``\/10”, which matches any address in that range.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that when dealing with Unicode hostnames, the matching is"},{"text":" ","type":"text"},{"type":"text","text":"done against the ASCII form of the name."}]},{"inlineContent":[{"type":"text","text":"Also note that hostname exclusions apply only to connections made"},{"type":"text","text":" "},{"text":"to hosts identified by name, and IP address exclusions apply only","type":"text"},{"type":"text","text":" "},{"text":"to connections made to hosts identified by address. That is, if","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example.com has an address of 192.168.1.1, and the :ignore-hosts list"},{"type":"text","text":" "},{"text":"contains only “192.168.1.1”, then a connection to “example.com”","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(eg, via a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkAddress","type":"reference","isActive":true},{"text":") will use the proxy, and a connection to","type":"text"},{"type":"text","text":" "},{"text":"“192.168.1.1” (eg, via a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress"},{"text":") will not.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"These rules match the “ignore-hosts”\/“noproxy” rules most","type":"text"},{"text":" ","type":"text"},{"text":"commonly used by other applications.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/simpleproxyresolverpropertyname\/ignorehosts"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleProxyResolverPropertyName"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":