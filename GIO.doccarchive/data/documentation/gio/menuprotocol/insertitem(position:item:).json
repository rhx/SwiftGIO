{"abstract":[{"text":"Inserts ","type":"text"},{"type":"codeVoice","code":"item"},{"text":" into ","type":"text"},{"type":"codeVoice","code":"menu"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"insertItem","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"MenuItemT"},{"text":">(","kind":"text"},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"text":"item","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"MenuItemT","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"MenuItemT"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol","text":"MenuItemProtocol","preciseIdentifier":"s:3GIO16MenuItemProtocolP"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"The “insertion” is actually done by copying all of the attribute and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"link values of "},{"code":"item","type":"codeVoice"},{"type":"text","text":" and using them to form a new item within "},{"type":"codeVoice","code":"menu"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"As such, "},{"type":"codeVoice","code":"item"},{"type":"text","text":" itself is not really inserted, but rather, a menu item"},{"text":" ","type":"text"},{"text":"that is exactly the same as the one presently described by ","type":"text"},{"code":"item","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This means that ","type":"text"},{"code":"item","type":"codeVoice"},{"type":"text","text":" is essentially useless after the insertion"},{"type":"text","text":" "},{"text":"occurs.  Any changes you make to it are ignored unless it is inserted","type":"text"},{"type":"text","text":" "},{"type":"text","text":"again (at which point its updated values will be copied)."}]},{"inlineContent":[{"text":"You should probably just free ","type":"text"},{"code":"item","type":"codeVoice"},{"text":" once you’re done.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There are many convenience functions to take care of common cases."},{"type":"text","text":" "},{"text":"See ","type":"text"},{"code":"g_menu_insert()","type":"codeVoice"},{"text":", ","type":"text"},{"code":"g_menu_insert_section()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"g_menu_insert_submenu()","type":"codeVoice"},{"text":" as well as “prepend” and “append” variants of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"each of these functions."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menuprotocol\/insertitem(position:item:)"]}],"metadata":{"role":"symbol","symbolKind":"method","title":"insertItem(position:item:)","roleHeading":"Instance Method","externalID":"s:3GIO12MenuProtocolPAAE10insertItem8position4itemySi_qd__tAA0beC0Rd__lF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"insertItem"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuItemT"},{"kind":"text","text":">("},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"item"},{"kind":"text","text":": "},{"text":"MenuItemT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"modules":[{"name":"GIO"}],"extendedModule":"GIO"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuProtocol"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuProtocol\/insertItem(position:item:)","interfaceLanguage":"swift"},"sections":[],"references":{"doc://GIO/documentation/GIO/MenuProtocol":{"abstract":[{"type":"codeVoice","code":"GMenu"},{"type":"text","text":" is a simple implementation of [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel"},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"You populate a ","type":"text"},{"code":"GMenu","type":"codeVoice"},{"type":"text","text":" by adding [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true},{"text":"] instances to it.","type":"text"}],"title":"MenuProtocol","role":"symbol","navigatorTitle":[{"text":"MenuProtocol","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuProtocol","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuProtocol","type":"topic","url":"\/documentation\/gio\/menuprotocol","kind":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/MenuProtocol/insertItem(position:item:)":{"abstract":[{"text":"Inserts ","type":"text"},{"type":"codeVoice","code":"item"},{"type":"text","text":" into "},{"type":"codeVoice","code":"menu"},{"type":"text","text":"."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuProtocol\/insertItem(position:item:)","url":"\/documentation\/gio\/menuprotocol\/insertitem(position:item:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"insertItem"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuItemT"},{"text":">(","kind":"text"},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"}