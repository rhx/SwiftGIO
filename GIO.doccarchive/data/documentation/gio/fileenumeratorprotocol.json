":"text"},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"text":" ","type":"text"},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorRef"},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"codeVoice","code":"GFileEnumerator"},{"text":" allows you to operate on a set of [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/File","type":"reference"},{"type":"text","text":"] objects,"},{"type":"text","text":" "},{"text":"returning a [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true},{"type":"text","text":"] structure for each file enumerated (e.g."},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.File.enumerate_children"},{"type":"text","text":"] will return a "},{"type":"codeVoice","code":"GFileEnumerator"},{"type":"text","text":" for each"},{"type":"text","text":" "},{"type":"text","text":"of the children within a directory)."}],"variants":[{"paths":["\/documentation\/gio\/fileenumeratorprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"roleHeading":"Protocol","navigatorTitle":[{"text":"FileEnumeratorProtocol","kind":"identifier"}],"title":"FileEnumeratorProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileEnumeratorProtocol"}],