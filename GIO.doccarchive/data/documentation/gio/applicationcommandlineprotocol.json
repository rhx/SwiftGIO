{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"kind":"symbol","topicSections":[{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/application_command_line_ptr-40oge","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/cwd","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/environ","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/exitStatus","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/isRemote","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/optionsDict","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/platformData","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/stdin"],"title":"Instance Properties","anchor":"Instance-Properties"},{"title":"Instance Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/bind(property:to:_:flags:transformFrom:transformTo:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/createFileFor(arg:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/done()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/get(property:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getArguments(argc:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getCwd()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getEnviron()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getExitStatus()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getIsRemote()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getOptionsDict()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getPlatformData()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getStdin()","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getenv(name:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/printLiteral(message:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/printerrLiteral(message:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/set(exitStatus:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/set(property:value:)"],"generated":true,"anchor":"Instance-Methods"}],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"title":"Inherits From"},{"type":"conformingTypes","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef"],"kind":"relationships","title":"Conforming Types"}],"abstract":[{"code":"GApplicationCommandLine","type":"codeVoice"},{"type":"text","text":" represents a command-line invocation of"},{"type":"text","text":" "},{"type":"text","text":"an application."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"ApplicationCommandLineProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B8ProtocolP","text":"ObjectProtocol"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is created by [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","type":"reference"},{"text":"] and emitted","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] signal and virtual function."}]},{"type":"paragraph","inlineContent":[{"text":"The class contains the list of arguments that the program was invoked","type":"text"},{"type":"text","text":" "},{"text":"with. It is also possible to query if the commandline invocation was","type":"text"},{"text":" ","type":"text"},{"text":"local (ie: the current process is running in direct response to the","type":"text"},{"type":"text","text":" "},{"text":"invocation) or remote (ie: some other process forwarded the","type":"text"},{"type":"text","text":" "},{"text":"commandline to this process).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GApplicationCommandLine"},{"text":" object can provide the ","type":"text"},{"code":"argc","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"argv"},{"text":" ","type":"text"},{"text":"parameters for use with the [struct[OptionContext](\/\/documentation\/glib\/optioncontext] command-line parsing API,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with the [method"},{"code":"Gio.ApplicationCommandLine.get_arguments","type":"codeVoice"},{"type":"text","text":"] function. See"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"for an example."}]},{"type":"paragraph","inlineContent":[{"text":"The exit status of the originally-invoked process may be set and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages can be printed to stdout or stderr of that process."}]},{"inlineContent":[{"text":"For remote invocation, the originally-invoked process exits when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.ApplicationCommandLine.done"},{"type":"text","text":"] method is called. This method is"},{"type":"text","text":" "},{"text":"also automatically called when the object is disposed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The main use for ","type":"text"},{"type":"codeVoice","code":"GApplicationCommandLine"},{"text":" (and the","type":"text"},{"type":"text","text":" "},{"text":"[signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] signal) is ‘Emacs server’ like use cases:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You can set the "},{"code":"EDITOR","type":"codeVoice"},{"type":"text","text":" environment variable to have e.g. git use"},{"text":" ","type":"text"},{"type":"text","text":"your favourite editor to edit commit messages, and if you already"},{"type":"text","text":" "},{"type":"text","text":"have an instance of the editor running, the editing will happen"},{"text":" ","type":"text"},{"type":"text","text":"in the running instance, instead of opening a new one. An important"},{"type":"text","text":" "},{"type":"text","text":"aspect of this use case is that the process that gets started by git"},{"type":"text","text":" "},{"type":"text","text":"does not return until the editing is done."}],"type":"paragraph"},{"inlineContent":[{"text":"Normally, the commandline is completely handled in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler. The launching instance exits"},{"type":"text","text":" "},{"type":"text","text":"once the signal handler in the primary instance has returned, and"},{"text":" ","type":"text"},{"type":"text","text":"the return value of the signal handler becomes the exit status"},{"text":" ","type":"text"},{"type":"text","text":"of the launching instance."}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["static int","command_line (GApplication            *application,","              GApplicationCommandLine *cmdline)","{","  gchar **argv;","  gint argc;","  gint i;","","  argv = g_application_command_line_get_arguments (cmdline, &argc);","","  g_application_command_line_print (cmdline,","                                    \"This text is written back\\n\"","                                    \"to stdout of the caller\\n\");","","  for (i = 0; i < argc; i++)","    g_print (\"argument `d:` `s`\\n\", i, argv[i]);","","  g_strfreev (argv);","","  return 0;","}"]},{"type":"paragraph","inlineContent":[{"text":"The complete example can be found here:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline.c","isActive":true,"type":"reference"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In more complicated cases, the handling of the commandline can be"},{"text":" ","type":"text"},{"type":"text","text":"split between the launcher and the primary instance."}]},{"type":"codeListing","syntax":"c","code":["static gboolean"," test_local_cmdline (GApplication   *application,","                     gchar        ***arguments,","                     gint           *exit_status)","{","  gint i, j;","  gchar **argv;","","  argv = *arguments;","","  if (argv[0] == NULL)","    {","      *exit_status = 0;","      return FALSE;","    }","","  i = 1;","  while (argv[i])","    {","      if (g_str_has_prefix (argv[i], \"--local-\"))","        {","          g_print (\"handling argument `s` locally\\n\", argv[i]);","          g_free (argv[i]);","          for (j = i; argv[j]; j++)","            argv[j] = argv[j + 1];","        }","      else","        {","          g_print (\"not handling argument `s` locally\\n\", argv[i]);","          i++;","        }","    }","","  *exit_status = 0;","","  return FALSE;","}","","static void","test_application_class_init (TestApplicationClass *class)","{","  G_APPLICATION_CLASS (class)->local_command_line = test_local_cmdline;","","  ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example of split commandline handling, options that start"},{"type":"text","text":" "},{"type":"text","text":"with "},{"code":"--local-","type":"codeVoice"},{"type":"text","text":" are handled locally, all other options are passed"},{"text":" ","type":"text"},{"type":"text","text":"to the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler which runs in the primary"},{"type":"text","text":" "},{"type":"text","text":"instance."}]},{"type":"paragraph","inlineContent":[{"text":"The complete example can be found here:","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c","isActive":true,"type":"reference"}]},{"inlineContent":[{"type":"text","text":"If handling the commandline requires a lot of work, it may be better to defer it."}],"type":"paragraph"},{"type":"codeListing","code":["static gboolean","my_cmdline_handler (gpointer data)","{","  GApplicationCommandLine *cmdline = data;","","  \/\/ do the heavy lifting in an idle","","  g_application_command_line_set_exit_status (cmdline, 0);","  g_object_unref (cmdline); \/\/ this releases the application","","  return G_SOURCE_REMOVE;","}","","static int","command_line (GApplication            *application,","              GApplicationCommandLine *cmdline)","{","  \/\/ keep the application running until we are done with this commandline","  g_application_hold (application);","","  g_object_set_data_full (G_OBJECT (cmdline),","                          \"application\", application,","                          (GDestroyNotify)g_application_release);","","  g_object_ref (cmdline);","  g_idle_add (my_cmdline_handler, cmdline);","","  return 0;","}"],"syntax":"c"},{"inlineContent":[{"text":"In this example the commandline is not completely handled before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler returns. Instead, we keep"},{"type":"text","text":" "},{"type":"text","text":"a reference to the "},{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" object and handle it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"later (in this example, in an idle). Note that it is necessary to"},{"text":" ","type":"text"},{"type":"text","text":"hold the application until you are done with the commandline."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The complete example can be found here:"},{"type":"text","text":" "},{"overridingTitle":"gapplication-example-cmdline3.c","overridingTitleInlineContent":[{"type":"text","text":"gapplication-example-cmdline3.c"}],"type":"reference","isActive":true,"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c"}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"code":"GApplicationCommandLine","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"text":" ","type":"text"},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","isActive":true},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef","isActive":true,"type":"reference"},{"text":" as a lighweight, ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/applicationcommandlineprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"ApplicationCommandLineProtocol","role":"symbol","symbolKind":"protocol","roleHeading":"Protocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ApplicationCommandLineProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"ApplicationCommandLineProtocol"}],"externalID":"s:3GIO30ApplicationCommandLineProtocolP","modules":[{"name":"GIO"}]},"sections":[],"references":{"doc://GIO/documentation/GIO/ApplicationCommandLineProtocol/getenv(name:)":{"abstract":[{"type":"text","text":"Gets the value of a particular environment variable of the command"},{"type":"text","text":" "},{"text":"line invocation, as would be returned by ","type":"text"},{"type":"codeVoice","code":"g_getenv()"},{"type":"text","text":".  The strings may"},{"type":"text","text":" "},{"type":"text","text":"contain non-utf8 data."}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getenv","kind":"identifier"},{"text":"(","kind":"text"},{"text":"name","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"!"}],"url":"\/documentation\/gio\/applicationcommandlineprotocol\/getenv(name:)","title":"getenv(name:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getenv(name:)","role":"symbol","kind":"symbol","type":"topic"},"https://gitlab.gnome.org/GNOME/glib/-/blob/HEAD/gio/tests/gapplication-example-cmdline.c":{"titleInlineContent":[{"text":"gapplication-example-cmdline.c","type":"text"}],"type":"link","title":"gapplication-example-cmdline.c","url":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline.c","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline.c"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ApplicationCommandLineProtocol/done()":{"kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"done"},{"text":"()","kind":"text"}],"title":"done()","abstract":[{"text":"Signals that command line processing is completed.","type":"text"}],"url":"\/documentation\/gio\/applicationcommandlineprotocol\/done()","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/done()"},"doc://GIO/documentation/GIO/ApplicationCommandLineProtocol/application_command_line_ptr-40oge":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/application_command_line_ptr-40oge","type":"topic","url":"\/documentation\/gio\/applicationcommandlineprotocol\/application_command_line_ptr-40oge","required":true,"abstract":[{"text":"Typed pointer to the underlying ","type":"text"},{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" instance.","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"application_command_line_ptr","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GApplicationCommandLine","kind":"typeIdentifier"},{"text":">!","kind":"text"}],"kind":"symbol","title":"application_command_line_ptr","role":"symbol","defaultImplementations":1},"doc://GIO/documentation/GIO/ApplicationCommandLineProt