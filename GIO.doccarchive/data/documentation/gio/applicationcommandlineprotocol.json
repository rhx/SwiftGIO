ion\/GIO\/ApplicationCommandLineProtocol\/set(property:value:)"},"doc://GIO/documentation/GIO/ApplicationCommandLineProtocol/set(exitStatus:)":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/set(exitStatus:)","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Sets the exit status that will be used when the invoking process"},{"text":" ","type":"text"},{"type":"text","text":"exits."}],"url":"\/documentation\/gio\/applicationcommandlineprotocol\/set(exitstatus:)","title":"set(exitStatus:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"exitStatus","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"doc://GIO/documentation/GIO/ApplicationCommandLineProtocol/getIsRemote()":{"url":"\/documentation\/gio\/applicationcommandlineprotocol\/getisremote()","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol\/getIsRemote()","type":"topic","title":"getIsRemote()","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getIsRemote"},{"kind":"text","text":"() -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Determines if "},{"code":"cmdline","type":"codeVoice"},{"type":"text","text":" represents a remote invocation."}]},"doc://GIO/documentation/GIO/ApplicationCommandLineProtocol/stdin":{"abstract":[{"text":"Gets the stdin of the invoking process.","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"stdin","kind":"identifier"},{"kind":"text","text":": "},{"text":"InputStreamRef","preciseIdentifier":"s:3GIO14InputStreamRefV","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"role":"symbol","kind":"symbol","url":"\/documentat