{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Cancellable","doc:\/\/GIO\/documentation\/GIO\/Cancellable\/CancellableProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/onCancelled(flags:handler:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/cancellable\/oncancelled(flags:handler:)"]}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onCancelled","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"cancelled"},{"text":" signal is emitted","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Can be used by implementations of cancellable operations. If the","type":"text"},{"text":" ","type":"text"},{"text":"operation is cancelled from another thread, the signal will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"emitted in the thread that cancelled the operation, not the"},{"text":" ","type":"text"},{"text":"thread that is running the operation.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that disconnecting from this signal (or any signal) in a"},{"type":"text","text":" "},{"type":"text","text":"multi-threaded program is prone to race conditions. For instance"},{"text":" ","type":"text"},{"type":"text","text":"it is possible that a signal handler may be invoked even after"},{"type":"text","text":" "},{"type":"text","text":"a call to "},{"type":"codeVoice","code":"g_signal_handler_disconnect()"},{"type":"text","text":" for that handler has"},{"type":"text","text":" "},{"text":"already returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"There is also a problem when cancellation happens right before","type":"text"},{"type":"text","text":" "},{"text":"connecting to the signal. If this happens the signal will","type":"text"},{"text":" ","type":"text"},{"text":"unexpectedly not be emitted, and checking before connecting to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the signal leaves a race condition where this is still happening."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In order to make it safe and easy to connect handlers there"},{"text":" ","type":"text"},{"type":"text","text":"are two helper functions: "},{"type":"codeVoice","code":"g_cancellable_connect()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_cancellable_disconnect()"},{"text":" which protect against problems","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"like this."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An example of how to us this:","type":"text"},{"type":"text","text":" "},{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["    \/\/ Make sure we don't do unnecessary work if already cancelled","    if (g_cancellable_set_error_if_cancelled (cancellable, error))","      return;","","    \/\/ Set up all the data needed to be able to handle cancellation","    \/\/ of the operation","    my_data = my_data_new (...);","","    id = 0;","    if (cancellable)","      id = g_cancellable_connect (cancellable,","    \t\t\t      G_CALLBACK (cancelled_handler)","    \t\t\t      data, NULL);","","    \/\/ cancellable operation here...","","    g_cancellable_disconnect (cancellable, id);","","    \/\/ cancelled_handler is never called after this, it is now safe","    \/\/ to free the data","    my_data_free (my_data);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Note that the cancelled signal is emitted in the thread that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the user cancelled from, which may be the main thread. So, the"},{"text":" ","type":"text"},{"type":"text","text":"cancellable signal should not do something that can block."}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" signal"}]}]}]}],"kind":"symbol","abstract":[{"type":"text","text":"Emitted when the operation has been cancelled."}],"metadata":{"modules":[{"name":"GIO"}],"title":"onCancelled(flags:handler:)","externalID":"s:3GIO19CancellableProtocolPAAE11onCancelled5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0B3RefVctF::SYNTHESIZED::s:3GIO11CancellableC","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onCancelled"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Method","role":"symbol","extendedModule":"GIO"},"references":{"doc://GIO/documentation/GIO/Cancellable/CancellableProtocol-Implementations":{"kind":"article","url":"\/documentation\/gio\/cancellable\/cancellableprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/CancellableProtocol-Implementations","title":"CancellableProtocol Implementations","type":"topic","abstract":[],"role":"collectionGroup"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Cancellable":{"navigatorTitle":[{"kind":"identifier","text":"Cancellable"}],"title":"Cancellable","type":"topic","abstract":[{"code":"GCancellable","type":"codeVoice"},{"text":" allows operations to be cancelled.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Cancellable","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable","url":"\/documentation\/gio\/cancellable"},"doc://GIO/documentation/GIO/Cancellable/onCancelled(flags:handler:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/onCancelled(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onCancelled"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"type":"topic","url":"\/documentation\/gio\/cancellable\/oncancelled(flags:handler:)","kind":"symbol","abstract":[{"text":"Emitted when the operation has been cancelled.","type":"text"}],"title":"onCancelled(flags:handler:)","role":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}