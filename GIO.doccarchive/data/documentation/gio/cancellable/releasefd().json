{"abstract":[{"type":"text","text":"Releases a resources previously allocated by "},{"code":"g_cancellable_get_fd()","type":"codeVoice"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"g_cancellable_make_pollfd()"},{"type":"text","text":"."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"releaseFd","kind":"identifier"},{"text":"()","kind":"text"}],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"For compatibility reasons with older releases, calling this function","type":"text"},{"text":" ","type":"text"},{"text":"is not strictly required, the resources will be automatically freed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when the "},{"code":"cancellable","type":"codeVoice"},{"text":" is finalized. However, the ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" will"},{"text":" ","type":"text"},{"type":"text","text":"block scarce file descriptors until it is finalized if this function"},{"type":"text","text":" "},{"type":"text","text":"is not called. This can cause the application to run out of file"},{"type":"text","text":" "},{"type":"text","text":"descriptors when many "},{"type":"codeVoice","code":"GCancellables"},{"type":"text","text":" are used at the same time."}]},{"inlineContent":[{"type":"text","text":"Note that in the event that a [signal[Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:)] signal handler is"},{"type":"text","text":" "},{"text":"currently running, this call will block until the handler has finished.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Calling this function from a signal handler will therefore result in a"},{"text":" ","type":"text"},{"type":"text","text":"deadlock."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/releaseFd()"},"metadata":{"role":"symbol","symbolKind":"method","extendedModule":"GIO","externalID":"s:3GIO19CancellableProtocolPAAE9releaseFdyyF::SYNTHESIZED::s:3GIO11CancellableC","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"releaseFd","kind":"identifier"},{"text":"()","kind":"text"}],"title":"releaseFd()"},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/gio\/cancellable\/releasefd()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Cancellable","doc:\/\/GIO\/documentation\/GIO\/Cancellable\/CancellableProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/Cancellable/releaseFd()":{"url":"\/documentation\/gio\/cancellable\/releasefd()","abstract":[{"type":"text","text":"Releases a resources previously allocated by "},{"type":"codeVoice","code":"g_cancellable_get_fd()"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"g_cancellable_make_pollfd()","type":"codeVoice"},{"type":"text","text":"."}],"role":"symbol","title":"releaseFd()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"releaseFd","kind":"identifier"},{"text":"()","kind":"text"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/releaseFd()"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Cancellable/CancellableProtocol-Implementations":{"kind":"article","url":"\/documentation\/gio\/cancellable\/cancellableprotocol-implementations","identifier":"doc:\/\/GIO\/