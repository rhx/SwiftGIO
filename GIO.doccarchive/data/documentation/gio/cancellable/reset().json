{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/reset()","interfaceLanguage":"swift"},"abstract":[{"text":"Resets ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" to its uncancelled state.","type":"text"}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/cancellable\/reset()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"externalID":"s:3GIO19CancellableProtocolPAAE5resetyyF::SYNTHESIZED::s:3GIO11CancellableC","role":"symbol","title":"reset()","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"extendedModule":"GIO","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"reset"},{"kind":"text","text":"()"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Cancellable","doc:\/\/GIO\/documentation\/GIO\/Cancellable\/CancellableProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"reset"},{"kind":"text","text":"()"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If cancellable is currently in use by any cancellable operation"},{"type":"text","text":" "},{"text":"then the behavior of this function is undefined.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that it is generally not a good idea to reuse an existing"},{"type":"text","text":" "},{"type":"text","text":"cancellable for more operations after it has been cancelled once,"},{"type":"text","text":" "},{"type":"text","text":"as this function might tempt you to do. The recommended practice"},{"type":"text","text":" "},{"text":"is to drop the reference to a cancellable after cancelling it,","type":"text"},{"text":" ","type":"text"},{"text":"and let it die with the outstanding async operations. You should","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"create a fresh cancellable for further async operations."}]},{"inlineContent":[{"type":"text","text":"In the event that a [signal[Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:)] signal handler is currently"},{"text":" ","type":"text"},{"text":"running, this call will block until the handler has finished.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Calling this function from a signal handler will therefore result in a"},{"type":"text","text":" "},{"type":"text","text":"deadlock."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/Cancellable/reset()":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/reset()","type":"topic","kind":"symbol","url":"\/documentation\/gio\/cancellable\/reset()","abstract":[{"type":"text","text":"Resets "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" to its uncancelled state."}],"title":"reset()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"reset","kind":"identifier"},{"text":"()","kind":"text"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Cancellable/CancellableProtocol-Implementations":{"kind":"article","url":"\/documentation\/gio\/cancellable\/cancellableprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable\/CancellableProtocol-Implementations","title":"CancellableProtocol Implementations","type":"topic","abstract":[],"role":"collectionGroup"},"doc://GIO/documentation/GIO/Cancellable":{"navigatorTitle":[{"kind":"identifier","text":"Cancellable"}],"title":"Cancellable","type":"topic","abstract":[{"code":"GCancellable","type":"codeVoice"},{"text":" allows operations to be cancelled.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Cancellable","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable","url":"\/documentation\/gio\/cancellable"}}}