{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"changeState"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"value"},{"type":"text","text":" will always be of the correct state type, i.e. the type of the"},{"text":" ","type":"text"},{"text":"initial state passed to ","type":"text"},{"type":"codeVoice","code":"g_simple_action_new_stateful()"},{"type":"text","text":". If an incorrect"},{"type":"text","text":" "},{"text":"type is given when requesting to change the state, this signal is not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"emitted."}]},{"type":"paragraph","inlineContent":[{"text":"If no handler is connected to this signal then the default","type":"text"},{"text":" ","type":"text"},{"text":"behaviour is to call ","type":"text"},{"type":"codeVoice","code":"g_simple_action_set_state()"},{"type":"text","text":" to set the state"},{"type":"text","text":" "},{"type":"text","text":"to the requested value. If you connect a signal handler then no"},{"type":"text","text":" "},{"type":"text","text":"default action is taken. If the state should change then you must"},{"text":" ","type":"text"},{"text":"call ","type":"text"},{"type":"codeVoice","code":"g_simple_action_set_state()"},{"type":"text","text":" from the handler."}]},{"inlineContent":[{"type":"text","text":"An example of a ‘change-state’ handler:"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["static void","change_volume_state (GSimpleAction *action,","                     GVariant      *value,","                     gpointer       user_data)","{","  gint requested;","","  requested = g_variant_get_int32 (value);","","  \/\/ Volume only goes from 0 to 10","  if (0 <= requested && requested <= 10)","    g_simple_action_set_state (action, value);","}"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"The handler need not set the state to the requested value.","type":"text"},{"text":" ","type":"text"},{"text":"It could set it to any value at all, or take some other action.","type":"text"}]}]}],"sections":[],"kind":"symbol","metadata":{"role":"symbol","title":"SimpleActionSignalName.changeState","modules":[{"name":"GIO"}],"externalID":"s:3GIO22SimpleActionSignalNameO11changeStateyA2CmF","symbolKind":"case","roleHeading":"Case","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"changeState"}]},"abstract":[{"text":"Indicates that the action just received a request to change its","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleActionSignalName"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/simpleactionsignalname\/changestate"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionSignalName\/changeState","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SimpleActionSignalName":{"title":"SimpleActionSignalName","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"text":"SimpleActionSignalName","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"SimpleActionSignalName"}],"url":"\/documentation\/gio\/simpleactionsignalname","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionSignalName","abstract":[],"role":"symbol"},"doc://GIO/documenta