{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/UnixConnectionRef","doc:\/\/GIO\/documentation\/GIO\/UnixConnectionRef\/IOStreamProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"close(cancellable:)","externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO17UnixConnectionRefV","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","extendedModule":"GIO"},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"type":"text","text":" "},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"type":"text","text":" "},{"type":"text","text":"closed."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/UnixConnectionRef\/close(cancellable:)","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return"},{"text":" ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":". Closing a stream multiple times will not"},{"type":"text","text":" "},{"type":"text","text":"return an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers"},{"text":" ","type":"text"},{"text":"in the stream.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"text":" ","type":"text"},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}]},{"type":"paragraph","inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"descriptor) open after the stream is closed. See the documentation for"},{"type":"text","text":" "},{"type":"text","text":"the individual stream for details."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the"},{"type":"text","text":" "},{"type":"text","text":"close operation will finish as much as possible. A stream that failed"},{"type":"text","text":" "},{"type":"text","text":"to close will still return "},{"code":"closed","type":"codeVoice"},{"text":" for all operations.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Still, it is important to check and report the error to the user,"},{"type":"text","text":" "},{"type":"text","text":"otherwise there might be a loss of data as all data might not be written."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not NULL, then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default implementation of this method just calls close on the"},{"text":" ","type":"text"},{"type":"text","text":"individual input\/output streams."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/unixconnectionref\/close(cancellable:)"]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/UnixConnectionRef":{"navigatorTitle":[{"text":"UnixConnectionRef","kind":"identifier"}],"type":"topic","url":"\/documentation\/gio\/unixconnectionref","identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixConnectionRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"UnixConnectionRef","kind":"identifier"}],"abstract":[{"text":"This is the subclass of [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference"},{"text":"] that is created","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for UNIX domain sockets."}],"title":"UnixConnectionRef","role":"symbol","kind":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/UnixConnectionRef/close(cancellable:)":{"url":"\/documentation\/gio\/unixconnectionref\/close(cancellable:)","type":"topic","title":"close(cancellable:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"abstract":[{"text":"Closes the stream, releasing resources related to it. This will also","type":"text"},{"type":"text","text":" "},{"text":"close the individual input and output streams, if they are not already","type":"text"},{"type":"text","text":" "},{"type":"text","text":"closed."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixConnectionRef\/close(cancellable:)"},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","url":"\/documentation\/gio\/socketconnection","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"type":"text","text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/UnixConnectionRef/IOStreamProtocol-Implementations":{"title":"IOStreamProtocol Implementations","role":"collectionGroup","abstract":[],"kind":"article","type":"topic","url":"\/documentation\/gio\/unixconnectionref\/iostreamprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixConnectionRef\/IOStreamProtocol-Implementations"}}}