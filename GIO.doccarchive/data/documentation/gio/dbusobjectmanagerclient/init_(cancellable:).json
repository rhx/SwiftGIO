{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/dbusobjectmanagerclient\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/InitableProtocol-Implementations"]]},"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/init_(cancellable:)","interfaceLanguage":"swift"},"metadata":{"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"symbolKind":"method","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO23DBusObjectManagerClientC","title":"init_(cancellable:)","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_initable_new()"},{"text":" should typically be used instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"type":"text","text":" "},{"text":"construction, either with this function or ","type":"text"},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"then initialization can be cancelled by triggering the cancellable object","type":"text"},{"type":"text","text":" "},{"text":"from another thread. If the operation was cancelled, the error","type":"text"},{"text":" ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"text":"the object doesn’t support cancellable initialization the error","type":"text"},{"type":"text","text":" "},{"code":"notSupported","type":"codeVoice"},{"type":"text","text":" will be returned."}]},{"inlineContent":[{"type":"text","text":"If the object is not initialized, or initialization returns with an"},{"text":" ","type":"text"},{"text":"error, then all operations on the object except ","type":"text"},{"code":"g_object_ref()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"g_object_unref()","type":"codeVoice"},{"text":" are considered to be invalid, and have undefined","type":"text"},{"text":" ","type":"text"},{"text":"behaviour. See the ","type":"text"},{"type":"reference","isActive":true,"identifier":"#iface@Gio.Initable#description"},{"type":"text","text":" for more details."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"type":"text","text":" can be"},{"type":"text","text":" "},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"text":" ","type":"text"},{"type":"text","text":"supporting this. Generally, a class’ implementation of "},{"code":"init()","type":"codeVoice"},{"text":" can assume","type":"text"},{"text":" ","type":"text"},{"text":"(and assert) that it will only be called once. Previously, this documentation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recommended all "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"type":"text","text":" implementations should be idempotent; that"},{"text":" ","type":"text"},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}]},{"inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"text":" ","type":"text"},{"text":"arguments should return the same results. Only the first call initializes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the object; further calls return the result of the first call."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"One reason why a class might need to support idempotent initialization is if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GObjectClass.constructor"},{"type":"text","text":" that sometimes returns an existing instance."},{"text":" ","type":"text"},{"type":"text","text":"In this pattern, a caller would expect to be able to call "},{"type":"codeVoice","code":"g_initable_init()"},{"text":" ","type":"text"},{"type":"text","text":"on the result of "},{"code":"g_object_new()","type":"codeVoice"},{"type":"text","text":", regardless of whether it is in fact a new"},{"type":"text","text":" "},{"text":"instance.","type":"text"}]}]}],"sections":[],"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"references":{"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/DBusObjectManagerClient":{"title":"DBusObjectManagerClient","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusObjectManagerClient","kind":"identifier"}],"url":"\/documentation\/gio\/dbusobjectmanagerclient","kind":"symbol","abstract":[{"code":"GDBusObjectManagerClient","type":"codeVoice"},{"text":" is used to create, monitor and delete object","type":"text"},{"type":"text","text":" "},{"text":"proxies for remote objects exported by a [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","isActive":true},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"(or any code implementing the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","isActive":true},{"type":"text","text":" "},{"type":"text","text":"interface)."}],"role":"symbol","navigatorTitle":[{"text":"DBusObjectManagerClient","kind":"identifier"}]},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"http://dbus.freedesktop.org/doc/dbus-specification.html#standard-interfaces-objectmanager":{"type":"link","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","url":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","title":"org.freedesktop.DBus.ObjectManager","titleInlineContent":[{"type":"text","text":"org.freedesktop.DBus.ObjectManager"}]},"doc://GIO/documentation/GIO/DBusObjectManagerClient/InitableProtocol-Implementations":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/InitableProtocol-Implementations","title":"InitableProtocol Implementations","type":"topic","url":"\/documentation\/gio\/dbusobjectmanagerclient\/initableprotocol-implementations","abstract":[]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusObjectManagerClient/init_(cancellable:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"type":"topic","url":"\/documentation\/gio\/dbusobjectmanagerclient\/init_(cancellable:)","title":"init_(cancellable:)","kind":"symbol","abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/init_(cancellable:)"},"#iface@Gio.Initable#description":{"type":"link","identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description","title":"description","titleInlineContent":[{"text":"description","type":"text"}]},"doc://GIO/documentation/GIO/DBusObjectManagerServer":{"title":"DBusObjectManagerServer","kind":"symbol","url":"\/documentation\/gio\/dbusobjectmanagerserver","abstract":[{"code":"GDBusObjectManagerServer","type":"codeVoice"},{"type":"text","text":" is used to export [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObject","isActive":true},{"type":"text","text":"] instances"},{"text":" ","type":"text"},{"type":"text","text":"using the standardized"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},{"text":" ","type":"text"},{"text":"interface. For example, remote D-Bus clients can get all objects","type":"text"},{"type":"text","text":" "},{"text":"and properties in a single call. Additionally, any change in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object hierarchy is broadcast using signals. This means that D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"clients can keep caches up to date by only listening to D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"signals."}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"DBusObjectManagerServer","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","role":"symbol","navigatorTitle":[{"text":"DBusObjectManagerServer","kind":"identifier"}]}}}