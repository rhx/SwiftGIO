"},{"type":"text","text":"clients can keep caches up to date by only listening to D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"signals."}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"DBusObjectManagerServer","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","role":"symbol","navigatorTitle":[{"text":"DBusObjectManagerServer","kind":"identifier"}]},"doc://GIO/documentation/GIO/DBusObjectManagerClient":{"title":"DBusObjectManagerClient","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusObjectManagerClient","kind":"identifier"}],"url":"\/documentation\/gio\/dbusobjectmanagerclient","kind":"symbol","abstract":[{"code":"GDBusObjectManagerClient","type":"codeVoice"},{"text":" is used to create, monitor and delete object","type":"text"},{"type":"text","text":" "},{"text":"proxies for remote objects exported by a [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","isActive":true},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"(or any code implementing the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","isActive":true},{"type":"text","text":" "},{"type":"text","text":"interface)."}],"role":"symbol","navigatorTitle":[{"text":"DBusObjectManagerClient","kind":"identifier"}]},"doc://GIO/documentation/GIO/DBusObjectManagerClientRef":{"abstract":[{"code":"GDBusObjectManagerClient","type":"codeVoice"},{"text":" is used to create, monitor and delete object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"proxies for remote objects exported by a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","isActive"