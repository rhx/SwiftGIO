{"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/DBusObjectManagerClientProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyGetProxyTypeDestroyNotify"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"text":"DBusObjectManagerClientRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef","preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"notifyGetProxyTypeDestroyNotify"},{"text":" signal is emitted","type":"text"}]}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference"},{"type":"text","text":" as"},{"text":" ","type":"text"},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::get-proxy-type-destroy-notify","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"}],"kind":"content"}],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","externalID":"s:3GIO31DBusObjectManagerClientProtocolPAAE027onNotifyGetProxyTypeDestroyH05flags7handlerSi04GLibC012ConnectFlagsV_yAA0bcdE3RefV_AG09ParamSpecR0VtctF::SYNTHESIZED::s:3GIO23DBusObjectManagerClientC","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyGetProxyTypeDestroyNotify","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"text":"DBusObjectManagerClientRef","preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"kind":"text","text":") -> "},{"text