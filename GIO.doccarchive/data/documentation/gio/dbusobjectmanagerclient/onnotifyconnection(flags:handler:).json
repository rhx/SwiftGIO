set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyConnection","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV","text":"DBusObjectManagerClientRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyConnection"},{"type":"text","text":" signal is emitted"}]}],"name":"handler"}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"text":" ","type":"text"},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::connection"},{"text":" signal","type":"text"}]}]}],"kind":"content"}],"references":{"http://dbus.freedesktop.org/doc/dbus-specification.html#standard-interfaces-objectmanager":{"title":"org.freedesktop.DBus.ObjectManager","type":"link","titleInlineContent":[{"type":"text","text":"org.freedesktop.DBus.ObjectManager"}],"url":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},"doc://GIO/documentation/GIO/DBusObjectManagerClient/DBusObjectManagerClientProtocol-Implementations":{"url":"\/documentation\/gio\/dbusobjectmanagerclient\/dbusobjectmanagerclientprotocol-implementations","title":"DBusObjectManagerClientProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/DBusObjectManagerClientProtocol-Implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"#class@GObject.ParamSpec#parameter-names":{"title":"canonical parameter names","type":"link","titleInlineContent":[{"text":"canonical parameter names","type":"text"}],"url":"#class@GObject.ParamSpec#parameter-names","identifier":"#class@GObject.ParamSpec#parameter-names"},"doc://GIO/documentation/GIO/DBusObjectManagerClient":{"title":"DBusObjectManagerClient","type":"topic",