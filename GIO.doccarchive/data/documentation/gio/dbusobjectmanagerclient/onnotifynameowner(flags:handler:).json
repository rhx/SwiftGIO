{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"type":"text","text":", et al."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusobjectmanagerclient\/onnotifynameowner(flags:handler:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/onNotifyNameOwner(flags:handler:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"externalID":"s:3GIO31DBusObjectManagerClientProtocolPAAE17onNotifyNameOwner5flags7handlerSi04GLibC012ConnectFlagsV_yAA0bcdE3RefV_AG09ParamSpecP0VtctF::SYNTHESIZED::s:3GIO23DBusObjectManagerClientC","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onNotifyNameOwner"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"DBusObjectManagerClientRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV"},{"kind":"text","text":", "},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"title":"onNotifyNameOwner(flags:handler:)","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","roleHeading":"Instance Method","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/DBusObjectManagerClientProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onNotifyNameOwner","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV","text":"DBusObjectManagerClientRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyNameOwner"},{"type":"text","text":" signal is emitted"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"text":" call, like this:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::name-owner"},{"text":" signal","type":"text"}]}],"style":"note","name":"Note"}]}],"sections":[],"references":{"http://dbus.freedesktop.org/doc/dbus-specification.html#standard-interfaces-objectmanager":{"titleInlineContent":[{"type":"text","text":"org.freedesktop.DBus.ObjectManager"}],"identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","title":"org.freedesktop.DBus.ObjectManager","url":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","type":"link"},"doc://GIO/documentation/GIO/DBusObjectManagerClient/DBusObjectManagerClientProtocol-Implementations":{"url":"\/documentation\/gio\/dbusobjectmanagerclient\/dbusobjectmanagerclientprotocol-implementations","title":"DBusObjectManagerClientProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/DBusObjectManagerClientProtocol-Implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic"},"doc://GIO/documentation/GIO/DBusObjectManagerClientRef":{"abstract":[{"code":"GDBusObjectManagerClient","type":"codeVoice"},{"text":" is used to create, monitor and delete object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"proxies for remote objects exported by a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","isActive":true,"type":"reference"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(or any code implementing the","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","isActive":true},{"type":"text","text":" "},{"text":"interface).","type":"text"}],"kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusObjectManagerClientRef"}],"navigatorTitle":[{"kind":"identifier","text":"DBusObjectManagerClientRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef","url":"\/documentation\/gio\/dbusobjectmanagerclientref","title":"DBusObjectManagerClientRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusObjectManagerServer":{"title":"DBusObjectManagerServer","kind":"symbol","url":"\/documentation\/gio\/dbusobjectmanagerserver","abstract":[{"code":"GDBusObjectManagerServer","type":"codeVoice"},{"type":"text","text":" is used to export [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObject","isActive":true},{"type":"text","text":"] instances"},{"text":" ","type":"text"},{"type":"text","text":"using the standardized"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},{"text":" ","type":"text"},{"text":"interface. For example, remote D-Bus clients can get all objects","type":"text"},{"type":"text","text":" "},{"text":"and properties in a single call. Additionally, any change in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object hierarchy is broadcast using signals. This means that D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"clients can keep caches up to date by only listening to D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"signals."}],"type":"topic","fr