{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/AsyncInitableProtocol-Implementations"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/initAsync(ioPriority:cancellable:callback:userData:)"},"variants":[{"paths":["\/documentation\/gio\/dbusobjectmanagerclient\/initasync(iopriority:cancellable:callback:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"extendedModule":"GIO","modules":[{"name":"GIO"}],"role":"symbol","symbolKind":"method","externalID":"s:3GIO21AsyncInitableProtocolPAAE04initB010ioPriority11cancellable8callback8userDataySi_AA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgATtF::SYNTHESIZED::s:3GIO23DBusObjectManagerClientC","title":"initAsync(ioPriority:cancellable:callback:userData:)","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"initAsync"},{"kind":"text","text":"("},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?, "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}]},"abstract":[{"type":"text","text":"Starts asynchronous initialization of the object implementing the"},{"type":"text","text":" "},{"text":"interface. This must be done before any real use of the object after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initial construction. If the object also implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"text":" you can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"optionally call "},{"code":"g_initable_init()","type":"codeVoice"},{"text":" instead.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"initAsync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil)"}]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"type":"text","text":" "},{"code":"g_async_initable_new_async()","type":"codeVoice"},{"type":"text","text":" should typically be used instead."}]},{"inlineContent":[{"type":"text","text":"When the initialization is finished, "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called. You can"},{"type":"text","text":" "},{"type":"text","text":"then call "},{"type":"codeVoice","code":"g_async_initable_init_finish()"},{"text":" to get the result of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialization."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"text":", then initialization can be cancelled by triggering the cancellable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object from another thread. If the operation was cancelled, the error"},{"text":" ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", and","type":"text"},{"type":"text","text":" "},{"text":"the object doesn’t support cancellable initialization, the error","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"notSupported"},{"text":" will be returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"As with ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"text":", if the object is not initialized, or initialization","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returns with an error, then all operations on the object except"},{"type":"text","text":" "},{"code":"g_object_ref()","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_object_unref()"},{"text":" are considered to be invalid, and","type":"text"},{"type":"text","text":" "},{"text":"have undefined behaviour. They will often fail with ","type":"text"},{"type":"codeVoice","code":"g_critical()"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_warning()","type":"codeVoice"},{"text":", but this must not be relied on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true},{"text":" can","type":"text"},{"text":" ","type":"text"},{"text":"be initialized multiple times; for more information, see ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"If a class explicitly supports being initialized multiple times,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation requires yielding all subsequent calls to "},{"type":"codeVoice","code":"init_async()"},{"type":"text","text":" on the"},{"type":"text","text":" "},{"text":"results of the first call.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For classes that also support the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" interface, the default"},{"type":"text","text":" "},{"type":"text","text":"implementation of this method will run the "},{"code":"g_initable_init()","type":"codeVoice"},{"text":" function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in a thread, so if you want to support asynchronous initialization via"},{"type":"text","text":" "},{"text":"threads, just implement the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true},{"type":"text","text":" interface without overriding"},{"text":" ","type":"text"},{"text":"any interface methods.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/DBusObjectManagerClient/initAsync(ioPriority:cancellable:callback:userData:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/initAsync(ioPriority:cancellable:callback:userData:)","url":"\/documentation\/gio\/dbusobjectmanagerclient\/initasync(iopriority:cancellable:callback:userdata:)","abstract":[{"text":"Starts asynchronous initialization of the object implementing the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interface. This must be done before any real use of the object after"},{"text":" ","type":"text"},{"text":"initial construction. If the object also implements ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" you can"},{"text":" ","type":"text"},{"type":"text","text":"optionally call "},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":" instead."}],"title":"initAsync(ioPriority:cancellable:callback:userData:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"initAsync"},{"kind":"text","text":"("},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/DBusObjectManagerServer":{"title":"DBusObjectManagerServer","kind":"symbol","url":"\/documentation\/gio\/dbusobjectmanagerserver","abstract":[{"code":"GDBusObjectManagerServer","type":"codeVoice"},{"type":"text","text":" is used to export [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObject","isActive":true},{"type":"text","text":"] instances"},{"text":" ","type":"text"},{"type":"text","text":"using the standardized"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},{"text":" ","type":"text"},{"text":"interface. For example, remote D-Bus clients can get all objects","type":"text"},{"type":"text","text":" "},{"text":"and properties in a single call. Additionally, any change in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object hierarchy is broadcast using signals. This means that D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"clients can keep caches up to date by only listening to D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"signals."}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"DBusObjectManagerServer","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","role":"symbol","navigatorTitle":[{"text":"DBusObjectManagerServer","kind":"identifier"}]},"doc://GIO/documentation/GIO/DBusObjectManagerClient/AsyncInitableProtocol-Implementations":{"title":"AsyncInitableProtocol Implementations","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClient\/AsyncInitableProtocol-Implementations","url":"\/documentation\/gio\/dbusobjectmanagerclient\/asyncinitableprotocol-implementations","role":"collectionGroup","abstract":[],"kind":"article"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"http://dbus.freedesktop.org/doc/dbus-specification.html#standard-interfaces-objectmanager":{"identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","title":"org.freedesktop.DBus.ObjectManager","titleInlineContent":[{"text":"org.freedesktop.DBus.ObjectManager","type":"text"}],"url":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.htm