{"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStreamRef","doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/InputStreamProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/readBytes(count:cancellable:)","interfaceLanguage":"swift"},"metadata":{"symbolKind":"method","roleHeading":"Instance Method","title":"readBytes(count:cancellable:)","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"readBytes"},{"text":"(","kind":"text"},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"externalID":"s:3GIO19InputStreamProtocolPAAE9readBytes5count11cancellable4GLib0F3RefVSgSi_AA011CancellableJ0VSgtKF::SYNTHESIZED::s:3GIO14InputStreamRefV","modules":[{"name":"GIO"}],"role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readBytes"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If count is zero, returns a zero-length [Bytes](\/\/documentation\/glib\/bytes and does nothing. A"},{"text":" ","type":"text"},{"type":"text","text":"value of "},{"code":"count","type":"codeVoice"},{"text":" larger than ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" will cause a"},{"text":" ","type":"text"},{"code":"invalidArgument","type":"codeVoice"},{"text":" error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On success, a new [Bytes](\/\/documentation\/glib\/bytes is returned. It is not an error if the"},{"type":"text","text":" "},{"type":"text","text":"size of this object is not the same as the requested size, as it"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. near the end of a file. A zero-length [Bytes](\/\/documentation\/glib\/bytes is"},{"type":"text","text":" "},{"type":"text","text":"returned on end of file (or if "},{"type":"codeVoice","code":"count"},{"text":" is zero), but never","type":"text"},{"text":" ","type":"text"},{"text":"otherwise.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"text":" ","type":"text"},{"text":"partial result will be returned, without an error.","type":"text"}]},{"inlineContent":[{"text":"On error ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned and "},{"code":"error","type":"codeVoice"},{"text":" is set accordingly.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"text":"Like ","type":"text"},{"code":"g_input_stream_read()","type":"codeVoice"},{"text":", this tries to read ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" bytes from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the stream in a blocking fashion. However, rather than reading into"},{"type":"text","text":" "},{"type":"text","text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing"},{"type":"text","text":" "},{"type":"text","text":"the data that was read. This may be easier to use from language"},{"type":"text","text":" "},{"type":"text","text":"bindings."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/inputstreamref\/readbytes(count:cancellable:)"]}],"references":{"doc://GIO/documentation/GIO/InputStreamRef":{"abstract":[{"code":"GInputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming input."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"InputStreamRef","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/gio\/inputstreamref","navigatorTitle":[{"text":"InputStreamRef","kind":"identifier"}],"type":"topic","role":"symbol","title":"InputStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/InputStreamRef/InputStreamProtocol-Implementations":{"abstract":[],"type":"topic","role":"collectionGroup","url":"\/documentation\/gio\/inputstreamref\/inputstreamprotocol-implementations","title":"InputStreamProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/InputStreamProtocol-Implementations","kind":"article"},"doc://GIO/documentation/GIO/InputStreamRef/readBytes(count:cancellable:)":{"type":"topic","url":"\/documentation\/gio\/inputstreamref\/readbytes(count:cancellable:)","abstract":[{"type":"text","text":"Like "},{"type":"codeVoice","code":"g_input_stream_read()"},{"text":", this tries to read ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" bytes from","type":"text"},{"type":"text","text":" "},{"text":"the stream in a blocking fashion. However, rather than reading into","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing"},{"type":"text","text":" "},{"text":"the data that was read. This may be easier to use from language","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bindings."}],"kind":"symbol","title":"readBytes(count:cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/readBytes(count:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text"