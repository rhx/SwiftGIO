{"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/skipAsync(count:ioPriority:cancellable:callback:userData:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Request an asynchronous skip of "},{"type":"codeVoice","code":"count"},{"text":" bytes from the stream.","type":"text"},{"text":" ","type":"text"},{"text":"When the operation is finished ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"text":"You can then call ","type":"text"},{"type":"codeVoice","code":"g_input_stream_skip_finish()"},{"type":"text","text":" to get the result"},{"type":"text","text":" "},{"text":"of the operation.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStreamRef","doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/InputStreamProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/inputstreamref\/skipasync(count:iopriority:cancellable:callback:userdata:)"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"skipAsync","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"text":" ","type":"text"},{"text":"and will result in ","type":"text"},{"type":"codeVoice","code":"pending"},{"type":"text","text":" errors."}]},{"type":"paragraph","inlineContent":[{"text":"A value of ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" larger than ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" will cause a "},{"code":"invalidArgument","type":"codeVoice"},{"type":"text","text":" error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes skipped will be passed to the callback."},{"type":"text","text":" "},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"text":" ","type":"text"},{"text":"can happen e.g. near the end of a file, but generally we try to skip","type":"text"},{"type":"text","text":" "},{"text":"as many bytes as requested. Zero is returned on end of file","type":"text"},{"text":" ","type":"text"},{"text":"(or if ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" is zero), but never otherwise."}]},{"type":"paragraph","inlineContent":[{"text":"Any outstanding i\/o request with higher priority (lower numerical value)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be executed before an outstanding request with lower priority."},{"text":" ","type":"text"},{"text":"Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implement asynchronicity, so they are optional for inheriting classes."},{"text":" ","type":"text"},{"type":"text","text":"However, if you override one, you must override all."}]}]}],"metadata":{"extendedModule":"GIO","title":"skipAsync(count:ioPriority:cancellable:callback:userData:)","role":"symbol","symbolKind":"method","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"skipAsync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?, "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"externalID":"s:3GIO19InputStreamProtocolPAAE9skipAsync5count10ioPriority11cancellable8callback8userDataySi_SiAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgAUtF::SYNTHESIZED::s:3GIO14InputStreamRefV","roleHeading":"Instance Method"},"refere