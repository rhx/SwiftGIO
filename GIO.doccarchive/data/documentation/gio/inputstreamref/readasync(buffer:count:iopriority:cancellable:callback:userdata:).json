{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"readAsync"},{"kind":"text","text":"("},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"During an async request no other sync and async calls are allowed on "},{"type":"codeVoice","code":"stream"},{"text":", and will","type":"text"},{"type":"text","text":" "},{"text":"result in ","type":"text"},{"code":"pending","type":"codeVoice"},{"type":"text","text":" errors."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A value of "},{"type":"codeVoice","code":"count"},{"text":" larger than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"text":" will cause a ","type":"text"},{"code":"invalidArgument","type":"codeVoice"},{"text":" error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes read into the buffer will be passed to the"},{"text":" ","type":"text"},{"type":"text","text":"callback. It is not an error if this is not the same as the requested size, as it"},{"text":" ","type":"text"},{"text":"can happen e.g. near the end of a file, but generally we try to read","type":"text"},{"text":" ","type":"text"},{"text":"as many bytes as requested. Zero is returned on end of file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(or if "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is zero),  but never otherwise."}]},{"type":"paragraph","inlineContent":[{"text":"Any outstanding i\/o request with higher priority (lower numerical value) will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be executed before an outstanding request with lower priority. Default"},{"type":"text","text":" "},{"text":"priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads to implement"},{"type":"text","text":" "},{"text":"asynchronicity, so they are optional for inheriting classes. However, if you","type":"text"},{"text":" ","type":"text"},{"text":"override one you must override all.","type":"text"}]}]}],"abstract":[{"text":"Request an asynchronous read of ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" bytes from the stream into the buffer","type":"text"},{"type":"text","text":" "},{"text":"starting at ","type":"text"},{"type":"codeVoice","code":"buffer"},{"type":"text","text":". When the operation is finished "},{"type":"codeVoice","code":"callback"},{"text":" will be called.","type":"text"},{"type":"text","text":" "},{"text":"You can then call ","type":"text"},{"type":"codeVoice","code":"g_input_stream_read_finish()"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"text":"operation.","type":"text"}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"readAsync"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"extendedModule":"GIO","roleHeading":"Instance Method","externalID":"s:3GIO19InputStreamProtocolPAAE9readAsync6buffer5count10ioPriority11cancellable8callback8userDataySvSg_S2iAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgAKtXCSgAKtF::SYNTHESIZED::s:3GIO14InputStreamRefV","modules":[{"name":"GIO"}],"title":"readAsync(buffer:count:ioPriority:cancellable:callback:userData:)","symbolKind":"method","role":"symbol"},"sections":[],"identifier":{"url":"doc:\/\/GIO\/doc