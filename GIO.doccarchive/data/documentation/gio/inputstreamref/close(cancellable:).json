{"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStreamRef","doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/InputStreamProtocol-Implementations"]]},"metadata":{"externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO14InputStreamRefV","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"roleHeading":"Instance Method","symbolKind":"method","extendedModule":"GIO","title":"close(cancellable:)"},"sections":[],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Closing a stream multiple times will not return an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"text":" ","type":"text"},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"text":"resources are released as early as possible.","type":"text"}]},{"inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"text":" ","type":"text"},{"text":"stream for details.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"text":" ","type":"text"},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"code":"closed","type":"codeVoice"},{"text":" for all operations. Still, it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is important to check and report the error to the user."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"text":"Cancelling a close will still leave the stream closed, but some streams","type":"text"},{"text":" ","type":"text"},{"text":"can use a faster close that doesn’t block to e.g. check errors.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/inputstreamref\/close(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/InputStreamRef/InputStreamProtocol-Implementations":{"abstract":[],"type":"topic","role":"collectionGroup","url":"\/documentation\/gio\/inputstreamref\/inputstreamprotocol-implementations","title":"InputStreamProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/InputStreamProtocol-Implementations","kind":"article"},"doc://GIO/documentation/GIO/InputStreamRef/close(cancellable:)":{"kind":"symbol","url":"\/documentation\/gio\/inputstreamref\/close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"title":"close(cancellable:)","role":"symbol","type":"topic","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef\/close(cancellable:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/InputStreamRef":{"abstract":[{"code":"GInputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming input."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"InputStreamRef","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/gio\/inputstreamref","navigatorTitle":[{"text":"InputStreamRef","kind":"identifier"}],"type":"topic","role":"symbol","title":"InputStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}