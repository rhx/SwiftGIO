{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"activateAction"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"actionName"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"parameter"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"If the action is expecting a parameter, then the correct type of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameter must be given as "},{"code":"parameter","type":"codeVoice"},{"type":"text","text":".  If the action is expecting no"},{"type":"text","text":" "},{"text":"parameters then ","type":"text"},{"type":"codeVoice","code":"parameter"},{"type":"text","text":" must be "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":".  See"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.ActionGroup.get_action_parameter_type"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"text":"If the [type","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","isActive":true},{"text":"] implementation supports asynchronous remote","type":"text"},{"text":" ","type":"text"},{"text":"activation over D-Bus, this call may return before the relevant","type":"text"},{"type":"text","text":" "},{"type":"text","text":"D-Bus traffic has been sent, or any replies have been received. In"},{"type":"text","text":" "},{"type":"text","text":"order to block on such asynchronous activation calls,"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"text":"] should be called prior to the code, which","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"depends on the result of the action activation. Without flushing"},{"text":" ","type":"text"},{"type":"text","text":"the D-Bus connection, there is no guarantee that the action would"},{"text":" ","type":"text"},{"type":"text","text":"have been activated."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code which runs in a remote app instance, shows an"},{"text":" ","type":"text"},{"type":"text","text":"example of a ‘quit’ action being activated on the primary app"},{"text":" ","type":"text"},{"type":"text","text":"instance over D-Bus. Here [method"},{"code":"Gio.DBusConnection.flush","type":"codeVoice"},{"type":"text","text":"] is called"},{"type":"text","text":" "},{"type":"text","text":"before "},{"type":"codeVoice","code":"exit()"},{"text":". Without ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_flush()"},{"type":"text","text":", the ‘quit’ action"},{"text":" ","type":"text"},{"type":"text","text":"may fail to be activated on the primary instance."}]},{"type":"codeListing","syntax":"c","code":["\/\/ call ‘quit’ action on primary instance","g_action_group_activate_action (G_ACTION_GROUP (app), \"quit\", NULL);","","\/\/ make sure the action is activated now","g_dbus_connection_flush (…);","","g_debug (\"Application has been terminated. Exiting.\");","","exit (0);"]}]}],"metadata":{"extendedModule":"GIO","title":"activateAction(actionName:parameter:)","externalID":"s:3GIO19ActionGroupProtocolPAAE08activateB010actionName9parameterySPys4Int8VGSg_4GLib10VariantRefVSgtF::SYNTHESIZED::s:3GIO20SimpleActionGroupRefV","role":"symbol","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[