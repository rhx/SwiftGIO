ract":[{"text":"Conditional initialiser from an optional pointer to the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"text":" data type","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(_:)-3i7wh","url":"\/documentation\/gio\/datagrambasedref\/init(_:)-3i7wh","title":"init(_:)"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/DatagramBasedProtocol/datagram_based_ptr-9b0pk":{"required":true,"type":"topic","kind":"symbol","url":"\/documentation\/gio\/datagrambasedprotocol\/datagram_based_ptr-9b0pk","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"datagram_based_ptr","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GDatagramBased"},{"kind":"text","text":">!"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/datagram_based_ptr-9b0pk","abstract":[{"text":"Typed pointer to the underlying ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"text":" instance.","type":"text"}],"defaultImplem