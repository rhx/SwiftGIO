 winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/DatagramBased":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/datagrambased","abstract":[{"type":"text","text":"Interface for socket-like objects with datagram semantics."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBased"}],"title":"DatagramBased","navigatorTitle":[{"text":"DatagramBased","kind":"identifier"}]},"doc://GIO/documentation/GIO/DatagramBasedRef/init(gconstpointer:)":{"title":"init(gconstpointer:)","type":"topic","abstract":[{"text":"Conditional initialiser from an optional, non-mutable ","type":"text"},{"type":"codeVoice","code":"gconstpointer"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(gconstpointer:)","role":"symbol","kind":"symbol","url":"\/documentation\/gio\/datagrambasedref\/init(gconstpointer:)","fragments":[{"text":"init","kind":"identifier"},{"text":"!(","kind":"text"},{"kind":"externalParam","text":"gconstpointer"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gconstpointer","preciseIdentifier":"c:gtypes.h@T@gconstpointer"},{"text":"?)","kind":"text"}]}}}