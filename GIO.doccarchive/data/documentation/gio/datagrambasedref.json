{"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Interface for socket-like objects with datagram semantics.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef"},"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"DatagramBasedRef","kind":"identifier"}],"title":"DatagramBasedRef","role":"symbol","navigatorTitle":[{"text":"DatagramBasedRef","kind":"identifier"}],"modules":[{"name":"GIO"}],"symbolKind":"struct","roleHeading":"Structure","externalID":"s:3GIO16DatagramBasedRefV"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBasedRef"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"A ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"text":" is a networking interface for representing datagram-based","type":"text"},{"text":" ","type":"text"},{"text":"communications. It is a more or less direct mapping of the core parts of the","type":"text"},{"type":"text","text":" "},{"text":"BSD socket API in a portable GObject interface. It is implemented by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":"], which wraps the UNIX socket API on UNIX and winsock2 on Windows."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GDatagramBased"},{"text":" is entirely platform independent, and is intended to be used","type":"text"},{"type":"text","text":" "},{"text":"alongside higher-level networking APIs such as [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"It uses vectored scatter\/gather I\/O by default, allowing for many messages"},{"type":"text","text":" "},{"type":"text","text":"to be sent or received in a single call. Where possible, implementations of"},{"text":" ","type":"text"},{"type":"text","text":"the interface should take advantage of vectored I\/O to minimise processing"},{"type":"text","text":" "},{"type":"text","text":"or system calls. For example, "},{"type":"codeVoice","code":"GSocket"},{"text":" uses ","type":"text"},{"type":"codeVoice","code":"recvmmsg()"},{"text":" and ","type":"text"},{"code":"sendmmsg()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"where possible. Callers should take advantage of scatter\/gather I\/O (the use of"},{"type":"text","text":" "},{"type":"text","text":"multiple buffers per message) to avoid unnecessary copying of data to"},{"type":"text","text":" "},{"type":"text","text":"assemble or disassemble a message."}],"type":"paragraph"},{"inlineContent":[{"text":"Each ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"text":" operation has a timeout parameter which may be negative","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for blocking behaviour, zero for non-blocking behaviour, or positive for"},{"text":" ","type":"text"},{"type":"text","text":"timeout behaviour. A blocking operation blocks until finished or there is an"},{"type":"text","text":" "},{"text":"error. A non-blocking operation will return immediately with a","type":"text"},{"type":"text","text":" "},{"code":"G_IO_ERROR_WOULD_BLOCK","type":"codeVoice"},{"text":" error if it cannot make progress. A timeout operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will block until the operation is complete or the timeout expires; if the"},{"type":"text","text":" "},{"text":"timeout expires it will return what progress it made, or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_IO_ERROR_TIMED_OUT"},{"text":" if no progress was made. To know when a call would","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"successfully run you can call [method"},{"type":"codeVoice","code":"Gio.DatagramBased.condition_check"},{"text":"] or","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"Gio.DatagramBased.condition_wait","type":"codeVoice"},{"type":"text","text":"]. You can also use"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.DatagramBased.create_source"},{"text":"] and attach it to a [struct[MainContext](\/\/documentation\/glib\/maincontext]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to get callbacks when I\/O is possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running a non-blocking operation applications should always be able to"},{"text":" ","type":"text"},{"type":"text","text":"handle getting a "},{"code":"G_IO_ERROR_WOULD_BLOCK","type":"codeVoice"},{"text":" error even when some other function","type":"text"},{"type":"text","text":" "},{"text":"said that I\/O was possible. This can easily happen in case of a race","type":"text"},{"type":"text","text":" "},{"text":"condition in the application, but it can also happen for other reasons. For","type":"text"},{"text":" ","type":"text"},{"text":"instance, on Windows a socket is always seen as writable until a write","type":"text"},{"type":"text","text":" "},{"text":"returns ","type":"text"},{"code":"G_IO_ERROR_WOULD_BLOCK","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"As with "},{"type":"codeVoice","code":"GSocket"},{"type":"text","text":", "},{"code":"GDatagramBased","type":"codeVoice"},{"text":"s can be either connection oriented (for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example, SCTP) or connectionless (for example, UDP). "},{"type":"codeVoice","code":"GDatagramBased"},{"text":"s must be","type":"text"},{"text":" ","type":"text"},{"text":"datagram-based, not stream-based. The interface does not cover connection","type":"text"},{"type":"text","text":" "},{"type":"text","text":"establishment — use methods on the underlying type to establish a connection"},{"type":"text","text":" "},{"text":"before sending and receiving data through the ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":" API. For"},{"type":"text","text":" "},{"text":"connectionless socket types the target\/source address is specified or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"received in each I\/O operation."}],"type":"paragraph"},{"inlineContent":[{"text":"Like most other APIs in GLib, ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"text":" is not inherently thread safe.","type":"text"},{"text":" ","type":"text"},{"text":"To use a ","type":"text"},{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":" concurrently from multiple threads, you must"},{"text":" ","type":"text"},{"type":"text","text":"implement your own locking."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GDatagramBased"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef","type":"reference"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GDatagramBased","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true,"type":"reference"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside"}]}],"variants":[{"paths":["\/documentation\/gio\/datagrambasedref"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(_:)-2tbrr","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(_:)-3i7wh","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(_:)-3q0g1","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(_:)-3shx9","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(_:)-xret","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/init(opaquePointer:)"],"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/ptr"],"anchor":"Instance-Properties","generated":true},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/DatagramBasedProtocol-Implementations","doc:\/\/GIO\/documentat