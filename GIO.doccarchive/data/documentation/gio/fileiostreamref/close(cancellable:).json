{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileiostreamref\/close(cancellable:)"]}],"abstract":[{"text":"Closes the stream, releasing resources related to it. This will also","type":"text"},{"type":"text","text":" "},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"type":"text","text":" "},{"text":"closed.","type":"text"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"extendedModule":"GIO","roleHeading":"Instance Method","title":"close(cancellable:)","role":"symbol","externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO15FileIOStreamRefV","symbolKind":"method","modules":[{"name":"GIO"}]},"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef","doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef\/IOStreamProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return"},{"text":" ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":". Closing a stream multiple times will not"},{"text":" ","type":"text"},{"type":"text","text":"return an error."}]},{"inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers"},{"text":" ","type":"text"},{"text":"in the stream.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"text":" ","type":"text"},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file"},{"text":" ","type":"text"},{"type":"text","text":"descriptor) open after the stream is closed. See the documentation for"},{"type":"text","text":" "},{"text":"the individual stream for details.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On failure the first error that happened will be reported, but the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"close operation will finish as much as possible. A stream that failed"},{"type":"text","text":" "},{"type":"text","text":"to close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Still, it is important to check and report the error to the user,"},{"type":"text","text":" "},{"type":"text","text":"otherwise there might be a loss of data as all data might not be written."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not NULL, then the operation can be cancelled by","type":"text"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"text":" ","type":"text"},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}]},{"type":"paragraph","inlineContent":[{"text":"The default implementation of this method just calls close on the","type":"text"},{"type":"text","text":" "},{"text":"individual input\/output streams.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/FileIOStreamRef/IOStreamProtocol-Implementations":{"abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef\/IOStreamProtocol-Implementations","url":"\/documentation\/gio\/fileiostreamref\/iostreamprotocol-implementations","kind":"article","type":"topic","title":"IOStreamProtocol Implementations","role":"collectionGroup"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileIOStreamRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef","title":"FileIOStreamRef","url":"\/documentation\/gio\/fileiostreamref","abstract":[{"type":"codeVoice","code":"GFileIOStream"},{"text":" provides I\/O streams that both read and write to the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file handle."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileIOStreamRef"}],"kind":"symbol","navigatorTitle":[{"text":"FileIOStreamRef","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileIOStreamRef/close(cancellable:)":{"abstract":[{"text":"Closes the stream, releasing resources related to it. This will also","type":"text"},{"text":" ","type":"text"},{"text":"close the individual input and output streams, if they are not already","type":"text"},{"type":"text","text":" "},{"text":"closed.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/gio\/fileiostreamref\/close(cancellable:)","role":"symbol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef\/close(cancellable:)","title":"close(cancellable:)"}}}