],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"text":" as","type":"text"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::use-system-certdb","type":"codeVoice"},{"text":" signal","type":"text"}]}]}],"kind":"content"}],"metadata":{"modules":[{"name":"GIO"}],"extendedModule":"GIO","role":"symbol","roleHeading":"Instance Method","externalID":"s:3GIO21TLSConnectionProtocolPAAE23onNotifyUseSystemCertdb5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0B3RefV_AG09ParamSpecO0VtctF","title":"onNotifyUseSystemCertdb(flags:handler:)","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyUseSystemCertdb","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"text":"TLSConnectionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"kind":"text","text":", "},{"text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol\/onNotifyUseSystemCertdb(flags:handler:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","abstrac