{"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/tlsconnectionprotocol\/handshake(cancellable:)-ovqy"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Instance Method","title":"handshake(cancellable:)","extendedModule":"GIO","externalID":"s:3GIO21TLSConnectionProtocolPAAE9handshake11cancellableSbAA14CancellableRefVSg_tKF","role":"symbol","symbolKind":"method","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"handshake"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]},"abstract":[{"text":"Attempts a TLS handshake on ","type":"text"},{"code":"conn","type":"codeVoice"},{"type":"text","text":"."}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol\/handshake(cancellable:)-ovqy","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"handshake","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"On the client side, it is never necessary to call this method;"},{"type":"text","text":" "},{"text":"although the connection needs to perform a handshake after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connecting (or after sending a “STARTTLS”-type command),"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"type":"text","text":" will handle this for you automatically when you try"},{"type":"text","text":" "},{"type":"text","text":"to send or receive data on the connection. You can call"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" manually if you want to know whether"},{"type":"text","text":" "},{"text":"the initial handshake succeeded or failed (as opposed to just","type":"text"},{"type":"text","text":" "},{"type":"text","text":"immediately trying to use "},{"code":"conn","type":"codeVoice"},{"text":" to read or write, in which case,","type":"text"},{"text":" ","type":"text"},{"text":"if it fails, it may not be possible to tell if it failed before or","type":"text"},{"type":"text","text":" "},{"text":"after completing the handshake), but beware that servers may reject","type":"text"},{"type":"text","text":" "},{"text":"client authentication after the handshake has completed, so a","type":"text"},{"text":" ","type":"text"},{"text":"successful handshake does not indicate the connection will be usable.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Likewise, on the server side, although a handshake is necessary at"},{"text":" ","type":"text"},{"text":"the beginning of the communication, you do not need to call this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function explicitly unless you want clearer error reporting."}]},{"type":"paragraph","inlineContent":[{"text":"Previously, calling ","type":"text"},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" after the initial"},{"type":"text","text":" "},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"type":"text","text":" "},{"type":"text","text":"deprecated in GLib 2.60 because rehandshaking was removed from the"},{"type":"text","text":" "},{"text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake will no longer do anything."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","type":"reference","isActive":true},{"text":" created by ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"type":"text","text":" performs the initial handshake, so calling this"},{"type":"text","text":" "},{"type":"text","text":"function manually is not recommended."}]},{"type":"paragraph","inlineContent":[{"text":"[TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the","type":"text"},{"type":"text","text":" "},{"text":"handshake.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSConnectionProtocol":{"url":"\/documentation\/gio\/tlsconnectionprotocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol","title":"TLSConnectionProtocol","navigatorTitle":[{"kind":"identifier","t