{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol\/handshake(cancellable:)-31mo2","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"Attempts a TLS handshake on "},{"type":"codeVoice","code":"conn"},{"text":".","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsconnectionprotocol\/handshake(cancellable:)-31mo2"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"handshake","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO19CancellableProtocolP","text":"CancellableProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"On the client side, it is never necessary to call this method;"},{"type":"text","text":" "},{"type":"text","text":"although the connection needs to perform a handshake after"},{"type":"text","text":" "},{"text":"connecting (or after sending a “STARTTLS”-type command),","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"type":"text","text":" will handle this for you automatically when you try"},{"text":" ","type":"text"},{"type":"text","text":"to send or receive data on the connection. You can call"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" manually if you want to know whether"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake succeeded or failed (as opposed to just"},{"text":" ","type":"text"},{"type":"text","text":"immediately trying to use "},{"type":"codeVoice","code":"conn"},{"text":" to read or write, in which case,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if it fails, it may not be possible to tell if it failed before or"},{"text":" ","type":"text"},{"type":"text","text":"after completing the handshake), but beware that servers may reject"},{"text":" ","type":"text"},{"type":"text","text":"client authentication after the handshake has completed, so a"},{"type":"text","text":" "},{"text":"successful handshake does not indicate the connection will be usable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Likewise, on the server side, although a handshake is necessary at","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the beginning of the communication, you do not need to call this"},{"text":" ","type":"text"},{"text":"function explicitly unless you want clearer error reporting.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Previously, calling ","type":"text"},{"code":"g_tls_connection_handshake()","type":"codeVoice"},{"type":"text","text":" after the initial"},{"text":" ","type":"text"},{"text":"handshake would trigger a rehandshake; however, this usage was","type":"text"},{"type":"text","text":" "},{"text":"deprecated in GLib 2.60 because rehandshaking was removed from the","type":"text"},{"type":"text","text":" "},{"text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the initial handshake will no longer do anything."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true,"type":"reference"},{"type":"text","text":" created by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","type":"reference","isActive":true},{"type":"text","text":" performs the initial handshake, so calling this"},{"type":"text","text":" "},{"text":"function manually is not recommended.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the"},{"text":" ","type":"text"},{"type":"text","text":"handshake."}]}],"kind":"content"}],"metadata":{"modules":[{"name":"GIO"}],"externalID":"s:3GIO21TLSConnectionProtocolPAAE9handshake11cancellableSbqd__Sg_tKAA011CancellableC0Rd__lF","role":"symbol","extendedModule":"GIO","title":"handshake(cancellable:)","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"handshake","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"symbolKind":"method"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol"]]},"references":{"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClient"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","abstract":[{"type":"codeVoice","code":"GSocketClient"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"title":"SocketClient","role":"symbol","url":"\/documentation\/gio\/socketclient","navigatorTitle":[{"kind":"identifier","text":"SocketClient"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSConnectionProtocol":{"url":"\/documentation\/gio\/tlsconnectionprotocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol","title":"TLSConnectionProtocol","navigatorTitle":[{"kind":"identifier","text":"TLSConnectionProtocol"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnectionProtocol","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsConnection"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"text":"a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"text":"], implement client-side and server-side TLS,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSConnectionProtocol/handshake(cancellable:)-31mo2":{"url":"\/documentation\/gio\/tlsconnectionprotocol\/handshake(cancellable:)-31mo2","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Attempts a TLS handshake on "},{"code":"conn","type":"codeVoice"},{"text":".","type":"text"}],"title":"handshake(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol\/