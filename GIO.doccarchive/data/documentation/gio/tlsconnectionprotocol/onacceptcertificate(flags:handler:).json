{"sections":[],"metadata":{"symbolKind":"method","role":"symbol","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onAcceptCertificate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"TLSConnectionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"kind":"text","text":", "},{"text":"TLSCertificateRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSCertificateRefV"},{"text":", ","kind":"text"},{"text":"TLSCertificateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Method","externalID":"s:3GIO21TLSConnectionProtocolPAAE19onAcceptCertificate5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0B3RefV_AA014TLSCertificateM0VAA0nL0VtctF","modules":[{"name":"GIO"}],"title":"onAcceptCertificate(flags:handler:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol"]]},"variants":[{"paths":["\/documentation\/gio\/tlsconnectionprotocol\/onacceptcertificate(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Emitted during the TLS handshake after the peer certificate has","type":"text"},{"type":"text","text":" "},{"text":"been received. You can examine ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":"’s certification path by"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"code":"g_tls_certificate_get_issuer()","type":"codeVoice"},{"type":"text","text":" on it."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onAcceptCertificate","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","kind":"typeIdentifier","text":"TLSConnectionRef","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","text":"TLSCertificateFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags"},{"kind":"text","text":") -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"true"},{"type":"text","text":" to accept "},{"type":"codeVoice","code":"peerCert"},{"text":" (which will also immediately end the signal emission). ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" to allow the signal emission to continue, which will cause the handshake to fail if no one else overrides it."},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"code":"acceptCertificate","type":"codeVoice"},{"text":" signal is emitted","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a client-side connection, "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" is the server’s"},{"type":"text","text":" "},{"text":"certificate, and the signal will only be emitted if the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate was not acceptable according to "},{"code":"conn","type":"codeVoice"},{"text":"’s","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","type":"reference","isActive":true},{"text":". If you would like the","type":"text"},{"type":"text","text":" "},{"text":"certificate to be accepted despite ","type":"text"},{"type":"codeVoice","code":"errors"},{"text":", return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" from the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"signal handler. Otherwise, if no handler accepts the certificate,"},{"text":" ","type":"text"},{"text":"the handshake will fail with ","type":"text"},{"type":"codeVoice","code":"badCertificate"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, this signal"},{"type":"text","text":" "},{"type":"text","text":"will be emitted with at least one error will be set in "},{"code":"errors","type":"codeVoice"},{"type":"text","text":", but"},{"type":"text","text":" "},{"type":"text","text":"it does not guarantee that all possible errors will be set."},{"type":"text","text":" "},{"type":"text","text":"Accordingly, you may not safely decide to ignore any particular"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"type":"text","text":" "},{"type":"codeVoice","code":"expired"},{"text":" if you want to allow expired","type":"text"},{"text":" ","type":"text"},{"text":"certificates, because this could potentially be the only error flag","type":"text"},{"type":"text","text":" "},{"text":"set even if other problems exist with the certificate.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For a server-side connection, ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"text":" is the certificate","type":"text"},{"type":"text","text":" "},{"text":"presented by the client, if this was requested via the server’s","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true},{"text":". On the server side,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the signal is always emitted when the client presents a"},{"type":"text","text":" "},{"type":"text","text":"certificate, and the certificate will only be accepted if a"},{"text":" ","type":"text"},{"type":"text","text":"handler returns "},{"code":"true","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"text":" ","type":"text"},{"type":"text","text":"in the main thread, then you should not attempt to interact with"},{"text":" ","type":"text"},{"type":"text","text":"the user before returning from the signal handler. If you want to"},{"text":" ","type":"text"},{"text":"let the user decide whether or not to accept the certificate, you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"would have to return "},{"type":"codeVoice","code":"false"},{"text":" from the signal handler on the first","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"attempt, and then after the connection attempt returns a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"badCertificate"},{"type":"text","text":", you can interact with the user, and"},{"text":" ","type":"text"},{"type":"text","text":"if the user decides to accept the certificate, remember that fact,"},{"type":"text","text":" "},{"type":"text","text":"create a new connection, and return "},{"type":"codeVoice","code":"true"},{"text":" from the signal handler","type":"text"},{"text":" ","type":"text"},{"text":"the next time.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If you are doing I\/O in another thread, you do not"},{"text":" ","type":"text"},{"text":"need to worry about this, and can simply block in the signal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handler until the UI thread returns an answer."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"accept-certificate"},{"type":"text","text":" signal"}]}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionProtocol\/onAcceptCertificate(flags:handler:)"},"references":{"//documentation/gio/tlsconnection/onacceptcertificate(flags:handler:)":{"type":"link","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","title":"TLSConnection","titleInlineContent":[{"type":"text","text":"TLSConnection"}],"url":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSCertificateFlags":{"url":"\/documentation\/gio\/tlscertificateflags","abstract":[{"type":"text","text":"A set of flags describing TLS certification validation. This can be"},{"type":"text","text":" "},{"type":"text","text":"used to describe why a particular certificate was rejected (for"},{"type":"text","text":" "},{"text":"example, in ","type":"text"},{"type":"reference","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","isActive":true},{"text":".","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateFlags","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateFlags"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","title":"TLSCertificateFlags","kind":"symbol"},"doc://GIO/documentation/GIO/TLSConnectionRef":{"type":"topic","url":"\/documentation\/gio\/tlsconnectionref","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TLSConnectionRef"}],"abstract":[{"type":"codeVoice","code":"GTlsConnection"},{"type":"text","text":" is the base TLS connection class type, whi