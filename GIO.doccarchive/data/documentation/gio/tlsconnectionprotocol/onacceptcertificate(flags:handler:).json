tion"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a server-side TLS connection.","type":"text"}]},"doc://GIO/documentation/GIO/TLSCertificateRef":{"abstract":[{"text":"A certificate used for TLS authentication and encryption.","type":"text"},{"text":" ","type":"text"},{"text":"This can represent either a certificate only (eg, the certificate","type":"text"},{"type":"text","text":" "},{"text":"received by a client from a server), or the combination of","type":"text"},{"type":"text","text":" "},{"text":"a certificate and a private key (which is needed when acting as a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference"},{"type":"text","text":"])."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateRef"}],"title":"TLSCertificateRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TLSCertificateRef","kind":"identifier"}],"url":"\/documentation\/gio\/tlscertificateref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef"}}}