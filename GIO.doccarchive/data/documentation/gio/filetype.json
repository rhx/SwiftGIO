{"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"FileType","kind":"identifier"},{"kind":"text","text":" = "},{"kind":"typeIdentifier","preciseIdentifier":"c:@EA@GFileType","text":"GFileType"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"On Windows systems a file will never have ","type":"text"},{"code":"symbolicLink","type":"codeVoice"},{"text":" type;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardIsSymlink"},{"text":" to determine","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether a file is a symlink or not. This is due to the fact that NTFS does"},{"text":" ","type":"text"},{"text":"not have a single filesystem object type for symbolic links - it has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"files that symlink to files, and directories that symlink to directories."},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileType","isActive":true,"type":"reference"},{"text":" enumeration cannot precisely represent this important distinction,","type":"text"},{"type":"text","text":" "},{"text":"which is why all Windows symlinks will continue to be reported as","type":"text"},{"type":"text","text":" "},{"code":"regular","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"directory"},{"type":"text","text":"."}]}],"kind":"content"}],"identifier":{"interfaceLangua