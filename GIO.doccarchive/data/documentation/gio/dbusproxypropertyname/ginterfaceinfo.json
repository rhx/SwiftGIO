{"abstract":[{"text":"Ensure that interactions with this proxy conform to the given","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"interface. This is mainly to ensure that malformed data received"},{"text":" ","type":"text"},{"text":"from the other peer is ignored. The given ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceInfo"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"said to be the “expected interface”.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"gInterfaceInfo","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"The checks performed are:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"When completing a method call, if the type signature of","type":"text"},{"text":" ","type":"text"},{"text":"the reply message isn’t what’s expected, the reply is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"discarded and the [GLibError](\/\/documentation\/glib\/gliberror is set to "},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Received signals that have a type signature mismatch are dropped and","type":"text"},{"text":" ","type":"text"},{"text":"a warning is logged via ","type":"text"},{"type":"codeVoice","code":"g_warning()"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Properties received via the initial "},{"code":"GetAll()","type":"codeVoice"},{"type":"text","text":" call or via the"},{"type":"text","text":" "},{"type":"codeVoice","code":"PropertiesChanged"},{"text":" signal (on the","type