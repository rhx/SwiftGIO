{"metadata":{"externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO19DataOutputStreamRefV","modules":[{"name":"GIO"}],"symbolKind":"method","roleHeading":"Instance Method","title":"close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"role":"symbol","extendedModule":"GIO"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dataoutputstreamref\/close(cancellable:)"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Once the stream is closed, all other operations will return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers in the"},{"text":" ","type":"text"},{"type":"text","text":"stream."}]},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"type":"text","text":" "},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"type":"text","text":" "},{"text":"stream for details.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"text":"operation will finish as much as possible. A stream that failed to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"close will still return "},{"code":"closed","type":"codeVoice"},{"text":" for all operations. Still, it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important to check and report the error to the user, otherwise"},{"type":"text","text":" "},{"type":"text","text":"there might be a loss of data as all data might not be written."}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"text":"Cancelling a close will still leave the stream closed, but there some streams","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors. On"},{"text":" ","type":"text"},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"type":"text","text":"data will reach the target."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/DataOutputStreamRef/close(cancellable:)":{"role":"symbol","url":"\/documentation\/gio\/dataoutputstreamref\/close(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"type":"topic","title":"close(cancellable:)","kind":"symbol"},"doc://GIO/documentation/GIO/DataOutputStreamRef/OutputStreamProtocol-Implementations":{"abstract":[],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/OutputStreamProtocol-Implementations","role":"collectionGroup","kind":"article","title":"OutputStreamProtocol Implementations","url":"\/documentation\/gio\/dataoutputstreamref\/outputstreamprotocol-implementations"},"doc://GIO/documentation/GIO/DataOutputStreamRef":{"url":"\/documentation\/gio\/dataoutputstreamref","abstract":[{"type":"text","text":"Data output stream implements [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","type":"reference","isActive":true},{"text":"] and includes functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for writing data directly to an output stream."}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"DataOutputStreamRef","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DataOutputStreamRef"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef","title":"DataOutputStreamRef"}}}