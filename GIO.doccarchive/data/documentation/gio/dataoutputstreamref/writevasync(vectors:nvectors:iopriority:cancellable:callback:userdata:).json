er numerical"},{"type":"text","text":" "},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}]},{"inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads"},{"type":"text","text":" "},{"type":"text","text":"to implement asynchronicity, so they are optional for inheriting"},{"text":" ","type":"text"},{"type":"text","text":"classes. However, if you override one you must override all."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_output_stream_writev()"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Note that no copy of ","type":"text"},{"code":"vectors","type":"codeVoice"},{"text":" will be made, so it must stay valid","type":"text"},{"text":" ","type":"text"},{"text":"until ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" is called.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/DataOutputStreamRef/writevAsync(vectors:nVectors:ioPriority:cancellable:callback:userData:)":{"role":"symbol","url":"\/documentation\/gio\/dataoutputstreamref\/writevasync(vectors:nvectors:iopriority:cancellable:callback:userdata:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/writevAsync(vectors:nVectors:ioPriority:cancellable:callback:userData:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"writevAsync","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"vectors"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GOutputVector","kind":"typeIdentifier"},{"text":">!, ","kind":