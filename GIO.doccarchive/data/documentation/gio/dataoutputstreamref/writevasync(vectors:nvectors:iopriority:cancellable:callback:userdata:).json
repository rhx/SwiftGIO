{"sections":[],"abstract":[{"type":"text","text":"Request an asynchronous write of the bytes contained in "},{"code":"nVectors","type":"codeVoice"},{"text":" ","type":"text"},{"code":"vectors","type":"codeVoice"},{"type":"text","text":" into"},{"type":"text","text":" "},{"type":"text","text":"the stream. When the operation is finished "},{"type":"codeVoice","code":"callback"},{"text":" will be called.","type":"text"},{"type":"text","text":" "},{"text":"You can then call ","type":"text"},{"code":"g_output_stream_writev_finish()","type":"codeVoice"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"text":"operation.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dataoutputstreamref\/writevasync(vectors:nvectors:iopriority:cancellable:callback:userdata:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"role":"symbol","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"writevAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"vectors"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GOutputVector"},{"text":">!, ","kind":"text"},{"text":"nVectors","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"modules":[{"name":"GIO"}],"externalID":"s:3GIO20OutputStreamProtocolPAAE11writevAsync7vectors8nVectors10ioPriority11cancellable8callback8userDataySPySo14_GOutputVectorVGSg_S2iAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgAZtF::SYNTHESIZED::s:3GIO19DataOutputStreamRefV","extendedModule":"GIO","symbolKind":"method","title":"writevAsync(vectors:nVectors:ioPriority:cancellable:callback:userData:)"},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/writevAsync(vectors:nVectors:ioPriority:cancellable:callback:userData:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"writevAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"vectors"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"GOutputVector","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"nVectors","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","precis