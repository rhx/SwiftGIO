{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dataoutputstreamref\/writev(vectors:nvectors:byteswritten:cancellable:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DataOutputStreamRef\/writev(vectors:nVectors:bytesWritten:cancellable:)"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"writev","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"vectors"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"GOutputVector","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"nVectors","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">! = nil, "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"nVectors","type":"codeVoice"},{"text":" is 0 or the sum of all bytes in ","type":"text"},{"type":"codeVoice","code":"vectors"},{"text":" is 0, returns 0 and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"does nothing."}]},{"inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"text":" ","type":"text"},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"type":"text","text":" "},{"text":"can happen e.g. on a partial I\/O error, or if there is not enough","type":"text"},{"text":" ","type":"text"},{"text":"storage in the stream. All writes block until at least one byte","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"type":"text","text":" "},{"code":"nVectors","type":"codeVoice"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"code":"vectors","type":"codeVoice"},{"text":" is 0).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"text":" ","type":"text"},{"text":"partial result will be returned, without an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Some implementations of ","type":"text"},{"code":"g_output_stream_writev()","type":"codeVoice"},{"text":" may have limitations on the","type":"text"},{"text":" ","type":"text"},{"text":"aggregate buffer size, and will return ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" if these"},{"type":"text","text":" "},{"type":"text","text":"are exceeded. For example, when writing to a local file on UNIX platforms,"},{"type":"text","text":" "},{"text":"the aggregate buffer size must not exceed ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" bytes."}]}],"kind":"content"}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writev","kind":"identifier"},{"text":"(","kind":"text"},{"text":"vectors","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GOutputVector"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"nVectors"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gsize","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","title":"writev(vectors:nVectors:bytesWritten:cancellable:)","modules":[{"name":"GIO"}],"externalID":"s:3GIO20OutputStreamProtocolPAAE6writev7vectors8nVectors12bytesWritten11cancellableSbSPySo14_GOutputVectorVGSg_SiSpySuGSgAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO19DataOutputStreamRefV","roleHeading":"Instance Method","extendedModule":"GIO","symbolKind":"method"},"sections":[],"abstract":[{"type":"tex