{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GSocketService","type":"codeVoice"},{"type":"text","text":" is an object that represents a service that"},{"type":"text","text":" "},{"type":"text","text":"is provided to the network or over local sockets.  When a new"},{"text":" ","type":"text"},{"type":"text","text":"connection is made to the service the [signal[SocketService](\/\/documentation\/gio\/socketservice\/onincoming(flags:handler:)]"},{"text":" ","type":"text"},{"text":"signal is emitted.","type":"text"}],"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/SocketListenerProtocol"],"title":"Inherits From"},{"title":"Inherited By","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketServiceProtocol"],"kind":"relationships","type":"inheritedBy"},{"title":"Conforming Types","kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SocketService","doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef","doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketService","doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketServiceRef"],"type":"conformingTypes"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketServiceProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListenerProtocol","text":"SocketListenerProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO22SocketListenerProtocolP"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"GSocketService","type":"codeVoice"},{"type":"text","text":" is a subclass of [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference","isActive":true},{"type":"text","text":"] and you need"},{"type":"text","text":" "},{"type":"text","text":"to add the addresses you want to accept connections on with the"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","isActive":true},{"type":"text","text":"] APIs."}]},{"type":"paragraph","inlineContent":[{"text":"There are two options for implementing a network service based on","type":"text"},{"type":"text","text":" "},{"code":"GSocketService","type":"codeVoice"},{"text":". The first is to create the service using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[ctor"},{"code":"Gio.SocketService.new","type":"codeVoice"},{"text":"] and to connect to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[signal[SocketService](\/\/documentation\/gio\/socketservice\/onincoming(flags:handler:)] signal. The second is to subclass"},{"text":" ","type":"text"},{"code":"GSocketService","type":"codeVoice"},{"type":"text","text":" and override the default signal handler implementation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In either case, the handler must immediately return, or else it"},{"text":" ","type":"text"},{"type":"text","text":"will block additional incoming connections from being serviced."},{"type":"text","text":" "},{"text":"If you are interested in writing connection handlers that contain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"blocking code then see [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketService","type":"reference","isActive":true},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The socket service runs on the main loop of the"},{"text":" ","type":"text"},{"type":"text","text":"thread-default context (see"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"type":"text","text":"]) of the thread it is"},{"type":"text","text":" "},{"type":"text","text":"created in, and is not threadsafe in general. However, the calls to start and"},{"text":" ","type":"text"},{"text":"stop the service are thread-safe so these can be used from threads that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handle incoming clients."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceProtocol","type":"reference","isActive":true},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GSocketService"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketService","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef"},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"metadata":{"role":"symbol","externalID":"s:3GIO21SocketServiceProtocolP","roleHeading":"Protocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"SocketServiceProtocol","kind":"identifier"}],"symbolKind":"protocol","navigatorTitle":[{"kind":"identifier","text":"SocketServiceProtocol"}],"title":"SocketServiceProtocol","modules":[{"