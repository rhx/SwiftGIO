{"relationshipsSections":[{"title":"Inherited By","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection"],"kind":"relationships","type":"inheritedBy"},{"kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP"],"title":"Conforms To","type":"conformsTo"}],"metadata":{"symbolKind":"class","role":"symbol","navigatorTitle":[{"text":"DatagramBased","kind":"identifier"}],"externalID":"s:3GIO13DatagramBasedC","modules":[{"name":"GIO"}],"roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"DatagramBased","kind":"identifier"}],"title":"DatagramBased"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datagrambased"]}],"topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(_:)-1j4x5","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(_:)-1sxq9","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(_:)-2612o","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(_:)-8zzpb","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(_:)-9w615","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(raw:)-49cxw","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(raw:)-8mn9r","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(retainingRaw:)-28j5f","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(retainingRaw:)-63dtq"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/metatypeReferenceForDatagramBased","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/ptr","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/wrapperForDatagramBased"]},{"generated":true,"title":"Type Properties","anchor":"Type-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/metatypeForDatagramBased"]},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/DatagramBasedProtocol-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBased"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GDatagramBased"},{"text":" is a networking interface for representing datagram-based","type":"text"},{"type":"text","text":" "},{"type":"text","text":"communications. It is a more or less direct mapping of the core parts of the"},{"type":"text","text":" "},{"type":"text","text":"BSD socket API in a portable GObject interface. It is implemented by"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true},{"text":"], which wraps the UNIX socket API on UNIX and winsock2 on Windows.","type":"text"}]},{"inlineContent":[{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":" is entirely platform independent, and is intended to be used"},{"text":" ","type":"text"},{"text":"alongside higher-level networking APIs such as [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","type":"reference","isActive":true},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It uses vectored scatter\/gather I\/O by default, allowing for many messages"},{"type":"text","text":" "},{"type":"text","text":"to be sent or received in a single call. Where possible, implementations of"},{"text":" ","type":"text"},{"type":"text","text":"the interface should take advantage of vectored I\/O to minimise processing"},{"text":" ","type":"text"},{"text":"or system calls. For example, ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"text":" uses ","type":"text"},{"code":"recvmmsg()","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"sendmmsg()"},{"type":"text","text":" "},{"text":"where possible. Callers should take advantage of scatter\/gather I\/O (the use of","type":"text"},{"type":"text","text":" "},{"text":"multiple buffers per message) to avoid unnecessary copying of data to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"assemble or disassemble a message."}]},{"inlineContent":[{"text":"Each ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":" operation has a timeout parameter which may be negative"},{"type":"text","text":" "},{"type":"text","text":"for blocking behaviour, zero for non-blocking behaviour, or positive for"},{"text":" ","type":"text"},{"text":"timeout behaviour. A blocking operation blocks until finished or there is an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"error. A non-blocking operation will return immediately with a"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_IO_ERROR_WOULD_BLOCK"},{"type":"text","text":" error if it cannot make progress. A timeout operation"},{"type":"text","text":" "},{"text":"will block until the operation is complete or the timeout expires; if the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"timeout expires it will return what progress it made, or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_IO_ERROR_TIMED_OUT"},{"type":"text","text":" if no progress was made. To know when a call would"},{"type":"text","text":" "},{"type":"text","text":"successfully run you can call [method"},{"code":"Gio.DatagramBased.condition_check","type":"codeVoice"},{"type":"text","text":"] or"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.DatagramBased.condition_wait"},{"text":"]. You can also use","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"Gio.DatagramBased.create_source","type":"codeVoice"},{"type":"text","text":"] and attach it to a [struct[MainContext](\/\/documentation\/glib\/maincontext]"},{"type":"text","text":" "},{"type":"text","text":"to get callbacks when I\/O is possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running a non-blocking operation applications should always be able to"},{"type":"text","text":" "},{"type":"text","text":"handle getting a "},{"code":"G_IO_ERROR_WOULD_BLOCK","type":"codeVoice"},{"text":" error even when some other function","type":"text"},{"type":"text","text":" "},{"text":"said that I\/O was possible. This can easily happen in case of a race","type":"text"},{"text":" ","type":"text"},{"text":"condition in the application, but it can also happen for other reasons. For","type":"text"},{"type":"text","text":" "},{"text":"instance, on Windows a socket is always seen as writable until a write","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"G_IO_ERROR_WOULD_BLOCK"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"As with ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":"s can be either connection oriented (for"},{"text":" ","type":"text"},{"type":"text","text":"example, SCTP) or connectionless (for example, UDP). "},{"type":"codeVoice","code":"GDatagramBased"},{"text":"s must be","type":"text"},{"type":"text","text":" "},{"text":"datagram-based, not stream-based. The interface does not cover connection","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"establishment — use methods on the underlying type to establish a connection"},{"text":" ","type":"text"},{"text":"before sending and receiving data through the ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"text":" API. For","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connectionless socket types the target\/source address is specified or"},{"type":"text","text":" "},{"text":"received in each I\/O operation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Like most other APIs in GLib, "},{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":" is not inherently thread safe."},{"text":" ","type":"text"},{"type":"text","text":"To use a "},{"type":"codeVoice","code":"GDatagramBased"},{"text":" concurrently from multiple threads, you must","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implement your own locking."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"type":"text","text":" type acts as an owner of an underlying "},{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GDatagramBased","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"abstract":[{"type":"text","text":"Interface for socket-like objects with datagram semantics."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/DatagramBased":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/datagrambased","abstract":[{"type":"text","text":"Interface for socket-like objects with datagram semantics."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBased"}],"title":"DatagramBased","navigatorTitle":[{"text":"DatagramBased","kind":"identifier"}]},"doc://GIO/documentation/GIO/DatagramBased/init(opaquePointer:)":{"abstract":[{"type":"text","text":"Unsafe untyped initialiser."},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"Do not use unless you know the underlying data type the pointer points to conforms to ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","isActive":true},{"type":"text","text":"."}]}],"type":"topic","role":"symbol","title":"init(opaquePointer:)","kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"opaquePointer"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s13OpaquePointerV","text":"OpaquePointer"},{"text":")","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(opaquePointer:)","url":"\/documentation\/gio\/datagrambased\/init(opaquepointer:)"},"doc://GIO/documentation/GIO/DatagramBased/init(raw:)-49cxw":{"kind":"symbol","abstract":[{"type":"text","text":"Unsafe untyped initialiser."},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"Do not use unless you know the underlying data type the pointer points to conforms to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","type":"reference"},{"text":".","type":"text"}]}],"title":"init(raw:)","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"text":"raw","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"kind":"text","text":")"}],"url":"\/documentation\/gio\/datagrambased\/init(raw:)-49cxw","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/init(raw:)-49cxw","role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/DtlsConnection":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DtlsConnection","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"DtlsConnection"}],"abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"type":"text","text":" is the base DTLS connection class type, which wraps"},{"text":" ","type":"text"},{"text":"a [iface","type":"text"},{"t