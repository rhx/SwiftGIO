fier"},{"kind":"text","text":"!"}],"symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"GIO"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseRef\/lookupCertificateIssuer(certificate:interaction:flags:cancellable:)-4d2r8"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"lookupCertificateIssuer","kind":"identifier"},{"kind":"text","text":"<"},{"text":"TLSCertificateT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"certificate"},{"text":": ","kind":"text"},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"interaction","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO17TLSInteractionRefV","text":"TLSInteractionRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@EA@GTlsDatabaseLookupFlags","kind":"typeIdentifier","text":"GTlsDatabaseLookupFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef"},{"text":"! ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","kind":"typeIdentifier","text":"TLSCertificateProtocol"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function can block. Use "},{"code":"g_tls_database_lookup_certificate_issuer_async()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to perform the lookup operation asynchronously."}]},{"inlineContent":[{"type":"text","text":"Beware this function cannot be used to build certification paths. The"},{"type":"text","text":" "},{"type":"text","text":"issuer certificate returned by this function may not be the same as"},{"type":"text","text":" "},{"text":"the certificate that would actually be used to construct a valid","type":"text"},{"type":"text","text":" "},{"text":"certification path during certificate verification.","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/datatracker.ietf.org\/doc\/html\/rfc4158","isActive":true},{"text":" explains","type":"text"},{"text":" ","type":"text"},{"text":"why an issuer certificate cannot be naively assumed to be part of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the certification path (though GLib’s TLS backends may not follow the"},{"text":" ","type":"text"},{"text":"path building strategies outlined in this RFC). Due to the complexity","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of certification path building, GLib does not provide any way to know"},{"type":"text","text":" "},{"text":"which certification path will actually be used when verifying a TLS","type":"text"},{"type":"text","text":" "},{"text":"certificate. Accordingly, this function cannot be used to make","type":"text"},{"type":"text","text":" "},{"text":"security-related decisions. Only GLib itself should make security","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"decisions about TLS certificates."}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Look up the issuer of "},{"code":"certificate","type":"codeVoice"},{"type":"text","text":" in the database. The"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"type":"text","text":" property of "},{"type":"codeVoice","code":"certificate"},{"text":" is not modified, and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the two certificates are not hooked into a chain."}],"references":{"doc://GIO/documentation/GIO/TLSDatabaseRef":{"type":"topic","abstract":[{"type":"codeVoice","code":"GTlsDatabase"},{"type":"text","text":" is used to look up certificates and other information"},{"type":"text","text":" "},{"text":"from a certificate or key store. It is an abstract base class which","type":"text"},{"type":"text","text":" "},{"type":"text","text":"TLS library specific subtypes override."}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"TLSDatabaseRef","kind":"identifier"}],"role":"symbol","kind":"symbol","title":"TLSDatabaseRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseRef","url":"\/documentation\/gio\/tlsdatabaseref","navigatorTitle":[{"kind":"identifier","text":"TLSDatabaseRef"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/TLSCertificate":{"role":"symbol","kind":"symbol","title":"TLSCertifica