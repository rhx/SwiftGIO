xt"},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier","text":"TLSCertificateFlags"}],"externalID":"s:3GIO19TLSDatabaseProtocolPAAE6verify5chain7purpose8identity11interaction5flags11cancellableAA19TLSCertificateFlagsVqd___SPys4Int8VGSgAA20SocketConnectableRefVSgAA014TLSInteractionP0VSgAA0b6VerifyL0VAA011CancellableP0VSgtKAA0kC0Rd__lF::SYNTHESIZED::s:3GIO14TLSDatabaseRefV","symbolKind":"method","roleHeading":"Instance Method","extendedModule":"GIO","title":"verify(chain:purpose:identity:interaction:flags:cancellable:)"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"verify","kind":"identifier"},{"text":"<","kind":"text"},{"text":"TLSCertificateT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"chain","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"TLSCertificateT"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"purpose"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"text":"identity","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableRef","kind":"typeIdentifier","text":"SocketConnectableRef","preciseIdentifier":"s:3GIO20SocketConnectableRefV"},{"text":"? = nil, ","kind":"text"},{"text":"interaction","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionRef","text":"TLSInteractionRef","preciseIdentifier":"s:3GIO17TLSInteractionRefV","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO22TLSDatabaseVerifyFlagsV","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseVerifyFlags","text":"TLSDatabaseVerifyFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","text":"TLSCertificateFlags"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"TLSCertificateT"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","text":"TLSCertificateProtocol"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"code":"chain","type":"codeVoice"},{"text":" is a chain of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference","isActive":true},{"text":" objects each pointing to the next","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate in the chain by its "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true},{"type":"text","text":" property."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"purpose"},{"text":" describes the purpose (or usage) for which the certificate","type":"text"},{"text":" ","type":"text"},{"text":"is being used. Typically ","type":"text"},{"type":"codeVoice","code":"purpose"},{"type":"text","text":" will be set to "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/tlsDatabasePurposeAuthenticateServer","isActive":true},{"type":"text","text":" "},{"type":"text","text":"which means that the certificate is being used to authenticate a server"},{"type":"text","text":" "},{"text":"(and we are acting as the client).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"identity"},{"type":"text","text":" is used to ensure the server certificate is valid for"},{"type":"text","text":" "},{"text":"the expected peer identity. If the identity does not match the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate, "},{"type":"codeVoice","code":"badIdentity"},{"text":" will be set in the","type":"text"},{"text":" ","type":"text"},{"text":"return value. If ","type":"text"},{"code":"identity","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":", that bit will never be set in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the return value. The peer identity may also be used to check for"},{"type":"text","text":" "},{"type":"text","text":"pinned certificates (trust exceptions) in the database. These may"},{"type":"text","text":" "},{"type":"text","text":"override the normal verification process on a host-by-host basis."}]},{"type":"paragraph","inlineContent":[{"text":"Currently there are no ","type":"text"},{"type":"codeVoice","code":"flags"},{"type":"text","text":", and "},{"type":"codeVoice","code":"none"},{"text":" should be","type":"text"},{"text":" ","type":"text"},{"text":"used.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"chain","type":"codeVoice"},{"text":" is found to be valid, then the return value will be 0. If","type":"text"},{"text":" ","type":"text"},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is found to be invalid, then the return value will indicate at"},{"text":" ","type":"text"},{"text":"least one problem found. If the function is unable to determine","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"whether "},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is valid (for example, because "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"triggered before it completes) then the return value will be","type":"text"},{"text":" ","type":"text"},{"code":"genericError","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" will be set accordingly."},{"text":" ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is not set when "},{"type":"codeVoice","code":"chain"},{"type":"text","text":" is successfully analyzed but found to"},{"text":" ","type":"text"},{"text":"be invalid.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"type":"text","text":" "},{"text":"error will be set in the return value, but it does not guarantee","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that all possible errors will be set. Accordingly, you may not safely"},{"type":"text","text":" "},{"text":"decide to ignore any particular type of error. For example, it would","type":"text"},{"text":" ","type":"text"},{"text":"be incorrect to mask ","type":"text"},{"type":"codeVoice","code":"expired"},{"type":"text","text":" if you want to allow"},{"text":" ","type":"text"},{"text":"expired certificates, because this could potentially be the only","type":"text"},{"type":"text","text":" "},{"text":"error flag set even if other problems exist with the certificate.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Prior to GLib 2.48, GLib’s default TLS backend modified "},{"type":"codeVoice","code":"chain"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"represent the certification path built by "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase"},{"text":" during","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate verification by adjusting the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"property of each certificate in "},{"type":"codeVoice","code":"chain"},{"text":". Since GLib 2.48, this no","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"longer occurs, so you cannot rely on "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true,"type":"reference"},{"text":" to","type":"text"},{"type":"text","text":" "},{"text":"represent the actual certification path used during certificate","type":"text"},{"text":" ","type":"text"},{"text":"verification.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because TLS session context is not used, "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","type":"reference"},{"text":" may not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"perform as many checks on the certificates as "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"type":"text","text":" would."},{"text":" ","type":"text"},{"type":"text","text":"For example, certificate constraints may not be honored, and"},{"type":"text","text":" "},{"type":"text","text":"revocation checks may not be performed. The best way to verify TLS"},{"type":"text","text":" "},{"text":"certificates used by a TLS connection is to let ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" "},{"text":"handle the verification.","type":"text"}]},{"inlineContent":[{"text":"The TLS backend may attempt to look up and add missing certificates","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the chain. This may involve HTTP requests to download missing"},{"text":" ","type":"text"},{"type":"text","text":"certificates."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function can block. Use "},{"type":"codeVoice","code":"g_tls_database_verify_chain_async()"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"type":"text","text":"perform the verification operation asynchronously."}]}]}],"variants":[{"paths":["\/documentation\/gio\/tlsdatabaseref\/verify(chain:purpose:identity:interaction:flags:cancellable:)-1e25e"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Determines the validity of a certificate chain, outside the context"},{"text":" ","type":"text"},{"text":"of a TLS session.","type":"text"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"//documentation/gio/tlsconnection/onacceptcertificate(flags:handler:)":{"titleInlineContent":[{"type":"text","text":"TLSConnection"}],"identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","url":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","title":"TLSConnection","type":"link"},"doc://GIO/documentation/GIO/TLSCertificateProtocol":{"type":"topic","navigatorTitle":[{"text":"TLSCertificateProtocol","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol","url":"\/documentation\/gio\/tlscertificateprotocol","title":"TLSCertificateProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TLSCertificateProtocol"}],"abstract":[{"text":"A certificate used for TLS authentication and encryption.","type":"text"},{"text":" ","type":"te