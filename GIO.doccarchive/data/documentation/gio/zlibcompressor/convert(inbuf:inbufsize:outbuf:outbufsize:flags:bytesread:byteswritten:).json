{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ZlibCompressor\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"convert","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"inbuf"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"outbuf"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"outbufSize"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConverterFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ConverterFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"bytesRead"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier","text":"gsize"},{"kind":"text","text":">!, "},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:@EA@GConverterResult","text":"GConverterResult","kind":"typeIdentifier"}],"symbolKind":"method","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","modules":[{"name":"GIO"}],"role":"symbol","extendedModule":"GIO","roleHeading":"Instance Method","externalID":"s:3GIO17ConverterProtocolPAAE7convert5inbuf0E4Size6outbuf0gF05flags9bytesRead0I7WrittenSo16GConverterResultaSvSg_SiANSiAA0B5FlagsVSpySuGSgARtKF::SYNTHESIZED::s:3GIO14ZlibCompressorC"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"convert","kind":"identifier"},{"kind":"text","text":"("},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"outbuf","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"outbufSize"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags"},{"kind":"text","text":", "},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!, "},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"GConverterResult","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Note that a single call may not consume all input (or any input at all).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Also a call may produce output even if given no input, due to state stored"},{"text":" ","type":"text"},{"type":"text","text":"in the converter producing output."}]},{"inlineContent":[{"text":"If any data was either produced or consumed, and then an error happens, then","type":"text"},{"text":" ","type":"text"},{"text":"only the successful conversion is reported and the error is returned on the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"next call."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A full conversion loop involves calling this method repeatedly, each time"},{"text":" ","type":"text"},{"type":"text","text":"giving it new input and space output space. When there is no more input"},{"type":"text","text":" "},{"text":"data after the data in ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", the flag "},{"code":"inputAtEnd","type":"codeVoice"},{"type":"text","text":" must be set."},{"text":" ","type":"text"},{"text":"The loop will be (unless some error happens) returning ","type":"text"},{"code":"converted","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"each time until all data is consumed and all output is produced, then"},{"text":" ","type":"text"},{"type":"codeVoice","code":"finished"},{"type":"text","text":" is returned instead. Note, that "},{"code":"finished","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"may be returned even if "},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" is not set, for instance"},{"text":" ","type":"text"},{"type":"text","text":"in a decompression converter where the end of data is detectable from the"},{"text":" ","type":"text"},{"type":"text","text":"data (and there might even be other data after the end of the compressed data)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When some data has successfully been converted "},{"type":"codeVoice","code":"bytesRead"},{"type":"text","text":" and is set to"},{"type":"text","text":" "},{"text":"the number of bytes read from ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", and "},{"type":"codeVoice","code":"bytesWritten"},{"text":" is set to indicate","type":"text"},{"text":" ","type":"text"},{"text":"how many bytes was written to ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":". If there are more data to output"},{"text":" ","type":"text"},{"text":"or consume (i.e. unless the ","type":"text"},{"code":"inputAtEnd","type":"codeVoice"},{"text":" is specified) then","type":"text"},{"type":"text","text":" "},{"code":"converted","type":"codeVoice"},{"type":"text","text":" is returned, and if no more data is to be output"},{"text":" ","type":"text"},{"type":"text","text":"then "},{"type":"codeVoice","code":"finished"},{"text":" is returned.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On error "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is returned and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly."},{"text":" ","type":"text"},{"text":"Some errors need special handling:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"noSpace","type":"codeVoice"},{"text":" is returned if there is not enough space","type":"text"},{"type":"text","text":" "},{"text":"to write the resulting converted data, the application should","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call the function again with a larger "},{"code":"outbuf","type":"codeVoice"},{"type":"text","text":" to continue."}]},{"inlineContent":[{"type":"codeVoice","code":"partialInput"},{"text":" is returned if there is not enough","type":"text"},{"type":"text","text":" "},{"type":"text","text":"input to fully determine what the conversion should produce,"},{"type":"text","text":" "},{"text":"and the ","type":"text"},{"code":"inputAtEnd","type":"codeVoice"},{"type":"text","text":" flag is not set. This happens for"},{"type":"text","text":" "},{"type":"text","text":"example with an incomplete multibyte sequence when converting text,"},{"type":"text","text":" "},{"type":"text","text":"or when a regexp matches up to the end of the input (and may match"},{"type":"text","text":" "},{"type":"text","text":"further input). It may also happen when "},{"type":"codeVoice","code":"inbufSize"},{"type":"text","text":" is zero and"},{"type":"text","text":" "},{"type":"text","text":"there is no more data to produce."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"When this happens the application should read more input and then","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call the function again. If further input shows that there is no"},{"type":"text","text":" "},{"text":"more data call the function again with the same data but with","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" flag set. This may cause the conversion"},{"text":" ","type":"text"},{"text":"to finish as e.g. in the regexp match case (or, to fail again with","type":"text"},{"type":"text","text":" "},{"code":"partialInput","type":"codeVoice"},{"text":" in e.g. a charset conversion where the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"input is actually partial)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After "},{"type":"codeVoice","code":"g_converter_convert()"},{"text":" has returned ","type":"text"},{"code":"finished","type":"codeVoice"},{"text":" the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"converter object is in an invalid state where its not allowed"},{"text":" ","type":"text"},{"text":"to call ","type":"text"},{"type":"codeVoice","code":"g_converter_convert()"},{"text":" anymore. At this time you can only","type":"text"},{"text":" ","type":"text"},{"text":"free the object or call ","type":"text"},{"code":"g_converter_reset()","type":"codeVoice"},{"text":" to reset it to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initial state."}]},{"inlineContent":[{"type":"text","text":"If the flag "},{"type":"codeVoice","code":"flush"},{"text":" is set then conversion is modified","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to try to write out all internal state to the output. The application"},{"type":"text","text":" "},{"text":"has to call the function multiple times with the flag set, and when","type":"text"},{"text":" ","type":"text"},{"text":"the available input has been consumed and all internal state has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been produced then "},{"code":"flushed","type":"codeVoice"},{"type":"text","text":" (or "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" if"},{"type":"text","text":" "},{"type":"text","text":"really at the end) is returned instead of "},{"type":"codeVoice","code":"converted"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This is somewhat similar to what happens at the end of the input stream,"},{"type":"text","text":" "},{"text":"but done in the middle of the data.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This has different meanings for different conversions. For instance"},{"type":"text","text":" "},{"type":"text","text":"in a compression converter it would mean that we flush all the"},{"text":" ","type":"text"},{"type":"text","text":"compression state into output such that if you uncompress the"},{"type":"text","text":" "},{"type":"text","text":"compressed data you get back all the input data. Doing this may"},{"type":"text","text":" "},{"type":"text","text":"make the final file larger due to padding though. Another example"},{"type":"text","text":" "},{"type":"text","text":"is a regexp conversion, where if you at the end of the flushed data"},{"type":"text","text":" "},{"type":"text","text":"have a match, but there is also a potential longer match. In the"},{"type":"text","text":" "},{"text":"non-flushed case we would ask for more input, but when flushing we","type":"text"},{"type":"text","text":" "},{"type":"text","text":"treat this as the end of input and do the match."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Flushing is not always possible (like if a charset converter flushes"},{"text":" ","type":"text"},{"type":"text","text":"at a partial multibyte sequence). Converters are supposed to try"},{"type":"text","text":" "},{"type":"text","text":"to produce as much output as possible and then return an error"},{"text":" ","type":"text"},{"text":"(typically ","type":"text"},{"type":"codeVoice","code":"partialInput"},{"text":").","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ZlibCompressor","doc:\/\/GIO\/documentation\/GIO\/ZlibCompressor\/ConverterProtocol-Implementations"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/zlibcompressor\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)"]}],"kind":"symbol","abstract":[{"text":"This is the main operation used when converting data. It is to be called","type":"text"},{"type":"text","text":" "},{"type":"text","text":"multiple times in a loop, and each time it will do some work, i.e."},{"text":" ","type":"text"},{"text":"producing some output (in ","type":"text"},{"code":"outbuf","type":"codeVoice"},{"type":"text","text":") or consuming some input (from "},{"code":"inbuf","type":"codeVoice"},{"text":") or","type":"text"},{"text":" ","type":"text"},{"text":"both. If its not possible to do any work an error is returned.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GIO/documentation/GIO/ConverterFlags":{"abstract":[{"type":"text","text":"Flags used when calling a "},{"type":"codeVoice","code":"g_converter_convert()"},{"text":".","type":"text"}],"title":"ConverterFlags","url":"\/documentation\/gio\/converterflags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConverterFlags"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","kind":"symbol","navigatorTitle":[{"text":"ConverterFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/ZlibCompressor/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)":{"url":"\/documentation\/gio\/zlibcompressor\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"convert","kind":"identifier"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"outbuf","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"text":"outbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConverterFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ConverterFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"bytesRead"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!, ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"kind":"text","text":">!) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"GConverterResult","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult"}],"kind":"symbol","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ZlibCompressor\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","abstract":[{"type":"text","text":"This is the main operation used when converting data. It is to be called"},{"text":" ","type":"text"},{"text":"multiple times in a loop, and each time it will do some work, i.e.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"producing some output (in "},{"type":"codeVoice","code":"outbuf"},{"text":") or consuming some input (from ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"text":") or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"both. If its not possible to do any work an error is returned."}],"type":"topic"},"doc://GIO/documentation/GIO/ZlibCompressor/ConverterProtocol-Implementations":{"url":"\/do