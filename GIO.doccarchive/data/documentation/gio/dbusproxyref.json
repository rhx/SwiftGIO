{"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef","interfaceLanguage":"swift"},"abstract":[{"code":"GDBusProxy","type":"codeVoice"},{"type":"text","text":" is a base class used for proxies to access a D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"interface on a remote object. A "},{"code":"GDBusProxy","type":"codeVoice"},{"text":" can be constructed for","type":"text"},{"type":"text","text":" "},{"text":"both well-known and unique names.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(_:)-3eelh","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(_:)-4anre","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(_:)-70o4i","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(_:)-7nr04","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(_:)-80s3w","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(busFinish:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(busSync:flags:info:name:objectPath:interfaceName:cancellable:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(finish:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/init(sync:flags:info:name:objectPath:interfaceName:cancellable:)"],"title":"Initializers","anchor":"Initializers","generated":true},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/ptr"],"title":"Instance Properties"},{"generated":true,"anchor":"Type-Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/new(finish:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/new(sync:flags:info:name:objectPath:interfaceName:cancellable:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/newFor(busFinish:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/newFor(busSync:flags:info:name:objectPath:interfaceName:cancellable:)","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/unowned(_:)"],"title":"Type Methods"},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/AsyncInitableProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/DBusInterfaceProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/DBusProxyProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/GWeakCapturing-Implementations","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/InitableProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/ObjectProtocol-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DBusProxyRef"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"By default, "},{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":" will cache all properties (and listen to"},{"type":"text","text":" "},{"type":"text","text":"changes) of the remote object, and proxy all signals that get"},{"text":" ","type":"text"},{"type":"text","text":"emitted. This behaviour can be changed by passing suitable"},{"text":" ","type":"text"},{"text":"[flags","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyFlags"},{"type":"text","text":"] when the proxy is created. If the proxy is for a"},{"type":"text","text":" "},{"type":"text","text":"well-known name, the property cache is flushed when the name owner"},{"type":"text","text":" "},{"text":"vanishes and reloaded when a name owner appears.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The unique name owner of the proxy’s name is tracked and can be read from"},{"text":" ","type":"text"},{"text":"[property","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxy","type":"reference"},{"type":"text","text":"]. Connect to the"},{"type":"text","text":" "},{"type":"text","text":"[signal[Object](\/\/documentation\/gobject\/object\/onnotify(flags:handler:)] signal to get notified of changes."},{"text":" ","type":"text"},{"text":"Additionally, only signals and property changes emitted from the current name","type":"text"},{"text":" ","type":"text"},{"text":"owner are considered and calls are always sent to the current name owner.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This avoids a number of race conditions when the name is lost by one owner"},{"type":"text","text":" "},{"type":"text","text":"and claimed by another. However, if no name owner currently exists,"},{"type":"text","text":" "},{"text":"then calls will be sent to the well-known name which may result in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the message bus launching an owner (unless"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_DBUS_PROXY_FLAGS_DO_NOT_AUTO_START"},{"type":"text","text":" is set)."}],"type":"paragraph"},{"inlineContent":[{"text":"If the proxy is for a stateless D-Bus service, where the name owner may","type":"text"},{"type":"text","text":" "},{"text":"be started and stopped between calls, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[property"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxy","isActive":true},{"type":"text","text":"] tracking of "},{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":" will cause the"},{"text":" ","type":"text"},{"text":"proxy to drop signal and property changes from the service after it has","type":"text"},{"text":" ","type":"text"},{"text":"restarted for the first time. When interacting with a stateless D-Bus","type":"text"},{"type":"text","text":" "},{"text":"service, do not use ","type":"text"},{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":" — use direct D-Bus method calls and signal"},{"text":" ","type":"text"},{"type":"text","text":"connections."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The generic [signal[DBusProxy](\/\/documentation\/gio\/dbusproxy\/ongpropertieschanged(flags:handler:)] and"},{"text":" ","type":"text"},{"type":"text","text":"[signal[DBusProxy](\/\/documentation\/gio\/dbusproxy\/ongsignal(flags:handler:)] signals are not very convenient to work"},{"type":"text","text":" "},{"type":"text","text":"with. Therefore, the recommended way of working with proxies is to subclass"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":", and have more natural properties and signals in your derived"},{"type":"text","text":" "},{"type":"text","text":"class. This "},{"type":"reference","identifier":"migrating-gdbus.html#using-gdbus-codegen","isActive":true},{"type":"text","text":" shows how"},{"text":" ","type":"text"},{"type":"text","text":"this can easily be done using the "},{"isActive":true,"identifier":"gdbus-codegen.html","type":"reference"},{"type":"text","text":" tool."}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GDBusProxy"},{"text":" instance can be used from multiple threads but note","type":"text"},{"type":"text","text":" "},{"text":"that all signals (e.g. [signal[DBusProxy](\/\/documentation\/gio\/dbusproxy\/ongsignal(flags:handler:)],","type":"text"},{"type":"text","text":" "},{"text":"[signal[DBusProxy](\/\/documentation\/gio\/dbusproxy\/ongpropertieschanged(flags:handler:)] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[signal"},{"identifier":"\/\/documentation\/gobject\/object\/onnotify(flags:handler:)]","type":"reference","isActive":true},{"text":" are emitted in the thread-default main","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"context (see [method"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"]) of the thread","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where the instance was constructed."}]},{"level":2,"type":"heading","text":"A watch proxy example","anchor":"A-watch-proxy-example"},{"inlineContent":[{"text":"An example using a proxy for a well-known name can be found in","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gdbus-example-watch-proxy.c"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GDBusProxy","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyProtocol"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GDBusProxy","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxy","type":"reference"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef","type":"reference","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/gio\/dbusproxyref"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","metadata":{"navigatorTitle":[{"text":"DBusProxyRef","kind":"identifier"}],"title":"DBusProxyRef","roleHeading":"Structure","symbolKind":"struct","externalID":"s:3GIO12DBusProxyRefV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusProxyRef","kind":"identifier"}],"role":"symbol","modules":[{"name":"GIO"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AsyncInitableProtocol","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceProtocol","doc:\/\/GIO\/documentation\/GIO\/DBusProxyProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/InitableProtocol"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"references":{"doc://GIO/documentation/GIO/DBusProxyProtocol/dbus_proxy_ptr-4nch8":{"title":"dbus_proxy_ptr","defaultImplementations":1,"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyProtocol\/dbus_proxy_ptr-4nch8","url":"\/documentation\/gio\/dbusproxyprotocol\/dbus_proxy_ptr-4nch8","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"dbus_proxy_ptr"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePoint