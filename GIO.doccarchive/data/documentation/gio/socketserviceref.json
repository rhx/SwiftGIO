{"abstract":[{"text":"A ","type":"text"},{"code":"GSocketService","type":"codeVoice"},{"type":"text","text":" is an object that represents a service that"},{"text":" ","type":"text"},{"type":"text","text":"is provided to the network or over local sockets.  When a new"},{"text":" ","type":"text"},{"type":"text","text":"connection is made to the service the [signal[SocketService](\/\/documentation\/gio\/socketservice\/onincoming(flags:handler:)]"},{"type":"text","text":" "},{"text":"signal is emitted.","type":"text"}],"metadata":{"symbolKind":"struct","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"SocketServiceRef","kind":"identifier"}],"modules":[{"name":"GIO"}],"externalID":"s:3GIO16SocketServiceRefV","role":"symbol","navigatorTitle":[{"text":"SocketServiceRef","kind":"identifier"}],"title":"SocketServiceRef"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"SocketServiceRef","kind":"identifier"}],"languages":["swift"]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GSocketService"},{"type":"text","text":" is a subclass of [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","isActive":true,"type":"reference"},{"type":"text","text":"] and you need"},{"text":" ","type":"text"},{"text":"to add the addresses you want to accept connections on with the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","isActive":true,"type":"reference"},{"text":"] APIs.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"There are two options for implementing a network service based on","type":"text"},{"text":" ","type":"text"},{"code":"GSocketService","type":"codeVoice"},{"type":"text","text":". The first is to create the service using"},{"type":"text","text":" "},{"type":"text","text":"[ctor"},{"type":"codeVoice","code":"Gio.SocketService.new"},{"text":"] and to connect to the","type":"text"},{"text":" ","type":"text"},{"text":"[signal[SocketService](\/\/documentation\/gio\/socketservice\/onincoming(flags:handler:)] signal. The second is to subclass","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GSocketService"},{"type":"text","text":" and override the default signal handler implementation."}]},{"type":"paragraph","inlineContent":[{"text":"In either case, the handler must immediately return, or else it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will block additional incoming connections from being serviced."},{"type":"text","text":" "},{"type":"text","text":"If you are interested in writing connection handlers that contain"},{"type":"text","text":" "},{"type":"text","text":"blocking code then see [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketService","isActive":true},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The socket service runs on the main loop of the"},{"text":" ","type":"text"},{"type":"text","text":"thread-default context (see"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"text":"]) of the thread it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"created in, and is not threadsafe in general. However, the calls to start and"},{"type":"text","text":" "},{"text":"stop the service are thread-safe so these can be used from threads that","type":"text"},{"type":"text","text":" "},{"text":"handle incoming clients.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef","type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GSocketService"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceProtocol","type":"reference","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GSocketService"},{"type":"text","text":" instance."}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketService"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef","isActive":true,"type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GSocketService"},{"type":"text","text":" instance."}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketserviceref"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef","interfaceLanguage":"swift"},"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/SocketListenerProtocol","doc:\/\/GIO\/documentation\/GIO\/SocketServiceProtocol"],"kind":"relationships","type":"conformsT