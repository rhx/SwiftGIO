{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Finishes handling a D-Bus method call by returning ","type":"text"},{"type":"codeVoice","code":"parameters"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the "},{"code":"parameters","type":"codeVoice"},{"type":"text","text":" GVariant is floating, it is consumed."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef","doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef\/DBusMethodInvocationProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef\/returnValue(parameters:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","title":"returnValue(parameters:)","extendedModule":"GIO","symbolKind":"method","roleHeading":"Instance Method","externalID":"s:3GIO28DBusMethodInvocationProtocolPAAE11returnValue10parametersy4GLib10VariantRefVSg_tF::SYNTHESIZED::s:3GIO23DBusMethodInvocationRefV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"returnValue","kind":"identifier"},{"kind":"text","text":"("},{"text":"parameters","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"modules":[{"name":"GIO"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"returnValue"},{"kind":"text","text":"("},{"kind":"externalParam","text":"parameters"},{"text":": ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"It is an error if ","type":"text"},{"type":"codeVoice","code":"parameters"},{"text":" is not of the right format: it must be a tuple","type":"text"},{"text":" ","type":"text"},{"text":"containing the out-parameters of the D-Bus method. Even if the method has a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"single out-parameter, it must be contained in a tuple. If the method has no"},{"text":" ","type":"text"},{"type":"text","text":"out-parameters, "},{"type":"codeVoice","code":"parameters"},{"type":"text","text":" may be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" or an empty tuple."}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","type":"codeListing","code":["GDBusMethodInvocation *invocation = some_invocation;","g_autofree gchar *result_string = NULL;","g_autoptr (GError) error = NULL;","","result_string = calculate_result (&error);","","if (error != NULL)","  g_dbus_method_invocation_return_gerror (invocation, error);","else","  g_dbus_method_invocation_return_value (invocation,","                                         g_variant_new (\"(s)\", result_string));","","\/\/ Do not free @invocation here; returning a value does that"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method will take ownership of "},{"type":"codeVoice","code":"invocation"},{"type":"text","text":". See"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","isActive":true},{"type":"text","text":" for more information about the ownership of"},{"type":"text","text":" "},{"code":"invocation","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"Since 2.48, if the method call requested for a reply not to be sent","type":"text"},{"type":"text","text":" "},{"text":"then this call will sink ","type":"text"},{"code":"parameters","type":"codeVoice"},{"type":"text","text":" and free "},{"code":"invocation","type":"codeVoice"},{"text":", but","type":"text"},{"type":"text","text":" "},{"text":"otherwise do nothing (as per the recommendations of the D-Bus","type":"text"},{"type":"text","text":" "},{"text":"specification).","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusmethodinvocationref\/returnvalue(parameters:)"]}],"references":{"doc://GIO/documentation/GIO/DBusMethodInvocationRef/returnValue(parameters:)":{"abstract":[{"type":"text","text":"Finishes handling a D-Bus method call by returning "},{"type":"codeVoice","code":"parameters"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"If the "},{"type":"codeVoice","code":"parameters"},{"text":" GVariant is floating, it is consumed.","type":"text"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef\/returnValue(parameters:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"returnValue"},{"text":"(","kind":"text"},{"text":"parameters","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"title":"returnValue(parameters:)","url":"\/documentation\/gio\/dbusmethodinvocationref\/returnvalue(parameters:)","type":"topic"},"doc://GIO/documentation/GIO/DBusMethodInvocationRef":{"url":"\/documentation\/gio\/dbusmethodinvocationref","kind":"symbol","title":"DBusMethodInvocationRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"DBusMethodInvocationRef","kind":"identifier"}],"navigatorTitle":[{"text":"DBusMethodInvocationRef","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"Instances of the "},{"type":"codeVoice","code":"GDBusMethodInvocation"},{"text":" class are used when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handling D-Bus method calls. It provides a way to asynchronously"},{"text":" ","type":"text"},{"type":"text","text":"return results and errors."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusInterfaceVTable":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"DBusInterfaceVTable","kind":"identifier"}],"navigatorTitle":[{"text":"DBusInterfaceVTable","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","type":"topic","abstract":[{"type":"text","text":"Virtual table for handling properties and method calls for a D-Bus"},{"text":" ","type":"text"},{"text":"interface.","type":"text"}],"title":"DBusInterfaceVTable","url":"\/documentation\/gio\/dbusinterfacevtable","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/DBusMethodInvocationRef/DBusMethodInvocationProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef\/DBusMethodInvocationProtocol-Implementations","url":"\/documentation\/gio\/dbusmethodinvocationref\/dbusmethodinvocationprotocol-implementations","abstract":[],"title":"DBusMethodInvocationProtocol Implementations","kind":"article","type":"topic","role":"collectionGroup"}}}