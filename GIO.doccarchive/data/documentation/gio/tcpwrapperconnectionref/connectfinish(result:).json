 is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/AsyncResultProtocol":{"kind":"symbol","type":"topic","title":"AsyncResultProtocol","role":"symbol","abstract":[{"code":"GAsyncResult","type":"codeVoice"},{"type":"text","text":" provides a base class for implementing asynchronous function results."}],"url":"\/documentation\/gio\/asyncresultprotocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AsyncResultProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"AsyncResultProtocol"}]},"doc://GIO/documentation/GIO/TcpWrapperConnectionRef/SocketConnectionProtocol-Implementations":{"type":"topic","title":"SocketConnectionProtocol Implementations","url":"\/documentation\/gio\/tcpwrapperconnectionref\/socketconnectionprotocol-implementations","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpWrapperConnectionRef\/SocketConnectionProtocol-Implementations","kind":"article","role":"collectionGroup"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClient"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","abstract":[{"type":"codeVoice","code":"GSocketClient"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"title":"SocketClient","role":"symbol","url":"\/documentation\/gio\/socketclient","navigatorTitle":[{"kind":"identifier","text":"SocketClient"}]}}}