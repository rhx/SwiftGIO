tation\/GIO\/SocketConnection","type":"reference"},{"type":"text","text":"]. This is used by [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":"] so","type":"text"},{"type":"text","text":" "},{"text":"that it can always return a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true,"type":"reference"},{"type":"text","text":"], even when the"},{"text":" ","type":"text"},{"type":"text","text":"connection it has actually created is not directly a"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true},{"text":"].","type":"text"}],"title":"TcpWrapperConnectionRef"},"doc://GIO/documentation/GIO/InputStreamRef":{"abstract":[{"code":"GInputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming input."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"InputStreamRef","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/gio\/inputstreamref","navigatorTitle":[{"text":"InputStreamRef","kind":"identifier"}],"type":"topic","role":"symbol","title":"InputStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamRef"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they sh