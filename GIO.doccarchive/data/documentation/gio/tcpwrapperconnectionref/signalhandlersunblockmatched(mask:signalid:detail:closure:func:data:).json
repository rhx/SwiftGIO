O/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/TcpWrapperConnectionRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpWrapperConnectionRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","abstract":[],"type":"topic","role":"collectionGroup","url":"\/documentation\/gio\/tcpwrapperconnectionref\/objectprotocol-implementations","kind":"article"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TcpWrapperConnectionRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"TcpWrapperConnectionRef","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TcpWrapperConnectionRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpWrapperConnectionRef","url":"\/documentation\/gio\/tcpwrapperconnectionref","abstract":[{"text":"A ","type":"text"},{"code":"GTcpWrapperConnection","type":"codeVoice"},{"type":"text","text":" can be used to wrap a [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","type":"reference"},{"type":"text","text":"] that is"},{"type":"text","text":" "},{"type":"text","text":"based on a [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":"], but which is not actually a"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference"},{"type":"text","text":"]. This is used by [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":"] so","type":"text"},{"type":"text","text":" "},{"text":"that it can always return a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true,"type":"reference"},{"type":"text","text":"], even when the"},{"text":" ","type":"text"},{"type":"text","text":"connection it has actually created is not directly a"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true},{"text":"].","type":"text"}],"