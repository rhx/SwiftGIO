:"keyword"},{"kind":"text","text":" "},{"text":"onNotifyAddress","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServerRef","text":"DBusServerRef","preciseIdentifier":"s:3GIO13DBusServerRefV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}]},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyAddress"},{"type":"text","text":" signal is emitted"}]}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"text":" ","type":"text"},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::address"},{"type":"text","text":" signal"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusserverprotocol\/onnotifyaddress(flags:handler:)"]}],"references":{"doc://GIO/documentation/GIO/DBusServerProtocol":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusServerProtocol"}],"title":"DBusServerProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServerProtocol","abstract":[{"code":"GDBusServer","type":"codeVoice"},{"text":" is a helper for listening to and accepting D-Bus","type":"text"},{"text":" ","type":"text"},{"text":"connections. This can be used to create a new D-Bus server, allowing two","type":"text"},{"type":"text","text":" "},{"type":"text","text":"peers to use the D-Bus protocol for their own specialized communication."},{"text":" ","type":"text"},{"text":"A server instance provided in this way will not perform message routing or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implement the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#message-bus-messages"},{"text":".","type":"text"}],"navigatorTitle":[{"text":"DBusServerProtocol","kind":"identifier"}],"kind":"symbol","type":"topic","url":"\/documentation\/gio\/dbusserverprotocol"},"https://dbus.freedesktop.org/doc/dbus-specification.html#message-bus-messages":{"titleInlineContent":[{"type":"codeVoice","code":"org.freedesktop.DBus"},{"type":"text","text":" interface"}],"type":"link","title":"org.freedesktop.DBus interface","url":"https:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#message-bus-messages","identifier":"https:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#message-bus-messages"},"doc://GIO/documentation/GIO/DBusServerRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServerRe