{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"send"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputMessage"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"timeout"},{"kind":"text","text":": "},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19CancellableProtocolP"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" structs and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"type":"text","text":" "},{"type":"text","text":"contains an address to send the data to, and a pointer to an array of"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector"},{"type":"text","text":" structs to describe the buffers that the data to be sent"},{"type":"text","text":" "},{"type":"text","text":"for each message will be gathered from."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for this are available in the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true,"type":"reference"},{"text":" enum, but the","type":"text"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}]},{"inlineContent":[{"type":"text","text":"The other members of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","type":"reference","isActive":true},{"type":"text","text":" are treated as described in its"},{"type":"text","text":" "},{"type":"text","text":"documentation."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"text":" is negative the call will block until ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" have been"},{"text":" ","type":"text"},{"type":"text","text":"sent, "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled, or an error occurs."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is 0 the call will send up to "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" without blocking,"},{"type":"text","text":" "},{"type":"text","text":"or will return "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" if there is no space to send messages."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"type":"text","text":" "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" were negative. If the timeout is reached before any messages are"},{"type":"text","text":" "},{"type":"text","text":"sent, "},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned, otherwise it will return the number"},{"type":"text","text":" "},{"text":"of messages sent before timing out.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition."},{"type":"text","text":" "},{"text":"Note though that you may still receive ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"text":" from","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"text":" even if you were previously notified of a","type":"text"},{"text":" ","type":"text"},{"text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the way the underlying APIs work.)"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"type":"codeVoice","code":"shutdown_write"},{"type":"text","text":" set, if it’s a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference","isActive":true},{"type":"text","text":", for"},{"type":"text","text":" "},{"text":"example), all calls to this function will return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"type":"text","text":"be returned if zero messages could be sent; otherwise the number of messages"},{"text":" ","type":"text"},{"type":"text","text":"successfully sent before the error will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"cancelled, ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" is returned as with any other error.","type":"text"}],"type":"paragraph"}]}],"sections":[],"abstract":[{"type":"text","text":"Send one or more data messages from "},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datagrambasedprotocol\/send(messages:nummessages:flags:timeout:cancellable:)-5ji3h"]}],"metadata":{"roleHeading":"Instance Method","externalID":"s:3GIO21DatagramBasedProtocolPAAE4send8messages11numMessages5flags7timeout11cancellableSiSpySo15_GOutputMessageVGSg_S2is5Int64Vqd__SgtKAA011CancellableD0Rd__lF","role":"symbol","title":"send(messages:numMessages:flags:timeout:cancellable:)","extendedModule":"GIO","fragments"