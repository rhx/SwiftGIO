{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"receive"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"timeout","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":" : "},{"text":"CancellableProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19CancellableProtocolP"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true},{"type":"text","text":" structs and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" must be the length of this array. Each ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","type":"reference"},{"type":"text","text":" "},{"text":"contains a pointer to an array of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector"},{"text":" structs describing the","type":"text"},{"text":" ","type":"text"},{"text":"buffers that the data received in each message will be written to.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"flags","type":"codeVoice"},{"type":"text","text":" modify how all messages are received. The commonly available"},{"type":"text","text":" "},{"type":"text","text":"arguments for this are available in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"text":" ","type":"text"},{"text":"are passed in as-is, so you can pass in system-specific flags too. These","type":"text"},{"type":"text","text":" "},{"text":"flags affect the overall receive operation. Flags affecting individual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messages are returned in "},{"code":"GInputMessage.flags","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The other members of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"type":"text","text":" are treated as described in its"},{"type":"text","text":" "},{"text":"documentation.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is negative the call will block until "},{"type":"codeVoice","code":"numMessages"},{"text":" have been","type":"text"},{"text":" ","type":"text"},{"text":"received, the connection is closed remotely (EOS), ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled,"},{"type":"text","text":" "},{"type":"text","text":"or an error occurs."}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is 0 the call will return up to "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" without blocking,"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" if no messages are queued in the operating system"},{"text":" ","type":"text"},{"type":"text","text":"to be received."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"text":" is positive the call will block on the same conditions as if","type":"text"},{"text":" ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" were negative. If the timeout is reached"},{"type":"text","text":" "},{"type":"text","text":"before any messages are received, "},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned,"},{"text":" ","type":"text"},{"text":"otherwise it will return the number of messages received before timing out.","type":"text"},{"type":"text","text":" "},{"text":"(Note: This is effectively the behaviour of ","type":"text"},{"code":"MSG_WAITFORONE","type":"codeVoice"},{"text":" with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"recvmmsg()"},{"type":"text","text":".)"}]},{"type":"paragraph","inlineContent":[{"text":"To be notified when messages are available, wait for the [in_](\/\/documentation\/gobject\/in_ condition.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Note though that you may still receive "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" from"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":" even if you were previously notified of a"},{"type":"text","text":" "},{"text":"[in_](\/\/documentation\/gobject\/in_ condition.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the remote peer closes the connection, any messages queued in the","type":"text"},{"text":" ","type":"text"},{"text":"underlying receive buffer will be returned, and subsequent calls to","type":"text"},{"text":" ","type":"text"},{"code":"g_datagram_based_receive_messages()","type":"codeVoice"},{"text":" will return 0 (with no error set).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"type":"codeVoice","code":"g_socket_close()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"code":"shutdown_read","type":"codeVoice"},{"type":"text","text":" set, if it’s a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true,"type":"reference"},{"text":", for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example), all calls to this function will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" is set accordingly. An error will only","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be returned if zero messages could be received; otherwise the number of"},{"text":" ","type":"text"},{"text":"messages successfully received before the error will be returned. If","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled, "},{"code":"cancelled","type":"codeVoice"},{"text":" is returned as with any","type":"text"},{"type":"text","text":" "},{"text":"other error.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"GIO"}],"externalID":"s:3GIO21DatagramBasedProtocolPAAE7receive8messages11numMessages5flags7timeout11cancellableSiSpySo14_GInputMessageVGSg_S2is5Int64Vqd__SgtKAA011CancellableD0Rd__lF","extendedModule":"GIO","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"receive","kind":"identifier"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"messages"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GInputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"roleHeading":"Instance Method","role":"symbol","title":"receive(messages:numMessages:flags:timeout:cancellable:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol"]]},"kind":"symbol","abstract":[{"type":"text","text":"Receive one or more data messages from "},{"type":"codeVoice","code":"datagramBased"},{"text":" in one go.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datagrambasedprotocol\/receive(messages:nummessages:flags:timeout:cancellable:)-4crmz"]}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/receive(messages:numMessages:flags:timeout:cancellable:)-4crmz","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GIO/documentation/GIO/DatagramBasedProtocol/receive(messages:numMessages:flags:timeout:cancellable:)-4crmz":{"url":"\/documentation\/gio\/datagrambasedprotocol\/receive(messages:nummessages:flags:timeout:cancellable:)-4crmz","abstract":[{"type":"text","text":"Receive one or more data messages from "},{"code":"datagramBased","type":"codeVoice"},{"text":" in one go.","type":"text"}],"role":"symbol","title":"receive(messages:numMessages:flags:timeout:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"receive","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"numMessages","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"timeout","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/receive(messages:numMessages:flags:timeout:cancellable:)-4crmz"},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/InputMessage":{"navigatorTitle":[{"text":"InputMessage","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","url":"\/documentation\/gio\/inputmessage","title":"InputMessage","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InputMessage","kind":"identifier"}],"abstract":[{"type":"text","text":"Structure used for scatter\/gather data input when receiving multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of empty","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"text":" and the operation will use all the buffers as if they","type":"text"},{"type":"text","text":" "},{"type":"text","text":"were one buffer, and will set "},{"type":"codeVoice","code":"bytes_received"},{"type":"text","text":" to the total number of bytes"},{"type":"text","text":" "},{"text":"received across all ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"type":"text","text":"."}],"role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/DatagramBasedProtocol":{"url":"\/documentation\/gio\/datagrambasedprotocol","type":"topic","abstract":[{"text":"Interface for socket-like objects with datagram semantics.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBasedProtocol"}],"title":"DatagramBasedProtocol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DatagramBasedProtocol"}]},"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","abstract":[{"text":"Flags used in ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_socket_send_message()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The flags listed in the enum are some commonly available flags, but the"},{"text":" ","type":"text"},{"type":"text","text":"values used for them are the same as on the platform, and any other flags"},{"text":" ","type":"text"},{"text":"are passed in\/out as is. So to use a platform specific flag, just include","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right system header and pass in the flag."}],"navigatorTitle":[{"kind":"identifier","text":"SocketMsgFlags"}],"url":"\/documentation\/gio\/socketmsgflags","title":"SocketMsgFlags","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketMsgFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/InputVector":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","title":"InputVector","url":"\/documentation\/gio\/inputvector","abstract":[{"type":"text","text":"Structure used for scatter\/gather data input."},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GInputVectors"},{"text":" ","type":"text"},{"text":"and the operation will store the read data starting in the","type":"text"},{"type":"text","text":" "},{"text":"first buffer, switching to the next as needed.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InputVector"}],"kind":"symbol","navigatorTitle":[{"text":"InputVector","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}