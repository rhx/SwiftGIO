{"sections":[],"abstract":[{"text":"Receive one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/receive(messages:numMessages:flags:timeout:cancellable:)-2w81h","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"externalID":"s:3GIO21DatagramBasedProtocolPAAE7receive8messages11numMessages5flags7timeout11cancellableSiSpySo14_GInputMessageVGSg_S2is5Int64VAA14CancellableRefVSgtKF","extendedModule":"GIO","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"receive"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"messages"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"GInputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"timeout"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"role":"symbol","symbolKind":"method","title":"receive(messages:numMessages:flags:timeout:cancellable:)","modules":[{"name":"GIO"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"receive","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GInputMessage"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"timeout"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gint64","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","type":"reference","isActive":true},{"text":" structs and","type":"text"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" must be the length of this array. Each "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"type":"text","text":" "},{"type":"text","text":"contains a pointer to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true,"type":"reference"},{"text":" structs describing the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"buffers that the data received in each message will be written to."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" modify how all messages are received. The commonly available"},{"text":" ","type":"text"},{"type":"text","text":"arguments for this are available in the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","type":"reference","isActive":true},{"text":" enum, but the","type":"text"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too. These"},{"text":" ","type":"text"},{"type":"text","text":"flags affect the overall receive operation. Flags affecting individual"},{"type":"text","text":" "},{"type":"text","text":"messages are returned in "},{"code":"GInputMessage.flags","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The other members of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true,"type":"reference"},{"text":" are treated as described in its","type":"text"},{"text":" ","type":"text"},{"text":"documentation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is negative the call will block until "},{"code":"numMessages","type":"codeVoice"},{"text":" have been","type":"text"},{"type":"text","text":" "},{"text":"received, the connection is closed remotely (EOS), ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled,"},{"text":" ","type":"text"},{"text":"or an error occurs.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is 0 the call will return up to "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" without blocking,"},{"type":"text","text":" "},{"type":"text","text":"or "},{"code":"wouldBlock","type":"codeVoice"},{"text":" if no messages are queued in the operating system","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to be received."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"text":" is positive the call will block on the same conditions as if","type":"text"},{"text":" ","type":"text"},{"code":"timeout","type":"codeVoice"},{"text":" were negative. If the timeout is reached","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before any messages are received, "},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned,"},{"text":" ","type":"text"},{"type":"text","text":"otherwise it will return the number of messages received before timing out."},{"text":" ","type":"text"},{"type":"text","text":"(Note: This is effectively the behaviour of "},{"code":"MSG_WAITFORONE","type":"codeVoice"},{"text":" with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"recvmmsg()"},{"text":".)","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To be notified when messages are available, wait for the [in_](\/\/documentation\/gobject\/in_ condition.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Note though that you may still receive "},{"code":"wouldBlock","type":"codeVoice"},{"text":" from","type":"text"},{"type":"text","text":" "},{"code":"g_datagram_based_receive_messages()","type":"codeVoice"},{"type":"text","text":" even if you were previously notified of a"},{"type":"text","text":" "},{"text":"[in_](\/\/documentation\/gobject\/in_ condition.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the remote peer closes the connection, any messages queued in the"},{"text":" ","type":"text"},{"type":"text","text":"underlying receive buffer will be returned, and subsequent calls to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":" will return 0 (with no error set)."}],"type":"paragraph"},{"inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"type":"codeVoice","code":"g_socket_close()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"g_socket_shutdown()","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"shutdown_read","type":"codeVoice"},{"type":"text","text":" set, if it’s a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true,"type":"reference"},{"text":", for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example), all calls to this function will return "},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"type":"text","text":"be returned if zero messages could be received; otherwise the number of"},{"type":"text","text":" "},{"type":"text","text":"messages successfully received before the error will be returned. If"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled, "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" is returned as with any"},{"type":"text","text":" "},{"type":"text","text":"other error."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datagrambasedprotocol\/receive(messages:nummessages:flags:timeout:cancellable:)-2w81h"]}],"references":{"doc://GIO/documentation/GIO/DatagramBasedProtocol/receive(messages:numMessages:flags:timeout:cancellable:)-2w81h":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/receive(messages:numMessages:flags:timeout:cancellable:)-2w81h","url":"\/documentation\/gio\/datagrambasedprotocol\/receive(messages:nummessages:flags:timeout:cancellable:)-2w81h","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"receive"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"type":"topic","role":"symbol","title":"receive(messages:numMessages:flags:timeout:cancellable:)","abstract":[{"text":"Receive one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"text":" in one go.","type":"text"}]},"doc://GIO/documentation/GIO/DatagramBasedProtocol":{"url":"\/documentation\/gio\/datagrambasedprotocol","type":"topic","abstract":[{"text":"Interface for socket-like objects with datagram semantics.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBasedProtocol"}],"title":"DatagramBasedProtocol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DatagramBasedProtocol"}]},"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","abstract":[{"text":"Flags used in ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_socket_send_message()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The flags listed in the enum are some commonly available flags, but the"},{"text":" ","type":"text"},{"type":"text","text":"values used for them are the same as on the platform, and any other flags"},{"text":" ","type":"text"},{"text":"are passed in\/out as is. So to use a platform specific flag, just include","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right system header and pass in the flag."}],"navigatorTitle":[{"kind":"identifier","text":"SocketMsgFlags"}],"url":"\/documentation\/gio\/socketmsgflags","title":"SocketMsgFlags","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketMsgFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/InputMessage":{"navigatorTitle":[{"text":"InputMessage","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","url":"\/documentation\/gio\/inputmessage","title":"InputMessage","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InputMessage","kind":"identifier"}],"abstract":[{"type":"text","text":"Structure used for scatter\/gather data input when receiving multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of empty","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"text":" and the operation will use all the buffers as if they","type":"text"},{"type":"text","text":" "},{"type":"text","text":"were one buffer, and will set "},{"type":"codeVoice","code":"bytes_received"},{"type":"text","text":" to the total number of bytes"},{"type":"text","text":" "},{"text":"received across all ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"type":"text","text":"."}],"role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/InputVector":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","title":"InputVector","url":"\/documentation\/gio\/inputvector","abstract":[{"type":"text","text":"Structure used for scatter\/gather data input."},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GInputVectors"},{"text":" ","type":"text"},{"text":"and the operation will store the read data starting in the","type":"text"},{"type":"text","text":" "},{"text":"first buffer, switching to the next as needed.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InputVector"}],"kind":"symbol","navigatorTitle":[{"text":"InputVector","kind":"identifier"}],"role":"symbol","type":"topic"}}}