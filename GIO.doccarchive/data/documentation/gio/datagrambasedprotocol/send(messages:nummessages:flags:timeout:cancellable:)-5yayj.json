ray of "},{"type":"codeVoice","code":"GOutputVectors"},{"text":" ","type":"text"},{"text":"and the operation will use all the buffers as if they were","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one buffer."}],"url":"\/documentation\/gio\/outputvector","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","navigatorTitle":[{"text":"OutputVector","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputVector","kind":"identifier"}],"title":"OutputVector","role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]}}}