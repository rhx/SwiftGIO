ext"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef","kind":"typeIdentifier","text":"FileInfoRef","preciseIdentifier":"s:3GIO11FileInfoRefV"},{"text":"!","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"attributes"},{"text":" value is a string that specifies the attributes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that should be gathered. It is not an error if it’s not possible"},{"type":"text","text":" "},{"text":"to read a particular requested attribute from a file - it just","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"won’t be set. "},{"type":"codeVoice","code":"attributes"},{"type":"text","text":" should be a comma-separated list of"},{"type":"text","text":" "},{"text":"attributes or attribute wildcards. The wildcard “*” means all","type":"text"},{"type":"text","text":" "},{"text":"attributes, and a wildcard like “filesystem","type":"text"},{"type":"codeVoice","code":"*\" means all attributes in the filesystem namespace. The standard namespace for filesystem attributes is \"filesystem\". Common attributes of interest are "},{"type":"text","text":"fileAttributeFilesystemSize"},{"code":"(the total size of the filesystem in bytes),","type":"codeVoice"},{"text":"fileAttributeFilesystemFree","type":"text"},{"code":"(number of bytes available), and","type":"codeVoice"},{"type":"text","text":"fileAttributeFilesystemType`` (type of the filesystem)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled","type":"text"},{"type":"text","text":" "},{"text":"by triggering the cancellable object from another thread. If the","type":"text"},{"text":" ","type":"text"},{"text":"operation was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the file does not exist, the "},{"code":"notFound","type":"codeVoice"},{"type":"text","text":" error will"},{"type":"text","text":" "},{"text":"be returned. Other errors are possible too, and depend on what","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"kind of filesystem the file is on."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/file\/queryfilesysteminfo(attributes:cancellable:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/File","doc:\/\/GIO\/documentation\/GIO\/File\/FileProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/File\/queryFilesystemInfo(attributes:cancellable:)"},"kind":"symbol","abstract":[{"type":"text","text":"Similar to "},{"code":"g_file_query_info()","type":"codeVoice"},{"text":", but obtains information","type":"text"},{"type":"text","text":" "},{"text":"about the filesystem the ","type":"text"},{"type":"codeVoice","code":"file"},{"text":" is on, rather than the file itself.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"For instance the amount of space available and the type of"},{"type":"text","text":" "},{"text":"the filesystem.","type":"text"}],"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/