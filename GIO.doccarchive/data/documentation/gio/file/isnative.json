{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/File","doc:\/\/GIO\/documentation\/GIO\/File\/FileProtocol-Implementations"]]},"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"isNative"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"A native file is one expressed in the platform-native filename format,"},{"type":"text","text":" "},{"type":"text","text":"e.g. “C:\\Windows” or “\/usr\/bin\/”. This does not mean the file is local,"},{"text":" ","type":"text"},{"type":"text","text":"as it might be on a locally mounted remote filesystem."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On some systems non-native files may be available using the native","type":"text"},{"type":"text","text":" "},{"type":"text","text":"filesystem via a userspace filesystem (FUSE), in these cases this call"},{"text":" ","type":"text"},{"text":"will return ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":", but "},{"code":"g_file_get_path()","type":"codeVoice"},{"type":"text","text":" will still return a native path."}]},{"type":"paragraph","inlineContent":[{"text":"This call does no blocking I\/O.","type":"text"}]}],"kind":"content"}],"abstract":[{"text":"Checks to see if a file is native to the platform.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/file\/isnative"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/File\/isNative"},"schemaVersion":{"minor":3,"major":