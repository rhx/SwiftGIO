{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/file\/queryinfo(attributes:flags:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/File\/queryInfo(attributes:flags:cancellable:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Gets the requested information about specified "},{"code":"file","type":"codeVoice"},{"type":"text","text":"."}],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","title":"queryInfo(attributes:flags:cancellable:)","externalID":"s:3GIO12FileProtocolPAAE9queryInfo10attributes5flags11cancellableAA0bE3RefVSgSPys4Int8VGSg_AA0b5QueryE5FlagsVAA011CancellableI0VSgtKF::SYNTHESIZED::s:3GIO4FileC","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"queryInfo","kind":"identifier"},{"text":"(","kind":"text"},{"text":"attributes","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"FileQueryInfoFlags","preciseIdentifier":"s:3GIO18FileQueryInfoFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"FileInfoRef","preciseIdentifier":"s:3GIO11FileInfoRefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"extendedModule":"GIO","modules":[{"name":"GIO"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"queryInfo"},{"kind":"text","text":"("},{"kind":"externalParam","text":"attributes"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO18FileQueryInfoFlagsV","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileQueryInfoFlags","text":"FileQueryInfoFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef","text":"FileInfoRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO11FileInfoRefV"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The result is a [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"type":"text","text":"] object that contains key-value"},{"text":" ","type":"text"},{"type":"text","text":"attributes (such as the type or size of the file)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"attributes"},{"text":" value is a string that specifies the file","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"attributes that should be gathered. It is not an error if"},{"type":"text","text":" "},{"text":"it’s not possible to read a particular requested attribute","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from a file — it just won’t be set. In particular this means that if a file"},{"type":"text","text":" "},{"type":"text","text":"is inaccessible (due to being in a folder with restrictive permissions), for"},{"text":" ","type":"text"},{"type":"text","text":"example, you can expect the returned [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","type":"reference"},{"type":"text","text":"] to have very few"},{"type":"text","text":" "},{"type":"text","text":"attributes set. You should check whether an attribute is set using"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.FileInfo.has_attribute"},{"type":"text","text":"] before trying to retrieve its value."}]},{"inlineContent":[{"text":"It is guaranteed that if any of the following attributes are listed in","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"attributes"},{"type":"text","text":", they will always be set in the returned [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","type":"reference"},{"type":"text","text":"],"},{"type":"text","text":" "},{"text":"even if the user doesn’t have permissions to access the file:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"[const","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName","isActive":true,"type":"reference"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[const"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardDisplayName"},{"type":"text","text":"]"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"codeVoice","code":"attributes"},{"text":" should be a comma-separated list of attributes or attribute","type":"text"},{"type":"text","text":" "},{"text":"wildcards. The wildcard ","type":"text"},{"type":"codeVoice","code":"\"*\""},{"type":"text","text":" means all attributes, and a wildcard like"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"standard``*\""},{"type":"text","text":" means all attributes in the standard namespace."},{"type":"text","text":" "},{"type":"text","text":"An example attribute query might be "},{"code":"\"standard``*,owner","type":"codeVoice"},{"text":"user","type":"text"},{"type":"codeVoice","code":"\""},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"The standard attributes are available as defines, like"},{"type":"text","text":" "},{"type":"text","text":"[const"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName","type":"reference","isActive":true},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled"},{"type":"text","text":" "},{"text":"by triggering the cancellable object from another thread. If the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation was cancelled, the error [error"},{"type":"codeVoice","code":"Gio.IOErrorEnum.CANCELLED"},{"text":"] will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For symlinks, normally the information about the target of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"symlink is returned, rather than information about the symlink"},{"type":"text","text":" "},{"text":"itself. However if you pass [flags","type":"text"},{"code":"Gio.FileQueryInfoFlags.NOFOLLOW_SYMLINKS","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"flags","type":"codeVoice"},{"type":"text","text":" the information about the symlink itself will be returned."},{"text":" ","type":"text"},{"type":"text","text":"Also, for symlinks that point to non-existing files the information"},{"text":" ","type":"text"},{"text":"about the symlink itself will be returned.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the file does not exist, the [error"},{"type":"codeVoice","code":"Gio.IOErrorEnum.NOT_FOUND"},{"text":"] error will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned. Other errors are possible too, and depend on what kind of"},{"type":"text","text":" "},{"text":"file system the file is on.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/File","doc:\/\/GIO\/documentation\/GIO\/File\/FileProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/File":{"abstract":[{"type":"codeVoice","code":"GFile"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"type":"text","text":"that do no I\/O upon creation. It is necessary to understand that"},{"type":"text","text":" "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"text":" ","type":"text"},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"text":"(see [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"text":"] and [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","url":"\/documentation\/gio\/file","title":"File","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"File","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"File"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},"doc://GIO/documentation/GIO/FileQueryInfoFlags":{"kind":"symbol","url":"\/documentation\/gio\/filequeryinfoflags","abstract":[{"type":"text","text":"Flags used when querying a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"topic","navigatorTitle":[{"text":"FileQueryInfoFlags","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FileQueryInfoFlags","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileQueryInfoFlags","title":"FileQueryInfoFlags"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileInfoRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef","title":"FileInfoRef","url":"\/documentation\/gio\/fileinforef","abstract":[{"type":"text","text":"Stores information about a file system object referenced by a [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"]."}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"FileInfoRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"FileInfoRef","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/fileAttributeStandardName":{"abstract":[{"type":"text","text":"A key in the “standard” namespace for getting the name of the file."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName","role":"symbol","kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fileAttributeStandardName"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"title":"fileAttributeStandardName","type":"topic","url":"\/documentation\/gio\/fileattributestandardname"},"doc://GIO/documentation/GIO/File/FileProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/File\/FileProtocol-Implementations","url":"\/documentation\/gio\/file\/fileprotocol-implementations","title":"FileProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/fileAttributeStandardDisplayName":{"type":"topic","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"fileAttributeStandardDisplayName","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"title":"fileAttributeStandardDisplayName","abstract":[{"text":"A key in the “standard” namespace for getting the display name of the file.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardDisplayName","kind":"symbol","url":"\/documentation\/gio\/fileattributestandarddisplayname","role":"symbol"},"doc://GIO/documentation/GIO/FileInfo":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileInfo"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","url":"\/documentation\/gio\/fileinfo","title":"FileInfo","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileInfo"}],"abstract":[{"text":"Stores information about a file system object referenced by a [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"]."}]},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/File/queryInfo(attributes:flags:cancellable:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"queryInfo","kind":"identifier"},{"kind":"text","text":"("},{"text":"attributes","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier"