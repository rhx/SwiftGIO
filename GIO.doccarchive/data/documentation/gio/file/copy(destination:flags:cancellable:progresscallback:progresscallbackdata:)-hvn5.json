ifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"If the flag "},{"code":"overwrite","type":"codeVoice"},{"text":" is specified an already","type":"text"},{"type":"text","text":" "},{"type":"text","text":"existing "},{"type":"codeVoice","code":"destination"},{"text":" file is overwritten.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the flag ","type":"text"},{"type":"codeVoice","code":"nofollowSymlinks"},{"text":" is specified then symlinks","type":"text"},{"type":"text","text":" "},{"text":"will be copied as symlinks, otherwise the target of the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"source"},{"type":"text","text":" symlink will be copied."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the flag ","type":"text"},{"code":"allMetadata","type":"codeVoice"},{"text":" is specified then all the metadata","type":"text"},{"text":" ","type":"text"},{"text":"that is possible to copy is copied, not just the default subset (which,","type":"text"},{"type":"text","text":" "},{"text":"for instance, does not include the owner, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"text":").","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"progressCallback","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be monitored"},{"type":"text","text":" "},{"type":"text","text":"by setting this to a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProgressCallback","isActive":true,"type":"reference"},{"text":" function.","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"progressCallbackData"},{"text":" will be passed to this function. It is guaranteed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that this callback will be called after all data has been transferred with"},{"type":"text","text":" "},{"type":"text","text":"the total number of bytes copied during the operation."}]},{"inlineContent":[{"type":"text","text":"If the "},{"type":"codeVoice","code":"source"},{"type":"text","text":" file does not exist, then the "},{"type":"codeVoice","code":"notFound"},{"type":"text","text":" error"},{"text":" ","type":"text"},{"type":"text","text":"is returned, independent on the status of the "},{"type":"codeVoice","code":"destination"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"overwrite","type":"codeVoice"},{"type":"text","text":" is not specified and the target exists, then"},{"type":"text","text":" "},{"text":"the error ","type":"text"},{"type":"codeVoice","code":"exists"},{"text":" is returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If trying to overwrite a file over a directory, the "},{"code":"isDirectory","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"error is returned. If trying to overwrite a directory with a directory the"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldMerge"},{"type":"text","text":" error is returned."}]},{"type":"paragraph","inlineCon