{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/file\/createreadwrite(flags:cancellable:)"]}],"abstract":[{"type":"text","text":"Creates a new file and returns a stream for reading and"},{"text":" ","type":"text"},{"type":"text","text":"writing to it. The file must not already exist."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/File","doc:\/\/GIO\/documentation\/GIO\/File\/FileProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"createReadwrite","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"FileCreateFlags","preciseIdentifier":"s:3GIO15FileCreateFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"FileIOStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef","preciseIdentifier":"s:3GIO15FileIOStreamRefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default files created are generally readable by everyone,"},{"text":" ","type":"text"},{"text":"but if you pass ","type":"text"},{"type":"codeVoice","code":"private"},{"type":"text","text":" in "},{"type":"codeVoice","code":"flags"},{"text":" the file","type":"text"},{"type":"text","text":" "},{"text":"will be made readable only to the current user, to the level","type":"text"},{"type":"text","text":" "},{"text":"that is supported on the target filesystem.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled"},{"text":" ","type":"text"},{"type":"text","text":"by triggering the cancellable object from another thread. If the"},{"type":"text","text":" "},{"type":"text","text":"operation was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a file or directory with this name already exists, the"},{"type":"text","text":" "},{"code":"exists","type":"codeVoice"},{"type":"text","text":" error will be returned. Some file systems don’t"},{"type":"text","text":" "},{"text":"allow all file names, and may return an ","type":"text"},{"type":"codeVoice","code":"invalidFilename"},{"text":" ","type":"text"},{"type":"text","text":"error, and if the name is too long, "},{"code":"filenameTooLong","type":"codeVoice"},{"text":" ","type":"text"},{"text":"will be returned. Other errors are possible too, and depend on what","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"kind of filesystem the file is on."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that in many non-local file cases read and write streams are"},{"type":"text","text":" "},{"type":"text","text":"not supported, so make sure you really need to do read and write"},{"text":" ","type":"text"},{"type":"text","text":"streaming, rather than just opening for reading or writing."}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/File\/createReadwrite(