{"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/file\/replace(etag:makebackup:flags:cancellable:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/File\/replace(etag:makeBackup:flags:cancellable:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Returns an output stream for overwriting the file, possibly","type":"text"},{"type":"text","text":" "},{"type":"text","text":"creating a backup copy of the file first. If the file doesn’t exist,"},{"type":"text","text":" "},{"type":"text","text":"it will be created."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/File","doc:\/\/GIO\/documentation\/GIO\/File\/FileProtocol-Implementations"]]},"metadata":{"symbolKind":"method","roleHeading":"Instance Method","extendedModule":"GIO","role":"symbol","title":"replace(etag:makeBackup:flags:cancellable:)","externalID":"s:3GIO12FileProtocolPAAE7replace4etag10makeBackup5flags11cancellableAA0B15OutputStreamRefVSgSPys4Int8VGSg_SbAA0B11CreateFlagsVAA011CancellableL0VSgtKF::SYNTHESIZED::s:3GIO4FileC","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"replace"},{"text":"(","kind":"text"},{"text":"etag","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"CChar","preciseIdentifier":"s:s5CChara"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"makeBackup"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileCreateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileCreateFlagsV"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"FileOutputStreamRef","preciseIdentifier":"s:3GIO19FileOutputStreamRefV"},{"kind":"text","text":"!"}]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"replace","kind":"identifier"},{"text":"(","kind":"text"},{"text":"etag","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"text":">? = nil, ","kind":"text"},{"text":"makeBackup","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"FileOutputStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19FileOutputStreamRefV"},{"text":"!","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will try to replace the file in the safest way possible so"},{"text":" ","type":"text"},{"type":"text","text":"that any errors during the writing will not affect an already"},{"text":" ","type":"text"},{"text":"existing copy of the file. For instance, for local files it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"may write to a temporary file and then atomically rename over"},{"text":" ","type":"text"},{"type":"text","text":"the destination when the stream is closed."}]},{"inlineContent":[{"type":"text","text":"By default files created are generally readable by everyone,"},{"type":"text","text":" "},{"text":"but if you pass ","type":"text"},{"type":"codeVoice","code":"private"},{"type":"text","text":" in "},{"code":"flags","type":"codeVoice"},{"text":" the file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be made readable only to the current user, to the level that"},{"type":"text","text":" "},{"type":"text","text":"is supported on the target filesystem."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled"},{"type":"text","text":" "},{"type":"text","text":"by triggering the cancellable object from another thread. If the"},{"text":" ","type":"text"},{"type":"text","text":"operation was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"returned."}]},{"inlineContent":[{"type":"text","text":"If you pass in a non-"},{"type":"codeVoice","code":"nil"},{"text":" ","type":"text"},{"code":"etag","type":"codeVoice"},{"type":"text","text":" value and "},{"type":"codeVoice","code":"file"},{"type":"text","text":" already exists, then"},{"text":" ","type":"text"},{"text":"this value is compared to the current entity tag of the file, and if","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"they differ an "},{"type":"codeVoice","code":"wrongEtag"},{"text":" error is returned. This","type":"text"},{"type":"text","text":" "},{"text":"generally means that the file has been changed since you last read","type":"text"},{"type":"text","text":" "},{"text":"it. You can get the new etag from ","type":"text"},{"type":"codeVoice","code":"g_file_output_stream_get_etag()"},{"type":"text","text":" "},{"type":"text","text":"after you’ve finished writing and closed the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStream","isActive":true},{"type":"text","text":". When"},{"text":" ","type":"text"},{"type":"text","text":"you load a new file you can use "},{"code":"g_file_input_stream_query_info()","type":"codeVoice"},{"text":" to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"get the etag of the file."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"makeBackup"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":", this function will attempt to make a","type":"text"},{"type":"text","text":" "},{"text":"backup of the current file before overwriting it. If this fails","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"type":"codeVoice","code":"cantCreateBackup"},{"text":" error will be returned. If you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"want to replace anyway, try again with "},{"code":"makeBackup","type":"codeVoice"},{"type":"text","text":" set to "},{"code":"false","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the file is a directory the "},{"type":"codeVoice","code":"isDirectory"},{"type":"text","text":" error will"},{"type":"text","text":" "},{"text":"be returned, and if the file is some other form of non-regular file","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then a "},{"type":"codeVoice","code":"notRegularFile"},{"text":" error will be returned. Some","type":"text"},{"text":" ","type":"text"},{"text":"file systems don’t allow all file names, and may return an","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"invalidFilename"},{"text":" error, and if the name is to long","type":"text"},{"type":"text","text":" "},{"code":"filenameTooLong","type":"codeVoice"},{"type":"text","text":" will be returned. Other errors are"},{"text":" ","type":"text"},{"type":"text","text":"possible too, and depend on what kind of filesystem the file is on."}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/File/FileProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/File\/FileProtocol-Implementations","url":"\/documentation\/gio\/file\/fileprotocol-implementations","title":"FileProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/File/replace(etag:makeBackup:flags:cancellable:)":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"replace"},{"kind":"text","text":"("},{"text":"etag","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"makeBackup"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"FileCreateFlags","preciseIdentifier":"s:3GIO15FileCreateFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO19FileOutputStreamRefV","text":"FileOutputStreamRef"},{"text":"!","kind":"text"}],"abstract":[{"text":"Returns an output stream for overwriting the file, possibly","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"creating a backup copy of the file first. If the file doesn’t exist,"},{"type":"text","text":" "},{"type":"text","text":"it will be created."}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/File\/replace(etag:makeBackup:flags:cancellable:)","title":"replace(etag:makeBackup:flags:cancellable:)","url":"\/documentation\/gio\/file\/replace(etag:makebackup:flags:cancellable:)","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileOutputStreamRef":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileOutputStreamRef"}],"url":"\/documentation\/gio\/fileoutputstreamref","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileOutputStreamRef"}],"title":"FileOutputStreamRef","kind":"symbol","abstract":[{"type":"codeVoice","code":"GFileOutputStream"},{"text":" provides output streams that write their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"content to a file."}]},"doc://GIO/documentation/GIO/FileOutputStream":{"navigatorTitle":[{"text":"FileOutputStream","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileOutputStream"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStream","url":"\/documentation\/gio\/fileoutputstream","title":"FileOutputStream","abstract":[{"code":"GFileOutputStream","type":"codeVoice"},{"text":" provides output streams that write their","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"content to a file."}],"kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/File":{"abstract":[{"type":"codeVoice","code":"GFile"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"type":"text","text":"that do no I\/O upon creation. It is necessary to understand that"},{"type":"text","text":" "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"text":" ","type":"text"},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"text":"(see [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"text":"] and [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","url":"\/documentation\/gio\/file","title":"File","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"File","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"File"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/FileCreateFlags":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags","navigatorTitle":[{"text":"FileCreateFlags","kind":"identifier"}],"abstract":[{"text":"Flags used when an operation may create a file.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileCreateFlags"}],"url":"\/documentation\/gio\/filecreateflags","type":"topic","kind":"symbol","title":"FileCreateFlags"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]}}}