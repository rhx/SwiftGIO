"text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/TcpConnectionProtocol":{"title":"TcpConnectionProtocol","abstract":[{"text":"This is the subclass of [class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection"},{"type":"text","text":"] that is created"},{"type":"text","text":" "},{"type":"text","text":"for TCP\/IP sockets."}],"role":"symbol","navigatorTitle":[{"text":"TcpConnectionProtocol","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnectionProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TcpConnectionProtocol"}],"kind":"symbol","url":"\/documentation\/gio\/tcpconnectionprotocol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}