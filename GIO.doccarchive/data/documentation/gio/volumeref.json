{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/VolumeRef"},"topicSections":[{"generated":true,"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(_:)-26e12","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(_:)-418yb","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(_:)-48cy5","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(_:)-5fruw","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(_:)-qxfk","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/init(opaquePointer:)"]},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/ptr"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/PointerWrapper-Implementations","doc:\/\/GIO\/documentation\/GIO\/VolumeRef\/VolumeProtocol-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/documentation\/GIO\/VolumeProtocol"],"kind":"relationships"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VolumeRef"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"type":"text","text":"If a "},{"code":"GVolume","type":"codeVoice"},{"type":"text","text":" is currently mounted, the corresponding [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Mount"},{"type":"text","text":"] can"},{"type":"text","text":" "},{"type":"text","text":"be retrieved using [method"},{"type":"codeVoice","code":"Gio.Volume.get_mount"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Mounting a "},{"type":"codeVoice","code":"GVolume"},{"text":" instance is an asynchronous operation. For more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"information about asynchronous operations, see [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","isActive":true},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"type":"text","text":"]. To mount a "},{"code":"GVolume","type":"codeVoice"},{"text":", first call [method","type":"text"},{"type":"codeVoice","code":"Gio.Volume.mount"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"with (at least) the ","type":"text"},{"type":"codeVoice","code":"GVolume"},{"type":"text","text":" instance, optionally a"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperation"},{"type":"text","text":"] object and a [type"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Typically, one will only want to pass ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" for the"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperation"},{"text":"] if automounting all volumes when a desktop session","type":"text"},{"type":"text","text":" "},{"type":"text","text":"starts since it’s not desirable to put up a lot of dialogs asking"},{"text":" ","type":"text"},{"text":"for credentials.","type":"text"}]},{"inlineContent":[{"text":"The callback will be fired when the operation has resolved (either","type":"text"},{"type":"text","text":" "},{"text":"with success or failure), and a [iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult"},{"type":"text","text":"] instance will be"},{"text":" ","type":"text"},{"type":"text","text":"passed to the callback.  That callback should then call"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.Volume.mount_finish"},{"type":"text","text":"] with the "},{"type":"codeVoice","code":"GVolume"},{"type":"text","text":" instance and the"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","isActive":true,"type":"reference"},{"text":"] data to see if the operation was completed","type":"text"},{"type":"text","text":" "},{"text":"successfully.  If a [type[GLibError](\/\/documentation\/glib\/gliberror] is present when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.Volume.mount_finish","type":"codeVoice"},{"type":"text","text":"] is called, then it will be filled with any"},{"type":"text","text":" "},{"text":"error information.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note, when "},{"type":"reference","identifier":"migrating-gnome-vfs.html","isActive":true},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"GVolume"},{"type":"text","text":" is the moral equivalent of "},{"type":"codeVoice","code":"GnomeVFSDrive"},{"text":".","type":"text"}]},{"level":2,"text":"Volume Identifiers","anchor":"Volume-Identifiers","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"It is sometimes necessary to directly access the underlying","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operating system object behind a volume (e.g. for passing a volume"},{"type":"text","text":" "},{"type":"text","text":"to an application via the command line). For this purpose, GIO"},{"type":"text","text":" "},{"text":"allows to obtain an ‘identifier’ for the volume. There can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"different kinds of identifiers, such as Hal UDIs, filesystem labels,"},{"text":" ","type":"text"},{"type":"text","text":"traditional Unix devices (e.g. "},{"code":"\/dev\/sda2","type":"codeVoice"},{"type":"text","text":"), UUIDs. GIO uses predefined"},{"type":"text","text":" "},{"text":"strings as names for the different kinds of identifiers:","type":"text"},{"text":" ","type":"text"},{"code":"G_VOLUME_IDENTIFIER_KIND_UUID","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"G_VOLUME_IDENTIFIER_KIND_LABEL"},{"type":"text","text":", etc."},{"text":" ","type":"text"},{"text":"Use [method","type":"text"},{"type":"codeVoice","code":"Gio.Volume.get_identifier"},{"text":"] to obtain an identifier for a volume.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that ","type":"text"},{"type":"codeVoice","code":"G_VOLUME_IDENTIFIER_KIND_HAL_UDI"},{"type":"text","text":" will only be available"},{"text":" ","type":"text"},{"text":"when the GVFS hal volume monitor is in use. Other volume monitors","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will generally be able to provide the "},{"type":"codeVoice","code":"G_VOLUME_IDENTIFIER_KIND_UNIX_DEVICE"},{"text":" ","type":"text"},{"type":"text","text":"identifier, which can be used to obtain a hal device by means of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"libhal_manager_find_device_string_match()"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/VolumeRef"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GVolume"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/VolumeProtocol","type":"reference","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/VolumeRef"},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GVolume"},{"type":"text","text":" instance."}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Volume","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/VolumeRef"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GVolume"},{"type":"text","text":" instance."}]}],"type":"aside"}]}],"abstract":[{"type":"text","text":"The "},{"code":"GVolume","type":"codeVoice"},{"text":" interface represents user-visible objects that can be","type":"text"},{"type":"text","text":" "},{"text":"mounted. For example, a file system partition on a USB flash drive, or an","type":"text"},{"type":"text","text":" "},{"text":"optical disc inserted into a disc drive.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"metadata":{"symbolKind":"struct","navigatorTitle":[{"text":"VolumeRef","kind":"identifier"}],"externalID":"s:3GIO9VolumeRe