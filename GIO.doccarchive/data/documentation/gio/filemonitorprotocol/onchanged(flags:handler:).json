ext":" on a directory monitor, and"},{"type":"text","text":" "},{"type":"text","text":"the information is available (and if supported by the backend),"},{"type":"text","text":" "},{"type":"codeVoice","code":"eventType"},{"text":" may be ","type":"text"},{"code":"renamed","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"movedIn"},{"type":"text","text":" or "},{"type":"codeVoice","code":"movedOut"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"In all cases "},{"code":"file","type":"codeVoice"},{"text":" will be a child of the monitored directory.  For","type":"text"},{"text":" ","type":"text"},{"text":"renames, ","type":"text"},{"type":"codeVoice","code":"file"},{"text":" will be the old name and ","type":"text"},{"type":"codeVoice","code":"otherFile"},{"type":"text","text":" is the new"},{"text":" ","type":"text"},{"text":"name.  For “moved in” events, ","type":"text"},{"type":"codeVoice","code":"file"},{"type":"text","text":" is the name of the file that"},{"text":" ","type":"text"},{"text":"appeared and ","type":"text"},{"code":"otherFile","type":"codeVoice"},{"type":"text","text":" is the old name that it was moved from (in"},{"type":"text","text":" "},{"type":"text","text":"another directory).  For “moved out” events, "},{"code":"file","type":"codeVoice"},{"type":"text","text":" is the name of"},{"text":" ","type":"text"},{"text":"the file that used to be in this directory and ","type":"text"},{"code":"otherFile","type":"codeVoice"},{"text":" is the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"name of the file at its new location."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It makes sense to treat ","type":"text"},{"type":"codeVoice","code":"movedIn"},{"type":"text","text":" as"},{"text":" ","type":"text"},{"text":"equivalent to ","type":"text"},{"code":"created","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"movedOut","type":"codeVoice"},{"type":"text","text":" as equivalent to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"deleted"},{"type":"text","text":", with extra information."},{"text":" ","type":"text"},{"code":"renamed","type":"codeVoice"},{"type":"text","text":" is equivalent to a delete\/create"},{"type":"text","text":" "},{"text":"pair.  This is exactly how the events will be reported in the case","type":"text"},{"text":" ","type":"text"},{"text":"that the ","type":"text"},{"code":"watchMoves","type":"codeVoice"},{"text":" flag is not in use.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If using the deprecated flag "},{"type":"codeVoice","code":"sendMoved"},{"type":"text","text":" flag and "},{"type":"codeVoice","code":"eventType"},{"type":"text","text":" is"},{"type":"text","text":" "},{"code":"moved","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"file"},{"type":"text","text":" will be set to a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/File","type":"reference","isActive":true},{"type":"text","text":" containing the"},{"type":"text","text":" "},{"text":"old path, and ","type":"text"},{"code":"otherFile","type":"codeVoice"},{"text":" will be set to a ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true,"type":"reference"},{"type":"text","text":" containing the new path."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In all the other cases, "},{"type":"codeVoice","code":"otherFile"},{"type":"text","text":" will be set to "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":"."}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"changed"},{"type":"text","text":" signal"}]}],"type":"aside","name":"Note"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileMonitorProtocol\/onChanged(flags:handler:)","interfaceLangu