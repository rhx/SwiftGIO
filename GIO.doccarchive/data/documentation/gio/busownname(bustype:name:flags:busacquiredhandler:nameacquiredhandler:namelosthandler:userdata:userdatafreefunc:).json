{"kind":"symbol","abstract":[{"type":"text","text":"Requests ownership of "},{"type":"codeVoice","code":"name"},{"text":" on the bus specified by ","type":"text"},{"type":"codeVoice","code":"busType"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"busOwnName"},{"kind":"text","text":"("},{"kind":"externalParam","text":"busType"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@EA@GBusType","text":"GBusType","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"name"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"BusNameOwnerFlags","preciseIdentifier":"s:3GIO17BusNameOwnerFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/BusNameOwnerFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"busAcquiredHandler"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GBusAcquiredCallback","text":"GBusAcquiredCallback","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"nameAcquiredHandler","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GBusNameAcquiredCallback","text":"GBusNameAcquiredCallback","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"nameLostHandler"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GBusNameLostCallback","text":"GBusNameLostCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userDataFreeFunc"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@GDestroyNotify","text":"GDestroyNotify"},{"kind":"text","text":"? = nil) -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"It asynchronously calls ","type":"text"},{"type":"codeVoice","code":"nameAcquiredHandler"},{"type":"text","text":" and "},{"code":"nameLostHandler","type":"codeVoice"},{"type":"text","text":" when"},{"type":"text","text":" "},{"text":"the name is acquired and lost, respectively.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Callbacks will be invoked in the thread-default"},{"type":"text","text":" "},{"text":"main context (see [method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"text":"])","type":"text"},{"type":"text","text":" "},{"text":"of the thread you are calling this function from.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You are guaranteed that one of the "},{"code":"nameAcquiredHandler","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"nameLostHandler"},{"type":"text","text":" "},{"text":"callbacks will be invoked after calling this function — there are three","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"possible cases:"}]},{"items":[{"content":[{"inlineContent":[{"code":"nameLostHandler","type":"codeVoice"},{"type":"text","text":" with a "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" connection (if a connection to the bus"},{"type":"text","text":" "},{"text":"can’t be made).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"busAcquiredHandler"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"nameLostHandler"},{"type":"text","text":" (if the name can’t be"},{"text":" ","type":"text"},{"text":"obtained).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"busAcquiredHandler","type":"codeVoice"},{"type":"text","text":" then "},{"type":"codeVoice","code":"nameAcquiredHandler"},{"type":"text","text":" (if the name was"},{"type":"text","text":" "},{"text":"obtained).","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you are done owning the name, call [func"},{"code":"Gio.bus_unown_name","type":"codeVoice"},{"text":"] with the","type":"text"},{"type":"text","text":" "},{"text":"owner ID this function returns.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the name is acquired or lost (for example another application","type":"text"},{"text":" ","type":"text"},{"text":"could acquire the name if you allow replacement or the application","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"currently owning the name exits), the handlers are also invoked."},{"type":"text","text":" "},{"text":"If the [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection","isActive":true,"type":"reference"},{"text":"] that is used for attempting to own the name","type":"text"},{"text":" ","type":"text"},{"text":"closes, then ","type":"text"},{"code":"nameLostHandler","type":"codeVoice"},{"text":" is invoked since it is no longer","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible for other processes to access the process."}]},{"type":"paragraph","inlineContent":[{"text":"You cannot use [func","type":"text"},{"code":"Gio.bus_own_name","type":"codeVoice"},{"text":"] several times for the same name (unless","type":"text"},{"type":"text","text":" "},{"text":"interleaved with calls to [func","type":"text"},{"type":"codeVoice","code":"Gio.bus_unown_name"},{"type":"text","text":"]) — only the first call"},{"type":"text","text":" "},{"type":"text","text":"will work."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Another guarantee is that invocations of "},{"type":"codeVoice","code":"nameAcquiredHandler"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"type":"codeVoice","code":"nameLostHandler"},{"type":"text","text":" are guaranteed to alternate; that"},{"type":"text","text":" "},{"text":"is, if ","type":"text"},{"code":"nameAcquiredHandler","type":"codeVoice"},{"type":"text","text":" is invoked then you are"},{"text":" ","type":"text"},{"type":"text","text":"guaranteed that the next time one of the handlers is invoked, it"},{"type":"text","text":" "},{"text":"will be ","type":"text"},{"type":"codeVoice","code":"nameLostHandler"},{"text":". The reverse is also true.","type":"text"}]},{"inlineContent":[{"text":"If you plan on exporting objects (using, for example,","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.DBusConnection.register_object"},{"text":"]), note that it is generally too late","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to export the objects in "},{"code":"nameAcquiredHandler","type":"codeVoice"},{"type":"text","text":". Instead, you can do this"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"busAcquiredHandler"},{"type":"text","text":" since you are guaranteed that this will run"},{"text":" ","type":"text"},{"text":"before ","type":"text"},{"code":"name","type":"codeVoice"},{"text":" is requested from the bus.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This behavior makes it very simple to write applications that want"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"type":"reference","isActive":true,"identifier":"dbus-name-owning.html#d-bus-name-owning"},{"type":"text","text":" and export objects."},{"text":" ","type":"text"},{"type":"text","text":"Simply register objects to be exported in "},{"type":"codeVoice","code":"busAcquiredHandler"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"text":"unregister the objects (if any) in ","type":"text"},{"code":"nameLostHandler","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"sections":[],"metadata":{"symbolKind":"func","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"busOwnName","kind":"identifier"},{"text":"(","kind":"text"},{"text":"busType","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GBusType","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GBusType"},{"text":", ","kind":"text"},{"text":"name","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"BusNameOwnerFlags","preciseIdentifier":"s:3GIO17BusNameOwnerFlagsV"},{"text":", ","kind":"text"},{"text":"busAcquiredHandler","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GBusAcquiredCallback","text":"GBusAcquiredCallback"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"nameAcquiredHandler"},{"text":": ","kind":"text"},{"text":"GBusNameAcquiredCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GBusNameAcquiredCallback"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"nameLostHandler"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GBusNameLostCallback","text":"GBusNameLostCallback"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"