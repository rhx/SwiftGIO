{"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketclientpropertyname\/tlsvalidationflags"]}],"sections":[],"abstract":[{"text":"The TLS validation flags used when creating TLS connections. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"default value is "},{"type":"codeVoice","code":"validateAll"},{"type":"text","text":"."}],"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"title":"SocketClientPropertyName.tlsValidationFlags","symbolKind":"case","roleHeading":"Case","externalID":"s:3GIO24SocketClientPropertyNameO18tlsValidationFlagsyA2CmF","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"tlsValidationFlags"}]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tlsValidationFlags","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"text":" ","type":"text"},{"type":"text","text":"flag will be set, but it does not guarantee that all possible flags"},{"text":" ","type":"text"},{"text":"will be set. Accordingly, you may not safely decide to ignore any","type":"text"},{"text":" ","type":"text"},{"text":"particular type of error. For example, it would be incorrect to mask","type":"text"},{"text":" ","type":"text"},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow expired certificates,"},{"text":" ","type":"text"},{"type":"text","text":"because this could potentially be the only error flag set even if"},{"text":" ","type":"text"},{"text":"other problems exist with the certificate. Therefore, there is no","type":"text"},{"type":"text","text":" "},{"text":"safe way to use this property. This is not a horrible problem,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"though, because you should not be attempting to ignore validation"},{"type":"text","text":" "},{"type":"text","text":"errors anyway. If you really must ignore TLS certificate errors,"},{"text":" ","type":"text"},{"text":"connect to the [SocketClient](\/\/documentation\/gio\/socketclient\/onevent(flags:handler:) signal, wait for it to be","type":"text"},{"text":" ","type":"text"},{"text":"emitted with ","type":"text"},{"code":"tlsHandshaking","type":"codeVoice"},{"type":"text","text":", and use that to"},{"text":" ","type":"text"},{"text":"connect to [TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"tls-validation-flags is deprecated:"}],"type":"strong"},{"text":" ","type":"text"},{"text":"Do not attempt to ignore validation errors.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketClientPropertyName"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketClientPropertyName\/tlsValidationFlags","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/SocketClientPropertyName/tlsValidationFlags":{"fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"tlsValidationFlags"}],"type":"topic","abstract":[{"type":"text","text":"The TLS validation flags used when creating TLS connections. The"},{"type":"text","text":" "},{"text":"default value is ","type":"text"},{"code":"validateAll","type":"codeVoice"},{"text":".","type":"text"}],"url":"\/documentation\/gio\/socketclientpropertyname\/tlsvalidationflags","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientPropertyName\/tlsValidationFlags","role":"symbol","title":"SocketClientPropertyName.tlsValidationFlags"},"doc://GIO/documentation/GIO/SocketClientPropertyName":{"title":"SocketClientPropertyName","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SocketClientPropertyName"}],"navigatorTitle":[{"text":"SocketClientPropertyName","kind":"identifier"}],"url":"\/documentation\/gio\/socketclientpropertyname","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientPropertyName","abstract":[],"role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}