{"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"acceptCertificate"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"For a client-side connection, "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" is the server’s"},{"type":"text","text":" "},{"type":"text","text":"certificate, and the signal will only be emitted if the"},{"type":"text","text":" "},{"type":"text","text":"certificate was not acceptable according to "},{"code":"conn","type":"codeVoice"},{"text":"’s","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","isActive":true},{"type":"text","text":". If you would like the"},{"text":" ","type":"text"},{"type":"text","text":"certificate to be accepted despite "},{"type":"codeVoice","code":"errors"},{"type":"text","text":", return "},{"code":"true","type":"codeVoice"},{"type":"text","text":" from the"},{"type":"text","text":" "},{"type":"text","text":"signal handler. Otherwise, if no handler accepts the certificate,"},{"type":"text","text":" "},{"text":"the handshake will fail with ","type":"text"},{"type":"codeVoice","code":"badCertificate"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"GLib guarantees that if certificate verification fails, this signal","type":"text"},{"text":" ","type":"text"},{"text":"will be emitted with at least one error will be set in ","type":"text"},{"type":"codeVoice","code":"errors"},{"type":"text","text":", but"},{"text":" ","type":"text"},{"type":"text","text":"it does not guarantee that all possible errors will be set."},{"type":"text","text":" "},{"type":"text","text":"Accordingly, you may not safely decide to ignore any particular"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"text":" ","type":"text"},{"type":"codeVoice","code":"expired"},{"text":" if you want to allow expired","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificates, because this could potentially be the only error flag"},{"type":"text","text":" "},{"type":"text","text":"set even if other problems exist with the certificate."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a server-side connection, "},{"type":"codeVoice","code":"peerCert"},{"text":" is the certificate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"presented by the client, if this was requested via the server’s"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","isActive":true},{"type":"text","text":". On the server side,"},{"text":" ","type":"text"},{"text":"the signal is always emitted when the client presents a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate, and the certificate will only be accepted if a"},{"type":"text","text":" "},{"text":"handler returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"type":"text","text":" "},{"text":"in the main thread, then you should not attempt to interact with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user before returning from the signal handler. If you want to"},{"type":"text","text":" "},{"type":"text","text":"let the user decide whether or not to accept the certificate, you"},{"type":"text","text":" "},{"type":"text","text":"would have to return "},{"type":"codeVoice","code":"false"},{"text":" from the signal handler on the first","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"attempt, and then after the connection attempt returns a"},{"text":" ","type":"text"},{"code":"badCertificate","type":"codeVoice"},{"type":"text","text":", you can interact with the user, and"},{"text":" ","type":"text"},{"text":"if the user decides to accept the certificate, remember that fact,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"create a new connection, and return "},{"type":"codeVoice","code":"true"},{"text":" from the signal handler","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the next time."}]},{"type":"paragraph","inlineContent":[{"text":"If you are doing I\/O in another thread, you do not","type":"text"},{"text":" ","type":"text"},{"text":"need to worry about this, and can simply block in the signal","type":"text"},{"type":"text","text":" "},{"text":"handler until the UI thread returns an answer.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/dtlsconnectionsignalname\/acceptcertificate"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionSignalName"]]},"abstract":[{"text":"Emitted during the TLS handshake after the peer certificate has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"been received. You can examine "},{"code":"peerCert","type":"codeVoice"},{"text":"’s certification path by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_tls_certificate_get_issuer()"},{"type":"text","text":" on it."}],"metadata":{"modules":[{"name":"GIO"}],"title":"DtlsConnectionSignalName.acceptCertificate","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"acceptCertificate","kind":"identifier"}],"roleHeading":"Case","symbolKind":"case","externalID":"s:3GIO24DtlsConnectionSignalNameO17acceptCertificateyA2CmF"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionSignalName\/acceptCertificate","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"references":{"doc://GIO/documentation/GIO/DtlsServerConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsserverconnection","abstract":[{"type":"codeVoice","code":"GDtlsServerConnection"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"type":"text","text":"], representing a server-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsServerConnection","kind":"identifier"}],"title":"DtlsServerConnection","navigatorTitle":[{"text":"DtlsServerConnection","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsClientConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsclientconnection","abstract":[{"code":"GDtlsClientConnection","type":"codeVoice"},{"text":" is the client-side subclass of","type":"text"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection"},{"type":"text","text":"], representing a client-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DtlsClientConnection"}],"title":"DtlsClientConnection","navigatorTitle":[{"kind":"identifier","text":"DtlsClientConnection"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DtlsConnectionSignalName":{"type":"topic","abstract":[],"kind":"symbol","title":"DtlsConnectionSignalName","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionSignalName","navigatorTitle":[{"text":"DtlsConnectionSignalName","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsConnectionSignalName","kind":"identifier"}],"url":"\/documentation\/gio\/dtlsconnectionsignalname"},"doc://GIO/documentation/GIO/DtlsConnection":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DtlsConnection","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"DtlsConnection"}],"abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"type":"text","text":" is the base DTLS connection class type, which wraps"},{"text":" ","type":"text"},{"text":"a [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"text":"] and provides DTLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"text":"subclasses, [iface","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection"},{"text":"] and","type":"text"},{"type":"text","text":" "},{"text":"[iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","isActive":true,"type":"reference"},{"text":"], implement client-side and server-side DTLS,","type":"text"},{"text":" ","type":"text"},{"text":"respectively.","type":"text"}],"title":"DtlsConnection","url":"\/documentation\/gio\/dtlsconnection"},"doc://GIO/documentation/GIO/DtlsConnectionSignalName/acceptCertificate":{"abstract":[{"type":"text","text":"Emitted during the TLS handshake after the peer certificate has"},{"type":"text","text":" "},{"type":"text","text":"been received. You can examine "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":"’s certification path by"},{"text":" ","type":"text"},{"text":"calling ","type":"text"},{"code":"g_tls_certificate_get_issuer()","type":"codeVoice"},{"type":"text","text":" on it."}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionSignalName\/acceptCertificate","kind":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"acceptCertificate","kind":"identifier"}],"title":"DtlsConnectionSignalName.acceptCertificate","url":"\/documentation\/gio\/dtlsconnectionsignalname\/acceptcertificate","type":"topic"}}}