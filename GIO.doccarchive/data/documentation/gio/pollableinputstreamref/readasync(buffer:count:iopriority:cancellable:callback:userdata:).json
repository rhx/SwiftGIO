d"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/PollableInputStreamRef":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef","title":"PollableInputStreamRef","kind":"symbol","abstract":[{"code":"GPollableInputStream","type":"codeVoice"},{"text":" is implemented by [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true},{"type":"text","text":"]s that"},{"type":"text","text":" "},{"type":"text","text":"can be polled for readiness to read. This can be used when"},{"text":" ","type":"text"},{"text":"interfacing with a non-GIO API that expects","type":"text"},{"type":"text","text":" "},{"type":"text","text":"UNIX-file-descriptor-style asynchronous I\/O rather than GIO-style."}],"type":"topic","navigatorTitle":[{"text":"PollableInputStreamRef","kind":"identifier"}],"url":"\/documentation\/gio\/pollableinputstreamref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"PollableInputStreamRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}