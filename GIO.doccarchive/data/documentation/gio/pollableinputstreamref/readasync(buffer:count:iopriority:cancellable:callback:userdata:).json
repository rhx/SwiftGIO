ype":"text","text":"be executed before an outstanding request with lower priority. Default"},{"text":" ","type":"text"},{"text":"priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads to implement","type":"text"},{"type":"text","text":" "},{"type":"text","text":"asynchronicity, so they are optional for inheriting classes. However, if you"},{"type":"text","text":" "},{"type":"text","text":"override one you must override all."}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/PollableInputStreamRef/InputStreamProtocol-Implementations":{"title":"InputStreamProtocol Implementations","kind":"article","abstract":[],"role":"collectionGroup","type":"topic","url":"\/documentation\/gio\/pollableinputstreamref\/inputstreamprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef\/InputStreamProtocol-Implementations"},"doc://GIO/documentation/GIO/PollableInputStreamRef/readAsync(buffer:count:ioPriority:cancellable:callback:userData:)":{"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"readAsync","kind":"identifier"},{"kind":"text","text":"("},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","tex