{"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef\/close(cancellable:)"},"sections":[],"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO22PollableInputStreamRefV","extendedModule":"GIO","role":"symbol","symbolKind":"method","title":"close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef\/InputStreamProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}],"type":"paragraph"},{"inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"type":"text","text":" "},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"text":" ","type":"text"},{"type":"text","text":"stream for details."}],"type":"paragraph"},{"inlineContent":[{"text":"On failure the first error that happened will be reported, but the close","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"text":" ","type":"text"},{"type":"text","text":"close will still return "},{"code":"closed","type":"codeVoice"},{"text":" for all operations. Still, it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is important to check and report the error to the user."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/pollableinputstreamref\/close(cancellable:)"]}],"references":{"doc://GIO/documentation/GIO/PollableInputStreamRef":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef","title":"PollableInputStreamRef","kind":"symbol","abstract":[{"code":"GPollableInputStream","type":"codeVoice"},{"text":" is implemented by [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true},{"type":"text","text":"]s that"},{"type":"text","text":" "},{"type":"text","text":"can be polled for readiness to read. This can be used when"},{"text":" ","type":"text"},{"text":"interfacing with a non-GIO API that expects","type":"text"},{"type":"text","text":" "},{"type":"text","text":"UNIX-file-descriptor-style asynchronous I\/O rather than GIO-style."}],"type":"topic","navigatorTitle":[{"text":"PollableInputStreamRef","kind":"identifier"}],"url":"\/documentation\/gio\/pollableinputstreamref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"PollableInputStreamRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/PollableInputStreamRef/close(cancellable:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef\/close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"kind":"symbol","type":"topic","title":"close(cancellable:)","url":"\/documentation\/gio\/pollableinputstreamref\/close(cancellable:)","role":"symbol","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}]},"doc://GIO/documentation/GIO/PollableInputStreamRef/InputStreamProtocol-Implementations":{"title":"InputStreamProtocol Implementations","kind":"article","abstract":[],"role":"collectionGroup","type":"topic","url":"\/documentation\/gio\/pollableinputstreamref\/inputstreamprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableInputStreamRef\/InputStreamProtocol-Implementations"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}