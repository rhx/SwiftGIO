{"metadata":{"role":"symbol","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"symbolKind":"method","title":"close(cancellable:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Once the stream is closed, all other operations will return","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"closed"},{"text":". Closing a stream multiple times will not","type":"text"},{"text":" ","type":"text"},{"text":"return an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the stream."}]},{"inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file"},{"type":"text","text":" "},{"text":"descriptor) open after the stream is closed. See the documentation for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the individual stream for details."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the"},{"text":" ","type":"text"},{"type":"text","text":"close operation will finish as much as possible. A stream that failed"},{"type":"text","text":" "},{"text":"to close will still return ","type":"text"},{"type":"codeVoice","code":"closed"},{"text":" for all operations.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Still, it is important to check and report the error to the user,"},{"type":"text","text":" "},{"type":"text","text":"otherwise there might be a loss of data as all data might not be written."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not NULL, then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"text":" ","type":"text"},{"text":"can use a faster close that doesn’t block to e.g. check errors.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default implementation of this method just calls close on the"},{"text":" ","type":"text"},{"text":"individual input\/output streams.","type":"text"}]}]}],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"type":"text","text":" "},{"text":"close the individual input and output streams, if they are not already","type":"text"},{"text":" ","type":"text"},{"text":"closed.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/iostreamprotocol\/close(cancellable:)-2f30g"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol"]]},"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol\/close(cancellable:)-2f30g","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/IOStreamProtocol":{"navigatorTitle":[{"text":"IOStreamProtocol","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"IOStreamProtocol","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol","url":"\/documentation\/gio\/iostreamprotocol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"text":" represents an object that has both read and write streams.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Generally the two streams act as separate input and output streams,"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"title":"IOStreamProtocol","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/IOStreamProtocol/close(cancellable:)-2f30g":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol\/close(cancellable:)-2f30g","title":"close(cancellable:)","type":"topic","kind":"symbol","url":"\/documentation\/gio\/iostreamprotocol\/close(cancellable:)-2f30g","abstract":[{"text":"Closes the stream, releasing resources related to it. This will also","type":"text"},{"type":"text","text":" "},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"text":" ","type":"text"},{"text":"closed.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"role":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}