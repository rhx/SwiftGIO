"},{"type":"text","text":"state of the action."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a"},{"type":"text","text":" "},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"text":" ","type":"text"},{"text":"returned then the tuple specifies the inclusive lower and upper bound","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of valid values for the state."}]},{"type":"paragraph","inlineContent":[{"text":"In any case, the information is merely a hint.  It may be possible to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have a state value outside of the hinted range and setting a value"},{"text":" ","type":"text"},{"type":"text","text":"within the range may fail."}]},{"inlineContent":[{"type":"text","text":"The return value (if non-"},{"type":"codeVoice","code":"NULL"},{"text":") should be freed with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"text":"] when it is no longer required.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/ActionRef/ActionProtocol-Implementations":{"role":"collectionGroup","kind":"article","title":"ActionProtocol Implementations","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef\/ActionProtocol-Implementations","type":"topic","url":"\/documentation\/gio\/actionref\/actionprotocol-implementations"},"doc://GIO/documentation/GIO/ActionRef/getStateHint()":{"title":"getStateHint()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getStateHint"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef\/getStateHint()","abstract":[{"text":"Requests a hint about the valid range of values for the state of","type":"text"},{"text":" ","type":"text"},{"code":"action","type":"codeVoice"},{"type":"text","text":"."}],"url":"\/documentation\/gio\/actionref\/getstatehint()","kind":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ActionRef":{"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"ActionRef"}],"title":"ActionRef","abstract":[{"code":"GAction","type":"codeVoice"},{"type":"text","text":" represents a single named action."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ActionRef"}],"type":"topic","url":"\/documentation\/gio\/actionref"}}}