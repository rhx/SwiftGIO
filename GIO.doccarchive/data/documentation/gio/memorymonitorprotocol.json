{"kind":"symbol","sections":[],"metadata":{"roleHeading":"Protocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MemoryMonitorProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"MemoryMonitorProtocol"}],"role":"symbol","title":"MemoryMonitorProtocol","modules":[{"name":"GIO"}],"symbolKind":"protocol","externalID":"s:3GIO21MemoryMonitorProtocolP"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"relationshipsSections":[{"title":"Inherits From","type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/documentation\/GIO\/InitableProtocol"]},{"type":"conformingTypes","identifiers":["doc:\/\/GIO\/documentation\/GIO\/MemoryMonitor","doc:\/\/GIO\/documentation\/GIO\/MemoryMonitorRef"],"kind":"relationships","title":"Conforming Types"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MemoryMonitorProtocol"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"code":"GMemoryMonitor","type":"codeVoice"},{"text":" will monitor system memory and suggest to the application","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when to free memory so as to leave more room for other applications."},{"type":"text","text":" "},{"text":"It is implemented on Linux using the","type":"text"},{"type":"text","text":" "},{"identifier":"https:\/\/gitlab.freedesktop.org\/hadess\/low-memory-monitor\/","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"("},{"identifier":"https:\/\/hadess.pages.freedesktop.org\/low-memory-monitor\/","isActive":true,"type":"reference"},{"type":"text","text":")."}],"topicSections":[{"anchor":"Instance-Properties","generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/MemoryMonitorProtocol\/memory_monitor_ptr-2xide"]},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/MemoryMonitorProtocol\/connect(signal