{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/asyncinitable\/initasync(iopriority:cancellable:callback:userdata:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","doc:\/\/GIO\/documentation\/GIO\/AsyncInitable\/AsyncInitableProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Starts asynchronous initialization of the object implementing the"},{"type":"text","text":" "},{"type":"text","text":"interface. This must be done before any real use of the object after"},{"type":"text","text":" "},{"type":"text","text":"initial construction. If the object also implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"text":" you can","type":"text"},{"type":"text","text":" "},{"text":"optionally call ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" instead."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"initAsync"},{"text":"(","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_async_initable_new_async()"},{"type":"text","text":" should typically be used instead."}]},{"inlineContent":[{"text":"When the initialization is finished, ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" will be called. You can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then call "},{"type":"codeVoice","code":"g_async_initable_init_finish()"},{"text":" to get the result of the","type":"text"},{"type":"text","text":" "},{"text":"initialization.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Implementations may also support cancellation. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"text":", then initialization can be cancelled by triggering the cancellable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"text":"the object doesn’t support cancellable initialization, the error","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"inlineContent":[{"text":"As with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"type":"text","text":", if the object is not initialized, or initialization"},{"text":" ","type":"text"},{"text":"returns with an error, then all operations on the object except","type":"text"},{"text":" ","type":"text"},{"code":"g_object_ref()","type":"codeVoice"},{"type":"text","text":" and "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" are considered to be invalid, and"},{"text":" ","type":"text"},{"text":"have undefined behaviour. They will often fail with ","type":"text"},{"type":"codeVoice","code":"g_critical()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"g_warning()","type":"codeVoice"},{"type":"text","text":", but this must not be relied on."}],"type":"paragraph"},{"inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference","isActive":true},{"text":" can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be initialized multiple times; for more information, see "},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"If a class explicitly supports being initialized multiple times,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implementation requires yielding all subsequent calls to "},{"code":"init_async()","type":"codeVoice"},{"text":" on the","type":"text"},{"type":"text","text":" "},{"text":"results of the first call.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For classes that also support the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"text":" interface, the default","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implementation of this method will run the "},{"type":"codeVoice","code":"g_initable_init()"},{"text":" function","type":"text"},{"text":" ","type":"text"},{"text":"in a thread, so if you want to support asynchronous initialization via","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads, just implement the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true,"type":"reference"},{"text":" interface without overriding","type":"text"},{"text":" ","type":"text"},{"text":"any interface methods.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable\/initAsync(ioPriority:cancellable:callback:userData:)"},"sections":[],"metadata":{"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","modules":[{"name":"GIO"}],"title":"initAsync(ioPriority:cancellable:callback:userData:)","extendedModule":"GIO","externalID":"s:3GIO21AsyncInitableProtocolPAAE04initB010ioPriority11cancellable8callback8userDataySi_AA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgATtF::SYNTHESIZED::s:3GIO13AsyncInitableC","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"initAsync","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}]},"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol"