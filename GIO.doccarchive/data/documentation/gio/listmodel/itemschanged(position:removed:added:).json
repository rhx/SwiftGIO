{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Emits the [ListModel](\/\/documentation\/gio\/listmodel\/onitemschanged(flags:handler:) signal on ","type":"text"},{"type":"codeVoice","code":"list"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"itemsChanged"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"position"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"removed"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"added","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function should only be called by classes implementing"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel"},{"type":"text","text":". It has to be called after the internal representation"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"codeVoice","code":"list"},{"type":"text","text":" has been updated, because handlers connected to this signal"},{"type":"text","text":" "},{"type":"text","text":"might query the new state of the list."}]},{"inlineContent":[{"text":"Implementations must only make changes to the model (as visible to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its consumer) in places that will not cause problems for that"},{"text":" ","type":"text"},{"type":"text","text":"consumer.  For models that are driven directly by a write API (such"},{"type":"text","text":" "},{"type":"text","text":"as "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListStore","isActive":true},{"text":"), changes can be reported in response to uses of that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"API.  For models that represent remote data, changes should only be"},{"type":"text","text":" "},{"type":"text","text":"made from a fresh mainloop dispatch.  It is particularly not"},{"type":"text","text":" "},{"text":"permitted to make changes in response to a call to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel"},{"text":" ","type":"text"},{"text":"consumer API.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Stated another way: in general, it is assumed that code making a"},{"text":" ","type":"text"},{"text":"series of accesses to the model via the API, without returning to the","type":"text"},{"type":"text","text":" "},{"text":"mainloop, and without calling other code, will continue to view the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"same contents of the model."}]}]}],"metadata":{"extendedModule":"GIO","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"itemsChanged"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"position"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"removed","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"added"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","externalID":"s