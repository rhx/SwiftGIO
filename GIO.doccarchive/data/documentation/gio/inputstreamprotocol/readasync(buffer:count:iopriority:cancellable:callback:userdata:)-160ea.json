PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}],"type":"paragraph"},{"inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads to implement","type":"text"},{"type":"text","text":" "},{"text":"asynchronicity, so they are optional for inheriting classes. However, if you","type":"text"},{"type":"text","text":" "},{"text":"override one you must override all.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/InputStreamProtocol/readAsync(buffer:count:ioPriority:cancellable:callback:userData:)-160ea":{"abstract":[{"type":"text","text":"Request an asynchronous read of "},{"code":"count","type":"codeVoice"},{"text":" bytes from the stream into the buffer","type":"text"},{"type":"text","text":" "},{"text":"starting at ","type":"text"},{"type":"codeVoice","code":"buffer"},{"text":". When the operation is finished ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"type":"text","text":" "},{"text":"You can then call ","type":"text"},{"type":"codeVoice","code":"g_input_stream_read_finish()"},{"text":" to get the result of the","type":"text"},{"text":" ","type":"text"},{"text":"operation.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"readAsync","kind":"identifier"},{"kind":"text","text":"("},{"text":"buffer","kind"