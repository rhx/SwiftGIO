{"abstract":[{"text":"Tries to read ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from the stream into the buffer starting at"},{"text":" ","type":"text"},{"code":"buffer","type":"codeVoice"},{"type":"text","text":". Will block during this read."}],"metadata":{"extendedModule":"GIO","role":"symbol","externalID":"s:3GIO19InputStreamProtocolPAAE4read6buffer5count11cancellableSiSvSg_Siqd__SgtKAA011CancellableD0Rd__lF","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"read"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize"}],"symbolKind":"method","title":"read(buffer:count:cancellable:)","modules":[{"name":"GIO"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol\/read(buffer:count:cancellable:)-1gypb","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/inputstreamprotocol\/read(buffer:count:cancellable:)-1gypb"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"read"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"buffer"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier","text":"gssize"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO19CancellableProtocolP","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"If count is zero returns zero and does nothing. A value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" "},{"type":"text","text":"larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a "},{"code":"invalidArgument","type":"codeVoice"},{"type":"text","text":" error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes read into the buffer is returned."},{"type":"text","text":" "},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. near the end of a file. Zero is returned on end of file"},{"type":"text","text":" "},{"text":"(or if ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" is zero),  but never otherwise."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The returned "},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" is not a nul-terminated string, it can contain nul bytes"},{"text":" ","type":"text"},{"type":"text","text":"at any position, and this function doesn’t nul-terminate the "},{"type":"codeVoice","code":"buffer"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly."}]}]}],"references":{"doc://GIO/documentation/GIO/InputStreamProtocol":{"type":"topic","title":"InputStreamProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"InputStreamProtocol"}],"abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"url":"\/documentation\/gio\/inputstreamprotocol","na