{"kind":"symbol","abstract":[{"type":"text","text":"Like "},{"type":"codeVoice","code":"g_input_stream_read()"},{"type":"text","text":", this tries to read "},{"code":"count","type":"codeVoice"},{"text":" bytes from","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the stream in a blocking fashion. However, rather than reading into"},{"text":" ","type":"text"},{"text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the data that was read. This may be easier to use from language"},{"type":"text","text":" "},{"type":"text","text":"bindings."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/inputstreamprotocol\/readbytes(count:cancellable:)-89xre"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"readBytes(count:cancellable:)","extendedModule":"GIO","modules":[{"name":"GIO"}],"role":"symbol","externalID":"s:3GIO19InputStreamProtocolPAAE9readBytes5count11cancellable4GLib0F3RefVSgSi_qd__SgtKAA011CancellableD0Rd__lF","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"readBytes","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:4GLib8BytesRefV","kind":"typeIdentifier","text":"BytesRef"},{"kind":"text","text":"!"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"readBytes","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef"},{"text":"! ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"text":" : ","kind":"text"},{"text":"CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If count is zero, returns a zero-length [Bytes](\/\/documentation\/glib\/bytes and does nothing. A","type":"text"},{"type":"text","text":" "},{"type":"text","text":"value of "},{"code":"count","type":"codeVoice"},{"type":"text","text":" larger than "},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" will cause a"},{"text":" ","type":"text"},{"code":"invalidArgument","type":"codeVoice"},{"type":"text","text":" error."}]},{"inlineContent":[{"text":"On success, a new [Bytes](\/\/documentation\/glib\/bytes is returned. It is not an error if the","type":"text"},{"type":"text","text":" "},{"text":"size of this object is not the same as the requested size, as it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can happen e.g. near the end of a file. A zero-length [Bytes](\/\/documentation\/glib\/bytes is"},{"text":" ","type":"text"},{"text":"returned on end of file (or if ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" is zero), but never"},{"type":"text","text":" "},{"text":"otherwise.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}]},{"type":"paragraph","inlineContent":[{"text":"On error ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol"]]},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol\/readBytes(count:cancellable:)-89xre","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/InputStreamProtocol/readBytes(count:cancellable:)-89xre":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol\/readBytes(count:cancellable:)-89xre","type":"topic","abstract":[{"type":"text","text":"Like "},{"code":"g_input_stream_read()","type":"codeVoice"},{"type":"text","text":", this tries to read "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from"},{"type":"text","text":" "},{"type":"text","