{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19CancellableProtocolP"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Closing a stream multiple times will not return an error."}]},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"type":"text","text":" "},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"type":"text","text":" "},{"type":"text","text":"stream for details."}]},{"type":"paragraph","inlineContent":[{"text":"On failure the first error that happened will be reported, but the close","type":"text"},{"text":" ","type":"text"},{"text":"operation will finish as much as possible. A stream that failed to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"type":"codeVoice","code":"closed"},{"type":"text","text":" for all operations. Still, it"},{"text":" ","type":"text"},{"type":"text","text":"is important to check and report the error to the user."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned.","type":"text"},{"type":"text","text":" "},{"text":"Cancelling a close will still leave the stream closed, but some streams","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}]}]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"variants":[{"paths":["\/documentation\/gio\/inputstreamprotocol\/close(cancellable:)-9qwk9"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol"]]},"metadata":{"extendedModule":"GIO","role":"symbol","symbolKind":"method","externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbqd__Sg_tKAA011CancellableD0Rd__lF","title":"close(cancellable:)","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol\/close(cancellable:)-9qwk9","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/InputStreamProtocol/close(cancellable:)-9qwk9":{"kind":"symbol","title":"close(cancellable:)","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"type":"topic","url":"\/documentation\/gio\/inputstreamprotocol\/close(cancellable:)-9qwk9","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol\/close(cancellable:)-9qwk9"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/InputStreamProtocol":{"type":"topic","title":"InputStreamProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"InputStreamProtocol"}],"abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"url":"\/documentation\/gio\/inputstreamprotocol","navigatorTitle":[{"kind":"identifier","text":"InputStreamProtocol"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"}}}