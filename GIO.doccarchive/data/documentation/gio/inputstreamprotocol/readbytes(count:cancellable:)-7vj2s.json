{"kind":"symbol","abstract":[{"type":"text","text":"Like "},{"type":"codeVoice","code":"g_input_stream_read()"},{"text":", this tries to read ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from"},{"text":" ","type":"text"},{"type":"text","text":"the stream in a blocking fashion. However, rather than reading into"},{"text":" ","type":"text"},{"text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing","type":"text"},{"type":"text","text":" "},{"text":"the data that was read. This may be easier to use from language","type":"text"},{"type":"text","text":" "},{"type":"text","text":"bindings."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readBytes"},{"kind":"text","text":"("},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If count is zero, returns a zero-length [Bytes](\/\/documentation\/glib\/bytes and does nothing. A"},{"text":" ","type":"text"},{"type":"text","text":"value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"On success, a new [Bytes](\/\/documentation\/glib\/bytes is returned. It is not an error if the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"size of this object is not the same as the requested size, as it"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. near the end of a file. A zero-length [Bytes](\/\/documentation\/glib\/bytes is"},{"type":"text","text":" "},{"text":"returned on end of file (or if ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" is zero), but never"},{"type":"text","text":" "},{"type":"text","text":"otherwise."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"text":" ","type":"text"},{"type":"text","text":"partial result will be returned, without an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/inputstreamprotocol\/readbytes(count:cancellable:)-7vj2s"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","symbolKind":"method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readBytes"},{"kind":"text","text":"("},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"externalID":"s:3GIO19InputStreamProtocolPAAE9readBytes5count11cancellable4GLib0F3RefVSgSi_AA011CancellableJ0VSgtKF","extendedModule":"GIO","title":"readBytes(count:cancellable:)"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol\/readBytes(count:cancellable:)-7vj2s","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStreamProtocol"]]},"references":{"doc://GIO/documentation/GIO/InputStreamProtocol/readBytes(count:cancellable:)-7vj2s":{"url":"\/documentation\/gio\/inputstreamprotocol\/readbytes(count:cancellable:)-7vj2s","kind":"symbol","abstract":[{"text":"Like ","type":"text"},{"type":"codeVoice","code":"g_input_stream_read()"},{"type":"text","text":", this tries to read "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from"},{"type":"text","text":" "},{"type":"text","text":"the stream in a blocking fashion. However, rather than reading into"},{"type":"text","text":" "},{"type":"text","text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing"},{"type":"text","text":" "},{"text":"the data that was read. This may be easier to use from language","t