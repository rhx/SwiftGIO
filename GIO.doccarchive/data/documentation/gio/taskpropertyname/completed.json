aph"},{"type":"paragraph","inlineContent":[{"text":"The [Object](\/\/documentation\/gobject\/object\/onnotify(flags:handler:) signal for this change is emitted in the same main","type":"text"},{"type":"text","text":" "},{"type":"text","text":"context as the task’s callback, immediately after that callback is invoked."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/taskpropertyname\/completed"]}],"metadata":{"symbolKind":"case","title":"TaskPropertyName.completed","roleHeading":"Case","role":"symbol","externalID":"s:3GIO16TaskPropertyNameO9completedyA2CmF","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"completed"}],"modules":[{"name":"GIO"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TaskPropertyName\/completed","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Whether the task has completed, meaning its callback (if set) has been"},{"type":"text","text":" "},{"type":"text","text":"invoked."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TaskPropertyName"]]},"references":{"doc://GIO/documentation/GIO/TaskPropertyName":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TaskPropertyName"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TaskPropertyName","url":"\/documentation\/gio\/taskpropertyname","role":"symbol","title":"TaskPropertyName","kind":"symbol","abstract":[],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"TaskPropertyName"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Task":{"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTask"},{"text":" represents and ma