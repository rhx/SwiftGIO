ce"},{"type":"text","text":" that the connection wraps. The connection holds a reference"},{"type":"text","text":" "},{"text":"to this stream, and may run operations on the stream from other threads","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"throughout its lifetime. Consequently, after the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"text":" has been","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constructed, application code may only run its own operations on this"},{"type":"text","text":" "},{"type":"text","text":"stream when no "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":" operations are running.","type":"text"}],"url":"\/documentation\/gio\/tlsconnectionpropertyname\/baseiostream","kind":"symbol","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"baseIoStream","kind":"identifier"}],"type":"topic"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\