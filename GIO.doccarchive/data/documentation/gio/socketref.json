ype":"text"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBasedProtocol"}],"title":"DatagramBasedProtocol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DatagramBasedProtocol"}]},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/SocketRef/init(_:)-75t18":{"type":"topic","title":"init(_:)","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"kind":"text","text":")"}],"url":"\/documentation\/gio\/socketref\/init(_:)-75t18","abstract":[{"type":"text","text":"Reference intialiser for a related type that implements "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol","isActive":true}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(_:)-75t18","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Async