{"metadata":{"externalID":"s:3GIO9SocketRefV","symbolKind":"struct","modules":[{"name":"GIO"}],"roleHeading":"Structure","title":"SocketRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SocketRef"}],"navigatorTitle":[{"kind":"identifier","text":"SocketRef"}],"role":"symbol"},"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GSocket"},{"text":" is a low-level networking primitive. It is a more or less","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(_:)-12wgv","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(_:)-1goah","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(_:)-1iyza","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(_:)-75t18","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(_:)-ebnx","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(family:type:protocol:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(fd:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(opaquePointer:)"]},{"title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SocketRef\/ptr"],"generated":true,"anchor":"Instance-Properties"},{"title":"Type Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SocketRef\/newFrom(fd:)","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/unowned(_:)"],"generated":true,"anchor":"Type-Methods"},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/SocketRef\/DatagramBasedProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/GWeakCapturing-Implementations","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/InitableProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/ObjectProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/SocketProtocol-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/InitableProtocol","doc:\/\/GIO\/documentation\/GIO\/SocketProtocol"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"SocketRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"GSocket"},{"type":"text","text":" is the platform independent base upon which the higher level"},{"type":"text","text":" "},{"type":"text","text":"network primitives are based. Applications are not typically meant to"},{"type":"text","text":" "},{"type":"text","text":"use it directly, but rather through classes like [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":"],","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketService","isActive":true},{"type":"text","text":"] and [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection"},{"text":"]. However there may","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be cases where direct use of "},{"type":"codeVoice","code":"GSocket"},{"type":"text","text":" is useful."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"GSocket"},{"type":"text","text":" implements the [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":"] interface, so if it is manually"},{"text":" ","type":"text"},{"type":"text","text":"constructed by e.g. [ctor"},{"code":"GObject.Object.new","type":"codeVoice"},{"text":"] you must call","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"type":"text","text":"] and check the results before using the object."},{"type":"text","text":" "},{"text":"This is done automatically in [ctor","type":"text"},{"type":"codeVoice","code":"Gio.Socket.new"},{"text":"] and","type":"text"},{"type":"text","text":" "},{"text":"[ctor","type":"text"},{"code":"Gio.Socket.new_from_fd","type":"codeVoice"},{"type":"text","text":"], so these functions can return "},{"code":"NULL","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sockets operate in two general modes, blocking or non-blocking. When"},{"type":"text","text":" "},{"text":"in blocking mode all operations (which don’t take an explicit blocking","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameter) block until the requested operation"},{"type":"text","text":" "},{"type":"text","text":"is finished or there is an error. In non-blocking mode all calls that"},{"type":"text","text":" "},{"type":"text","text":"would block return immediately with a "},{"type":"codeVoice","code":"G_IO_ERROR_WOULD_BLOCK"},{"text":" error.","type":"text"},{"type":"text","text":" "},{"text":"To know when a call would successfully run you can call","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.Socket.condition_check","type":"codeVoice"},{"text":"], or [method","type":"text"},{"code":"Gio.Socket.condition_wait","type":"codeVoice"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"You can also use [method","type":"text"},{"code":"Gio.Socket.create_source","type":"codeVoice"},{"text":"] and attach it to a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[type[MainContext](\/\/documentation\/glib\/maincontext] to get callbacks when I\/O is possible."},{"type":"text","text":" "},{"type":"text","text":"Note that all sockets are always set to non blocking mode in the system, and"},{"type":"text","text":" "},{"type":"text","text":"blocking mode is emulated in "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When working in non-blocking mode applications should always be able to"},{"type":"text","text":" "},{"type":"text","text":"handle getting a "},{"type":"codeVoice","code":"G_IO_ERROR_WOULD_BLOCK"},{"type":"text","text":" error even when some other"},{"type":"text","text":" "},{"type":"text","text":"function said that I\/O was possible. This can easily happen in case"},{"text":" ","type":"text"},{"type":"text","text":"of a race condition in the application, but it can also happen for other"},{"type":"text","text":" "},{"type":"text","text":"reasons. For instance, on Windows a socket is always seen as writable"},{"text":" ","type":"text"},{"type":"text","text":"until a write returns "},{"code":"G_IO_ERROR_WOULD_BLOCK","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"codeVoice","code":"GSocket"},{"type":"text","text":"s can be either connection oriented or datagram based."},{"type":"text","text":" "},{"type":"text","text":"For connection oriented types you must first establish a connection by"},{"type":"text","text":" "},{"text":"either connecting to an address or accepting a connection from another","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"address. For connectionless socket types the target\/source address is"},{"type":"text","text":" "},{"type":"text","text":"specified or received in each I\/O operation."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All socket file descriptors are set to be close-on-exec."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that creating a "},{"type":"codeVoice","code":"GSocket"},{"type":"text","text":" causes the signal "},{"code":"SIGPIPE","type":"codeVoice"},{"text":" to be","type":"text"},{"text":" ","type":"text"},{"text":"ignored for the remainder of the program. If you are writing a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"command-line utility that uses "},{"type":"codeVoice","code":"GSocket"},{"type":"text","text":", you may need to take into"},{"text":" ","type":"text"},{"text":"account the fact that your program will not automatically be killed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"if it tries to write to "},{"type":"codeVoice","code":"stdout"},{"type":"text","text":" after it has been closed."}]},{"inlineContent":[{"text":"Like most other APIs in GLib, ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"text":" is not inherently thread safe. To use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"GSocket"},{"type":"text","text":" concurrently from multiple threads, you must implement your own"},{"type":"text","text":" "},{"text":"locking.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"Nagles-algorithm","text":"Nagle’s algorithm"},{"inlineContent":[{"type":"text","text":"Since GLib 2.80, "},{"code":"GSocket","type":"codeVoice"},{"text":" will automatically set the ","type":"text"},{"type":"codeVoice","code":"TCP_NODELAY"},{"text":" option on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"all "},{"code":"G_SOCKET_TYPE_STREAM","type":"codeVoice"},{"text":" sockets. This disables","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/en.wikipedia.org\/wiki\/Nagle%27s_algorithm"},{"type":"text","text":" as it"},{"type":"text","text":" "},{"text":"typically does more harm than good on modern networks.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your application needs Nagle’s algorithm enabled, call"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.Socket.set_option","type":"codeVoice"},{"type":"text","text":"] after constructing a "},{"type":"codeVoice","code":"GSocket"},{"text":" to enable it:","type":"text"}]},{"type":"codeListing","syntax":"c","code":["socket = g_socket_new (…, G_SOCKET_TYPE_STREAM, …);","if (socket != NULL)","  {","    g_socket_set_option (socket, IPPROTO_TCP, TCP_NODELAY, FALSE, &local_error);","    \/\/ handle error if needed","  }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference"},{"text":" (instead of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketRef","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"variants":[{"paths":["\/documentation\/gio\/socketref"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/4GLib14PointerWrapperP":{"type":"unresolvable","identifier":"doc:\/\/GIO\/4GLib14PointerWrapperP","title":"GLib.PointerWrapper"},"doc://GIO/documentation/GIO/SocketRef/init(_:)-ebnx":{"url":"\/documentation\/gio\/socketref\/init(_:)-ebnx","title":"init(_:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"text":"!(","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"GSocket","kind":"typeIdentifier"},{"kind":"text","text":">?)"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init(_:)-ebnx","abstract":[{"type":"text","text":"Conditional initialiser from an optional, non-mutable pointer to the underlying "},{"code":"C","type":"codeVoice"},{"text":" data type","type":"text"}]},"doc://GIO/documentation/GIO/SocketProtocol/socket_ptr-6kzmb":{"role":"symbol","abstract":[{"type":"text","text":"Typed pointer to the underlying "},{"type":"codeVoice","code":"GSocket"},{"text":" instance.","type":"text"}],"title":"socket_ptr","url":"\/docume