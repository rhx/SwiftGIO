:"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"send","kind":"identifier"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GOutputMessage"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"code":"messages","type":"codeVoice"},{"text":" must point to an array of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"type":"text","text":" structs and"},{"text":" ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"text":" must be the length of this array. Each ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" "},{"text":"contains an address to send the data to, and a pointer to an array of","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","type":"reference"},{"type":"text","text":" structs to describe the buffers that the data to be sent"},{"text":" ","type":"text"},{"type":"text","text":"for each message will be gathered from."}],"type":"paragraph"},{"inlineContent":[{"code":"flags","type":"codeVoice"},{"type":"text","text":" modify how the message is sent. The commonly available arguments"},{"text":" ","type":"text"},{"text":"for this are available in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"type":"text","text":" enum, but the"},{"text":" ","type":"text"},{"type":"text","text":"values there are the same as the system values, and the flags"},{"type":"text","text":" "},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The other members of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","type":"reference","isActive":true},{"text":" are treated as described in its","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"documentation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is negative the call will block until "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" have been"},{"text":" ","type":"text"},{"type":"text","text":"sent, "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled, or an error occurs."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is 0 the call will send up to "},{"type":"codeVoice","code":"numMessages"},{"text":" without blocking,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or will return "},{"code":"wouldBlock","type":"codeVoice"},{"text":" if there is no space to send messages.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"type":"text","text":" "},{"type":"codeVoice","code":"timeout"},{"text":" were negative. If the timeout is reached before any messages are","type":"text"},{"text":" ","type":"text"},{"text":"sent, ","type":"text"},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned, otherwise it will return the number"},{"text":" ","type":"text"},{"text":"of messages sent before timing out.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition."},{"type":"text","text":" "},{"text":"Note though that you may still receive ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"type":"text","text":" even if you were previously notified of a"},{"text":" ","type":"text"},{"type":"text","text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to"},{"text":" ","type":"text"},{"type":"text","text":"the way the underlying APIs work.)"}]},{"inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"type":"codeVoice","code":"g_socket_close()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_shutdown()"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"shutdown_write"},{"text":" set, if it’s a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true},{"text":", for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example), all calls to this function will return "},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly. An error will only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be returned if zero messages could be sent; otherwise the number of messages"},{"text":" ","type":"text"},{"text":"successfully sent before the error will be returned. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cancelled, "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any other error."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsserverconnectionref\/send(messages:nummessages:flags:timeout:cancellable:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnectionRef\/send(messages:numMessages:flags:timeout:cancellable:)","interfaceLanguage":"swift"},"kind":"symbol","references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/docum