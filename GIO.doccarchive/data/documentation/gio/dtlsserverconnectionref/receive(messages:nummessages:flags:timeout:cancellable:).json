{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"Receive one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"receive"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GInputMessage"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"timeout"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gint64","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"messages"},{"type":"text","text":" must point to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true,"type":"reference"},{"text":" structs and","type":"text"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"text":" must be the length of this array. Each ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"type":"text","text":" "},{"type":"text","text":"contains a pointer to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","type":"reference","isActive":true},{"type":"text","text":" structs describing the"},{"text":" ","type":"text"},{"text":"buffers that the data received in each message will be written to.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" modify how all messages are received. The commonly available","type":"text"},{"text":" ","type":"text"},{"text":"arguments for this are available in the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true},{"text":" enum, but the","type":"text"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too. These"},{"type":"text","text":" "},{"text":"flags affect the overall receive operation. Flags affecting individual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messages are returned in "},{"type":"codeVoice","code":"GInputMessage.flags"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The other members of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"text":" are treated as described in its","type":"text"},{"type":"text","text":" "},{"text":"documentation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is negative the call will block until ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"text":" have been","type":"text"},{"type":"text","text":" "},{"text":"received, the connection is closed remotely (EOS), ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is cancelled,","type":"text"},{"type":"text","text":" "},{"text":"or an error occurs.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"text":" is 0 the call will return up to ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" without blocking,","type":"text"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"text":" if no messages are queued in the operating system","type":"text"},{"type":"text","text":" "},{"text":"to be received.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"type":"text","text":" "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" were negative. If the timeout is reached"},{"text":" ","type":"text"},{"type":"text","text":"before any messages are received, "},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned,"},{"type":"text","text":" "},{"type":"text","text":"otherwise it will return the number of messages received before timing out."},{"type":"text","text":" "},{"text":"(Note: This is effectively the behaviour of ","type":"text"},{"type":"codeVoice","code":"MSG_WAITFORONE"},{"text":" with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"recvmmsg()"},{"text":".)","type":"text"}]},{"inlineContent":[{"text":"To be notified when messages are available, wait for the [in_](\/\/documentation\/gobject\/in_ condition.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Note though that you may still receive "},{"type":"codeVoice","code":"wouldBlock"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"code":"g_datagram_based_receive_messages()","type":"codeVoice"},{"text":" even if you were previously notified of a","type":"text"},{"type":"text","text":" "},{"text":"[in_](\/\/documentation\/gobject\/in_ condition.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the remote peer closes the connection, any messages queued in the","type":"text"},{"type":"text","text":" "},{"text":"underlying receive buffer will be returned, and subsequent calls to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":" will return 0 (with no error set)."}]},{"inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"code":"shutdown_read","type":"codeVoice"},{"text":" set, if it’s a ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference","isActive":true},{"text":", for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example), all calls to this function will return "},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"type":"text","text":"be returned if zero messages could be received; otherwise the number of"},{"type":"text","text":" "},{"text":"messages successfully received before the error will be returned. If","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled, "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any"},{"text":" 