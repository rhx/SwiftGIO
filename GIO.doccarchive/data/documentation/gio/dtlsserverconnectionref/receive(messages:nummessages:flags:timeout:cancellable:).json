 Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/InputMessage":{"navigatorTitle":[{"text":"InputMessage","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","url":"\/documentation\/gio\/inputmessage","title":"InputMessage","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InputMessage","kind":"identifier"}],"abstract":[{"type":"text","text":"Structure used for scatter\/gather data input when receiving multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of empty","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"text":" and the operation will use all the buffers as if they","type":"text"},{"type":"text","text":" "},{"type":"text","text":"were one buffer, and will set "},{"type":"codeVoice","code":"bytes_received"},{"type":"text","text":" to the total number of bytes"},{"type":"text","text":" "},{"text":"received across all ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"type":"text","text":"."}],"role":"symbol","kind":"symbol","type":"topic"}}}