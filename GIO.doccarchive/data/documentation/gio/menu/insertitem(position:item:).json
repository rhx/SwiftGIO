{"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menu\/insertitem(position:item:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Menu\/insertItem(position:item:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"insertItem","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuItemT"},{"text":">(","kind":"text"},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"item"},{"text":": ","kind":"text"},{"text":"MenuItemT","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItemT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"text":"MenuItemProtocol","preciseIdentifier":"s:3GIO16MenuItemProtocolP","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"The “insertion” is actually done by copying all of the attribute and","type":"text"},{"type":"text","text":" "},{"text":"link values of ","type":"text"},{"type":"codeVoice","code":"item"},{"text":" and using them to form a new item within ","type":"text"},{"type":"codeVoice","code":"menu"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"As such, "},{"type":"codeVoice","code":"item"},{"text":" itself is not really inserted, but rather, a menu item","type":"text"},{"type":"text","text":" "},{"text":"that is exactly the same as the one presently described by ","type":"text"},{"type":"codeVoice","code":"item"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"This means that ","type":"text"},{"code":"item","type":"codeVoice"},{"type":"text","text":" is essentially useless after the insertion"},{"type":"text","text":" "},{"type":"text","text":"occurs.  Any changes you make to it are ignored unless it is inserted"},{"text":" ","type":"text"},{"text":"again (at which point its updated values will be copied).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should probably just free "},{"type":"codeVoice","code":"item"},{"type":"text","text":" once you’re done."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are many convenience functions to take care of common cases."},{"type":"text","text":" "},{"text":"See ","type":"text"},{"type":"codeVoice","code":"g_menu_insert()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_menu_insert_section()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_menu_insert_submenu()"},{"type":"text","text":" as well as “prepend” and “append” variants of"},{"text":" ","type":"text"},{"type":"text","text":"each of these functions."}]}],"kind":"content"}],"metadata":{"role":"symbol","externalID":"s:3GIO12MenuProtocolPAAE10insertItem8position4itemySi_qd__tAA0beC0Rd__lF::SYNTHESIZED::s:3GIO4MenuC","modules":[{"name":"GIO"}],"extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"insertItem","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"MenuItemT"},{"kind":"text","text":">("},{"text":"position","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"item","kind":"externalParam"},{"kind":"text","text":": "},{"text":"MenuItemT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"title":"insertItem(position:item:)"},"kind":"symbol","abstract":[{"type":"text","text":"Inserts "},{"code":"item","type":"codeVoice"},{"type":"text","text":" into "},{"type":"codeVoice","code":"menu"},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Menu","doc:\/\/GIO\/documentation\/GIO\/Menu\/MenuProtocol-Implementations"]]},"sections":[],"references":{"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/Menu/insertItem(position:item:)":{"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"insertItem"},{"text":"<","kind":"text"},{"text":"MenuItemT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"item","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MenuItemT"},{"kind":"text","text":")"}],"kind":"symbol","role":"symbol","title":"insertItem(position:item:)","abstract":[{"text":"Inserts ","type":"text"},{"type":"codeVoice","code":"item"},{"type":"text","text":" into "},{"code":"menu","type":"codeVoice"},{"type":"text","text":"."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu\/insertItem(position:item:)","url":"\/documentation\/gio\/menu\/insertitem(position:item:)"},"doc://GIO/documentation/GIO/MenuItemProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MenuItemProtocol","kind":"identifier"}],"title":"MenuItemProtocol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem"},{"type":"text","text":" is an opaque structure type.  You must access it using the"},{"type":"text","text":" "},{"text":"functions below.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol","kind":"symbol","url":"\/documentation\/gio\/menuitemprotocol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MenuItemProtocol"}]},"doc://GIO/documentation/GIO/Menu":{"type":"topic","kind":"symbol","title":"Menu","navigatorTitle":[{"kind":"identifier","text":"Menu"}],"abstract":[{"type":"codeVoice","code":"GMenu"},{"type":"text","text":" is a simple implementation of [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"You populate a ","type":"text"},{"type":"codeVoice","code":"GMenu"},{"type":"text","text":" by adding [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem"},{"type":"text","text":"] instances to it."}],"url":"\/documentation\/gio\/menu","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Menu","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/Menu/MenuProtocol-Implementations":{"type":"topic","abstract":[],"kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu\/MenuProtocol-Implementations","url":"\/documentation\/gio\/menu\/menuprotocol-implementations","title":"MenuProtocol Implementations"}}}