"text":"constPointer","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":">)","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef\/init(constPointer:)","role":"symbol"},"doc://GIO/documentation/GIO/DBusObjectManagerClientRef/init(_:)-520vh":{"title":"init(_:)","kind":"symbol","url":"\/documentation\/gio\/dbusobjectmanagerclientref\/init(_:)-520vh","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"!("},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"GDBusObjectManagerClient","kind":"typeIdentifier"},{"text":">?)","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef\/init(_:)-520vh","abstract":[{"type":"text","text":"Conditional initialiser from an optional, non-mutable pointer to the underlying "},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type"}],"type":"topic"},"doc://GIO/documentation/GIO/DBusObjectManagerClientProtocol/dbus_object_manager_client_ptr-8wtaw":{"title":"dbus_object_manager_client_ptr","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientProtocol\/dbus_object_manager_client_ptr-8wtaw","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"dbus_object_manager_client_ptr","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GDBusObjectManagerClient"},{"kind":"text","text":">!"}],"type":"topic","url":"\/documentation\/gio\/dbusobjectmanagerclientprotocol\/dbus_object_manager_client_ptr-8wtaw","defaultImplementations":1,"kind":"symbol","required":true,"abstract":[{"text":"Typed pointer to the underlying ","type":"text"},{"code":"GDBusObjec