{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ActionProtocol\/stateHint"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"stateHint","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"! { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" is returned it either means that the action is not stateful"},{"type":"text","text":" "},{"type":"text","text":"or that there is no hint about the valid range of values for the"},{"type":"text","text":" "},{"text":"state of the action.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"type":"text","text":" "},{"type":"text","text":"returned then the tuple specifies the inclusive lower and upper bound"},{"type":"text","text":" "},{"type":"text","text":"of valid values for the state."}]},{"inlineContent":[{"type":"text","text":"In any case, the information is merely a hint.  It may be possible to"},{"type":"text","text":" "},{"type":"text","text":"have a state value outside of the hinted range and setting a value"},{"type":"text","text":" "},{"text":"within the range may fail.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The return value (if non-","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":") should be freed with"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.Variant.unref","type":"codeVoice"},{"text":"] when it is no longer required.","type":"text"}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ActionProtocol"]]},"metadata":{"externalID":"s:3GIO14ActionProtocolPAAE9stateHint4GLib10VariantRefVSgvp","extendedModule":"GIO","modules":[{"name":"GIO"}],"title":"stateHint","symbolKind":"property","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stateHint"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"roleHeading":"Instance Property"},"abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of"},{"text":" ","type":"text"},{"code":"action","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/actionprotocol\/statehint"]}],"references":{"doc://GIO/documentation/GIO/ActionProtocol/stateHint":{"abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of"},{"type":"text","text":" "},{"type":"codeVoice","code":"action"},{"text":".","type":"text"}],"url":"\/documentation\/gio\/actionprotocol\/statehint","type":"topic","title":"stateHint","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stateHint"},{"text":": ","kind":"text"},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionProtocol\/stateHint","role":"symbol"},"doc://GIO/documentation/GIO/ActionProtocol":{"role":"symbol","title":"ActionProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"ActionProtocol","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionProtocol","navigatorTitle":[{"kind":"identifier","text":"ActionProtocol"}],"type":"topic","url":"\/documentation\/gio\/actionprotocol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}