"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"model"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO12MenuModelRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","text":"MenuModelRef"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Links are used to establish a relationship between a particular menu","type":"text"},{"type":"text","text":" "},{"type":"text","text":"item and another menu.  For example, "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSubmenu","isActive":true,"type":"reference"},{"type":"text","text":" is used to"},{"type":"text","text":" "},{"text":"associate a submenu with a particular menu item, and ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSection","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"is used to create a section. Other types of link can be used, but there"},{"type":"text","text":" "},{"type":"text","text":"is no guarantee that clients will be able to make sense of them."},{"type":"text","text":" "},{"type":"text","text":"Link types are restricted to lowercase characters, numbers"},{"text":" ","type":"text"},{"type":"text","text":"and ‘-’. Furthermore, the names must begin with a lowercase character,"},{"text":" ","type":"text"},{"type":"text","text":"must not end with a ‘-’, and must not contain consecutive dashes."}]}]}],"references":{"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuItem/set(link:model:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem\/set(link:model:)","abstract":[{"text":"Creates a link from ","type":"text"},{"code":"menuItem","type":"codeVoice"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"model"},{"type":"text","text":" if non-"},{"type":"codeVoice","code":"nil"},{"text":", or unsets it.","type":"text"}],"title":"set(link:model:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"link","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"model"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO12MenuModelRefV","text":"MenuModelRef"},{"kind":"text","text":"?)"}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/menuitem\/set(link:model:)","type":"topic"},"doc://GIO/documentation/GIO/menuLinkSection":{"kind":"symbol","title":"menuLinkSection","url":"\/documentation\/gio\/menulinksection","type":"topic","abstract":[{"type":"text","text":"The name of the link that associates a menu item with a section.  The linked"},{"text":" ","type":"text"},{"type":"text","text":"menu will usually be shown in place of the menu item, using the item’s label"},{"text":" ","type":"text"},{"type":"text","text":"as a header."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSection","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"menuLinkSection"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}]},"doc://GIO/documentation/GIO/menuLinkSubmenu":{"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"menuLinkSubmenu"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"kind":"symbol","url":"\/documentation\/gio\/menulinksubmenu","abstract":[{"type":"text","text":"The name of the link that associates a menu item with a submenu."}],"type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSubmenu","title":"menuLinkSubmenu"},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuItem/MenuItemProtocol-Implementations":{"type":"topic","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem\/MenuItemProtocol-Implementations","title":"MenuItemProtocol Implementations","kind":"article","abstract":[],"url":"\/documentation\/gio\/menuitem\/menuitemprotocol-implementations"}}}