{"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuItem\/init(section:section:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Creates a new "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"type":"text","text":" representing a section."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"MenuModelT"},{"kind":"text","text":">("},{"text":"section","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"label"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">? = nil, ","kind":"text"},{"text":"section","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MenuModelT"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"MenuModelT"},{"kind":"text","text":" : "},{"text":"MenuModelProtocol","preciseIdentifier":"s:3GIO17MenuModelProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is a convenience API around "},{"type":"codeVoice","code":"g_menu_item_new()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_menu_item_set_section()"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The effect of having one menu appear as a section of another is","type":"text"},{"type":"text","text":" "},{"text":"exactly as it sounds: the items from ","type":"text"},{"type":"codeVoice","code":"section"},{"text":" become a direct part of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the menu that "},{"type":"codeVoice","code":"menu_item"},{"text":" is added to.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Visual separation is typically displayed between two non-empty"},{"type":"text","text":" "},{"text":"sections.  If ","type":"text"},{"code":"label","type":"codeVoice"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then it will be incorporated into"},{"type":"text","text":" "},{"type":"text","text":"this visual indication.  This allows for labeled subsections of a"},{"type":"text","text":" "},{"type":"text","text":"menu."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As a simple example, consider a typical “Edit” menu from a simple"},{"text":" ","type":"text"},{"text":"program.  It probably contains an “Undo” and “Redo” item, followed by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a separator, followed by “Cut”, “Copy” and “Paste”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This would be accomplished by creating three "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu","isActive":true},{"type":"text","text":" instances.  The"},{"text":" ","type":"text"},{"type":"text","text":"first would be populated with the “Undo” and “Redo” items, and the"},{"type":"text","text":" "},{"type":"text","text":"second with the “Cut”, “Copy” and “Paste” items.  The first and"},{"type":"text","text":" "},{"type":"text","text":"second menus would then be added as submenus of the third.  In XML"},{"text":" ","type":"text"},{"type":"text","text":"format, this would look something like the following:"}]},{"code":["<menu id='edit-menu'>","  <section>","    <item label='Undo'\/>","    <item label='Redo'\/>","  <\/section>","  <section>","    <item label='Cut'\/>","    <item label='Copy'\/>","    <item label='Paste'\/>","  <\/section>","<\/menu>"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The following example is exactly equivalent.  It is more illustrative","type":"text"},{"type":"text","text":" "},{"text":"of the exact relationship between the menus and items (keeping in","type":"text"},{"type":"text","text":" "},{"text":"mind that the ‘link’ element defines a new menu that is linked to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"containing one).  The style of the second example is more verbose and"},{"text":" ","type":"text"},{"type":"text","text":"difficult to read (and therefore not recommended except for the"},{"type":"text","text":" "},{"text":"purpose of understanding what is really going on).","type":"text"}]},{"type":"codeListing","syntax":null,"code":["<menu id='edit-menu'>","  <item>","    <link name='section'>","      <item label='Undo'\/>","      <item label='Redo'\/>","    <\/link>","  <\/item>","  <item>","    <link name='section'>","      <item label='Cut'\/>","      <item label='Copy'\/>","      <item label='Paste'\/>","    <\/link>","  <\/item>","<\/menu>"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menuitem\/init(section:section:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItem"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"title":"init(section:section:)","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuModelT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"section"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">?, ","kind":"text"},{"text":"section","kind":"externalParam"},{"kind":"text","text":": "},{"text":"MenuModelT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"externalID":"s:3GIO8MenuItemC7sectionAdCSPys4Int8VGSg_xtcAA0B13ModelProtocolRzlufc","symbolKind":"init","roleHeading":"Initializer"},"references":{"doc://GIO/documentation/GIO/MenuItem/init(section:section:)":{"fragments":[{"kind":"identifier","text":"init"},{"text":"<","kind":"text"},{"text":"MenuModelT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"section","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?, "},{"text":"section","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MenuModelT"},{"kind":"text","text":")"}],"type":"topic","url":"\/documentation\/gio\/menuitem\/init(section:section:)","title":"init(section:section:)","kind":"symbol","abstract":[{"text":"Creates a new ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","type":"reference","isActive":true},{"type":"text","text":" representing a section."}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem\/init(section:section:)"},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModelProtocol":{"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/menumodelprotocol","navigatorTitle":[{"text":"MenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/Menu":{"type":"topic","kind":"symbol","title":"Menu","navigatorTitle":[{"kind":"identifier","text":"Menu"}],"abstract":[{"type":"codeVoice","code":"GMenu"},{"type":"text","text":" is a simple implementation of [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"You populate a ","type":"text"},{"type":"codeVoice","code":"GMenu"},{"type":"text","text":" by adding [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem"},{"type":"text","text":"] instances to it."}],"url":"\/documentation\/gio\/menu","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Menu","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu"}}}