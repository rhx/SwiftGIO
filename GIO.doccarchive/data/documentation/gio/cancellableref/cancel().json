{"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CancellableRef","doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/CancellableProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/cancel()","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"cancel"},{"kind":"text","text":"()"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is thread-safe. In other words, you can safely call"},{"text":" ","type":"text"},{"text":"it from a thread other than the one running the operation that was","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"passed the "},{"code":"cancellable","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", this function returns immediately for convenience."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The convention within GIO is that cancelling an asynchronous","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation causes it to complete asynchronously. That is, if you"},{"type":"text","text":" "},{"text":"cancel the operation from the same thread in which it is running,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then the operation’s "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback"},{"type":"text","text":" will not be invoked until"},{"text":" ","type":"text"},{"type":"text","text":"the application returns to the main loop."}]},{"type":"paragraph","inlineContent":[{"text":"It is safe (although useless, since it will be a no-op) to call","type":"text"},{"type":"text","text":" "},{"text":"this function from a [signal[Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:)] signal handler.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/cancellableref\/cancel()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Will set "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" to cancelled, and will emit the"},{"type":"text","text":" "},{"type":"text","text":"[Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:) signal. (However, see the warning about"},{"text":" ","type":"text"},{"text":"race conditions in the documentation for that signal if you are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"planning to connect to it.)"}],"metadata":{"extendedModule":"GIO","title":"cancel()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancel","kind":"identifier"},{"text":"()","kind":"text"}],"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","externalID":"s:3GIO19CancellableProtocolPAAE6cancelyyF::SYNTHESIZED::s:3GIO14CancellableRefV"},"references":{"doc://GIO/documentation/GIO/AsyncReadyCallback":{"navigatorTitle":[{"kind":"identifier","text":"AsyncReadyCallback"}],"title":"AsyncReadyCallback","abstract":[{"text":"Type definition for a function that will be called back when an asynchronous","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation within GIO has been completed. "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"callbacks from "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"text":" are guaranteed to be invoked in a later","type":"text"},{"type":"text","text":" "},{"text":"iteration of the thread-default main context","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(see [method"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"])","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"type":"text","text":" was created. All other users of"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","isActive":true,"type":"reference"},{"type":"text","text":" must likewise call it asynchronously in a"},{"text":" ","type":"text"},{"text":"later iteration of the main context.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AsyncReadyCallback"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","url":"\/documentation\/gio\/asyncreadycallback"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/CancellableRef/CancellableProtocol-Implementations":{"type":"topic","url":"\/documentation\/gio\/cancellableref\/cancellableprotocol-implementations","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/CancellableProtocol-Implementations","title":"CancellableProtocol Implementations","kind":"article"},"doc://GIO/documentation/GIO/CancellableRef/cancel()":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/cancel()","abstract":[{"type":"text","text":"Will set "},{"type":"codeVoice","code":"cancellable"},{"text":" to cancelled, and will emit the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:) signal. (However, see the warning about"},{"type":"text","text":" "},{"text":"race conditions in the documentation for that signal if you are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"planning to connect to it.)"}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancel","kind":"identifier"},{"text":"()","kind":"text"}],"title":"cancel()","url":"\/documentation\/gio\/cancellableref\/cancel()"},"doc://GIO/documentation/GIO/Task":{"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GTask"},{"text":" represents and manages a cancellable ‘task’.","type":"text"}],"type":"topic","url":"\/documentation\/gio\/task","title":"Task","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"Task","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Task"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"}}}