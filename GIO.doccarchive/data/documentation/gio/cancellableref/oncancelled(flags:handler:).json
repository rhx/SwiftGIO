{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/onCancelled(flags:handler:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onCancelled","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"kind":"text","text":" = ConnectFlags(0), "},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"code":"cancelled","type":"codeVoice"},{"text":" signal is emitted","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Can be used by implementations of cancellable operations. If the","type":"text"},{"text":" ","type":"text"},{"text":"operation is cancelled from another thread, the signal will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"emitted in the thread that cancelled the operation, not the"},{"type":"text","text":" "},{"text":"thread that is running the operation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that disconnecting from this signal (or any signal) in a"},{"text":" ","type":"text"},{"type":"text","text":"multi-threaded program is prone to race conditions. For instance"},{"type":"text","text":" "},{"type":"text","text":"it is possible that a signal handler may be invoked even after"},{"text":" ","type":"text"},{"type":"text","text":"a call to "},{"code":"g_signal_handler_disconnect()","type":"codeVoice"},{"text":" for that handler has","type":"text"},{"text":" ","type":"text"},{"text":"already returned.","type":"text"}]},{"inlineContent":[{"text":"There is also a problem when cancellation happens right before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connecting to the signal. If this happens the signal will"},{"type":"text","text":" "},{"type":"text","text":"unexpectedly not be emitted, and checking before connecting to"},{"type":"text","text":" "},{"text":"the signal leaves a race condition where this is still happening.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to make it safe and easy to connect handlers there"},{"text":" ","type":"text"},{"type":"text","text":"are two helper functions: "},{"type":"codeVoice","code":"g_cancellable_connect()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"g_cancellable_disconnect()","type":"codeVoice"},{"type":"text","text":" which protect against problems"},{"text":" ","type":"text"},{"text":"like this.","type":"text"}]},{"inlineContent":[{"text":"An example of how to us this:","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","code":["    \/\/ Make sure we don't do unnecessary work if already cancelled","    if (g_cancellable_set_error_if_cancelled (cancellable, error))","      return;","","    \/\/ Set up all the data needed to be able to handle cancellation","    \/\/ of the operation","    my_data = my_data_new (...);","","    id = 0;","    if (cancellable)","      id = g_cancellable_connect (cancellable,","    \t\t\t      G_CALLBACK (cancelled_handler)","    \t\t\t      data, NULL);","","    \/\/ cancellable operation here...","","    g_cancellable_disconnect (cancellable, id);","","    \/\/ cancelled_handler is never called after this, it is now safe","    \/\/ to free the data","    my_data_free (my_data);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Note that the cancelled signal is emitted in the thread that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user cancelled from, which may be the main thread. So, the"},{"type":"text","text":" "},{"type":"text","text":"cancellable signal should not do something that can block."}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" signal"}]}],"type":"aside","style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/cancellableref\/oncancelled(flags:handler:)"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"metadata":{"title":"onCancelled(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onCancelled"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"modules":[{"name":"GIO"}],"extendedModule":"GIO","symbolKind":"method","role":"symbol","externalID":"s:3GIO19CancellableProtocolPAAE11onCancelled5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0B3RefVctF::SYNTHESIZED::s:3GIO14CancellableRefV","roleHeading":"Instance Method"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CancellableRef","doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/CancellableProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Emitted when the operation has been cancelled."}],"references":{"doc://GIO/documentation/GIO/CancellableRef/onCancelled(flags:handler:)":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/onCancelled(flags:handler:)","abstract":[{"type":"text","text":"Emitted when the operation has been cancelled."}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onCancelled","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"title":"onCancelled(flags:handler:)","url":"\/documentation\/gio\/cancellableref\/oncancelled(flags:handler:)"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef/CancellableProtocol-Implementations":{"type":"topic","url":"\/documentation\/gio\/cancellableref\/cancellableprotocol-implementations","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef\/CancellableProtocol-Implementations","title":"CancellableProtocol Implementations","kind":"article"}}}