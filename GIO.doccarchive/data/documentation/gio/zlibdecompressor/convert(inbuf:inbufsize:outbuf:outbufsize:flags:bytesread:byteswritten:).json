{"metadata":{"extendedModule":"GIO","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"convert","kind":"identifier"},{"kind":"text","text":"("},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"outbuf"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ConverterFlagsV","text":"ConverterFlags"},{"kind":"text","text":", "},{"text":"bytesRead","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"GConverterResult","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult"}],"externalID":"s:3GIO17ConverterProtocolPAAE7convert5inbuf0E4Size6outbuf0gF05flags9bytesRead0I7WrittenSo16GConverterResultaSvSg_SiANSiAA0B5FlagsVSpySuGSgARtKF::SYNTHESIZED::s:3GIO16ZlibDecompressorC","role":"symbol"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"convert","kind":"identifier"},{"kind":"text","text":"("},{"text":"inbuf","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"text":"inbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"outbuf"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","kind":"typeIdentifier","text":"ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV"},{"text":", ","kind":"text"},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"bytesWritten"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:@EA@GConverterResult","kind":"typeIdentifier","text":"GConverterResult"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Note that a single call may not consume all input (or any input at all).","type":"text"},{"text":" ","type":"text"},{"text":"Also a call may produce output even if given no input, due to state stored","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the converter producing output."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If any data was either produced or consumed, and then an error happens, then"},{"type":"text","text":" "},{"type":"text","text":"only the successful conversion is reported and the error is returned on the"},{"type":"text","text":" "},{"type":"text","text":"next call."}]},{"inlineContent":[{"type":"text","text":"A full conversion loop involves calling this method repeatedly, each time"},{"type":"text","text":" "},{"text":"giving it new input and space output space. When there is no more input","type":"text"},{"text":" ","type":"text"},{"text":"data after the data in ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", the flag "},{"type":"codeVoice","code":"inputAtEnd"},{"text":" must be set.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The loop will be (unless some error happens) returning "},{"code":"converted","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"each time until all data is consumed and all output is produced, then"},{"type":"text","text":" "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" is returned instead. Note, that "},{"type":"codeVoice","code":"finished"},{"type":"text","text":" "},{"type":"text","text":"may be returned even if "},{"type":"codeVoice","code":"inputAtEnd"},{"text":" is not set, for instance","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in a decompression converter where the end of data is detectable from the"},{"type":"text","text":" "},{"type":"text","text":"data (and there might even be other data after the end of the compressed data)."}],"type":"paragraph"},{"inlineContent":[{"text":"When some data has successfully been converted ","type":"text"},{"type":"codeVoice","code":"bytesRead"},{"type":"text","text":" and is set to"},{"type":"text","text":" "},{"text":"the number of bytes read from ","type":"text"},{"code":"inbuf","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"bytesWritten","type":"codeVoice"},{"type":"text","text":" is set to indicate"},{"type":"text","text":" "},{"text":"how many bytes was written to ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"text":". If there are more data to output","type":"text"},{"text":" ","type":"text"},{"text":"or consume (i.e. unless the ","type":"text"},{"code":"inputAtEnd","type":"codeVoice"},{"text":" is specified) then","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"converted"},{"text":" is returned, and if no more data is to be output","type":"text"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"finished"},{"type":"text","text":" is returned."}],"type":"paragraph"},{"inlineContent":[{"text":"On error ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is returned and "},{"code":"error","type":"codeVoice"},{"text":" is set accordingly.","type":"text"},{"type":"text","text":" "},{"text":"Some errors need special handling:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"noSpace","type":"codeVoice"},{"type":"text","text":" is returned if there is not enough space"},{"type":"text","text":" "},{"type":"text","text":"to write the resulting converted data, the application should"},{"text":" ","type":"text"},{"type":"text","text":"call the function again with a larger "},{"code":"outbuf","type":"codeVoice"},{"text":" to continue.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"partialInput"},{"type":"text","text":" is returned if there is not enough"},{"text":" ","type":"text"},{"text":"input to fully determine what the conversion should produce,","type":"text"},{"type":"text","text":" "},{"text":"and the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"text":" flag is not set. This happens for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example with an incomplete multibyte sequence when converting text,"},{"type":"text","text":" "},{"type":"text","text":"or when a regexp matches up to the end of the input (and may match"},{"text":" ","type":"text"},{"type":"text","text":"further input). It may also happen when "},{"code":"inbufSize","type":"codeVoice"},{"type":"text","text":" is zero and"},{"text":" ","type":"text"},{"type":"text","text":"there is no more data to produce."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When this happens the application should read more input and then"},{"text":" ","type":"text"},{"text":"call the function again. If further input shows that there is no","type":"text"},{"type":"text","text":" "},{"text":"more data call the function again with the same data but with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"codeVoice","code":"inputAtEnd"},{"text":" flag set. This may cause the conversion","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to finish as e.g. in the regexp match case (or, to fail again with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"partialInput"},{"type":"text","text":" in e.g. a charset conversion where the"},{"text":" ","type":"text"},{"text":"input is actually partial).","type":"text"}]},{"inlineContent":[{"type":"text","text":"After "},{"type":"codeVoice","code":"g_converter_convert()"},{"type":"text","text":" has returned "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" the"},{"text":" ","type":"text"},{"type":"text","text":"converter object is in an invalid state where its not allowed"},{"text":" ","type":"text"},{"text":"to call ","type":"text"},{"type":"codeVoice","code":"g_converter_convert()"},{"type":"text","text":" anymore. At this time you can only"},{"type":"text","text":" "},{"type":"text","text":"free the object or call "},{"type":"codeVoice","code":"g_converter_reset()"},{"type":"text","text":" to reset it to the"},{"text":" ","type":"text"},{"type":"text","text":"initial state."}],"type":"paragraph"},{"inlineContent":[{"text":"If the flag ","type":"text"},{"type":"codeVoice","code":"flush"},{"text":" is set then conversion is modified","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to try to write out all internal state to the output. The application"},{"text":" ","type":"text"},{"type":"text","text":"has to call the function multiple times with the flag set, and when"},{"type":"text","text":" "},{"type":"text","text":"the available input has been consumed and all internal state has"},{"type":"text","text":" "},{"type":"text","text":"been produced then "},{"type":"codeVoice","code":"flushed"},{"type":"text","text":" (or "},{"type":"codeVoice","code":"finished"},{"type":"text","text":" if"},{"text":" ","type":"text"},{"text":"really at the end) is returned instead of ","type":"text"},{"code":"converted","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This is somewhat similar to what happens at the end of the input stream,"},{"type":"text","text":" "},{"text":"but done in the middle of the data.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This has different meanings for different conversions. For instance"},{"text":" ","type":"text"},{"type":"text","text":"in a compression converter it would mean that we flush all the"},{"text":" ","type":"text"},{"type":"text","text":"compression state into output such that if you uncompress the"},{"type":"text","text":" "},{"text":"compressed data you get back all the input data. Doing this may","type":"text"},{"text":" ","type":"text"},{"text":"make the final file larger due to padding though. Another example","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is a regexp conversion, where if you at the end of the flushed data"},{"type":"text","text":" "},{"text":"have a match, but there is also a potential longer match. In the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"non-flushed case we would ask for more input, but when flushing we"},{"type":"text","text":" "},{"text":"treat this as the end of input and do the match.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Flushing is not always possible (like if a charset converter flushes"},{"type":"text","text":" "},{"type":"text","text":"at a partial multibyte sequence). Converters are supposed to try"},{"text":" ","type":"text"},{"text":"to produce as much output as possible and then return an error","type":"text"},{"text":" ","type":"text"},{"text":"(typically ","type":"text"},{"type":"codeVoice","code":"partialInput"},{"type":"text","text":")."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressor","doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressor\/ConverterProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/gio\/zlibdecompressor\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"This is the main operation used when converting data. It is to be called"},{"text":" ","type":"text"},{"type":"text","text":"multiple times in a loop, and each time it will do some work, i.e."},{"text":" ","type":"text"},{"text":"producing some output (in ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":") or consuming some input (from "},{"code":"inbuf","type":"codeVoice"},{"type":"text","text":") or"},{"type":"text","text":" "},{"text":"both. If its not possible to do any work an error is returned.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressor\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)"},"sections":[],"kind":"symbol","references":{"doc://GIO/documentation/GIO/ZlibDecompressor":{"type":"topic","kind":"symbol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ZlibDecompressor"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressor","abstract":[{"code":"GZlibDecompressor","type":"codeVoice"},{"text":" is an implementation of [iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter"},{"type":"text","text":"] that"},{"type":"text","text":" "},{"type":"text","text":"decompresses data compressed with zlib."}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"ZlibDecompressor","kind":"identifier"}],"title":"ZlibDecompressor","url":"\/documentation\/gio\/zlibdecompressor"},"doc://GIO/documentation/GIO/ZlibDecompressor/ConverterProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressor\/ConverterProtocol-Implementations","role":"collectionGroup","type":"topic","abstract":[],"kind":"article","title":"ConverterProtocol Implementations","url":"\/documentation\/gio\/zlibdecompressor\/converterprotocol-implementations"},"doc://GIO/documentation/GIO/ConverterFlags":{"abstract":[{"type":"text","text":"Flags used when calling a "},{"type":"codeVoice","code":"g_converter_convert()"},{"text":".","type":"text"}],"title":"ConverterFlags","url":"\/documentation\/gio\/converterflags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConverterFlags"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","kind":"symbol","navigatorTitle":[{"text":"ConverterFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/ZlibDecompressor/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)":{"abstract":[{"type":"text","text":"This is the main operation used when converting data. It is to be called"},{"text":" ","type":"text"},{"type":"text","text":"multiple times in a loop, and each time it will do some work, i.e."},{"text":" ","type":"text"},{"text":"producing some output (in ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"text":") or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"both. If its not possible to do any work an error is returned."}],"kind":"symbol","url":"\/documentation\/gio\/zlibdecompressor\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"convert","kind":"identifier"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"inbufSize"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"outbuf"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"bytesWritten"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult","text":"GConverterResult"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressor\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","role":"symbol"},"doc://GIO/documentation/GIO/Converter":{"kind":"symbol","type":"topic","title":"Converter","role":"symbol","abstract":[{"type":"codeVoice","code":"GConverter"},{"type":"text","text":" is an interface for streaming conversions."}],"url":"\/documentation\/gio\/converter","identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Converter","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Converter"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}