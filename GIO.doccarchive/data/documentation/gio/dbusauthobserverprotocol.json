{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"kind":"symbol","topicSections":[{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/dbus_auth_observer_ptr-50wdc"]},{"generated":true,"title":"Instance Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/allow(mechanism:)","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/authorizeAuthenticatedPeer(stream:credentials:)-1qyjq","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/authorizeAuthenticatedPeer(stream:credentials:)-8cemy","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/connect(signal:flags:data:destroyData:signalHandler:)","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/connect(signal:flags:handler:)","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/onAllowMechanism(flags:handler:)","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/onAuthorizeAuthenticatedPeer(flags:handler:)"],"anchor":"Instance-Methods"},{"anchor":"Type-Properties","title":"Type Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/allowMechanismSignal","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol\/authorizeAuthenticatedPeerSignal"],"generated":true}],"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"kind":"relationships","title":"Inherits From"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserver","doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverRef"],"kind":"relationships","title":"Conforming Types","type":"conformingTypes"}],"abstract":[{"code":"GDBusAuthObserver","type":"codeVoice"},{"text":" provides a mechanism for participating","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in how a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServer","type":"reference","isActive":true},{"type":"text","text":"] (or a [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection","type":"reference"},{"type":"text","text":"])"},{"text":" ","type":"text"},{"type":"text","text":"authenticates remote peers."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"DBusAuthObserverProtocol","kind":"identifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B8ProtocolP","kind":"typeIdentifier","text":"ObjectProtocol"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"Simply instantiate a ","type":"text"},{"type":"codeVoice","code":"GDBusAuthObserver"},{"type":"text","text":" and connect to the"},{"type":"text","text":" "},{"text":"signals you are interested in. Note that new signals may be added","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the future."}],"type":"paragraph"},{"text":"Controlling Authentication Mechanisms","level":2,"type":"heading","anchor":"Controlling-Authentication-Mechanisms"},{"inlineContent":[{"text":"By default, a ","type":"text"},{"type":"codeVoice","code":"GDBusServer"},{"text":" or server-side ","type":"text"},{"type":"codeVoice","code":"GDBusConnection"},{"type":"text","text":" will allow"},{"type":"text","text":" "},{"type":"text","text":"any authentication mechanism to be used. If you only want to allow D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"connections with the "},{"code":"EXTERNAL","type":"codeVoice"},{"text":" mechanism, which makes use of credentials","type":"text"},{"type":"text","text":" "},{"type":"text","text":"passing and is the recommended mechanism for modern Unix platforms such"},{"type":"text","text":" "},{"text":"as Linux and the BSD family, you would use a signal handler like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["static gboolean","on_allow_mechanism (GDBusAuthObserver *observer,","                    const gchar       *mechanism,","                    gpointer           user_data)","{","  if (g_strcmp0 (mechanism, \"EXTERNAL\") == 0)","    {","      return TRUE;","    }","","  return FALSE;","}"],"syntax":"c"},{"text":"Controlling Authorization","level":2,"type":"heading","anchor":"Controlling-Authorization"},{"inlineContent":[{"type":"text","text":"By default, a "},{"code":"GDBusServer","type":"codeVoice"},{"text":" or server-side ","type":"text"},{"type":"codeVoice","code":"GDBusConnection"},{"type":"text","text":" will accept"},{"type":"text","text":" "},{"type":"text","text":"connections from any successfully authenticated user (but not from"},{"type":"text","text":" "},{"type":"text","text":"anonymous connections using the "},{"type":"codeVoice","code":"ANONYMOUS"},{"text":" mechanism). If you only","type":"text"},{"text":" ","type":"text"},{"text":"want to allow D-Bus connections from processes owned by the same uid","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as the server, since GLib 2.68, you should use the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_DBUS_SERVER_FLAGS_AUTHENTICATION_REQUIRE_SAME_USER"},{"text":" flag. It’s equivalent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the following signal handler:"}],"type":"paragraph"},{"code":["static gboolean","on_authorize_authenticated_peer (GDBusAuthObserver *observer,","                                 GIOStream         *stream,","                                 GCredentials      *credentials,","                                 gpointer           user_data)","{","  gboolean authorized;","","  authorized = FALSE;","  if (credentials != NULL)","    {","      GCredentials *own_credentials;","      own_credentials = g_credentials_new ();","      if (g_credentials_is_same_user (credentials, own_credentials, NULL))","        authorized = TRUE;","      g_object_unref (own_credentials);","    }","","  return authorized;","}"],"type":"codeListing","syntax":"c"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol","isActive":true,"type":"reference"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"code":"GDBusAuthObserver","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserver","isActive":true,"type":"reference"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverRef"},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusauthobserverprotocol"]}],"metadata":{"externalID":"s:3GIO24DBusAuthObserverProtocolP","role":"symbol","modules":[{"name":"GIO"}],"symbolKind":"protocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"DBusAuthObserverProtocol","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"DBusAuthObserverProtocol"}],"roleHeading":"Protocol","title":"DBusAuthObserverProtocol"},"sections":[],"references":{"doc://GIO/documentation/GIO/DBusAuthObserverP