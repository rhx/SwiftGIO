{"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(_:)-221be","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(_:)-2vrnq","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(_:)-6j05s","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(_:)-7hn6u","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(iOStream:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(raw:)-6c2ts","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(raw:)-8ymzr","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(retainingRaw:)-1e1mu","doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(retainingRaw:)-58w65"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStream\/metatypeReferenceForIOStream","doc:\/\/GIO\/documentation\/GIO\/IOStream\/wrapperForIOStream"],"anchor":"Instance-Properties","generated":true},{"anchor":"Type-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStream\/metatypeForIOStream"],"generated":true,"title":"Type Properties"},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStream\/IOStreamProtocol-Implementations"]}],"variants":[{"paths":["\/documentation\/gio\/iostream"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},"abstract":[{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" represents an object that has both read and write streams."},{"type":"text","text":" "},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"text":"but they share some common resources and state. For instance, for","type":"text"},{"text":" ","type":"text"},{"text":"seekable streams, both streams may use the same position.","type":"text"}],"metadata":{"externalID":"s:3GIO8IOStreamC","modules":[{"name":"GIO"}],"navigatorTitle":[{"kind":"identifier","text":"IOStream"}],"symbolKind":"class","roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"title":"IOStream","role":"symbol"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"IOStream","kind":"identifier"}]}]},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"Examples of ","type":"text"},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" objects are [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection"},{"type":"text","text":"], which represents"},{"type":"text","text":" "},{"type":"text","text":"a two-way network connection; and [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStream","type":"reference"},{"text":"], which represents a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file handle opened in read-write mode."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To do the actual reading and writing you need to get the substreams"},{"text":" ","type":"text"},{"text":"with [method","type":"text"},{"code":"Gio.IOStream.get_input_stream","type":"codeVoice"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.IOStream.get_output_stream"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" object owns the input and the output streams, not the other"},{"type":"text","text":" "},{"type":"text","text":"way around, so keeping the substreams alive will not keep the "},{"code":"GIOStream","type":"codeVoice"},{"text":" ","type":"text"},{"text":"object alive. If the ","type":"text"},{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" object is freed it will be closed, thus"},{"type":"text","text":" "},{"type":"text","text":"closing the substreams, so even if the substreams stay alive they will"},{"type":"text","text":" "},{"text":"always return ","type":"text"},{"type":"codeVoice","code":"G_IO_ERROR_CLOSED"},{"text":" for all operations.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To close a stream use [method"},{"code":"Gio.IOStream.close","type":"codeVoice"},{"type":"text","text":"] which will close the common"},{"type":"text","text":" "},{"type":"text","text":"stream object and also the individual substreams. You can also close"},{"text":" ","type":"text"},{"type":"text","text":"the substreams themselves. In most cases this only marks the"},{"text":" ","type":"text"},{"type":"text","text":"substream as closed, so further I\/O on it fails but common state in the"},{"text":" ","type":"text"},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" may still be open. However, some streams may support"},{"text":" ","type":"text"},{"text":"‘half-closed’ states where one direction of the stream is actually shut down.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Operations on "},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":"s cannot be started while another operation on the"},{"type":"text","text":" "},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" or its substreams is in progress. Specifically, an application can"},{"text":" ","type":"text"},{"type":"text","text":"read from the [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true},{"text":"] and write to the","type":"text"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","type":"reference","isActive":true},{"type":"text","text":"] simultaneously (either in separate threads, or as"},{"text":" ","type":"text"},{"text":"asynchronous operations in the same thread), but an application cannot start","type":"text"},{"type":"text","text":" "},{"type":"text","text":"any "},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" operation while there is a "},{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":", "},{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"code":"GOutputStream","type":"codeVoice"},{"text":" operation in progress, and an application can’t start any","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" or "},{"type":"codeVoice","code":"GOutputStream"},{"type":"text","text":" operation while there is a "},{"type":"codeVoice","code":"GIOStream"},{"text":" ","type":"text"},{"text":"operation in progress.","type":"text"}]},{"inlineContent":[{"text":"This is a product of individual stream operations being associated with a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"given [type[MainContext](\/\/documentation\/glib\/maincontext] (the thread-default context at the time the"},{"text":" ","type":"text"},{"type":"text","text":"operation was started), rather than entire streams being associated with a"},{"text":" ","type":"text"},{"type":"text","text":"single "},{"code":"GMainContext","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"GIO may run operations on ","type":"text"},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":"s from other (worker) threads, and this"},{"text":" ","type":"text"},{"type":"text","text":"may be exposed to application code in the behaviour of wrapper streams, such"},{"text":" ","type":"text"},{"type":"text","text":"as [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStream","isActive":true},{"type":"text","text":"] or [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true,"type":"reference"},{"text":"]. With such","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"wrapper APIs, application code may only run operations on the base (wrapped)"},{"text":" ","type":"text"},{"type":"text","text":"stream when the wrapper stream is idle. Note that the semantics of such"},{"text":" ","type":"text"},{"type":"text","text":"operations may not be well-defined due to the state the wrapper stream leaves"},{"text":" ","type":"text"},{"text":"the base stream in (though they are guaranteed not to crash).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol","type":"reference","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GIOStream","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef","isActive":true},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GIOStream"},{"text":" instance.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/GIO\/10GLibObject0B0C"]},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/FileIOStream","doc:\/\/GIO\/documentation\/GIO\/SimpleIOStream","doc:\/\/GIO\/documentation\/GIO\/SocketConnection","doc:\/\/GIO\/documentation\/GIO\/TLSConnection"],"title":"Inherited By","kind":"relationships","type":"inheritedBy"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol"],"type":"conformsTo"}],"references":{"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/IOStream/IOStreamProtocol-Implementations":{"role":"collectionGroup","kind":"article","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream\/IOStreamProtocol-Implementations","title":"IOStreamProtocol Implementations","abstract":[],"url":"\/documentation\/gio\/iostream\/iostreamprotocol-implementations"},"doc://GIO/documentation/GIO/IOStream/init(_:)-221be":{"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GIOStream"},{"kind":"text","text":">)"}],"abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type."},{"text":" ","type":"text"},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"text":" ","type":"text"},{"text":"i.e., ownership is transferred to the ","type":"text"},{"type":"codeVoice","code":"IOStream"},{"type":"text","text":" instance."}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream\/init(_:)-221be","role":"symbol","title":"init(_:)","url":"\/documentation\/gio\/iostream\/init(_:)-221be","kind":"symbol"},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"tex