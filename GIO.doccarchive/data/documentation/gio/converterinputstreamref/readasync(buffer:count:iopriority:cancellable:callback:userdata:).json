ement","type":"text"},{"type":"text","text":" "},{"type":"text","text":"asynchronicity, so they are optional for inheriting classes. However, if you"},{"type":"text","text":" "},{"type":"text","text":"override one you must override all."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef\/InputStreamProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/converterinputstreamref\/readasync(buffer:count:iopriority:cancellable:callback:userdata:)"]}],"sections":[],"metadata":{"role":"symbol","externalID":"s:3GIO19InputStreamProtocolPAAE9readAsync6buffer5count10ioPriority11cancellable8callback8userDataySvSg_S2iAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgAKtXCSgAKtF::SYNTHESIZED::s:3GIO23ConverterInputStreamRefV","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAsync"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffer"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"k