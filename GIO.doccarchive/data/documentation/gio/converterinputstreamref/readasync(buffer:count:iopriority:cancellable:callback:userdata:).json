{"abstract":[{"type":"text","text":"Request an asynchronous read of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from the stream into the buffer"},{"text":" ","type":"text"},{"type":"text","text":"starting at "},{"code":"buffer","type":"codeVoice"},{"text":". When the operation is finished ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" will be called.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You can then call "},{"type":"codeVoice","code":"g_input_stream_read_finish()"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"type":"text","text":"operation."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"readAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffer"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil, "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"tex