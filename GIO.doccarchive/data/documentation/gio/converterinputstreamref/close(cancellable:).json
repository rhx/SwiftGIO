{"metadata":{"role":"symbol","externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO23ConverterInputStreamRefV","title":"close(cancellable:)","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"extendedModule":"GIO","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]},"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef\/InputStreamProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/converterinputstreamref\/close(cancellable:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef\/close(cancellable:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"text":" ","type":"text"},{"text":"resources are released as early as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"type":"text","text":" "},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stream for details."}]},{"inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations. Still, it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is important to check and report the error to the user."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"text":" ","type":"text"},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/ConverterInputStreamRef/InputStreamProtocol-Implementations":{"url":"\/documentation\/gio\/converterinputstreamref\/inputstreamprotocol-implementations","kind":"article","title":"InputStreamProtocol Implementations","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef\/InputStreamProtocol-Implementations","abstract":[],"type":"topic"},"doc://GIO/documentation/GIO/ConverterInputStreamRef":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"ConverterInputStreamRef"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef","url":"\/documentation\/gio\/converterinputstreamref","title":"ConverterInputStreamRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ConverterInputStreamRef","kind":"identifier"}],"abstract":[{"text":"Converter input stream implements [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO