paragraph","inlineContent":[{"type":"text","text":"If count is zero, returns a zero-length [Bytes](\/\/documentation\/glib\/bytes and does nothing. A"},{"text":" ","type":"text"},{"type":"text","text":"value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"type":"text","text":" "},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}]},{"inlineContent":[{"type":"text","text":"On success, a new [Bytes](\/\/documentation\/glib\/bytes is returned. It is not an error if the"},{"type":"text","text":" "},{"text":"size of this object is not the same as the requested size, as it","type":"text"},{"type":"text","text":" "},{"text":"can happen e.g. near the end of a file. A zero-length [Bytes](\/\/documentation\/glib\/bytes is","type":"text"},{"type":"text","text":" "},{"text":"returned on end of file (or if ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is zero), but never","type":"text"},{"type":"text","text":" "},{"type":"text","text":"otherwise."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}]},{"inlineContent":[{"text":"On error ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef\/readBytes(count:cancellable:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/ConverterInputStreamRef\/InputStreamProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/gio\/converterinputstreamref\/readbytes(count:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Like "},{"code":"g_input_stream_read()","type":"codeVoice"},{"type":"text","text":", this tries to read "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from"},{"text":" ","type":"text"},{"text":"the stream in a blocking fashion. However, rather than reading into","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing"},{"type":"text","text":" "},{"text":"the data that was read. This may be easier to use from language","type":"text"},{"type":"text","text":" "},{"type":"text","text":"bindings."}],"sections":[],"references":{"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"Ca