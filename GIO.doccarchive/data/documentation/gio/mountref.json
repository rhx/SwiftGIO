{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MountRef"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"GMount","type":"codeVoice"},{"type":"text","text":" is a ‘mounted’ filesystem that you can access. Mounted is in"},{"text":" ","type":"text"},{"text":"quotes because it’s not the same as a UNIX mount, it might be a GVFS","type":"text"},{"type":"text","text":" "},{"type":"text","text":"mount, but you can still access the files on it if you use GIO."}]},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GMount"},{"type":"text","text":" might be associated with a [iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Volume"},{"text":"] (such as a USB flash","type":"text"},{"type":"text","text":" "},{"text":"drive) which hosts it.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Unmounting a ","type":"text"},{"type":"codeVoice","code":"GMount"},{"text":" instance is an asynchronous operation. For","type":"text"},{"type":"text","text":" "},{"type":"text","text":"more information about asynchronous operations, see [iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","isActive":true,"type":"reference"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"text":"]. To unmount a ","type":"text"},{"type":"codeVoice","code":"GMount"},{"text":" instance, first call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.Mount.unmount_with_operation","type":"codeVoice"},{"text":"] with (at least) the ","type":"text"},{"type":"codeVoice","code":"GMount"},{"text":" ","type":"text"},{"type":"text","text":"instance and a [type"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback"},{"type":"text","text":"].  The callback will be fired"},{"type":"text","text":" "},{"type":"text","text":"when the operation has resolved (either with success or failure), and a"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","isActive":true},{"type":"text","text":"] structure will be passed to the callback.  That"},{"type":"text","text":" "},{"text":"callback should then call [method","type":"text"},{"code":"Gio.Mount.unmount_with_operation_finish","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with the "},{"type":"codeVoice","code":"GMount"},{"type":"text","text":" and the [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult"},{"text":"] data to see if the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation was completed successfully.  If an "},{"type":"codeVoice","code":"error"},{"text":" is present when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.Mount.unmount_with_operation_finish","type":"codeVoice"},{"type":"text","text":"] is called, then it will be"},{"text":" ","type":"text"},{"text":"filled with any error information.","type":"text"}]},{"inlineContent":[{"text":"Note, when ","type":"text"},{"type":"reference","identifier":"migrating-gnome-vfs.html","isActive":true},{"type":"text","text":", "},{"code":"GMount","type":"codeVoice"},{"type":"text","text":" is the"},{"text":" ","type":"text"},{"type":"text","text":"moral equivalent of "},{"code":"GnomeVFSVolume","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GIO\/