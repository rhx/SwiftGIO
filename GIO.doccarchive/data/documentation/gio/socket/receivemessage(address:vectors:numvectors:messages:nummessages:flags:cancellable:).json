oice","code":"nil"},{"type":"text","text":" buffer pointer."}],"type":"paragraph"},{"inlineContent":[{"text":"As a special case, if ","type":"text"},{"code":"numVectors","type":"codeVoice"},{"text":" is 0 (in which case, ","type":"text"},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" "},{"type":"text","text":"may of course be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"), then a single byte is received and"},{"type":"text","text":" "},{"type":"text","text":"discarded. This is to facilitate the common practice of sending a"},{"type":"text","text":" "},{"text":"single ‘\\0’ byte for the purposes of transferring ancillary data.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"messages"},{"type":"text","text":", if non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", will be set to point to a newly-allocated"},{"type":"text","text":" "},{"text":"array of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage"},{"text":" instances or ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if no such"},{"type":"text","text":" "},{"type":"text","text":"messages was received. These correspond to the control messages"},{"type":"text","text":" "},{"text":"received from the kernel, one ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","type":"reference","isActive":true},{"type":"text","text":" per message"},{"text":" ","type":"text"},{"type":"text","text":"from the kernel. This array is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"-terminated and must be freed"},{"type":"text","text":" "},{"type":"text","text":"by the caller using "},{"code":"g_free()","type":"codeVoice"},{"type":"text","text":" after calling "},{"type":"codeVoice","code":"g_object_unref()"},{"text":" on each","type":"text"},{"type":"text","text":" "},{"type":"text","text":"element. If "},{"code":"messages","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", any control messages received will"},{"type":"text","text":" "},{"type":"text","text":"be discarded."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"numMessages"},{"type":"text","text":", if non-"},{"code":"nil","type":"codeVoice"},{"text":", will be set to the number of control","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messages received."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If both "},{"code":"messages","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"numMessages"},{"text":" are non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"text":" gives the number of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage"},{"type":"text","text":" instances"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"messages","type":"codeVoice"},{"text":" (ie: not including the ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" terminator).","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" is an in\/out parameter. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"text":"for this are available in the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"text":" ","type":"text"},{"text":"are passed in as-is, so you can pass in system-specific flags too","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(and "},{"type":"codeVoice","code":"g_socket_receive_message()"},{"t