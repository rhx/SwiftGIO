O\/OutputVector","isActive":true,"type":"reference"},{"type":"text","text":" structs and"},{"text":" ","type":"text"},{"code":"numVectors","type":"codeVoice"},{"type":"text","text":" must be the length of this array. (If "},{"type":"codeVoice","code":"numVectors"},{"type":"text","text":" is -1,"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is assumed to be terminated by a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector"},{"type":"text","text":" with a"},{"type":"text","text":" "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" buffer pointer.) The "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true},{"text":" structs describe the buffers","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the sent data will be gathered from. Using multiple"},{"type":"text","text":" "},{"type":"codeVoice","code":"GOutputVectors"},{"type":"text","text":" is more memory-efficient than manually copying"},{"type":"text","text":" "},{"type":"text","text":"data from multiple sources into a single buffer, and more"},{"type":"text","text":" "},{"type":"text","text":"network-efficient than making multiple calls to "},{"code":"g_socket_send()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"codeVoice","code":"messages"},{"type":"text","text":", if non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", is taken to point to an array of "},{"type":"codeVoice","code":"numMessages"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage"},{"type":"text","text":" instances. These correspond to the control"},{"text":" ","type":"text"},{"text":"messages to be sent on the socket.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" is -1 then "},{"code":"messages","type":"codeVoice"},{"text":" is treated as a ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":"-terminated"},{"type":"text","text":" "},{"type":"text","text":"array."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"text":"for this are available in the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true,"type":"reference"},{"type":"text","text":" enum, but the"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the socket is in blocking mode the call will block until there is"},{"text":" ","type":"text"},{"type":"text","text":"space for the data in the socket queue. If there is no space available"},{"text":" ","type":"text"},{"type":"text","text":"and the socket is in non-blocking mode a "},{"code":"wouldBlock","type":"codeVoice"},{"text":" error","type":"text"},{"text":" ","type":"text"},{"text":"will be returned. To be notified when space is available, wait for the","type":"text"},{"text":" ","type":"text"},{"text":"[out](\/\/documentation\/gobject\/out condition. Note though that you may still receive","type":"text"},{"type":"text","text":" "},{"code":"wouldBlock","type":"codeVoice"},{"text":" from ","type":"text"},{"type":"codeVoice","code":"g_socket_send()"},{"type":"text","text":" even if you were previously"},{"text":" ","type":"text"},{"type":"text","text":"notified of a [out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is"},{"text":" ","type":"text"},{"text":"very common due to the way the underlying APIs work.)","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The sum of the sizes of each "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true},{"type":"text","text":" in vectors must not be"},{"text":" ","type":"text"},{"text":"greater than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":". If the message can be larger than this,"},{"type":"text","text":" "},{"type":"text","text":"then it is mandatory to use the "},{"code":"g_socket_send_message_with_timeout()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"function."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly."}]}]}],"variants":[{"paths":["\/documentation\/gio\/socket\/sendmessage(address:vectors:numvectors:messages:nummessages:flags:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/OutputVector":{"abstract":[{"text":"Structure used for scatter\/gather data output.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVo