xt"},{"text":" ","type":"text"},{"type":"text","text":"checked with "},{"code":"g_socket_check_connect_result()","type":"codeVoice"},{"type":"text","text":"."}]}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Socket\/connect(address:cancellable:)-4d7fg","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Connect the socket to the specified remote address."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socket\/connect(address:cancellable:)-4d7fg"]}],"sections":[],"references":{"doc://GIO/documentation/GIO/SocketAddressProtocol":{"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"SocketAddressProtocol","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddressProtocol","abstract":[{"type":"codeVoice","code":"GSocketAddress"},{"text":" is the equivalent of","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"man:sockaddr(3type)","isActive":true},{"text":" and its subtypes in the BSD sockets","type":"text"},{"type":"text","text":" "},{"type":"text","text":"API. This is an abstract class; use [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress","type":"reference","isActive":true},{"type":"text","text":"] for"},{"text":" ","type":"text"},{"type":"text","text":"internet sockets, or [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress"},{"text":"] for UNIX domain sockets.","type":"text"}],"url":"\/documentation\/gio\/socketaddressprotocol","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketAddressProtocol","kind":"identifier"}],"type":"topic","title":"SocketAddressProtocol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"i