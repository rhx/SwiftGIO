{"metadata":{"role":"symbol","extendedModule":"GIO","roleHeading":"Instance Method","title":"init_(cancellable:)","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"modules":[{"name":"GIO"}],"externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO6SocketC"},"variants":[{"paths":["\/documentation\/gio\/socket\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Socket","doc:\/\/GIO\/documentation\/GIO\/Socket\/InitableProtocol-Implementations"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_initable_new()"},{"type":"text","text":" should typically be used instead."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The object must be initialized before any real use after initial"},{"text":" ","type":"text"},{"text":"construction, either with this function or ","type":"text"},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"text":" ","type":"text"},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"text":" ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"text":"the object doesn’t support cancellable initialization the error","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSupported"},{"text":" will be returned.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the object is not initialized, or initialization returns with an"},{"type":"text","text":" "},{"type":"text","text":"error, then all operations on the object except "},{"type":"codeVoice","code":"g_object_ref()"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"text":" ","type":"text"},{"text":"behaviour. See the ","type":"text"},{"type":"reference","identifier":"#iface@Gio.Initable#description","isActive":true},{"type":"text","text":" for more details."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"type":"text","text":" can be"},{"type":"text","text":" "},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"text":" ","type":"text"},{"type":"text","text":"supporting this. Generally, a class’ implementation of "},{"code":"init()","type":"codeVoice"},{"type":"text","text":" can assume"},{"text":" ","type":"text"},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"text":" ","type":"text"},{"type":"text","text":"recommended all "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"text":" implementations should be idempotent; that","type":"text"},{"text":" ","type":"text"},{"text":"recommendation was relaxed in GLib 2.54.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"text":" ","type":"text"},{"text":"recommended that the method is idempotent: multiple calls with the same","type":"text"},{"text":" ","type":"text"},{"text":"arguments should return the same results. Only the first call initializes","type":"text"},{"type":"text","text":" "},{"text":"the object; further calls return the result of the first call.","type":"text"}]},{"inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"type":"text","text":" "},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"type":"text","text":" "},{"code":"GObjectClass.constructor","type":"codeVoice"},{"type":"text","text":" that sometimes returns an existing instance."},{"type":"text","text":" "},{"text":"In this pattern, a caller would expect to be able to call ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"type":"text","text":"on the result of "},{"type":"codeVoice","code":"g_object_new()"},{"type":"text","text":", regardless of whether it is in fact a new"},{"type":"text","text":" "},{"type":"text","text":"instance."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Socket\/init_(cancellable:)","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/Socket/init_(cancellable:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/init_(cancellable:)","url":"\/documentation\/gio\/socket\/init_(cancellable:)","title":"init_(cancellable:)","abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"#iface@Gio.Initable#description":{"title":"description","url":"#iface@Gio.Initable#description","type":"link","titleInlineContent":[{"text":"description","type":"text"}],"identifier":"#iface@Gio.Initable#description"},"doc://GIO/documentation/GIO/Socket/InitableProtocol-Implementations":{"type":"topic","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/InitableProtocol-Implementations","title":"InitableProtocol Implementations","kind":"article","abstract":[],"url":"\/documentation\/gio\/socket\/initableprotocol-implementations"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}