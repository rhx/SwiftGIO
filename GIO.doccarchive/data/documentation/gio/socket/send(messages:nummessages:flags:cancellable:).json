{"abstract":[{"text":"Send multiple data messages from ","type":"text"},{"code":"socket","type":"codeVoice"},{"type":"text","text":" in one go.  This is the most"},{"type":"text","text":" "},{"type":"text","text":"complicated and fully-featured version of this call. For easier use, see"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_send()"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_socket_send_to()"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"g_socket_send_message()"},{"type":"text","text":"."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Socket\/send(messages:numMessages:flags:cancellable:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","metadata":{"role":"symbol","externalID":"s:3GIO14SocketProtocolPAAE4send8messages11numMessages5flags11cancellableSiSpySo15_GOutputMessageVGSg_S2iAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO6SocketC","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"send"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputMessage"},{"text":">!, ","kind":"text"},{"text":"numMessages","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"symbolKind":"method","roleHeading":"Instance Method","title":"send(messages:numMessages:flags:cancellable:)","extendedModule":"GIO"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Socket","doc:\/\/GIO\/documentation\/GIO\/Socket\/SocketProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"send"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputMessage"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"messages"},{"text":" must point to an array of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" structs and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" "},{"text":"contains an address to send the data to, and a pointer to an array of","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector"},{"type":"text","text":" structs to describe the buffers that the data to be sent"},{"type":"text","text":" "},{"type":"text","text":"for each message will be gathered from. Using multiple "},{"type":"codeVoice","code":"GOutputVectors"},{"text":" is","type":"text"},{"type":"text","text":" "},{"text":"more memory-efficient than manually copying data from multiple sources","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"into a single buffer, and more network-efficient than making multiple"},{"text":" ","type":"text"},{"type":"text","text":"calls to "},{"code":"g_socket_send()","type":"codeVoice"},{"type":"text","text":". Sending multiple messages in one go avoids the"},{"text":" ","type":"text"},{"type":"text","text":"overhead of making a lot of syscalls in scenarios where a lot of data"},{"type":"text","text":" "},{"type":"text","text":"packets need to be sent (e.g. high-bandwidth video streaming over RTP\/UDP),"},{"text":" ","type":"text"},{"type":"text","text":"or where the same data needs to be sent to multiple recipients."}]},{"inlineContent":[{"code":"flags","type":"codeVoice"},{"type":"text","text":" modify how the message is sent. The commonly available arguments"},{"type":"text","text":" "},{"text":"for this are available in the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true,"type":"reference"},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the socket is in blocking mode the call will block until there is"},{"type":"text","text":" "},{"text":"space for all the data in the socket queue. If there is no space available","type":"text"},{"type":"text","text":" "},{"text":"and the socket is in non-blocking mode a ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" error"},{"type":"text","text":" "},{"text":"will be returned if no data was written at all, otherwise the number of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages sent will be returned. To be notified when space is available,"},{"type":"text","text":" "},{"text":"wait for the [out](\/\/documentation\/gobject\/out condition. Note though that you may still receive","type":"text"},{"type":"text","text":" "},{"code":"wouldBlock","type":"codeVoice"},{"text":" from ","type":"text"},{"type":"codeVoice","code":"g_socket_send()"},{"text":" even if you were previously","type":"text"},{"type":"text","text":" "},{"type":"text","text":"notified of a [out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is"},{"type":"text","text":" "},{"text":"very common due to the way the underlying APIs work.)","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"text":"be returned if zero messages could be sent; otherwise the number of messages","type":"text"},{"type":"text","text":" "},{"type":"text","text":"successfully sent before the error will be returned."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socket\/send(messages:nummessages:flags:cancellable:)"]}],"references":{"doc://GIO/documentation/GIO/Socket/send(messages:numMessages:flags:cancellable:)":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/send(messages:numMessages:flags:cancellable:)","role":"symbol","url":"\/documentation\/gio\/socket\/send(messages:nummessages:flags:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"send","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputMessage"},{"text":">!, ","kind":"text"},{"text":"numMessages","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"type":"topic","abstract":[{"type":"text","text":"Send multiple data messages from "},{"code":"socket","type":"codeVoice"},{"type":"text","text":" in one go.  This is the most"},{"type":"text","text":" "},{"type":"text","text":"complicated and fully-featured version of this call. For easier use, see"},{"type":"text","text":" "},{"code":"g_socket_send()","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_socket_send_to()"},{"type":"text","text":", and "},{"type":"codeVoice","code":"g_socket_send_message()"},{"text":".","type":"text"}],"title":"send(messages:numMessages:flags:cancellable:)"},"doc://GIO/documentation/GIO/Socket/SocketProtocol-Implementations":{"url":"\/documentation\/gio\/socket\/socketprotocol-implementations","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/SocketProtocol-Implementations","kind":"article","abstract":[],"title":"SocketProtocol Implementations","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/OutputMessage":{"abstract":[{"type":"text","text":"Structure used for scatter\/gather data output when sending multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of","type":"text"},{"type":"text","text":" "},{"code":"GOutputVectors","type":"codeVoice"},{"type":"text","text":" and the operation will use all the buffers as if they"},{"type":"text","text":" "},{"type":"text","text":"were one buffer."}],"url":"\/documentation\/gio\/outputmessage","type":"topic","title":"OutputMessage","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputMessage","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OutputMessage"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","abstract":[{"text":"Flags used in ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_socket_send_message()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The flags listed in the enum are some commonly available flags, but the"},{"text":" ","type":"text"},{"type":"text","text":"values used for them are the same as on the platform, and any other flags"},{"text":" ","type":"text"},{"text":"are passed in\/out as is. So to use a platform specific flag, just include","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right system header and pass in the flag."}],"navigatorTitle":[{"kind":"identifier","text":"SocketMsgFlags"}],"url":"\/documentation\/gio\/socketmsgflags","title":"SocketMsgFlags","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketMsgFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/OutputVector":{"abstract":[{"text":"Structure used for scatter\/gather data output.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GOutputVectors"},{"text":" ","type":"text"},{"text":"and the operation will use all the buffers as if they were","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one buffer."}],"url":"\/documentation\/gio\/outputvector","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","navigatorTitle":[{"text":"OutputVector","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputVector","kind":"identifier"}],"title":"OutputVector","role":"symbol","kind":"symbol","type":"topic"}}}