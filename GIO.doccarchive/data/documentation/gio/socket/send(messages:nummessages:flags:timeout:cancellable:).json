","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"send(messages:numMessages:flags:timeout:cancellable:)"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"send","kind":"identifier"},{"kind":"text","text":"("},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GOutputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"text":" must point to an array of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"text":" structs and","type":"text"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" must be the length of this array. Each "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"contains an address to send the data to, and a pointer to an array of"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector"},{"text":" structs to describe the buffers that the data to be sent","type":"text"},{"text":" ","type":"text"},{"text":"for each message will be gathered from.","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for this are available in the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"text":"are passed in as-is, so you can pass in system-specific flags too.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The other members of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" are treated as described in its"},{"type":"text","text":" "},{"text":"documentation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is negative the call will block until ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" have been"},{"text":" ","type":"text"},{"type":"text","text":"sent, "},{"type":"codeVoice","code":"cancellable"},{"text":" is cancelled, or an error occurs.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is 0 the call will send up to "},{"type":"codeVoice","code":"numMessages"},{"text":" without blocking,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or will return "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" if there is no space to send messages."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"type":"text","text":" "},{"code":"timeout","type":"codeVoice"},{"text":" were negative. If the timeout is reached before any messages are","type":"text"},{"type":"text","text":" "},{"text":"sent, ","type":"text"},{"code":"timedOut","type":"codeVoice"},{"text":" is returned, otherwise it will return the number","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of messages sent before timing out."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition."},{"text":" ","type":"text"},{"type":"text","text":"Note though that you may still receive "},{"type":"codeVoice","code":"wouldBlock"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"text":" even if you were previously notified of a","type":"text"},{"type":"text","text":" "},{"text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the way the underlying APIs work.)"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_shutdown()"},{"type":"text","text":" with "},{"type":"codeVoice","code":"shutdown_write"},{"text":" set, if it’s a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":", for"},{"text":" ","type":"text"},{"type":"text","text":"example), all calls to this function will return "},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"type":"text","text":"be returned if zero messages could be sent; otherwise the number of messages"},{"type":"text","text":" "},{"type":"text","text":"successfully sent before the error will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"cancelled, "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any other error."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/Socket/DatagramBasedProtocol-Implementations":{"role":"collectionGroup","url":"\/documentation\/gio\/socket\/datagrambasedprotocol-implementations","abstract":[],"title":"DatagramBasedProtocol Implementations","kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/DatagramBasedProtocol-Implementations","type":"topic"},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/Socket/send(messages:numMessages:flags:timeout:cancellable:)":{"type":"topic","url":"\/documentation\/gio\/socket\/send(messages:nummessages:flags:timeout:cancellable:)","abstract":[{"text":"Send one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/send(messages:numMessages:flags:timeout:cancellable:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"send","kind":"identifier"},{"kind":"text","text":"("},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GOutputMessage"},{"text":">!, ","kind":"text"},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"title":"send(messages:numMessages:flags:timeout:cancellable:)","role":"symbol"},"doc://GIO/documentation/GIO/OutputVector":{"abstract":[{"text":"Structure used for scatter\/gather data output.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GOutputVectors"},{"text":" ","type":"text"},{"text":"and the operation will use all the buffers as if they were","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one buffer."}],"url":"\/documentation\/gio\/outputvector","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","navigatorTitle":[{"text":"OutputVector","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputVector","kind":"identifier"}],"title":"OutputVector","role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","abstract":[{"text":"Flags used in ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_socket_send_message()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The flags listed in the enum are some commonly available flags, but the"},{"text":" ","type":"text"},{"type":"text","text":"values used for them are the same as on the platform, and any other flags"},{"text":" ","type":"text"},{"text":"are passed in\/out as is. So to use a platform specific flag, just include","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right system header and pass in the flag."}],"navigatorTitle":[{"kind":"identifier","text":"SocketMsgFlags"}],"url":"\/documentation\/gio\/socketmsgflags","title":"SocketMsgFlags","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketMsgFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/OutputMessage":{"abstract":[{"type":"text","text":"Structure used for scatter\/gather data output when sending multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of","type":"text"},{"type":"text","text":" "},{"code":"GOutputVectors","type":"codeVoice"},{"type":"text","text":" and the operation will use all the buffers as if they"},{"type":"text","text":" "},{"type":"text","text":"were one buffer."}],"url":"\/documentation\/gio\/outputmessage","type":"topic","title":"OutputMessage","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputMessage","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OutputMessage"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}