r inefficient in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"UDP case, and so if you know any plausible upper bound on the size"},{"type":"text","text":" "},{"type":"text","text":"of the incoming packet, it is better to just do a"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_receive()"},{"type":"text","text":" with a buffer of that size, rather than calling"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_get_available_bytes()"},{"text":" first and then doing a receive of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"exactly the right size."}]}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GIO/documentation/GIO/Socket/availableBytes":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/availableBytes","abstract":[{"text":"Get the amount of data pending in the OS input buffer, without blocking.","type":"text"}],"type":"topic","role":"symbol","title":"availableBytes","url":"\/documentation\/gio\/socket\/availablebytes","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"availableBytes"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"}]},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"clas