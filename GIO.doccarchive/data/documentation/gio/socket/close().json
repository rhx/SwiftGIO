{"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"kind":"text","text":"() "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Closing a socket does not wait for all outstanding I\/O operations","type":"text"},{"type":"text","text":" "},{"text":"to finish, so the caller should not rely on them to be guaranteed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to complete even if the close returns with no error."}]},{"inlineContent":[{"type":"text","text":"Once the socket is closed, all other operations will return"},{"type":"text","text":" "},{"type":"codeVoice","code":"closed"},{"type":"text","text":". Closing a socket multiple times will not"},{"type":"text","text":" "},{"type":"text","text":"return an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sockets will be automatically closed when the last reference"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}]},{"type":"paragraph","inlineContent":[{"text":"Beware that due to the way that TCP works, it is possible for","type":"text"},{"text":" ","type":"text"},{"text":"recently-sent data to be lost if either you close a socket while the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[in_](\/\/documentation\/gobject\/in_ condition is set, or else if the remote connection tries to"},{"text":" ","type":"text"},{"type":"text","text":"send something to you after you close the socket but before it has"},{"type":"text","text":" "},{"type":"text","text":"finished reading all of the data you sent. There is no easy generic"},{"text":" ","type":"text"},{"text":"way to avoid this problem; the easiest fix is to design the network","type":"text"},{"type":"text","text":" "},{"type":"text","text":"protocol such that the client will never send data “out of turn”."},{"text":" ","type":"text"},{"text":"Another solution is for the server to half-close the connection by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_socket_shutdown()"},{"type":"text","text":" with only the "},{"code":"shutdown_write","type":"codeVoice"},{"text":" flag set,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and then wait for the client to notice this and close its side of the"},{"text":" ","type":"text"},{"type":"text","text":"connection, after which the server can safely call "},{"type":"codeVoice","code":"g_socket_close()"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"(This is what "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnection","type":"reference","isActive":true},{"type":"text","text":" does if you call"},{"type":"text","text":" "},{"code":"g_tcp_connection_set_graceful_disconnect()","type":"codeVoice"},{"text":". But of course, this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only works if the client will close its connection after the server"},{"text":" ","type":"text"},{"type":"text","text":"does.)"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socket\/close()"]}],"abstract":[{"type":"text","text":"Closes the socket, shutting down any active connection."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Socket\/close()"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Socket","doc:\/\/GIO\/documentation\/GIO\/Socket\/SocketProtocol-Implementations"]]},"metadata":{"symbolKind":"method","title":"close()","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"kind":"text","text":"() "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"externalID":"s:3GIO14SocketProtocolPAAE5closeSbyKF::SYNTHESIZED::s:3GIO6SocketC","roleHeading":"Instance Method","extendedModule":"GIO","role":"symbol"},"references":{"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","url":"\/documentation\/gio\/socketconnection","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"type":"text","text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/Socket/close()":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/close()","abstract":[{"text":"Closes the socket, shutting down any active connection.","type":"text"}],"type":"topic","role":"symbol","title":"close()","url":"\/documentation\/gio\/socket\/close()","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"kind":"text","text":"() "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]},"doc://GIO/documentation/GIO/TcpConnection":{"abstract":[{"type":"text","text":"This is the subclass of [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection"},{"type":"text","text":"] that is created"},{"text":" ","type":"text"},{"type":"text","text":"for TCP\/IP sockets."}],"navigatorTitle":[{"kind":"identifier","text":"TcpConnection"}],"title":"TcpConnection","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TcpConnection","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnection","kind":"symbol","url":"\/documentation\/gio\/tcpconnection"},"doc://GIO/documentation/GIO/Socket/SocketProtocol-Implementations":{"url":"\/documentation\/gio\/socket\/socketprotocol-implementations","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket\/SocketProtocol-Implementations","kind":"article","abstract":[],"title":"SocketProtocol Implementations","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}