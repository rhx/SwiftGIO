{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMask\/init_(cancellable:)"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/inetaddressmask\/init_(cancellable:)"]}],"kind":"symbol","metadata":{"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"modules":[{"name":"GIO"}],"extendedModule":"GIO","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO15InetAddressMaskC","title":"init_(cancellable:)","role":"symbol","roleHeading":"Instance Method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_initable_new()"},{"type":"text","text":" should typically be used instead."}]},{"inlineContent":[{"type":"text","text":"The object must be initialized before any real use after initial"},{"text":" ","type":"text"},{"text":"construction, either with this function or ","type":"text"},{"code":"g_async_initable_init_async()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"text":" ","type":"text"},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"text":"the object doesn’t support cancellable initialization the error","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}]},{"inlineContent":[{"text":"If the object is not initialized, or initialization returns with an","type":"text"},{"text":" ","type":"text"},{"text":"error, then all operations on the object except ","type":"text"},{"type":"codeVoice","code":"g_object_ref()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"text":" ","type":"text"},{"type":"text","text":"behaviour. See the "},{"identifier":"#iface@Gio.Initable#description","isActive":true,"type":"reference"},{"type":"text","text":" for more details."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" can be"},{"type":"text","text":" "},{"text":"initialized multiple times, unless the class explicitly documents itself as","type":"text"},{"type":"text","text":" "},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"code":"init()","type":"codeVoice"},{"text":" can assume","type":"text"},{"type":"text","text":" "},{"text":"(and assert) that it will only be called once. Previously, this documentation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended all "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"type":"text","text":" implementations should be idempotent; that"},{"type":"text","text":" "},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}],"type":"paragraph"},{"inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"text":" ","type":"text"},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"text":" ","type":"text"},{"type":"text","text":"the object; further calls return the result of the first call."}],"type":"paragraph"},{"inlineContent":[{"text":"One reason why a class might need to support idempotent initialization is if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"type":"text","text":" "},{"code":"GObjectClass.constructor","type":"codeVoice"},{"text":" that sometimes returns an existing instance.","type":"text"},{"type":"text","text":" "},{"text":"In this pattern, a caller would expect to be able to call ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"text":"on the result of ","type":"text"},{"code":"g_object_new()","type":"codeVoice"},{"type":"text","text":", regardless of whether it is in fact a new"},{"text":" ","type":"text"},{"type":"text","text":"instance."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InetAddressMask","doc:\/\/GIO\/documentation\/GIO\/InetAddressMask\/InitableProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO/InetAddressMask/InitableProtocol-Implementations":{"title":"InitableProtocol Implementations","url":"\/documentation\/gio\/inetaddressmask\/initableprotocol-implementations","type":"topic","kind":"article","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMask\/InitableProtocol-Implementations"},"doc://GIO/documentation/GIO/InetAddressMask":{"title":"InetAddressMask","role":"symbol","url":"\/documentation\/gio\/inetaddressmask","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMask","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"InetAddressMask"}],"kind":"symbol","navigatorTitle":[{"text":"InetAddressMask","kind":"identifier"}],"abstract":[{"code":"GInetAddressMask","type":"codeVoice"},{"type":"text","text":" represents a range of IPv4 or IPv6 addresses"},{"text":" ","type":"text"},{"text":"described by a base address and a length indicating how many bits","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the base address are relevant for matching purposes. These are"},{"type":"text","text":" "},{"text":"often given in string form. For example, ","type":"text"},{"code":"10.0.0.0\/8","type":"codeVoice"},{"type":"text","text":", or "},{"type":"codeVoice","code":"fe80``\/10"},{"type":"text","text":"."}]},"#iface@Gio.Initable#description":{"identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description","titleInlineContent":[{"text":"description","type":"text"}],"title":"description","type":"link"},"doc://GIO/documentation/GIO/InetAddressMask/init_(cancellable:)":{"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/inetaddressmask\/init_(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMask\/init_(cancellable:)","title":"init_(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]}}}