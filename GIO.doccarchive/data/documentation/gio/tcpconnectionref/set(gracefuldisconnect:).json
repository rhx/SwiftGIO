{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"gracefulDisconnect","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A graceful disconnect means that we can be sure that we successfully sent"},{"text":" ","type":"text"},{"text":"all the outstanding data to the other end, or get an error reported.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"However, it also means we have to wait for all the data to reach the"},{"type":"text","text":" "},{"text":"other side and for it to acknowledge this by closing the socket, which may","type":"text"},{"type":"text","text":" "},{"text":"take a while. For this reason it is disabled by default.","type":"text"}]}],"kind":"content"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"s:3GIO21TcpConnectionProtocolPAAE3set18gracefulDisconnectySb_tF::SYNTHESIZED::s:3GIO16TcpConnectionRefV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"gracefulDisconnect"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":")"}],"role":"symbol","title":"set(gracefulDisconnect:)","modules":[{"name":"GIO"}],"extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"method"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TcpConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TcpConnectionRef\/TcpConnectionProtocol-Implementations"]]},"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TcpConnectionRef\/set(gracefulDisconnect:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tcpconnectionref\/set(gracefuldisconnect:)"]}],"abstract":[{"type":"text","text":"This enables graceful disconnects on close. A graceful disconnect"},{"text":" ","type":"text"},{"text":"means that we signal the receiving end that the connection is terminated","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and wait for it to close the connection before closing the connection."}],"references":{"doc://GIO/documentation/GIO/TcpConnectionRef/TcpConnectionProtocol-Implementations":{"title":"TcpConnectionProtocol Implementations","abstract":[],"role":"collectionGroup","url":"\/documentation\/gio\/tcpconnectionref\/tcpconnectionprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnectionRef\/TcpConnectionProtocol-Implementations","kind":"article","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","url":"\/documentation\/gio\/socketconnection","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"type":"text","text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/TcpConnectionRef/set(gracefulDisconnect:)":{"abstract":[{"type":"text","text":"This enables graceful disconnects on close. A graceful disconnect"},{"type":"text","text":" "},{"text":"means that we signal the receiving end that the connection is terminated","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and wait for it to close the connection before closing the connection."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"gracefulDisconnect","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnectionRef\/set(gracefulDisconnect:)","title":"set(gracefulDisconnect:)","url":"\/documentation\/gio\/tcpconnectionref\/set(gracefuldisconnect:)","type":"topic"},"doc://GIO/documentation/GIO/TcpConnectionRef":{"type":"topic","kind":"symbol","navigatorTitle":[{"text":"TcpConnectionRef","kind":"identifier"}],"url":"\/documentation\/gio\/tcpconnectionref","role":"symbol","abstract":[{"text":"This is the subclass of [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true},{"text":"] that is created","type":"text"},{"type":"text","text":" "},{"text":"for TCP\/IP sockets.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnectionRef","title":"TcpConnectionRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"t