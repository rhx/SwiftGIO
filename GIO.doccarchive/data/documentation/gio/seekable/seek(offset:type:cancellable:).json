he end and then writing","type":"text"},{"type":"text","text":" "},{"text":"will result in zeros filling the empty space.  Seeking past the end","type":"text"},{"type":"text","text":" "},{"text":"of a resizable stream and reading will result in EOF.  Seeking past","type":"text"},{"text":" ","type":"text"},{"text":"the end of a fixed-sized stream will fail.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any operation that would result in a negative offset will fail."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/seekable\/seek(offset:type:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"seek(offset:type:cancellable:)","extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"seek","kind":"identifier"},{"kind":"text","text":"("},{"text":"offset","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"goffset","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@goffset"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"type"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@EA@GSeekType","text":"GSeekType"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentif