nd":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"removed"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"added","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function should only be called by classes implementing"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","type":"reference","isActive":true},{"text":". It has to be called after the internal representation","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"type":"codeVoice","code":"list"},{"type":"text","text":" has been updated, because handlers connected to this signal"},{"text":" ","type":"text"},{"type":"text","text":"might query the new state of the list."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations must only make changes to the model (as visible to"},{"type":"text","text":" "},{"type":"text","text":"its consumer) in places that will not cause problems for that"},{"text":" ","type":"text"},{"type":"text","text":"consumer.  For models that are driven directly by a write API (such"},{"text":" ","type":"text"},{"text":"as ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListStore","isActive":true,"type":"reference"},{"type":"text","text":"), changes can be reported in response to uses of that"},{"text":" ","type":"text"},{"text":"API.  For models that represent remote data, changes should only be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"made from a fresh mainloop dispatch.  It is particularly not"},{"type":"text","text":" "},{"type":"text","text":"permitted to make changes in response to a call to the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"consumer API."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Stated another way: in general, it is assumed that code making a"},{"type":"text","text":" "},{"text":"series of accesses to the model via the API, without returning to the","type":"text"},{"text":" ","type":"text"},{"text":"mainloop, and without calling other code, will continue to view the","type":"text"},{"text":" ","type":"text"},{"text":"same contents of the model.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ListStore":{"navigatorTitle":[{"kind":"identifier","text":"ListStore"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListStore","title":"ListStore","url":"\/documentation\/gio\/liststore","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ListStore"}],"abstract":[{"code":"GListStore","type":"codeVoice"},{"text":" is a simple implementation of [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","type":"reference","isActive":true},{"text":"] that stores","type":"text"},{"type":"text","text":" "},{"type":"text","text":"all items in memory."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/ListModel":{"title":"ListModel","kind":"symbol","url":"\/documentation\/gio\/listmodel","abstract":[{"type":"codeVoice","code":"GListModel"},{"text":" is an interface that represents a mutable list of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class[Object](\/\/documentation\/gobject\/object]. Its main intention is as a model for various widgets"},{"type":"text","text":" "},{"type":"text","text":"in user interfaces, such as list views, but it can also be used as a"},{"type":"text","text":" "},{"type":"text","text":"convenient method of returning lists of data, with support for"},{"type":"text","text":" "},{"text":"updates.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"ListModel","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ListModel"}]},"doc://GIO/documentation/GIO/ListStoreRef":{"navigatorTitle":[{"text":"ListStoreRef","kind":"identifier"}],"url":"\/documentation\/gio\/liststoreref","kind":"symbol","title":"ListStoreRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListStoreRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ListStoreRef"}],"abstract":[{"type":"codeVoice","code":"GListStore"},{"text":" is a simple implementation of [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","type":"reference"},{"text":"] that stores","type":"text"},{"type":"text","text":" "},{"text":"all items in memory.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/ListStoreRef/ListModelProtocol-Implementations":{"title":"ListModelProtocol Implementations","kind":"article","url":"\/documentation\/gio\/liststoreref\/listmodelprotocol-implementations","abstract":[],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListStoreRef\/ListModelProtocol-Implementations","role":"collectionGroup"},"doc://GIO/documentation/GIO/ListStoreRef/itemsChanged(position:removed:added:)":{"abstract":[{"type":"text","text":"Emits the [ListModel](\/\/documentation\/gio\/listmodel\/onitemschanged(flags:handler:) signal on "},{"type":"codeVoice","code":"list"},{"text":".","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"te