{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","metadata":{"externalID":"s:3GIO19DebugControllerDBusC","modules":[{"name":"GIO"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DebugControllerDBus"}],"role":"symbol","title":"DebugControllerDBus","roleHeading":"Class","navigatorTitle":[{"kind":"identifier","text":"DebugControllerDBus"}],"symbolKind":"class"},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus"},"abstract":[{"type":"codeVoice","code":"GDebugControllerDBus"},{"text":" is an implementation of [iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"which exposes debug settings as a D-Bus object.","type":"text"}],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(_:)-6hwe5","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(_:)-82m7p","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(_:)-96itn","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(_:)-9rq9g","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(connection:cancellable:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(debugControllerDBus:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(raw:)-5no2w","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(raw:)-9iirb","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(retainingRaw:)-3fy9y","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(retainingRaw:)-62i45"]},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/metatypeReferenceForDebugControllerDBus","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/wrapperForDebugControllerDBus"],"title":"Instance Properties"},{"title":"Type Properties","anchor":"Type-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/metatypeForDebugControllerDBus"],"generated":true},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/DebugControllerDBusProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/DebugControllerProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/InitableProtocol-Implementations"],"anchor":"Default-Implementations"}],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/GIO\/10GLibObject0B0C"]},{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol","doc:\/\/GIO\/documentation\/GIO\/DebugControllerProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/InitableProtocol"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DebugControllerDBus"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is a [iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"type":"text","text":"] object, and will register an object at"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\/org\/gtk\/Debugging"},{"type":"text","text":" on the bus given as"},{"type":"text","text":" "},{"text":"[property","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus"},{"text":"] once it’s initialized. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object will be unregistered when the last reference to the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GDebugControllerDBus"},{"type":"text","text":" is dropped."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This D-Bus object can be used by remote processes to enable or disable debug"},{"text":" ","type":"text"},{"text":"output in this process. Remote processes calling","type":"text"},{"type":"text","text":" "},{"code":"org.gtk.Debugging.SetDebugEnabled()","type":"codeVoice"},{"type":"text","text":" will affect the value of"},{"text":" ","type":"text"},{"type":"text","text":"[property"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","type":"reference","isActive":true},{"text":"] and, by default,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"GLib.log_get_debug_enabled","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"By default, no processes are allowed to call ","type":"text"},{"type":"codeVoice","code":"SetDebugEnabled()"},{"text":" unless a","type":"text"},{"type":"text","text":" "},{"text":"[signal[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:)] signal handler is installed. This","type":"text"},{"text":" ","type":"text"},{"text":"is because the process may be privileged, or might expose sensitive","type":"text"},{"type":"text","text":" "},{"type":"text","text":"information in its debug output. You may want to restrict the ability to"},{"type":"text","text":" "},{"text":"enable debug output to privileged users or processes.","type":"text"}]},{"inlineContent":[{"text":"One option is to install a D-Bus security policy which restricts access to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"SetDebugEnabled()"},{"type":"text","text":", installing something like the following in"},{"text":" ","type":"text"},{"type":"codeVoice","code":"$datadir\/dbus-1\/system.d\/"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"xml","type":"codeListing","code":["<?xml version=\"1.0\"?> <!--*-nxml-*-->","<!DOCTYPE busconfig PUBLIC \"-\/\/freedesktop\/\/DTD D-BUS Bus Configuration 1.0\/\/EN\"","     \"http:\/\/www.freedesktop.org\/standards\/dbus\/1.0\/busconfig.dtd\">","<busconfig>","  <policy user=\"root\">","    <allow send_destination=\"com.example.MyService\" send_interface=\"org.gtk.Debugging\"\/>","  <\/policy>","  <policy context=\"default\">","    <deny send_destination=\"com.example.MyService\" send_interface=\"org.gtk.Debugging\"\/>","  <\/policy>","<\/busconfig>"]},{"inlineContent":[{"type":"text","text":"This will prevent the "},{"code":"SetDebugEnabled()","type":"codeVoice"},{"type":"text","text":" method from being called by all"},{"type":"text","text":" "},{"text":"except root. It will not prevent the ","type":"text"},{"code":"DebugEnabled","type":"codeVoice"},{"text":" property from being read,","type":"text"},{"type":"text","text":" "},{"text":"as it’s accessed through the ","type":"text"},{"code":"org.freedesktop.DBus.Properties","type":"codeVoice"},{"type":"text","text":" interface."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Another option is to use polkit to allow or deny requests on a case-by-case"},{"type":"text","text":" "},{"type":"text","text":"basis, allowing for the possibility of dynamic authorisation. To do this,"},{"text":" ","type":"text"},{"type":"text","text":"connect to the [signal[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:)] signal and query"},{"text":" ","type":"text"},{"text":"polkit in it:","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["  `g_autoptr(GError)` child_error = NULL;","  `g_autoptr(GDBusConnection)` connection = g_bus_get_sync (G_BUS_TYPE_SYSTEM, NULL, NULL);","  gulong debug_controller_authorize_id = 0;","","  \/\/ Set up the debug controller.","  debug_controller = G_DEBUG_CONTROLLER (g_debug_controller_dbus_new (priv->connection, NULL, &child_error));","  if (debug_controller == NULL)","    {","      g_error (\"Could not register debug controller on bus: `s`\",","               child_error->message);","    }","","  debug_controller_authorize_id = g_signal_connect (debug_controller,","                                                    \"authorize\",","                                                    G_CALLBACK (debug_controller_authorize_cb),","                                                    self);","","  static gboolean","  debug_controller_authorize_cb (GDebugControllerDBus  *debug_controller,","                                 GDBusMethodInvocation *invocation,","                                 gpointer               user_data)","  {","    `g_autoptr(PolkitAuthority)` authority = NULL;","    `g_autoptr(PolkitSubject)` subject = NULL;","    `g_autoptr(PolkitAuthorizationResult)` auth_result = NULL;","    `g_autoptr(GError)` local_error = NULL;","    GDBusMessage *message;","    GDBusMessageFlags message_flags;","    PolkitCheckAuthorizationFlags flags = POLKIT_CHECK_AUTHORIZATION_FLAGS_NONE;","","    message = g_dbus_method_invocation_get_message (invocation);","    message_flags = g_dbus_message_get_flags (message);","","    authority = polkit_authority_get_sync (NULL, &local_error);","    if (authority == NULL)","      {","        g_warning (\"Failed to get polkit authority: `s`\", local_error->message);","        return FALSE;","      }","","    if (message_flags & G_DBUS_MESSAGE_FLAGS_ALLOW_INTERACTIVE_AUTHORIZATION)","      flags |= POLKIT_CHECK_AUTHORIZATION_FLAGS_ALLOW_USER_INTERACTION;","","    subject = polkit_system_bus_name_new (g_dbus_method_invocation_get_sender (invocation));","","    auth_result = polkit_authority_check_authorization_sync (authority,","                                                             subject,","                                                             \"com.example.MyService.set-debug-enabled\",","                                                             NULL,","                                                             flags,","                                                             NULL,","                                                             &local_error);","    if (auth_result == NULL)","      {","        g_warning (\"Failed to get check polkit authorization: `s`\", local_error->message);","        return FALSE;","      }","","    return polkit_authorization_result_get_is_authorized (auth_result);","  }"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GDebugControllerDBus"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","isActive":true,"type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GDebugControllerDBus","type":"codeVoice"},{"type":"text","text":" instance."}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef"},{"text":" (instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","type":"reference"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"code":"GDebugControllerDBus","type":"codeVoice"},{"text":" instance.","type":"text"}]}],"style":"note","name":"Note","type":"aside"}]}],"variants":[{"paths":["\/documentation\/gio\/debugcontrollerdbus"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DebugControllerDBus/InitableProtocol-Implementations":{"url":"\/documentation\/gio\/debugcontrollerdbus\/initableprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/InitableProtocol-Implementations","abstract":[],"role":"collectionGroup","title":"InitableProtocol Implementations","type":"topic","kind":"article"},"doc://GIO/4GLib14PointerWrapperP":{"type":"unresolvable","identifier":"doc:\/\/GIO\/4GLib14PointerWrapperP","title":"GLib.PointerWrapper"},"doc://GIO/documentation/GIO/DebugControllerDBus/init(retaining:)":{"title":"init(retaining:)","url":"\/documentation\/gio\/debugcontrollerdbus\/init(retaining:)","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init(retaining:)","type":"topic","abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"code":"C","type":"codeVoice"},{"text":" data type.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Will ret