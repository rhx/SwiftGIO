{"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef\/close(cancellable:)"},"kind":"symbol","metadata":{"roleHeading":"Instance Method","symbolKind":"method","externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO23PollableOutputStreamRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"extendedModule":"GIO","role":"symbol","title":"close(cancellable:)","modules":[{"name":"GIO"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Once the stream is closed, all other operations will return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers in the"},{"text":" ","type":"text"},{"type":"text","text":"stream."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"text":" ","type":"text"},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"type":"text","text":" "},{"text":"resources are released as early as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"type":"text","text":" "},{"text":"stream for details.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"text":" ","type":"text"},{"text":"close will still return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":" for all operations. Still, it"},{"text":" ","type":"text"},{"text":"is important to check and report the error to the user, otherwise","type":"text"},{"type":"text","text":" "},{"type":"text","text":"there might be a loss of data as all data might not be written."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but there some streams"},{"text":" ","type":"text"},{"text":"can use a faster close that doesn’t block to e.g. check errors. On","type":"text"},{"text":" ","type":"text"},{"text":"cancellation (as with any error) there is no guarantee that all written","type":"text"},{"type":"text","text":" "},{"type":"text","text":"data will reach the target."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/pollableoutputstreamref\/close(cancellable:)"]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/PollableOutputStreamRef/close(cancellable:)":{"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef\/close(cancellable:)","title":"close(cancellable:)","type":"topic","kind":"symbol","url":"\/documentation\/gio\/pollableoutputstreamref\/close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"role":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/PollableOutputStreamRef":{"role":"symbol","abstract":[{"type":"codeVoice","code":"GPollableOutputStream"},{"text":" is implemented by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","type":"reference"},{"type":"text","text":"]s that"},{"type":"text","text":" "},{"text":"can be polled for readiness to write. This can be used when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interfacing with a non-GIO API that expects"},{"text":" ","type":"text"},{"text":"UNIX-file-descriptor-style asynchronous I\/O rather than GIO-style.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef","kind":"symbol","title":"PollableOutputStreamRef","url":"\/documentation\/gio\/pollableoutputstreamref","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"PollableOutputStreamRef"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"PollableOutputStreamRef"}]},"doc://GIO/documentation/GIO/PollableOutputStreamRef/OutputStreamProtocol-Implementations":{"kind":"article","url":"\/documentation\/gio\/pollableoutputstreamref\/outputstreamprotocol-implementations","abstract":[],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef\/OutputStreamProtocol-Implementations","title":"OutputStreamProtocol Implementations"}}}