{"kind":"symbol","abstract":[{"type":"text","text":"Tries to write "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from "},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" into the stream. Will block"},{"type":"text","text":" "},{"type":"text","text":"during the operation."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"write"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If count is 0, returns 0 and does nothing. A value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" "},{"type":"text","text":"larger than "},{"code":"G_MAXSSIZE","type":"codeVoice"},{"text":" will cause a ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"type":"text","text":" "},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"type":"text","text":" "},{"text":"can happen e.g. on a partial I\/O error, or if there is not enough","type":"text"},{"text":" ","type":"text"},{"text":"storage in the stream. All writes block until at least one byte","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"type":"text","text":" "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is 0)."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/pollableoutputstreamref\/write(buffer:count:cancellable:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef\/write(buffer:count:cancellable:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sect