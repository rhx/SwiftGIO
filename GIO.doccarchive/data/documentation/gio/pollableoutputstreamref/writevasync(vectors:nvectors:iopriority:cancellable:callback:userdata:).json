ncReadyCallback","kind":"typeIdentifier","text":"GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef\/writevAsync(vectors:nVectors:ioPriority:cancellable:callback:userData:)"},"abstract":[{"type":"text","text":"Request an asynchronous write of the bytes contained in "},{"type":"codeVoice","code":"nVectors"},{"type":"text","text":" "},{"type":"codeVoice","code":"vectors"},{"text":" into","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the stream. When the operation is finished "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"text":"You can then call ","type":"text"},{"code":"g_output_stream_writev_finish()","type":"codeVoice"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"type":"text","text":"operation."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writevAsync","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"vectors"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GOutputVector"},{"text":">!, ","kind":"text"},{"text":"nVectors","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"text":" ","type":"text"},{"text":"and will result in ","type":"text"},{"code":"pending","type":"codeVoice"},{"type":"text","text":" errors."}]},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes written will be passed to the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"callback"},{"type":"text","text":". It is not an error if this is not the same as the"},{"text":" ","type":"text"},{"type":"text","text":"requested size, as it can happen e.g. on a partial I\/O error,"},{"type":"text","text":" "},{"type":"text","text":"but generally we try to write as many bytes as requested."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You are guaranteed that this method will never fail with"},{"text":" ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" — if "},{"code":"stream","type":"codeVoice"},{"type":"text","text":" can’t accept more data, the"},{"text":" ","type":"text"},{"text":"method will just wait until this changes.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical"},{"type":"text","text":" "},{"type":"text","text":"value) will be executed before an outstanding request with lower"},{"text":" ","type":"text"},{"text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads","type":"text"},{"type":"text","text":" "},{"text":"to implement asynchronicity, so they are optional for inheriting","type":"text"},{"text":" ","type":"text"},{"text":"classes. However, if you override one you must override all.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"type":"text","text":" "},{"code":"g_output_stream_writev()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that no copy of ","type":"text"},{"code":"vectors","type":"codeVoice"},{"text":" will be made, so it must stay valid","type":"text"},{"text":" ","type":"text"},{"text":"until ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" is called."}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/PollableOutputStreamRef":{"role":"symbol","abstract":[{"type":"codeVoice","code":"GPollableOutputStream"},{"text":" is implemented by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","type":"reference"},{"type":"text","text":"]s that"},{"type":"text","text":" "},{"text":"can be polled for readiness to write. This can be used when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interfacing with a non-GIO API that expects"},{"text":" ","type":"text"},{"text":"UNIX-file-descriptor-style asynchronous I\/O rather than GIO-style.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableOutputStreamRef","kind":"symbol","title":"PollableOutputStreamRef","u