f [method"},{"type":"codeVoice","code":"Gio.Settings.reset"},{"type":"text","text":"] were to be"},{"type":"text","text":" "},{"text":"called on the key.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this may be a different value than returned by"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SettingsSchemaKey.get_default_value"},{"text":"] if the system administrator","type":"text"},{"type":"text","text":" "},{"text":"has provided a default value.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Comparing the return values of [method"},{"type":"codeVoice","code":"Gio.Settings.get_default_value"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.Settings.get_value"},{"type":"text","text":"] is not sufficient for determining if a value"},{"text":" ","type":"text"},{"type":"text","text":"has been set because the user may have explicitly set the value to"},{"type":"text","text":" "},{"type":"text","text":"something that happens to be equal to the default.  The difference"},{"text":" ","type":"text"},{"type":"text","text":"here is that if the default changes in the future, the user’s key"},{"type":"text","text":" "},{"type":"text","text":"will still be set."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function may be useful for adding an indication to a UI of what","type":"text"},{"text":" ","type":"text"},{"text":"the default value was before the user set it.","type":"text"}]},{"inlineContent":[{"type":"text","text":"It is a programmer error to give a "},{"type":"codeVoice","code":"key"},{"text":" that isn’t contained in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"schema for "},{"type":"codeVoice","code":"settings"},{"type":"text","text":"."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text"