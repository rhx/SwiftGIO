xt","text":"If "},{"code":"backend","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" then the default backend is used."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"path"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" then the path from the schema is used.  It is an"},{"text":" ","type":"text"},{"text":"error if ","type":"text"},{"type":"codeVoice","code":"path"},{"type":"text","text":" is "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" and the schema has no path of its own or if"},{"type":"text","text":" "},{"code":"path","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" and not equal to the path that the schema does"},{"type":"text","text":" "},{"type":"text","text":"have."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/settings\/init(full:backend:path:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Settings"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"s:3GIO8SettingsC4full7backend4pathACq__xSgSPys4Int8VGSgtcAA0B15BackendProtocolRzAA0b6SchemaH0R_r0_lufc","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SettingsBackendT","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"SettingsSchemaT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"full"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"SettingsSchemaT"},{"kind":"text","text":", "},{"text":"backend","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"SettingsBackendT"},{"text":"?, ","kind":"text"},{"text":"path","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifi