l is emitted"}]}],"name":"handler"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should connect"},{"type":"text","text":" "},{"type":"text","text":"to this signal if you are interested in viewing groups of changes"},{"type":"text","text":" "},{"text":"before they are split out into multiple emissions of the","type":"text"},{"text":" ","type":"text"},{"text":"[signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)] signal.  For most use cases it is more","type":"text"},{"type":"text","text":" "},{"type":"text","text":"appropriate to use the [signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)] signal."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that the writability change applies only to a single"},{"text":" ","type":"text"},{"text":"key, ","type":"text"},{"type":"codeVoice","code":"key"},{"text":" will be set to the [alias[Quark](\/\/documentation\/glib\/quark] for that key.  In the event","type":"text"},{"type":"text","text":" "},{"text":"that the writability change affects the entire settings object,","type":"text"},{"text":" ","type":"text"},{"code":"key","type":"codeVoice"},{"type":"text","text":" will be "},{"code":"0","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The default handler for this signal invokes the [signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)]","type":"text"},{"text":" ","type":"text"},{"text":"and [signal[Settings](\/\/documentation\/gio\/settings\/onchanged(flags:handler:)] signals for each affected key.  This is done because","type":"text"},{"type":"text","text":" "},{"type":"text","text":"changes in writability might also imply changes in value (if for"},{"type":"text","text":" "},{"type":"text","text":"example, a new mandatory setting is introduced).  If any other"},{"type":"text","text":" "},{"type":"text","text":"connected handler returns true then this default functionality"},{"text":" ","type":"text"},{"type":"text","text":"will be suppressed."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"writable-change-event"},{"text":" signal","type":"text"}]}],"type":"aside","style":"note","name":"Note"}]}],"abstract":[{"text":"Emitted once per writability change event that affects this settings object.","type":"text"}],"variants":[{"paths":["\/documentation\/gio\/settings\/onwritablechangeevent(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onWritableChangeEvent"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO11SettingsRefV","text":"SettingsRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Su","text":"UInt"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"role":"symbol","externalID":"s:3GIO16SettingsProtocolPAAE21onWritableChangeEvent5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0B3RefV_SutctF::SYNTHESIZED::s:3GIO8SettingsC","modules":[{"name":"GIO"}],"title":"onWritableChangeEvent(flags:handler:)","roleHeading":"Instance Method","symbolKind":"method"},"references":{"doc://GIO/documentation/GIO/Settings/onWritableChangeEvent(flags:handler:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings\/