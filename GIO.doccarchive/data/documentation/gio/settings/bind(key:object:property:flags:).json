pe":"paragraph","inlineContent":[{"text":"The binding uses the default GIO mapping functions to map","type":"text"},{"text":" ","type":"text"},{"text":"between the settings and property values. These functions","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handle booleans, numeric types and string types in a"},{"type":"text","text":" "},{"text":"straightforward way. Use [method","type":"text"},{"type":"codeVoice","code":"Gio.Settings.bind_with_mapping"},{"type":"text","text":"] if"},{"text":" ","type":"text"},{"type":"text","text":"you need a custom mapping, or map between types that are not"},{"text":" ","type":"text"},{"type":"text","text":"supported by the default mapping functions."}]},{"inlineContent":[{"type":"text","text":"Unless the "},{"code":"flags","type":"codeVoice"},{"type":"text","text":" include [flags"},{"type":"codeVoice","code":"Gio.SettingsBindFlags.NO_SENSITIVITY"},{"text":"], this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function also establishes a binding between the writability of"},{"type":"text","text":" "},{"code":"key","type":"codeVoice"},{"text":" and the ","type":"text"},{"type":"codeVoice","code":"sensitive"},{"type":"text","text":" property of "},{"type":"codeVoice","code":"object"},{"type":"text","text":" (if "},{"code":"object","type":"codeVoice"},{"text":" has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a boolean property by that name). See [method"},{"type":"codeVoice","code":"Gio.Settings.bind_writable"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"for more details about writable bindings."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that the lifecycle of the binding is tied to ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and that you can have only one binding per object property."},{"text":" ","type":"text"},{"text":"If you bind the same property twice on the same object, the second","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"binding overrides the first one."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Settings/SettingsProtocol-Implementations":{"type":"topic","role":"collectionGroup","title":"SettingsProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings\/SettingsProtocol-Implementations","abstract":[],"url":"\/documentation\/gio\/settings\/settingsprotocol-implementations","kind":"article"},"doc://GIO/documentation/GIO/Settings/bind(key:object:property:flags:)":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings\/bind(key:object:property:flags:)","title":"bind(key:object:property:flags:)","url":"\/documentation\/gio\/settings\/bind(key:object:property:flags:)","abstract":[{"type":"text","text":"Create a binding between the "},{"type":"codeVoice","code":"key"},{"text":" in the ","type":"text"},{"type":"codeVoice","code":"settings"},{"type":"text","text":" object"},{"text":" ","type":"text"},{"text":"and the property ","type":"text"},{"type":"codeVoice","code":"property"},{"text":" of ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"bind"},{"text":"<","kind":"text"},{"text":"GObjectObjectT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"key","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"text":"