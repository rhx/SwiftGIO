,"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::delay-apply","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"}]}],"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Settings\/onNotifyDelayApply(flags:handler:)"},"metadata":{"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","extendedModule":"GIO","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onNotifyDelayApply","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"SettingsRef","preciseIdentifier":"s:3GIO11SettingsRefV"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Void","preciseI