"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getMapped","kind":"identifier"},{"kind":"text","text":"("},{"text":"key","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"mapping"},{"kind":"text","text":": "},{"text":"GSettingsGetMapping","preciseIdentifier":"c:@T@GSettingsGetMapping","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil) -> "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"You should use this function when the application needs to perform","type":"text"},{"text":" ","type":"text"},{"text":"some processing on the value of the key (for example, parsing).  The","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"mapping"},{"type":"text","text":" function performs that processing.  If the function"},{"type":"text","text":" "},{"type":"text","text":"indicates that the processing was unsuccessful (due to a parse error,"},{"text":" ","type":"text"},{"type":"text","text":"for example) then the mapping is tried again with another value."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This allows a robust ‘fall back to defaults’ behaviour to be"},{"type":"text","text":" "},{"text":"implemented somewhat automatically.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The first value that is tried is the user’s setting for the key.  If"},{"type":"text","text":" "},{"type":"text","text":"the mapping function fails to map this value, other values may be"},{"type":"text","text":" "},{"type":"text","text":"tried in an unspecified order (system or site defaults, translated"},{"type":"text","text":" "},{"type":"text","text":"schema default values, untranslated schema default values, etc)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the mapping function fails for all possible values, one additional","type":"text"},{"type":"text","text":" "},{"type":"text","text":"attempt is made: the mapping function is called with a "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" value."},{"text":" ","type":"text"},{"text":"If the mapping function still indicates failure at this point then","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the application will be aborted."}]},{"inlineContent":[{"type":"text","text":"The result parameter for the "},{"type":"codeVoice","code":"mapping"},{"text":" function is pointed to a","type":"text"},{"text":" ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"text":" which is initially set to ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":".  The same pointer is given"},{"type":"text","text":" "},{"text":"to each invocation of ","type":"text"},{"type":"codeVoice","code":"mapping"},{"type":"text","text":".  The final value of that "},{"type":"codeVoice","code":"gpointer"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"what is returned by this function.  ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" is valid; it is returned"},{"type":"text","text":" "},{"type":"text","text":"just as any other value would be."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/settings\/getmapped(key:mapping:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc: