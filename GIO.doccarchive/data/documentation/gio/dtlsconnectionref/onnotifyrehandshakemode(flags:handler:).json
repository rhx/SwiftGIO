{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/DtlsConnectionProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyRehandshakeMode","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17DtlsConnectionRefV","text":"DtlsConnectionRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to