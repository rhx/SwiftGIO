 this:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::rehandshake-mode"},{"type":"text","text":" signal"}]}],"name":"Note","style":"note"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/onNotifyRehandshakeMode(flags:handler:)"},"metadata":{"symbolKind":"method","role":"symbol","extendedModule":"GIO","modules":[{"name":"GIO"}],"title":"onNotifyRehandshakeMode(flags:handler:)","externalID":"s:3GIO22DtlsConnectionProtocolPAAE23onNotifyRehandshakeMode5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecO0VtctF::SYNTHESIZED::s:3GIO17DtlsConnectionRefV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onNotifyRehandshakeMode","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"DtlsConnectionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17DtlsConnectionRefV"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ParamSpe