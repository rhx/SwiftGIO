{"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/DtlsConnectionProtocol-Implementations"]]},"kind":"symbol","metadata":{"extendedModule":"GIO","role":"symbol","externalID":"s:3GIO22DtlsConnectionProtocolPAAE9handshake11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO17DtlsConnectionRefV","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"handshake"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"title":"handshake(cancellable:)","modules":[{"name":"GIO"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"handshake"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"On the client side, it is never necessary to call this method;"},{"text":" ","type":"text"},{"type":"text","text":"although the connection needs to perform a handshake after"},{"type":"text","text":" "},{"text":"connecting, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection"},{"text":" will handle this for you automatically","type":"text"},{"text":" ","type":"text"},{"text":"when you try to send or receive data on the connection. You can call","type":"text"},{"type":"text","text":" "},{"code":"g_dtls_connection_handshake()","type":"codeVoice"},{"text":" manually if you want to know whether","type":"text"},{"text":" ","type":"text"},{"text":"the initial handshake succeeded or failed (as opposed to just","type":"text"},{"type":"text","text":" "},{"type":"text","text":"immediately trying to use "},{"type":"codeVoice","code":"conn"},{"type":"text","text":" to read or write, in which case,"},{"type":"text","text":" "},{"text":"if it fails, it may not be possible to tell if it failed before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or after completing the handshake), but beware that servers may reject"},{"type":"text","text":" "},{"text":"client authentication after the handshake has completed, so a","type":"text"},{"text":" ","type":"text"},{"text":"successful handshake does not indicate the connection will be usable.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Likewise, on the server side, although a handshake is necessary at","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the beginning of the communication, you do not need to call this"},{"type":"text","text":" "},{"type":"text","text":"function explicitly unless you want clearer error reporting."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Previously, calling "},{"code":"g_dtls_connection_handshake()","type":"codeVoice"},{"text":" after the initial","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"text":" ","type":"text"},{"text":"deprecated in GLib 2.60 because rehandshaking was removed from the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after"},{"text":" ","type":"text"},{"text":"the initial handshake will no longer do anything.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the"},{"type":"text","text":" "},{"type":"text","text":"handshake."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsconnectionref\/handshake(cancellable:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/handshake(cancellable:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Attempts a TLS handshake on "},{"type":"codeVoice","code":"conn"},{"text":".","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DtlsConnectionRef":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsconnectionref","abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"text":" is the base DTLS connection class type, which wraps","type":"text"},{"type":"text","text":" "},{"text":"a [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","type":"reference"},{"type":"text","text":"] and provides DTLS encryption on top of it. Its"},{"text":" ","type":"text"},{"text":"subclasses, [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","isActive":true},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection"},{"type":"text","text":"], implement client-side and server-side DTLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsConnectionRef","kind":"identifier"}],"title":"DtlsConnectionRef","navigatorTitle":[{"text":"DtlsConnectionRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsServerConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsserverconnection","abstract":[{"type":"codeVoice","code":"GDtlsServerConnection"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"type":"text","text":"], representing a server-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsServerConnection","kind":"identifier"}],"title":"DtlsServerConnection","navigatorTitle":[{"text":"DtlsServerConnection","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/DtlsConnectionRef/DtlsConnectionProtocol-Implementations":{"type":"topic","abstract":[],"kind":"article","title":"DtlsConnectionProtocol Implementations","rol