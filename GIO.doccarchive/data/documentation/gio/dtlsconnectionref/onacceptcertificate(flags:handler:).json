{"abstract":[{"text":"Emitted during the TLS handshake after the peer certificate has","type":"text"},{"text":" ","type":"text"},{"text":"been received. You can examine ","type":"text"},{"type":"codeVoice","code":"peerCert"},{"text":"’s certification path by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"g_tls_certificate_get_issuer()","type":"codeVoice"},{"type":"text","text":" on it."}],"sections":[],"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/onAcceptCertificate(flags:handler:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsconnectionref\/onacceptcertificate(flags:handler:)"]}],"metadata":{"symbolKind":"method","role":"symbol","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onAcceptCertificate"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17DtlsConnectionRefV","text":"DtlsConnectionRef"},{"text":", ","kind":"text"},{"text":"TLSCertificateRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSCertificateRefV"},{"text":", ","kind":"text"},{"text":"TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"roleHeading":"Instance Method","modules":[{"name":"GIO"}],"title":"onAcceptCertificate(flags:handler:)","externalID":"s:3GIO22DtlsConnectionProtocolPAAE19onAcceptCertificate5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0bC3RefV_AA014TLSCertificateN0VAA0oM0VtctF::SYNTHESIZED::s:3GIO17DtlsConnectionRefV"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onAcceptCertificate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier","text":"ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:3GIO17DtlsConnectionRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","text":"DtlsConnectionRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"TLSCertificateRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","text":"TLSCertificateFlags"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}],"name":"flags"},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"true"},{"type":"text","text":" to accept "},{"type":"codeVoice","code":"peerCert"},{"text":" (which will also immediately end the signal emission). ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" to allow the signal emission to continue, which will cause the handshake to fail if no one else overrides it.","type":"text"},{"text":" ","type":"text"},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"acceptCertificate"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"For a client-side connection, "},{"type":"codeVoice","code":"peerCert"},{"text":" is the server’s","type":"text"},{"type":"text","text":" "},{"text":"certificate, and the signal will only be emitted if the","type":"text"},{"text":" ","type":"text"},{"text":"certificate was not acceptable according to ","type":"text"},{"code":"conn","type":"codeVoice"},{"type":"text","text":"’s"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection"},{"text":". If you would like the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate to be accepted despite "},{"type":"codeVoice","code":"errors"},{"text":", return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the"},{"type":"text","text":" "},{"type":"text","text":"signal handler. Otherwise, if no handler accepts the certificate,"},{"text":" ","type":"text"},{"type":"text","text":"the handshake will fail with "},{"type":"codeVoice","code":"badCertificate"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, this signal"},{"text":" ","type":"text"},{"text":"will be emitted with at least one error will be set in ","type":"text"},{"type":"codeVoice","code":"errors"},{"text":", but","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it does not guarantee that all possible errors will be set."},{"type":"text","text":" "},{"type":"text","text":"Accordingly, you may not safely decide to ignore any particular"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"text":" ","type":"text"},{"type":"codeVoice","code":"expired"},{"text":" if you want to allow expired","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificates, because this could potentially be the only error flag"},{"type":"text","text":" "},{"text":"set even if other problems exist with the certificate.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a server-side connection, "},{"code":"peerCert","type":"codeVoice"},{"text":" is the certificate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"presented by the client, if this was requested via the server’s"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","isActive":true},{"text":". On the server side,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the signal is always emitted when the client presents a"},{"text":" ","type":"text"},{"text":"certificate, and the certificate will only be accepted if a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handler returns "},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"text":" ","type":"text"},{"type":"text","text":"in the main thread, then you should not attempt to interact with"},{"type":"text","text":" "},{"text":"the user before returning from the signal handler. If you want to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"let the user decide whether or not to accept the certificate, you"},{"type":"text","text":" "},{"type":"text","text":"would have to return "},{"type":"codeVoice","code":"false"},{"type":"text","text":" from the signal handler on the first"},{"type":"text","text":" "},{"text":"attempt, and then after the connection attempt returns a","type":"text"},{"type":"text","text":" "},{"code":"badCertificate","type":"codeVoice"},{"text":", you can interact with the user, and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if the user decides to accept the certificate, remember that fact,"},{"type":"text","text":" "},{"type":"text","text":"create a new connection, and return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the signal handler"},{"type":"text","text":" "},{"type":"text","text":"the next time."}],"type":"paragraph"},{"inlineContent":[{"text":"If you are doing I\/O in another thread, you do not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"need to worry about this, and can simply block in the signal"},{"type":"text","text":" "},{"type":"text","text":"handler until the UI thread returns an answer."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"accept-certificate","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/DtlsConnectionProtocol-Implementations"]]},"references":{"//documentation/gio/tlsconnection/onacceptcertificate(flags:handler:)":{"titleInlineContent":[{"text":"TLSConnection","type":"text"}],"url":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","type":"link","title":"TLSConnection","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":