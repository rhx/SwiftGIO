ext","text":" "},{"text":"DtlsConnection","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"DtlsConnection"}],"abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"type":"text","text":" is the base DTLS connection class type, which wraps"},{"text":" ","type":"text"},{"text":"a [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"text":"] and provides DTLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"text":"subclasses, [iface","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection"},{"text":"] and","type":"text"},{"type":"text","text":" "},{"text":"[iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","isActive":true,"type":"reference"},{"text":"], implement client-side and server-side DTLS,","type":"text"},{"text":" ","type":"text"},{"text":"respectively.","type":"text"}],"title":"DtlsConnection","url":"\/documentation\/gio\/dtlsconnection"},"doc://GIO/documentation/GIO/DtlsConnectionRef/DtlsConnectionProtocol-Implementations":{"type":"topic","abstract":[],"kind":"article","title":"DtlsConnectionProtocol Implementations","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/DtlsConnectionProtocol-Implementations","url":"\/documentation\/gio\/dtlsconnectionref\/dtlsconnectionprotocol-implementations"},"doc://GIO/documentation/GIO/DtlsServerConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsserverconnection","abstract":[{"type":"codeVoice","code":"GDtlsServerConnection"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"type":"text","text":"], representing a server-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsServerConnection","kind":"identifier"}],"title":"DtlsServerConnection","navigatorTitle":[{"text":"DtlsServerConnection","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsClientConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsclientconnection","abstract":[{"code":"GDtlsClientConnection","type":"codeVoice"},{"text":" is the client-side subclass of","type":"text"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection"},{"type":"text","text":"], representing a client-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DtlsClientConnection"}],"title":"DtlsClientConnection","navigatorTitle":[{"kind":"identifier","text":"DtlsClientConnection"}]},"doc://GIO/documentation/GIO/TLSCertificateRef":{"abstract":[{"text":"A certificate used for TLS authentication and encryption.","type":"text"},{"text":" ","type":"text"},{"text":"This can represent either a certificate only (eg, the certificate","type":"text"},{"type":"text","text":" "},{"text":"received by a client from a server), or the combination of","type":"text"},{"type":"text","text":" "},{"text":"a certificate and a private key (which is needed when acting as a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference"},{"type":"text","text":"])."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateRef"}],"title":"TLSCertificateRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TLSCertificateR