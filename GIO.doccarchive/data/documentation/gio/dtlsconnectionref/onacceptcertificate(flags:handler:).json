GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a server-side TLS connection.","type":"text"}]},"doc://GIO/documentation/GIO/TLSCertificateFlags":{"url":"\/documentation\/gio\/tlscertificateflags","abstract":[{"type":"text","text":"A set of flags describing TLS certification validation. This can be"},{"type":"text","text":" "},{"type":"text","text":"used to describe why a particular certificate was rejected (for"},{"type":"text","text":" "},{"text":"example, in ","type":"text"},{"type":"reference","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","isActive":true},{"text":".","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateFlags","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateFlags"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","title":"TLSCertificateFlags","kind":"symbol"}}}