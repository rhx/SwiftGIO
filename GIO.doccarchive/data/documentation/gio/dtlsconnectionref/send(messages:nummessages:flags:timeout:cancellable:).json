peIdentifier"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/DatagramBasedProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/send(messages:numMessages:flags:timeout:cancellable:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"send"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GOutputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"timeout","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"codeVoice","code":"messages"},{"type":"text","text":" must point to an array of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"text":" structs and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"type":"text","text":" "},{"text":"contains an address to send the data to, and a pointer to an array of","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true,"type":"reference"},{"text":" structs to describe the buffers that the data to be sent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for each message will be gathered from."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"text":" ","type":"text"},{"text":"for this are available in the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true,"type":"reference"},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"type":"text","text":"values there are the same as the system values, and the flags"},{"type":"text","text":" "},{"text":"are passed in as-is, so you can pass in system-specific flags too.","type":"text"}]},{"inlineContent":[{"text":"The other members of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"text":" are treated as described in its","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"documentation."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is negative the call will block until "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" have been"},{"type":"text","text":" "},{"text":"sent, ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled, or an error occurs."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"text":" is 0 the call will send up to ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" without blocking,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or will return "},{"code":"wouldBlock","type":"codeVoice"},{"text":" if there is no space to send messages.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is positive the call will block on the same conditions as if","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" were negative. If the timeout is reached before any messages are"},{"type":"text","text":" "},{"type":"text","text":"sent, "},{"code":"timedOut","type":"codeVoice"},{"type":"text","text":" is returned, otherwise it will return the number"},{"text":" ","type":"text"},{"text":"of messages sent before timing out.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Note though that you may still receive "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" from"},{"type":"text","text":" "},{"code":"g_datagram_based_send_messages()","type":"codeVoice"},{"text":" even if you were previously notified of a","type":"text"},{"text":" ","type":"text"},{"text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to","type":"text"},{"text":" ","type":"text"},{"text":"the way the underlying APIs work.)","type":"text"}]},{"inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_shutdown()"},{"text":" with ","type":"text"},{"code":"shutdown_write","type":"codeVoice"},{"type":"text","text":" set, if it’s a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":", for"},{"type":"text","text":" "},{"text":"example), all calls to this function will return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" is set accordingly. An error will only","type":"text"},{"type":"text","text":" "},{"text":"be returned if zero messages could be sent; otherwise the number of messages","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"successfully sent before the error will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"cancelled, "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any other error."}]}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/DtlsConnectionRef":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsconnectionref","abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"text":" is the base DTLS connection class type, which wraps","type":"text"},{"type":"text","text":" "},{"text":"a [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","type":"reference"},{"type":"text","text":"] and provides DTLS encryption on top of it. Its"},{"text":" ","type":"text"},{"text":"subclasses, [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectio