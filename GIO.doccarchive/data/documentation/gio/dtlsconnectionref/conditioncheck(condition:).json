{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsconnectionref\/conditioncheck(condition:)"]}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/conditionCheck(condition:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Checks on the readiness of "},{"code":"datagramBased","type":"codeVoice"},{"type":"text","text":" to perform operations. The"},{"type":"text","text":" "},{"text":"operations specified in ","type":"text"},{"type":"codeVoice","code":"condition"},{"text":" are checked for and masked against the","type":"text"},{"type":"text","text":" "},{"text":"currently-satisfied conditions on ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"text":". The result is returned.","type":"text"}],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","title":"conditionCheck(condition:)","externalID":"s:3GIO21DatagramBasedProtocolPAAE14conditionCheck0E04GLib11IOConditionVAH_tF::SYNTHESIZED::s:3GIO17DtlsConnectionRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"conditionCheck","kind":"identifier"},{"text":"(","kind":"text"},{"text":"condition","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib11IOConditionV","kind":"typeIdentifier","text":"IOCondition"},{"kind":"text","text":") -> "},{"text":"IOCondition","kind":"typeIdentifier","preciseIdentifier":"s:4GLib11IOConditionV"}],"extendedModule":"GIO","modules":[{"name":"GIO"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"conditionCheck","kind":"identifier"},{"kind":"text","text":"("},{"text":"condition","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib11IOConditionV","text":"IOCondition"},{"text":") -> ","kind":"text"},{"text":"IOCondition","preciseIdentifier":"s:4GLib11IOConditionV","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"[In_](\/\/Documentation\/Gobject\/In_ will be set in the return value if data is available to read with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":", or if the connection is closed remotely"},{"type":"text","text":" "},{"type":"text","text":"(EOS); and if the datagram_based has not been closed locally using some"},{"text":" ","type":"text"},{"type":"text","text":"implementation-specific method (such as "},{"code":"g_socket_close()","type":"codeVoice"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"code":"shutdown_read","type":"codeVoice"},{"type":"text","text":" set, if it’s a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true,"type":"reference"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"type":"codeVoice","code":"g_socket_close()"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_shutdown()"},{"text":" with ","type":"text"},{"code":"shutdown_read","type":"codeVoice"},{"type":"text","text":" set, if it’s a "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true},{"type":"text","text":", for"},{"type":"text","text":" "},{"type":"text","text":"example), all calls to this function will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"[out](\/\/documentation\/gobject\/out will be set if it is expected that at least one byte can be sent"},{"type":"text","text":" "},{"type":"text","text":"using "},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"type":"text","text":" without blocking. It will not be set"},{"type":"text","text":" "},{"type":"text","text":"if the datagram_based has been closed locally."}]},{"inlineContent":[{"type":"text","text":"[hup](\/\/documentation\/gobject\/hup will be set if the connection has been closed locally."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"[err](\/\/documentation\/gobject\/err will be set if there was an asynchronous error in transmitting data"},{"type":"text","text":" "},{"type":"text","text":"previously enqueued using "},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that on Windows, it is possible for an operation to return"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"text":" even immediately after","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_condition_check()"},{"text":" has claimed that the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"ready for writing. Rather than calling "},{"code":"g_datagram_based_condition_check()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"then writing to the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","type":"reference","isActive":true},{"type":"text","text":" if it succeeds, it is generally better to"},{"type":"text","text":" "},{"type":"text","text":"simply try writing right away, and try again later if the initial attempt"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"It is meaningless to specify [err](\/\/documentation\/gobject\/err or [hup](\/\/documentation\/gobject\/hup in ","type":"text"},{"type":"codeVoice","code":"condition"},{"type":"text","text":"; these"},{"type":"text","text":" "},{"type":"text","text":"conditions will always be set in the output if they are true. Apart from"},{"type":"text","text":" "},{"type":"text","text":"these flags, the output is guaranteed to be masked by "},{"code":"condition","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This call never blocks.","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/DatagramBasedProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/DtlsConnectionRef":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsconnectionref","abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"text":" is the base DTLS connection class type, which wraps","type":"text"},{"type":"text","text":" "},{"text":"a [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","type":"reference"},{"type":"text","text":"] and provides DTLS encryption on top of it. Its"},{"text":" ","type":"text"},{"text":"subclasses, [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","isActive":true},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection"},{"type":"text","text":"], implement client-side and server-side DTLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","fragments":[{"text":"struct","kind":"keyword