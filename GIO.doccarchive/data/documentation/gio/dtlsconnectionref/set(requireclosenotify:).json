{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/DtlsConnectionProtocol-Implementations"]]},"sections":[],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"requireCloseNotify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"symbolKind":"method","title":"set(requireCloseNotify:)","role":"symbol","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","externalID":"s:3GIO22DtlsConnectionProtocolPAAE3set18requireCloseNotifyySb_tF::SYNTHESIZED::s:3GIO17DtlsConnectionRefV","extendedModule":"GIO"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/gio\/dtlsconnectionref\/set(requireclosenotify:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef\/set(requireCloseNotify:)"},"abstract":[{"text":"Sets whether or not ","type":"text"},{"code":"conn","type":"codeVoice"},{"type":"text","text":" expects a proper TLS close notification"},{"type":"text","text":" "},{"type":"text","text":"before the connection is closed. If this is "},{"code":"true","type":"codeVoice"},{"type":"text","text":" (the default),"},{"text":" ","type":"text"},{"type":"text","text":"then "},{"type":"codeVoice","code":"conn"},{"text":" will expect to receive a TLS close notification from its","type":"text"},{"text":" ","type":"text"},{"text":"peer before the connection is closed, and will return a","type":"text"},{"type":"text","text":" "},{"code":"eof","type":"codeVoice"},{"text":" error if the connection is closed without proper","type":"text"},{"type":"text","text":" "},{"text":"notification (since this may indicate a network error, or","type":"text"},{"text":" ","type":"text"},{"text":"man-in-the-middle attack).","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"requireCloseNotify","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"In some protocols, the application will know whether or not the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connection was closed cleanly based on application-level data"},{"type":"text","text":" "},{"text":"(because the application-level data includes a length field, or is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"somehow self-delimiting); in this case, the close notify is"},{"text":" ","type":"text"},{"text":"redundant and may be omitted. You","type":"text"},{"type":"text","text":" "},{"text":"can use ","type":"text"},{"type":"codeVoice","code":"g_dtls_connection_set_require_close_notify()"},{"type":"text","text":" to tell "},{"type":"codeVoice","code":"conn"},{"text":" ","type":"text"},{"type":"text","text":"to allow an “unannounced” connection close, in which case the close"},{"type":"text","text":" "},{"type":"text","text":"will show up as a 0-length read, as in a non-TLS"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"type":"text","text":", and it is up to the application to check that"},{"text":" ","type":"text"},{"text":"the data has been fully received.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this only affects the behavior when the peer closes the"},{"text":" ","type":"text"},{"type":"text","text":"connection; when the application calls "},{"code":"g_dtls_connection_close_async()","type":"codeVoice"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"codeVoice","code":"conn"},{"type":"text","text":" itself, this will send a close notification regardless of the"},{"text":" ","type":"text"},{"type":"text","text":"setting of this property. If you explicitly want to do an unclean"},{"text":" ","type":"text"},{"type":"text","text":"close, you can close "},{"code":"conn","type":"codeVoice"},{"text":"’s ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"text":" rather","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"than closing "},{"code":"conn","type":"codeVoice"},{"text":" itself.","type":"text"}]}]}],"references":{"doc://GIO/documentation/GIO/DtlsServerConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsserverconnection","abstract":[{"type":"codeVoice","code":"GDtlsServerConnection"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"type":"text","text":"], representing a server-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsServerConnection","kind":"identifier"}],"title":"DtlsServerConnection","navigatorTitle":[{"text":"DtlsServerConnection","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsConnectionRef/set(requireCloseNotify:)":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"requireCloseNotify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"