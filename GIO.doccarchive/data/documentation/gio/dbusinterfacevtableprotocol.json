{"metadata":{"title":"DBusInterfaceVTableProtocol","modules":[{"name":"GIO"}],"role":"symbol","symbolKind":"protocol","navigatorTitle":[{"kind":"identifier","text":"DBusInterfaceVTableProtocol"}],"roleHeading":"Protocol","externalID":"s:3GIO27DBusInterfaceVTableProtocolP","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DBusInterfaceVTableProtocol"}]},"topicSections":[{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol\/getProperty","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol\/methodCall","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol\/setProperty"],"anchor":"Instance-Properties"}],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP"]},{"title":"Conforming Types","kind":"relationships","type":"conformingTypes","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"sections":[],"variants":[{"paths":["\/documentation\/gio\/dbusinterfacevtableprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Virtual table for handling properties and method calls for a D-Bus","type":"text"},{"type":"text","text":" "},{"text":"interface.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DBusInterfaceVTableProtocol"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4GLib14PointerWrapperP","kind":"typeIdentifier","text":"PointerWrapper"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since 2.38, if you want to handle getting\/setting D-Bus properties"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, give "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" as your "},{"code":"get_property()","type":"codeVoice"},{"type":"text","text":" or "},{"code":"set_property()","type":"codeVoice"},{"type":"text","text":" "},{"text":"function. The D-Bus call will be directed to your ","type":"text"},{"type":"codeVoice","code":"method_call"},{"type":"text","text":" function,"},{"type":"text","text":" "},{"text":"with the provided ","type":"text"},{"code":"interface_name","type":"codeVoice"},{"text":" set to “org.freedesktop.DBus.Properties”.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Ownership of the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation"},{"type":"text","text":" object passed to the"},{"type":"text","text":" "},{"code":"method_call()","type":"codeVoice"},{"text":" function is transferred to your handler; you must","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call one of the methods of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","isActive":true},{"text":" to return a reply","type":"text"},{"text":" ","type":"text"},{"text":"(possibly empty), or an error. These functions also take ownership","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the passed-in invocation object, so unless the invocation"},{"text":" ","type":"text"},{"type":"text","text":"object has otherwise been referenced, it will be then be freed."},{"text":" ","type":"text"},{"type":"text","text":"Calling one of these functions may be done within your"},{"type":"text","text":" "},{"code":"method_call()","type":"codeVoice"},{"type":"text","text":" implementation but it also can be done at a later"},{"text":" ","type":"text"},{"type":"text","text":"point to handle the method asynchronously."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The usual checks on the validity of the calls is performed. For","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"Get"},{"type":"text","text":" calls, an error is automatically returned if the property does"},{"type":"text","text":" "},{"type":"text","text":"not exist or the permissions do not allow access. The same checks are"},{"text":" ","type":"text"},{"text":"performed for ","type":"text"},{"type":"codeVoice","code":"Set"},{"type":"text","text":" calls, and the provided value is also checked for"},{"text":" ","type":"text"},{"text":"being the correct type.","type":"text"}]},{"inlineContent":[{"type":"text","text":"For both "},{"type":"codeVoice","code":"Get"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Set"},{"type":"text","text":" calls, the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"passed to the ","type":"text"},{"code":"method_call","type":"codeVoice"},{"text":" handler can be queried with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_dbus_method_invocation_get_property_info()"},{"type":"text","text":" to get a pointer"},{"text":" ","type":"text"},{"type":"text","text":"to the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusPropertyInfo","isActive":true},{"text":" of the property.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have readable properties specified in your interface info,"},{"type":"text","text":" "},{"type":"text","text":"you must ensure that you either provide a non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" "},{"type":"codeVoice","code":"get_property``()"},{"type":"text","text":" "},{"type":"text","text":"function or provide implementations of both the "},{"type":"codeVoice","code":"Get"},{"text":" and ","type":"text"},{"code":"GetAll","type":"codeVoice"},{"type":"text","text":" "},{"text":"methods on org.freedesktop.DBus.Properties interface in your ","type":"text"},{"type":"codeVoice","code":"method_call"},{"text":" ","type":"text"},{"text":"function. Note that the required return type of the ","type":"text"},{"type":"codeVoice","code":"Get"},{"text":" call is","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"(v)"},{"text":", not the type of the property. ","type":"text"},{"code":"GetAll","type":"codeVoice"},{"type":"text","text":" expects a return value"},{"text":" ","type":"text"},{"type":"text","text":"of type "},{"type":"codeVoice","code":"a{sv}"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have writable properties specified in your interface info,"},{"type":"text","text":" "},{"type":"text","text":"you must ensure that you either provide a non-"},{"code":"nil","type":"codeVoice"},{"text":" ","type":"text"},{"code":"set_property``()","type":"codeVoice"},{"type":"text","text":" "},{"text":"function or provide an implementation of the ","type":"text"},{"code":"Set","type":"codeVoice"},{"type":"text","text":" call. If implementing"},{"type":"text","text":" "},{"type":"text","text":"the call, you must return the value of type "},{"code":"G_VARIANT_TYPE_UNIT","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol","isActive":true,"type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GDBusInterfaceVTable"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Alternatively, use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef"},{"text":" as a lighweight, ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference if you already have an instance you just want to use.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/DBusInterfaceVTableProtocol/methodCall":{"url":"\/documentation\/gio\/dbusinterfacevtableprotocol\/methodcall","abstract":[{"type":"text","text":"Function for handling incoming method calls."}],"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"methodCall"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GDBusInterfaceMethodCallFunc","text":"GDBusInterfaceMethodCallFunc","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol\/methodCall","kind":"symbol","title":"methodCall"},"doc://GIO/4GLib14PointerWrapperP":{"title":"GLib.PointerWrapper","type":"unresolvable","identifier":"doc:\/\/GIO\/4GLib14PointerWrapperP"},"doc://GIO/documentation/GIO/DBusMethodInvocation":{"url":"\/documentation\/gio\/dbusmethodinvocation","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"DBusMethodInvocation","kind":"identifier"}],"title":"DBusMethodInvocation","abstract":[{"type":"text","text":"Instances of the "},{"code":"GDBusMethodInvocation","type":"codeVoice"},{"text":" class are used when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handling D-Bus method calls. It provides a way to asynchronously"},{"text":" ","type":"text"},{"type":"text","text":"return results and errors."}],"type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","navigatorTitle":[{"kind":"identifier","text":"DBusMethodInvocation"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusPropertyInfo":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusPropertyInfo","title":"DBusPropertyInfo","url":"\/documentation\/gio\/dbuspropertyinfo","abstract":[{"type":"text","text":"Information about a D-Bus property on a D-Bus interface."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusPropertyInfo","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"DBusPropertyInfo","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/DBusInterfaceVTableProtocol/setProperty":{"type":"topic","title":"setProperty","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"setProperty"},{"text":": ","kind":"text"},{"text":"GDBusInterfaceSetPropertyFunc","preciseIdentifier":"c:@T@GDBusInterfaceSetPropertyFunc","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"url":"\/documentation\/gio\/dbusinterfacevtableprotocol\/setproperty","abstract":[{"text":"Function for setting a property.","type":"text"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol\/setProperty","kind":"symbol"},"doc://GIO/documentation/GIO/DBusInterfaceVTableProtocol":{"abstract":[{"type":"text","text":"Virtual table for handling properties and method calls for a D-Bus"},{"text":" ","type":"text"},{"text":"interface.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol","url":"\/documentation\/gio\/dbusinterfacevta