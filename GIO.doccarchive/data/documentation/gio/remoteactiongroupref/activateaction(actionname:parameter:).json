{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/remoteactiongroupref\/activateaction(actionname:parameter:)"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"activateAction"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"actionName"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"text":"parameter","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If the action is expecting a parameter, then the correct type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parameter must be given as "},{"type":"codeVoice","code":"parameter"},{"text":".  If the action is expecting no","type":"text"},{"text":" ","type":"text"},{"text":"parameters then ","type":"text"},{"type":"codeVoice","code":"parameter"},{"text":" must be ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":".  See","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.ActionGroup.get_action_parameter_type","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"text":"If the [type","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","type":"reference"},{"text":"] implementation supports asynchronous remote","type":"text"},{"type":"text","text":" "},{"type":"text","text":"activation over D-Bus, this call may return before the relevant"},{"text":" ","type":"text"},{"text":"D-Bus traffic has been sent, or any replies have been received. In","type":"text"},{"type":"text","text":" "},{"type":"text","text":"order to block on such asynchronous activation calls,"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"text":"] should be called prior to the code, which","type":"text"},{"type":"text","text":" "},{"type":"text","text":"depends on the result of the action activation. Without flushing"},{"type":"text","text":" "},{"text":"the D-Bus connection, there is no guarantee that the action would","type":"text"},{"text":" ","type":"text"},{"text":"have been activated.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following code which runs in a remote app instance, shows an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example of a ‘quit’ action being activated on the primary app"},{"type":"text","text":" "},{"text":"instance over D-Bus. Here [method","type":"text"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"type":"text","text":"] is called"},{"text":" ","type":"text"},{"type":"text","text":"before "},{"code":"exit()","type":"codeVoice"},{"type":"text","text":". Without "},{"type":"codeVoice","code":"g_dbus_connection_flush()"},{"text":", the ‘quit’ action","type":"text"},{"type":"text","text":" "},{"text":"may fail to be activated on the primary instance.","type":"text"}],"type":"paragraph"},{"code":["\/\/ call ‘quit’ action on primary instance","g_action_group_activate_action (G_ACTION_GROUP (app), \"quit\", NULL);","","\/\/ make sure the action is activated now","g_dbus_connection_flush (…);","","g_debug (\"Application has been terminated. Exiting.\");","","exit (0);"],"syntax":"c","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/RemoteActionGroupRef