xt":" "},{"type":"text","text":"within the range may fail."}]},{"inlineContent":[{"type":"text","text":"The return value (if non-"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":") should be freed with"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"type":"text","text":"] when it is no longer required."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/RemoteActionGroupRef","doc:\/\/GIO\/documentation\/GIO\/RemoteActionGroupRef\/ActionGroupProtocol-Implementations"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/RemoteActionGroupRef\/getActionStateHint(actionName:)"},"abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of the"},{"type":"text","text":" "},{"text":"named action within ","type":"text"},{"type":"codeVoice","code":"actionGroup"},{"text":".","type":"text"}],"metadata":{"role":"symbol","externalID":"s:3GIO19ActionGroupProtocolPAAE03getB9StateHint10actionName4GLib10VariantRefVSgSPys4Int8VGSg_tF::SYNTHESIZED::s:3GIO20RemoteActionGroupRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getActionStateHint","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"actionName"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"title":"getActionStateHint(actionName:)","modules":[{"name":"GIO"}],"extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"method"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/remoteacti