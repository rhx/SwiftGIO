eciseIdentifier":"s:Si","text":"Int"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"connection"},{"type":"text","text":" is not a message bus connection, "},{"code":"sender","type":"codeVoice"},{"text":" must be","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"sender","type":"codeVoice"},{"text":" is a well-known name note that ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" is invoked with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the unique name for the owner of "},{"type":"codeVoice","code":"sender"},{"text":", not the well-known name","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as one would expect. This is because the message bus rewrites the"},{"type":"text","text":" "},{"text":"name. As such, to avoid certain race conditions, users should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tracking the name owner of the well-known name and use that when"},{"type":"text","text":" "},{"type":"text","text":"processing the received signal."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If one of "},{"type":"codeVoice","code":"matchArg0Namespace"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"matchArg0Path","type":"codeVoice"},{"text":" are given, ","type":"text"},{"type":"codeVoice","code":"arg0"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"interpreted as part of a namespace or path.  The first argument"},{"type":"text","text":" "},{"type":"text","text":"of a signal is matched against that part as specified by D-Bus."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"userDataFreeFunc"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", it will be called (in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"thread-default main context of the thread you are calling this"},{"text":" ","type":"text"},{"text":"method from) at some point after ","type":"text"},{"type":"codeVoice","code":"userData"},{"text":" is no longer","type":"text"},{"type":"text","text":" "},{"type":"text","text":"needed. (It is not guaranteed to be called synchronously when the"},{"text":" ","type":"text"},{"type":"text","text":"signal is unsubscribed from, and may be called after "},{"type":"codeVoice","code":"connection"},{"text":" ","type":"text"},{"text":"has been destroyed.)","type":"text"}]},{"inlineContent":[{"text":"As ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" is potentially invoked in a different thread from where it’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"emitted, it’s possible for this to happen after"},{"text":" ","type":"text"},{"code":"g_dbus_connection_signal_unsubscribe()","type":"codeVoice"},{"text":" has been called in another thread.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Due to this, "},{"type":"codeVoice","code":"userData"},{"text":" should have a strong reference which is freed with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"userDataFreeFunc"},{"text":", rather than pointing to data whose lifecycle is tied","type":"text"},{"text":" ","type":"text"},{"text":"to the signal subscription. For example, if a [Object](\/\/documentation\/gobject\/object is used to store the","type":"text"},{"type":"text","text":" "},{"text":"subscription ID from ","type":"text"},{"code":"g_dbus_connection_signal_subscribe()","type":"codeVoice"},{"type":"text","text":", a strong reference"},{"type":"text","text":" "},{"text":"to that [Object](\/\/documentation\/gobject\/object must be passed to ","type":"text"},{"code":"userData","type":"codeVoice"},{"type":"text","text":", and "},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" passed to"},{"type":"text","text":" "},{"code":"userDataFreeFunc","type":"codeVoice"},{"type":"text","text":". You are responsible for breaking the resulting"},{"text":" ","type":"text"},{"text":"reference count cycle by explicitly unsubscribing from the signal when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dropping the last external reference to the [Object](\/\/documentation\/gobject\/object. Alternatively, a weak"},{"text":" ","type":"text"},{"text":"reference may be used.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It is guaranteed that if you unsubscribe from a signal using"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_signal_unsubscribe()"},{"type":"text","text":" from the same thread which made the"},{"text":" ","type":"text"},{"type":"text","text":"corresponding "},{"type":"codeVoice","code":"g_dbus_connection_signal_subscribe()"},{"text":" call, ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will not"},{"text":" ","type":"text"},{"text":"be invoked after ","type":"text"},{"code":"g_dbus_connection_signal_unsubscribe()","type":"codeVoice"},{"type":"text","text":" returns."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The returned subscription identifier is an opaque value which is guaranteed"},{"type":"text","text":" "},{"type":"text","text":"to never be zero."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function can never fail."}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef\/DBusConnectionProtocol-Implementations"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Subscribes to signals on "