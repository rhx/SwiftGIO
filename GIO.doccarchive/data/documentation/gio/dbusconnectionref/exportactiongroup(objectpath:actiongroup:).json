},{"text":"If this constraint is violated, the export will fail and 0 will be","type":"text"},{"text":" ","type":"text"},{"text":"returned (with ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" set accordingly)."}],"type":"paragraph"},{"inlineContent":[{"text":"You can unexport the action group using","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.DBusConnection.unexport_action_group","type":"codeVoice"},{"type":"text","text":"] with the return value of"},{"text":" ","type":"text"},{"type":"text","text":"this function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The thread default main context is taken at the time of this call."},{"text":" ","type":"text"},{"type":"text","text":"All incoming action activations and state change requests are"},{"text":" ","type":"text"},{"type":"text","text":"reported from this context.  Any changes on the action group that"},{"text":" ","type":"text"},{"type":"text","text":"cause it to emit signals must also come from this same context."},{"type":"text","text":" "},{"text":"Since incoming action activations and state change requests are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"rather likely to cause changes on the action group, this effectively"},{"type":"text","text":" "},{"text":"limits a given action group to being exported from only one main","type":"text"},{"type":"text","text":" "},{"type":"text","text":"context."}]}]}],"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"exportActionGroup"},{"text":"<","kind":"text"},{"text":"ActionGroupT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"objectPath","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeI