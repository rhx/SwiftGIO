FreeFunc"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusInterfaceInfoT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO25DBusInterfaceInfoProtocolP","text":"DBusInterfaceInfoProtocol","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceInfoProtocol"},{"text":", ","kind":"text"},{"text":"DBusInterfaceVTableT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"DBusInterfaceVTableProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO27DBusInterfaceVTableProtocolP"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"Calls to functions in ","type":"text"},{"type":"codeVoice","code":"vtable"},{"type":"text","text":" (and "},{"code":"userDataFreeFunc","type":"codeVoice"},{"type":"text","text":") will happen"},{"type":"text","text":" "},{"type":"text","text":"in the thread-default main context"},{"text":" ","type":"text"},{"type":"text","text":"(see [method"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"type":"text","text":"])"},{"text":" ","type":"text"},{"type":"text","text":"of the thread you are calling this method from."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that all [Variant](\/\/documentation\/glib\/variant values passed to functions in ","type":"text"},{"type":"codeVoice","code":"vtable"},{"type":"text","text":" will match"},{"text":" ","type":"text"},{"type":"text","text":"the signature given in "},{"type":"codeVoice","code":"interfaceInfo"},{"type":"text","text":" - if a remote caller passes"},{"type":"text","text":" "},{"type":"text","text":"incorrect values, the "},{"code":"org.freedesktop.DBus.Error.InvalidArgs","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"is returned to the remote caller."}],"type":"paragraph"},{"inlineContent":[{"text":"Additionally, if the remote caller attempts to invoke methods or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"access properties not mentioned in "},{"code":"interfaceInfo","type":"codeVoice"},{"type":"text","text":" the"},{"type":"text","text":" "},{"code":"org.freedesktop.DBus.Error.UnknownMethod","type":"codeVoice"},{"text":" resp.","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"org.freedesktop.DBus.Error.InvalidArgs"},{"type":"text","text":" errors"},{"type":"text","text":" "},{"text":"are returned to the caller.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is considered a programming error if the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceGetPropertyFunc","type":"reference","isActive":true},{"text":" function in ","type":"text"},{"code":"vtable","type":"codeVoice"},{"text":" returns a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[Variant](\/\/documentation\/glib\/variant of incorrect type."}]},{"type":"paragraph","inlineContent":[{"text":"If an existing callback is already registered at ","type":"text"},{"type":"codeVoice","code":"objectPath"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"interface_name"},{"type":"text","text":", then "},{"type":"codeVoice","code":"error"},{"text":" is set to ","type":"text"},{"code":"exists","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"GDBus automatically implements the standard D-Bus interfaces","type":"text"},{"type":"text","text":" "},{"text":"org.freedeskt