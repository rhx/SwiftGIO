IO\/menuExporterMaxSectionSize","isActive":true},{"type":"text","text":" items is not supported and results in"},{"type":"text","text":" "},{"type":"text","text":"undefined behavior."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can unexport the menu model using"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_dbus_connection_unexport_menu_model()"},{"text":" with the return value of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GIO/documentation/GIO/DBusConnectionRef":{"role":"symbol","url":"\/documentation\/gio\/dbusconnectionref","abstract":[{"text":"The ","type":"text"},{"code":"GDBusConnection","type":"codeVoice"},{"text":" type is used for D-Bus connections to remote","type":"text"},{"type":"text","text":" "},{"type":"text","text":"peers such as a message buses."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"DBusConnectionRef","kind":"identifier"}],"title":"DBusConnectionRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef","navigatorTitle":[{"kind":"identifier","text":"DBusConnectionRef"}],"type":"topic"},"doc://GIO/documentation/GIO/menuExporterMaxSectionSize":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuExporterMaxSectionSize","type":"topic","url":"\/documentation\/gio\/menuexportermaxsectionsize","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"menuExporterMaxSectionSize"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"abstract":[{"type":"text","text":"The maximum number of entries in a menu section supported by"},{"type":"text","text":" "},{"code":"g_dbus_connection_export_menu_model()","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","title":"menuExporterMaxSectionSize","role":"symbol"},"doc://GIO/documentation/GIO/DBusConnectionRef/exportMenuModel(objectPath:menu:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef\/exportMenuModel(objectPath:menu:)","title":"exportMenuModel(objectPath:menu:)","url":"\/documentation\/gio\/dbusconnectionref\/exportmenumodel(objectpath:menu:)","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"exportMenuModel"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"MenuModelT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"objectPath"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"menu"},{"text":": ","kind":"text"},{"text":"MenuModelT","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"type":"topic","abstract":[{"text":"Exports ","type":"text"},{"type":"codeVoice","code":"menu"},{"type":"text","text":" on "},{"type":"codeVoice","code":"connection"},{"type":"text","text":" at "},{"type":"codeVoice","code":"objectPath"},{"text":".","type":"text"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusConnectionRef/DBusConnectionProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef\/DBusConnectionProtocol-Implementations","title":"DBusConnectionProtocol Implementations","type":"topic","kind":"article","role":"collectionGroup","url":"\/documentation\/gio\/dbusconnectionref\/dbusconnectionprotocol-implementations","abstract":[]},"doc://GIO/documentation/GIO/MenuModelProtocol":{"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/menumodelprotocol","navigatorTitle":[{"text":"MenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]}}}