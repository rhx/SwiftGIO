{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusconnectionref\/initasync(iopriority:cancellable:callback:userdata:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef\/initAsync(ioPriority:cancellable:callback:userData:)"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"initAsync","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil, "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"text":" ","type":"text"},{"code":"g_async_initable_new_async()","type":"codeVoice"},{"type":"text","text":" should typically be used instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the initialization is finished, "},{"code":"callback","type":"codeVoice"},{"text":" will be called. You can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then call "},{"type":"codeVoice","code":"g_async_initable_init_finish()"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"text":"initialization.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"code":"nil","type":"codeVoice"},{"text":", then initialization can be cancelled by triggering the cancellable","type":"text"},{"type":"text","text":" "},{"text":"object from another thread. If the operation was cancelled, the error","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the object doesn’t support cancellable initialization, the error"},{"text":" ","type":"text"},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}]},{"type":"paragraph","inlineContent":[{"text":"As with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":", if the object is not initialized, or initialization"},{"text":" ","type":"text"},{"type":"text","text":"returns with an error, then all operations on the object except"},{"text":" ","type":"text"},{"code":"g_object_ref()","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" are considered to be invalid, and"},{"text":" ","type":"text"},{"text":"have undefined behaviour. They will often fail with ","type":"text"},{"type":"codeVoice","code":"g_critical()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_warning()"},{"text":", but this must not be relied on.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable"},{"type":"text","text":" can"},{"text":" ","type":"text"},{"text":"be initialized multiple times; for more information, see ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"If a class explicitly supports being initialized multiple times,","type":"text"},{"text":" ","type":"text"},{"text":"implementation requires yielding all subsequent calls to ","type":"text"},{"code":"init_async()","type":"codeVoice"},{"type":"text","text":" on the"},{"type":"text","text":" "},{"type":"text","text":"results of the first call."}]},{"inlineContent":[{"type":"text","text":"For classes that also support the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":" interface, the default"},{"text":" ","type":"text"},{"text":"implementation of this method will run the ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" function"},{"text":" ","type":"text"},{"text":"in a thread, so if you want to support asynchronous initialization via","type":"text"},{"type":"text","text":" "},{"text":"threads, just implement the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true},{"type":"text","text":" interface without overriding"},{"type":"text","text":" "},{"type":"text","text":"any interface methods."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"Starts asynchronous initialization of the object implementing the","type":"text"},{"text":" ","type":"text"},{"text":"interface. This must be done before any real use of the object after","type":"t