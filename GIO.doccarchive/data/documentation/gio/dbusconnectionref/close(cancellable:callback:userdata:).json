nil)"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Once the connection is closed, operations such as sending a message"},{"type":"text","text":" "},{"text":"will return with the error ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":". Closing a connection"},{"type":"text","text":" "},{"type":"text","text":"will not automatically flush the connection so queued messages may"},{"type":"text","text":" "},{"text":"be lost. Use ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_flush()"},{"text":" if you need such guarantees.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"connection","type":"codeVoice"},{"text":" is already closed, this method fails with","type":"text"},{"text":" ","type":"text"},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"connection"},{"type":"text","text":" has been closed, the [DBusConnection](\/\/documentation\/gio\/dbusconnection\/onclosed(flags:handler:)"},{"text":" ","type":"text"},{"type":"text","text":"signal is emitted in the thread-default main context"},{"text":" ","type":"text"},{"text":"(see [method","type":"text"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"])","type":"text"},{"type":"text","text":" "},{"text":"of the thread that ","type":"text"},{"type":"codeVoice","code":"connection"},{"type":"text","text":" was constructed in."}]},{"inlineContent":[{"text":"This is an asynchronous method. When the operation is finished,","type":"text"},{"type":"text","text":" "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be invoked in the thread-default main context"},{"type":"text","text":" "},{"text":"(see [method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"text":"])","type":"text"},{"text":" ","type":"text"},{"text":"of the thread you are calling this method from. You can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then call "},{"code":"g_dbus_connection_close_finish()","type":"codeVoice"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"text":"operation. See ","type":"text"},{"code":"g_dbus_connection_close_sync()","type":"codeVoice"},{"text":" for the synchronous","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"version."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef\/DBusConnectionProtocol-Implementations"]]},"abstract":[{"text":"Closes ","type":"text"},{"code":"connection","type":"codeVoice"},{"type":"text","text":". Note that this never causes the process to"},{"type":"text","text":" "},{"type":"text","text":"exit (this might only happen if the other end of a shared message"},{"type":"text","text":" "},{"text":"bus connection disconnects, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection"},{"type":"text","text":")."}],"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionRef\/close(cancellable:callback:userData:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusconnectionref\/close(cancellable:callback:userdata:)"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://GIO/documentation/GIO/DBusConnection":{"type":"topic","navigatorTitle":[{"text":"DBusConnection","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection","url":"\/documentation\/gio\/dbusconnection","title":"DBusConnection","fragments":[{"text":"