{"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseProtocol\/verify(chain:purpose:identity:interaction:flags:cancellable:)-10aiq","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"verify","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"TLSCertificateT"},{"kind":"text","text":">("},{"text":"chain","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"purpose"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"identity"},{"text":": ","kind":"text"},{"text":"SocketConnectableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO20SocketConnectableRefV"},{"text":"? = nil, ","kind":"text"},{"text":"interaction","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSInteractionRefV","text":"TLSInteractionRef"},{"text":"? = nil, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"TLSDatabaseVerifyFlags","preciseIdentifier":"s:3GIO22TLSDatabaseVerifyFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseVerifyFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier","text":"TLSCertificateFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol","text":"TLSCertificateProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chain"},{"type":"text","text":" is a chain of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"text":" objects each pointing to the next","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate in the chain by its "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"text":" property.","type":"text"}]},{"inlineContent":[{"code":"purpose","type":"codeVoice"},{"text":" describes the purpose (or usage) for which the certificate","type":"text"},{"text":" ","type":"text"},{"text":"is being used. Typically ","type":"text"},{"type":"codeVoice","code":"purpose"},{"type":"text","text":" will be set to "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/tlsDatabasePurposeAuthenticateServer","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"which means that the certificate is being used to authenticate a server"},{"type":"text","text":" "},{"type":"text","text":"(and we are acting as the client)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"identity","type":"codeVoice"},{"type":"text","text":" is used to ensure the server certificate is valid for"},{"text":" ","type":"text"},{"text":"the expected peer identity. If the identity does not match the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate, "},{"type":"codeVoice","code":"badIdentity"},{"type":"text","text":" will be set in the"},{"text":" ","type":"text"},{"text":"return value. If ","type":"text"},{"type":"codeVoice","code":"identity"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", that bit will never be set in"},{"text":" ","type":"text"},{"text":"the return value. The peer identity may also be used to check for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"pinned certificates (trust exceptions) in the database. These may"},{"text":" ","type":"text"},{"type":"text","text":"override the normal verification process on a host-by-host basis."}]},{"inlineContent":[{"type":"text","text":"Currently there are no "},{"type":"codeVoice","code":"flags"},{"text":", and ","type":"text"},{"code":"none","type":"codeVoice"},{"text":" should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is found to be valid, then the return value will be 0. If"},{"type":"text","text":" "},{"code":"chain","type":"codeVoice"},{"text":" is found to be invalid, then the return value will indicate at","type":"text"},{"type":"text","text":" "},{"text":"least one problem found. If the function is unable to determine","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether "},{"type":"codeVoice","code":"chain"},{"text":" is valid (for example, because ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"triggered before it completes) then the return value will be"},{"type":"text","text":" "},{"type":"codeVoice","code":"genericError"},{"type":"text","text":" and "},{"code":"error","type":"codeVoice"},{"text":" will be set accordingly.","type":"text"},{"text":" ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" is not set when ","type":"text"},{"type":"codeVoice","code":"chain"},{"text":" is successfully analyzed but found to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be invalid."}]},{"type":"paragraph","inlineContent":[{"text":"GLib guarantees that if certificate verification fails, at least one","type":"text"},{"type":"text","text":" "},{"text":"error will be set in the return value, but it does not guarantee","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that all possible errors will be set. Accordingly, you may not safely"},{"type":"text","text":" "},{"type":"text","text":"decide to ignore any particular type of error. For example, it would"},{"type":"text","text":" "},{"type":"text","text":"be incorrect to mask "},{"type":"codeVoice","code":"expired"},{"text":" if you want to allow","type":"text"},{"type":"text","text":" "},{"text":"expired certificates, because this could potentially be the only","type":"text"},{"type":"text","text":" "},{"text":"error flag set even if other problems exist with the certificate.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Prior to GLib 2.48, GLib’s default TLS backend modified "},{"type":"codeVoice","code":"chain"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"represent the certification path built by ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","type":"reference","isActive":true},{"text":" during","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate verification by adjusting the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true},{"type":"text","text":" "},{"text":"property of each certificate in ","type":"text"},{"code":"chain","type":"codeVoice"},{"type":"text","text":". Since GLib 2.48, this no"},{"type":"text","text":" "},{"text":"longer occurs, so you cannot rely on ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"type":"text","text":"represent the actual certification path used during certificate"},{"type":"text","text":" "},{"type":"text","text":"verification."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Because TLS session context is not used, ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","type":"reference"},{"type":"text","text":" may not"},{"text":" ","type":"text"},{"text":"perform as many checks on the certificates as ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"text":" would.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"For example, certificate constraints may not be honored, and"},{"text":" ","type":"text"},{"type":"text","text":"revocation checks may not be performed. The best way to verify TLS"},{"text":" ","type":"text"},{"text":"certificates used by a TLS connection is to let ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"handle the verification.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The TLS backend may attempt to look up and add missing certificates"},{"text":" ","type":"text"},{"type":"text","text":"to the chain. This may involve HTTP requests to download missing"},{"type":"text","text":" "},{"text":"certificates.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This function can block. Use ","type":"text"},{"code":"g_tls_database_verify_chain_async()","type":"codeVoice"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"text":"perform the verification operation asynchronously.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseProtocol"]]},"abstract":[{"text":"Determines the validity of a certificate chain, outside the context","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of a TLS session."}],"metadata":{"role":"symbol","extendedModule":"GIO","roleHeading":"Instance Method","title":"verify(chain:purpose:identity:interaction:flags:cancellable:)","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"verify","kind":"identifier"},{"kind":"text","text":"<"},{"text":"TLSCertificateT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"chain"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"TLSCertificateT"},{"kind":"text","text":", "},{"kind":"externalParam","text":"purpose"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"identity"},{"text":": ","kind":"text"},{"text":"SocketConnectableRef","preciseIdentifier":"s:3GIO20SocketConnectableRefV","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"interaction","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSInteractionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSInteractionRefV"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"TLSDatabaseVerifyFlags","preciseIdentifier":"s:3GIO22TLSDatabaseVerifyFlagsV"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14Cancellable