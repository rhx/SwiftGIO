type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsdatabaseprotocol\/lookupcertificateissuer(certificate:interaction:flags:cancellable:)-43ssv"]}],"abstract":[{"text":"Look up the issuer of ","type":"text"},{"type":"codeVoice","code":"certificate"},{"type":"text","text":" in the database. The"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true,"type":"reference"},{"type":"text","text":" property of "},{"type":"codeVoice","code":"certificate"},{"type":"text","text":" is not modified, and"},{"type":"text","text":" "},{"type":"text","text":"the two certificates are not hooked into a chain."}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseProtocol\/lookupCertificateIssuer(certificate:interaction:flags:cancellable:)-43ssv"},"references":{"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a server-side TLS connection.","type":"text"}]},"https://datatracker.ietf.org/doc/html/rfc4158":{"title":"RFC 4158","type":"link","titleInlineContent":[{"text":"RFC 4158","type":"text"}],