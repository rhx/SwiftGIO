xt":"<"},{"kind":"genericParameter","text":"CancellableT"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"TLSCertificateT"},{"kind":"text","text":", "},{"text":"TLSInteractionT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"certificate","kind":"externalParam"},{"kind":"text","text":": "},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"interaction","kind":"externalParam"},{"kind":"text","text":": "},{"text":"TLSInteractionT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@EA@GTlsDatabaseLookupFlags","kind":"typeIdentifier","text":"GTlsDatabaseLookupFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","kind":"typeIdentifier"},{"text":"! ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19CancellableProtocolP"},{"kind":"text","text":", "},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"TLSCertificateProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"TLSInteractionT"},{"kind":"text","text":" : "},{"text":"TLSInteractionProtocol","preciseIdentifier":"s:3GIO22TLSInteractionProtocolP","kind":"typeIdentifier","id