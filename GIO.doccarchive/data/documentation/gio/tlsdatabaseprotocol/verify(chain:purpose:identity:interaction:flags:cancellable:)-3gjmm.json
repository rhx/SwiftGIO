ction","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/tlsDatabasePurposeAuthenticateServer":{"role":"symbol","kind":"symbol","title":"tlsDatabasePurposeAuthenticateServer","abstract":[{"text":"The purpose used to verify the server certificate in a TLS connection. This","type":"text"},{"type":"text","text":" "},{"text":"is the most common purpose in use. Used by TLS clients.","type":"text"}],"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"tlsDatabasePurposeAuthenticateServer"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/tlsDatabasePurposeAuthenticateServer","type":"topic","url":"\/documentation\/gio\/tlsdatabasepurposeauthenticateserver"},"doc://GIO/documentation/GIO/TLSDatabaseProtocol":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"TLSDatabaseProtocol","kind":"identifier"}],"navigatorTitle":[{"text":"TLSDatabaseProtocol","kind":"identifier"}],"role":"symbol","abstract":[{"code":"GTlsDatabase","type":"codeVoice"},{"text":" is used to look up certificates and other information","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from a certificate or key store. It is an abstract base class which"},{"type":"text","text":" "},{"text":"TLS library specific subtypes override.","type":"text"}],"title":"TLSDatabaseProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseProtocol","url":"\/docume