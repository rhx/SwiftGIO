ind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"identity","kind":"externalParam"},{"kind":"text","text":": "},{"text":"SocketConnectableT","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"interaction"},{"kind":"text","text":": "},{"text":"TLSInteractionT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO22TLSDatabaseVerifyFlagsV","text":"TLSDatabaseVerifyFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier","text":"TLSCertificateFlags"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"verify","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"SocketConnectableT","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"TLSCertificateT","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"TLSInteractionT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"chain"},{"kind":"text","text":": "},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"purpose","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"identity","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"SocketConnectableT"},{"kind":"text","text":"?, "},{"text":"interaction","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSInteractionT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"TLSDatabaseVerifyFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseVerifyFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO22TLSDatabaseVerifyFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"SocketConnectableT"},{"kind":"text","text":" : "},{"text":"SocketConnectableProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO25SocketConnectableProtocolP"},{"kind":"text","text":", "},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"TLSCertificateProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol"},{"text":", ","kind":"text"},{"text":"TLSInteractionT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO22TLSInteractionProtocolP","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionProtocol","text":"TLSInteractionProtocol"}]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"code":"chain","type":"codeVoice"},{"text":" is a chain of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true},{"type":"text","text":" objects each pointing to the next"},{"text":" ","type":"text"},{"text":"certificate in the chain by its ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"type":"text","text":" property."}]},{"inlineContent":[{"code":"purpose","type":"codeVoice"},{"type":"text","text":" describes the purpose (or usage) for which the certificate"},{"type":"text","text":" "},{"type":"text","text":"is being used. Typically "},{"code":"purpose","type":"codeVoice"},{"type":"text","text":" will be set to "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/tlsDatabasePurposeAuthenticateServer","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"which means that the certificate is being used to authenticate a server"},{"text":" ","type":"text"},{"text":"(and we are acting as the client).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"identity"},{"text":" is used to ensure the server certificate is valid for","type":"text"},{"type":"text","text":" "},{"text":"the expected peer identity. If the identity does not match the","type":"text"},{"type":"text","text":" "},{"text":"certificate, ","type":"text"},{"code":"badIdentity","type":"codeVoice"},{"text":" will be set in the","type":"text"},{"text":" ","type":"text"},{"text":"return value. If ","type":"text"},{"type":"codeVoice","code":"identity"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", that bit will never be set in"},{"text":" ","type":"text"},{"text":"the return value. The peer identity may also be used to check for","type":"text"},{"type":"text","text":" "},{"text":"pinned certificates (trust exceptions) in the database. These may","type":"text"},{"type":"text","text":" "},{"text":"override the normal verification process on a host-by-host basis.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Currently there are no ","type":"text"},{"code":"flags","type":"codeVoice"},{"type":"text","text":", and "},{"type":"codeVoice","code":"none"},{"type":"text","text":" should be"},{"text":" ","type":"text"},{"text":"used.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"chain"},{"text":" is found to be valid, then the return value will be 0. If","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"chain"},{"type":"text","text":" is found to be invalid, then the return value will indicate at"},{"text":" ","type":"text"},{"type":"text","text":"least one problem found. If the function is unable to determine"},{"type":"text","text":" "},{"type":"text","text":"whether "},{"type":"codeVoice","code":"chain"},{"text":" is valid (for example, because ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"triggered before it completes) then the return value will be"},{"type":"text","text":" "},{"type":"codeVoice","code":"genericError"},{"type":"text","text":" and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" will be set accordingly."},{"type":"text","text":" "},{"code":"error","type":"codeVoice"},{"text":" is not set when ","type":"text"},{"type":"codeVoice","code":"chain"},{"type":"text","text":" is successfully analyzed but found to"},{"text":" ","type":"text"},{"text":"be invalid.","type":"text"}]},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"text":" ","type":"text"},{"text":"error will be set in the return value, but it does not guarantee","type":"text"},{"type":"text","text":" "},{"text":"that all possible errors will be set. Accordingly, you may not safely","type":"text"},{"type":"text","text":" "},{"type":"text","text":"decide to ignore any particular type of error. For example, it would"},{"type":"text","text":" "},{"text":"be incorrect to mask ","type":"text"},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow"},{"type":"text","text":" "},{"type":"text","text":"expired certificates, because this could potentially be the only"},{"type":"text","text":" "},{"type":"text","text":"error flag set even if other problems exist with the certificate."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prior to GLib 2.48, GLib’s default TLS backend modified "},{"type":"codeVoice","code":"chain"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"represent the certification path built by ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","isActive":true},{"text":" during","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate verification by adjusting the "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"property of each certificate in "},{"type":"codeVoice","code":"chain"},{"text":". Since GLib 2.48, this no","type":"text"},{"type":"text","text":" "},{"text":"longer occurs, so you cannot rely on ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"text":"represent the actual certification path used during certificate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"verification."}]},{"inlineContent":[{"text":"Because TLS session context is not used, ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","isActive":true},{"text":" may not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"perform as many checks on the certificates as "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":" would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For example, certificate constraints may not be honored, and"},{"type":"text","text":" "},{"type":"text","text":"revocation checks may not be performed. The best way to verify TLS"},{"type":"text","text":" "},{"type":"text","text":"certificates used by a TLS connection is to let "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"text":" ","type":"text"},{"text":"handle the verification.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The TLS backend may attempt to look up and add missing certificates"},{"type":"text","text":" "},{"text":"to the chain. This may involve HTTP requests to download missing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificates."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function can block. Use "},{"code":"g_tls_database_verify_chain_async()","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"perform the verification operation asynchronously.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO/TLSDatabaseProtocol/verify(chain:purpose:identity:interaction:flags:cancellable:)-3gjmm":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"verify"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParame