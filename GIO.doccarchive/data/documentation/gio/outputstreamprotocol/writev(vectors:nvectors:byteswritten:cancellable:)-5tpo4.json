"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"nVectors"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"code":"vectors","type":"codeVoice"},{"text":" is 0, returns 0 and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"does nothing."}]},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes written to the stream is returned.","type":"text"},{"type":"text","text":" "},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. on a partial I\/O error, or if there is not enough"},{"text":" ","type":"text"},{"type":"text","text":"storage in the stream. All writes block until at least one byte"},{"text":" ","type":"text"},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"text":" ","type":"text"},{"type":"codeVoice","code":"nVectors"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"code":"vectors","type":"codeVoice"},{"type":"text","text":" is 0)."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If an"},{"text":" ","type":"text"},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some implementations of "},{"code":"g_output_stream_writev()","type":"codeVoice"},{"type":"text","text":" may have limitations on the"},{"type":"text","text":" "},{"type":"text","text":"aggregate buffer size, and will return "},{"type":"codeVoice","code":"invalidArgument"},{"text":" if these","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are exceeded. For example, when writing to a local file on UNIX platforms,"},{"type":"text","text":" "},{"type":"text","text":"the aggregate buffer size must not exceed "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" bytes."}]}]}],"metadata":{"symbolKind":"method","extendedModule":"GIO","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"role":"symbol","externalID":"s:3GIO20OutputStreamProtocolPAAE6writev7vectors8nVectors12bytesWritten11cancellableSbSPySo14_GOutputVectorVGSg_SiSpySuGSgAA14CancellableRefVSgtKF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"writev","kind":"identifier"},{"text":"(","kind":"text"},{"text":"vectors","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputVector"},{"kind":"text","text":">!, "},{"text":"nVectors","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gsize","preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"cancellab