"GIO"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/outputstreamprotocol\/writevasync(vectors:nvectors:iopriority:cancellable:callback:userdata:)-9dqqj"]}],"kind":"symbol","abstract":[{"type":"text","text":"Request an asynchronous write of the bytes contained in "},{"code":"nVectors","type":"codeVoice"},{"type":"text","text":" "},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" into"},{"text":" ","type":"text"},{"text":"the stream. When the operation is finished ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" will be called.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You can then call "},{"code":"g_output_stream_writev_finish()","type":"codeVoice"},{"text":" to get the result of the","type":"text"},{"type":"text","text":" "},{"text":"operation.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"writevAsync"},{"kind":"text","text":"("},{"text":"vectors","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"GOutputVector","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"nVectors"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"text":" ","type":"text"},{"text":"and will result in ","type":"text"},{"code":"pending","type":"codeVoice"},{"type":"text","text":" errors."}],"type":"paragraph"},{"inlineContent":[{"text":"On success, the number of bytes written will be passed to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":". It is not an error if this is not the same as the"},{"type":"text","text":" "},{"type":"text","text":"requested size, as it can happen e.g. on a partial I\/O error,"},{"text":" ","type":"text"},{"type":"text","text":"but generally we try to write as many bytes as requested."}],"type":"paragraph"},{"inlineContent":[{"text":"You are guaranteed that this method will never fail with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" — if "},{"type":"codeVoice","code":"stream"},{"type":"text","text":" can’t accept more data, the"},{"type":"text","text":" "},{"type":"text","text":"method will just wait until this changes."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical"},{"type":"text","text":" "},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"text":" ","type":"text"},{"text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads","type":"text"},{"type":"text","text":" "},{"text":"to implement asynchronicity, so they are optional for inheriting","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"classes. However, if you override one you must override all."}]},{"type":"paragraph","inlineContent":[{"text":"For the synchronous, blocking version of this function, see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_output_stream_writev()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Note that no copy of "},{"type":"codeVoice","code":"vectors"},{"text":" will be made, so it must stay valid","type":"text"},{"type":"text","text":" "},{"type":"text","text":"until "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" is called."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol"]]},"references":{"doc://GIO/documentation/GIO/OutputStreamProtocol":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol","role":"symbol","url":"\/documentation\/gio\/outputstreamprotocol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"navigatorTitle":[{"text":"OutputStreamProtocol","kind":"identifier"}],"title":"OutputStreamProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OutputStreamProtocol","kind":"identifier"}],"type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO