"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"During an async request no other sync and async calls are allowed,"},{"type":"text","text":" "},{"type":"text","text":"and will result in "},{"type":"codeVoice","code":"pending"},{"type":"text","text":" errors."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes written will be passed to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"callback"},{"type":"text","text":". It is not an error if this is not the same as the"},{"type":"text","text":" "},{"type":"text","text":"requested size, as it can happen e.g. on a partial I\/O error,"},{"type":"text","text":" "},{"type":"text","text":"but generally we try to write as many bytes as requested."}],"type":"paragraph"},{"inlineContent":[{"text":"You are guaranteed that this method will never fail with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" — if "},{"code":"stream","type":"codeVoice"},{"text":" can’t accept more data, the","type":"text"},{"type":"text","text":" "},{"text":"method will just wait until this changes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical"},{"type":"text","text":" "},{"type":"text","text":"value) will be executed before an outstanding request with lower"},{"type":"text","text":" "},{"text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to implement asynchronicity, so they are optional for inheriting"},{"text":" ","type":"text"},{"type":"text","text":"classes. However, if you override one you must override all."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"type":"text","text":" "},{"code":"g_output_stream_writev()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Note that no copy of ","type":"text"},{"type":"codeVoice","code":"vectors"},{"text":" will be made, so it must stay valid","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"until "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" is called."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Request an asynchronous write of the bytes contained in "},{"code":"nVectors","type":"codeVoice"},{"type":"text","text":" "},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" into"},{"type":"text","text":" "},{"type":"text","text":"the stream. When the operation is finished "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"type":"text","text":"You can then call "},{"type":"codeVoice","code":"g_output_stream_writev_finish()"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"type":"text","text":"operation."}],"sections":[],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/OutputStreamProtocol":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol","role":"symbol","url":"\/documentation\/gio\/outputstreamprotocol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"navigatorTitle":[{"text":"OutputStreamProtocol","kind":"identifier"}],"ti