"kind":"text"},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil)","kind":"text"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"type":"text","text":" "},{"text":"and will result in ","type":"text"},{"type":"codeVoice","code":"pending"},{"type":"text","text":" errors."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"code":"G_MAXSSIZE","type":"codeVoice"},{"text":" will cause a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On success, the number of bytes written will be passed to the"},{"type":"text","text":" "},{"code":"callback","type":"codeVoice"},{"type":"text","text":". It is not an error if this is not the same as the"},{"type":"text","text":" "},{"type":"text","text":"requested size, as it can happen e.g. on a partial I\/O error,"},{"type":"text","text":" "},{"text":"but generally we try to write as many bytes as requested.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You are guaranteed that this method will never fail with"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"text":" - if ","type":"text"},{"code":"stream","type":"codeVoice"},{"type":"text","text":" can’t accept more data, the"},{"text":" ","type":"text"},{"text":"method will just wait until this changes.","type":"text"}]},{"inlineContent":[{"text":"Any outstanding I\/O request with higher priority (lower numerical","type":"text"},{"type":"text","text":" "},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads"},{"type":"text","text":" "},{"type":"text","text":"to implement asynchronicity, so they are optional for inheriting"},{"text":" ","type":"text"},{"text":"classes. However, if you override one you must override all.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"type":"text","text":" "},{"code":"g_output_stream_write()","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Note that no copy of "},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" will be made, so it must stay valid"},{"type":"text","text":" "},{"type":"text","text":"until "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" is called. See "},{"type":"codeVoice","code":"g_output_stream_write_bytes_async()"},{"type":"text","text":" "},{"type":"text","text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to"},{"type":"text","text":" "},{"type":"text","text":"the contents (without copying) for the duration of the call."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/outputstreamprotocol\/writeasync(buffer:count:iopriority:cancellable:callback:userdata:)-5ap3v"]}],"abstract":[{"type":"text","text":"Request an asynchronous write of "},{"type":"codeVoice","code":"count"},{"text":" bytes from ","type":"text"},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" into"},{"type":"text","text":" "},{"type":"text","text":"the stream. When the operation is finished "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"type":"text","text":" "},{"type":"text","text":"You can then call "},{"type":"codeVoice","code":"g_output_stream_write_finish()"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"type":"text","text":"operation."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)-5ap3v"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO/OutputStreamProtocol":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol","role":"symbol","url":"\/documentation\/gio\/outputstreamprotocol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"navigatorTitle":[{"text":"OutputStreamProtocol","kind":"identifier"}],"title":"OutputStreamProtocol","fragme