{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol\/close(cancellable:)-448fy","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/outputstreamprotocol\/close(cancellable:)-448fy"]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol"]]},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"CancellableProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Once the stream is closed, all other operations will return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Closing a stream multiple times will not return an error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers in the"},{"type":"text","text":" "},{"text":"stream.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"text":" ","type":"text"},{"text":"resources are released as early as possible.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"type":"text","text":" "},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"type":"text","text":" "},{"text":"stream for details.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations. Still, it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is important to check and report the error to the user, otherwise"},{"type":"text","text":" "},{"type":"text","text":"there might be a loss of data as all data might not be written."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but there some streams"},{"type":"text","text":" "},{"text":"can use a faster close that doesn’t block to e.g. check errors. On","type":"text"},{"type":"text","text":" "},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"text":"data will reach the target.","type":"text"}],"type":"paragraph"}]}],"metadata":{"symbolKind":"method","role":"symbol","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"roleHeading":"Instance Method","title":"close(cancellable:)","externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbqd__Sg_tKAA011CancellableD0Rd__lF","modules":[{"name":"GIO"}]},"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"references":{"doc://GIO/documentation/GIO/OutputStreamProtocol":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol","role":"symbol","url":"\/documentation\/gio\/outputstreamprotocol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"navigatorTitle":[{"text":"OutputStreamProtocol","kind":"identifier"}],"title":"OutputStreamProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OutputStreamProtocol","kind":"identifier"}],"type":"topic"},"doc://GIO/documentation/GIO/OutputStreamProtocol/close(cancellable:)-448fy":{"title":"close(cancellable:)","kind":"symbol","url":"\/documentation\/gio\/outputstreamprotocol\/close(cancellable:)-448fy","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol\/close(cancellable:)-448fy","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"}}}