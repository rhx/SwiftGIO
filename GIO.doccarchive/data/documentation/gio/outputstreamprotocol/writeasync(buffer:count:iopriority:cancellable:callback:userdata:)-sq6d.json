{"sections":[],"variants":[{"paths":["\/documentation\/gio\/outputstreamprotocol\/writeasync(buffer:count:iopriority:cancellable:callback:userdata:)-sq6d"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"text":"Request an asynchronous write of ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from "},{"code":"buffer","type":"codeVoice"},{"text":" into","type":"text"},{"text":" ","type":"text"},{"text":"the stream. When the operation is finished ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"type":"text","text":" "},{"type":"text","text":"You can then call "},{"type":"codeVoice","code":"g_output_stream_write_finish()"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"type":"text","text":"operation."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamProtocol\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)-sq6d"},"metadata":{"extendedModule":"GIO","externalID":"s:3GIO20OutputStreamProtocolPAAE10writeAsync6buffer5count10ioPriority11cancellable8callback8userDataySvSg_S2iqd__SgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgAKtXCSgAKtAA011CancellableD0Rd__lF","title":"writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"writeAsync"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"CancellableT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"?)"}],"modules":[{"name":"GIO"}],"symbolKind":"method"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"writeAsync","kind":"identifier"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19CancellableProtocolP"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"text":" ","type":"text"},{"text":"and will result in ","type":"text"},{"code":"pending","type":"codeVoice"},{"text":" errors.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"text":" will cause a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written will be passed to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"callback"},{"text":". It is not an error if this is not the same as the","type":"text"},{"type":"text","text":" "},{"text":"requested size, as it can happen e.g. on a partial I\/O error,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but generally we try to write as many bytes as requested."}]},{"type":"paragraph","inlineContent":[{"text":"You are guaranteed that this method will never fail with","type":"text"},{"text":" ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"text":" - if ","type":"text"},{"code":"stream","type":"codeVoice"},{"text":" can’t accept more data, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method will just wait until this changes."}]},{"inlineContent":[{"text":"Any outstanding I\/O request with higher priority (lower numerical","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"value) will be executed before an outstanding request with lower"},{"type":"text","text":" "},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads"},{"type":"text","text":" "},{"text":"to implement asynchronicity, so they are optional for inheriting","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"classes. However, if you override one you must override all."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_output_stream_write()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that no copy of "},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" will be made, so it must stay valid"},{"type":"text","text":" "},{"type":"text","text":"until "},{"code":"callback","type":"codeVoice"},{"text":" is called. See ","type":"text"},{"type":"codeVoice","code":"g_output_stream_write_bytes_async()"},{"text":" ","type":"text"},{"type":"text","text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to"},{"type":"text","text":" "},{"text":"the contents (without copying) for the duration of the call.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documen