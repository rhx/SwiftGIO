{"sections":[],"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketServiceProtocol"]]},"variants":[{"paths":["\/documentation\/gio\/socketserviceprotocol\/onnotifyactive(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyActive","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:3GIO16SocketServiceRefV","kind":"typeIdentifier","text":"SocketServiceRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}],"name":"flags"},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyActive"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"code":"g_object_set_property()","type":"codeVoice"},{"text":" results","type":"text"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::active"},{"type":"text","text":" signal"}]}],"type":"aside","name":"Note"}],"kind":"content"}],"metadata":{"title":"onNotifyActive(flags:handler:)","extendedModule":"GIO","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onNotifyActive","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO16SocketServiceRefV","text":"SocketServiceRef"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"symbolKind":"method","externalID":"s:3GIO21SocketServiceProtocolPAAE14onNotifyActive5flags7handlerSi10GLibObje