{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)"},"kind":"symbol","metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","title":"writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"writeAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"externalID":"s:3GIO20OutputStreamProtocolPAAE10writeAsync6buffer5count10ioPriority11cancellable8callback8userDataySvSg_S2iAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgAKtXCSgAKtF::SYNTHESIZED::s:3GIO21FilterOutputStreamRefV","extendedModule":"GIO"},"abstract":[{"text":"Request an asynchronous write of ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from "},{"type":"codeVoice","code":"buffer"},{"type":"text","text":" into"},{"type":"text","text":" "},{"text":"the stream. When the operation is finished ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" will be called.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You can then call "},{"code":"g_output_stream_write_finish()","type":"codeVoice"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"text":"operation.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/filteroutputstreamref\/writeasync(buffer:count:iopriority:cancellable:callback:userdata:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"writeAsync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"text":" ","type":"text"},{"text":"and will result in ","type":"text"},{"code":"pending","type":"codeVoice"},{"text":" errors.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A value of ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"text":" will cause a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}],"type":"paragraph"},{"inlineContent":[{"text":"On success, the number of bytes written will be passed to the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"callback"},{"type":"text","text":". It is not an error if this is not the same as the"},{"type":"text","text":" "},{"type":"text","text":"requested size, as it can happen e.g. on a partial I\/O error,"},{"text":" ","type":"text"},{"text":"but generally we try to write as many bytes as requested.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You are guaranteed that this method will never fail with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" - if "},{"type":"codeVoice","code":"stream"},{"type":"text","text":" can’t accept more data, the"},{"type":"text","text":" "},{"text":"method will just wait until this changes.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical"},{"text":" ","type":"text"},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads"},{"type":"text","text":" "},{"text":"to implement asynchronicity, so they are optional for inheriting","type":"text"},{"type":"text","text":" "},{"text":"classes. However, if you override one you must override all.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"text":" ","type":"text"},{"code":"g_output_stream_write()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"Note that no copy of ","type":"text"},{"type":"codeVoice","code":"buffer"},{"text":" will be made, so it must stay valid","type":"text"},{"text":" ","type":"text"},{"text":"until ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":" is called. See "},{"type":"codeVoice","code":"g_output_stream_write_bytes_async()"},{"text":" ","type":"text"},{"type":"text","text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to"},{"type":"text","text":" "},{"type":"text","text":"the contents (without copying) for the duration of the call."}],"type":"paragraph"}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documenta