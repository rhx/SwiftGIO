{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Once the stream is closed, all other operations will return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Closing a stream multiple times will not return an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stream."}]},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"text":" ","type":"text"},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"type":"text","text":" "},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stream for details."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"text":" ","type":"text"},{"text":"close will still return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":" for all operations. Still, it"},{"text":" ","type":"text"},{"text":"is important to check and report the error to the user, otherwise","type":"text"},{"type":"text","text":" "},{"type":"text","text":"there might be a loss of data as all data might not be written."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"type":"text","text":"Cancelling a close will still leave the stream closed, but there some streams"},{"text":" ","type":"text"},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors. On"},{"type":"text","text":" "},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"type":"text","text":"data will reach the target."}]}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/gio\/filteroutputstreamref\/close(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef\/close(cancellable:)"},"metadata":{"title":"close(cancellable:)","modules":[{"name":"GIO"}],"externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO21FilterOutputStreamRefV","extendedModule":"GIO","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"roleHeading":"Instance Method","role":"symbol"},"references":{"doc://GIO/documentation/GIO/FilterOutputStreamRef/OutputStreamProtocol-Implementations":{"title":"OutputStreamProtocol Implementations","kind":"article","url":"\/documentation\/gio\/filteroutputstreamref\/outputstreamprotocol-implementations","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef\/OutputStreamProtocol-Implementations","abstract":[],"role":"collectionGroup"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FilterOutputStreamRef/close(cancellable:)":{"title":"close(cancellable:)","type":"topic","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"url":"\/documentation\/gio\/filteroutputstreamref\/close(cancellable:)","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef\/close(cancellable:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]},"doc://GIO/documentation/GIO/FilterOutputStreamRef":{"url":"\/documentation\/gio\/filteroutputstreamref","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FilterOutputStreamRef","kind":"identifier"}],"title":"FilterOutputStreamRef","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterOutputStreamRef","abstract":[{"type":"text","text":"Base class for output stream implementations that perform some"},{"text":" ","type":"text"},{"text":"kind of filtering operation on a base stream. Typical examples","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of filtering operations are character set conversion, compression"},{"text":" ","type":"text"},{"type":"text","text":"and byte order flipping."}],"navigatorTitle":[{"text":"FilterOutputStreamRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}