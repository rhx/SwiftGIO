nd":"identifier","text":"write"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If count is 0, returns 0 and does nothing. A value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" "},{"text":"larger than ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"text":" will cause a ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"type":"text","text":" "},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. on a partial I\/O error, or if there is not enough"},{"type":"text","text":" "},{"text":"storage in the stream. All writes block until at least one byte","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"type":"text","text":" "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is 0)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"text":"partial result will be returned, without an error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/filteroutputstreamref\/write(buffer:count:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FilterOutputStreamRef":{"url":"\/documentation\/gio\/filteroutputstreamref","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FilterOutputStreamRef","kind":"identifier"}],"title":"FilterOutp