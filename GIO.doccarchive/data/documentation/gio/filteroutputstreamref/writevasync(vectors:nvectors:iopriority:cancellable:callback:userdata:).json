{"sections":[],"variants":[{"paths":["\/documentation\/gio\/filteroutputstreamref\/writevasync(vectors:nvectors:iopriority:cancellable:callback:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Request an asynchronous write of the bytes contained in "},{"type":"codeVoice","code":"nVectors"},{"type":"text","text":" "},{"code":"vectors","type":"codeVoice"},{"type":"text","text":" into"},{"text":" ","type":"text"},{"type":"text","text":"the stream. When the operation is finished "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"type":"text","text":" "},{"type":"text","text":"You can then call "},{"code":"g_output_stream_writev_finish()","type":"codeVoice"},{"text":" to get the result of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"writevAsync","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"vectors"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GOutputVector","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"nVectors"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil)"}],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"text":" ","type":"text"},{"text":"and will result in ","type":"text"},{"code":"pending","type":"codeVoice"},{"type":"text","text":" errors."}]},{"inlineContent":[{"text":"On success, the number of bytes written will be passed to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":". It is not an error if this is not the same as the","type":"text"},{"text":" ","type":"text"},{"text":"requested size, as it can happen e.g. on a partial I\/O error,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but generally we try to write as many bytes as requested."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You are guaranteed that this method will never fail with","type":"text"},{"text":" ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"text":" — if ","type":"text"},{"code":"stream","type":"codeVoice"},{"text":" can’t accept more data, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method will just wait until this changes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical"},{"text":" ","type":"text"},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}]},{"inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads"},{"text":" ","type":"text"},{"type":"text","text":"to implement asynchronicity, so they are optional for inheriting"},{"text":" ","type":"text"},{"type":"text","text":"classes. However, if you override one you must override all."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For the synchronous, blocking version of this function, see","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_output_stream_writev()"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Note that no copy of ","type":"text"},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" will be made, so it must stay valid"},{"type":"text","text":" "},{"type":"text","text":"until "},{"code":"callback","type":"codeVoice"},{"text":" is called.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"symbol","symbolKind":"method","externalID":"s:3GIO20OutputStreamProtocolPAAE11writevAsync7vectors8nVectors10ioPriority11cancellable8callback8userDataySPySo14_GOutputVectorVGSg_S2iAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgAZtF::SYNTHESIZED::s:3GIO21FilterOutputStreamRefV","roleHeading":"Instance Method","extendedModule":"GIO","title":"writevAsync(vectors:nVectors:ioPriority:cancellable:callback:userData:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"writevAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"vectors"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputVector"},{"kind":"text","text":">!, "},{"text":"nVectors","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier