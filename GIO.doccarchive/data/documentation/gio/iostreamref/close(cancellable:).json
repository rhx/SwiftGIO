{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/IOStreamProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/iostreamref\/close(cancellable:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Once the stream is closed, all other operations will return","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":". Closing a stream multiple times will not"},{"type":"text","text":" "},{"type":"text","text":"return an error."}]},{"inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers"},{"type":"text","text":" "},{"text":"in the stream.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file"},{"text":" ","type":"text"},{"type":"text","text":"descriptor) open after the stream is closed. See the documentation for"},{"type":"text","text":" "},{"type":"text","text":"the individual stream for details."}],"type":"paragraph"},{"inlineContent":[{"text":"On failure the first error that happened will be reported, but the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"close operation will finish as much as possible. A stream that failed"},{"type":"text","text":" "},{"type":"text","text":"to close will still return "},{"code":"closed","type":"codeVoice"},{"text":" for all operations.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Still, it is important to check and report the error to the user,"},{"text":" ","type":"text"},{"text":"otherwise there might be a loss of data as all data might not be written.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not NULL, then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"text":"Cancelling a close will still leave the stream closed, but some streams","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default implementation of this method just calls close on the"},{"text":" ","type":"text"},{"type":"text","text":"individual input\/output streams."}]}]}],"sections":[],"metadata":{"title":"close(cancellable:)","role":"symbol","extendedModule":"GIO","externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO11IOStreamRefV","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"type":"text","text":" "},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"type":"text","text":" "},{"type":"text","text":"closed."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO/IOStreamRef/close(cancellable:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/close(cancellable:)","title":"close(cancellable:)","abstract":[{"text":"Closes the stream, releasing resources related to it. This will also","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"text":" ","type":"text"},{"type":"text","text":"closed."}],"type":"topic","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"url":"\/documentation\/gio\/iostreamref\/close(cancellable:)"},"doc://GIO/documentation/GIO/IOStreamRef/IOStreamProtocol-Implementations":{"type":"topic","title":"IOStreamProtocol Implementations","url":"\/documentation\/gio\/iostreamref\/iostreamprotocol-implementations","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/IOStreamProtocol-Implementations","kind":"article","role":"collectionGroup"},"doc://GIO/documentation/GIO/IOStreamRef":{"role":"symbol","abstract":[{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"text":" ","type":"text"},{"text":"but they share some common resources and state. For instance, for","type":"text"},{"text":" ","type":"text"},{"text":"seekable streams, both streams may use the same position.","type":"text"}],"url":"\/documentation\/gio\/iostreamref","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStreamRef"}],"title":"IOStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef","navigatorTitle":[{"text":"IOStreamRef","kind":"identifier"}],"type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}