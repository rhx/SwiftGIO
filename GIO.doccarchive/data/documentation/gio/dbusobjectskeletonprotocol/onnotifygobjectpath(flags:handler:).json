{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeletonProtocol"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"text":", ","type":"text"},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyGObjectPath","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeletonRef","text":"DBusObjectSkeletonRef","preciseIdentifier":"s:3GIO21DBusObjectSkeletonRefV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The signal handler to call","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyGObjectPath"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}],"name":"handler"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"text":" ","type":"text"},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::g-object-path","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"name":"Note"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeletonProtocol\/onNotifyGObjectPath(flags:handler:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","extendedModule":"GIO","symbolKind":"method","title":"onNotifyGObjectPath(flags:handler:)","role":"symbol","externalID":"s:3GIO26DBusObjectSkeletonProtocolPAAE19onNotifyGObjectPath5flags7handlerSi04GLibC012ConnectFlagsV_yAA0bcD3RefV_AG09ParamSpecO0VtctF","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyGObjectPath","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"DBusObjectSkeletonRef","preciseIdentifier":"s:3GIO21DBusObjectSkeletonRefV"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","pr