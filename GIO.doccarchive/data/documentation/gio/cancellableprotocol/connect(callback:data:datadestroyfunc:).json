{"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/cancellableprotocol\/connect(callback:data:datadestroyfunc:)"]}],"metadata":{"title":"connect(callback:data:dataDestroyFunc:)","extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"connect","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gclosure.h@T@GCallback","kind":"typeIdentifier","text":"GCallback"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"dataDestroyFunc"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@GDestroyNotify","text":"GDestroyNotify"},{"text":"?) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"role":"symbol","externalID":"s:3GIO19CancellableProtocolPAAE7connect8callback4data0F11DestroyFuncSiyyXCSg_SvSgyAIXCSgtF"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol\/connect(callback:data:dataDestroyFunc:)","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"connect","kind":"identifier"},{"kind":"text","text":"("},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gclosure.h@T@GCallback","text":"GCallback","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"dataDestroyFunc"},{"text":": ","kind":"text"},{"text":"GDestroyNotify","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@GDestroyNotify"},{"kind":"text","text":"? = nil) -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"code":"callback","type":"codeVoice"},{"type":"text","text":" is called exactly once each time "},{"type":"codeVoice","code":"cancellable"},{"text":" is cancelled,","type":"text"},{"type":"text","text":" "},{"text":"either directly at the time of the connect if ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is already"},{"text":" ","type":"text"},{"type":"text","text":"cancelled, or when "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled in some thread."},{"text":" ","type":"text"},{"text":"In case the cancellable is reset via [method","type":"text"},{"type":"codeVoice","code":"Gio.Cancellable.reset"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"then the callback can be called again if the "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled and"},{"type":"text","text":" "},{"type":"text","text":"if it had not been previously cancelled at the time"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.Cancellable.connect"},{"type":"text","text":"] was called (e.g. if the connection actually"},{"type":"text","text":" "},{"text":"took place, returning a non-zero value).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"dataDestroyFunc","type":"codeVoice"},{"type":"text","text":" will be called when the handler is"},{"type":"text","text":" "},{"text":"disconnected, or immediately if the cancellable is already","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cancelled."}]},{"inlineContent":[{"type":"text","text":"See [Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:) for details on how to use this."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Since GLib 2.40, the lock protecting "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not held when"},{"text":" ","type":"text"},{"type":"codeVoice","code":"callback"},{"text":" is invoked. This lifts a restriction in place for","type":"text"},{"text":" ","type":"text"},{"text":"earlier GLib versions which now makes it easier to write cleanup","type":"text"},{"type":"text","text":" "},{"text":"code that unconditionally invokes e.g. [method","type":"text"},{"code":"Gio.Cancellable.cancel","type":"codeVoice"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Note that since 2.82 GLib still holds a lock during the callback but it’s"},{"text":" ","type":"text"},{"type":"text","text":"designed in a way that most of the [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable"},{"text":"] methods can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"called, including [method"},{"code":"Gio.Cancellable.cancel","type":"codeVoice"},{"type":"text","text":"] or"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.Object.unref"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"There are still some methods that will deadlock (by design) when"},{"type":"text","text":" "},{"text":"called from the [signal[Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:)] callbacks:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"[method","type":"text"},{"code":"Gio.Cancellable.connect","type":"codeVoice"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[method"},{"code":"Gio.Cancellable.disconnect","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"[method"},{"code":"Gio.Cancellable.reset","type":"codeVoice"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[method"},{"code":"Gio.Cancellable.make_pollfd","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[method","type":"text"},{"code":"Gio.Cancellable.release_fd","type":"codeVoice"},{"type":"text","text":"]"}]}]}]}]}],"abstract":[{"type":"text","text":"Convenience function to connect to the [Cancellable](\/\/documentation\/gio\/cancellable\/oncancelled(flags:handler:)"},{"type":"text","text":" "},{"type":"text","text":"signal. Also handles the race condition that may happen"},{"text":" ","type":"text"},{"text":"if the cancellable is cancelled right before connecting.","type":"text"}],"references":{"doc://GIO/documentation/GIO/Cancellable":{"navigatorTitle":[{"kind":"identifier","text":"Cancellable"}],"title":"Cancellable","type":"topic","abstract":[{"code":"GCancellable","type":"codeVoice"},{"text":" allows operations to be cancelled.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Cancellable","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable","url":"\/documentation\/gio\/cancellable"},"doc://GIO/documentation/GIO/CancellableProtocol/connect(callback:data:dataDestroyFunc:)":{"role":"symbol","title":"connect(callback:data:dataDestroyFunc:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"connect",