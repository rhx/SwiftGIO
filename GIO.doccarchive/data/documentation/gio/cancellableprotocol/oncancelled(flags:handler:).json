{"sections":[],"abstract":[{"type":"text","text":"Emitted when the operation has been cancelled."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onCancelled"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier","text":"ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" signal is emitted"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Can be used by implementations of cancellable operations. If the"},{"text":" ","type":"text"},{"type":"text","text":"operation is cancelled from another thread, the signal will be"},{"type":"text","text":" "},{"text":"emitted in the thread that cancelled the operation, not the","type":"text"},{"type":"text","text":" "},{"text":"thread that is running the operation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that disconnecting from this signal (or any signal) in a"},{"text":" ","type":"text"},{"type":"text","text":"multi-threaded program is prone to race conditions. For instance"},{"type":"text","text":" "},{"type":"text","text":"it is possible that a signal handler may be invoked even after"},{"text":" ","type":"text"},{"type":"text","text":"a call to "},{"type":"codeVoice","code":"g_signal_handler_disconnect()"},{"type":"text","text":" for that handler has"},{"type":"text","text":" "},{"type":"text","text":"already returned."}]},{"inlineContent":[{"type":"text","text":"There is also a problem when cancellation happens right before"},{"type":"text","text":" "},{"text":"connecting to the signal. If this happens the signal will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unexpectedly not be emitted, and checking before connecting to"},{"type":"text","text":" "},{"type":"text","text":"the signal leaves a race condition where this is still happening."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In order to make it safe and easy to connect handlers there"},{"type":"text","text":" "},{"text":"are two helper functions: ","type":"text"},{"code":"g_cancellable_connect()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_cancellable_disconnect()"},{"type":"text","text":" which protect against problems"},{"text":" ","type":"text"},{"type":"text","text":"like this."}],"type":"paragraph"},{"inlineContent":[{"text":"An example of how to us this:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["    \/\/ Make sure we don't do unnecessary work if already cancelled","    if (g_cancellable_set_error_if_cancelled (cancellable, error))","      return;","","    \/\/ Set up all the data needed to be able to handle cancellation","    \/\/ of the operation","    my_data = my_data_new (...);","","    id = 0;","    if (cancellable)","      id = g_cancellable_connect (cancellable,","    \t\t\t      G_CALLBACK (cancelled_handler)","    \t\t\t      data, NULL);","","    \/\/ cancellable operation here...","","    g_cancellable_disconnect (cancellable, id);","","    \/\/ cancelled_handler is never called after this, it is now safe","    \/\/ to free the data","    my_data_free (my_data);"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Note that the cancelled signal is emitted in the thread that"},{"text":" ","type":"text"},{"text":"the user cancelled from, which may be the main thread. So, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cancellable signal should not do something that can block."}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" signal"}]}]}]}],"variants":[{"paths":["\/documentation\/gio\/cancellableprotocol\/oncancelled(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Instance Method","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onCancelled"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"extendedModule":"GIO","modules":[{"name":"GIO"}],"externalID":"s:3GIO19CancellableProtocolPAAE11onCancelled5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0B3RefVctF","title":"onCancelled(flags:handler:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol\/onCancelled(flags:handler:)","interfaceLanguage":"swift"},"kind":"symbol","references":{"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableProtocol/onCancelled(flags:handler:)":{"abstract":[{"text":"Emitted when the operation has been cancelled.","type":"text"}],"url":"\/documentation\/gio\/cancellableprotocol\/oncancelled(flags:handler:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol\/onCancelled(flags:handler:)","type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onCancelled"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"title":"onCancelled(flags:handler:)"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}