{"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/Action\/init(_:)-1wbca","doc:\/\/GIO\/documentation\/GIO\/Action\/init(_:)-2rwhr","doc:\/\/GIO\/documentation\/GIO\/Action\/init(_:)-4ihrq","doc:\/\/GIO\/documentation\/GIO\/Action\/init(_:)-6b8i4","doc:\/\/GIO\/documentation\/GIO\/Action\/init(_:)-8a056","doc:\/\/GIO\/documentation\/GIO\/Action\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/Action\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/Action\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/Action\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/Action\/init(raw:)-4r6sl","doc:\/\/GIO\/documentation\/GIO\/Action\/init(raw:)-7dqvo","doc:\/\/GIO\/documentation\/GIO\/Action\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/Action\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/Action\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/Action\/init(retainingRaw:)-54re4","doc:\/\/GIO\/documentation\/GIO\/Action\/init(retainingRaw:)-7rbdp"],"generated":true},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/Action\/metatypeReferenceForAction","doc:\/\/GIO\/documentation\/GIO\/Action\/ptr","doc:\/\/GIO\/documentation\/GIO\/Action\/wrapperForAction"],"anchor":"Instance-Properties"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/Action\/metatypeForAction"],"title":"Type Properties","anchor":"Type-Properties","generated":true},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/Action\/ActionProtocol-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"variants":[{"paths":["\/documentation\/gio\/action"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Action","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The main interface to an action is that it can be activated with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.Action.activate"},{"type":"text","text":"]. This results in the ‘activate’ signal being"},{"text":" ","type":"text"},{"type":"text","text":"emitted. An activation has a "},{"type":"codeVoice","code":"GVariant"},{"text":" parameter (which may be","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"NULL"},{"text":"). The correct type for the parameter is determined by a static","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parameter type (which is given at construction time)."}]},{"type":"paragraph","inlineContent":[{"text":"An action may optionally have a state, in which case the state may be","type":"text"},{"type":"text","text":" "},{"text":"set with [method","type":"text"},{"code":"Gio.Action.change_state","type":"codeVoice"},{"text":"]. This call takes a [type[Variant](\/\/documentation\/glib\/variant]. The","type":"text"},{"text":" ","type":"text"},{"text":"correct type for the state is determined by a static state type","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(which is given at construction time)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The state may have a hint associated with it, specifying its valid"},{"type":"text","text":" "},{"type":"text","text":"range."}]},{"inlineContent":[{"code":"GAction","type":"codeVoice"},{"type":"text","text":" is merely the interface to the concept of an action, as"},{"type":"text","text":" "},{"text":"described above.  Various implementations of actions exist, including","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAction"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In all cases, the implementing class is responsible for storing the","type":"text"},{"text":" ","type":"text"},{"text":"name of the action, the parameter type, the enabled state, the optional","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state type and the state and emitting the appropriate signals when these"},{"type":"text","text":" "},{"text":"change. The implementor is responsible for filtering calls to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.Action.activate"},{"type":"text","text":"] and [method"},{"code":"Gio.Action.change_state","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"for type safety and for the state being enabled."}]},{"inlineContent":[{"text":"Probably the only useful thing to do with a ","type":"text"},{"code":"GAction","type":"codeVoice"},{"text":" is to put it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"inside of a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroup","isActive":true,"type":"reference"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true},{"type":"text","text":" type acts as an owner of an underlying "},{"code":"GAction","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionProtocol","type":"reference","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true,"type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GAction","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef"},{"text":" (instead of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GAction"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}],"sections":[],"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Class","symbolKind":"class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Action"}],"externalID":"s:3GIO6ActionC","title":"Action","navigatorTitle":[{"text":"Action","kind":"identifier"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ActionProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Action"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"references":{"doc://GIO/documentation/GIO/ActionMap":{"role":"symbol","title":"ActionMap","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"ActionMap","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionMap","navigatorTitle":[{"kind":"identifier","text":"ActionMap"}],"type":"topic","url":"\/documentation\/gio\/actionmap","abstract":[{"type":"codeVoice","code":"GActionMap"},{"type":"text","text":" is an interface for action contain