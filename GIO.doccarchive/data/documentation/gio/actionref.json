d":true}],"abstract":[{"code":"GAction","type":"codeVoice"},{"type":"text","text":" represents a single named action."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"ActionRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"text":"The main interface to an action is that it can be activated with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.Action.activate","type":"codeVoice"},{"type":"text","text":"]. This results in the ‘activate’ signal being"},{"type":"text","text":" "},{"type":"text","text":"emitted. An activation has a "},{"code":"GVariant","type":"codeVoice"},{"text":" parameter (which may be","type":"text"},{"type":"text","text":" "},{"code":"NULL","type":"codeVoice"},{"text":"). The correct type for the parameter is determined by a static","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameter type (which is given at construction time)."}],"type":"paragraph"},{"inlineContent":[{"text":"An action may optionally have a state, in which case the state may be","type":"text"},{"text":" ","type":"text"},{"text":"set with [method","type":"text"},{"type":"codeVoice","code":"Gio.Action.change_state"},{"text":"]. This call takes a [type[Variant](\/\/documentation\/glib\/variant]. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"correct type for the state is determined by a static state type"},{"text":" ","type":"text"},{"type":"text","text":"(which is given at construction time)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The state may have a hint associated with it, specifying its valid"},{"type":"text","text":" "},{"type":"text","text":"range."}],"type":"paragraph"},{"inlineContent":[{"code":"GAction","type":"codeVoice"},{"type":"text","text":" is merely the interface to the concept of an action, as"},{"text":" ","type":"text"},{"text":"described above.  Various implementations of actions exist, including","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAction","type":"reference"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In all cases, the implementing class is responsible for storing the"},{"text":" ","type":"text"},{"type":"text","text":"name of the action, the parameter type, the enabled state, the optional"},{"text":" ","type":"text"},{"text":"state type and the state and emitting the appropriate signals when these","type":"text"},{"type":"text","text":" "},{"type":"text","text":"change. The implementor is responsible for filtering calls to"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.Action.activate"},{"text":"] and [method","type":"text"},{"type":"codeVoice","code":"Gio.Action.change_state"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"for type safety and for the state being enabled.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Probably the only useful thing to do with a "},{"type":"codeVoice","code":"GAction"},{"text":" is to put it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"inside of a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroup","isActive":true,"type":"reference"},{"text":"].","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GAction","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionProtocol","type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef","type":"reference","isActive":true},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference to an existing "},{"code":"GAction","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef","type":"reference","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"code":"GAction","type":"codeVoice"},{"text":" instance.","type":"text"}]}],"type":"aside"}]}],"references":{"doc://GIO/documentation/GIO/ActionRef/init(constPointer:)":{"kind":"symbol","url":"\/documentation\/gio\/actionref\/init(constpointer:)","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"constPointer","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"T"},{"kind":"text","text":">)"}],"title":"init(constPointer:)","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionRef\/init(constPointer:)","type":"topic","abstract":[{"type":"text","text":"Unsafe typed initialiser."},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"Do not use unless you know the