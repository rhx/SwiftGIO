{"kind":"symbol","metadata":{"externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF","role":"symbol","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"roleHeading":"Instance Method","title":"init_(cancellable:)"},"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/InitableProtocol\/init_(cancellable:)-444cc"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_initable_new()"},{"type":"text","text":" should typically be used instead."}]},{"type":"paragraph","inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"construction, either with this function or "},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Implementations may also support cancellation. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"text":" ","type":"text"},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"text":" ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"text":" ","type":"text"},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the object is not initialized, or initialization returns with an"},{"type":"text","text":" "},{"type":"text","text":"error, then all operations on the object except "},{"type":"codeVoice","code":"g_object_ref()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"type":"text","text":" "},{"type":"text","text":"behaviour. See the "},{"isActive":true,"type":"reference","identifier":"#iface@Gio.Initable#description"},{"text":" for more details.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"text":" can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"text":" ","type":"text"},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"code":"init()","type":"codeVoice"},{"text":" can assume","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"text":" ","type":"text"},{"type":"text","text":"recommended all "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":" implementations should be idempotent; that"},{"type":"text","text":" "},{"text":"recommendation was relaxed in GLib 2.54.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If a class explicitly supports being initialized multiple times, it is"},{"type":"text","text":" "},{"text":"recommended that the method is idempotent: multiple calls with the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"type":"text","text":" "},{"text":"the object; further calls return the result of the first call.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"type":"text","text":" "},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"type":"text","text":" "},{"type":"codeVoice","code":"GObjectClass.constructor"},{"text":" that sometimes returns an existing instance.","type":"text"},{"text":" ","type":"text"},{"text":"In this pattern, a caller would expect to be able to call ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"type":"text","text":"on the result of "},{"type":"codeVoice","code":"g_object_new()"},{"text":", regardless of whether it is in fact a new","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instance."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/initableprotocol\/init_(cancellable:)-444cc"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InitableProtocol"]]},"sections":[],"references":{"doc://GIO/documentation/GIO/InitableProtocol":{"url":"\/documentation\/gio\/initableprotocol","type":"topic","abstract":[{"code":"GInitable","type":"codeVoice"},{"text":" is implemented by objects that can fail during","type":"text"},{"text":" ","type":"text"},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it must be initialized as the first thing after construction,"},{"text":" ","type":"text"},{"type":"text","text":"either via [method"},{"code":"Gio.Initable.init","type":"codeVoice"},{"type":"text","text":"] or [method"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true},{"type":"text","text":"])."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/InitableProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"InitableProtocol","kind":"identifier"}],"title":"InitableProtocol","role":"symbol","navigatorTitle":[{"text":"InitableProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/InitableProtocol/init_(cancellable:)-444cc":{"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/InitableProtocol\/init_(cancellable:)-444cc","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"init_(cancellable:)","url":"\/documentation\/gio\/initableprotocol\/init_(cancellable:)-444cc","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"#iface@Gio.Initable#description":{"type":"link","identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description","title":"description","titleInlineContent":[{"text":"description","type":"text"}]}}}