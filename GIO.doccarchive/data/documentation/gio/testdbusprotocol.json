is can’t be"},{"text":" ","type":"text"},{"text":"called after ","type":"text"},{"type":"codeVoice","code":"g_test_dbus_up()"},{"type":"text","text":"."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusProtocol\/addServiceDir(path:)","url":"\/documentation\/gio\/testdbusprotocol\/addservicedir(path:)","kind":"symbol","role":"symbol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TestDBusProtocol/down()":{"role":"symbol","abstract":[{"text":"Stop the session bus started by ","type":"text"},{"type":"codeVoice","code":"g_test_dbus_up()"},{"type":"text","text":"."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusProtocol\/down()","type":"topic","url":"\/documentation\/gio\/testdbusprotocol\/down()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"down","kind":"identifier"},{"text":"()","kind":"text"}],"title":"down()"},"doc://GIO/documentation/GIO/TestDBusProtocol/test_dbus_ptr-399n4":{"abstract":[{"type":"text","text":"Typed pointer to the underlying "},{"type":"codeVoice","code":"GTestDBus"},{"text":" instance.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusProtocol\/test_dbus_ptr-399n4","required":true,"kind":"symbol","url":"\/documentation\/gio\/testdbusprotocol\/test_dbus_ptr-399n4","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"test_dbus_ptr","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"GTestDBus","kind":"typeIdentifier"},{"text":">!","kind":"text"}],"defaultImplementations":1,"type":"topic","title":"test_dbus_ptr"},"doc://GIO/documentation/GIO/TestDBusProtocol/up()":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusProtocol\/up()","url":"\/documentation\/gio\/testdbusprotocol\/up()","abstract":[{"type":"text","text":"Start a dbus-daemon instance and set DBUS_SESSION_BUS_ADDRESS. After this"},{"text":" ","type":"text"},{"text":"call, it is safe for unit tests to start sending messages on the session bus.","type":"text"}],"title":"up()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"up","kind":"identifier"},{"kind":"text","text":"()"}],"type":"topic","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/TestDBus":{"navigatorTitle":[{"kind":"identifier","text":"TestDBus"}],"title":"TestDBus","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"A helper class for testing code which uses D-Bus without touching the user’s"},{"type":"text","text":" "},{"type":"text","text":"session bus."}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBus","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TestDBus","kind":"identifier"}],"url":"\/documentation\/gio\/testdbus"},"doc://GIO/documentation/GIO/TestDBusPropertyName":{"type":"topic","url":"\/documentation\/gio\/testdbuspropertyname","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"TestDBusPropertyName","kind":"identifier"}],"abstract":[],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusPropertyName","navigatorTitle":[{"text":"TestDBusPropertyName","kind":"identifier"}],"title":"TestDBusPropertyName","kind":"symbol"},"doc://GIO/documentation/GIO/TestDBusProtocol/bind(property:to:_:flags:transformFrom:transformTo:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusProtocol\/bind(property:to:_:flags:transformFrom:transformTo:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"bind","kind":"identifier"},{"kind":"text","text":"<"},{"text":"Q","kind":"genericParameter"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"