] when it is no longer required."}]}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/DBusActionGroupRef/getActionStateHint(actionName:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getActionStateHint","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"actionName"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"kind":"text","text":"!"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusActionGroupRef\/getActionStateHint(actionName:)","url":"\/documentation\/gio\/dbusactiongroupref\/getactionstatehint(actionname:)","role":"symbol","title":"getActionStateHint(actionName:)","kind":"symbol","abstract":[{"text":"Requests a hint about the valid range of values for the state of the","type":"text"},{"type":"text","text":" "},{"text":"named action within ","type":"text"},{"type":"codeVoice","code":"actionGroup"},{"type":"text","text":"."}],"type":"topic"},"doc://GIO/documentation/GIO/DBusActionGroupRef/ActionGroupProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusActionGroupRef\/ActionGroupProtocol-Implementations","kind":"article","abstract":[],"role":"collectionGroup","url":"\/documentation\/gio\/dbusactiongroupref\/actiongroupprotocol-implementations","title":"ActionGroupProtocol Implementations","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ActionGroup":{"role":"symbol","title":"ActionGroup","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action