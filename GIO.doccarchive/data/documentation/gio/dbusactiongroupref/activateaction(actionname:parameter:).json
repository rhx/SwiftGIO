{"sections":[],"metadata":{"title":"activateAction(actionName:parameter:)","role":"symbol","extendedModule":"GIO","externalID":"s:3GIO19ActionGroupProtocolPAAE08activateB010actionName9parameterySPys4Int8VGSg_4GLib10VariantRefVSgtF::SYNTHESIZED::s:3GIO18DBusActionGroupRefV","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"activateAction","kind":"identifier"},{"text":"(","kind":"text"},{"text":"actionName","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"parameter","kind":"externalParam"},{"kind":"text","text":": "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"?)"}],"symbolKind":"method","modules":[{"name":"GIO"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusActionGroupRef","doc:\/\/GIO\/documentation\/GIO\/DBusActionGroupRef\/ActionGroupProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusActionGroupRef\/activateAction(actionName:parameter:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Activate the named action within "},{"type":"codeVoice","code":"actionGroup"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"activateAction","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"actionName"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"parameter"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If the action is expecting a parameter, then the correct type of","type":"text"},{"type":"text","text":" "},{"text":"parameter must be given as ","type":"text"},{"code":"parameter","type":"codeVoice"},{"type":"text","text":".  If the action is expecting no"},{"type":"text","text":" "},{"type":"text","text":"parameters then "},{"code":"parameter","type":"codeVoice"},{"type":"text","text":" must be "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":".  See"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.ActionGroup.get_action_parameter_type"},{"type":"text","text":"]."}]},{"inlineContent":[{"text":"If the [type","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","type":"reference","isActive":true},{"text":"] implementation supports asynchronous remote","type":"text"},{"text":" ","type":"text"},{"text":"activation over D-Bus, this call may return before the relevant","type":"text"},{"type":"text","text":" "},{"text":"D-Bus traffic has been sent, or any replies have been received. In","type":"text"},{"type":"text","text":" "},{"text":"order to block on such asynchronous activation calls,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"type":"text","text":"] should be called prior to the code, which"},{"type":"text","text":" "},{"text":"depends on the result of the action activation. Without flushing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the D-Bus connection, there is no guarantee that the action would"},{"text":" ","type":"text"},{"text":"have been activated.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following code which runs in a remote app instance, shows an","type":"text"},{"type":"text","text":" "},{"text":"example of a ‘quit’ action being activated on the primary app","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance over D-Bus. Here [method"},{"code":"Gio.DBusConnection.flush","type":"codeVoice"},{"type":"text","text":"] is called"},{"type":"text","text":" "},{"text":"before ","type":"text"},{"type":"codeVoice","code":"exit()"},{"text":". Without ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_flush()"},{"text":", the ‘quit’ action","type":"text"},{"type":"text","text":" "},{"type":"text","text":"may fail to be activated on the primary instance."}]},{"type":"codeListing","syntax":"c","code":["\/\/ call ‘quit’ action on primary instance","g_action_group_activate_action (G_ACTION_GROUP (app), \"quit\", NULL);","","\/\/ make sure the action is activated now","g_dbus_connection_flush (…);","","g_debug (\"Application has been terminated. Exiting.\");","","exit (0);"]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/dbusactiongroupref\/activateaction(actionname:parameter:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/DBusActionGroupRef/activateAction(actionName:parameter:)":{"type":"topic","title":"activateAction(actionName:parameter:)","url":"\/documentation\/gio\/dbusactiongroupref\/activateaction(actionname:parameter:)","kind":"symbol","abstract":[{"type":"text","text":"Activate the named action within "},{"code":"actionGroup","type":"codeVoice"},{"type":"text","text":"."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusActionGroupRef\/activateAction(actionName:parameter:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"activateAc