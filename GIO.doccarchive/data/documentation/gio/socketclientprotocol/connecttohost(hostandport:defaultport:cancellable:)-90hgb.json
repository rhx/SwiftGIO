{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"connectToHost"},{"kind":"text","text":"("},{"kind":"externalParam","text":"hostAndPort"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"defaultPort","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@guint16","text":"guint16","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:3GIO19SocketConnectionRefV","text":"SocketConnectionRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef"},{"text":"!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"Attempts to create a TCP connection to the named host.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"hostAndPort","type":"codeVoice"},{"text":" may be in any of a number of recognized formats; an IPv6","type":"text"},{"type":"text","text":" "},{"type":"text","text":"address, an IPv4 address, or a domain name (in which case a DNS"},{"text":" ","type":"text"},{"type":"text","text":"lookup is performed).  Quoting with [] is supported for all address"},{"text":" ","type":"text"},{"type":"text","text":"types.  A port override may be specified in the usual way with a"},{"text":" ","type":"text"},{"type":"text","text":"colon.  Ports may be given as decimal numbers or symbolic names (in"},{"type":"text","text":" "},{"text":"which case an \/etc\/services lookup is performed).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If no port override is given in "},{"code":"hostAndPort","type":"codeVoice"},{"text":" then ","type":"text"},{"code":"defaultPort","type":"codeVoice"},{"text":" will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used as the port number to connect to."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general, "},{"code":"hostAndPort","type":"codeVoice"},{"type":"text","text":" is expected to be provided by the user (allowing"},{"type":"text","text":" "},{"text":"them to give the hostname, and a port override if necessary) and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"defaultPort"},{"text":" is expected to be provided by the application.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the case that an IP address is given, a single connection"},{"text":" ","type":"text"},{"type":"text","text":"attempt is made.  In the case that a name is given, multiple"},{"type":"text","text":" "},{"text":"connection attempts may be made, in turn and according to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"number of address records in DNS, until a connection succeeds."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Upon a successful connection, a new "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","isActive":true,"type":"reference"},{"type":"text","text":" is constructed"},{"type":"text","text":" "},{"text":"and returned.  The caller owns this new object and must drop their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference to it when finished with it."}]},{"inlineContent":[{"text":"In the event of any failure (DNS error, service not found, no hosts","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connectable) "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" (if non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":") is set"},{"text":" ","type":"text"},{"type":"text","text":"accordingly."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketClientProtocol\/connectToHost(hostAndPort:defaultPort:cancellable:)-90hgb","interfaceLanguage":"swift"},"abstract":[{"text":"This is a helper function for ","type":"text"},{"type":"codeVoice","code":"g_socket_client_connect()"},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketclientprotocol\/connecttohost(hostandport:defaultport:cancellable:)-90hgb"]}],"metadata":{"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"connectToHost","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"hostAndPort"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"defaultPort","kind":"externalParam"},{"kind":"text","text":": "},{"text":"guint16","kind":"typeIdentifier","preciseIdentifier":"c:@T@guint16"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"SocketConnectionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19SocketConnectionRefV"},{"text":"!","kind