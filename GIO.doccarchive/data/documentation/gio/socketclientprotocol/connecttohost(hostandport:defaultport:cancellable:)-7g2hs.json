efaultPort","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"guint16","kind":"typeIdentifier","preciseIdentifier":"c:@T@guint16"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef","text":"SocketConnectionRef","preciseIdentifier":"s:3GIO19SocketConnectionRefV"},{"kind":"text","text":"! "},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP","text":"CancellableProtocol"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Attempts to create a TCP connection to the named host.","type":"text"}]},{"inlineContent":[{"code":"hostAndPort","type":"codeVoice"},{"text":" may be in any of a number of recognized formats; an IPv6","type":"text"},{"type":"text","text":" "},{"text":"address, an IPv4 address, or a domain name (in which case a DNS","type":"text"},{"text":" ","type":"text"},{"text":"lookup is performed).  Quoting with [] is supported for all address","type":"text"},{"text":" ","type":"text"},{"text":"types.  A port override may be specified in the usual way with a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"colon.  Ports may be given as decimal numbers or symbolic names (in"},{"type":"text","text":" "},{"type":"text","text":"which case an \/etc\/services lookup is performed)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If no port override is given in "},{"type":"codeVoice","code":"hostAndPort"},{"type":"text","text":" then "},{"code":"defaultPort","type":"codeVoice"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"text":"used as the port number to connect to.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In general, ","type":"text"},{"code":"hostAndPort","type":"codeVoice"},{"text":" is expected to be provided by the user (allowing","type":"text"},{"type":"text","text":" "},{"text":"them to give the hostname, and a port override if necessary) and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"defaultPort"},{"text":" is expected to be provided by the application.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the case that an IP address is given, a single connection"},{"text":" ","type":"text"},{"text":"attempt is made.  In the case that a name is given, multiple","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connection attempts may be made, in turn and according to the"},{"text":" ","type":"text"},{"type":"text","text":"number of address records in DNS, until a connection succeeds."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Upon a successful connection, a new "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference","isActive":true},{"type":"text","text":" is constructed"},{"type":"text","text":" "},{"text":"and returned.  The caller owns this new object and must drop their","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reference to it when finished with it."}]},{"inlineContent":[{"text":"In the event of any failure (DNS error, service not found, no hosts","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connectable) "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" (if non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":") is set"},{"text":" ","type":"text"},{"type":"text","text":"accordingly."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketClientProtocol\/connectToHost(hostAndPort:defaultPort:cancellable:)-7g2hs","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketClientProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketclientprotocol\/connecttohost(hostandport:defaultport:cancellable:)-7g2hs"]}],"abstract":[{"type":"text","text":"This is a helper function for "},{"code":"g_socket_client_connect()","type":"codeVoice"},{"text":".","type":"text"}],"sections":[],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SocketConnectionRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef","type":"topic","url":"\/documentation\/gio\/socketconnectionref","kind":"symbol","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"text":" is a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","type":"reference","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be created either by [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"type":"text","text":"or by [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnectionRef","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketConnectionRe