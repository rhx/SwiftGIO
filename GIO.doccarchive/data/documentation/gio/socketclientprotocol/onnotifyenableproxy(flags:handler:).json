d GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::enable-proxy"},{"type":"text","text":" signal"}]}]}],"kind":"content"}],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","externalID":"s:3GIO20SocketClientProtocolPAAE19onNotifyEnableProxy5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecO0VtctF","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyEnableProxy"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier","text":"ConnectFlags"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO15SocketClientRefV","text":"SocketClientRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"role":"symbol","modules":[{"name":"GIO"}],"title":"onNotifyEnableProxy(flags:handler:)"},"variants":[{"paths":["\/documentation\/gio\/socketclientprotocol\/onnotifyenableproxy(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SocketClientProtocol\/onNotifyEnableProxy(flags:handler:)"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketClientProtocol"]]},"kind":"symbol","abstract":[{"text":"The notify signal is emitted