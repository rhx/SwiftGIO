t":"onNotifyTLS","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:3GIO15SocketClientRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientRef","text":"SocketClientRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}],"name":"flags"},{"content":[{"inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"code":"notifyTLS","type":"codeVoice"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}],"name":"handler"}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"text":" ","type":"text"},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"text":" as","type":"text"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]},{"content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"notify::tls","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketclientprotocol\/onnotifytls(flags:handler:)"]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/SocketClientRef":{"title":"SocketClientRef","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClientRef"}],"navigatorTitle":[{"kind":"identifier","text":"SocketClientRef"}],"url":"\/documentation\/gio\/socketclientref","type":"topic","abstract":[{"code":"GSocketClient","type":"codeVoice"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientRef","role":"symbol"},"#class@GObject.ParamSpec#parameter-names":{"url":"#class@GObject.ParamSpec#parameter-names","title":"canonical parameter names","identifier":"#class@GObject.ParamSpec#parameter-names","type":"link","titleInlineContent":[{"type":"text","text":"canonical parameter names"}]},"doc://GIO/documentation/GIO/SocketClientProtocol":{"navigatorTitle":[{"text":"SocketClientProtocol","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"SocketClientProtocol","kind":"identifier"}],"title":"SocketClientProtocol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientProtocol","role":"symbol","type":"topic","abstract":[{"code":"GSocketClient","type":"codeVoice"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"text":" ","type":"text"},{"text":"a network host using a connection oriented socket type.","type":"text"}],"url":"\/documentation\/gio\/socketclientprotocol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO