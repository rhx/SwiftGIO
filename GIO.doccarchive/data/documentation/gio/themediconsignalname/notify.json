{"metadata":{"title":"ThemedIconSignalName.notify","externalID":"s:3GIO20ThemedIconSignalNameO6notifyyA2CmF","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}],"modules":[{"name":"GIO"}],"roleHeading":"Case","symbolKind":"case","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notify"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"text":"when they explicitly call ","type":"text"},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names"},{"text":" as","type":"text"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ThemedIconSignalName"]]},"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ThemedIconSignalName\/notify","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/gio\/themediconsignalname\/notify"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/ThemedIconSignalName/notify":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ThemedIconSignalName\/notify","abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text