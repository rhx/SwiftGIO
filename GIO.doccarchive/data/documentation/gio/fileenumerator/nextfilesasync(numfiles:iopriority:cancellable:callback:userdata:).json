tions","abstract":[],"title":"FileEnumeratorProtocol Implementations","role":"collectionGroup","kind":"article"},"doc://GIO/documentation/GIO/File":{"abstract":[{"type":"codeVoice","code":"GFile"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"type":"text","text":"that do no I\/O upon creation. It is necessary to understand that"},{"type":"text","text":" "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"text":" ","type":"text"},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"text":"(see [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"text":"] and [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","url":"\/documentation\/gio\/file","title":"File","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"File","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"File"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileInfo":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileInfo"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","url":"\/documentation\/gio\/fileinfo","title":"FileInfo","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileInfo"}],"abstract":[{"text":"Stores information about a file system object referenced by a [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"]."}]},"doc://GIO/documentation/GIO/FileEnumerator/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)":{"abstract":[{"type":"text","text":"Request information for a number of files from the enumerator asynchronously."},{"type":"text","text":" "},{"type":"text","text":"When all I\/O for the operation is finished the "},{"code":"callback","type":"codeVoice"},{"text":" will be called with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the requested information."}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator\/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"nextFilesAsync","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"numFiles"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?, "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"?)","kind":"text"}],"type":"topic","url":"\/documentation\/gio\/fileenumerator\/nextfilesasync(numfiles:iopriority:cancellable:callback:userdata:)","title":"nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileEnumerator":{"kind":"symbol","url":"\/documentation\/gio\/fileenumerator","role":"symbol","abstract":[{"type":"codeVoice","code":"GFileEnumerator"},{"text":" allows you to operate on a set of [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"] objects,"},{"text":" ","type":"text"},{"type":"text","text":"returning a [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"type":"text","text":"] structure for each file enumerated (e.g."},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.File.enumerate_children"},{"type":"text","text":"] will return a "},{"type":"codeVoice","code":"GFileEnumerator"},{"text":" for each","type":"text"},{"type":"text","text":" "},{"text":"of the children within a directory).","type":"text"}],"title":"FileEnumerator","navigatorTitle":[{"text":"FileEnumerator","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"FileEnumerator","kind":"identifier"}]}}}