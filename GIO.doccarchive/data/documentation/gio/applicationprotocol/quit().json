{"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"quit","kind":"identifier"},{"kind":"text","text":"()"}],"roleHeading":"Instance Method","role":"symbol","externalID":"s:3GIO19ApplicationProtocolPAAE4quityyF","title":"quit()","modules":[{"name":"GIO"}],"extendedModule":"GIO","symbolKind":"method"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"quit"},{"kind":"text","text":"()"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Upon return to the mainloop, "},{"type":"codeVoice","code":"g_application_run()"},{"type":"text","text":" will return,"},{"type":"text","text":" "},{"text":"calling only the ‘shutdown’ function before doing so.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The hold count is ignored.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Take care if your code has called "},{"code":"g_application_hold()","type":"codeVoice"},{"text":" on the application and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is therefore still expecting it to exist."},{"type":"text","text":" "},{"text":"(Note that you may have called ","type":"text"},{"code":"g_application_hold()","type":"codeVoice"},{"text":" indirectly, for example","type":"text"},{"type":"text","text":" "},{"type":"text","text":"through "},{"code":"gtk_application_add_window()","type":"codeVoice"},{"text":".)","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The result of calling "},{"type":"codeVoice","code":"g_application_run()"},{"text":" again after it returns is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"unspecified."}]}]}],"variants":[{"paths":["\/documentation\/gio