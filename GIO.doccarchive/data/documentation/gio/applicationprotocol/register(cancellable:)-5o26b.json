{"abstract":[{"type":"text","text":"Attempts registration of the application."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/register(cancellable:)-5o26b","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"register","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the point at which the application discovers if it is the"},{"type":"text","text":" "},{"text":"primary instance or merely acting as a remote for an already-existing","type":"text"},{"type":"text","text":" "},{"text":"primary instance.  This is implemented by attempting to acquire the","type":"text"},{"type":"text","text":" "},{"text":"application identifier as a unique bus name on the session bus using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GDBus."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no application ID or if "},{"code":"nonUnique","type":"codeVoice"},{"type":"text","text":" was"},{"text":" ","type":"text"},{"text":"given, then this process will always become the primary instance.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Due to the internal architecture of GDBus, method calls can be"},{"text":" ","type":"text"},{"type":"text","text":"dispatched at any time (even if a main loop is not running).  For"},{"type":"text","text":" "},{"text":"this reason, you must ensure that any object paths that you wish to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"register are registered before calling this function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the application has already been registered then "},{"type":"codeVoice","code":"true"},{"text":" is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned with no work performed."}]},{"inlineContent":[{"type":"text","text":"The [Application](\/\/documentation\/gio\/application\/onstartup(flags:handler:) signal is emitted if registration succeeds"},{"type":"text","text":" "},{"type":"text","text":"and "},{"code":"application","type":"codeVoice"},{"text":" is the primary instance (including the non-unique","type":"text"},{"type":"text","text":" "},{"type":"text","text":"case)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event of an error (such as "},{"type":"codeVoice","code":"cancellable"},{"text":" being cancelled, or a","type":"text"},{"type":"text","text":" "},{"text":"failure to connect to the session bus), ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" "},{"text":"is set appropriately.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note: the return value of this function is not an indicator that this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instance is or is not the primary instance of the application.  See"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_application_get_is_remote()"},{"text":" for that.","type":"text"}]}],"kind":"content"}],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"register"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"symbolKind":"method","modules":[{"name":"GIO"}],"externalID":"s:3GIO19ApplicationProtocolPAAE8register11cancellableSbAA14CancellableRefVSg_tKF","title":"register(cancellable:)","extendedModule":"GIO","role":"symbol","roleHeading":"Instance Method"},"variants":[{"paths":["\/documentation\/gio\/applicationprotocol\/register(cancellable:)-5o26b"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol"]]},"references":{"doc://GIO/documentation/GIO/ApplicationProtocol":{"type":"topic","kind":"symbol","navigatorTitle":[{"text":"ApplicationProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/applicationprotocol","role":"symbol","abstract":[{"code":"GApplication","type":"codeVoice"},{"type":"text","text":" is the core class for application support."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol","title":"ApplicationProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApplicationProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO/ApplicationProtocol/register(cancellable:)-5o26b":{"abstract":[{"type":"text","text":"Attempts registration of the application."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/register(cancellable:)-5o26b","kind":"symbol","url":"\/documentation\/gio\/applicationprotocol\/register(cancellable:)-5o26b","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"register","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"type":"topic","title":"register(cancellable:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}