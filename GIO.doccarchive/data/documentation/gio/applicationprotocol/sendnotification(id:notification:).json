ng.","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"id"},{"type":"text","text":" may be "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":", but it is impossible to replace or withdraw"},{"type":"text","text":" "},{"text":"notifications without an id.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"notification","type":"codeVoice"},{"type":"text","text":" is no longer relevant, it can be withdrawn with"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.Application.withdraw_notification"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"It is an error to call this function if "},{"type":"codeVoice","code":"application"},{"type":"text","text":" has no"},{"text":" ","type":"text"},{"type":"text","text":"application ID."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/sendNotification(id:notification:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol"]]},"sections":[],"abstract":[{"text":"Sends a notification on behalf of ","type":"text"},{"code":"application","type":"codeVoice"},{"type":"text","text":" to the desktop shell."},{"type":"text","text":" "},{"text":"There is no guarantee that the notification is displayed immediately,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or even at all."}],"references":{"doc://GIO/documentation/GIO/ApplicationProtocol":{"type":"topic","kind":"symbol","navigatorTitle":[{"text":"ApplicationProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/applicationprotocol","role":"symbol","abstract":[{"code":"GApplication","type":"codeVoice"},{"type":"text","text":" is the core class for application support."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol