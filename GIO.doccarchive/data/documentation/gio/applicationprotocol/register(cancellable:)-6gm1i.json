{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/register(cancellable:)-6gm1i"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol"]]},"abstract":[{"type":"text","text":"Attempts registration of the application."}],"variants":[{"paths":["\/documentation\/gio\/applicationprotocol\/register(cancellable:)-6gm1i"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","externalID":"s:3GIO19ApplicationProtocolPAAE8register11cancellableSbqd__Sg_tKAA011CancellableC0Rd__lF","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"register","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"symbolKind":"method","title":"register(cancellable:)","extendedModule":"GIO","roleHeading":"Instance Method"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"register","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:3GIO19CancellableProtocolP","text":"CancellableProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the point at which the application discovers if it is the"},{"type":"text","text":" "},{"text":"primary instance or merely acting as a remote for an already-existing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"primary instance.  This is implemented by attempting to acquire the"},{"type":"text","text":" "},{"text":"application identifier as a unique bus name on the session bus using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GDBus."}]},{"inlineContent":[{"text":"If there is no application ID or if ","type":"text"},{"type":"codeVoice","code":"nonUnique"},{"type":"text","text":" was"},{"type":"text","text":" "},{"text":"given, then this process will always become the primary instance.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Due to the internal architecture of GDBus, method calls can be"},{"type":"text","text":" "},{"type":"text","text":"dispatched at any time (even if a main loop is not running).  For"},{"type":"text","text":" "},{"type":"text","text":"this reason, you must ensure that any object paths that you wish to"},{"type":"text","text":" "},{"type":"text","text":"register are registered before calling this function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the application has already been registered then "},{"code":"true","type":"codeVoice"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"returned with no work performed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The [Application](\/\/documentation\/gio\/application\/onstartup(flags:handler:) signal is emitted if registration succeeds"},{"type":"text","text":" "},{"text":"and ","type":"text"},{"type":"codeVoice","code":"application"},{"type":"text","text":" is the primary instance (including the non-unique"},{"text":" ","type":"text"},{"type":"text","text":"case)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event of an error (such as "},{"type":"codeVoice","code":"cancellable"},{"text":" being cancelled, or a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"failure to connect to the session bus), "},{"code":"false","type":"codeVoice"},{"text":" is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"is set appropriately."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note: the return value of this function is not an indicator that this"},{"text":" ","type":"text"},{"text":"instance is or is not the primary instance of the application.  See","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_application_get_is_remote()"},{"text":" for that.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"},"doc://GIO/documentation/GIO/ApplicationProtocol/register(cancellable:)-6gm1i":{"title":"register(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/register(cancellable:)-6gm1i","kind":"symbol","abstract":[{"text":"Attempts registration of the application.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"register","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"role":"symbol","url":"\/documentation\/gio\/applicationprotocol\/register(cancellable:)-6gm1i"},"doc://GIO/documentation/GIO/ApplicationProtocol":{"type":"topic","kind":"symbol","navigatorTitle":[{"text":"ApplicationProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/applicationprotocol","role":"symbol","abstract":[{"code":"GApplication","type":"codeVoice"},{"type":"text","text":" is the core class for application support."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol","title":"ApplicationProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApplicationProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}