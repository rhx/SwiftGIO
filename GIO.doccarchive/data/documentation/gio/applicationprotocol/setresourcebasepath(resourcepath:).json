{"kind":"symbol","abstract":[{"type":"text","text":"Sets (or unsets) the base resource path of "},{"type":"codeVoice","code":"application"},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setResourceBasePath"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"resourcePath"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">? = nil)"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The path is used to automatically load various","type":"text"},{"text":" ","type":"text"},{"identifier":"#struct@Gio.Resource","type":"reference","isActive":true},{"type":"text","text":" such as menu layouts and"},{"type":"text","text":" "},{"type":"text","text":"action descriptions. The various types of resources will be found at"},{"text":" ","type":"text"},{"text":"fixed names relative to the given base path.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, the resource base path is determined from the application"},{"text":" ","type":"text"},{"type":"text","text":"ID by prefixing ‘\/’ and replacing each ‘.’ with ‘\/’.  This is done at"},{"text":" ","type":"text"},{"type":"text","text":"the time that the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application"},{"type":"text","text":" object is constructed.  Changes to"},{"type":"text","text":" "},{"type":"text","text":"the application ID after that point will not have an impact on the"},{"type":"text","text":" "},{"type":"text","text":"resource base path."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an example, if the application has an ID of “org.example.app” then"},{"text":" ","type":"text"},{"type":"text","text":"the default resource base path will be “\/org\/example\/app”.  If this"},{"type":"text","text":" "},{"type":"text","text":"is a "},{"type":"codeVoice","code":"GtkApplication"},{"text":" (and you have not manually changed the path)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then Gtk will then search for the menus of the application at"},{"text":" ","type":"text"},{"type":"text","text":"“\/org\/example\/app\/gtk\/menus.ui”."}]},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Resource","type":"reference"},{"type":"text","text":" for more information about adding resources to your"},{"type":"text","text":" "},{"type":"text","text":"application."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can disable automatic resource loading functionality by setting"},{"text":" ","type":"text"},{"type":"text","text":"the path to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Changing the resource base path once the application is running is"},{"type":"text","text":" "},{"type":"text","text":"not recommended.  The point at which the resource path is consulted"},{"type":"text","text":" "},{"type":"text","text":"for forming paths for various purposes is unspecified.  When writing"},{"text":" ","type":"text"},{"text":"a sub-class of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","isActive":true,"type":"reference"},{"text":" you should either set the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","type":"reference","isActive":true},{"text":" property at construction time, or call","type":"text"},{"type":"text","text":" "},{"text":"this function during the instance initialization. Alternatively, you","type":"text"},{"type":"text","text":" "},{"text":"can call this function in the ","type":"text"},{"code":"GApplicationClass.startup","type":"codeVoice"},{"text":" virtual function,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before chaining up to the parent implementation."}]}],"kind":"content"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/applicationprotocol\/setresourcebasepath(resourcepath:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"GIO"}],"externalID":"s:3GIO19ApplicationProtocolPAAE19setResourceBasePath08resourceG0ySPys4Int8VGSg_tF","roleHeading":"Instance Method","extendedModule":"GIO","symbolKind":"method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"setResourceBasePath","kind":"identifier"},{"text":"(","kind":"text"},{"text":"resourcePath","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?)","kind":"text"}],"title":"setResourceBasePath(resourcePath:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/setResourceBasePath(resourcePath:)"},"references":{"doc://GIO/documentation/GIO/ApplicationProtocol/setResourceBasePath(resourcePath:)":{"kind":"symbol","url":"\/documentation\/gio\/applicationprotocol\/setresourcebasepath(resourcepath:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/setResourceBasePath(resourcePath:)","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Sets (or unsets) the base resource path of "},{"type":"codeVoice","code":"applica