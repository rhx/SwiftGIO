{"kind":"symbol","sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"extendedModule":"GIO","externalID":"s:3GIO19ApplicationProtocolPAAE20onHandleLocalOptions5flags7handlerSi10GLibObject12ConnectFlagsV_SiAA0B3RefV_0J0011VariantDictN0VtctF","role":"symbol","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onHandleLocalOptions","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"ApplicationRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ApplicationRefV"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:4GLib14VariantDictRefV","text":"VariantDictRef","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"onHandleLocalOptions(flags:handler:)","roleHeading":"Instance Method","modules":[{"name":"GIO"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationprotocol\/onhandlelocaloptions(flags:handler:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol"]]},"abstract":[{"text":"The ","type":"text"},{"code":"handle-local-options","type":"codeVoice"},{"type":"text","text":" signal is emitted on the local instance"},{"type":"text","text":" "},{"text":"after the parsing of the commandline options has occurred.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onHandleLocalOptions"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"text":"ApplicationRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","preciseIdentifier":"s:3GIO14ApplicationRefV"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:4GLib14VariantDictRefV","text":"VariantDictRef","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]}]},{"parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An exit code. If you have handled your options and want to exit the process, return a non-negative option, 0 for success, and a positive value for failure. To continue, return -1 to let the default option processing continue."},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"handleLocalOptions"},{"type":"text","text":" signal is emitted"}]}],"name":"handler"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can add options to be recognised during commandline option"},{"type":"text","text":" "},{"text":"parsing using ","type":"text"},{"code":"g_application_add_main_option_entries()","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"g_application_add_option_group()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Signal handlers can inspect ","type":"text"},{"type":"codeVoice","code":"options"},{"text":" (along with values pointed to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from the "},{"type":"codeVoice","code":"arg_data"},{"text":" of an installed ","type":"text"},{"type":"codeVoice","code":"GOptionEntrys"},{"type":"text","text":") in order to"},{"text":" ","type":"text"},{"type":"text","text":"decide to perform certain actions, including direct local handling"},{"text":" ","type":"text"},{"type":"text","text":"(which may be useful for options like –version)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that the application is marked"},{"type":"text","text":" "},{"type":"codeVoice","code":"handlesCommandLine"},{"type":"text","text":" the “normal processing” will"},{"type":"text","text":" "},{"text":"send the ","type":"text"},{"type":"codeVoice","code":"options"},{"type":"text","text":" dictionary to the primary instance where it can be"},{"text":" ","type":"text"},{"type":"text","text":"read with "},{"code":"g_application_command_line_get_options_dict()","type":"codeVoice"},{"text":".  The signal","type":"text"},{"type":"text","text":" "},{"text":"handler can modify the dictionary before returning, and the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"modified dictionary will be sent."}]},{"type":"paragraph","inlineContent":[{"text":"In the event that ","type":"text"},{"code":"handlesCommandLine","type":"codeVoice"},{"type":"text","text":" is not set,"},{"text":" ","type":"text"},{"text":"“normal processing” will treat the remaining uncollected command","type":"text"},{"text":" ","type":"text"},{"text":"line arguments as filenames or URIs.  If there are no arguments,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the application is activated by "},{"type":"codeVoice","code":"g_application_activate()"},{"type":"text","text":".  One or"},{"type":"text","text":" "},{"type":"text","text":"more arguments results in a call to "},{"type":"codeVoice","code":"g_application_open()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to handle the local commandline arguments for yourself"},{"type":"text","text":" "},{"type":"text","text":"by converting them to calls to "},{"type":"codeVoice","code":"g_application_open()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"g_action_group_activate_action()","type":"codeVoice"},{"text":" then you must be sure to register","type":"text"},{"text":" ","type":"text"},{"text":"the application first.  You should probably not call","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_application_activate()"},{"type":"text","text":" for yourself, however: just return -1 and"},{"text":" ","type":"text"},{"type":"text","text":"allow the default handler to do it for you.  This will ensure that"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"--gapplication-service"},{"type":"text","text":" switch works properly (i.e. no activation"},{"type":"text","text":" "},{"text":"in that case).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that this signal is emitted from the default implementation of","type":"text"},{"type":"text","text":" "},{"code":"local_command_line()","type":"codeVoice"},{"text":".  If you override that function and don’t","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"chain up then this signal will never be emitted."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can override "},{"type":"codeVoice","code":"local_command_line()"},{"text":" if you need more powerful","type":"text"},{"text":" ","type":"text"},{"text":"capabilities than what is provided here, but this should not","type":"text"},{"type":"text","text":" "},{"text":"normally be required.","type":"text"}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"handle-local-options","type":"codeVoice"},{"type":"text","text":" signal"}]}],"style":"note","type":"aside"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/onHandleLocalOptions(flags:handler:)"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ApplicationProtocol/onHandleLocalOptions(flags:handler:)":{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"handle-local-options"},{"type":"text","text":" signal is emitted on the local instance"},{"type":"text","text":" "},{"type":"text","text":"after the parsing of the commandline options has occurred."}],"url":"\/documentation\/gio\/applicationprotocol\/onhandlelocaloptions(flags:handler:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol\/onHandleLocalOptions(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onHandleLocalOptions"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier","text":"ConnectFlags"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"ApplicationRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ApplicationRefV"},{"text":", ","kind":"text"},{"text":"VariantDictRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14VariantDictRefV"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"title":"onHandleLocalOptions(flags:handler:)","role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/ApplicationProtocol":{"type":"topic","kind":"symbol","navigatorTitle":[{"text":"ApplicationProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/applicationprotocol","role":"symbol","abstract":[{"code":"GApplication","type":"codeVoice"},{"type":"text","text":" is the core class for application support."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationProtocol","title":"ApplicationProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApplicationProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO/ApplicationRef":{"type":"topic","navigatorTitle":[{"text":"ApplicationRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","url":"\/documentation\/gio\/applicationref","title":"ApplicationRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ApplicationRef"}],"abstract":[{"type":"codeVoice","code":"GApplication"},{"text":" is the core class for application support.","type":"text"}]}}}