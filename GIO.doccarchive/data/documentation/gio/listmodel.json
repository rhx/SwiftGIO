{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ListModel","interfaceLanguage":"swift"},"abstract":[{"type":"codeVoice","code":"GListModel"},{"type":"text","text":" is an interface that represents a mutable list of"},{"type":"text","text":" "},{"text":"[class[Object](\/\/documentation\/gobject\/object]. Its main intention is as a model for various widgets","type":"text"},{"type":"text","text":" "},{"text":"in user interfaces, such as list views, but it can also be used as a","type":"text"},{"type":"text","text":" "},{"text":"convenient method of returning lists of data, with support for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"updates."}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(_:)-2d8it","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(_:)-2kt3j","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(_:)-7hevy","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(_:)-8rwc4","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(_:)-9c3kl","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(raw:)-5oywt","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(raw:)-ltn6","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(retainingRaw:)-1vr9w","doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(retainingRaw:)-ynrd"],"generated":true,"anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModel\/metatypeReferenceForListModel","doc:\/\/GIO\/documentation\/GIO\/ListModel\/ptr","doc:\/\/GIO\/documentation\/GIO\/ListModel\/wrapperForListModel"],"title":"Instance Properties","anchor":"Instance-Properties"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModel\/metatypeForListModel"],"anchor":"Type-Properties","generated":true,"title":"Type Properties"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModel\/ListModelProtocol-Implementations"],"generated":true,"title":"Default Implementations","anchor":"Default-Implementations"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"ListModel","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Each object in the list may also report changes in itself via some","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"mechanism (normally the [signal[Object](\/\/documentation\/gobject\/object\/onnotify(flags:handler:)] signal).  Taken"},{"type":"text","text":" "},{"type":"text","text":"together with the [signal[ListModel](\/\/documentation\/gio\/listmodel\/onitemschanged(flags:handler:)] signal, this provides"},{"text":" ","type":"text"},{"type":"text","text":"for a list that can change its membership, and in which the members can"},{"type":"text","text":" "},{"text":"change their individual properties.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A good example would be the list of visible wireless network access","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"points, where each access point can report dynamic properties such as"},{"type":"text","text":" "},{"text":"signal strength.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is important to note that the ","type":"text"},{"code":"GListModel","type":"codeVoice"},{"text":" itself does not report","type":"text"},{"text":" ","type":"text"},{"text":"changes to the individual items.  It only reports changes to the list","type":"text"},{"type":"text","text":" "},{"text":"membership.  If you want to observe changes to the objects themselves","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then you need to connect signals to the objects that you are"},{"text":" ","type":"text"},{"text":"interested in.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All items in a "},{"type":"codeVoice","code":"GListModel"},{"type":"text","text":" are of (or derived from) the same type."},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.ListModel.get_item_type"},{"type":"text","text":"] returns that type.  The type may be an"},{"text":" ","type":"text"},{"type":"text","text":"interface, in which case all objects in the list must implement it."}]},{"type":"paragraph","inlineContent":[{"text":"The semantics are close to that of an array:","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.ListModel.get_n_items","type":"codeVoice"},{"text":"] returns the number of items in the list","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and [method"},{"code":"Gio.ListModel.get_item","type":"codeVoice"},{"type":"text","text":"] returns an item at a (0-based) position."},{"type":"text","text":" "},{"type":"text","text":"In order to allow implementations to calculate the list length lazily,"},{"text":" ","type":"text"},{"type":"text","text":"you can also iterate over items: starting from 0, repeatedly call"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"Gio.ListModel.get_item","type":"codeVoice"},{"type":"text","text":"] until it returns "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"An implementation may create objects lazily, but must take care to"},{"type":"text","text":" "},{"type":"text","text":"return the same object for a given position until all references to"},{"text":" ","type":"text"},{"type":"text","text":"it are gone."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On the other side, a consumer is expected only to hold references on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"objects that are currently ‘user visible’, in order to facilitate the"},{"type":"text","text":" "},{"type":"text","text":"maximum level of laziness in the implementation of the list and to"},{"text":" ","type":"text"},{"text":"reduce the required number of signal connections at a given time.","type":"text"}]},{"inlineContent":[{"text":"This interface is intended only to be used from a single thread.  The","type":"text"},{"text":" ","type":"text"},{"text":"thread in which it is appropriate to use it depends on the particular","type":"text"},{"type":"text","text":" "},{"text":"implementation, but typically it will be from the thread that owns","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the thread-default main context (see"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"type":"text","text":"]) in effect at the time that the"},{"type":"text","text":" "},{"type":"text","text":"model was created."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Over time, it has established itself as good practice for list model"},{"type":"text","text":" "},{"text":"implementations to provide properties ","type":"text"},{"code":"item-type","type":"codeVoice"},{"type":"text","text":" and "},{"code":"n-items","type":"codeVoice"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"ease working with them. While it is not required, it is recommended"},{"text":" ","type":"text"},{"type":"text","text":"that implementations provide these two properties. They should return"},{"type":"text","text":" "},{"text":"the values of [method","type":"text"},{"code":"Gio.ListModel.get_item_type","type":"codeVoice"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.ListModel.get_n_items"},{"text":"] respectively and be defined as such:","type":"text"}]},{"syntax":"c","type":"codeListing","code":["properties[PROP_ITEM_TYPE] =","  g_param_spec_gtype (\"item-type\", NULL, NULL, G_TYPE_OBJECT,","                      G_PARAM_CONSTRUCT_ONLY | G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS);","properties[PROP_N_ITEMS] =","  g_param_spec_uint (\"n-items\", NULL, NULL, 0, G_MAXUINT, 0,","                     G_PARAM_READABLE | G_PARAM_STATIC_STRINGS);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","isActive":true},{"type":"text","text":" type acts as an owner of an underlying "},{"type":"codeVoice","code":"GListModel"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","type":"reference","isActive":true},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GListModel"},{"type":"text","text":" instance."}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModelRef"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","type":"reference","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GListModel"},{"type":"text","text":" instance."}]}],"type":"aside"}],"kind":"content"}],"kind":"symbol","relationshipsSections":[{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/listmodel"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"navigatorTitle":[{"kind":"identifier","text":"ListModel"}],"symbolKind":"class","role":"symbol","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"ListModel","kind":"identifier"}],"externalID":"s:3GIO9ListModelC","roleHeading":"Class","title":"ListModel"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"references":{"doc://GIO/documentation/GIO/ListModel/init(_:)-2kt3j":{"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel\/init(_:)-2kt3j","url":"\/documentation\/gio\/listmodel\/init(_:)-2kt3j","title":"init(_:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"!("},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"GListModel","kind":"typeIdentifier"},{"text":">?)","kind":"text"}],"role":"symbol","kind":"symbol","abstract":[{"text":"Optional initialiser from the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type."},{"type":"text","text":" "},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"type":"text","text":" "},{"text":"i.e., ownership is transferred to the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","isActive":true},{"type":"text","text":" instance."}]},"doc://GIO/documentation/GIO/ListModelProtocol":{"url":"\/documentation\/gio\/listmodelprotocol","identifier":"doc:\/\/GIO\/documentation\/G