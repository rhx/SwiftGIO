ind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/MenuModel/parentInstance":{"abstract":[],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"parentInstance","kind":"identifier"},{"kind":"text","text":": "},{"text":"GObject","kind":"typeIdentifier"}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/menumodel\/parentinstance","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/parentInstance","title":"parentInstance"},"doc://GIO/documentation/GIO/MenuModel/MenuModelProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/MenuModelProtocol-Implementations","kind":"article","url":"\/documentation\/gio\/menumodel\/menumodelprotocol-implementations","role":"collectionGroup","title":"MenuModelProtocol Implementations","abstract":[]}}}