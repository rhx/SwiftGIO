{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuModel","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/MenuModelProtocol-Implementations"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Emitted when a change has occurred to the menu."}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/onItemsChanged(flags:handler:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menumodel\/onitemschanged(flags:handler:)"]}],"metadata":{"externalID":"s:3GIO17MenuModelProtocolPAAE14onItemsChanged5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_S3itctF::SYNTHESIZED::s:3GIO9MenuModelC","roleHeading":"Instance Method","symbolKind":"method","title":"onItemsChanged(flags:handler:)","extendedModule":"GIO","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onItemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO12MenuModelRefV","text":"MenuModelRef"},{"kind":"text","text":", "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":") -> "},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onItemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"text":"MenuModelRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO12MenuModelRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}],"name":"flags"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"code":"itemsChanged","type":"codeVoice"},{"text":" signal is emitted","type":"text"}]}],"name":"handler"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The only changes that can occur to a menu is that items are removed"},{"text":" ","type":"text"},{"text":"or added.  Items may not change (except by being removed and added","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"back in the same location).  This signal is capable of describing"},{"type":"text","text":" "},{"type":"text","text":"both of those changes (at the same time)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The signal means that starting at the index "},{"type":"codeVoice","code":"position"},{"type":"text","text":", "},{"type":"codeVoice","code":"removed"},{"text":" ","type":"text"},{"text":"items were removed and ","type":"text"},{"type":"codeVoice","code":"added"},{"type":"text","text":" items were added in their place.  If"},{"type":"text","text":" "},{"type":"codeVoice","code":"removed"},{"type":"text","text":" is zero then only items were added.  If "},{"type":"codeVoice","code":"added"},{"type":"text","text":" is zero"},{"type":"text","text":" "},{"type":"text","text":"then only items were removed."}]},{"inlineContent":[{"text":"As an example, if the menu contains items a, b, c, d (in that","type":"text"},{"type":"text","text":" "},{"text":"order) and the signal (2, 1, 3) occurs then the new composition of","type":"text"},{"type":"text","text":" "},{"text":"the menu will be a, b, _, _, _, d (with each _ representing some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"new item)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Signal handlers may query the model (particularly the added items)"},{"type":"text","text":" "},{"type":"text","text":"and expect to see the results of the modification that is being"},{"type":"text","text":" "},{"type":"text","text":"reported.  The signal is emitted after the modification."}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"items-changed","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}]}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/MenuModel/onItemsChanged(flags:handler:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/onItemsChanged(flags:handler:)","kind":"symbol","url":"\/documentation\/gio\/menumodel\/onitemschanged(flags:handler:)","title":"onItemsChanged(flags:handler:)","abstract":[{"type":"text","text":"Emitted when a change has occurred to the menu."}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onItemsChanged"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"preciseIdentifier":"s:3GIO12MenuModelRefV","kind":"typeIdentifier","text":"MenuModelRef"},{"kind":"text","text":", "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"role":"symbol"},"doc://GIO/documentation/GIO/MenuModel/MenuModelProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/MenuModelProtocol-Implementations","kind":"article","url":"\/documentation\/gio\/menumodel\/menumodelprotocol-implementations","role":"collectionGroup","title":"MenuModelProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"}}}