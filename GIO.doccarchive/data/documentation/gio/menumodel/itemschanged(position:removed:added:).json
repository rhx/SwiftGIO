{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/itemsChanged(position:removed:added:)"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Requests emission of the [MenuModel](\/\/documentation\/gio\/menumodel\/onitemschanged(flags:handler:) signal on "},{"code":"model","type":"codeVoice"},{"type":"text","text":"."}],"metadata":{"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"itemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"position","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"removed","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"added"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"externalID":"s:3GIO17MenuModelProtocolPAAE12itemsChanged8position7removed5addedySi_S2itF::SYNTHESIZED::s:3GIO9MenuModelC","extendedModule":"GIO","role":"symbol","title":"itemsChanged(position:removed:added:)","modules":[{"name":"GIO"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuModel","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/MenuModelProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/gio\/menumodel\/itemschanged(position:removed:added:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"itemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"position","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"removed"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"added","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function should never be called except by "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"subclasses.  Any other calls to this function will very likely lead"},{"type":"text","text":" "},{"text":"to a violation of the interface of the model.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The implementation should update its internal representation of the"},{"text":" ","type":"text"},{"text":"menu before emitting the signal.  The implementation should further","type":"text"},{"type":"text","text":" "},{"text":"expect to receive queries about the new state of the menu (and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"particularly added menu items) while signal handlers are running."}]},{"inlineContent":[{"type":"text","text":"The implementation must dispatch this call directly from a mainloop"},{"type":"text","text":" "},{"type":"text","text":"entry and not in response to calls – particularly those from the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference","isActive":true},{"type":"text","text":" API.  Said another way: the menu must not change while"},{"text":" ","type":"text"},{"text":"user code is running without returning to the mainloop.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/MenuModel/itemsChanged(position:removed:added:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"itemsChanged","kind":"identifier"},{"kind":"text","text":"("},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"text":"removed","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"added","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"type":"topic","url":"\/documentation\/gio\/menumodel\/itemschanged(position:removed:added:)","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/itemsChanged(position:removed:added:)","title":"itemsChanged(position:removed:added:)","role":"symbol","abstract":[{"type":"text","text":"Requests emission of the [MenuModel](\/\/documentation\/gio\/menumodel\/onitemschanged(flags:handler:) signal on "},{"type":"codeVoice","code":"model"},{"text":".","type":"text"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModel/MenuModelProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/MenuModelProtocol-Implementations","kind":"article","url":"\/documentation\/gio\/menumodel\/menumodelprotocol-implementations","role":"collectionGroup","title":"MenuModelProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]}}}