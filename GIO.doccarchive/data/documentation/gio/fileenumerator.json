{"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"externalID":"s:3GIO14FileEnumeratorC","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"FileEnumerator","kind":"identifier"}],"title":"FileEnumerator","roleHeading":"Class","role":"symbol","symbolKind":"class","navigatorTitle":[{"text":"FileEnumerator","kind":"identifier"}],"modules":[{"name":"GIO"}]},"abstract":[{"type":"codeVoice","code":"GFileEnumerator"},{"type":"text","text":" allows you to operate on a set of [iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/File","type":"reference","isActive":true},{"type":"text","text":"] objects,"},{"type":"text","text":" "},{"type":"text","text":"returning a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true,"type":"reference"},{"text":"] structure for each file enumerated (e.g.","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.File.enumerate_children"},{"type":"text","text":"] will return a "},{"type":"codeVoice","code":"GFileEnumerator"},{"type":"text","text":" for each"},{"type":"text","text":" "},{"type":"text","text":"of the children within a directory)."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileenumerator"]}],"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/10GLibObject0B0C"],"title":"Inherits From","kind":"relationships","type":"inheritsFrom"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"type":"conformsTo"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileEnumerator"}]}]},{"content":[{"type":"heading","anchor":"overview","level"