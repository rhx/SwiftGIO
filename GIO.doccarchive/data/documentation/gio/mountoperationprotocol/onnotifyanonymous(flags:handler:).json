rived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"notify","type":"codeVoice"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::anonymous"},{"type":"text","text":" signal"}]}],"type":"aside"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MountOperationProtocol":{"type":"topic","navigatorTitle":[{"text":"MountOperationProtocol","kind":"identifier"}],"title":"MountOperationProtocol","url":"\/documentation\/gio\/mountoperationprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"MountOperationProtocol","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationProtocol","abstract":[{"type":"codeVoice","code":"GMountOperation"},{"text":" provides a mechanism for interacting with the user.","type":"text"},{"text":" ","type":"text"},{"text":"It can be used for authenticating mountable operations, such as loop","type":"text"},{"type":"text","text":" "},{"text":"mounting files, hard drive partitions or server locations. It can","type":"text"},{"type":"text","text":" "},{"text":"also be used to ask the user questions or show a list of applications","type":"text"},{"type":"text","text":" "},{"type":"text","text":"preventing unmount or eject operations from completing."}]},"#class@GObject.ParamSpec#parameter-names":{"title":"canonical parameter names","url":"#class@GObject.ParamSpec#parameter-names","type":"link","titleInlineContent":[{"text":"canonical parameter names","type":"text"}],"identifier":"#class@GObject.ParamSpec#parameter-names"},"doc://GIO/documentation/GIO/MountOperationProtocol/onNotifyAnonymous(flags:handler:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationProtoco