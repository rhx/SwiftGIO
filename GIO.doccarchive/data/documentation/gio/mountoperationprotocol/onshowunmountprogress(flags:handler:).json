ens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onShowUnmountProgress","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"text":"MountOperationRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17MountOperationRefV"},{"text":", ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64"},{"text":", ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}],"name":"flags"},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"showUnmountProgress"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"When unmounting or ejecting a volume, the kernel might need to flush","type":"text"},{"text":" ","type":"text"},{"text":"pending data in its buffers to the volume stable storage, and this operation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can take a considerable amount of time. This signal may be emitted several"},{"type":"text","text":" "},{"type":"text","text":"times as long as the unmount operation is outstanding, and then one"},{"text":" ","type":"text"},{"text":"last time when the operation is completed, with ","type":"text"},{"type":"codeVoice","code":"bytesLeft"},{"type":"text","text":" set to zero."}],"type":"paragraph"},{"inlineContent":[{"text":"Implementations of GMountOperation should handle this signal by","type":"text"},{"text":" ","type":"text"},{"text":"showing an UI notification, and then dismiss it, or show another notification","type":"text"},{"type":"text","text":" "},{"text":"of completion, when ","type":"text"},{"code":"bytesLeft","type":"codeVoice"},{"type":"text","text":" reaches zero."}],"type":"paragraph"},{"inlineContent":[{"text":"If the message contains a line break, the first line should be","type":"text"},{"type":"text","text":" "},{"text":"presented as a heading. For example, it may be used as the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"primary text in a "},{"type":"codeVoice","code":"GtkMessageDialog"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"show-unmount-progress"},{"type":"text","text":" signal"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/mountoperationprotocol\/onshowunmountprogress(flags:handler:)"]}],"references":{"doc://GIO/documentation/GIO/MountOperationProtocol":{"type":"topic","navigatorTitle":[{"text":"MountOperationProtocol","kind":"identifier"}],"title":"MountOperationProtocol","url":"\/documentation\/gio\/mountoperationprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"MountOperationProtocol","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationProtocol","abstract":[{"type":"codeVoice","code":"GMountOperation"},{"text":" provides a mechanism for interacting with the user.","type":"text"},{"text":" ","type":"text"},{"text":"It can be used for authenticating mountable operations, such as loop","type":"text"},{"type":"text","text":" "},{"text":"mounting files, hard drive partitions or server locations. It can","type":"text"},{"type":"text","text":" "},{"text":"also be used to ask the user questions or show a list of applications","type":"text"},{"type":"text","text":" "},{"type":"text","text":"preventing unmount or eject operations from completing."}]},"doc://GIO/documentation/GIO/MountOperationProtocol/onShowUnmountProgress(flags:handler:)":{"title":"onShowUnmountProgress(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onShowUnmountProgress"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO17MountOperationRefV","kind":"typeIdentifier","text":"MountOperationRef"},{"kind":"text","text":", "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"gint64","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationProtocol\/onShowUnmountProgress(flags:handler:)","url":"\/documentation\/gio\/mountoperationprotocol\/onshowunmountprogress(flags:handler:)","kind":"symbol","type":"topic","abstract":[{"text":"Emitted when an unmount operation has been busy for more than some time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(typically 1.5 seconds)."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MountOperationRef":{"title":"MountOperationRef","kind":"symbol","url":"\/documentation\/gio\/mountoperationref","abstract":[{"type":"codeVoice","code":"GMountOperation"},{"text":" provides a mechanism for interacting with the user.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It can be used for authenticating mountable operations, such as loop"},{"text":" ","type":"text"},{"type":"text","text":"mounting files, hard drive partitions or server locations. It can"},{"text":" ","type":"text"},{"type":"text","text":"also be used to ask the user questions or show a list of applications"},{"type":"text","text":" "},{"type":"text","text":"preventing unmount or eject operations from completing."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MountOperationRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationRef","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MountOperationRef"}]}}}