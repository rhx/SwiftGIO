{"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncherRef\/takeStdout(fd:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeStdout"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fd"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"fd","type":"codeVoice"},{"text":" is -1 then any previously given fd is unset.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that the default behaviour is to pass stdout through to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stdout of the parent process."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The passed "},{"code":"fd","type":"codeVoice"},{"text":" is noted but will not be touched in the current","type":"text"},{"type":"text","text":" "},{"text":"process.  It is therefore necessary that it be kept open by the","type":"text"},{"text":" ","type":"text"},{"text":"caller until the subprocess is spawned.  The file descriptor will","type":"text"},{"text":" ","type":"text"},{"text":"also not be explicitly closed on the child side, so it must be marked","type":"text"},{"type":"text","text":" "},{"text":"O_CLOEXEC if that’s what you want.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You may not set a stdout fd if a stdout file path is already set or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if the launcher flags contain any flags directing stdout elsewhere."}]},{"type":"paragraph","inlineContent":[{"text":"This featu