OEXEC if that’s what you want.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You may not set a stdin fd if a stdin file path is already set or if","type":"text"},{"text":" ","type":"text"},{"text":"the launcher flags contain any flags directing stdin elsewhere.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This feature is only available on UNIX."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncherRef\/takeStdin(fd:)","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeStdin","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fd"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":")"}],"role":"symbol","symbolKind":"method","extendedModule":"GIO","modules":[{"name":"GIO"}],"title":"takeStdin(fd:)","externalID":"s:3GIO26SubprocessLauncherProtocolPAAE9takeStdin2fdySi_tF::SYNTHESIZED::s:3GIO21SubprocessLauncherRefV","roleHeading":"Instance Method"},"abstract":[{"text":"Sets the file descriptor to use as the stdin for spawned processes.","type":"text"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SubprocessLauncherRef/SubprocessLauncherProtocol-Implementations":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncherRef\/SubprocessLauncherProtocol-Implementations","url":"\/documentation\/gio\/subprocesslauncherref\/subprocesslauncherprotocol-implementations","role":"collectionGroup","kind":"article","title":"SubprocessLauncherProtocol Implementations"},"doc://GIO/documentation/GIO/SubprocessLauncherRef":{"navigatorTitle":[{"text":"SubprocessLauncherRef","kind":"identifier"}