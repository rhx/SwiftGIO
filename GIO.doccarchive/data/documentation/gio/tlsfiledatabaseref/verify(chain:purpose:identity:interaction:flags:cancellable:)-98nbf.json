text":">!, ","kind":"text"},{"text":"identity","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"SocketConnectableT"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"interaction"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"TLSInteractionT"},{"text":"?, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSDatabaseVerifyFlags","preciseIdentifier":"s:3GIO22TLSDatabaseVerifyFlagsV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseVerifyFlags"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","text":"TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:3GIO19CancellableProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"SocketConnectableT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:3GIO25SocketConnectableProtocolP","text":"SocketConnectableProtocol","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableProtocol"},{"text":", ","kind":"text"},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","kind":"typeIdentifier","text":"TLSCertificateProtocol"},{"text":", ","kind":"text"},{"text":"TLSInteractionT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO22TLSInteractionProtocolP","text":"TLSInteractionProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionProtocol","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"codeVoice","code":"chain"},{"text":" is a chain of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference","isActive":true},{"text":" objects each pointing to the next","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate in the chain by its "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true},{"type":"text","text":" property."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"purpose"},{"text":" describes the purpose (or usage) for which the certificate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is being used. Typically "},{"type":"codeVoice","code":"purpose"},{"text":" will be set to ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/tlsDatabasePurposeAuthenticateServer","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"which means that the certificate is being used to authenticate a server"},{"type":"text","text":" "},{"type":"text","text":"(and we are acting as the client)."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"identity"},{"text":" is used to ensure the server certificate is valid for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the expected peer identity. If the identity does not match the"},{"type":"text","text":" "},{"type":"text","text":"certificate, "},{"code":"badIdentity","type":"codeVoice"},{"type":"text","text":" will be set in the"},{"text":" ","type":"text"},{"type":"text","text":"return value. If "},{"type":"codeVoice","code":"identity"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":", that bit will never be set in","type":"text"},{"text":" ","type":"text"},{"text":"the return value. The peer identity may also be used to check for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"pinned certificates (trust exceptions) in the database. These may"},{"type":"text","text":" "},{"text":"override the normal verification process on a host-by-host basis.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Currently there are no ","type":"text"},{"code":"flags","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"none","type":"codeVoice"},{"type":"text","text":" should be"},{"type":"text","text":" "},{"type":"text","text":"used."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"chain"},{"text":" is found to be valid, then the return value will be 0. If","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"chain"},{"type":"text","text":" is found to be invalid, then the return value will indicate at"},{"type":"text","text":" "},{"type":"text","text":"least one problem found. If the function is unable to determine"},{"type":"text","text":" "},{"type":"text","text":"whether "},{"code":"chain","type":"codeVoice"},{"text":" is valid (for example, because ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"triggered before it completes) then the return value will be","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"genericError"},{"type":"text","text":" and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" will be set accordingly."},{"text":" ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is not set when "},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is successfully analyzed but found to"},{"text":" ","type":"text"},{"type":"text","text":"be invalid."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"text":" ","type":"text"},{"text":"error will be set in the return value, but it does not guarantee","type":"text"},{"type":"text","text":" "},{"text":"that all possible errors will be set. Accordingly, you may not safely","type":"text"},{"type":"text","text":" "},{"type":"text","text":"decide to ignore any particular type of error. For example, it would"},{"type":"text","text":" "},{"type":"text","text":"be incorrect to mask "},{"code":"expired","type":"codeVoice"},{"text":" if you want to allow","type":"text"},{"type":"text","text":" "},{"type":"text","text":"expired certificates, because this could potentially be the only"},{"text":" ","type":"text"},{"text":"error flag set even if other problems exist with the certificate.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prior to GLib 2.48, GLib’s default TLS backend modified "},{"code":"chain","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"represent the certification path built by "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","isActive":true,"type":"reference"},{"text":" during","type":"text"},{"text":" ","type":"text"},{"text":"certificate verification by adjusting the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true},{"text":" ","type":"text"},{"text":"property of each certificate in ","type":"text"},{"code":"chain","type":"codeVoice"},{"type":"text","text":". Since GLib 2.48, this no"},{"type":"text","text":" "},{"type":"text","text":"longer occurs, so you cannot rely on "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference","isActive":true},{"text":" to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"represent the actual certification path used during certificate"},{"type":"text","text":" "},{"text":"verification.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because TLS session context is not used, "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","isActive":true,"type":"reference"},{"text":" may not","type":"text"},{"text":" ","type":"text"},{"text":"perform as many checks on the certificates as ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"text":" would.","type":"text"},{"text":" ","type":"text"},{"text":"For example, certificate constraints may not be honored, and","type":"text"},{"type":"text","text":" "},{"text":"revocation checks may not be performed. The best way to verify TLS","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificates used by a TLS connection is to let "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" "},{"type":"text","text":"handle the verification."}]},{"inlineContent":[{"type":"text","text":"The TLS backend may attempt to look up and add missing certificates"},{"text":" ","type":"text"},{"type":"text","text":"to the chain. This may involve HTTP requests to download missing"},{"text":" ","type":"text"},{"type":"text","text":"certificates."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function can block. Use ","type":"text"},{"type":"codeVoice","code":"g_tls_database_verify_chain_async()"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"perform the verification operation asynchronously."}]}]}],"references":{"doc://GIO/documentation/GIO/TLSFileDatabaseRef":{"url":"\/documentation\/gio\/tlsfiledatabaseref","abstract":[{"type":"codeVoice","code":"GTlsFileDatabase"},{"text":" is implemented by [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","type":"reference","isActive":true},{"type":"text","text":"] objects which"},{"type":"text","text":" "},{"text":"load their certificate information from a file. It is an interface which","type":"text"},{"type":"text","text":" "},{"type":"text","text":"TLS library specific subtypes implement."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSFileDatabaseRef","role":"symbol","navigatorTitle":[{"text":"TLSFileDatabaseRef","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TLSFileDatabaseRef"}],"type":"topic","kind":"symbol","title":"TLSFileDatabaseRef"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSServerConnec