ib does not provide any way to know","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which certification path will actually be used when verifying a TLS"},{"text":" ","type":"text"},{"type":"text","text":"certificate. Accordingly, this function cannot be used to make"},{"type":"text","text":" "},{"type":"text","text":"security-related decisions. Only GLib itself should make security"},{"type":"text","text":" "},{"text":"decisions about TLS certificates.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/tlsfiledatabaseref\/lookupcertificateissuer(certificate:interaction:flags:cancellable:)-50x4k"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSFileDatabaseRef","doc:\/\/GIO\/documentation\/GIO\/TLSFileDatabaseRef\/TLSDatabaseProtocol-Implementations"]]},"kind":"symbol","abstract":[{"type":"text","text":"Look up the issuer of "},{"type":"codeVoice","code":"certificate"},{"text":" in the database. The","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true},{"type":"text","text":" property of "},{"code":"certificate","type":"codeVoice"},{"type":"text","text":" is not modified, and"},{"type":"text","text":" "},{"type":"text","text":"the two certificates are not hooked into a chain."}],"sections":[],"metadata":{"roleHeading":"Instance Method","modules":[{"name":"GIO"}],"title":"lookupCertificateIssuer(certificate:interaction:flags:cancellable:)","role":"symbol","externalID":"s:3GIO19TLSDatabaseProtocolPAAE23lookupCertificateIssuer11certificate11interaction5flags11cancellableAA17TLSCertificateRefVSgqd_0__qd_1_SgSo23GTlsDatabaseLookupFlagsaqd__SgtKAA011CancellableC0Rd__AA0kC0Rd_0_AA014TLSInteractionC0Rd_1_r1_lF::SYNTHESIZED::s:3GIO18TLSFileDatabaseRefV","symbolKind":"method","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"}