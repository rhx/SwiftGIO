ntent":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"It is an error if ","type":"text"},{"type":"codeVoice","code":"parameters"},{"text":" is not of the right format: it must be a tuple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"containing the out-parameters of the D-Bus method. Even if the method has a"},{"text":" ","type":"text"},{"type":"text","text":"single out-parameter, it must be contained in a tuple. If the method has no"},{"type":"text","text":" "},{"type":"text","text":"out-parameters, "},{"type":"codeVoice","code":"parameters"},{"type":"text","text":" may be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" or an empty tuple."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":["GDBusMethodInvocation *invocation = some_invocation;","g_autofree gchar *result_string = NULL;","g_autoptr (GError) error = NULL;","","result_string = calculate_result (&error);","","if (error != NULL)","  g_dbus_method_invocation_return_gerror (invocation, error);","else","  g_dbus_method_invocation_return_value (invocation,","                                         g_variant_new (\"(s)\", result_string));","","\/\/ Do not free @invocation here; returning a value does that"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"This method will take ownership of ","type":"text"},{"code":"invocation","type":"codeVoice"},{"type":"text","text":". See"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","isActive":true},{"text":" for more information about the ownership of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"invocation"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Since 2.48, if the method call requested for a reply not to be sent","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then this call will sink "},{"type":"codeVoice","code":"parameters"},{"type":"text","text":" and free "},{"code":"invocation","type":"codeVoice"},{"text":", but","type":"text"},{"text":" ","type":"text"},{"text":"otherwise do nothing (as per the recommendations of the D-Bus","type":"text"},{"type":"text","text":" "},{"type":"text","text":"specification)."}]}]}],"variants":[{"paths":["\/documentation\/gio\/dbusmethodinvocationprotocol\/returnvalue(parameters:)-41rj1"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"references":{"doc://GIO/documentation/GIO/DBusMethodInvocationProtocol/returnValue(parameters:)-41rj1":{"url":"\/documentation\/gio\/dbusmethodinvocationprotocol\/returnvalue(parameters:)-41rj1","title":"returnValue(parameters:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationProtocol\/returnValue(parameters:)-41rj1","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"returnValue"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GLibVariantT"},{"text":">(","kind":"text"},{"text":"parameters","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GLibVariantT","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"abstract":[{"type":"text","text":"Finishes handling a D-Bus method call by returning "},{"code":"parameters","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"If the "},{"type":"codeVoice","code":"parameters"},{"type":"text","text":" GVariant is floating, it is consumed."}]},"doc://GIO/documentation/GIO/DBusMethodInvocationProtocol":{"role":"symbol","abstract":[{"type":"text","text":"Instances of the "},{"type":"codeVoice","code":"GDBusMethodInvocation"},{"text":" class are used when","type":"text"},{"text":" ","type":"text"},{"text":"handling D-Bus method calls. It provides a way to asynchronously","type":"text"},{"type":"text","text":" "},{"text":"return results and errors.","type":"text"}],"url":"\/documentation\/gio\/dbusmethodinvocationprotocol","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"DBusMethodInvocationProtocol","kind":"identifier"}],"title":"DBusMethodInvocationProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationProtocol","navigatorTitle":[{"text":"DBusMethodInvocationProtocol","kind":"identifier"}],"type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusInterfaceVTable":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"DBusInterfaceVTable","kind":"identifier"}],"navigatorTitle":[{"text":"DBusInterfaceVTable","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","type":"topic","abstract":[{"type":"text","text":"Virtual table for handling properties and method calls for a D-Bus"},{"text":" ","type":"text"},{"text":"interface.","type":"text"}],"title":"DBusInterfaceVTable","url":"\/documentation\/gio\/dbusinterfacevtable","kind":"symbol","role":"symbol"}}}