{"sections":[],"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ProxyAddressEnumeratorSignalName"]]},"variants":[{"paths":["\/documentation\/gio\/proxyaddressenumeratorsignalname\/notify"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"externalID":"s:3GIO32ProxyAddressEnumeratorSignalNameO6notifyyA2CmF","role":"symbol","symbolKind":"case","roleHeading":"Case","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notify"}],"modules":[{"name":"GIO"}],"title":"ProxyAddressEnumeratorSignalName.notify"},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ProxyAddressEnumeratorSignalName\/notify"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notify","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbo