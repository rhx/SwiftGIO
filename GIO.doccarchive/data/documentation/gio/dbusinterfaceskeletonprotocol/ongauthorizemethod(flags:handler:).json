{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"abstract":[{"text":"Emitted when a method is invoked by a remote caller and used to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"determine if the method call is authorized."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onGAuthorizeMethod","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":" = ConnectFlags(0), "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"text":"DBusInterfaceSkeletonRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeletonRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO24DBusInterfaceSkeletonRefV"},{"text":", ","kind":"text"},{"text":"DBusMethodInvocationRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef","preciseIdentifier":"s:3GIO23DBusMethodInvocationRefV","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}]},{"parameters":[{"name":"flags","content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the call is authorized, "},{"type":"codeVoice","code":"false"},{"text":" otherwise.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"gAuthorizeMethod"},{"type":"text","text":" signal is emitted"}]}],"name":"handler"}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Note that this signal is emitted in a thread dedicated to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handling the method call so handlers are allowed to perform"},{"type":"text","text":" "},{"type":"text","text":"blocking IO. This means that it is appropriate to call e.g."},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#polkit-authority-check-authorization-sync"},{"type":"text","text":" "},{"type":"text","text":"with the"},{"type":"text","text":" "},{"identifier":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#POLKIT-CHECK-AUTHORIZATION-FLAGS-ALLOW-USER-INTERACTION:CAPS","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"flag set."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned then no further handlers are run and the"},{"type":"text","text":" "},{"type":"text","text":"signal handler must take a reference to "},{"code":"invocation","type":"codeVoice"},{"type":"text","text":" and finish"},{"type":"text","text":" "},{"text":"handling the call (e.g. return an error via","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_dbus_method_invocation_return_error()"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Otherwise, if "},{"type":"codeVoice","code":"true"},{"text":" is returned, signal emission continues. If no","type":"text"},{"type":"text","text":" "},{"text":"handlers return ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", then the method is dispatched. If","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"interface"},{"type":"text","text":" has an enclosing "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeleton","type":"reference","isActive":true},{"type":"text","text":", then the"},{"type":"text","text":" "},{"text":"[DBusObjectSkeleton](\/\/documentation\/gio\/dbusobjectskeleton\/onauthorizemethod(flags:handler:) signal handlers run before","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the handlers for this signal."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default class handler just returns "},{"code":"true","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Please note that the common case is optimized: if no signals"},{"text":" ","type":"text"},{"text":"handlers are connected and the default class handler isn’t","type":"text"},{"text":" ","type":"text"},{"text":"overridden (for both ","type":"text"},{"type":"codeVoice","code":"interface"},{"type":"text","text":" and the enclosing"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeleton","type":"reference","isActive":true},{"text":", if any) and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeleton","type":"reference"},{"text":" does","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"not have the"},{"text":" ","type":"text"},{"code":"handleMethodInvocationsInThread","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"flags set, no dedicated thread is ever used and the call will be"},{"type":"text","text":" "},{"text":"handled in the same thread as the object that ","type":"text"},{"type":"codeVoice","code":"interface"},{"text":" belongs","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to was exported in."}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"g-authorize-method"},{"type":"text","text":" signal"}]}]}],"kind":"content"}],"metadata":{"modules":[{"name":"GIO"}],"externalID":"s:3GIO29DBusInterfaceSkeletonProtocolPAAE18onGAuthorizeMethod5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0bcD3RefV_AA0bh10InvocationO0VtctF","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onGAuthorizeMethod","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"preciseIdentifier":"s:3GIO24DBusInterfaceSkeletonRefV","text":"DBusInterfaceSkeletonRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"DBusMethodInvocationRef","preciseIdentifier":"s:3GIO23DBusMethodInvocationRefV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Method","symbolKind":"method","role":"symbol","title":"onGAuthorizeMethod(flags:handler:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusinterfaceskeletonprotocol\/ongauthorizemethod(flags:handler:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeletonProtocol\/onGAuthorizeMethod(flags:handler:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeletonProtocol"]]},"kind":"symbol","references":{"doc://GIO/documentation/GIO/DBusInterfaceSkeletonProtocol/onGAuthorizeMethod(flags:handler:)":{"url":"\/documentation\/gio\/dbusinterfaceskeletonprotocol\/ongauthorizemethod(flags:handler: