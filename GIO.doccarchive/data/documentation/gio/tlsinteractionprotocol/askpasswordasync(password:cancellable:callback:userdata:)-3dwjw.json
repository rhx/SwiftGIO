{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Derived subclasses usually implement a password prompt, although they may"},{"type":"text","text":" "},{"type":"text","text":"also choose to provide a password from elsewhere. The "},{"type":"codeVoice","code":"password"},{"type":"text","text":" value will"},{"type":"text","text":" "},{"text":"be filled in and then ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called. Alternatively the user may"},{"text":" ","type":"text"},{"type":"text","text":"abort this password request, which will usually abort the TLS connection."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the interaction is cancelled by the cancellation object, or by the"},{"type":"text","text":" "},{"type":"text","text":"user then "},{"type":"codeVoice","code":"failed"},{"text":" will be returned with an error that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"contains a "},{"code":"cancelled","type":"codeVoice"},{"text":" error code. Certain implementations may","type":"text"},{"type":"text","text":" "},{"text":"not support immediate cancellation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Certain implementations may not support immediate cancellation.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/TLSInteractionProtocol":{"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TLSInteractionProtocol"}],"abstract":[{"type":"codeVoice","code":"GTlsInteraction"},{"text":" provides a mechanism for the TLS connection and database","type":"text"},{"type":"text","text":" "},{"text":"code to interact with the user. It can be used to ask the user for passwords.","type":"text"}],"title":"TLSInteractionProtocol","type":"topic","url":"\/documentation\/gio\/tlsinteractionprotocol","identifier"