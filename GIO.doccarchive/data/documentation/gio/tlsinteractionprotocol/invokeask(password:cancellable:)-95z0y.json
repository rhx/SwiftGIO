 common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSDatabase":{"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","role":"symbol","url":"\/documentation\/gio\/tlsdatabase","abstract":[{"type":"codeVoice","code":"GTlsDatabase"},{"type":"text","text":" is used to look up certificates and other information"},{"type":"text","text":" "},{"type":"text","text":"from a certificate or key store. It is an abstract base class which"},{"text":" ","type":"text"},{"type":"text","text":"TLS library specific subtypes override."}],"navig