callback","type":"codeVoice"},{"type":"text","text":" will be called. Alternatively the user may"},{"text":" ","type":"text"},{"text":"abort this password request, which will usually abort the TLS connection.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The implementation can either be a synchronous (eg: modal dialog) or an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"asynchronous one (eg: modeless dialog). This function will take care of"},{"type":"text","text":" "},{"type":"text","text":"calling which ever one correctly."}]},{"inlineContent":[{"text":"If the interaction is cancelled by the cancellation object, or by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"user then "},{"type":"codeVoice","code":"failed"},{"type":"text","text":" will be returned with an error that"},{"type":"text","text":" "},{"type":"text","text":"contains a "},{"code":"cancelled","type":"codeVoice"},{"text":" error code. Certain implementations may","type":"text"},{"type":"text","text":" "},{"text":"not support immediate cancellation.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsinteractionprotocol\/invokeask(password:cancellable:)-95z0y"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionProtocol\/invokeAsk(password:cancellable:)-95z0y"},"abstract":[{"text":"Invoke the interaction to ask the user for a password. It invokes this","type":"text"},{"type":"text","text":" "},{"text":"interaction in the main loop, specifically the [MainContext](\/\/documentation\/glib\/maincontext returned by","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_main_context_get_thread_default()"},{"type":"text","text":" when the interaction is created. This"},{"text":" ","type":"text"},{"text":"is called by called by ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" or "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase"},{"text":" to ask the user","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for a password."}],"kind":"symbol","metadata":{"symbolKind":"method","modules":[{"name":"GIO"}],"extendedModule":"GIO","externalID":"s:3GIO22TLSInteractionProtocolPAAE9invokeAsk8password11cancellableSo21GTlsInteractionResultaqd_0__qd__SgtKAA011CancellableC0Rd__AA011TLSPasswordC0Rd_0_r0_lF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"invokeAsk","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"TLSPasswordT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"password","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"TLSPasswordT"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"GTlsInteractionResult","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GTlsInteractionResult"}],"title":"invokeAsk(password:cancellable:)","roleHeading":"Instance Method","role":"symbol"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSInteractionProtocol"]]},"references":{"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"s