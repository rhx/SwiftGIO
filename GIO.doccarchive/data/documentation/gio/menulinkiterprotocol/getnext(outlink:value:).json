that fails, then ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" is returned and there are no other effects.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If successful, "},{"type":"codeVoice","code":"outLink"},{"type":"text","text":" and "},{"code":"value","type":"codeVoice"},{"type":"text","text":" are set to the name and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel"},{"text":" ","type":"text"},{"text":"of the link that has just been advanced to.  At this point,","type":"text"},{"type":"text","text":" "},{"code":"g_menu_link_iter_get_name()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"g_menu_link_iter_get_value()","type":"codeVoice"},{"type":"text","text":" will return the"},{"type":"text","text":" "},{"text":"same values again.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The value returned in "},{"type":"codeVoice","code":"outLink"},{"type":"text","text":" remains valid for as long as the iterator"},{"text":" ","type":"text"},{"text":"remains at the current position.  The value returned in ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" must"},{"text":" ","type":"text"},{"text":"be unreffed using ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"text":" when it is no longer in use.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","title":"getNext(outLink:value:)","extendedModule":"GIO","externalID":"s:3GIO20MenuLinkIterProtocolPAAE7getNext03outC05valueSbSpySPys4Int8VGSgGSg_SpySpySo11_GMenuModelVGSgGSgtF","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getNext","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"outLink"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"Unsafe