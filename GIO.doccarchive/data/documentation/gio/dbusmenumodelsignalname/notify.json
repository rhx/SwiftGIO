text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelSignalName"]]},"variants":[{"paths":["\/documentation\/gio\/dbusmenumodelsignalname\/notify"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"#class@GObject.ParamSpec#parameter-names":{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"link","titleInlineContent":[{"type":"text","text":"canonical parameter names"}],"url":"#class@GObject.ParamSpec#paramete