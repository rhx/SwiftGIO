{"variants":[{"paths":["\/documentation\/gio\/applicationsignalname\/handlelocaloptions"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"The ","type":"text"},{"code":"handle-local-options","type":"codeVoice"},{"type":"text","text":" signal is emitted on the local instance"},{"type":"text","text":" "},{"type":"text","text":"after the parsing of the commandline options has occurred."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationSignalName\/handleLocalOptions"},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationSignalName"]]},"metadata":{"symbolKind":"case","roleHeading":"Case","title":"ApplicationSignalName.handleLocalOptions","role":"symbol","externalID":"s:3GIO21ApplicationSignalNameO18handleLocalOptionsyA2CmF","modules":[{"name":"GIO"}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"handleLocalOptions","kind":"identifier"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"handleLocalOptions"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"You can add options to be recognised during commandline option"},{"type":"text","text":" "},{"text":"parsing using ","type":"text"},{"type":"codeVoice","code":"g_application_add_main_option_entries()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_application_add_option_group()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Signal handlers can inspect ","type":"text"},{"code":"options","type":"codeVoice"},{"type":"text","text":" (along with values pointed to"},{"type":"text","text":" "},{"type":"text","text":"from the "},{"type":"codeVoice","code":"arg_data"},{"type":"text","text":" of an installed "},{"type":"codeVoice","code":"GOptionEntrys"},{"type":"text","text":") in order to"},{"type":"text","text":" "},{"text":"decide to perform certain actions, including direct local handling","type":"text"},{"type":"text","text":" "},{"text":"(which may be useful for options like –version).","type":"text"}]},{"inlineContent":[{"type":"text","text":"In the event that the application is marked"},{"type":"text","text":" "},{"code":"handlesCommandLine","type":"codeVoice"},{"text":" the “normal processing” will","type":"text"},{"text":" ","type":"text"},{"text":"send the ","type":"text"},{"code":"options","type":"codeVoice"},{"type":"text","text":" dictionary to the primary instance where it can be"},{"type":"text","text":" "},{"text":"read with ","type":"text"},{"type":"codeVoice","code":"g_application_command_line_get_options_dict()"},{"type":"text","text":".  The signal"},{"text":" ","type":"text"},{"type":"text","text":"handler can modify the dictionary before returning, and the"},{"type":"text","text":" "},{"text":"modified dictionary will be sent.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that "},{"type":"codeVoice","code":"handlesCommandLine"},{"text":" is not set,","type":"text"},{"text":" ","type":"text"},{"text":"“normal processing” will treat the remaining uncollected command","type":"text"},{"type":"text","text":" "},{"type":"text","text":"line arguments as filenames or URIs.  If there are no arguments,"},{"type":"text","text":" "},{"text":"the application is activated by ","type":"text"},{"type":"codeVoice","code":"g_application_activate()"},{"text":".  One or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"more arguments results in a call to "},{"code":"g_application_open()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"If you want to handle the local commandline arguments for yourself"},{"text":" ","type":"text"},{"text":"by converting them to calls to ","type":"text"},{"code":"g_application_open()","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_action_group_activate_action()"},{"type":"text","text":" then you must be sure to register"},{"text":" ","type":"text"},{"type":"text","text":"the application first.  You should probably not call"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_application_activate()"},{"type":"text","text":" for yourself, however: just return -1 and"},{"type":"text","text":" "},{"text":"allow the default handler to do it for you.  This will ensure that","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"--gapplication-service"},{"type":"text","text":" switch works properly (i.e. no activation"},{"type":"text","text":" "},{"text":"in that case).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that this signal is emitted from the default implementation of"},{"type":"text","text":" "},{"type":"codeVoice","code":"local_command_line()"},{"text":".  If you override that function and don’t","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"chain up then this signal will never be emitted."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can override "},{"type":"codeVoice","code":"local_command_line()"},{"text":" if you need more powerful","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"capabilities than what is provided here, but this should not"},{"text":" ","type":"text"},{"type":"text","text":"normally be required."}]}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/ApplicationSignalName/handleLocalOptions":{"abstract":[{"text":"The ","type":"text"},{"code":"handle-local-options","type":"codeVoice"},{"text":" signal 