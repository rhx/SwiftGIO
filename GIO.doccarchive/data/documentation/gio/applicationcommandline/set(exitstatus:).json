{"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"exitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"The return value of the [Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:) signal is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"passed to this function when the handler returns.  This is the usual"},{"text":" ","type":"text"},{"type":"text","text":"way of setting the exit status."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the event that you want the remote invocation to continue running"},{"text":" ","type":"text"},{"text":"and want to decide on the exit status in the future, you can use this","type":"text"},{"text":" ","type":"text"},{"text":"call.  For the case of a remote invocation, the remote process will","type":"text"},{"text":" ","type":"text"},{"text":"typically exit when the last reference is dropped on ","type":"text"},{"type":"codeVoice","code":"cmdline"},{"type":"text","text":".  The"},{"type":"text","text":" "},{"type":"text","text":"exit status of the remote process will be equal to the last value"},{"text":" ","type":"text"},{"type":"text","text":"that was set with this function."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the case that the commandline invocation is local, the situation"},{"text":" ","type":"text"},{"text":"is slightly more complicated.  If the commandline invocation results","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in the mainloop running (ie: because the use-count of the application"},{"type":"text","text":" "},{"type":"text","text":"increased to a non-zero value) then the application is considered to"},{"type":"text","text":" "},{"type":"text","text":"have been ‘successful’ in a certain sense, and the exit status is"},{"type":"text","text":" "},{"text":"always zero.  If the application use count is zero, though, the exit","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"status of the local "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","type":"reference"},{"text":" is used.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This method is a no-op if ","type":"text"},{"type":"codeVoice","code":"g_application_command_line_done()"},{"text":" has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been called."}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/ApplicationCommandLineProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/set(exitStatus:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationcommandline\/set(exitstatus:)"]}],"metadata":{"role":"symbol","externalID":"s:3GIO30ApplicationCommandLineProtocolPAAE3set10exitStatusySi_tF::SYNTHESIZED::s:3GIO22ApplicationCommandLineC","extendedModule":"GIO","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"exitStatus","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":")"}],"symbolKind":"method","title":"set(exitStatus:)","roleHeading":"Instance Method"},"sections":[],"abstract":[{"type":"text","text":"Sets the exit status that will be used when the invoking process"},{"text":" ","type":"text"},{"text":"exits.","type":"text"}],"references":{"doc://GIO/documentation/GIO/ApplicationCommandLine/ApplicationCommandLineProtocol-Implementations":{"kind":"article","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/ApplicationCommandLineProtocol-Implementations","type":"topic","url":"\/documentation\/gio\/applicationcommandline\/applicationcommandlineprotocol-implementations","title":"ApplicationCommandLineProtocol Implementations"},"doc://GIO/documentation/GIO/ApplicationCommandLine/set(exitStatus:)":{"type":"topic","kind":"symbol","url":"\/documentation\/gio\/applicationcommandline\/set(exitstatus:)","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/set(exitStatus:)","title":"set(exitStatus:)","abstract":[{"type":"text","text":"Sets the exit status that will be used when the invoking process"},{"type":"text","text":" "},{"type":"text","text":"exits."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"exitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ApplicationCommandLine":{"title":"ApplicationCommandLine","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApplicationCommandLine","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"ApplicationCommandLine"}],"url":"\/documentation\/gio\/applicationcommandline","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","abstract":[{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" represents a command-line invocation of","type":"text"},{"type":"text","text":" "},{"text":"an application.","type":"text"}],"role":"symbol"}}}