{"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"variants":[{"paths":["\/documentation\/gio\/dbusproxy\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"type":"text","text":" "},{"code":"g_initable_new()","type":"codeVoice"},{"type":"text","text":" should typically be used instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The object must be initialized before any real use after initial"},{"text":" ","type":"text"},{"type":"text","text":"construction, either with this function or "},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"text":" ","type":"text"},{"text":"from another thread. If the operation was cancelled, the error","type":"text"},{"text":" ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"inlineContent":[{"text":"If the object is not initialized, or initialization returns with an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"error, then all operations on the object except "},{"code":"g_object_ref()","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"g_object_unref()","type":"codeVoice"},{"text":" are considered to be invalid, and have undefined","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behaviour. See the "},{"type":"reference","identifier":"#iface@Gio.Initable#description","isActive":true},{"text":" for more details.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"type":"text","text":" can be"},{"type":"text","text":" "},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"type":"text","text":" "},{"type":"text","text":"supporting this. Generally, a class’ implementation of "},{"code":"init()","type":"codeVoice"},{"type":"text","text":" can assume"},{"type":"text","text":" "},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"text":" ","type":"text"},{"text":"recommended all ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" implementations should be idempotent; that"},{"type":"text","text":" "},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}],"type":"paragraph"},{"inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"type":"text","text":" "},{"text":"arguments should return the same results. Only the first call initializes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the object; further calls return the result of the first call."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"text":" ","type":"text"},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"type":"text","text":" "},{"code":"GObjectClass.constructor","type":"codeVoice"},{"text":" that sometimes returns an existing instance.","type":"text"},{"type":"text","text":" "},{"text":"In this pattern, a caller would expect to be able to call ","type":"text"},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"on the result of "},{"code":"g_object_new()","type":"codeVoice"},{"text":", regardless of whether it is in fact a new","type":"text"},{"type":"text","text":" "},{"text":"instance.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusProxy\/init_(cancellable:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","metadata":{"modules":[{"name":"GIO"}],"title":"init_(cancellable:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO9DBusProxyC","symbolKind":"method","extendedModule":"GIO","roleHeading":"Instance Method"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusProxy","doc:\/\/GIO\/documentation\/GIO\/DBusProxy\/InitableProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/DBusProxy/init_(cancellable:)":{"title":"init_(cancellable:)","type":"topic","url":"\/documentation\/gio\/dbusproxy\/init_(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxy\/init_(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"kind":"symbol","role":"symbol","abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}]},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/DBusProxy":{"kind":"symbol","abstract":[{"code":"GDBusProxy","type":"codeVoice"},{"type":"text","text":" is a base class used for proxies to access a D-Bus"},{"text":" ","type":"text"},{"text":"interface on a remote object. A ","type":"text"},{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":" can be constructed for"},{"type":"text","text":" "},{"text":"both well-known and unique names.","type":"text"}],"title":"DBusProxy","type":"topic","url":"\/documentation\/gio\/dbusproxy","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxy","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusProxy"}],"navigatorTitle":[{"text":"DBusProxy","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"#iface@Gio.Initable#description":{"identifier":"#iface@Gio.Initable#description","title":"description","titleInlineContent":[{"text":"description","type":"text"}],"url":"#iface@Gio.Initable#description","type":"link"},"doc://GIO/documentation/GIO/DBusProxy/InitableProtocol-Implementations":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxy\/InitableProtocol-Implementations","title":"InitableProtocol Implementations","type":"topic","url":"\/documentation\/gio\/dbusproxy\/initableprotocol-implementations","abstract":[]},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}