"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusMenuModelRef/MenuModelProtocol-Implementations":{"type":"topic","abstract":[],"role":"collectionGroup","title":"MenuModelProtocol Implementations","url":"\/documentation\/gio\/dbusmenumodelref\/menumodelprotocol-implementations","kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/MenuModelProtocol-Implementations"}}}