":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/DBusMenuModelRef":{"abstract":[{"code":"GDBusMenuModel","type":"codeVoice"},{"text":" is an implementation of [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"text":"] that can be","type":"text"},{"type":"text","text":" "},{"text":"used as a proxy for a menu model that is exported over D-Bus with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.DBusConnection.export_menu_model","type":"codeVoice"},{"type":"text","text":"]."}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/dbusmenumodelref","type":"topic","navigatorTitle":[{"text":"DBusMenuModelRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DBusMenuModelRef"}],"title":"DBusMenuModelRef"}}}