ocumentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/DBusMenuModelRef/ObjectProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/ObjectProtocol-Implementations","url":"\/documentation\/gio\/dbusmenumodelref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusMenuModelRef":{"abstract":[{"code":"GDBusMenuModel","type":"codeVoice"},{"text":" is an implementation of [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"text":"] that can be","type":"text"},{"type":"text","text":" "},{"text":"used as a proxy for a menu model that is exported over D-Bus with"