enuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/DBusMenuModelRef/isFloating":{"type":"topic","title":"isFloating","abstract":[],"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/dbusmenumodelref\/isfloating","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isFloating","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/isFloating"},"doc://GIO/documentation/GIO/DBusMenuModelRef/ObjectProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/ObjectProtocol-Implementations","url":"\/documentation\/gio\/dbusmenumodelref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusMenuModelRef":{"abstract":[{"code":"GDBusMenuModel","type":"codeVoice"},{"text":" is an implementation of [class","type":"tex