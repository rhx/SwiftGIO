e":true,"type":"reference"},{"text":"] that can be","type":"text"},{"type":"text","text":" "},{"text":"used as a proxy for a menu model that is exported over D-Bus with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.DBusConnection.export_menu_model","type":"codeVoice"},{"type":"text","text":"]."}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/dbusmenumodelref","type":"topic","navigatorTitle":[{"text":"DBusMenuModelRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DBusMenuModelRef"}],"title":"DBusMenuModelRef"},"doc://GIO/documentation/GIO/DBusMenuModelRef/ObjectProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/ObjectProtocol-Implementations","url":"\/documentation\/gio\/dbusmenumodelref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/DBusMenuModelRef/takeRef()":{"type":"topic","url":"\/documentation\/gio\/dbusmenumodelref\/takeref()","kind":"symbol","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/takeRef()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}],"title":"takeRef()"},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]}}}