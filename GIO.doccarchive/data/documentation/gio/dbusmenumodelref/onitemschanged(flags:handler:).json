{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/onItemsChanged(flags:handler:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/gio\/dbusmenumodelref\/onitemschanged(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef","doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/MenuModelProtocol-Implementations"]]},"kind":"symbol","metadata":{"externalID":"s:3GIO17MenuModelProtocolPAAE14onItemsChanged5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_S3itctF::SYNTHESIZED::s:3GIO16DBusMenuModelRefV","symbolKind":"method","role":"symbol","extendedModule":"GIO","title":"onItemsChanged(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onItemsChanged"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"preciseIdentifier":"s:3GIO12MenuModelRefV","text":"MenuModelRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Method","modules":[{"name":"GIO"}]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onItemsChanged","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","preciseIdentifier":"s:3GIO12MenuModelRefV","kind":"typeIdentifier","text":"MenuModelRef"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}]},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"itemsChanged"},{"text":" signal is emitted","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The only changes that can occur to a menu is that items are removed"},{"text":" ","type":"text"},{"type":"text","text":"or added.  Items may not change (except by being removed and added"},{"text":" ","type":"text"},{"text":"back in the same location).  This signal is capable of describing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"both of those changes (at the same time)."}]},{"inlineContent":[{"type":"text","text":"The signal means that starting at the index "},{"code":"position","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"removed"},{"text":" ","type":"text"},{"text":"items were removed and ","type":"text"},{"type":"codeVoice","code":"added"},{"type":"text","text":" items were added in their place.  If"},{"type":"text","text":" "},{"code":"removed","type":"codeVoice"},{"type":"text","text":" is zero then only items were added.  If "},{"type":"codeVoice","code":"added"},{"type":"text","text":" is zero"},{"text":" ","type":"text"},{"text":"then only items were removed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As an example, if the menu contains items a, b, c, d (in that"},{"type":"text","text":" "},{"type":"text","text":"order) and the signal (2, 1, 3) occurs then the new composition of"},{"text":" ","type":"text"},{"type":"text","text":"the menu will be a, b, _, _, _, d (with each _ representing some"},{"text":" ","type":"text"},{"text":"new item).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Signal handlers may query the model (particularly the added items)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and expect to see the results of the modification that is being"},{"type":"text","text":" "},{"type":"text","text":"reported.  The signal is emitted after the modification."}]},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"items-changed"},{"type":"text","text":" signal"}]}],"style":"note"}]}],"abstract":[{"type":"text","text":"Emitted when a change has occurred to the menu."}],"references":{"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusMenuModelRef/MenuModelProtocol-Implementations":{"type":"topic","abstract":[],"role":"collectionGroup","title":"MenuModelProtocol Implementations","url":"\/documentation\/gio\/dbusmenumodelref\/menumodelprotocol-implementations","kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/MenuModelProtocol-Implementations"},"doc://GIO/documentation/GIO/DBusMenuModelRef":{"abstract":[{"code":"GDBusMenuModel","type":"codeVoice"},{"text":" is an implementation of [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"text":"] that can be","type":"text"},{"type":"text","text":" "},{"text":"used as a proxy for a menu model that is exported over D-Bus with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.DBusConnection.export_menu_model","type":"codeVoice"},{"type":"text","text":"]."}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/dbusmenumodelref","type":"topic","navigatorTitle":[{"text":"DBusMenuModelRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DBusMenuModelRef"}],"title":"DBusMenuModelRef"},"doc://GIO/documentation/GIO/DBusMenuModelRef/onItemsChanged(flags:handler:)":{"title":"onItemsChanged(flags:handler:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef\/onItemsChanged(flags:handler:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onItemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"text":"MenuModelRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO12MenuModelRefV"},{"kind":"text","text":", "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"type":"topic","kind":"symbol","url":"\/documentation\/gio\/dbusmenumodelref\/onitemschanged(flags:handler:)","role":"symbol","abstract":[{"type":"text","text":"Emitted when a change has occurred to the menu."}]},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]}}}