{"abstract":[{"text":"Queries the range of a key.","type":"text"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyRef\/range","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyRef","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyRef\/SettingsSchemaKeyProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"range","kind":"identifier"},{"kind":"text","text":": "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"! { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"This function will return a [Variant](\/\/documentation\/glib\/variant that fully describes the range","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of values that are valid for "},{"type":"codeVoice","code":"key"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The type of [Variant](\/\/documentation\/glib\/variant returned is ","type":"text"},{"code":"(sv)","type":"codeVoice"},{"text":". The string describes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the type of range restriction in effect. The type and meaning of"},{"type":"text","text":" "},{"type":"text","text":"the value contained in the variant depends on the string."}]},{"inlineContent":[{"type":"text","text":"If the string is "},{"code":"'type'","type":"codeVoice"},{"text":" then the variant contains an empty array.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The element type of that empty array is the expected type of value"},{"text":" ","type":"text"},{"type":"text","text":"and all values of that type are valid."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the string is "},{"type":"codeVoice","code":"'enum'"},{"text":" then the variant contains an array","type":"text"},{"type":"text","text":" "},{"type":"text","text":"enumerating the possible values. Each item in the array is"},{"text":" ","type":"text"},{"text":"a possible valid value and no other values are valid.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the string is ","type":"text"},{"code":"'flags'","type":"codeVoice"},{"text":" then the variant contains an array. Each","type":"text"},{"type":"text","text":" "},{"text":"item in the array is a value that may appear zero or one times in an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"array to be used as the value for this key. For example, if the"},{"text":" ","type":"text"},{"type":"text","text":"variant contained the array "},{"type":"codeVoice","code":"['x', 'y']"},{"text":" then the valid values for","type":"text"},{"type":"text","text":" "},{"text":"the key would be ","type":"text"},{"code":"[]","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"['x']"},{"type":"text","text":", "},{"code":"['y']","type":"codeVoice"},{"type":"text","text":", "},{"code":"['x', 'y']","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"['y', 'x']","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Finally, if the string is "},{"type":"codeVoice","code":"'range'"},{"type":"text","text":" then the variant contains a pair"},{"type":"text","text":" "},{"type":"text","text":"of like-typed values – the minimum and maximum permissible values"},{"type":"text","text":" "},{"text":"for this key.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This information should not be used by normal programs.  It is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"considered to be a hint for introspection purposes.  Normal programs"},{"type":"text","text":" "},{"text":"should already know what is permitted by their own schema.  The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"format may change in any way in the future – but particularly, new"},{"type":"text","text":" "},{"type":"text","text":"forms may be added to the possibilities described above."}]},{"inlineContent":[{"type":"text","text":"You should free the returned value with "},{"type":"codeVoice","code":"g_variant_unref()"},{"text":" when it is","type":"text"},{"type":"text","text":" "},{"text":"no longer needed.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"range","kind":"identifier"},{"kind":"text","text":": "},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"title":"range","modules":[{"name":"GIO"}],"role":"symbol","externalID":"s:3GIO25SettingsSchemaKeyProtocolPAAE5range4GLib10VariantRefVSgvp::SYNTHESIZED::s:3GIO20SettingsSchemaKeyRefV","symbolKind":"property","roleHeading":"Instance Property","extendedModule":"GIO"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingsschemakeyref\/range"]}],"references":{"doc://GIO/documentation/GIO/SettingsSchemaKey":{"abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","isActive":true,"type":"reference"},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"text":" ","type":"text"},{"type":"text","text":"using the following functions."}],"url":"\/documentation\/gio\/settingsschemakey","type":"topic","kind":"symbol","title":"SettingsSchemaKey","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchemaKey"}],"navigatorTitle":[{"text":"SettingsSchemaKey","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey"},"doc://GIO/documentation/GIO/SettingsSchemaKeyRef/SettingsSchemaKeyProtocol-Implementations":{"abstract":[],"title":"SettingsSchemaKeyProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyRef\/SettingsSchemaKeyProtocol-Implementations","url":"\/documentation\/gio\/settingsschemakeyref\/settingsschemakeyprotocol-implementations","kind":"article","type":"topic","role":"collectionGroup"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SettingsSchemaKeyRef/range":{"abstract":[{"text":"Queries the range of a key.","type":"text"}],"url":"\/documentation\/gio\/settingsschemakeyref\/range","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyRef\/range","type":"topic","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"range","kind":"identifier"},{"text":": ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"title":"range"},"doc://GIO/documentation/GIO/SettingsSchemaKeyRef":{"navigatorTitle":[{"kind":"identifier","text":"SettingsSchemaKeyRef"}],"type":"topic","url":"\/documentation\/gio\/settingsschemakeyref","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SettingsSchemaKeyRef"}],"abstract":[{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","isActive":true},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"text":" ","type":"text"},{"text":"using the following functions.","type":"text"}],"title":"SettingsSchemaKeyRef","role":"symbol","kind":"symbol"}}}