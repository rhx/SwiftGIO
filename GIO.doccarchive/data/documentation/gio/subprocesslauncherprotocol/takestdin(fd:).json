{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncherProtocol\/takeStdin(fd:)"},"sections":[],"metadata":{"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeStdin","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"fd"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":")"}],"modules":[{"name":"GIO"}],"symbolKind":"method","title":"takeStdin(fd:)","role":"symbol","externalID":"s:3GIO26SubprocessLauncherProtocolPAAE9takeStdin2fdySi_tF","roleHeading":"Instance Method"},"abstract":[{"text":"Sets the file descriptor to use as the stdin for spawned processes.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncherProtocol"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeStdin","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fd","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"fd","type":"codeVoice"},{"type":"text","text":" is -1 then any previously given fd is unset."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if your intention is to have the stdin of the calling"},{"type":"text","text":" "},{"type":"text","text":"process inherited by the child then "},{"type":"codeVoice","code":"stdinInherit"},{"type":"text","text":" "},{"text":"is a better way to go about doing that.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The passed ","type":"text"},{"type":