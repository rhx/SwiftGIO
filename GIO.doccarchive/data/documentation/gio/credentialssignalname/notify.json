{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notify","kind":"identifier"}],"role":"symbol","symbolKind":"case","roleHeading":"Case","modules":[{"name":"GIO"}],"title":"CredentialsSignalName.notify","externalID":"s:3GIO21CredentialsSignalNameO6notifyyA2CmF"},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"text":", ","type":"text"},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/credentialssignalname\/notify"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notify"}]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CredentialsSignalName"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/CredentialsSignalName\/notify"},"sections":[],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"#class@GObject.ParamSpec#parameter-names":{"title"