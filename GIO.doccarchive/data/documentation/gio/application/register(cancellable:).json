{"metadata":{"extendedModule":"GIO","symbolKind":"method","externalID":"s:3GIO19ApplicationProtocolPAAE8register11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO11ApplicationC","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"register"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"title":"register(cancellable:)","roleHeading":"Instance Method"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Application","doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"register","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This is the point at which the application discovers if it is the"},{"text":" ","type":"text"},{"type":"text","text":"primary instance or merely acting as a remote for an already-existing"},{"text":" ","type":"text"},{"type":"text","text":"primary instance.  This is implemented by attempting to acquire the"},{"type":"text","text":" "},{"type":"text","text":"application identifier as a unique bus name on the session bus using"},{"text":" ","type":"text"},{"text":"GDBus.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If there is no application ID or if "},{"type":"codeVoice","code":"nonUnique"},{"type":"text","text":" was"},{"text":" ","type":"text"},{"text":"given, then this process will always become the primary instance.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Due to the internal architecture of GDBus, method calls can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dispatched at any time (even if a main loop is not running).  For"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you must ensure that any object paths that you wish to"},{"text":" ","type":"text"},{"text":"register are registered before calling this function.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the application has already been registered then "},{"code":"true","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"returned with no work performed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The [Application](\/\/documentation\/gio\/application\/onstartup(flags:handler:) signal is emitted if registration succeeds"},{"text":" ","type":"text"},{"type":"text","text":"and "},{"code":"application","type":"codeVoice"},{"text":" is the primary instance (including the non-unique","type":"text"},{"type":"text","text":" "},{"type":"text","text":"case)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the event of an error (such as "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" being cancelled, or a"},{"type":"text","text":" "},{"text":"failure to connect to the session bus), ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" "},{"type":"text","text":"is set appropriately."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note: the return value of this function is not an indicator that this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance is or is not the primary instance of the application.  See"},{"type":"text","text":" "},{"code":"g_application_get_is_remote()","type":"codeVoice"},{"type":"text","text":" for that."}]}],"kind":"content"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Application\/register(cancellable:)"},"abstract":[{"text":"Attempts registration of the application.","type":"text"}],"variants":[{"paths":["\/documentation\/gio\/application\/register(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/Application/register(cancellable:)":{"url":"\/documentation\/gio\/application\/register(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application\/register(cancellable:)","kind":"symbol","abstract":[{"text":"Attempts registration of the application.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"register","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"register(cancellable:)","type":"topic"},"doc://GIO/documentation/GIO/Application":{"navigatorTitle":[{"kind":"identifier","text":"Application"}],"title":"Application","abstract":[{"type":"codeVoice","code":"GAp