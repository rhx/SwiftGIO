{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Application","doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","metadata":{"extendedModule":"GIO","modules":[{"name":"GIO"}],"externalID":"s:3GIO19ApplicationProtocolPAAE9addOption5groupyqd___t4GLib0e5GroupC0Rd__lF::SYNTHESIZED::s:3GIO11ApplicationC","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addOption"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GLibOptionGroupT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"group"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GLibOptionGroupT"},{"kind":"text","text":")"}],"role":"symbol","title":"addOption(group:)","roleHeading":"Instance Method","symbolKind":"method"},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Application\/addOption(group:)"},"abstract":[{"text":"Adds a [OptionGroup](\/\/documentation\/glib\/optiongroup to the commandline handling of ","type":"text"},{"type":"codeVoice","code":"application"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addOption","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GLibOptionGroupT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"group"},{"text":": ","kind":"text"},{"text":"GLibOptionGroupT","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"GLibOptionGroupT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib19OptionGroupProtocolP","text":"OptionGroupProtocol"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is comparable to "},{"code":"g_option_context_add_group()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"Unlike "},{"code":"g_application_add_main_option_entries()","type":"codeVoice"},{"type":"text","text":", this function does"},{"text":" ","type":"text"},{"type":"text","text":"not deal with "},{"type":"codeVoice","code":"nil"},{"text":" ","type":"text"},{"code":"arg_data","type":"codeVoice"},{"text":" and never transmits options to the","type":"text"},{"text":" ","type":"text"},{"text":"primary instance.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The reason for that is because, by the time the options arrive at the"},{"type":"text","text":" "},{"type":"text","text":"primary instance, it is typically too late to do anything with them."},{"type":"text","text":" "},{"type":"text","text":"Taking the GTK option group as an example: GTK will already have been"},{"type":"text","text":" "},{"type":"text","text":"initialised by the time the [Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:) handler runs."},{"text":" ","type":"text"},{"type":"text","text":"In the case that this is not the first-running instance of the"},{"type":"text","text":" "},{"type":"text","text":"application, the existing instance may already have been running for"},{"text":" ","type":"text"},{"type":"text","text":"a very long time."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This means that the options from [OptionGroup](\/\/documentation\/glib\/optiongroup are only really usable","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in the case that the instance of the application being run is the"},{"type":"text","text":" "},{"text":"first instance.  Passing options like ","type":"text"},{"type":"codeVoice","code":"--display="},{"type":"text","text":" or "},{"type":"codeVoice","code":"--gdk-debug="},{"text":" ","type":"text"},{"type":"text","text":"on future runs will have no effect on the existing primary instance."}]},{"type":"paragraph","inlineContent":[{"text":"Calling this function will cause the options in the supplied option","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"group to be parsed, but it does not cause you to be “opted in” to the"},{"text":" ","type":"text"},{"type":"text","text":"new functionality whereby unrecognized options are rejected even if"},{"text":" ","type":"text"},{"code":"handlesCommandLine","type":"codeVoice"},{"type":"text","text":" was given."}]}]}],"variants":[{"paths":["\/documentation\/gio\/application\/addoption(group:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Application":{"navigatorTitle":[{"kind":"identifier","text":"Application"}],"title":"Application","abstract":[{"type":"codeVoice","code":"GApplication"},{"type":"text","text":" is the core class for application support."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Application","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","url":"\/documentation\/gio\/application"},"doc://GIO/documentation/GIO/Application/addOption(group:)":{"url":"\/documentation\/gio\/application\/addoption(group:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application\/addOption(group:)","kind":"symbol","abstract":[{"text":"Adds a [OptionGroup](\/\/documentation\/glib\/optiongroup to the commandline handling of ","type":"text"},{"type":"codeVoice","code":"application"},{"text":".","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addOption"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GLibOptionGroupT"},{"text":">(","kind":"text"},{"text":"group","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GLibOptionGroupT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"title":"addOption(group:)","type":"topic"},"doc://GIO/documentation/GIO/Application/ApplicationProtocol-Implementations":{"title":"ApplicationProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations","role":"collectionGroup","abstract":[],"type":"topic","url":"\/documentation\/gio\/application\/applicationprotocol-implementations","kind":"article"}}}