{"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/application\/addmainoption(entries:)"]}],"abstract":[{"type":"text","text":"Adds main option entries to be handled by "},{"code":"application","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","metadata":{"modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addMainOption","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"entries"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GOptionEntry"},{"kind":"text","text":">!)"}],"externalID":"s:3GIO19ApplicationProtocolPAAE13addMainOption7entriesySPySo13_GOptionEntryVGSg_tF::SYNTHESIZED::s:3GIO11ApplicationC","extendedModule":"GIO","role":"symbol","title":"addMainOption(entries:)","roleHeading":"Instance Method","symbolKind":"method"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Application\/addMainOption(entries:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Application","doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addMainOption","kind":"identifier"},{"kind":"text","text":"("},{"text":"entries","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOptionEntry"},{"kind":"text","text":">!)"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is comparable to "},{"type":"codeVoice","code":"g_option_context_add_main_entries()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"After the commandline arguments are parsed, the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) signal will be emitted.  At this"},{"text":" ","type":"text"},{"type":"text","text":"point, the application can inspect the values pointed to by "},{"code":"arg_data","type":"codeVoice"},{"type":"text","text":" "},{"text":"in the given ","type":"text"},{"type":"codeVoice","code":"GOptionEntrys"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike [OptionContext](\/\/documentation\/glib\/optioncontext, "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","isActive":true},{"type":"text","text":" supports giving a "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" "},{"code":"arg_data","type":"codeVoice"},{"type":"text","text":" for a non-callback [OptionEntry](\/\/documentation\/glib\/optionentry.  This results in the"},{"type":"text","text":" "},{"text":"argument in question being packed into a [VariantDict](\/\/documentation\/glib\/variantdict which is also","type":"text"},{"type":"text","text":" "},{"text":"passed to [Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:), where it can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"inspected and modified.  If "},{"type":"codeVoice","code":"handlesCommandLine"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"set, then the resulting dictionary is sent to the primary instance,"},{"type":"text","text":" "},{"text":"where ","type":"text"},{"code":"g_application_command_line_get_options_dict()","type":"codeVoice"},{"text":" will return it.","type":"text"},{"text":" ","type":"text"},{"text":"As it has been passed outside the process at this point, the types of all","type":"text"},{"type":"text","text":" "},{"text":"values in the options dict must be checked before being used.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This “packing” is done according to the type of the argument –"},{"type":"text","text":" "},{"type":"text","text":"booleans for normal flags, strings for strings, bytestrings for"},{"text":" ","type":"text"},{"type":"text","text":"filenames, etc.  The packing only occurs if the flag is given (ie: we"},{"type":"text","text":" "},{"text":"do not pack a “false” [Variant](\/\/documentation\/glib\/variant in the case that a flag is missing).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general, it is recommended that all commandline arguments are"},{"type":"text","text":" "},{"type":"text","text":"parsed locally.  The options dictionary should then be used to"},{"text":" ","type":"text"},{"type":"text","text":"transmit the result of the parsing to the primary instance, where"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_variant_dict_lookup()"},{"type":"text","text":" can be used.  For local options, it is"},{"type":"text","text":" "},{"text":"possible to either use ","type":"text"},{"code":"arg_data","type":"codeVoice"},{"type":"text","text":" in the usual way, or to consult (and"},{"text":" ","type":"text"},{"text":"potentially remove) the option from the options dictionary.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This function is new in GLib 2.40.  Before then, the only real choice","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was to send all of the commandline arguments (options and all) to the"},{"type":"text","text":" "},{"type":"text","text":"primary instance for handling.  "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","isActive":true},{"text":" ignored them completely","type":"text"},{"type":"text","text":" "},{"text":"on the local side.  Calling this function “opts in” to the new","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"behaviour, and in particular, means that unrecognized options will be"},{"type":"text","text":" "},{"type":"text","text":"treated as errors.  Unrecognized options have never been ignored when"},{"type":"text","text":" "},{"type":"codeVoice","code":"handlesCommandLine"},{"type":"text","text":" is unset."}]},{"inlineContent":[{"text":"If [Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) needs to see the list of","type":"text"},{"type":"text","text":" "},{"text":"filenames, then the use of [OPTION_REMAINING](\/\/documentation\/glib\/option_remaining is recommended.  If","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"arg_data"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then [OPTION_REMAINING](\/\/documentation\/glib\/option_remaining can be used as a key into"},{"type":"text","text":" "},{"type":"text","text":"the options dictionary.  If you do use [OPTION_REMAINING](\/\/documentation\/glib\/option_remaining then you"},{"type":"text","text":" "},{"type":"text","text":"need to handle these arguments for yourself because once they are"},{"type":"text","text":" "},{"text":"consumed, they will no longer be visible to the default handling","type":"text"},{"text":" ","type":"text"},{"text":"(which treats them as filenames to be opened).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is important to use the proper GVariant format when retrieving","type":"text"},{"text":" ","type":"text"},{"text":"the options with ","type":"text"},{"code":"g_variant_dict_lookup()","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"for ","type":"text"},{"type":"codeVoice","code":"none"},{"type":"text","text":", use "},{"code":"b","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"for [string](\/\/documentation\/glib\/string, use ","type":"text"},{"type":"codeVoice","code":"&s"}]}]},{"content":[{"inlineContent":[{"text":"for [CInt](\/\/documentation\/glib\/cint, use ","type":"text"},{"type":"codeVoice","code":"i"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"for [int64](\/\/documentation\/glib\/int64, use "},{"type":"codeVoice","code":"x"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"for [CDouble](\/\/documentation\/glib\/cdouble, use "},{"code":"d","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"for [String](\/\/documentation\/glib\/string, use "},{"type":"codeVoice","code":"^&ay"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"for [string_array](\/\/documentation\/glib\/string_array, use ","type":"text"},{"code":"^a&s","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"for [filename_array](\/\/documentation\/glib\/filename_array, use "},{"type":"codeVoice","code":"^a&ay"}],"type":"paragraph"}]}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/Application":{"navigatorTitle":[{"kind":"identifier","text":"Application"}],"title":"Application","abstract":[{"type":"codeVoice","code":"GApplication"},{"type":"text","text":" is the core class for application support."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Application","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","url":"\/documentation\/gio\/application"},"doc://GIO/documentation/GIO/Application/ApplicationProtocol-Implementations":{"title":"ApplicationProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations","role":"collectionGroup","abstract":[],"type":"topic","url":"\/documentation\/gio\/application\/applicationprotocol-implementations","kind":"article"},"doc://GIO/documentation/GIO/Application/addMainOption(entries:)":{"type":"topic","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addMainOption","kind":"identifier"},{"text":"(","kind":"text"},{"text":"entries","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GOptionEntry"},{"text":">!)","kind":"text"}],"role":"symbol","url":"\/documentation\/gio\/application\/addmainoption(entries:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application\/addMainOption(entries:)","title":"addMainOption(entries:)","abstract":[{"type":"text","text":"Adds main option entries to be handled by "},{"type":"codeVoice","code":"application"},{"type":"text","text":"."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}