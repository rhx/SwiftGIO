type":"text","text":" results"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"text":" call, like this:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::is-registered","type":"codeVoice"},{"type":"text","text":" signal"}]