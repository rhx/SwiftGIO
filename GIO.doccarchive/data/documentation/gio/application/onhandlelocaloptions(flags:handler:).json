{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onHandleLocalOptions"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier","text":"ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"text":"ApplicationRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ApplicationRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:4GLib14VariantDictRefV","kind":"typeIdentifier","text":"VariantDictRef"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":") -> "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}]}]},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}]},{"name":"handler","content":[{"inlineContent":[{"text":"An exit code. If you have handled your options and want to exit the process, return a non-negative option, 0 for success, and a positive value for failure. To continue, return -1 to let the default option processing continue.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"handleLocalOptions"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can add options to be recognised during commandline option"},{"text":" ","type":"text"},{"type":"text","text":"parsing using "},{"code":"g_application_add_main_option_entries()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"g_application_add_option_group()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"Signal handlers can inspect ","type":"text"},{"type":"codeVoice","code":"options"},{"type":"text","text":" (along with values pointed to"},{"type":"text","text":" "},{"type":"text","text":"from the "},{"code":"arg_data","type":"codeVoice"},{"text":" of an installed ","type":"text"},{"code":"GOptionEntrys","type":"codeVoice"},{"type":"text","text":") in order to"},{"type":"text","text":" "},{"type":"text","text":"decide to perform certain actions, including direct local handling"},{"text":" ","type":"text"},{"text":"(which may be useful for options like –version).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that the application is marked"},{"type":"text","text":" "},{"type":"codeVoice","code":"handlesCommandLine"},{"type":"text","text":" the “normal processing” will"},{"type":"text","text":" "},{"text":"send the ","type":"text"},{"code":"options","type":"codeVoice"},{"text":" dictionary to the primary instance where it can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"read with "},{"code":"g_application_command_line_get_options_dict()","type":"codeVoice"},{"type":"text","text":".  The signal"},{"text":" ","type":"text"},{"type":"text","text":"handler can modify the dictionary before returning, and the"},{"type":"text","text":" "},{"type":"text","text":"modified dictionary will be sent."}]},{"inlineContent":[{"type":"text","text":"In the event that "},{"code":"handlesCommandLine","type":"codeVoice"},{"type":"text","text":" is not set,"},{"text":" ","type":"text"},{"type":"text","text":"“normal processing” will treat the remaining uncollected command"},{"type":"text","text":" "},{"type":"text","text":"line arguments as filenames or URIs.  If there are no arguments,"},{"text":" ","type":"text"},{"type":"text","text":"the application is activated by "},{"code":"g_application_activate()","type":"codeVoice"},{"type":"text","text":".  One or"},{"type":"text","text":" "},{"text":"more arguments results in a call to ","type":"text"},{"code":"g_application_open()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you want to handle the local commandline arguments for yourself"},{"text":" ","type":"text"},{"text":"by converting them to calls to ","type":"text"},{"type":"codeVoice","code":"g_application_open()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_action_group_activate_action()"},{"text":" then you must be sure to register","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the application first.  You should probably not call"},{"type":"text","text":" "},{"code":"g_application_activate()","type":"codeVoice"},{"type":"text","text":" for yourself, however: just return -1 and"},{"text":" ","type":"text"},{"type":"text","text":"allow the default handler to do it for you.  This will ensure that"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"codeVoice","code":"--gapplication-service"},{"text":" switch works properly (i.e. no activation","type":"text"},{"type":"text","text":" "},{"text":"in that case).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this signal is emitted from the default implementation of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"local_command_line()"},{"type":"text","text":".  If you override that function and don’t"},{"text":" ","type":"text"},{"text":"chain up then this signal will never be emitted.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can override "},{"code":"local_command_line()","type":"codeVoice"},{"text":" if you need more powerful","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"capabilities than what is provided here, but this should not"},{"type":"text","text":" "},{"type":"text","text":"normally be required."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"handle-local-options","type":"codeVoice"},{"text":" signal","type":"text"}]}],"name":"Note","style":"note"}]}],"abstract":[{"text":"The ","type":"text"},{"code":"handle-local-options","type":"codeVoice"},{"type":"text","text":" signal is emitted on the local instance"},{"type":"text","text":" "},{"text":"after the parsing of the commandline options has occurred.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Application","doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Instance Method","title":"onHandleLocalOptions(flags:handler:)","extendedModule":"GIO","modules":[{"name":"GIO"}],"externalID":"s:3GIO19ApplicationProtocolPAAE20onHandleLocalOptions5flags7handlerSi10GLibObject12ConnectFlagsV_SiAA0B3RefV_0J0011VariantDictN0VtctF::SYNTHESIZED::s:3GIO11ApplicationC","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onHandleLocalOptions","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier","text":"ConnectFlags"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO14ApplicationRefV","kind":"typeIdentifier","text":"ApplicationRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s: