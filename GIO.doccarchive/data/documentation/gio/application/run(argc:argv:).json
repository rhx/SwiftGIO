{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"run"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"argc"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"argv"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"kind":"text","text":">?>! = nil) -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This function is intended to be run from ","type":"text"},{"code":"main()","type":"codeVoice"},{"type":"text","text":" and its return value"},{"type":"text","text":" "},{"type":"text","text":"is intended to be returned by "},{"type":"codeVoice","code":"main()"},{"type":"text","text":". Although you are expected to pass"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"argc","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"argv"},{"type":"text","text":" parameters from "},{"code":"main()","type":"codeVoice"},{"text":" to this function, it is possible","type":"text"},{"type":"text","text":" "},{"text":"to pass ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" if ","type":"text"},{"type":"codeVoice","code":"argv"},{"text":" is not available or commandline handling is not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"required.  Note that on Windows, "},{"code":"argc","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"argv","type":"codeVoice"},{"text":" are ignored, and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_win32_get_command_line()"},{"type":"text","text":" is called internally (for proper support"},{"type":"text","text":" "},{"type":"text","text":"of Unicode commandline arguments)."}]},{"inlineContent":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","type":"reference","isActive":true},{"text":" will attempt to parse the commandline arguments.  You","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can add commandline flags to the list of recognised options by way of"},{"text":" ","type":"text"},{"code":"g_application_add_main_option_entries()","type":"codeVoice"},{"text":".  After this, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) signal is emitted, from which the"},{"type":"text","text":" "},{"type":"text","text":"application can inspect the values of its "},{"code":"GOptionEntrys","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"[Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) is a good place to handle options","type":"text"},{"text":" ","type":"text"},{"text":"such as ","type":"text"},{"type":"codeVoice","code":"--version"},{"type":"text","text":", where an immediate reply from the local process is"},{"text":" ","type":"text"},{"type":"text","text":"desired (instead of communicating with an already-running instance)."},{"type":"text","text":" "},{"text":"A [Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) handler can stop further processing","type":"text"},{"type":"text","text":" "},{"text":"by returning a non-negative value, which then becomes the exit status of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the process."}]},{"inlineContent":[{"type":"text","text":"What happens next depends on the flags: if"},{"text":" ","type":"text"},{"type":"codeVoice","code":"handlesCommandLine"},{"text":" was specified then the remaining","type":"text"},{"text":" ","type":"text"},{"text":"commandline arguments are sent to the primary instance, where a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:) signal is emitted.  Otherwise, the"},{"text":" ","type":"text"},{"type":"text","text":"remaining commandline arguments are assumed to be a list of files."},{"type":"text","text":" "},{"type":"text","text":"If there are no files listed, the application is activated via the"},{"type":"text","text":" "},{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/onactivate(flags:handler:) signal.  If there are one or more files, and"},{"text":" ","type":"text"},{"code":"handlesOpen","type":"codeVoice"},{"type":"text","text":" was specified then the files are opened"},{"type":"text","text":" "},{"type":"text","text":"via the [Application](\/\/documentation\/gio\/application\/onopen(flags:handler:) signal."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you are interested in doing more complicated local handling of the"},{"text":" ","type":"text"},{"type":"text","text":"commandline then you should implement your own "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application"},{"type":"text","text":" subclass"},{"text":" ","type":"text"},{"type":"text","text":"and override "},{"code":"local_command_line()","type":"codeVoice"},{"type":"text","text":". In this case, you most likely want"},{"text":" ","type":"text"},{"type":"text","text":"to return "},{"code":"true","type":"codeVoice"},{"text":" from your ","type":"text"},{"type":"codeVoice","code":"local_command_line()"},{"type":"text","text":" implementation to"},{"text":" ","type":"text"},{"text":"suppress the default handling. See","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"#https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c","isActive":true},{"type":"text","text":" "},{"text":"for an example.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If, after the above is done, the use count of the application is zero"},{"type":"text","text":" "},{"type":"text","text":"then the exit status is returned immediately.  If the use count is"},{"type":"text","text":" "},{"text":"non-zero then the default main context is iterated until the use count","type":"text"},{"text":" ","type":"text"},{"text":"falls to zero, at which point 0 is returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the "},{"type":"codeVoice","code":"isService"},{"type":"text","text":" flag is set, then the service will"},{"type":"text","text":" "},{"type":"text","text":"run for as much as 10 seconds with a use count of zero while waiting"},{"text":" ","type":"text"},{"text":"for the message that caused the activation to arrive.  After that,","type":"text"},{"text":" ","type":"text"},{"text":"if the use count falls to zero the application will exit immediately,","type":"text"},{"type":"text","text":" "},{"text":"except in the case that ","type":"text"},{"code":"g_application_set_inactivity_timeout()","type":"codeVoice"},{"type":"text","text":" is in"},{"type":"text","text":" "},{"text":"use.","type":"text"}]},{"inlineContent":[{"text":"This function sets the prgname (","type":"text"},{"type":"codeVoice","code":"g_set_prgname()"},{"type":"text","text":"), if not already set,"},{"type":"text","text":" "},{"text":"to the basename of argv[0].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Much like "},{"type":"codeVoice","code":"g_main_loop_run()"},{"type":"text","text":", this function will acquire the main context"},{"type":"text","text":" "},{"type":"text","text":"for the duration that the application is running."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since 2.40, applications that are not explicitly flagged as services"},{"type":"text","text":" "},{"type":"text","text":"or launchers (ie: neither "},{"type":"codeVoice","code":"isService"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"isLauncher","type":"codeVoice"},{"text":" are given as flags) will check (from the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"default handler for local_command_line) if “–gapplication-service”"},{"type":"text","text":" "},{"text":"was given in the command line.  If this flag is present then normal","type":"text"},{"text":" ","type":"text"},{"text":"commandline processing is interrupted and the","type":"text"},{"text":" ","type":"text"},{"code":"isService","type":"codeVoice"},{"type":"text","text":" flag is set.  This provides a “compromise”"},{"text":" ","type":"text"},{"type":"text","text":"solution whereby running an application directly from the commandline"},{"type":"text","text":" "},{"type":"text","text":"will invoke it in the normal way (which can be useful for debugging)"},{"type":"text","text":" "},{"type":"text","text":"while still allowing applications to be D-Bus activated in service"},{"text":" ","type":"text"},{"type":"text","text":"mode.  The D-Bus service file should invoke the executable with"},{"type":"text","text":" "},{"type":"text","text":"“–gapplication-service” as the sole commandline argument.  This"},{"type":"text","text":" "},{"type":"text","text":"approach is suitable for use by most graphical applications but"},{"type":"text","text":" "},{"type":"text","text":"should not be used from applications like editors that need precise"},{"text":" ","type":"text"},{"type":"text","text":"control over when processes invoked via the commandline will exit and"},{"text":" ","type":"text"},{"type":"text","text":"what their exit status will be."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Application","doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations"]]},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Runs the application.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/application\/run(argc:argv:)"]}],"sections":[],"metadata":{"extendedModule":"GIO","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"run","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"argc"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"argv"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"text":">?>!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"externalID":"s:3GIO19ApplicationProtocolPAAE3run4argc4argvS2i_SpySpys4Int8VGSgGSgtF::SYNTHESIZED::s:3GIO11ApplicationC","title":"run(argc:argv:)"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Application\/run(argc:argv:)"},"references":{"doc://GIO/documentation/GIO/Application":{"navigatorTitle":[{"kind":"identifier","text":"Application"}],"title":"Application","abstract":[{"type":"codeVoice","code":"GApplication"},{"type":"text","text":" is the core class for application support."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Application","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","url":"\/documentation\/gio\/application"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Application/ApplicationProtocol-Implementations":{"title":"ApplicationProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application\/ApplicationProtocol-Implementations","role":"collectionGroup","abstract":[],"type":"topic","url":"\/documentation\/gio\/application\/applicationprotocol-implementations","kind":"article"},"#https://gitlab.gnome.org/GNOME/glib/-/blob/HEAD/gio/tests/gapplication-example-cmdline2.c":{"title":"gapplication-example-cmdline2.c","identifier":"#https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c","type":"link","titleInlineContent":[{"type":"text","text":"gapplication-example-cmdline2.c"}],"url":"#https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c"},"doc://GIO/documentation/GIO/Application/run(argc:argv:)":{"url":"\/documentation\/gio\/application\/run(argc:argv:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application\/run(argc:argv:)","abstract":[{"text":"Runs the application.","type":"text"}],"role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"run","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"argc"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"argv","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"text":">?>!) -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"run(argc:argv:)"}}}