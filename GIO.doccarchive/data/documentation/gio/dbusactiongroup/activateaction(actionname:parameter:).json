:"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If the action is expecting a parameter, then the correct type of"},{"text":" ","type":"text"},{"type":"text","text":"parameter must be given as "},{"code":"parameter","type":"codeVoice"},{"type":"text","text":".  If the action is expecting no"},{"text":" ","type":"text"},{"type":"text","text":"parameters then "},{"type":"codeVoice","code":"parameter"},{"type":"text","text":" must be "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":".  See"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.ActionGroup.get_action_parameter_type"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the [type"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","isActive":true},{"type":"text","text":"] implementation supports asynchronous remote"},{"text":" ","type":"text"},{"text":"activation over D-Bus, this call may return before the relevant","type":"text"},{"type":"text","text":" "},{"text":"D-Bus traffic has been sent, or any replies have been received. In","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"order to block on such asynchronous activation calls,"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.DBusConnection.flush","type":"codeVoice"},{"text":"] should be called prior to the code, which","type":"text"},{"type":"text","text":" "},{"text":"depends on the result of the action activation. Without flushing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the D-Bus connection, there is no guarantee that the action would"},{"text":" ","type":"text"},{"type":"text","text":"have been activated."}]},{"inlineContent":[{"type":"text","text":"The following code which runs in a remote app instance, shows an"},{"type":"text","text":" "},{"type":"text","text":"example of a ‘quit’ action being activated on the primary app"},{"type":"text","text":" "},{"type":"text","text":"instance over D-Bus. Here [method"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"type":"text","text":"] is called"},{"type":"text","text":" "},{"type":"text","text":"before "},{"type":"codeVoice","code":"exit()"},{"text":". Without ","type":"text"},{"code":"g_dbus_connection_flush()","type":"codeVoice"},{"type":"text","text":", the ‘quit’ action"},{"type":"text","text":" "},{"text":"may fail to be activated on the primary instance.","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["\/\/ call ‘quit’ action on primary instance","g_action_group_activate_action (G_ACTION_GROUP (app), \"quit\", NULL);","","\/\/ make sure the action is activated now","g_dbus_connection_flush (…);","","g_debug (\"Application has been terminated. Exiting.\");","","exit (0);"],"type":"codeListing"}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusActionGroup\/activateAction(actionName:parameter:)"},"kind":"symbol","abstract":[{"text":"Activate the named action within ","type":"text"},{"type":"codeVoice","code":"actionGroup"},{"type":"text","text":"."}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusActionGroup/activateAction(actionName:parameter:)":{"title":"activateAction(actionName:parameter:)","url":"\/documentation\/gio\/dbusactiongroup\/activateaction(actionname:parameter:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"activateAction"},{"kind":"text","text":"("},{"kind":"externalParam","text":"actionName"},{"text":": ","kind":"text"},{"preciseIdentifier":