{"variants":[{"paths":["\/documentation\/gio\/datagrambasedref\/receive(messages:nummessages:flags:timeout:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"receive"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GInputMessage"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true},{"type":"text","text":" structs and"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" must be the length of this array. Each "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"type":"text","text":" "},{"text":"contains a pointer to an array of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","type":"reference","isActive":true},{"text":" structs describing the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"buffers that the data received in each message will be written to."}]},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" modify how all messages are received. The commonly available","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arguments for this are available in the "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","type":"reference"},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"type":"text","text":"values there are the same as the system values, and the flags"},{"text":" ","type":"text"},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too. These"},{"type":"text","text":" "},{"type":"text","text":"flags affect the overall receive operation. Flags affecting individual"},{"type":"text","text":" "},{"type":"text","text":"messages are returned in "},{"type":"codeVoice","code":"GInputMessage.flags"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The other members of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"text":" are treated as described in its","type":"text"},{"text":" ","type":"text"},{"text":"documentation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is negative the call will block until "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" have been"},{"text":" ","type":"text"},{"text":"received, the connection is closed remotely (EOS), ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is cancelled,","type":"text"},{"text":" ","type":"text"},{"text":"or an error occurs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is 0 the call will return up to "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" without blocking,"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"text":" if no messages are queued in the operating system","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to be received."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is positive the call will block on the same conditions as if","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" were negative. If the timeout is reached"},{"text":" ","type":"text"},{"type":"text","text":"before any messages are received, "},{"type":"codeVoice","code":"timedOut"},{"text":" is returned,","type":"text"},{"type":"text","text":" "},{"text":"otherwise it will return the number of messages received before timing out.","type":"text"},{"text":" ","type":"text"},{"text":"(Note: This is effectively the behaviour of ","type":"text"},{"code":"MSG_WAITFORONE","type":"codeVoice"},{"text":" with","type":"text"},{"text":" ","type":"text"},{"code":"recvmmsg()","type":"codeVoice"},{"type":"text","text":".)"}]},{"inlineContent":[{"text":"To be notified when messages are available, wait for the [in_](\/\/documentation\/gobject\/in_ condition.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Note though that you may still receive "},{"code":"wouldBlock","type":"codeVoice"},{"text":" from","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"text":" even if you were previously notified of a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[in_](\/\/documentation\/gobject\/in_ condition."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the remote peer closes the connection, any messages queued in the","type":"text"},{"text":" ","type":"text"},{"text":"underlying receive buffer will be returned, and subsequent calls to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":" will return 0 (with no error set)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_shutdown()"},{"type":"text","text":" with "},{"type":"codeVoice","code":"shutdown_read"},{"type":"text","text":" set, if it’s a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true,"type":"reference"},{"type":"text","text":", for"},{"type":"text","text":" "},{"type":"text","text":"example), all calls to this function will return "},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"text":"be returned if zero messages could be received; otherwise the number of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages successfully received before the error will be returned. If"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is cancelled, "},{"type":"codeVoice","code":"cancelled"},{"text":" is returned as with any","type":"text"},{"type":"text","text":" "},{"text":"other error.","type":"text"}]}]}],"kind":"symbol","metadata":{"extendedModule":"GIO","role":"symbol","externalID":"s:3GIO21DatagramBasedProtocolPAAE7receive8messages11numMessages5flags7timeout11cancellableSiSpySo14_GInputMessageVGSg_S2is5Int64VAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO16DatagramBasedRefV","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"receive","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"messages"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gint64","kind":"typeIdentifier","text":"gint64"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"receive(messages:numMessages:flags:timeout:cancellable:)","roleHeading":"Instance Method"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/receive(messages:numMessages:flags:timeout:cancellable:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\