."}],"navigatorTitle":[{"kind":"identifier","text":"SocketMsgFlags"}],"url":"\/documentation\/gio\/socketmsgflags","title":"SocketMsgFlags","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketMsgFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/DatagramBasedRef":{"type":"topic","abstract":[{"text":"Interface for socket-like objects with datagram semantics.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef","navigatorTitle":[{"text":"DatagramBasedRef","kind":"identifier"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"DatagramBasedRef","kind":"identifier"}],"url":"\/documentation\/gio\/datagrambasedref","title":"DatagramBasedRef"},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/DatagramBasedRef/DatagramBasedProtocol-Implementations":{"abstract":[],"kind":"article","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/DatagramBasedProtocol-Implementations","url":"\/documentation\/gio\/datagrambasedref\/datagrambasedprotocol-implementations","title":"DatagramBasedProtocol Implementations","role":"collectionGroup"},"doc://GIO/documentation/GIO/InputMessage":{"navigatorTitle":[{"text":"InputMessage","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","url":"\/documentation\/gio\/inputmessage","title":"InputMessage","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InputMessage","kind":"identifier"}],"abstract":[{"type":"text","text":"Structure used for scatter\/gather data input when receiving multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of empty","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"text":" and the operation will use all the buffers as if they","type":"text"},{"type":"text","text":" "},{"type":"text","text":"were one buffer, and will set "},{"type":"codeVoice","code":"bytes_received"},{"type":"text","text":" to the total number of bytes"},{"type":"text","text":" "},{"text":"received across all ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"type":"text","text":"."}],"role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}