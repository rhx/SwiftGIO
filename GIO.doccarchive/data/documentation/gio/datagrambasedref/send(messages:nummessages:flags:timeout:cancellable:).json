"text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/OutputMessage":{"abstract":[{"type":"text","text":"Structure used for scatter\/gather data output when sending multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of","type":"text"},{"type":"text","text":" "},{"code":"GOutputVectors","type":"codeVoice"},{"type":"text","text":" and the operation will use all the buffers as if they"},{"type":"text","text":" "},{"type":"text","text":"were one buffer."}],"url":"\/documentation\/gio\/outputmessage","type":"topic","title":"OutputMessage","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputMessage","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OutputMessage"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},"doc://GIO/documentation/GIO/OutputVector":{"abstract":[{"text":"Structure used for scatter\/gather data output.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GOutputVectors"},{"text":" ","type":"text"},{"text":"and the operation will use all the buffers as if they were","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one buffer."}],"url":"\/documentation\/gio\/outputvector","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","navigatorTitle":[{"text":"OutputVector","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputVector","kind":"identifier"}],"title":"OutputVector","role":"symbol","kind":"symbol","type":"topic"}}}