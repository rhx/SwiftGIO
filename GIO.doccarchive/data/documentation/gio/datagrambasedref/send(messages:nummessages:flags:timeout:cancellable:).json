{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"send"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GOutputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:glibconfig.h@T@gint64","kind":"typeIdentifier","text":"gint64"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" structs and"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"type":"text","text":" "},{"type":"text","text":"contains an address to send the data to, and a pointer to an array of"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true,"type":"reference"},{"text":" structs to describe the buffers that the data to be sent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for each message will be gathered from."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"flags","type":"codeVoice"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"text":"for this are available in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"type":"text","text":" enum, but the"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"text":" ","type":"text"},{"text":"are passed in as-is, so you can pass in system-specific flags too.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The other members of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"type":"text","text":" are treated as described in its"},{"type":"text","text":" "},{"type":"text","text":"documentation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"text":" is negative the call will block until ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" have been"},{"type":"text","text":" "},{"type":"text","text":"sent, "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is cancelled, or an error occurs."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is 0 the call will send up to "},{"code":"numMessages","type":"codeVoice"},{"text":" without blocking,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or will return "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" if there is no space to send messages."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"type":"text","text":" "},{"type":"codeVoice","code":"timeout"},{"text":" were negative. If the timeout is reached before any messages are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"sent, "},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned, otherwise it will return the number"},{"type":"text","text":" "},{"text":"of messages sent before timing out.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition."},{"type":"text","text":" "},{"type":"text","text":"Note though that you may still receive "},{"type":"codeVoice","code":"wouldBlock"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"text":" even if you were previously notified of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to"},{"type":"text","text":" "},{"text":"the way the underlying APIs work.)","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_shutdown()"},{"type":"text","text":" with "},{"type":"codeVoice","code":"shutdown_write"},{"type":"text","text":" set, if it’s a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":", for"},{"type":"text","text":" "},{"type":"text","text":"example), all calls to this function will return "},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"type":"text","text":"be returned if zero messages could be sent; otherwise the number of messages"},{"text":" ","type":"text"},{"type":"text","text":"successfully sent before the error will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"cancelled, "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any other error."}]}]}],"sections":[],"abstract":[{"type":"text","text":"Send one or more data messages from "},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/DatagramBasedProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datagrambasedref\/send(messages:nummessages:flags:timeout:cancellable:)"]}],"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"send","kind":"identifier"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GOutputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"numMessages","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"timeout","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"symbolKind":"method","title":"send(messages:numMessages:flags:timeout:cancellable:)","roleHeading":"Instance Method","externalID":"s:3GIO21DatagramBasedProtocolPAAE4send8messages11numMessages5flags7timeout11cancellableSiSpySo15_GOutputMessageVGSg_S2is5Int64VAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO16DatagramBasedRefV"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/send(messages:numMessages:flags:timeout:cancellable:)"},"references":{"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","abstract":[{"text":"Flags used in ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_socket_send_message()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The flags listed in the enum are some commonly available flags, but the"},{"text":" ","type":"text"},{"type":"text","text":"values used for them are the same as on the platform, and any other flags"},{"text":" ","type":"text"},{"text":"are passed in\/out as is. So to use a platform specific flag, just include","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right system header and pass in the flag."}],"navigatorTitle":[{"kind":"identifier","text":"SocketMsgFlags"}],"url":"\/documentation\/gio\/socketmsgflags","title":"SocketMsgFlags","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketMsgFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DatagramBasedRef/DatagramBasedProtocol-Implementations":{"abstract":[],"kind":"article","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef\/DatagramBasedProtocol-Implementations","url":"\/documentation\/gio\/datagrambasedref\/datagrambasedprotocol-implementations","title":"DatagramBasedProtocol Implementations","role":"collectionGroup"},"doc://GIO/documentation/GIO/DatagramBasedRef":{"type":"topic","abstract":[{"text":"Interface for socket-like objects with datagram semantics.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef","navigatorTitle":[{"text":"DatagramBasedRef","kind":"identifier"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"DatagramBasedRef","kind":"identifier"}],"url":"\/documentation\/gio\/datagrambasedref","title":"DatagramBasedRef"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","