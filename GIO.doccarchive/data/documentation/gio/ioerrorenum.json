ype":"paragraph","inlineContent":[{"text":"See also ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableReturn","type":"reference","isActive":true},{"type":"text","text":" for a cheaper way of returning"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"text":" to callers without allocating a [GLibError](\/\/documentation\/glib\/gliberror.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/ioerrorenum"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO/IOErrorEnum":{"type":"topic","title":"IOErrorEnum","role":"symbol","url":"\/documentation\/gio\/ioerrorenum","abstract":[{"type":"text","text":"Error codes returned by GIO functions."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOErrorEnum","kind":"symbol","fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"text":"IOErrorEnum","kind":"identifier"}],"navigatorTitle":[{"text":"IOErrorEnum","kind":"identifier"}]},"doc://GIO/documentation/GIO/PollableReturn":{"type":"topic","url":"\/documentation\/gio\/pollablereturn","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/PollableReturn","kind":"symbol","title":"PollableReturn","navigatorTitle":[{"kind":"identifier","text":"PollableReturn"}],"abstract":[{"type":"text","text":"Return value for various IO operations that signal errors via the"},{"type":"text","text":" "},{"type":"text","text":"return value and not necessarily via a [GLibError](\/\/documentation\/glib\/gliberror."}],"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PollableReturn","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}