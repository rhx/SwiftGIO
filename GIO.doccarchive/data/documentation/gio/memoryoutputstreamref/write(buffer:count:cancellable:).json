{"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/write(buffer:count:cancellable:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"write"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","kind":"typeIdentifier","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize"}],"symbolKind":"method","modules":[{"name":"GIO"}],"externalID":"s:3GIO20OutputStreamProtocolPAAE5write6buffer5count11cancellableSiSvSg_SiAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO21MemoryOutputStreamRefV","title":"write(buffer:count:cancellable:)","extendedModule":"GIO","role":"symbol","roleHeading":"Instance Method"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/memoryoutputstreamref\/write(buffer:count:cancellable:)"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"write","kind":"identifier"},{"kind":"text","text":"("},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"gssize","preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If count is 0, returns 0 and does nothing. A value of "},{"code":"count","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"larger than "},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" will cause a "},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes written to the stream is returned.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. on a partial I\/O error, or if there is not enough"},{"type":"text","text":" "},{"text":"storage in the stream. All writes block until at least one byte","type":"text"},{"type":"text","text":" "},{"text":"is written or an error occurs; 0 is never returned (unless","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is 0).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If an","type":"text"},{"text":" ","type":"text"},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"text":"partial result will be returned, without an error.","type":"text"}]},{"inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Tries to write "},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from "},{"type":"codeVoice","code":"buffer"},{"type":"text","text":" into the stream. Will block"},{"text":" ","type":"text"},{"text":"during the operation.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/MemoryOutputStreamRef":{"navigatorTitle":[{"text":"MemoryOutputStreamRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef","kind":"symbol","abstract":[{"type":"codeVoice","code":"GMemoryOutputStream"},{"type":"text","text":" is a class for using arbitrary"},{"text":" ","type":"text"},{"text":"memory chunks as output for GIO streaming output operations.","type":"text"}],"title":"MemoryOutputStreamRef","url":"\/documentation\/gio\/memoryoutputstreamref","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MemoryOutputStreamRef"}],"type":"topic"},"doc://GIO/documentation/GIO/MemoryOutputStreamRef/OutputStreamProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documenta