{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"writeAsync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"During an async request no other sync and async calls are allowed,"},{"type":"text","text":" "},{"type":"text","text":"and will result in "},{"type":"codeVoice","code":"pending"},{"text":" errors.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"text":" will cause a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On success, the number of bytes written will be passed to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"callback"},{"type":"text","text":". It is not an error if this is not the same as the"},{"type":"text","text":" "},{"type":"text","text":"requested size, as it can happen e.g. on a partial I\/O error,"},{"type":"text","text":" "},{"text":"but generally we try to write as many bytes as requested.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You are guaranteed that this method will never fail with"},{"text":" ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" - if "},{"code":"stream","type":"codeVoice"},{"type":"text","text":" can’t accept more data, the"},{"text":" ","type":"text"},{"type":"text","text":"method will just wait until this changes."}]},{"type":"paragraph","inlineContent":[{"text":"Any outstanding I\/O request with higher priority (lower numerical","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"value) will be executed before an outstanding request with lower"},{"type":"text","text":" "},{"text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads","type":"text"},{"type":"text","text":" "},{"text":"to implement asynchronicity, so they are optional for inheriting","type":"text"},{"type":"text","text":" "},{"text":"classes. However, if you override one you must override all.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For the synchronous, blocking version of this function, see","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_output_stream_write()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that no copy of "},{"type":"codeVoice","code":"buffer"},{"type":"text","text":" will be made, so it must stay valid"},{"text":" ","type":"text"},{"text":"until ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":" is called. See "},{"code":"g_output_stream_write_bytes_async()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to"},{"text":" ","type":"text"},{"text":"the contents (without copying) for the duration of the call.","type":"text"}]}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/memoryoutputstreamref\/writeasync(buffer:count:iopriority:cancellable:callback:userdata:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Request an asynchronous write of "},{"type":"codeVoice","code":"count"},{"text":" bytes from ","type":"text"},{"type":"codeVoice","code":"buffer"},{"text":" into","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the stream. When the operation is finished "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called."},{"type":"text","text":" "},{"type":"text","text":"You can then call "},{"type":"codeVoice","code":"g_output_stream_write_finish()"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"type":"text","text":"operation."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Ins