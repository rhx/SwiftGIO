ype":"text"},{"type":"text","text":"does nothing."}]},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes written to the stream is returned.","type":"text"},{"text":" ","type":"text"},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. on a partial I\/O error, or if there is not enough"},{"text":" ","type":"text"},{"type":"text","text":"storage in the stream. All writes block until at least one byte"},{"type":"text","text":" "},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"text":" ","type":"text"},{"code":"nVectors","type":"codeVoice"},{"text":" is 0 or the sum of all bytes in ","type":"text"},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is 0)."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If an"},{"text":" ","type":"text"},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"text":" ","type":"text"},{"text":"partial result will be returned, without an error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some implementations of "},{"code":"g_output_stream_writev()","type":"codeVoice"},{"type":"text","text":" may have limitations on the"},{"type":"text","text":" "},{"type":"text","text":"aggregate buffer size, and will return "},{"type":"codeVoice","code":"invalidArgument"},{"text":" if these","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are exceeded. For example, when writing to a local file on UNIX platforms,"},{"text":" ","type":"text"},{"text":"the aggregate buffer size must not exceed ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" bytes."}]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/memoryoutputstreamref\/writev(vectors:nvectors:byteswritten:cancellable:)"]}],"abstract":[{"text":"Tries to write the bytes contained in the ","type":"text"},{"code":"nVectors","type":"codeVoice"},{"text":" ","type":"text"},{"type":"codeVoice","code":"vectors"},{"text":" into the","type":"text"},{"type":"text","text":" "},{"text":"stream. Will block during the operation.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/writev(vectors:nVectors:bytesWritten:cancellable:)"},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"writev"},{"text":"(","kind":"text"},{"text":"vectors","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GOutputVector","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"nVectors"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"bytesWritten"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!, "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throw