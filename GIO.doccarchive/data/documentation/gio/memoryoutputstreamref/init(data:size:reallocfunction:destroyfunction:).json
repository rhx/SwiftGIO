{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/init(data:size:reallocFunction:destroyFunction:)","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"size","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"reallocFunction"},{"text":": ","kind":"text"},{"text":"GReallocFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GReallocFunc"},{"text":"?, ","kind":"text"},{"text":"destroyFunction","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@GDestroyNotify","text":"GDestroyNotify"},{"kind":"text","text":"?)"}],"modules":[{"name":"GIO"}],"title":"init(data:size:reallocFunction:destroyFunction:)","externalID":"s:3GIO21MemoryOutputStreamRefV4data4size15reallocFunction07destroyI0ACSvSg_SiA2H_SutXCSgyAHXCSgtcfc","extendedModule":"GIO","roleHeading":"Initializer","role":"symbol","symbolKind":"init"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"("},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"size"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"reallocFunction","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GReallocFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GReallocFunc"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"destroyFunction"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In most cases this is not the function you want.  See"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_memory_output_stream_new_resizable()"},{"type":"text","text":" instead."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"data","type":"codeVoice"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", the stream will use that for its internal storage."}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"realloc_fn","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", it will be used for resizing the internal"},{"type":"text","text":" "},{"text":"storage when necessary and the stream will be considered resizable.","type":"text"},{"text":" ","type":"text"},{"text":"In that case, the stream will start out being (conceptually) empty.","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"size"},{"text":" is used only as a hint for how big ","type":"text"},{"type":"codeVoice","code":"data"},{"type":"text","text":" is.  Specifically,"},{"type":"text","text":" "},{"type":"text","text":"seeking to the end of a newly-created stream will seek to zero, not"},{"text":" ","type":"text"},{"code":"size","type":"codeVoice"},{"text":".  Seeking past the end of the stream and then writing will","type":"text"},{"text":" ","type":"text"},{"text":"introduce a zero-filled gap.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"realloc_fn"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"text":" then the stream is fixed-sized.  Seeking to","type":"text"},{"type":"text","text":" "},{"text":"the end will seek to ","type":"text"},{"type":"codeVoice","code":"size"},{"type":"text","text":" exactly.  Writing past the end will give"},{"type":"text","text":" "},{"text":"an ‘out of space’ error.  Attempting to seek past the end will fail.","type":"text"},{"text":" ","type":"text"},{"text":"Unlike the resizable case, seeking to an offset within the stream and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"writing will preserve the bytes passed in as "},{"code":"data","type":"codeVoice"},{"type":"text","text":" before that point"},{"type":"text","text":" "},{"type":"text","text":"and will return them as part of "},{"type":"codeVoice","code":"g_memory_output_stream_steal_data()"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"If you intend to seek you should probably therefore ensure that ","type":"text"},{"code":"data","type":"codeVoice"},{"text":" ","type":"text"},{"text":"is properly initialised.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is probably only meaningful to provide "},{"code":"data","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"size"},{"text":" in the case","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that you want a fixed-sized stream.  Put another way: if "},{"code":"realloc_fn","type":"codeVoice"},{"type":"text","text":" "},{"text":"is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" then it makes most sense to give ","type":"text"},{"code":"data","type":"codeVoice"},{"text":" as ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"size"},{"text":" as 0 (allowing ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStream","type":"reference","isActive":true},{"text":" to do the initial","type":"text"},{"text":" ","type":"text"},{"text":"allocation for itself).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["\/\/ a stream that can grow","stream = g_memory_output_stream_new (NULL, 0, realloc, free);","","\/\/ another stream that can grow","stream2 = g_memory_output_stream_new (NULL, 0, g_realloc, g_free);","","\/\/ a fixed-size stream","data = malloc (200);","stream3 = g_memory_output_stream_new (data, 200, NULL, free);"]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef"]]},"kind":"symbol","abstract":[{"type":"text","text":"Creates a new "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStream","isActive":true},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/memoryoutputstreamref\/init(data:size:reallocfunction:destroyfunction:)"]}],"references":{"doc://GIO/documentation/GIO/MemoryOutputStream":{"abstract":[{"code":"GMemoryOutputStream","type":"codeVoice"},{"type":"text","text":" is a class for using arbitrary"},{"type":"text","text":" "},{"type":"text","text":"memory chunks as output for GIO streaming output operations."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MemoryOutputStream","kind":"identifier"}],"url":"\/documentation\/gio\/memoryoutputstream","title":"MemoryOutputStream","kind":"symbol","navigatorTitle":[{"text":"MemoryOutputStream","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStream","type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/MemoryOutputStreamRef/init(data:size:reallocFunction:destroyFunction:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/init(data:size:reallocFunction: