{"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"metadata":{"modules":[{"name":"GIO"}],"extendedModule":"GIO","symbolKind":"method","roleHeading":"Instance Method","externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO21MemoryOutputStreamRefV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"close(cancellable:)","role":"symbol"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}]},{"inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers in the"},{"text":" ","type":"text"},{"type":"text","text":"stream."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"type":"text","text":" "},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stream for details."}],"type":"paragraph"},{"inlineContent":[{"text":"On failure the first error that happened will be reported, but the close","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations. Still, it","type":"text"},{"type":"text","text":" "},{"text":"is important to check and report the error to the user, otherwise","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"there might be a loss of data as all data might not be written."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but there some streams"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors. On"},{"text":" ","type":"text"},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"text":" ","type":"text"},{"type":"text","text":"data will reach the target."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/memoryoutputstreamref\/close(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/MemoryOutputStreamRef/close(cancellable:)":{"type":"topic","title":"close(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/close(cancellable:)","kind":"symbol","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"role":"symbol","url":"\/documentation\/gio\/memoryoutputstreamref\/close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/MemoryOutputStreamRef/OutputStreamProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef\/OutputStreamProtocol-Implementations","type":"topic","url":"\/documentation\/gio\/memoryoutputstreamref\/outputstreamprotocol-implementations","abstract":[],"kind":"article","title":"OutputStreamProtocol Implementations","role":"collectionGroup"},"doc://GIO/documentation/GIO/MemoryOutputStreamRef":{"navigatorTitle":[{"text":"MemoryOutputStreamRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryOutputStreamRef","kind":"symbol","abstract":[{"type":"codeVoice","code":"GMemoryOutputStream"},{"type":"text","text":" is a class for using arbitrary"},{"text":" ","type":"text"},{"text":"memory chunks as output for GIO streaming output operations.","type":"text"}],"title":"MemoryOutputStreamRef","url":"\/documentation\/gio\/memoryoutputstreamref","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MemoryOutputStreamRef"}],"type":"topic"}}}