{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"writev"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"vectors"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"GOutputVector","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"nVectors","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"text":">! = nil, ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"If ","type":"text"},{"code":"nVectors","type":"codeVoice"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is 0, returns 0 and"},{"type":"text","text":" "},{"text":"does nothing.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"text":" ","type":"text"},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"text":" ","type":"text"},{"text":"can happen e.g. on a partial I\/O error, or if there is not enough","type":"text"},{"type":"text","text":" "},{"type":"text","text":"storage in the stream. All writes block until at least one byte"},{"text":" ","type":"text"},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"text":" ","type":"text"},{"type":"codeVoice","code":"nVectors"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is 0)."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Some implementations of ","type":"text"},{"code":"g_output_stream_writev()","type":"codeVoice"},{"type":"text","text":" may have limitations on the"},{"text":" ","type":"text"},{"type":"text","text":"aggregate buffer size, and will return "},{"type":"codeVoice","code":"invalidArgument"},{"text":" if these","type":"text"},{"type":"text","text":" "},{"text":"are exceeded. For example, when writing to a local file on UNIX platforms,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the aggregate buffer size must not exceed "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" bytes."}