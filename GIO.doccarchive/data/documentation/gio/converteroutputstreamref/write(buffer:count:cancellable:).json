ed by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/converteroutputstreamref\/write(buffer:count:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","references":{"doc://GIO/documentation/GIO/ConverterOutputStreamRef/write(buffer:count:cancellable:)":{"title":"write(buffer:count:cancellable:)","kind":"symbol","url":"\/documentation\/gio\/converteroutputstreamref\/write(buffer:count:cancellable:)","abstract":[{"type":"text","text":"Tries to write "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from "},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" into the stream. Will block"},{"text":" ","type":"text"},{"text":"during the operation.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/write(buffer:count:cancellable:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"write"},{"kind":"text","text":"("},{"text":"b