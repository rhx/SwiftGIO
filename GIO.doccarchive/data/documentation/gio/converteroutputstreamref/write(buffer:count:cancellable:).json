{"metadata":{"extendedModule":"GIO","title":"write(buffer:count:cancellable:)","symbolKind":"method","externalID":"s:3GIO20OutputStreamProtocolPAAE5write6buffer5count11cancellableSiSvSg_SiAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO24ConverterOutputStreamRefV","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"write"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize"}]},"sections":[],"abstract":[{"text":"Tries to write ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" bytes from ","type":"text"},{"type":"codeVoice","code":"buffer"},{"type":"text","text":" into the stream. Will block"},{"type":"text","text":" "},{"text":"during the operation.","type":"text"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/write(buffer:count:cancellable:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"write","kind":"identifier"},{"kind":"text","text":"("},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv","kind":"typeIdentifier"}