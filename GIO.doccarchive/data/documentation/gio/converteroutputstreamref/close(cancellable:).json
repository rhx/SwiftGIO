{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"symbolKind":"method","title":"close(cancellable:)","modules":[{"name":"GIO"}],"role":"symbol","extendedModule":"GIO","roleHeading":"Instance Method","externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO24ConverterOutputStreamRefV"},"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/converteroutputstreamref\/close(cancellable:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"Once the stream is closed, all other operations will return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers in the"},{"text":" ","type":"text"},{"text":"stream.","type":"text"}]},{"inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"text":" ","type":"text"},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"type":"text","text":" "},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stream for details."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"text":"operation will finish as much as possible. A stream that failed to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations. Still, it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is important to check and report the error to the user, otherwise"},{"type":"text","text":" "},{"type":"text","text":"there might be a loss of data as all data might not be written."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"type":"text","text":"Cancelling a close will still leave the stream closed, but there some streams"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors. On"},{"text":" ","type":"text"},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"type":"text","text":"data will reach the target."}]}]}],"references":{"doc://GIO/documentation/GIO/ConverterOutputStreamRef/OutputStreamProtocol-Implementations":{"abstract":[],"title":"OutputStreamProtocol Implementations","type":"topic","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/OutputStreamProtocol-Implementations","kind":"article","url":"\/documentation\/gio\/converteroutputstreamref\/outputstreamprotocol-implementations"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/Converte