{"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ConverterOutputStreamRef\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/converteroutputstreamref\/writeasync(buffer:count:iopriority:cancellable:callback:userdata:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writeAsync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"During an async request no other sync and async calls are allowed,"},{"type":"text","text":" "},{"type":"text","text":"and will result in "},{"code":"pending","type":"codeVoice"},{"text":" errors.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A value of "},{"code":"count","type":"codeVoice"},{"text":" larger than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written will be passed to the"},{"text":" ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":". It is not an error if this is not the same as the"},{"text":" ","type":"text"},{"text":"requested size, as it can happen e.g. on a partial I\/O error,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but generally we try to write as many bytes as requested."}]},{"inlineContent":[{"type":"text","text":"You are guaranteed that this method will never fail with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" - if "},{"type":"codeVoice","code":"stream"},{"type":"text","text":" can’t accept more data, the"},{"type":"text","text":" "},{"type":"text","text":"method will just wait until this changes."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical"},{"text":" ","type":"text"},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}]},{"inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads","type":"text"},{"type":"text","text":" "},{"text":"to implement asynchronicity, so they are optional for inheriting","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"classes. However, if you override one you must override all."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"text":" ","type":"text"},{"code":"g_output_stream_write()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"Note that no copy of ","type":"text"},{"type":"codeVoice","code":"buffer"},{"type":"text","text":" will be made, so it must stay valid"},{"type":"text","text":" "},{"type":"text","text":"until "},{"code":"callback","type":"codeVoice"},{"text":" is called. See ","type":"text"},{"code":"g_output_stream_write_bytes_async()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the contents (without copying) for the duration of the call."}],"type":"paragraph"}]}],"metadata":{"roleHeading":"Instance Method","title":"writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"writeAsync"},{"kind":"text","text":"("},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeI