{"variants":[{"paths":["\/documentation\/gio\/appinforef"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"AppInfoRef","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"AppInfoRef","kind":"identifier"}],"role":"symbol","externalID":"s:3GIO10AppInfoRefV","symbolKind":"struct","roleHeading":"Structure","modules":[{"name":"GIO"}],"navigatorTitle":[{"text":"AppInfoRef","kind":"identifier"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/AppInfoRef"},"abstract":[{"type":"text","text":"Information about an installed application and methods to launch"},{"type":"text","text":" "},{"text":"it (with file arguments).","type":"text"}],"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(_:)-2bbeq","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(_:)-2nent","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(_:)-3yyz5","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(_:)-4bz7v","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(_:)-72cmu","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(opaquePointer:)"]},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/ptr"],"anchor":"Instance-Properties","title":"Instance Properties"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/createFrom(commandline:applicationName:flags:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/getDefaultFor(type:mustSupportURIs:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/getDefaultFor(typeFinish:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/getDefaultFor(uriScheme:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/getDefaultFor(uriSchemeFinish:)"],"title":"Type Methods","generated":true,"anchor":"Type-Methods"},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/AppInfoProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/PointerWrapper-Implementations"]}],"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AppInfoRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GAppInfo"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"GAppLaunchContext"},{"text":" are used for describing and launching","type":"text"},{"type":"text","text":" "},{"type":"text","text":"applications installed on the system."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As of GLib 2.20, URIs will always be converted to POSIX paths"},{"type":"text","text":" "},{"type":"text","text":"(using [method"},{"type":"codeVoice","code":"Gio.File.get_path"},{"type":"text","text":"]) when using [method"},{"type":"codeVoice","code":"Gio.AppInfo.launch"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"even if the application requested an URI and not a POSIX path. For example","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for a desktop-file based application with the following Exec key:"}]},{"syntax":null,"code":["Exec=totem `U`"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"and a single URI, ","type":"text"},{"code":"sftp:\/\/foo\/file.avi","type":"codeVoice"},{"type":"text","text":", then"},{"text":" ","type":"text"},{"code":"\/home\/user\/.gvfs\/sftp on foo\/file.avi","type":"codeVoice"},{"type":"text","text":" will be passed. This will only work"},{"type":"text","text":" "},{"type":"text","text":"if a set of suitable GIO extensions (such as GVfs 2.26 compiled with FUSE"},{"text":" ","type":"text"},{"type":"text","text":"support), is available and operational; if this is not the case, the URI"},{"type":"text","text":" "},{"type":"text","text":"will be passed unmodified to the application. Some URIs, such as "},{"code":"mailto:","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of course cannot be mapped to a POSIX path (in GVfs there’s no FUSE mount"},{"text":" ","type":"text"},{"type":"text","text":"for it); such URIs will be passed unmodified to the application."}]},{"inlineContent":[{"text":"Specifically for GVfs 2.26 and later, the POSIX URI will be mapped","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"back to the GIO URI in the [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},{"text":"] constructors (since GVfs","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implements the GVfs extension point). As such, if the application"},{"type":"text","text":" "},{"text":"needs to examine the URI, it needs to use [method","type":"text"},{"code":"Gio.File.get_uri","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"text":"or similar on [iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},{"text":"]. In other words, an application cannot","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"assume that the URI passed to e.g. [func"},{"type":"codeVoice","code":"Gio.File.new_for_commandline_arg"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"is equal to the result of [method","type":"text"},{"type":"codeVoice","code":"Gio.File.get_uri"},{"text":"]. The following snippet","type":"text"},{"type":"text","text":" "},{"text":"illustrates this:","type":"text"}],"type":"paragraph"},{"syntax":"c","type":"codeListing","code":["GFile *f;","char *uri;","","file = g_file_new_for_commandline_arg (uri_from_commandline);","","uri = g_file_get_uri (file);","strcmp (uri, uri_from_commandline) == 0;","g_free (uri);","","if (g_file_has_uri_scheme (file, \"cdda\"))","  {","    \/\/ do something special with uri","  }","g_object_unref (file);"]},{"type":"paragraph","inlineContent":[{"text":"This code will work when both ","type":"text"},{"code":"cdda:\/\/sr0\/Track 1.wav","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"\/home\/user\/.gvfs\/cdda on sr0\/Track 1.wav"},{"type":"text","text":" is passed to the"},{"type":"text","text":" "},{"type":"text","text":"application. It should be noted that it’s generally not safe"},{"text":" ","type":"text"},{"type":"text","text":"for applications to rely on the format of a particular URIs."},{"text":" ","type":"text"},{"text":"Different launcher applications (e.g. file managers) may have","type":"text"},{"text":" ","type":"text"},{"text":"different ideas of what a given URI means.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoRef"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GAppInfo"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoProtocol","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoRef","type":"reference","isActive":true},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GAppInfo"},{"text":" instance.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfo","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoRef","type":"reference","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GAppInfo"},{"type":"text","text":" instance."}]}],"name":"Note","type":"aside","style":"note"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/AppInfoRef/init(_:)-2bbeq":{"type":"topic","kind":"symbol","url":"\/documentation\/gio\/appinforef\/init(_:)-2bbeq","abstract":[{"type":"text","text":"Designated initialiser from a constant pointer to the underlying "},{"type":"codeVoice","code":"C"},{"text":" data type","type":"text"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoRef\/init(_:)-2bbeq","title":"init(_:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GAppInfo"},{"text":">)","kind":"text"}]},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/d