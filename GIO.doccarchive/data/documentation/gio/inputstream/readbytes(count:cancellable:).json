ll be returned, without an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"On error ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" is set accordingly.","type":"text"}]}]}],"metadata":{"title":"readBytes(count:cancellable:)","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"readBytes","kind":"identifier"},{"kind":"text","text":"("},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"BytesRef","preciseIdentifier":"s:4GLib8BytesRefV"},{"kind":"text","text":"!"}],"extendedModule":"GIO","symbolKind":"method","modules":[{"name":"GIO"}],"externalID":"s:3GIO19InputStreamProtocolPAAE9readBytes5count11cancellable4GLib0F3RefVSgSi_AA011CancellableJ0VSgtKF::SYNTHESIZED::s:3GIO11InputStreamC","role":"symbol"},"references":{"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragment