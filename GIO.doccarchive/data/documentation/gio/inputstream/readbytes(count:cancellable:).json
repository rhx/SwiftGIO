{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStream\/readBytes(count:cancellable:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Like "},{"code":"g_input_stream_read()","type":"codeVoice"},{"type":"text","text":", this tries to read "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from"},{"text":" ","type":"text"},{"type":"text","text":"the stream in a blocking fashion. However, rather than reading into"},{"type":"text","text":" "},{"text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the data that was read. This may be easier to use from language"},{"text":" ","type":"text"},{"text":"bindings.","type":"text"}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStream","doc:\/\/GIO\/documentation\/GIO\/InputStream\/InputStreamProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/gio\/inputstream\/readbytes(count:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readBytes"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef","kind":"typeIdentifier"},{"text":"!","kind":"text