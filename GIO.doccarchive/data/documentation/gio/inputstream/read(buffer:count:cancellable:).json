{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"read","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If count is zero returns zero and does nothing. A value of "},{"type":"codeVoice","code":"count"},{"text":" ","type":"text"},{"text":"larger than ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" will cause a "},{"code":"invalidArgument","type":"codeVoice"},{"type":"text","text":" error."}]},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes read into the buffer is returned.","type":"text"},{"type":"text","text":" "},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can happen e.g. near the end of a file. Zero is returned on end of file"},{"type":"text","text":" "},{"text":"(or if ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is zero),  but never otherwise.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The returned "},{"type":"codeVoice","code":"buffer"},{"text":" is not a nul-terminated string, it can contain nul bytes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"at any position, and this function doesn’t nul-terminate the "},{"type":"codeVoice","code":"buffer"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"read","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIden