{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/inputstream\/close(cancellable:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InputStream","doc:\/\/GIO\/documentation\/GIO\/InputStream\/InputStreamProtocol-Implementations"]]},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InputStream\/close(cancellable:)","interfaceLanguage":"swift"},"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO11InputStreamC","symbolKind":"method","role":"symbol","title":"close(cancellable:)"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Closing a stream multiple times will not return an error."}],"type":"paragraph"},{"inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"text":"resources are released as early as possible.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"text":" ","type":"text"},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"text":" ","type":"text"},{"type":"text","text":"stream for details."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"text":" ","type":"text"},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"text":" ","type":"text"},{"type":"text","text":"close will still return "},{"code":"closed","type":"codeVoice"},{"text":" for all operations. Still, it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important to check and report the error to the user."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/InputStream/InputStreamProtocol-Implementations":{"abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream\/InputStreamProtocol-Implementations","type":"topic","title":"InputStreamProtocol Implementations","role":"collectionGroup","kind":"article","url":"\/documentation\/gio\/inputstream\/inputstreamprotocol-implementations"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/InputStream/close(cancellable:)":{"type":"topic","title":"close(cancellable:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream\/close(cancellable:)","url":"\/documentation\/gio\/inputstream\/close(cancellable:)"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}