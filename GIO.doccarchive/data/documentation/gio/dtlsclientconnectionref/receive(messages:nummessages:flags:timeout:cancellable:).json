{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionRef\/receive(messages:numMessages:flags:timeout:cancellable:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"receive"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GInputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"timeout"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"messages"},{"text":" must point to an array of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"text":" structs and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"contains a pointer to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true,"type":"reference"},{"type":"text","text":" structs describing the"},{"type":"text","text":" "},{"type":"text","text":"buffers that the data received in each message will be written to."}]},{"type":"paragraph","inlineContent":[{"code":"flags","type":"codeVoice"},{"type":"text","text":" modify how all messages are received. The commonly available"},{"text":" ","type":"text"},{"type":"text","text":"arguments for this are available in the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","type":"reference","isActive":true},{"text":" enum, but the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"values there are the same as the system values, and the flags"},{"text":" ","type":"text"},{"text":"are passed in as-is, so you can pass in system-specific flags too. These","type":"text"},{"type":"text","text":" "},{"type":"text","text":"flags affect the overall receive operation. Flags affecting individual"},{"type":"text","text":" "},{"type":"text","text":"messages are returned in "},{"code":"GInputMessage.flags","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The other members of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","type":"reference","isActive":true},{"type":"text","text":" are treated as described in its"},{"text":" ","type":"text"},{"type":"text","text":"documentation."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"text":" is negative the call will block until ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" have been"},{"text":" ","type":"text"},{"text":"received, the connection is closed remotely (EOS), ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is cancelled,"},{"type":"text","text":" "},{"text":"or an error occurs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"text":" is 0 the call will return up to ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" without blocking,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" if no messages are queued in the operating system"},{"type":"text","text":" "},{"type":"text","text":"to be received."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is positive the call will block on the same conditions as if","type":"text"},{"type":"text","text":" "},{"code":"timeout","type":"codeVoice"},{"text":" were negative. If the timeout is reached","type":"text"},{"type":"text","text":" "},{"type":"text","text":"before any messages are received, "},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned,"},{"text":" ","type":"text"},{"type":"text","text":"otherwise it will return the number of messages received before timing out."},{"text":" ","type":"text"},{"text":"(Note: This is effectively the behaviour of ","type":"text"},{"type":"codeVoice","code":"MSG_WAITFORONE"},{"text":" with","type":"text"},{"text":" ","type":"text"},{"code":"recvmmsg()","type":"codeVoice"},{"type":"text","text":".)"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To be notified when messages are available, wait for the [in_](\/\/documentation\/gobject\/in_ condition."},{"text":" ","type":"text"},{"text":"Note though that you may still receive ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"text":" from","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":" even if you were previously notified of a"},{"type":"text","text":" "},{"text":"[in_](\/\/documentation\/gobject\/in_ condition.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the remote peer closes the connection, any messages queued in the"},{"text":" ","type":"text"},{"type":"text","text":"underlying receive buffer will be returned, and subsequent calls to"},{"type":"text","text":" "},{"code":"g_datagram_based_receive_messages()","type":"codeVoice"},{"type":"text","text":" will return 0 (with no error set)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"type":"codeVoice","code":"shutdown_read"},{"type":"text","text":" set, if it’s a "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true},{"type":"text","text":", for"},{"type":"text","text":" "},{"text":"example), all calls to this function will return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly. An error will only"},{"type":"text","text":" "},{"type":"text","text":"be returned if zero messages could be received; otherwise the number of"},{"text":" ","type":"text"},{"text":"messages successfully received before the error will be returned. If","type":"text"},{"text":" ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is cancelled, ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" is returned as with any"},{"text":" ","type":"text"},{"text":"other error.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsclientconnectionref\/receive(messages:nummessages:flags:timeout:cancellable:)"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionRef\/DatagramBasedProtocol-Implementations"]]},"abstract":[{"text":"Receive one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"text":" in one go.","type":"text"}],"metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"receive"},{"kind":"text","text":"("},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gint64","preciseIdentifier":"c:glibconfig.h@T@gint64","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"extendedModule":"GIO","modules":[{"name":"GIO"}],"title":"re