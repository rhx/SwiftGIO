":"reference"},{"text":" structs and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"contains an address to send the data to, and a pointer to an array of"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","type":"reference","isActive":true},{"type":"text","text":" structs to describe the buffers that the data to be sent"},{"text":" ","type":"text"},{"type":"text","text":"for each message will be gathered from."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"flags","type":"codeVoice"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for this are available in the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true},{"type":"text","text":" enum, but the"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"text":" ","type":"text"},{"text":"are passed in as-is, so you can pass in system-specific flags too.","type":"text"}]},{"inlineContent":[{"text":"The other members of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","type":"reference"},{"text":" are treated as described in its","type":"text"},{"type":"text","text":" "},{"text":"documentation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is negative the call will block until ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" have been"},{"type":"text","text":" "},{"type":"text","text":"sent, "},{"code":"cancellable","type":"codeVoice"},{"text":" is cancelled, or an error occurs.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is 0 the call will send up to "},{"type":"codeVoice","code":"numMessages"},{"text":" without blocking,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or will return "},{"type":"codeVoice","code":"wouldBlock"},{"text":" if there is no space to send messages.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"text":" ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" were negative. If the timeout is reached before any messages are"},{"type":"text","text":" "},{"type":"text","text":"sent, "},{"type":"codeVoice","code":"timedOut"},{"text":" is returned, otherwise it will return the number","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of messages sent before timing out."}]},{"inlineContent":[{"type":"text","text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition."},{"text":" ","type":"text"},{"type":"text","text":"Note though that you may still receive "},{"type":"codeVoice","code":"wouldBlock"},{"text":" from","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"text":" even if you were previously notified of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to"},{"type":"text","text":" "},{"type":"text","text":"the way the underlying APIs work.)"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_shutdown()"},{"text":" with ","type":"text"},{"code":"shutdown_write","type":"codeVoice"},{"text":" set, if it’s a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":", for"},{"text":" ","type":"text"},{"text":"example), all calls to this function will return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"type":"text","text":"be returned if zero messages could be sent; otherwise the number of messages"},{"text":" ","type":"text"},{"type":"text","text":"successfully sent before the error will be returned. If "},{"type":"codeVoice","code":"cancellable"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"cancelled, ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any other error."}],"type":"paragraph"}]}],"abstract":[{"text":"Send one or more data messages from ","type":"text"},{"code":"datagramBased","type":"codeVoice"},{"type":"text","text":" in one go."}],"references":{"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Soc