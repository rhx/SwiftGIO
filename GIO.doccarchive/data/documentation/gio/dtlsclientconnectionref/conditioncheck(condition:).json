":"codeVoice","code":"g_datagram_based_receive_messages()"},{"text":", or if the connection is closed remotely","type":"text"},{"text":" ","type":"text"},{"text":"(EOS); and if the datagram_based has not been closed locally using some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation-specific method (such as "},{"code":"g_socket_close()","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"code":"shutdown_read","type":"codeVoice"},{"text":" set, if it’s a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"type":"codeVoice","code":"g_socket_close()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_shutdown()"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"shutdown_read"},{"type":"text","text":" set, if it’s a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"text":", for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example), all calls to this function will return "},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[out](\/\/documentation\/gobject\/out will be set if it is expected that at least one byte can be sent"},{"type":"text","text":" "},{"text":"using ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"type":"text","text":" without blocking. It will not be set"},{"type":"text","text":" "},{"type":"text","text":"if the datagram_based has been closed locally."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[hup](\/\/documentation\/gobject\/hup will be set if the connection has be