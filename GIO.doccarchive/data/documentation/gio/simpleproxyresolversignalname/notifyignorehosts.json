{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notifyIgnoreHosts","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Entries can be in one of 4 formats:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A hostname, such as “example.com”, “.example.com”, or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“*.example.com”, any of which match “example.com” or"},{"type":"text","text":" "},{"text":"any subdomain of it.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An IPv4 or IPv6 address, such as “192.168.1.1”,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which matches only that address."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A hostname or IP address followed by a port, such as"},{"type":"text","text":" "},{"text":"“example.com:80”, which matches whatever the hostname or IP","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"address would match, but only for URLs with the (explicitly)"},{"text":" ","type":"text"},{"type":"text","text":"indicated port. In the case of an IPv6 address, the address"},{"type":"text","text":" "},{"text":"part must appear in brackets: “[","type":"text"},{"type":"codeVoice","code":"1"},{"type":"text","text":"]:443”"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An IP address range, given by a base address and prefix length,"},{"type":"text","text":" "},{"text":"such as “fe80``\/10”, which matches any address in that range.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Note that when dealing with Unicode hostnames, the matching is"},{"text":" ","type":"text"},{"text":"done against the ASCII form of the name.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Also note that hostname exclusions apply only to connections made","type":"text"},{"text":" ","type":"text"},{"text":"to hosts identified by name, and IP address exclusions apply only","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to connections made to hosts identified by address. That is, if"},{"type":"text","text":" "},{"text":"example.com has an address of 192.168.1.1, and the :ignore-hosts list","type":"text"},{"text":" ","type":"text"},{"text":"contains only “192.168.1.1”, then a connection to “example.com”","type":"text"},{"text":" ","type":"text"},{"text":"(eg, via a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkAddress","isActive":true},{"text":") will use the proxy, and a connection to","type":"text"},{"text":" ","type":"text"},{"text":"“192.168.1.1” (eg, via a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress","isActive":true},{"text":") will not.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"These rules match the “ignore-hosts”\/“noproxy” rules most","type":"text"},{"type":"text","text":" "},{"type":"text","text":"commonly used by other applications."}]}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/simpleproxyresolversignalname\/notifyignorehosts"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","roleHeading":"Case","externalID":"s:3GIO29SimpleProxyResolverSignalNameO17notifyIgnoreHostsyA2CmF","symbolKind":"case","title":"SimpleProxyResolverSignalName.notifyIgnoreHosts","modules":[{"name":"GIO"}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notifyIgnoreHosts","kind":"identifier"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/docum