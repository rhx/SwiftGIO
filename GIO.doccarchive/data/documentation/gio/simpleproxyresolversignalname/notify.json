{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SimpleProxyResolverSignalName\/notify","interfaceLanguage":"swift"},"sections":[],"metadata":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}],"modules":[{"name":"GIO"}],"symbolKind":"case","title":"SimpleProxyResolverSignalName.notify","role":"symbol","externalID":"s:3GIO29SimpleProxyResolverSignalNameO6notifyyA2CmF","roleHeading":"Case"},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleProxyResolverSignalName"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":" results"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]}]}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/simpleproxyresolversignalname\/notify"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"#class@GObject.ParamSpec#parameter-names":{"identifier":"#class@GObject.ParamSpec#parameter-names","title":"canonical parameter names","type":"link","titleInlineContent":[{"type":"text","text":"canonical parameter names"}],"url":"#class@GObject.ParamSpec#parameter-names"},"doc://GIO/documentation/GIO/SimpleProxyResolverSignalName/notify":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleProxyResolverSignalName\/notify","abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}],"type":"topic","role":"symbol","kind":"symbol","title":"SimpleProxyResolverSignalName.notify","url":"\/documentation\/gio\/simpleproxyresolversignalname\/notify"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SimpleProxyResolverSignalName":{"fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SimpleProxyResolverSignalName"}],"title":"SimpleProxyResolverSignalName","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleProxyResolverSignalName","role":"symbol","type":"topic","abstract":[],"kind":"symbol","url":"\/documentation\/gio\/simpleproxyresolversignalname","navigatorTitle":[{"kind":"identifier","text":"SimpleProxyResolverSignalName"}]}}}