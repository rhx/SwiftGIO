{"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onItemsChanged","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"text":"MenuModelRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","preciseIdentifier":"s:3GIO12MenuModelRefV"},{"kind":"text","text":", "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}]},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The signal handler to call"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"itemsChanged"},{"type":"text","text":" signal is emitted"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"The only changes that can occur to a menu is that items are removed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or added.  Items may not change (except by being removed and added"},{"type":"text","text":" "},{"type":"text","text":"back in the same location).  This signal is capable of describing"},{"text":" ","type":"text"},{"type":"text","text":"both of those changes (at the same time)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The signal means that starting at the index "},{"code":"position","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"removed"},{"text":" ","type":"text"},{"type":"text","text":"items were removed and "},{"type":"codeVoice","code":"added"},{"type":"text","text":" items were added in their place.  If"},{"type":"text","text":" "},{"type":"codeVoice","code":"removed"},{"text":" is zero then only items were added.  If ","type":"text"},{"code":"added","type":"codeVoice"},{"type":"text","text":" is zero"},{"type":"text","text":" "},{"text":"then only items were removed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"As an example, if the menu contains items a, b, c, d (in that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"order) and the signal (2, 1, 3) occurs then the new composition of"},{"type":"text","text":" "},{"type":"text","text":"the menu will be a, b, _, _, _, d (with each _ representing some"},{"text":" ","type":"text"},{"type":"text","text":"new item)."}]},{"inlineContent":[{"type":"text","text":"Signal handlers may query the model (particularly the added items)"},{"text":" ","type":"text"},{"text":"and expect to see the results of the modification that is being","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reported.  The signal is emitted after the modification."}],"type":"paragraph"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"items-changed","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"name":"Note","type":"aside"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/MenuModelProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Emitted when a change has occurred to the menu."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/onItemsChanged(flags:handler:)","interfaceLanguage":"swift"},"metadata":{"externalID":"s:3GIO17MenuModelProtocolPAAE14onItemsChanged5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_S3itctF::SYNTHESIZED::s:3GIO12MenuModelRefV","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onItemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"preciseIdentifier":"s:3GIO12MenuModelRefV","kind":"typeIdentifier","text":"MenuModelRef"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"roleHeading":"Instance Method","extendedModule":"GIO","title":"onItemsChanged(flags:handler:)","modules":[{"name":"GIO"}],"symbolKind":"method"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menumodelref\/onitemschanged(flags:handler:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModelRef/onItemsChanged(flags:handler:)":{"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onItemsChanged"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"text":"MenuModelRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO12MenuModelRefV"},{"kind":"text","text":", "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"abstract":[{"type":"text","text":"Emitted when a change has occurred to the menu."}],"url":"\/documentation\/gio\/menumodelref\/onitemschanged(flags:handler:)","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/onItemsChanged(flags:handler:)","role":"symbol","title":"onItemsChanged(flags:handler:)"},"doc://GIO/documentation/GIO/MenuModelRef/MenuModelProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/MenuModelProtocol-Implementations","type":"topic","kind":"article","role":"collectionGroup","abstract":[],"title":"MenuModelProtocol Implementations","url":"\/documentation\/gio\/menumodelref\/menumodelprotocol-implementations"},"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"}}}