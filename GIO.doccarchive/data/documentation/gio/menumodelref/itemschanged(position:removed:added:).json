{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/itemsChanged(position:removed:added:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/MenuModelProtocol-Implementations"]]},"abstract":[{"text":"Requests emission of the [MenuModel](\/\/documentation\/gio\/menumodel\/onitemschanged(flags:handler:) signal on ","type":"text"},{"code":"model","type":"codeVoice"},{"type":"text","text":"."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menumodelref\/itemschanged(position:removed:added:)"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"itemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"position"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"removed"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"added","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"This function should never be called except by "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"subclasses.  Any other calls to this function will very likely lead","type":"text"},{"text":" ","type":"text"},{"text":"to a violation of the interface of the model.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The implementation should update its internal representation of the"},{"type":"text","text":" "},{"type":"text","text":"menu before emitting the signal.  The implementation should further"},{"type":"text","text":" "},{"text":"expect to receive queries about the new state of the menu (and","type":"text"},{"text":" ","type":"text"},{"text":"particularly added menu items) while signal handlers are running.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The implementation must dispatch this call directly from a mainloop"},{"type":"text","text":" "},{"text":"entry and not in response to calls – particularly those from the","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference","isActive":true},{"type":"text","text":" API.  Said another way: the menu must not change while"},{"text":" ","type":"text"},{"text":"user code is running without returning to the mainloop.","type":"text"}]}],"kind":"content"}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"itemsChanged","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"position"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"removed"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"added"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":")"}],"modules":[{"name":"GIO"}],"title":"itemsChanged(position:removed:added:)","externalID":"s:3GIO17MenuModelProtocolPAAE12itemsChanged8position7removed5addedySi_S2itF::SYNTHESIZED::s:3GIO12MenuModelRefV","extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"m