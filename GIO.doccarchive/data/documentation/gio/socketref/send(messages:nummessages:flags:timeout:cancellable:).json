":"text","text":" "},{"text":"for each message will be gathered from.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" modify how the message is sent. The commonly available arguments"},{"type":"text","text":" "},{"text":"for this are available in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"type":"text","text":" enum, but the"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"text":"are passed in as-is, so you can pass in system-specific flags too.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The other members of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true},{"type":"text","text":" are treated as described in its"},{"type":"text","text":" "},{"type":"text","text":"documentation."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is negative the call will block until ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" have been","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"sent, "},{"code":"cancellable","type":"codeVoice"},{"text":" is cancelled, or an error occurs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is 0 the call will send up to "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" without blocking,"},{"type":"text","text":" "},{"text":"or will return ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"text":" if there is no space to send messages.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"type":"text","text":" "},{"type":"codeVoice","code":"timeout"},{"text":" were negative. If the timeout is reached before any messages are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"sent, "},{"type":"codeVoice","code":"timedOut"},{"text":" is returned, otherwise it will return the number","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of messages sent before timing out."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition."},{"type":"text","text":" "},{"type":"text","text":"Note though that you may still receive "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" from"},{"text":" ","type":"text"},{"code":"g_datagram_based_send_messages()","type":"codeVoice"},{"type":"text","text":" even if you were previously notified of a"},{"type":"text","text":" "},{"type":"text","text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to"},{"text":" ","type":"text"},{"text":"the way the underlying APIs work.)","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"type":"codeVoice","code":"g_socket_close()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"g_socket_shutdown()","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"shutdown_write","type":"codeVoice"},{"text":" set, if it’s a ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference","isActive":true},{"type":"text","text":", for"},{"text":" ","type":"text"},{"type":"text","text":"example), all calls to this function will return "},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" is set accordingly. An error will only","type":"text"},{"text":" ","type":"text"},{"text":"be returned if zero messages could be sent; otherwise the number of messages","type":"text"},{"text":" ","type":"text"},{"text":"successfully sent before the error will be returned. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"cancelled, "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any other error."}]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketref\/send(messages:nummessages:flags:timeout:cancellable:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/send(messages:numMessages:flags:timeout:cancellable:)"},"kind":"symbol","abstract":[{"text":"Send one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketRef","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/DatagramBasedProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SocketRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef","title":"SocketRef","url":"\/documentation\/gio\/socketref","abstract":[{"type":"text","text":"A "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"text":" ","type":"text"},{"text":"direct mapping of the BSD socket API in a portable GObject based API.","type":"text"},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementatio