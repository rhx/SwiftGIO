{"variants":[{"paths":["\/documentation\/gio\/socketref\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init_(cancellable:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketRef","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/InitableProtocol-Implementations"]]},"kind":"symbol","metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","title":"init_(cancellable:)","extendedModule":"GIO","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO9SocketRefV","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_initable_new()"},{"type":"text","text":" should typically be used instead."}]},{"type":"paragraph","inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"text":" ","type":"text"},{"text":"construction, either with this function or ","type":"text"},{"code":"g_async_initable_init_async()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Implementations may also support cancellation. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"text":" ","type":"text"},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and"},{"type":"text","text":" "},{"text":"the object doesn’t support cancellable initialization the error","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}]},{"type":"paragraph","inlineContent":[{"text":"If the object is not initialized, or initialization returns with an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"error, then all operations on the object except "},{"code":"g_object_ref()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"text":" ","type":"text"},{"type":"text","text":"behaviour. See the "},{"type":"reference","identifier":"#iface@Gio.Initable#description","isActive":true},{"type":"text","text":" for more details."}]},{"inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"type":"text","text":" can be"},{"text":" ","type":"text"},{"text":"initialized multiple times, unless the class explicitly documents itself as","type":"text"},{"text":" ","type":"text"},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"type":"codeVoice","code":"init()"},{"text":" can assume","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"text":" ","type":"text"},{"type":"text","text":"recommended all "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"text":" implementations should be idempotent; that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}],"type":"paragraph"},{"inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"text":" ","type":"text"},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"type":"text","text":" "},{"type":"text","text":"the object; further calls return the result of the first call."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"text":" ","type":"text"},{"text":"it is designed to be used via the singleton pattern, with a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GObjectClass.constructor"},{"text":" that sometimes returns an existing instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"In this pattern, a caller would expect to be able to call "},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"type":"text","text":"on the result of "},{"type":"codeVoice","code":"g_object_new()"},{"type":"text","text":", regardless of whether it is in fact a new"},{"type":"text","text":" "},{"text":"instance.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"#iface@Gio.Initable#description":{"type":"link","identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description","title":"description","titleInlineContent":[{"text":"description","type":"text"}]},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/SocketRef/InitableProtocol-Implementations":{"title":"InitableProtocol Implementations","url":"\/documentation\/gio\/socketref\/initableprotocol-implementations","kind":"article","abstract":[],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/InitableProtocol-Implementations","role":"collectionGroup"},"doc://GIO/documentation/GIO/SocketRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef","title":"SocketRef","url":"\/documentation\/gio\/socketref","abstract":[{"type":"text","text":"A "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"text":" ","type":"text"},{"text":"direct mapping of the BSD socket API in a portable GObject based API.","type":"text"},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SocketRef","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/SocketRef/init_(cancellable:)":{"url":"\/documentation\/gio\/socketref\/init_(cancellable:)","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/init_(cancellable:)","title":"init_(cancellable:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"type":"topic"}}}