{"abstract":[{"type":"text","text":"When a socket is created it is attached to an address family, but it"},{"type":"text","text":" "},{"text":"doesn’t have an address in this family. ","type":"text"},{"type":"codeVoice","code":"g_socket_bind()"},{"text":" assigns the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"address (sometimes called name) of the socket."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/bind(address:allowReuse:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"modules":[{"name":"GIO"}],"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","extendedModule":"GIO","title":"bind(address:allowReuse:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"bind","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"SocketAddressT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"address"},{"kind":"text","text":": "},{"text":"SocketAddressT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"allowReuse"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"externalID":"s:3GIO14SocketProtocolPAAE4bind7address10allowReuseSbqd___SbtKAA0b7AddressC0Rd__lF::SYNTHESIZED::s:3GIO9SocketRefV"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"bind","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SocketAddressT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"address","kind":"externalParam"},{"kind":"text","text":": "},{"text":"SocketAddressT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"allowReuse"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"SocketAddressT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddressProtocol","preciseIdentifier":"s:3GIO21SocketAddressProtocolP","text":"SocketAddressProtocol","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"It is generally required to bind to a local address before you can","type":"text"},{"text":" ","type":"text"},{"text":"receive connections. (See ","type":"text"},{"code":"g_socket_listen()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"g_socket_accept()","type":"codeVoice"},{"text":" ).","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"In certain situations, you may also want to bind a socket that will be"},{"type":"text","text":" "},{"text":"used to initiate connections, though this is not normally required.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"socket"},{"type":"text","text":" is a TCP socket, then "},{"type":"codeVoice","code":"allowReuse"},{"type":"text","text":" controls the setting"},{"text":" ","type":"text"},{"text":"of the ","type":"text"},{"type":"codeVoice","code":"SO_REUSEADDR"},{"type":"text","text":" socket option; normally it should be "},{"code":"true","type":"codeVoice"},{"text":" for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"server sockets (sockets that you will eventually call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_accept()"},{"text":" on), and ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" for client sockets. (Failing to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"set this flag on a server socket may cause "},{"type":"codeVoice","code":"g_socket_bind()"},{"type":"text","text":" to return"},{"text":" ","type":"text"},{"code":"addressInUse","type":"codeVoice"},{"text":" if the server program is stopped and then","type":"text"},{"text":" ","type":"text"},{"text":"immediately restarted.)","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"socket","type":"codeVoice"},{"text":" is a UDP socket, then ","type":"text"},{"type":"codeVoice","code":"allowReuse"},{"type":"text","text":" determines whether or"},{"text":" ","type":"text"},{"text":"not other UDP sockets can be bound to the same address at the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"time. In particular, you can have several UDP sockets bound to the"},{"type":"text","text":" "},{"text":"same address, and they will all receive all of the multicast and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"broadcast packets sent to that address. (The behavior of unicast"},{"type":"text","text":" "},{"type":"text","text":"UDP packets to an address with multiple listeners is not defined.)"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/socketref\/bind(address:allowreuse:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketRef","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/SocketProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/SocketRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef","title":"SocketRef","url":"\/documentation\/gio\/socketref","abstract":[{"type":"text","text":"A "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"text":" ","type":"text"},{"text":"direct mapping of the BSD socket API in a portable GObject based API.","type":"text"},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SocketRef","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/SocketRef/SocketProtocol-Implementations":{"title":"SocketProtocol Implementations","abstract":[],"role":"collectionGroup","url":"\/documentation\/gio\/socketref\/socketprotocol-implementations","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/SocketProtocol-Implementations","kind":"article"},"doc://GIO/documentation/GIO/SocketRef/bind(address:allowReuse:)":{"abstract":[{"type":"text","text":"When a socket is created it is attached to an address family, but it"},{"type":"text","text":" "},{"type":"text","text":"doesn’t have an address in this family. "},{"type":"codeVoice","code":"g_socket_bind()"},{"type":"text","text":" assigns the"},{"type":"text","text":" "},{"text":"address (sometimes called name) of the socket.","type":"text"}],"type":"topic","role":"symbol","title":"bind(address:allowReuse:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"bind","kind":"identifier"},{"kind":"text","text":"<"},{"text":"SocketAddressT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"address","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SocketAddressT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"allowReuse"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/bind(address:allowReuse:)","url":"\/documentation\/gio\/socketref\/bind(address:allowreuse:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/UnixSocketAddress":{"title":"UnixSocketAddress","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnixSocketAddress"}],"type":"topic","url":"\/documentation\/gio\/unixsocketaddress","abstract":[{"type":"text","text":"Support for UNIX-domain (also known as local) sockets, corresponding to"},{"type":"text","text":" "},{"type":"codeVoice","code":"struct sockaddr_un"},{"type":"text","text":"."}],"role":"symbol","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"UnixSocketAddress"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress"},"doc://GIO/documentation/GIO/InetSocketAddress":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InetSocketAddress"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress","abstract":[{"text":"An IPv4 or IPv6 socket address. That is, the combination of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddress","isActive":true,"type":"reference"},{"type":"text","text":"] and a port number."}],"url":"\/documentation\/gio\/inetsocketaddress","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"InetSocketAddress","kind":"identifier"}],"type":"topic","title":"InetSocketAddress"},"doc://GIO/documentation/GIO/SocketAddressProtocol":{"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"SocketAddressProtocol","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddressProtocol","abstract":[{"type":"codeVoice","code":"GSocketAddress"},{"text":" is the equivalent of","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"man:sockaddr(3type)","isActive":true},{"text":" and its subtypes in the BSD sockets","type":"text"},{"type":"text","text":" "},{"type":"text","text":"API. This is an abstract class; use [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress","type":"reference","isActive":true},{"type":"text","text":"] for"},{"text":" ","type":"text"},{"type":"text","text":"internet sockets, or [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress"},{"text":"] for UNIX domain sockets.","type":"text"}],"url":"\/documentation\/gio\/socketaddressprotocol","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketAddressProtocol","kind":"identifier"}],"type":"topic","title":"SocketAddressProtocol"},"man:sockaddr(3type)":{"titleInlineContent":[{"code":"struct sockaddr","type":"codeVoice"}],"title":"struct sockaddr","identifier":"man:sockaddr(3type)","url":"man:sockaddr(3type)","type":"link"}}}