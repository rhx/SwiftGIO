pe":"text"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/receive(messages:numMessages:flags:cancellable:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"receive"},{"kind":"text","text":"("},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"text":" must point to an array of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"type":"text","text":" structs and"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"text":" must be the length of this array. Each ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"contains a pointer to an array of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true},{"type":"text","text":" structs describing the"},{"type":"text","text":" "},{"type":"text","text":"buffers that the data received in each message will be written to. Using"},{"type":"text","text":" "},{"text":"multiple ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"text":" is more memory-efficient than manually copying data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"out of a single buffer to multiple sources, and more system-call-efficient"},{"type":"text","text":" "},{"type":"text","text":"than making multiple calls to "},{"code":"g_socket_receive()","type":"codeVoice"},{"type":"text","text":", such as in scenarios where"},{"type":"text","text":" "},{"text":"a lot of data packets need to be received (e.g. high-bandwidth video","type":"text"},{"type":"text","text":" "},{"type":"text","text":"streaming over RTP\/UDP)."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" modify how all messages are received. The commonly available"},{"type":"text","text":" "},{"type":"text","text":"arguments for this are available in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"type":"text","text":" enum, but the"},{"text":" ","type":"text"},{"type":"text","text":"values there are the same as the system values, and the flags"},{"text":" ","type":"text"},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too. These"},{"type":"text","text":" "},{"text":"flags affect the overall receive operation. Flags affecting individual","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages are returned in "},{"type":"codeVoice","code":"GInputMessage.flags"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The other members of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage"},{"type":"text","text":" are treated as described in its"},{"type":"text","text":" "},{"text":"documentation.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":" the call will block until ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" have"},{"text":" ","type":"text"},{"text":"been received, or the end of the stream is reached.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference","isActive":true},{"type":"text","text":" is "},{"code":"false","type":"codeVoice"},{"text":" the call will return up to ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" "},{"type":"text","text":"without blocking, or "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" if no messages are queued in the"},{"type":"text","text":" "},{"type":"text","text":"operating system to be received."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In blocking mode, if "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":" is positive and is reached before any"},{"type":"text","text":" "},{"type":"text","text":"messages are received, "},{"code":"timedOut","type":"codeVoice"},{"type":"text","text":" is returned, otherwise up to"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" are returned. (Note: This is effectively the"},{"type":"text","text":" "},{"type":"text","text":"behaviour of "},{"type":"codeVoice","code":"MSG_WAITFORONE"},{"type":"text","text":" with "},{"code":"recvmmsg()","type":"codeVoice"},{"type":"text","text":".)"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To be notified when messages are available, wait for the"},{"type":"text","text":" "},{"type":"text","text":"[in_](\/\/documentation\/gobject\/in_ condition. Note though that you may still receive"},{"text":" ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"text":" from ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_messages()"},{"text":" even if you were","type":"text"},{"text":" ","type":"text"},{"text":"previously notified of a [in_](\/\/documentation\/gobject\/in_ condition.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the remote peer closes the connection, any messages queued in the"},{"type":"text","text":" "},{"type":"text","text":"operating system will be returned, and subsequent calls to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_messages()"},{"type":"text","text":" will return 0 (with no error set)."}]},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"code":"error","type":"codeVoice"},{"text":" is set accordingly. An error will only","type":"text"},{"text":" ","type":"text"},{"text":"be returned if zero messages could be received; otherwise the number of","type":"text"},{"text":" ","type":"text"},{"text":"messages successfully received before the error will be returned.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/socketref\/receive(messages:nummessages:flags:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketRef","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/SocketProtocol-Implementations"]]},"sections":[],"references":{"doc://GIO/documentation/GIO/InputVector":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","