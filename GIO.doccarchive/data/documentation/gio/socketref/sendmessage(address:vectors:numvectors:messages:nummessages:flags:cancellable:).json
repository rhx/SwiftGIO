ype":"text","text":" "},{"type":"text","text":"values there are the same as the system values, and the flags"},{"text":" ","type":"text"},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}]},{"inlineContent":[{"type":"text","text":"If the socket is in blocking mode the call will block until there is"},{"type":"text","text":" "},{"text":"space for the data in the socket queue. If there is no space available","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and the socket is in non-blocking mode a "},{"code":"wouldBlock","type":"codeVoice"},{"text":" error","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be returned. To be notified when space is available, wait for the"},{"type":"text","text":" "},{"text":"[out](\/\/documentation\/gobject\/out condition. Note though that you may still receive","type":"text"},{"type":"text","text":" "},{"code":"wouldBlock","type":"codeVoice"},{"text":" from ","type":"text"},{"code":"g_socket_send()","type":"codeVoice"},{"type":"text","text":" even if you were previously"},{"type":"text","text":" "},{"type":"text","text":"notified of a [out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is"},{"text":" ","type":"text"},{"type":"text","text":"very common due to the way the underlying APIs work.)"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The sum of the sizes of each "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true},{"text":" in vectors must not be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"greater than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":". If the message can be larger than this,"},{"text":" ","type":"text"},{"text":"then it is mandatory to use the ","type":"text"},{"code":"g_socket_send_message_with_timeout()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"function."}],"type":"paragraph