{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketRef","doc:\/\/GIO\/documentation\/GIO\/SocketRef\/SocketProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"title":"send(messages:numMessages:flags:cancellable:)","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","extendedModule":"GIO","externalID":"s:3GIO14SocketProtocolPAAE4send8messages11numMessages5flags11cancellableSiSpySo15_GOutputMessageVGSg_S2iAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO9SocketRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"send","kind":"identifier"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputMessage"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"symbolKind":"method"},"abstract":[{"text":"Send multiple data messages from ","type":"text"},{"type":"codeVoice","code":"socket"},{"text":" in one go.  This is the most","type":"text"},{"text":" ","type":"text"},{"text":"complicated and fully-featured version of this call. For easier use, see","type":"text"},{"type":"text","text":" "},{"code":"g_socket_send()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_socket_send_to()"},{"type":"text","text":", and "},{"code":"g_socket_send_message()","type":"codeVoice"},{"type":"text","text":"."}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/send(messages:numMessages:flags:cancellable:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"send","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GOutputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"messages"},{"type":"text","text":" must point to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true,"type":"reference"},{"type":"text","text":" structs and"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" "},{"text":"contains an address to send the data to, and a pointer to an array of","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true},{"text":" structs to describe the buffers that the data to be sent","type":"text"},{"text":" ","type":"text"},{"text":"for each message will be gathered from. Using multiple ","type":"text"},{"code":"GOutputVectors","type":"codeVoice"},{"text":" is","type":"text"},{"type":"text","text":" "},{"text":"more memory-efficient than manually copying data from multiple sources","type":"text"},{"type":"text","text":" "},{"text":"into a single buffer, and more network-efficient than making multiple","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calls to "},{"type":"codeVoice","code":"g_socket_send()"},{"type":"text","text":". Sending multiple messages in one go avoids the"},{"type":"text","text":" "},{"type":"text","text":"overhead of making a lot of syscalls in scenarios where a lot of data"},{"text":" ","type":"text"},{"text":"packets need to be sent (e.g. high-bandwidth video streaming over RTP\/UDP),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or where the same data needs to be sent to multiple recipients."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" modify how the message is sent. The commonly available arguments"},{"type":"text","text":" "},{"type":"text","text":"for this are available in the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","type":"reference","isActive":true},{"text":" enum, but the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"values there are the same as the system values, and the flags"},{"text":" ","type":"text"},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}]},{"inlineContent":[{"type":"text","text":"If the socket is in blocking mode the call will block until there is"},{"type":"text","text":" "},{"type":"text","text":"space for all the data in the socket queue. If there is no space available"},{"type":"text","text":" "},{"type":"text","text":"and the socket is in non-blocking mode a "},{"type":"codeVoice","code":"wouldBlock"},{"text":" error","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will be returned if no data was written at all, otherwise the number of"},{"type":"text","text":" "},{"text":"messages sent will be returned. To be notified when space is available,","type":"text"},{"type":"text","text":" "},{"text":"wait for the [out](\/\/documentation\/gobject\/out condition. Note though that you may still receive","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" from "},{"type":"codeVoice","code":"g_socket_send()"},{"text":" even if you were previously","type":"text"},{"type":"text","text":" "},{"text":"notified of a [out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"very common due to the way the underlying APIs work.)"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"text":"be returned if zero messages could be sent; otherwise the number of messages","type":"text"},{"type":"text","text":" "},{"type":"text","text":"successfully sent before the error will be returned."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/socketref\/send(messages:nummessages:flags:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/SocketRef/SocketProtocol-Implementations":{"title":"SocketProtocol Implementations","abstract":[],"role":"collectionGroup","url":"\/documentation\/gio\/socketref\/socketprotocol-implementations","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef\/SocketProtocol-Implementations","kind":"article"},"doc://GIO/documentation/GIO/OutputMessage":{"abstract":[{"type":"text","text":"Structure used for scatter\/gather data output when sending multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of","type":"text"},{"type":"text","text":" "},{"code":"GOutputVectors","type":"codeVoice"},{"type":"text","text":" and the operation will use all the buffers as if they"},{"type":"text","text":" "},{"type":"text","text":"were one buffer."}],"url":"\/documentation\/gio\/outputmessage","type":"topic","title":"OutputMessage","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputMessage","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OutputMessage"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},"doc://GIO/documentation/GIO/OutputVector":{"abstract":[{"text":"Structure used for scatter\/gather data output.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GOutputVectors"},{"text":" ","type":"text"},{"text":"and the operation will use all the buffers as if they were","type":"text"},{"type":"text","text":" "},{"type":"text","text":"one buffer."}],"url":"\/documentation\/gio\/outputvector","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","navigatorTitle":[{"text":"OutputVector","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputVector","kind":"identifier"}],"title":"OutputVector","role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","abstract":[{"text":"Flags used in ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_socket_send_message()"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The flags listed in the enum are some commonly available flags, but the"},{"text":" ","type":"text"},{"type":"text","text":"values used for them are the same as on the platform, and any other flags"},{"text":" ","type":"text"},{"text":"are passed in\/out as is. So to use a platform specific flag, just include","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the right system header and pass in the flag."}],"navigatorTitle":[{"kind":"identifier","text":"SocketMsgFlags"}],"url":"\/documentation\/gio\/socketmsgflags","title":"SocketMsgFlags","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketMsgFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/SocketRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketRef","title":"SocketRef","url":"\/documentation\/gio\/socketref","abstract":[{"type":"text","text":"A "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"text":" ","type":"text"},{"text":"direct mapping of the BSD socket API in a portable GObject based API.","type":"text"},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SocketRef","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\