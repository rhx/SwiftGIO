,"text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"shutdownRead"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"text":" then the receiving side of the connection","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is shut down, and further reading is disallowed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"shutdownWrite","type":"codeVoice"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":" then the sending side of the connection"},{"type":"text","text":" "},{"type":"text","text":"is shut down, and further writing is disallowed."}]},{"inlineContent":[{"text":"It is allowed for both ","type":"text"},{"type":"codeVoice","code":"shutdownRead"},{"type":"text","text":" and "},{"code":"shutdownWrite","type":"codeVoice"},{"type":"text","text":" to be "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"One example where it is useful to shut down only one side of a connection is"},{"type":"text","text":" "},{"text":"graceful disconnect for TCP connections where you close the sending side,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then wait for the other side to close the connection, thus ensuring that the"},{"type":"text","text":" "},{"type":"text","text":"other side saw all sent data."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/socketref\/shutdown(shutdownread:shutdownwrite:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/SocketRef/shutdown(shutdownRead:shutdownWrite:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identi