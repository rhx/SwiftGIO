,"code":"numVectors"},{"text":" is 0 (in which case, ","type":"text"},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" "},{"type":"text","text":"may of course be "},{"type":"codeVoice","code":"nil"},{"text":"), then a single byte is received and","type":"text"},{"type":"text","text":" "},{"text":"discarded. This is to facilitate the common practice of sending a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single ‘\\0’ byte for the purposes of transferring ancillary data."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"text":", if non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", will be set to point to a newly-allocated"},{"type":"text","text":" "},{"type":"text","text":"array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","isActive":true,"type":"reference"},{"type":"text","text":" instances or "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" if no such"},{"type":"text","text":" "},{"type":"text","text":"messages was received. These correspond to the control messages"},{"type":"text","text":" "},{"type":"text","text":"received from the kernel, one "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","isActive":true},{"text":" per message","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from the kernel. This array is "},{"code":"nil","type":"codeVoice"},{"text":"-terminated and must be freed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"by the caller using "},{"type":"codeVoice","code":"g_free()"},{"text":" after calling ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"text":" on each","type":"text"},{"type":"text","text":" "},{"type":"text","text":"element. If "},{"type":"codeVoice","code":"messages"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", any control messages received will","type":"text"},{"type":"text","text":" "},{"text":"be discarded.","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"numMessages","type":"codeVoice"},{"type":"text","text":", if non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", will be set to the number of control"},{"text":" ","type":"text"},{"type":"text","text":"messages received."}]},{"type":"paragraph","inlineContent":[{"text":"If both ","type":"text"},{"type":"codeVoice","code":"messages"},{"text":" and ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" are non-"},{"type":"codeVoice","code":"nil"},{"text":", then","type":"text"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"text":" gives the number of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","isActive":true},{"text":" instances","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"messages"},{"type":"text","text":" (ie: not including the "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" terminator)."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" is an in\/out parameter. The commonly available arguments","type":"text"},{"text":" ","type":"text"},{"text":"for this are available in the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true,"type":"reference"},{"text":" enum, but the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"values there are the same as the system values, and the flags"},{"text":" ","type":"text"},{"text":"are passed in as-is, so you can pass in system-specific flags too","type":"text"},{"type":"text","text":" "},{"text":"(and ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" may pass system-specific flags out)."},{"text":" ","type":"text"},{"text":"Flags passed in to the parameter affect the receive operation; flags returned","type":"text"},{"type":"text","text":" "},{"text":"out of it are relevant to the specific returned message.","type":"text"}]},{"inlineContent":[{"text":"As with ","type":"text"},{"code":"g_socket_receive()","type":"codeVoice"},{"type":"text","text":", data may be discarded if "},{"code":"socket","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"code":"datagram","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"seqpacket","type":"codeVoice"},{"text":" and you do not","type":"text"},{"type":"text","text":" "},{"text":"provide enough buffer space to read a complete message. You can pass","type":"text"},{"type":"text","text":" "},{"code":"peek","type":"codeVoice"},{"type":"text","text":" in "},{"type":"codeVoice","code":"flags"},{"text":" to peek at the current message without","type":"text"},{"type":"text","text":" "},{"text":"removing it from the receive queue, but there is no portable way to find","type":"text"},{"text":" ","type":"text"},{"text":"out the length of the message other than by reading it into a","type":"text"},{"type":"text","text":" "},{"text":"sufficiently-large buffer.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the socket is in blocking mode the call will block until there"},{"text":" ","type":"text"},{"type":"text","text":"is some data to receive, the connection is closed, or there is an"},{"type":"text","text":" "},{"text":"error. If there is no data available and the socket is in","type":"text"},{"type":"text","text":" "},{"text":"non-blocking mode, a ","type":"text"},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" error will be"},{"type":"text","text":" "},{"text":"returned. To be notified when data is available, wait for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[in_](\/\/documentation\/gobject\/in_ condition."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -