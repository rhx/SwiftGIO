ateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]},"doc://GIO/documentation/GIO/MenuModelRef/GWeakCapturing-Implementations":{"role":"collectionGroup","abstract":[],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/GWeakCapturing-Implementations","url":"\/documentation\/gio\/menumodelref\/gweakcapturing-implementations","title":"GWeakCapturing Implementations","kind":"article"},"doc://GIO/documentation/GIO/MenuModelRef/init(_:)-669zx":{"abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"type":"codeVoice","code":"C"},{"text":" data type","type":"text"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/init(_:)-669zx","role":"symbol","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GMenuModel"},{"kind":"text","text":">)"}],"title":"init(_:)","url":"\/documentation\/gio\/menumodelref\/init(_:)-669zx"},"doc://GIO/documentation/GIO/MenuModelRef/init(_:)-8pdws":{"abstract":[{"text":"Conditional initialiser from an optional pointer to the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/init(_:)-8pdws","type":"topic","url":"\/documentation\/gio\/menumodelref\/init(_:)-8pdws","kind":"symbol","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"!("},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GMenuModel","kind":"typeIdentifier"},{"text":">?)","kind":"text"}],"title":"init(_:)"},"doc://GIO/documentation/GIO/MenuModelRef/init(_:)-36vr0":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/init(_:)-36vr0","role":"symbol","url":"\/documentation\/gio\/menumodelref\/init(_:)-36vr0","title":"init(_:)","type":"topic","abstract":[{"type":"text","text":"Conditional initialiser from an optional, non-mutable pointer to the underlying "},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type"}],"kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"!("},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GMenuModel","kind":"typeIdentifier"},{"text":">?)","kind":"text"}]},"doc://GIO/documentation/GIO/MenuModelRef/init(_:)-41da1":{"title":"init(_:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/init(_:)-41da1","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"GMenuModel","kind":"typeIdentifier"},{"text":">)","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Designated initialiser from a constant pointer to the underlying "},{"type":"codeVoice","code":"C"},{"text":" data type","type":"text"}],"url":"\/documentation\/gio\/menumodelref\/init(_:)-41da1","type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/MenuModelRef/init(constPointer:)":{"kind":"symbol","role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"T"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"constPointer"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"T"},{"text":">)","kind":"text"}],"iden