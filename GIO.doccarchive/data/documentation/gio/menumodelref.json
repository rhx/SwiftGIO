","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},"doc://GIO/documentation/GIO/DBusMenuModel":{"title":"DBusMenuModel","type":"topic","navigatorTitle":[{"text":"DBusMenuModel","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusMenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDBusMenuModel"},{"type":"text","text":" is an implementation of [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"type":"text","text":"] that can be"},{"type":"text","text":" "},{"text":"used as a proxy for a menu model that is exported over D-Bus with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.DBusConnection.export_menu_model","type":"codeVoice"},{"text":"].","type":"text"}],"url":"\/documentation\/gio\/dbusmenumodel","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel","role":"symbol"},"doc://GIO/documentation/GIO/MenuModelRef/MenuModelProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef\/MenuModelProtocol-Implementations","type":"topic","kind":"article","role":"collectionGroup","abstract":[],"title":"MenuModelProtocol Implement