el":2},{"type":"paragraph","inlineContent":[{"text":"By default, a ","type":"text"},{"code":"GDBusServer","type":"codeVoice"},{"text":" or server-side ","type":"text"},{"code":"GDBusConnection","type":"codeVoice"},{"text":" will allow","type":"text"},{"text":" ","type":"text"},{"text":"any authentication mechanism to be used. If you only want to allow D-Bus","type":"text"},{"type":"text","text":" "},{"text":"connections with the ","type":"text"},{"type":"codeVoice","code":"EXTERNAL"},{"type":"text","text":" mechanism, which makes use of credentials"},{"type":"text","text":" "},{"type":"text","text":"passing and is the recommended mechanism for modern Unix platforms such"},{"type":"text","text":" "},{"type":"text","text":"as Linux and the BSD family, you would use a signal handler like this:"}]},{"syntax":"c","code":["static gboolean","on_allow_mechanism (GDBusAuthObserver *observer,","                    const gchar       *mechanism,","                    gpointer           user_data)","{","  if (g_strcmp0 (mechanism, \"EXTERNAL\") == 0)","    {","      return TRUE;","    }","","  return FALSE;","}"],"type":"codeListing"},{"level":2,"anchor":"Controlling-Authorization","text":"Controlling Authorization","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, a "},{"type":"codeVoice","code":"GDBusServer"},{"text":" or server-side ","type":"text"},{"type":"codeVoice","code":"GDBusConnection"},{"text":" will accept","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connections from any successfully authenticated user (but not from"},{"type":"text","text":" "},{"type":"text","text":"anonymous connections using the "},{"type":"codeVoice","code":"ANONYMOUS"},{"type":"text","text":" mechanism). If you only"},{"text":" ","type":"text"},{"type":"text","text":"want to allow D-Bus connections from processes owned by the same uid"},{"type":"text","text":" "},{"text":"as the server, since GLib 2.68, you should use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_DBUS_SERVER_FLAGS_AUTHENTICATION_REQUIRE_SAME_USER"},{"text":" flag. It’s equivalent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the following signal handler:"}]},{"type":"codeListing","code":["static gboolean","on_authorize_authenticated_peer (GDBusAuthObserver *observer,","                                 GIOStream         *stream,","                                 GCredentials      *credentials,","                                 gpointer           user_data)","{","  gboolean authorized;","","  authorized = FALSE;","  if (credentials != NULL)","    {","      GCredentials *own_credentials;","      own_credentials = g_credentials_new ();","      if (g_credentials_is_same_user (credentials, own_credentials, NULL))","        authorized = TRUE;","      g_object_unref (own_credentials);","    }","","  return authorized;","}"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverRef","isActive":true},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GDBusAuthObserver"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusAuthObserverRef","type":"reference","isActive":true},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GDBusAuthObserver","type":"codeVoice"},{"type":"text","text":" instance."}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inli