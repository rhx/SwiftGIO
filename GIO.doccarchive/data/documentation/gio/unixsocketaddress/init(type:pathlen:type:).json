xt":" ","type":"text"},{"type":"text","text":"bytes will be considered part of the name. (If "},{"code":"pathLen","type":"codeVoice"},{"type":"text","text":" is -1,"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"path"},{"type":"text","text":" is assumed to be NUL-terminated.) For example, if "},{"code":"path","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"was “test”, then calling "},{"type":"codeVoice","code":"g_socket_address_get_native_size()"},{"type":"text","text":" on the"},{"text":" ","type":"text"},{"type":"text","text":"returned socket would return 7 (2 bytes of overhead, 1 byte for the"},{"text":" ","type":"text"},{"type":"text","text":"abstract-socket indicator byte, and 4 bytes for the name “test”)."}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"path_type","type":"codeVoice"},{"type":"text","text":" is "},{"code":"abstractPadded","type":"codeVoice"},{"type":"text","text":", then"},{"type":"text","text":" "},{"type":"codeVoice","code":"pathLen"},{"text":" bytes of ","type":"text"},{"code":"path","type":"codeVoice"},{"type":"text","text":" will be copied to the socket’s path, the"},{"type":"text","text":" "},{"text":"rest of the path will be padded with 0 bytes, and the entire","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"zero-padded buffer will be considered the name. (As above, if"},{"text":" ","type":"text"},{"code":"pathLen","type":"codeVoice"},{"text":" is -1, then ","type":"text"},{"code":"path","type":"codeVoice"},{"type":"text","text":" is assumed to be NUL-terminated.) In"},{"type":"text","text":" "},{"text":"this case, ","type":"text"},{"code":"g_socket_address_get_native_size()","type":"codeVoice"},{"type":"text","text":" will always return"},{"text":" ","type":"text"},{"type":"text","text":"the full size of a "},{"code":"struct sockaddr_un","type":"codeVoice"},{"type":"text","text":", although"},{"text":" ","type":"text"},{"code":"g_unix_socket_addre