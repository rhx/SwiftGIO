{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef\/InputStreamProtocol-Implementations"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/filterinputstreamref\/read(buffer:count:cancellable:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef\/read(buffer:count:cancellable:)"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"read","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"If count is zero returns zero and does nothing. A value of ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" "},{"type":"text","text":"larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"text":" will cause a ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes read into the buffer is returned."},{"type":"text","text":" "},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. near the end of a file. Zero is returned on end of file"},{"type":"text","text":" "},{"type":"text","text":"(or if "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is zero),  but never otherwise."}],"type":"paragraph"},{"inlineContent":[{"text":"The returned ","type":"text"},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" is not a nul-terminated string, it can contain nul bytes"},{"text":" ","type":"text"},{"type":"text","text":"at any position, and this function doesn’t nul-terminate the "},{"type":"codeVoice","code":"buffer"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}]}]}],"sections":[],"metadata":{"title":"read(buffer:count:cancellable:)","fragments":[{"text":"func","k