y_default."}],"type":"paragraph"},{"inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads to implement","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"asynchronicity, so they are optional for inheriting classes. However, if you"},{"type":"text","text":" "},{"text":"override one you must override all.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/filterinputstreamref\/readasync(buffer:count:iopriority:cancellable:callback:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/FilterInputStreamRef":{"type":"topic","navigatorTitle":[{"text":"FilterInputStreamRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef","url":"\/documentation\/gio\/filterinputstreamref","title":"FilterInputStreamRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FilterInputStreamRef"}],"abstract":[{"type":"text","text":"Base class for input stream implementations that perform some"},{"text":" ","type":"text"},{"text":"kind of filtering operation on a base stream. Typical examples","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of filtering operations are character set conversion, compression"},{"text":" ","type":"text"},{"type":"text","text":"and byte order flipping."}]},"doc://GIO/documentation/GIO/FilterInputStreamRef/InputStreamProtocol-Implementations":{"kind":"article","role":"collectionGroup","url":"\/documentation\/gio\/filterinputstreamref\/inputstreamprotocol-implementations","abstract":[],"title":"InputStreamProtocol Implementations","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef\/InputStreamProtocol-Implementations"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/docu