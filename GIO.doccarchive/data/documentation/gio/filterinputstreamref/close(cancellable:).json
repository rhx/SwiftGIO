{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/filterinputstreamref\/close(cancellable:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef\/close(cancellable:)"},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","title":"close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"extendedModule":"GIO","modules":[{"name":"GIO"}],"externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO20FilterInputStreamRefV","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef\/InputStreamProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"type":"text","text":" "},{"text":"resources are released as early as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"type":"text","text":" "},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"type":"text","text":" "},{"text":"stream for details.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"text":" ","type":"text"},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"text":"close will still return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":" for all operations. Still, it"},{"type":"text","text":" "},{"type":"text","text":"is important to check and report the error to the user."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"type":"text","text":" "},{"text":"can use a faster close that doesn’t block to e.g. check errors.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/FilterInputStreamRef":{"type":"topic","navigatorTitle":[{"text":"FilterInputStreamRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef","url":"\/documentation\/gio\/filterinputstreamref","title":"FilterInputStreamRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FilterInputStreamRef"}],"abstract":[{"type":"text","text":"Base class for input stream implementations that perform some"},{"text":" ","type":"text"},{"text":"kind of filtering operation on a base stream. Typical examples","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of filtering operations are character set conversion, compression"},{"text":" ","type":"text"},{"type":"text","text":"and byte order flipping."}]},"doc://GIO/documentation/GIO/FilterInputStreamRef/close(cancellable:)":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef\/close(cancellable:)","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"url":"\/documentation\/gio\/filterinputstreamref\/close(cancellable:)","title":"close(cancellable:)","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FilterInputStreamRef/InputStreamProtocol-Implementations":{"kind":"article","role":"collectionGroup","url":"\/documentation\/gio\/filterinputstreamref\/inputstreamprotocol-implementations","abstract":[],"title":"InputStreamProtocol Implementations","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef\/InputStreamProtocol-Implementations"}}}