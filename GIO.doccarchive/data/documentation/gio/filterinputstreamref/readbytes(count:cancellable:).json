 end of a file. A zero-length [Bytes](\/\/documentation\/glib\/bytes is"},{"text":" ","type":"text"},{"text":"returned on end of file (or if ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" is zero), but never"},{"text":" ","type":"text"},{"type":"text","text":"otherwise."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"text":" ","type":"text"},{"text":"partial result will be returned, without an error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On error "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/FilterInputStreamRef":{"type":"topic","navigatorTitle":[{"text":"FilterInputStreamRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStreamRef","url":"\/documentation\/gio\/filterinputstreamref","title":"FilterInputStreamRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FilterInputStreamRef"}],"abstract":[{"type":"text","text":"Base class for input stream implementations that perform some"},{"text":" ","type":"text"},{"text":"kind of filtering operation on a base stream. Typical examples","