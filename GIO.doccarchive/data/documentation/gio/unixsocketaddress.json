ype":"text","text":" "},{"text":"to see if abstract names are supported.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since GLib 2.72, ","type":"text"},{"type":"codeVoice","code":"GUnixSocketAddress"},{"type":"text","text":" is available on all platforms. It"},{"text":" ","type":"text"},{"type":"text","text":"requires underlying system support (such as Windows 10 with "},{"type":"codeVoice","code":"AF_UNIX"},{"text":") at","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"run time."}]},{"inlineContent":[{"type":"text","text":"Before GLib 2.72, "},{"type":"codeVoice","code":"<gio\/gunixsocketaddress.h>"},{"text":" belonged to the UNIX-specific","type":"text"},{"type":"text","text":" "},{"text":"GIO interfaces, thus you had to use the ","type":"text"},{"type":"codeVoice","code":"gio-unix-2.0.pc"},{"text":" pkg-config file","type":"text"},{"type":"text","text":" "},{"text":"when using it. This is no longer necessary since GLib 2.72.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress"},{"text":" type acts as a reference-counted owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GUnixSocketAddress"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddressProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress","type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GUnixSocketAddress"},{"text":" instance.","type":"text"}]},{"type":"aside","content":[{"inlineContent":[{"t