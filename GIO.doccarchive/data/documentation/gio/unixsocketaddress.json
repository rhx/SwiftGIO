{"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress"},"sections":[],"abstract":[{"text":"Support for UNIX-domain (also known as local) sockets, corresponding to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"struct sockaddr_un"},{"type":"text","text":"."}],"topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(_:)-14cvn","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(_:)-3dx2e","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(_:)-7ninv","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(_:)-9egea","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(abstract:pathLen:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(path:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(raw:)-2r4nx","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(raw:)-s7m0","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(retainingRaw:)-4m7ut","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(retainingRaw:)-7r7lm","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(type:pathLen:type:)","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddress\/init(unixSocketAddress:)"],"title":"Initializers","generated":true,"anchor":"Initializers"},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/G