:"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"type":"text","text":" "},{"type":"text","text":"returned then the tuple specifies the inclusive lower and upper bound"},{"text":" ","type":"text"},{"type":"text","text":"of valid values for the state."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In any case, the information is merely a hint.  It may be possible to"},{"text":" ","type":"text"},{"type":"text","text":"have a state value outside of the hinted range and setting a value"},{"text":" ","type":"text"},{"text":"within the range may fail.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value (if non-"},{"type":"codeVoice","code":"NULL"},{"text":") should be freed with","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.Variant.unref","type":"codeVoice"},{"type":"text","text":"] when it is no longer required."}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of the"},{"text":" ","type":"text"},{"type":"text","text":"named action within "},{"code":"actionGroup","type":"codeVoice"},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/actiongroupref\/getactionstatehint(actionname:)"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ActionGroupRef","doc:\/\/GIO\/documentation\/GIO\/ActionGroupRef\/ActionGroupProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ActionGroupRef\/