{"sections":[],"abstract":[{"type":"text","text":"Request an asynchronous write of "},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from "},{"type":"codeVoice","code":"buffer"},{"type":"text","text":" into"},{"text":" ","type":"text"},{"text":"the stream. When the operation is finished ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"type":"text","text":"You can then call "},{"type":"codeVoice","code":"g_output_stream_write_finish()"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"type":"text","text":"operation."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/bufferedoutputstreamref\/writeasync(buffer:count:iopriority:cancellable:callback:userdata:)"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writeAsync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"type":"text","text":" "},{"text":"and will result in ","type":"text"},{"code":"pending","type":"codeVoice"},{"text":" errors.","type":"text"}]},{"inlineContent":[{"text":"A value of ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"text":" ","type":"text"},{"code":"invalidArgument","type":"codeVoice"},{"text":" error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes written will be passed to the","type":"text"},{"type":"text","text":" "},{"code":"callback","type":"codeVoice"},{"type":"text","text":". It is not an error if this is not the same as the"},{"text":" ","type":"text"},{"type":"text","text":"requested size, as it can happen e.g. on a partial I\/O error,"},{"type":"text","text":" "},{"type":"text","text":"but generally we try to write as many bytes as requested."}]},{"inlineContent":[{"text":"You are guaranteed that this method will never fail with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" - if "},{"type":"codeVoice","code":"stream"},{"text":" can’t accept more data, the","type":"text"},{"type":"text","text":" "},{"text":"method will just wait until this changes.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical"},{"text":" ","type":"text"},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}]},{"type":"paragraph","inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads","type":"text"},{"type":"text","text":" "},{"text":"to implement asynchronicity, so they are optional for inheriting","type":"text"},{"text":" ","type":"text"},{"text":"classes. However, if you override one you must override all.","type":"text"}]},{"inlineContent":[{"text":"For the synchronous, blocking version of this function, see","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_output_stream_write()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that no copy of "},{"code":"buffer","type":"codeVoice"},{"text":" will be made, so it must stay valid","type":"text"},{"type":"text","text":" "},{"type":"text","text":"until "},{"type":"codeVoice","code":"callback"},{"text":" is called. See ","type":"text"},{"type":"codeVoice","code":"g_output_stream_write_bytes_async()"},{"type":"text","text":" "},{"text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to","type":"text"},{"text":" ","type":"text"},{"text":"the contents (without copying) for the duration of the call.","type":"text"}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/BufferedOutputStreamRef\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","role":"symbol","externalID":"s:3GIO20OutputStreamProtocolPAAE10writeAsync6buffer5count10ioPriority11cancellable8callback8userDataySvSg_S2iAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgAKtXCS