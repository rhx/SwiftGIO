{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/BufferedOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/BufferedOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Closing a stream multiple times will not return an error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers in the","type":"text"},{"type":"text","text":" "},{"text":"stream.","type":"text"}]},{"inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"type":"text","text":" "},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stream for details."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"text":" ","type":"text"},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"text":" ","type":"text"},{"text":"close will still return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":" for all operations. Still, it"},{"text":" ","type":"text"},{"text":"is important to check and report the error to the user, otherwise","type":"text"},{"type":"text","text":" "},{"text":"there might be a loss of data as all data might not be written.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but there some streams"},{"text":" ","type":"text"},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors. On"},{"type":"text","text":" "},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"type":"text","text":"data will reach the target."}],"type":"paragraph"}]}],"sections":[],"metadata":{"roleHeading":"Instance Method","title":"close(cancellable:)","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO23BufferedOutputStreamRefV","role":"symbol","extendedModule":"GIO"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/BufferedOutputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/bufferedoutputstreamref\/close(cancellable:)"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"references":{"doc://GIO/documentation/GIO/FilterOutputStream":{"title":"FilterOutputStream","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterOutputStream","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Base class for output stream implementations that perform some"},{"type":"text","text":" "},{"text":"kind of filtering operation on a base stream. Typical examples","type":"text"},{"type":"text","text":" "},{"text":"of filtering operations are character set conversion, compression","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and byte order flipping."}],"navigatorTitle":[{"kind":"identifier","text":"FilterOutputStream"}],"url":"\/documentation\/gio\/filteroutputstream","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"FilterOutputStream"}],"type":"topic"},"doc://GIO/documentation/GIO/BufferedOutputStreamRef/OutputStreamProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedOutputStreamRef\/OutputStreamProtocol-Implementations","url":"\/documentation\/gio\/bufferedoutputstreamref\/outputstreamprotocol-implementations","title":"OutputStreamProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/BufferedOutputStreamRef/close(cancellable:)":{"title":"close(cancellable:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedOutputStreamRef\/close(cancellable:)","url":"\/documentation\/gio\/bufferedoutputstreamref\/close(cancellable:)","type":"topic","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/BufferedOutputStreamRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedOutputStreamRef","title":"BufferedOutputStreamRef","url":"\/documentation\/gio\/bufferedoutputstreamref","abstract":[{"type":"text","text":"Buffered output stream implements [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterOutputStream","isActive":true,"type":"reference"},{"type":"text","text":"] and provides"},{"type":"text","text":" "},{"text":"for buffered writes.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"BufferedOutputStreamRef"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"BufferedOutputStreamRef"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}