{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor","interfaceLanguage":"swift"},"sections":[],"topicSections":[{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(_:)-2dz3e","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(_:)-3hhtz","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(_:)-9h1q2","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(_:)-9h7gp","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(appInfoMonitor:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(raw:)-1g0ce","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(raw:)-72b92","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(retainingRaw:)-4in2t","doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/init(retainingRaw:)-nsoa"]},{"title":"Type Methods","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/appInfoMonitorGet()"],"anchor":"Type-Methods"},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor\/AppInfoMonitorProtocol-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"metadata":{"roleHeading":"Class","title":"AppInfoMonitor","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"AppInfoMonitor","kind":"identifier"}],"symbolKind":"class","navigatorTitle":[{"text":"AppInfoMonitor","kind":"identifier"}],"externalID":"s:3GIO14AppInfoMonitorC","role":"symbol"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AppInfoMonitor"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"inlineContent":[{"type":"codeVoice","code":"GAppInfoMonitor"},{"type":"text","text":" is a very simple object used for monitoring the app"},{"type":"text","text":" "},{"type":"text","text":"info database for changes (newly installed or removed applications)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call [func"},{"code":"Gio.AppInfoMonitor.get","type":"codeVoice"},{"type":"text","text":"] to get a "},{"type":"codeVoice","code":"GAppInfoMonitor"},{"text":" and connect","type":"text"},{"text":" ","type":"text"},{"text":"to the [signal[AppInfoMonitor](\/\/documentation\/gio\/appinfomonitor\/onchanged(flags:handler:)] signal. The signal will be emitted once when","type":"text"},{"type":"text","text":" "},{"text":"the app info database changes, and will not be emitted again until after the","type":"text"},{"type":"text","text":" "},{"text":"next call to [func","type":"text"},{"type":"codeVoice","code":"Gio.AppInfo.get_all"},{"type":"text","text":"] or another "},{"code":"g_app_info_*()","type":"codeVoice"},{"type":"text","text":" function."},{"text":" ","type":"text"},{"text":"This is because monitoring the app info database for changes is expensive.","type":"text"}]},{"inlineContent":[{"text":"The following functions will re-arm the [signal[AppInfoMonitor](\/\/documentation\/gio\/appinfomonitor\/onchanged(flags:handler:)]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"signal so it can be emitted again:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"Gio.AppInfo.get_all","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"code":"Gio.AppInfo.get_all_for_type","type":"codeVoice"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"Gio.AppInfo.get_default_for_type","type":"codeVoice"},{"type":"text","text":"]"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"Gio.AppInfo.get_fallback_for_type"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"Gio.AppInfo.get_recommended_for_type"},{"type":"text","text":"]"}]}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"..\/gio-unix\/type_func.DesktopAppInfo.get_implementation.html","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"..\/gio-unix\/ctor.DesktopAppInfo.new.html"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"..\/gio-unix\/ctor.DesktopAppInfo.new_from_filename.html","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"..\/gio-unix\/ctor.DesktopAppInfo.new_from_keyfile.html","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"..\/gio-unix\/type_func.DesktopAppInfo.search.html","isActive":true}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The latter functions are available if using"},{"type":"text","text":" "},{"identifier":"..\/gio-unix\/class.DesktopAppInfo.html","isActive":true,"type":"reference"},{"type":"text","text":" from"},{"type":"text","text":" "},{"type":"codeVoice","code":"gio-unix-2.0.pc"},{"type":"text","text":" (GIR namespace "},{"code":"GioUnix-2.0","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the usual case, applications should try to make note of the change"},{"text":" ","type":"text"},{"text":"(doing things like invalidating caches) but not act on it. In","type":"text"},{"type":"text","text":" "},{"text":"particular, applications should avoid making calls to ","type":"text"},{"type":"codeVoice","code":"GAppInfo"},{"type":"text","text":" APIs"},{"type":"text","text":" "},{"type":"text","text":"in response to the change signal, deferring these until the time that"},{"text":" ","type":"text"},{"type":"text","text":"the updated data is actually required. The exception to this case is when"},{"type":"text","text":" "},{"type":"text","text":"application information is actually being displayed on the screen"},{"text":" ","type":"text"},{"type":"text","text":"(for example, during a search or when the list of all applications is shown)."},{"type":"text","text":" "},{"type":"text","text":"The reason for this is that changes to the list of installed applications"},{"type":"text","text":" "},{"text":"often come in groups (like during system updates) and rescanning the list","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"on every change is pointless and expensive."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor","type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GAppInfoMonitor"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorProtocol","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor","type":"reference","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GAppInfoMonitor"},{"text":" instance.","type":"text"}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorRef"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GAppInfoMonitor"},{"type":"text","text":" instance."}]}],"name":"Note"}]}],"variants":[{"paths":["\/documentation\/gio\/appinfomonitor"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/10GLibObject0B0C"],"type":"inheritsFrom","kind":"relationships","title":"Inherits From"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"type":"conformsTo"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"codeVoice","code":"GAppInfoMonitor"},{"text":" monitors application information for changes.","type":"text"}],"kind":"symbol","references":{"doc://GIO/10GLibObject0B0C":{"identifier":"doc:\/\/GIO\/10GLibObject0B0C","title":"GLibObject.Object","type":"unresolvable"},"../gio-unix/class.DesktopAppInfo.html":{"identifier":"..\/gio-unix\/class.DesktopAppInfo.html","type":"link","url":"..\/gio-unix\/class.DesktopAppInfo.html","titleInlineContent":[{"code":"GDesktopAppInfo","type":"codeVoice"}],"title":"GDesktopAppInfo"},"../gio-unix/ctor.DesktopAppInfo.new_from_keyfile.html":{"identifier":"..\/gio-unix\/ctor.DesktopAppInfo.new_from_keyfile.html","type":"link","url":"..\/gio-unix\/ctor.Deskt