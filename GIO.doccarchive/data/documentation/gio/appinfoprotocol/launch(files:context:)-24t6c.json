pe":"codeVoice","code":"DISPLAY"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"XDG_ACTIVATION_TOKEN","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"DESKTOP_STARTUP_ID"},{"type":"text","text":" environment"},{"text":" ","type":"text"},{"text":"variables are also set, based on information provided in ","type":"text"},{"code":"context","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AppInfoProtocol"]]},"sections":[],"metadata":{"roleHeading":"Instance Method","extendedModule":"GIO","symbolKind":"method","title":"launch(files:context:)","externalID":"s:3GIO15AppInfoProtocolPAAE6launch5files7contextSbqd_0_Sg_qd__SgtKAA0b13LaunchContextD0Rd__4GLib04ListD0Rd_0_r0_lF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"launch"},{"text":"<","kind":"text"},{"text":"AppLaunchContextT","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"GLibListT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"files"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GLibListT"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"context"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"AppLaunchContextT"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","modules":[{"name":"GIO"}]},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Launches the application. Passes ","type":"text"},{"code":"files","type":"codeVoice"},{"text":" to the launched application","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as arguments, using the optional "},{"code":"context","type":"codeVoice"},{"text":" to get information","type":"text"},{"text":" ","type":"te