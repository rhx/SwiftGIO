{"abstract":[{"text":"Launches the application. Passes ","type":"text"},{"code":"files","type":"codeVoice"},{"type":"text","text":" to the launched application"},{"type":"text","text":" "},{"text":"as arguments, using the optional ","type":"text"},{"type":"codeVoice","code":"context"},{"text":" to get information","type":"text"},{"type":"text","text":" "},{"type":"text","text":"about the details of the launcher (like what screen it is on)."},{"type":"text","text":" "},{"type":"text","text":"On error, "},{"type":"codeVoice","code":"error"},{"text":" will be set accordingly.","type":"text"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/appinfoprotocol\/launch(files:context:)-32tr1"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AppInfoProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/AppInfoProtocol\/launch(files:context:)-32tr1"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"launch","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"files"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ListRef","preciseIdentifier":"s:4GLib7ListRefV"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"context"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO19AppLaunchContextRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppLaunchContextRef","text":"AppLaunchContextRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"To launch the application without arguments pass a ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" "},{"type":"codeVoice","code":"files"},{"text":" list.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that even if the launch is successful the application launched","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can fail to start if it runs into problems during startup. There is"},{"type":"text","text":" "},{"text":"no way to detect this.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Some URIs can be changed when passed through a GFile (for instance","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unsupported URIs with strange formats like mailto:), so if you have"},{"text":" ","type":"text"},{"text":"a textual URI you want to pass in as argument, consider using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.AppInfo.launch_uris","type":"codeVoice"},{"type":"text","text":"] instead."}]},{"inlineContent":[{"type":"text","text":"The launched application inherits the environment of the launching"},{"text":" ","type":"text"},{"type":"text","text":"process, but it can be modified with [method"},{"type":"codeVoice","code":"Gio.AppLaunchContext.setenv"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"and [method","type":"text"},{"type":"codeVoice","code":"Gio.AppLaunchContext.unsetenv"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On UNIX, this function sets the "},{"type":"codeVoice","code":"GIO_LAUNCHED_DESKTOP_FILE"},{"type":"text","text":" "},{"type":"text","text":"environment variable with the path of the launched desktop file and"},{"text":" ","type":"text"},{"code":"GIO_LAUNCHED_DESKTOP_FILE_PID","type":"codeVoice"},{"text":" to the process id of the launched","type":"text"},{"type":"text","text":" "},{"type":"text","text":"process. This can be used to ignore "},{"type":"codeVoice","code":"GIO_LAUNCHED_DESKTOP_FILE"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"should it be inherited by further processes. The ","type":"text"},{"type":"codeVoice","code":"DISPLAY"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"XDG_ACTIVATION_TOKEN","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"DESKTOP_STARTUP_ID"},{"type":"text","text":" environment"},{"type":"text","text":" "},{"type":"text","text":"variables are also set, based on information provided in "},{"code":"context","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"launch","kind":"identifier"},{"kind":"text","text":"("},{"text":"files","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ListRef","preciseIdentifier":"s:4GLib7ListRefV","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"context","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO19AppLaunchContextRefV","text":"AppLaunchContextRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"extendedModule":"GIO","role":"symbol","externalID":"s:3GIO15AppInfoProtocolPAAE6launch5files7contextSb4GLib7ListRefVSg_AA0b13LaunchContextJ0VSgtKF","title":"launch(files:context:)","modules":[{"name":"GIO"}],"symbolKind":"method"},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GIO/documentation/GIO/AppInfoProtocol/launch(files:context:)-32tr1":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoProtocol\/launch(files:context:)-32tr1","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"launch","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"f