{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"type":"text","text":" "},{"code":"g_initable_new()","type":"codeVoice"},{"text":" should typically be used instead.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The object must be initialized before any real use after initial"},{"type":"text","text":" "},{"type":"text","text":"construction, either with this function or "},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"then initialization can be cancelled by triggering the cancellable object","type":"text"},{"type":"text","text":" "},{"text":"from another thread. If the operation was cancelled, the error","type":"text"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"type":"text","text":" "},{"code":"notSupported","type":"codeVoice"},{"text":" will be returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the object is not initialized, or initialization returns with an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"error, then all operations on the object except "},{"type":"codeVoice","code":"g_object_ref()"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"type":"text","text":" "},{"type":"text","text":"behaviour. See the "},{"type":"reference","identifier":"#iface@Gio.Initable#description","isActive":true},{"text":" for more details.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"text":" can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"type":"text","text":" "},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"code":"init()","type":"codeVoice"},{"text":" can assume","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"type":"text","text":" "},{"text":"recommended all ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" implementations should be idempotent; that"},{"type":"text","text":" "},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a class explicitly supports being initialized multiple times, it is"},{"text":" ","type":"text"},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"text":" ","type":"text"},{"text":"arguments should return the same results. Only the first call initializes","type":"text"},{"text":" ","type":"text"},{"text":"the object; further calls return the result of the first call.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"One reason why a class might need to support idempotent initialization is if","type":"text"},{"text":" ","type":"text"},{"text":"it is designed to be used via the singleton pattern, with a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GObjectClass.constructor"},{"text":" that sometimes returns an existing instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"In this pattern, a caller would expect to be able to call "},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":" "},{"text":"on the result of ","type":"text"},{"code":"g_object_new()","type":"codeVoice"},{"type":"text","text":", regardless of whether it is in fact a new"},{"text":" ","type":"text"},{"type":"text","text":"instance."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorRef","doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorRef\/InitableProtocol-Implementations"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorRef\/init_(cancellable:)","interfaceLanguage":"swift"},"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"metadata":{"symbolKind":"method","modules":[{"name":"GIO"}],"role":"symbol","roleHeading":"Instance Method","extendedModule":"GIO","title":"init_(cancellable:)","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO17NetworkMonitorRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/networkmonitorref\/init_(cancellable:)"]}],"references":{"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/NetworkMonitorRef/init_(cancellable:)":{"kind":"symbol","abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"url":"\/documentation\/gio\/networkmonitorref\/init_(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorRef\/init_(cancellable:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"title":"init_(cancellable:)","type":"topic"},"doc://GIO/documentation/GIO/NetworkMonitorRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorRef","title":"NetworkMonitorRef","url":"\/documentation\/gio\/networkmonitorref","abstract":[{"type":"codeVoice","code":"GNetworkMonitor"},{"text":" provides an easy-to-use cross-platform API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for monitoring network connectivity. On Linux, the available"},{"type":"text","text":" "},{"type":"text","text":"implementations are based on the kernel’s netlink interface and"},{"type":"text","text":" "},{"type":"text","text":"on NetworkManager."}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"NetworkMonitorRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"NetworkMonitorRef"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/NetworkMonitorRef/InitableProtocol-Implementations":{"kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorRef\/InitableProtocol-Implementations","title":"InitableProtocol Implementations","type":"topic","url":"\/documentation\/gio\/networkmonitorref\/initableprotocol-implementations","abstract":[]},"#iface@Gio.Initable#description":{"identifier":"#iface@Gio.Initable#description","type":"link","titleInlineContent":[{"type":"text","text":"description"}],"url":"#iface@Gio.Initable#description","title":"description"}}}