{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroup","doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroup\/ActionGroupProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"activateAction","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"actionName"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!, "},{"text":"parameter","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If the action is expecting a parameter, then the correct type of","type":"text"},{"type":"text","text":" "},{"text":"parameter must be given as ","type":"text"},{"code":"parameter","type":"codeVoice"},{"text":".  If the action is expecting no","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameters then "},{"type":"codeVoice","code":"parameter"},{"type":"text","text":" must be "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":".  See"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.ActionGroup.get_action_parameter_type"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the [type"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","isActive":true,"type":"reference"},{"type":"text","text":"] implementation supports asynchronous remote"},{"type":"text","text":" "},{"text":"activation over D-Bus, this call may return before the relevant","type":"text"},{"type":"text","text":" "},{"type":"text","text":"D-Bus traffic has been sent, or any replies have been received. In"},{"text":" ","type":"text"},{"text":"order to block on such asynchronous activation calls,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"type":"text","text":"] should be called prior to the code, which"},{"type":"text","text":" "},{"type":"text","text":"depends on the result of the action activation. Without flushing"},{"text":" ","type":"text"},{"type":"text","text":"the D-Bus connection, there is no guarantee that the action would"},{"text":" ","type":"text"},{"type":"text","text":"have been activated."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following code which runs in a remote app instance, shows an"},{"text":" ","type":"text"},{"text":"example of a ‘quit’ action being activated on the primary app","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instance over D-Bus. Here [method"},{"code":"Gio.DBusConnection.flush","type":"codeVoice"},{"text":"] is called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"before "},{"type":"codeVoice","code":"exit()"},{"text":". Without ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_flush()"},{"text":", the ‘quit’ action","type":"text"},{"type":"text","text":" "},{"type":"text","text":"may fail to be activated on the primary instance."}],"type":"paragraph"},{"code":["\/\/ call ‘quit’ action on primary instance","g_action_group_activate_action (G_ACTION_GROUP (app), \"quit\", NULL);","","\/\/ make sure the action is activated now","g_dbus_connection_flush (…);","","g_debug (\"Application has been terminated. Exiting.\");","","exit (0);"],"type":"codeListing","syntax":"c"}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/simpleactiongroup\/activateaction(actionname:parameter:)"],