{"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileenumeratorref\/nextfilesasync(numfiles:iopriority:cancellable:callback:userdata:)"]}],"sections":[],"abstract":[{"type":"text","text":"Request information for a number of files from the enumerator asynchronously."},{"text":" ","type":"text"},{"type":"text","text":"When all I\/O for the operation is finished the "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called with"},{"type":"text","text":" "},{"text":"the requested information.","type":"text"}],"metadata":{"title":"nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"nextFilesAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"numFiles"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?, "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"modules":[{"name":"GIO"}],"extendedModule":"GIO","role":"symbol","roleHeading":"Instance Method","externalID":"s:3GIO22FileEnumeratorProtocolPAAE14nextFilesAsync03numF010ioPriority11cancellable8callback8userDataySi_SiAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgAUtF::SYNTHESIZED::s:3GIO17FileEnumeratorRefV"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"nextFilesAsync"},{"text":"(","kind":"text"},{"text":"numFiles","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil, "},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"See the documentation of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator"},{"text":" for information about the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"order of returned files."}]},{"type":"paragraph","inlineContent":[{"text":"Once the end of the enumerator is reached, or if an error occurs, the","type":"text"},{"type":"text","text":" "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called with an empty list. In this case, the previous call"},{"type":"text","text":" "},{"text":"to ","type":"text"},{"code":"g_file_enumerator_next_files_async()","type":"codeVoice"},{"text":" will typically have returned fewer","type":"text"},{"type":"text","text":" "},{"type":"text","text":"than "},{"type":"codeVoice","code":"numFiles"},{"type":"text","text":" items."}]},{"inlineContent":[{"text":"If a request is cancelled the callback will be called with","type":"text"},{"text":" ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"This leads to the following pseudo-code usage:","type":"text"}],"type":"paragraph"},{"syntax":null,"type":"codeListing","code":["g_autoptr(GFile) dir = get_directory ();","g_autoptr(GFileEnumerator) enumerator = NULL;","g_autolist(GFileInfo) files = NULL;","g_autoptr(GError) local_error = NULL;","","enumerator = yield g_file_enumerate_children_async (dir,","                                                    G_FILE_ATTRIBUTE_STANDARD_NAME \",\"","                                                    G_FILE_ATTRIBUTE_STANDARD_TYPE,","                                                    G_FILE_QUERY_INFO_NONE,","                                                    G_PRIORITY_DEFAULT,","                                                    cancellable,","                                                    …,","                                                    &local_error);","if (enumerator == NULL)","  g_error (\"Error enumerating: %s\", local_error->message);","","\/\/ Loop until no files are returned, either because the end of the enumerator","\/\/ has been reached, or an error was returned.","do","  {","    files = yield g_file_enumerator_next_files_async (enumerator,","                                                      5,  \/\/ number of files to request","                                                      G_PRIORITY_DEFAULT,","                                                      cancellable,","                                                      …,","                                                      &local_error);","","    \/\/ Process the returned files, but don’t assume that exactly 5 were returned.","    for (GList *l = files; l != NULL; l = l->next)","      {","        GFileInfo *info = l->data;","        handle_file_info (info);","      }","  }","while (files != NULL);","","if (local_error != NULL &&","    !g_error_matches (local_error, G_IO_ERROR, G_IO_ERROR_CANCELLED))","  g_error (\"Error while enumerating: %s\", local_error->message);"]},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed, and will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"result in "},{"type":"codeVoice","code":"pending"},{"type":"text","text":" errors."}]},{"inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical value) will"},{"text":" ","type":"text"},{"text":"be executed before an outstanding request with lower priority. Default","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorRef\/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorRef","doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorRef\/FileEnumeratorProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/FileInfo":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileInfo"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","url":"\/documentation\/gio\/fileinfo","title":"FileInfo","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileInfo"}],"abstract":[{"text":"Stores information about a file system object referenced by a [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"]."}]},"doc://GIO/documentation/GIO/FileEnumerator":{"kind":"symbol","url":"\/documentation\/gio\/fileenumerator","role":"symbol","abstract":[{"type":"codeVoice","code":"GFileEnumerator"},{"text":" allows you to operate on a set of [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"] objects,"},{"text":" ","type":"text"},{"type":"text","text":"returning a [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"type":"text","text":"] structure for each file enumerated (e.g."},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.File.enumerate_children"},{"type":"text","text":"] will return a "},{"type":"codeVoice","code":"GFileEnumerator"},{"text":" for each","type":"text"},{"type":"text","text":" "},{"text":"of the children within a directory).","type":"text"}],"title":"FileEnumerator","navigatorTitle":[{"text":"FileEnumerator","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"FileEnumerator","kind":"identifier"}]},"doc://GIO/documentation/GIO/FileEnumeratorRef":{"role":"symbol","navigatorTitle":[{"text":"FileEnumeratorRef","kind":"identifier"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FileEnumeratorRef","kind":"identifier"}],"title":"FileEnumeratorRef","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorRef","abstract":[{"type":"codeVoice","code":"GFileEnumerator"},{"type":"text","text":" allows you to operate on a set of [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},{"text":"] objects,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returning a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true},{"type":"text","text":"] structure for each file enumerated (e.g."},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.File.enumerate_children","type":"codeVoice"},{"text":"] will return a ","type":"text"},{"code":"GFileEnumerator","type":"codeVoice"},{"text":" for each","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the children within a directory)."}],"url":"\/documentation\/gio\/fileenumeratorref"},"doc://GIO/documentation/GIO/File":{"abstract":[{"type":"codeVoice","code":"GFile"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"type":"text","text":"that do no I\/O upon creation. It is necessary to understand that"},{"type":"text","text":" "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"text":" ","type":"text"},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"text":"(see [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"text":"] and [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","url":"\/documentation\/gio\/file","title":"File","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"File","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"File"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileEnumeratorRef/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)":{"kind":"symbol","abstract":[{"type":"text","text":"Request information for a number of files from the enumerator asynchronously."},{"text":" ","type":"text"},{"type":"text","text":"When all I\/O for the operation is finished the "},{"type":"codeVoice","code":"callback"},{"text":" will be called with","type":"text"},{"text":" ","type":"text"},{"text":"the requested information.","type":"text"}],"role":"symbol","type":"topic","url":"\/documentation\/gio\/fileenumeratorref\/nextfilesasync(numfiles:iopriority:cancellable:callback:userdata:)","title":"nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorRef\/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"nextFilesAsync","kind":"identifier"},{"text":"(","kind":"text"},{"text":"numFiles","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileEnumeratorRef/FileEnumeratorProtocol-Implementations":{"abstract":[],"url":"\/documentation\/gio\/fileenumeratorref\/fileenumeratorprotocol-implementations","title":"FileEnumeratorProtocol Implementations","type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorRef\/FileEnumeratorProtocol-Implementations"}}}