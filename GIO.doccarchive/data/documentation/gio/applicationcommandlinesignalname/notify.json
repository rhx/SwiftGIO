{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineSignalName\/notify"},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notify","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"notify","type":"codeVoice"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names"},{"text":" as","type":"text"},{"text":" ","type":"text"},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/applicationcommandlinesignalname\/notify"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineSignalName"]]},"sections":[],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"title":"ApplicationCommandLineSignalName.notify","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"notify","kind":"identifier"}],"externalID":"s:3GIO32ApplicationCommandLineSignalNameO6notifyyA2CmF","role":"symbol","symbolKind":"case","modules":[{"name":"GIO"}],"roleHeading":"Case"},"references":{"doc://GIO/documentation/GIO/ApplicationCommandLineSignalName/notify":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineSignalName\/notify","title":"ApplicationCom