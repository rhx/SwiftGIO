{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/TLSConnectionProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onAcceptCertificate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:3GIO16TLSConnectionRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","text":"TLSConnectionRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:3GIO17TLSCertificateRefV","text":"TLSCertificateRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","text":"TLSCertificateFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":""},{"code":"true","type":"codeVoice"},{"type":"text","text":" to accept "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" (which will also immediately end the signal emission). "},{"code":"false","type":"codeVoice"},{"text":" to allow the signal emission to continue, which will cause the handshake to fail if no one else overrides it.","type":"text"},{"text":" ","type":"text"},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"acceptCertificate"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a client-side connection, "},{"type":"codeVoice","code":"peerCert"},{"text":" is the server’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate, and the signal will only be emitted if the"},{"type":"text","text":" "},{"type":"text","text":"certificate was not acceptable according to "},{"type":"codeVoice","code":"conn"},{"type":"text","text":"’s"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","type":"reference","isActive":true},{"text":". If you would like the","type":"text"},{"text":" ","type":"text"},{"text":"certificate to be accepted despite ","type":"text"},{"type":"codeVoice","code":"errors"},{"type":"text","text":", return "},{"type":"codeVoice","code":"true"},{"text":" from the","type":"text"},{"type":"text","text":" "},{"text":"signal handler. Otherwise, if no handler accepts the certificate,","type":"text"},{"text":" ","type":"text"},{"text":"the handshake will fail with ","type":"text"},{"type":"codeVoice","code":"badCertificate"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"GLib guarantees that if certificate verification fails, this signal","type":"text"},{"text":" ","type":"text"},{"text":"will be emitted with at least one error will be set in ","type":"text"},{"type":"codeVoice","code":"errors"},{"type":"text","text":", but"},{"text":" ","type":"text"},{"text":"it does not guarantee that all possible errors will be set.","type":"text"},{"type":"text","text":" "},{"text":"Accordingly, you may not safely decide to ignore any particular","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"type":"text","text":" "},{"type":"codeVoice","code":"expired"},{"type":"text","text":" if you want to allow expired"},{"type":"text","text":" "},{"text":"certificates, because this could potentially be the only error flag","type":"text"},{"text":" ","type":"text"},{"text":"set even if other problems exist with the certificate.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For a server-side connection, ","type":"text"},{"type":"codeVoice","code":"peerCert"},{"text":" is the certificate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"presented by the client, if this was requested via the server’s"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true},{"text":". On the server side,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the signal is always emitted when the client presents a"},{"text":" ","type":"text"},{"type":"text","text":"certificate, and the certificate will only be accepted if a"},{"text":" ","type":"text"},{"text":"handler returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"type":"text","text":" "},{"type":"text","text":"in the main thread, then you should not attempt to interact with"},{"text":" ","type":"text"},{"text":"the user before returning from the signal handler. If you want to","type":"text"},{"text":" ","type":"text"},{"text":"let the user decide whether or not to accept the certificate, you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"would have to return "},{"type":"codeVoice","code":"false"},{"text":" from the signal handler on the first","type":"text"},{"type":"text","text":" "},{"type":"text","text":"attempt, and then after the connection attempt returns a"},{"type":"text","text":" "},{"code":"badCertificate","type":"codeVoice"},{"text":", you can interact with the user, and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if the user decides to accept the certificate, remember that fact,"},{"text":" ","type":"text"},{"type":"text","text":"create a new connection, and return "},{"code":"true","type":"codeVoice"},{"text":" from the signal handler","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the next time."}]},{"inlineContent":[{"text":"If you are doing I\/O in another thread, you do not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"need to worry about this, and can simply block in the signal"},{"type":"text","text":" "},{"type":"text","text":"handler until the UI thread returns an answer."}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"accept-certificate"},{"type":"text","text":" signal"}]}],"name":"Note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/onAcceptCertificate(flags:handler:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/gio\/tlsconnectionref\/onacceptcertificate(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Instance Method","title":"onAcceptCertificate(flags:handler:)","modules":[{"name":"GIO"}],"symbolKind":"method","role":"symbol","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onAcceptCertificate"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"TLSConnectionRef","preciseIdentifier":"s:3GIO16TLSConnectionRefV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:3GIO17TLSCertificateRefV","kind":"typeIdentifier","text":"TLSCertificateRef"},{"kind":"text","text":", "},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier","text":"TLSCertificateFlags"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"externalID":"s:3GIO21TLSConnectionProtocolPAAE19onAcceptCertificate5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0B3RefV_AA014TLSCertificateM0VAA0nL0VtctF::SYNTHESIZED::s:3GIO16TLSConnectionRefV"},"sections":[],"abstract":[{"type":"text","text":"Emitted during the TLS handshake after the peer certificate has"},{"type":"text","text":" "},{"type":"text","text":"been received. You can examine "},{"type":"codeVoice","code":"peerCert"},{"type":"text","text":"’s certification path by"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"g_tls_certificate_get_issuer()","type":"codeVoice"},{"text":" on it.","type":"text"}],"references":{"doc://GIO/documentation/GIO/TLSCertificateRef":{"abstract":[{"text":"A certificate used for TLS authentication and encryption.","type":"text"},{"text":" ","type":"text"},{"text":"This can represent either a certificate only (eg, the certificate","type":"text"},{"type":"text","text":" "},{"text":"received by a client from a server), or the combination of","type":"text"},{"type":"text","text":" "},{"text":"a certificate and a private key (which is needed when acting as a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference"},{"type":"text","text":"])."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateRef"}],"title":"TLSCertificateRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TLSCertificateRef","kind":"identifier"}],"url":"\/documentation\/gio\/tlscertificateref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef"},"doc://GIO/documentation/GIO/TLSConnectionRef/TLSConnectionProtocol-Implementations":{"type":"topic","url":"\/documentation\/gio\/tlsconnectionref\/tlsconnectionprotocol-implementations","role":"collectionGroup","abstract":[],"kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/TLSConnectionProtocol-Implementations","title":"TLSConnectionProtocol Implementations"},"doc://GIO/documentation/GIO/TLSConnectionRef":{"type":"topic","url":"\/documentation\/gio\/tlsconnectionref","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TLSConnectionRef"}],"abstract":[{"type":"codeVoice","code":"GTlsConnection"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"type":"text","text":" "},{"text":"a [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"type":"text","text":"] and provides TLS encryption on top of it. Its"},{"type":"text","text":" "},{"text":"subclasses, [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true,"type":"reference"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference","isActive":true},{"type":"text","text":"], implement client-side and server-side TLS,"},{"text":" ","type":"text"},{"type":"text","text":"respectively."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","title":"TLSConnectionRef","navigatorTitle":[{"text":"TLSConnectionRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/TLSCertificateFlags":{"url":"\/documentation\/gio\/tlscertificateflags","abstract":[{"type":"text","text":"A set of flags describing TLS certification validation. This can be"},{"type":"text","text":" "},{"type":"text","text":"used to describe why a particular certificate was rejected (for"},{"type":"text","text":" "},{"text":"example, in ","type":"text"},{"type":"reference","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","isActive":true},{"text":".","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateFlags","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateFlags"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","title":"TLSCertificateFlags","kind":"symbol"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"t