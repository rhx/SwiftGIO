{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/TLSConnectionProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"extendedModule":"GIO","title":"handshake(cancellable:)","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"handshake","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"modules":[{"name":"GIO"}],"externalID":"s:3GIO21TLSConnectionProtocolPAAE9handshake11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO16TLSConnectionRefV","symbolKind":"method","role":"symbol"},"abstract":[{"type":"text","text":"Attempts a TLS handshake on "},{"type":"codeVoice","code":"conn"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"handshake"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On the client side, it is never necessary to call this method;"},{"text":" ","type":"text"},{"type":"text","text":"although the connection needs to perform a handshake after"},{"text":" ","type":"text"},{"text":"connecting (or after sending a “STARTTLS”-type command),","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"type":"text","text":" will handle this for you automatically when you try"},{"text":" ","type":"text"},{"type":"text","text":"to send or receive data on the connection. You can call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"text":" manually if you want to know whether","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake succeeded or failed (as opposed to just"},{"type":"text","text":" "},{"type":"text","text":"immediately trying to use "},{"type":"codeVoice","code":"conn"},{"text":" to read or write, in which case,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if it fails, it may not be possible to tell if it failed before or"},{"type":"text","text":" "},{"type":"text","text":"after completing the handshake), but beware that servers may reject"},{"type":"text","text":" "},{"text":"client authentication after the handshake has completed, so a","type":"text"},{"type":"text","text":" "},{"text":"successful handshake does not indicate the connection will be usable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Likewise, on the server side, although a handshake is necessary at"},{"type":"text","text":" "},{"type":"text","text":"the beginning of the communication, you do not need to call this"},{"type":"text","text":" "},{"type":"text","text":"function explicitly unless you want clearer error reporting."}]},{"inlineContent":[{"type":"text","text":"Previously, calling "},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" after the initial"},{"text":" ","type":"text"},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"type":"text","text":" "},{"text":"deprecated in GLib 2.60 because rehandshaking was removed from the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake will no longer do anything."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When using a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" created by "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","type":"reference","isActive":true},{"type":"text","text":", the"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","type":"reference","isActive":true},{"type":"text","text":" performs the initial handshake, so calling this"},{"type":"text","text":" "},{"text":"function manually is not recommended.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"[TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the","type":"text"},{"type":"text","text":" "},{"text":"handshake.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsconnectionref\/handshake(cancellable:)"]}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/handshake(cancellable:)","interfaceLanguage":"swift"},"sections":[],"references":{"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClient"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","abstract":[{"type":"codeVoice","code":"GSocketClient"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"title":"SocketClient","role":"symbol","url":"\/documentation\/gio\/socketclient","navigatorTitle":[{"kind":"identifier","text":"SocketClient"}]},"doc://GIO/documentation/GIO/TLSConnectionRef/TLSConnectionProtocol-Implementations":{"type":"topic","url":"\/documentation\/gio\/tlsconnectionref\/tlsconnectionprotocol-implementations","role":"collectionGroup","abstract":[],"kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/TLSConnectionProtocol-Implementations","title":"TLSConnectionProtocol Implementations"},"do