{"sections":[],"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/TLSConnectionProtocol-Implementations"]]},"metadata":{"symbolKind":"method","title":"onNotifyRehandshakeMode(flags:handler:)","role":"symbol","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","externalID":"s:3GIO21TLSConnectionProtocolPAAE23onNotifyRehandshakeMode5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0B3RefV_AG09ParamSpecN0VtctF::SYNTHESIZED::s:3GIO16TLSConnectionRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyRehandshakeMode","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"TLSConnectionRef","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"extendedModule":"GIO"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyRehandshakeMode"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"text":"TLSConnectionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO16TLSConnectionRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}],"name":"flags"},{"name":"handler","content":[{"inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"notifyRehandshakeMode"},{"text":" signal is emitted","type":"text"}],"type":"paragraph"}]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names"},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::rehandshake-mode","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"style":"note"}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/tlsconnectionref\/onnotifyrehandshakemode(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/onNotifyRehandshakeMode(flags:handler:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], represe