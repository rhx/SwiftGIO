te","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::negotiated-protocol"},{"text":" signal","type":"text"}]}]}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef\/TLSConnectionProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/TLSConnectionRef/onNotifyNegotiatedProtocol(flags:handler:)":{"title":"onNotifyNegotiatedProtocol(flags:handler:)","type":"topic","abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"kind":"symbol","url":"\/documentation\/gio\/tlsconnectionref\/onnotifynegotiatedprotocol(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyNegotiatedProtocol"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","text":"TLSConnectionRef","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"kind":"text","text":", "},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\