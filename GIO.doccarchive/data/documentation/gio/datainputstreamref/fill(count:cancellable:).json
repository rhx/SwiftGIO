{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datainputstreamref\/fill(count:cancellable:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DataInputStreamRef\/fill(count:cancellable:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DataInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/DataInputStreamRef\/BufferedInputStreamProtocol-Implementations"]]},"abstract":[{"text":"Tries to read ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from the stream into the buffer."},{"type":"text","text":" "},{"text":"Will block during this read.","type":"text"}],"sections":[],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","extendedModule":"GIO","externalID":"s:3GIO27BufferedInputStreamProtocolPAAE4fill5count11cancellableS2i_AA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO18DataInputStreamRefV","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"fill","kind":"identifier"},{"kind":"text","text":"("},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"gssize","preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier"}],"role":"symbol","modules":[{"name":"GIO"}],"title":"fill(count:cancellable:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fill","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier","text":"gssize"}]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"count"},{"text":" is zero, returns zero and does nothing. A value of ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" "},{"text":"larger than ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" will cause a"},{"type":"text","text":" "},{"type":"text","text":"[error"},{"code":"Gio.IOErrorEnum.INVALID_ARGUMENT","type":"codeVoice"},{"text":"] error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes read into the buffer is returned."},{"type":"text","text":" "},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"type":"text","text":" "},{"type":"text","text":"can happen e.g. near the end of a file. Zero is returned on end of file"},{"type":"text","text":" "},{"type":"text","text":"(or if "},{"type":"codeVoice","code":"count"},{"text":" is zero),  but never otherwise.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" is -1 then the attempted read size is equal to the number of"},{"type":"text","text":" "},{"text":"bytes that are required to fill the buffer.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error [error"},{"code":"Gio.IOErrorEnum.CANCELLED","type":"codeVoice"},{"type":"text","text":"] will be returned."},{"text":" ","type":"text"},{"text":"If an operation was partially finished when the operation was cancelled the","type":"text"},{"text":" ","type":"text"},{"text":"partial result will be returned, without an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error "},{"code":"-1","type":"codeVoice"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For the asynchronous, non-blocking, version of this function, see","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.BufferedInputStream.fill_async"},{"type":"text","text":"]."}]}],"kind":"content"}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/DataInputStreamRef/fill(count:cancellable:)":{"role"