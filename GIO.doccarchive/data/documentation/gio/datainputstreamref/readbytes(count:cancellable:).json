{"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DataInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/DataInputStreamRef\/InputStreamProtocol-Implementations"]]},"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","title":"readBytes(count:cancellable:)","extendedModule":"GIO","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"readBytes","kind":"identifier"},{"kind":"text","text":"("},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef"},{"text":"!","kind":"text"}],"externalID":"s:3GIO19InputStreamProtocolPAAE9readBytes5count11cancellable4GLib0F3RefVSgSi_AA011CancellableJ0VSgtKF::SYNTHESIZED::s:3GIO18DataInputStreamRefV","role":"symbol"},"abstract":[{"text":"Like ","type":"text"},{"type":"codeVoice","code":"g_input_stream_read()"},{"text":", this tries to read ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" bytes from","type":"text"},{"type":"text","text":" "},{"text":"the stream in a blocking fashion. However, rather than reading into","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing"},{"type":"text","text":" "},{"type":"text","text":"the data that was read. This may be easier to use from language"},{"text":" ","type":"text"},{"type":"text","text":"bindings."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DataInputStreamRef\/readBytes(count:cancellable:)"},"variants":[{"paths":["\/documentation\/gio\/datainputstreamref\/readbytes(count:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"readBytes"},{"text":"(","kind":"text"},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"BytesRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8BytesRefV"},{"text":"!","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"If count is zero, returns a zero-length [Bytes](\/\/documentation\/glib\/bytes and does nothing. A","type":"text"},{"type":"text","text":" "},{"text":"value of ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On success, a new [Bytes](\/\/documentation\/glib\/bytes is returned. It is not an error if the","type":"text"},{"type":"text","text":" "},{"text":"size of this object is not the same as the requested size, as it","type":"text"},{"text":" ","type":"text"},{"text":"can happen e.g. near the end of a file. A zero-length [Bytes](\/\/documentation\/glib\/bytes is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned on end of file (or if "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is zero), but never"},{"type":"text","text":" "},{"type":"text","text":"otherwise."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If an"},{"text":" ","type":"text"},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"text":"partial result will be returned, without an error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"On error ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/DataInputStreamRef/InputStreamProtocol-Implementations":{"url":"\/documentation\/gio\/datainputstreamref\/inputstreamprotocol-implementations","title":"InputStreamProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DataInputStreamRef\/InputStreamProtocol-Implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}]