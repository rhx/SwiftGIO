{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint","interfaceLanguage":"swift"},"abstract":[{"type":"codeVoice","code":"GIOExtensionPoint"},{"type":"text","text":" provides a mechanism for modules to extend the"},{"text":" ","type":"text"},{"text":"functionality of the library or application that loaded it in an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"organized fashion."}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/gio\/ioextensionpoint"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IOExtensionPoint","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"text":"IOExtensionPoint","kind":"identifier"}],"title":"IOExtensionPoint","externalID":"s:3GIO16IOExtensionPointC","modules":[{"name":"GIO"}],"symbolKind":"class"},"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(_:)-32vhw","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(_:)-5l0kx","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(_:)-5q0ph","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(_:)-6y1r5","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(_:)-8g9w","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(raw:)-25sbn","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(raw:)-9l1bn","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(retainingRaw:)-2ven2","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(retainingRaw:)-5hyof"],"anchor":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/ptr"],"generated":true,"title":"Instance Properties"},{"anchor":"Type-Methods","title":"Type Methods","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/lookup(name:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/register(name:)"]},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/IOExtensionPointProtocol-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOExtensionPoint"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"An extension point is identified by a name, and it may optionally"},{"type":"text","text":" "},{"type":"text","text":"require that any implementation must be of a certain type (or derived"},{"type":"text","text":" "},{"text":"thereof). Use [func","type":"text"},{"code":"Gio.IOExtensionPoint.register","type":"codeVoice"},{"text":"] to register an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"extension point, and [method"},{"code":"Gio.IOExtensionPoint.set_required_type","type":"codeVoice"},{"type":"text","text":"] to"},{"text":" ","type":"text"},{"type":"text","text":"set a required type."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A module can implement an extension point by specifying the"},{"type":"text","text":" "},{"text":"[type[Type_](\/\/documentation\/gobject\/type_] that implements the functionality. Additionally, each","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation of an extension point has a name, and a priority. Use"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"Gio.IOExtensionPoint.implement","type":"codeVoice"},{"type":"text","text":"] to implement an extension point."}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["GIOExtensionPoint *ep;","","\/\/ Register an extension point","ep = g_io_extension_point_register (\"my-extension-point\");","g_io_extension_point_set_required_type (ep, MY_TYPE_EXAMPLE);"]},{"syntax":"c","type":"codeListing","code":["\/\/ Implement an extension point","G_DEFINE_TYPE (MyExampleImpl, my_example_impl, MY_TYPE_EXAMPLE)","g_io_extension_point_implement (\"my-extension-point\",","                                my_example_impl_get_type (),","                                \"my-example\",","                                10);"]},{"inlineContent":[{"type":"text","text":"It is up to the code that registered the extension point how"},{"type":"text","text":" "},{"text":"it uses the implementations that have been associated with it.","type":"text"},{"text":" ","type":"text"},{"text":"Depending on the use case, it may use all implementations, or","type":"text"},{"type":"text","text":" "},{"text":"only the one with the highest priority, or pick a specific","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"one by name."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To avoid opening all modules just to find out what extension"},{"type":"text","text":" "},{"text":"points they implement, GIO makes use of a caching mechanism,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"see "},{"isActive":true,"identifier":"gio-querymodules.html","type":"reference"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"You are expected to run this command after installing a"},{"type":"text","text":" "},{"text":"GIO module.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"GIO_EXTRA_MODULES","type":"codeVoice"},{"type":"text","text":" environment variable can be used to"},{"text":" ","type":"text"},{"type":"text","text":"specify additional directories to automatically load modules"},{"type":"text","text":" "},{"text":"from. This environment variable has the same syntax as the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"PATH"},{"text":". If two modules have the same base name in different","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"directories, then the latter one will be ignored. If additional"},{"type":"text","text":" "},{"text":"directories are specified GIO will load modules from the built-in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"directory last."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint","isActive":true,"type":"reference"},{"type":"text","text":" type acts as an owner of an underlying "},{"type":"codeVoice","code":"GIOExtensionPoint"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GIOExtensionPoint","type":"codeVoice"},{"type":"text","text":" instance."}]},{"name":"Note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointRef","isActive":true},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GIOExtensionPoint"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}]}],"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"references":{"doc://GIO/documentation/GIO/IOExtensionPoint/init(gpointer:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint\/init(gpointer:)","type":"topic","kind":"symbol","url":"\/documentation\/gio\/ioextensionpoint\/init(gpointer:)","abstract":[{"text":"Optional initialiser from a non-mutating ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"text":" to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the underlying "},{"code":"C","type":"codeVoice"},{"text":" data type.","type":"text"},{"type":"text","text":" "},{"text":"This creates an instance without performing an unbalanced retain","type":"text"},{"type":"text","text":" "},{"type":"text","text":"i.e., ownership is transferred to the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint","isActive":true,"type":"reference"},{"type":"text","text":" instance."}],"title":"init(gpointer:)","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"text":"!(","kind":"text"},{"kind":"externalParam","text":"gpointer"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}]},"doc://GIO/documentation/GIO/IOExtensionPoint/init(raw:)-25sbn":{"fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"text":"raw","kind":"externalParam"},{"kind":"text"