o obtain change notification for a"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names"},{"text":" as","type":"text"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}]}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketAddressEnumeratorSignalName\/notify","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"title":"SocketAddressEnumeratorSignalName.notify","modules":[{"name":"GIO"}],"role":"symbol","roleHeading":"Case","externalID":"s:3GIO33SocketAddressEnumeratorSignalNameO6notifyyA2CmF","symbolKind":"case","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}]},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"text":"its value set through ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"type":"text","text":", et al."}],"references":{"doc://GIO/documentation/GIO/SocketAddressEnumeratorSignalName":{"title":"SocketAddressEnumeratorSignalName","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddressEnumerato