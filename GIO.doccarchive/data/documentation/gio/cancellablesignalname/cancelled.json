{"metadata":{"role":"symbol","roleHeading":"Case","symbolKind":"case","title":"CancellableSignalName.cancelled","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"cancelled"}],"modules":[{"name":"GIO"}],"externalID":"s:3GIO21CancellableSignalNameO9cancelledyA2CmF"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CancellableSignalName"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/CancellableSignalName\/cancelled"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/cancellablesignalname\/cancelled"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancelled"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Can be used by implementations of cancellable operations. If the"},{"type":"text","text":" "},{"type":"text","text":"operation is cancelled from another thread, the signal will be"},{"text":" ","type":"text"},{"type":"text","text":"emitted in the thread that cancelled the operation, not the"},{"text":" ","type":"text"},{"type":"text","text":"thread that is running the operation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that disconnecting from this signal (or any signal) in a"},{"text":" ","type":"text"},{"type":"text","text":"multi-threaded program is prone to race conditions. For instance"},{"type":"text","text":" "},{"text":"it is possible that a signal handler may be invoked even after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a call to "},{"type":"codeVoice","code":"g_signal_handler_disconnect()"},{"type":"text","text":" for that handler has"},{"type":"text","text":" "},{"text":"already returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There is also a problem when cancellation happens right before","type":"text"},{"text":" ","type":"text"},{"text":"connecting to the signal. If this happens the signal will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unexpectedly not be emitted, and checking before connecting to"},{"text":" ","type":"text"},{"type":"text","text":"the signal leaves a race condition where this is still happening."}]},{"inlineContent":[{"type":"text","text":"In order to make it safe and easy to connect handlers there"},{"text":" ","type":"text"},{"type":"text","text":"are two helper functions: "},{"type":"codeVoice","code":"g_cancellable_connect()"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"g_cancellable_disconnect()","type":"codeVoice"},{"text":" which protect against problems","type":"text"},{"type":"text","text":" "},{"text":"like this.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An example of how to us this:"},{"text":" ","type":"text"},{"text":"(C Language Example):","type":"text"}]},{"code":["    \/\/ Make sure we don't do unnecessary work if already cancelled","    if (g_cancellable_set_error_if_cancelled (cancellable, error))","      return;","","    \/\/ Set up all the data needed to be able to handle cancellation","    \/\/ of the operation","    my_data = my_data_new (...);","","    id = 0;","    if (cancellable)","      id = g_cancellable_connect (cancellable,","    \t\t\t      G_CALLBACK (cancelled_handler)","    \t\t\t      data, NULL);","","    \/\/ cancellable operation here...","","    g_cancellable_disconnect (cancellable, id);","","    \/\/ cancelled_handler is never called after this, it is now safe","    \/\/ to free the data","    my_data_free (my_data);"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"text":"Note that the cancelled signal is emitted in the thread that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the user cancelled from, which may be the main thread. So, the"},{"text":" ","type":"text"},{"text":"cancellable signal should not do something that can block.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Emitted when the operation has been cancelled.","type":"text"}],"references":{"doc://GIO/documentation/GIO/CancellableSignalName/cancelled":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableSignalName\/cancelled","url":"\/documentation\/gio\/cancellablesignalname\/cancelled","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"cancelled","kind":"identifier"}],"kind":"symbol","role":"symbol","title":"CancellableSignalName.cancelled","type":"topic","abstract":[{"text":"Emitted when the operation has been cancelled.","type":"text"}]},"doc://GIO/documentation/GIO/CancellableSignalName":{"navigatorTitle":[{"text":"CancellableSignalName","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableSignalName","kind":"symbol","type":"topic","abstract":[],"url":"\/documentation\/gio\/cancellablesignalname","title":"CancellableSignalName","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CancellableSignalName"}],"role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}