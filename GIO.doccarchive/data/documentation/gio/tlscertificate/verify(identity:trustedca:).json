{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","doc:\/\/GIO\/documentation\/GIO\/TLSCertificate\/TLSCertificateProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"verify","kind":"identifier"},{"kind":"text","text":"("},{"text":"identity","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO20SocketConnectableRefV","kind":"typeIdentifier","text":"SocketConnectableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableRef"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"trustedCa"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV"},{"text":"? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","text":"TLSCertificateFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV"}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"cert","type":"codeVoice"},{"text":" is valid, ","type":"text"},{"code":"noFlags","type":"codeVoice"},{"type":"text","text":" is returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"identity"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", ","type":"text"},{"code":"cert","type":"codeVoice"},{"type":"text","text":"’s "},{"type":"codeVoice","code":"name(s)"},{"text":" will be compared against","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it, and "},{"code":"badIdentity","type":"codeVoice"},{"type":"text","text":" will be set in the return"},{"type":"text","text":" "},{"type":"text","text":"value if it does not match. If "},{"code":"identity","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"text":", that bit will","type":"text"},{"type":"text","text":" "},{"text":"never be set in the return value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"trustedCa"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then "},{"type":"codeVoice","code":"cert"},{"text":" (or one of the certificates","type":"text"},{"text":" ","type":"text"},{"text":"in its chain) must be signed by it, or else","type":"text"},{"text":" ","type":"text"},{"code":"unknownCa","type":"codeVoice"},{"type":"text","text":" will be set in the return value. If"},{"text":" ","type":"text"},{"code":"trustedCa","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", that bit will never be set in the return","type":"text"},{"type":"text","text":" "},{"type":"text","text":"value."}]},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"type":"text","text":" "},{"text":"error will be set in the return value, but it does not guarantee","type":"text"},{"type":"text","text":" "},{"text":"that all possible errors will be set. Accordingly, you may not safely","type":"text"},{"type":"text","text":" "},{"type":"text","text":"decide to ignore any particular type of error. For example, it would"},{"text":" ","type":"text"},{"text":"be incorrect to mask ","type":"text"},{"type":"codeVoice","code":"expired"},{"text":" if you want to allow","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"expired certificates, because this could potentially be the only"},{"type":"text","text":" "},{"type":"text","text":"error flag set even if other problems exist with the certificate."}],"type":"paragraph"},{"inl