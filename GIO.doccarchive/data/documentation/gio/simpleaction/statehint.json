xt"},{"text":"SimpleActionGroup","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SimpleActionGroup"}]},"doc://GIO/documentation/GIO/SimpleAction":{"url":"\/documentation\/gio\/simpleaction","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAction","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GSimpleAction"},{"type":"text","text":" is the obvious simple implementation of the"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true},{"text":"] interface. This is the easiest way to create an action for","type":"text"},{"type":"text","text":" "},{"text":"purposes of adding it to a [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroup"},{"type":"text","text":"]."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"SimpleAction"}],"title":"SimpleAction","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SimpleAction"}],"kind":"symbol","role":"symbol"}}}