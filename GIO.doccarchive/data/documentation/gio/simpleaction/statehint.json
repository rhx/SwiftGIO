{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleAction","doc:\/\/GIO\/documentation\/GIO\/SimpleAction\/ActionProtocol-Implementations"]]},"sections":[],"metadata":{"extendedModule":"GIO","roleHeading":"Instance Property","title":"stateHint","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stateHint"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"externalID":"s:3GIO14ActionProtocolPAAE9stateHint4GLib10VariantRefVSgvp::SYNTHESIZED::s:3GIO12SimpleActionC","symbolKind":"property","modules":[{"name":"GIO"}]},"variants":[{"paths":["\/documentation\/gio\/simpleaction\/statehint"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"stateHint","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"! { ","kind":"text"},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"NULL"},{"text":" is returned it either means that the action is not stateful","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or that there is no hint about the valid range of values for the"},{"type":"text","text":" "},{"type":"text","text":"state of the action."}]},{"inlineContent":[{"text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"type":"text","text":" "},{"type":"text","text":"returned then the tuple specifies the inclusive lower and upper bound"},{"type":"text","text":" "},{"text":"of valid values for the state.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In any case, the information is merely a hint.  It may be possible to"},{"type":"text","text":" "},{"text":"have a state value outside of the hinted range and setting a value","type":"text"},{"text":" ","type":"text"},{"text":"within the range may fail.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value (if non-"},{"type":"codeVoice","code":"NULL"},{"text":") should be freed with","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.Variant.unref","type":"codeVoice"},{"text":"] when it is no longer required.","type":"text"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SimpleAction\/stateHint","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Requests a hint about the valid range of values for the state of","type":"text"},{"text":" ","type":"text"},{"code":"action","type":"codeVoice"},{"text":".","type":"text"}],"references":{"doc://GIO/documentation/GIO/SimpleAction/stateHint":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAction\/stateHint","title":"stateHint","kind":"symbol","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"stateHint","kind":"identifier"},{"kind":"text","text":": "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"abstract":[{"text":"Requests a hint about the valid range of values for the state of","type":"text"},{"type":"text","text":" "},{"code":"action","type":"codeVoice"},{"text":".","type":"text"}],"url":"\/documentation\/gio\