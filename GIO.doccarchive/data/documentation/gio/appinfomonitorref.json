tion.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This is because monitoring the app info database for changes is expensive."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following functions will re-arm the [signal[AppInfoMonitor](\/\/documentation\/gio\/appinfomonitor\/onchanged(flags:handler:)]"},{"type":"text","text":" "},{"type":"text","text":"signal so it can be emitted again:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"code":"Gio.AppInfo.get_all","type":"codeVoice"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"Gio.AppInfo.get_all_for_type"},{"text":"]","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"Gio.AppInfo.get_default_for_type"},{"text":"]","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"Gio.AppInfo.get_fallback_for_type"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"[func","type":"text"},{"type":"codeVoice","code":"Gio.AppInfo.get_recommended_for_type"},{"text":"]","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"..\/gio-unix\/type_func.DesktopAppInfo.get_implementation.html","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"..\/gio-unix\/ctor.DesktopAppInfo.new.html","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"..\/gio-unix\/ctor.DesktopAppInfo.new_from_filename.html"}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"..\/gio-unix\/ctor.DesktopAppInfo.new_from_keyfile.html"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"..\/gio-unix\/type_func.DesktopAppInfo.search.html","isActive":true,"type":"reference"}]}]}]},{"inlineContent":[{"type":"text","text":"The latter functions are available if using"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"..\/gio-unix\/class.DesktopAppInfo.html"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"code":"gio-unix-2.0.pc","type":"codeVoice"},{"type":"text","text":" (GIR namespace "},{"code":"GioUnix-2.0","type":"codeVoice"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the usual case, applications should try to make note of the change"},{"text":" ","type":"text"},{"type":"text","text":"(doing things like invalidating caches) but not act on it. In"},{"text":" ","type":"text"},{"text":"particular, applications should avoid making calls to ","type":"text"},{"type":"codeVoice","code":"GAppInfo"},{"text":" APIs","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in response to the change signal, deferring these until the time that"},{"text":" ","type":"text"},{"text":"the updated data is actually required. The exception to this case is when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"application information is actually being displayed on the screen"},{"type":"text","text":" "},{"text":"(for example, during a search or when the list of all applications is shown).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The reason for this is that changes to the list of installed applications"},{"type":"text","text":" "},{"text":"often come in groups (like during system updates) and rescanning the list","type":"text"},{"type":"text","text":" "},{"text":"on every change is pointless and expensive.","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GAppInfoMonitor","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorProtocol"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorRef","type":"reference"},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GAppInfoMonitor","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitor","type":"reference"},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GAppInfoMonitor"},{"type":"text","text":" instance."}]}],"style":"note","name":"Note","type":"aside"}]}],"abstract":[{"code":"GAppInfoMonitor","type":"codeVoice"},{"type":"text","text":" monitors application information for changes."}],"sections":[],"references":{"doc://GIO/documentation/GIO/AppInfoMonitorRef/init(_:)-9uk0w":{"url":"\/documentation\/gio\/appinfomonitorref\/init(_:)-9uk0w","kind":"symbol","title":"init(_:)","abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfoMonitorRef\/init(_:)-9uk0w","role":"symbol","fragments":[{"text"