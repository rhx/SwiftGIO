},{"kind":"text","text":") -> "},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"kind":"symbol"},"doc://GIO/documentation/GIO/MountOperationRef":{"title":"MountOperationRef","kind":"symbol","url":"\/documentation\/gio\/mountoperationref","abstract":[{"type":"codeVoice","code":"GMountOperation"},{"text":" provides a mechanism for interacting with the user.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It can be used for authenticating mountable operations, such as loop"},{"text":" ","type":"text"},{"type":"text","text":"mounting files, hard drive partitions or server locations. It can"},{"text":" ","type":"text"},{"type":"text","text":"also be used to ask the user questions or show a list of applications"},{"type":"text","text":" "},{"type":"text","text":"preventing unmount or eject operations from completing."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MountOperationRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationRef","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MountOperationRef"}]},"doc://GIO/documentation/GIO/MountOperationRef/MountOperationProtocol-Implementations":{"role":"collectionGroup","url":"\/documentation\/gio\/mountoperationref\/mountoperationprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationRef\/MountOperationProtocol-Implementations","title":"MountOperationProtocol Implementations","type":"topic","abstract":[],"kind":"article"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}