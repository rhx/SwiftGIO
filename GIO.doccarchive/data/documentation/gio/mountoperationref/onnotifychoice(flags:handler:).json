{"sections":[],"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onNotifyChoice","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17MountOperationRefV","text":"MountOperationRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationRef"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyChoice"},{"text":" signal is emitted","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"notify::choice","type":"codeVoice"},{"text":" signal","type":"text"}],"type":"paragraph"}],"name":"Note"}]}],"metadata":{"externalID":"s:3GIO22MountOperationProtocolPAAE14onNotifyChoice5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecN0VtctF::SYNTHESIZED::s:3GIO17MountOperationRefV","symbolKind":"method","role":"symbol","modules":[{"name":"GIO"}],"title":"onNotifyChoice(flags:handler:)","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onNotifyChoice"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO17MountOperationRefV","text":"MountOperationRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"roleHeading":"Instance Method"},"variants":[{"paths":["\/documentation\/gio\/mountoperationref\/onnotifychoice(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"sy