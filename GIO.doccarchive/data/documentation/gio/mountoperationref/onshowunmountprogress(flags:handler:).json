ontent":[{"text":"When unmounting or ejecting a volume, the kernel might need to flush","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"pending data in its buffers to the volume stable storage, and this operation"},{"type":"text","text":" "},{"type":"text","text":"can take a considerable amount of time. This signal may be emitted several"},{"type":"text","text":" "},{"type":"text","text":"times as long as the unmount operation is outstanding, and then one"},{"type":"text","text":" "},{"type":"text","text":"last time when the operation is completed, with "},{"type":"codeVoice","code":"bytesLeft"},{"type":"text","text":" set to zero."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations of GMountOperation should handle this signal by"},{"text":" ","type":"text"},{"type":"text","text":"showing an UI notification, and then dismiss it, or show another notification"},{"type":"text","text":" "},{"type":"text","text":"of completion, when "},{"code":"bytesLeft","type":"codeVoice"},{"type":"text","text":" reaches zero."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the message contains a line break, the first line should be"},{"type":"text","text":" "},{"type":"text","text":"presented as a heading. For example, it may be used as the"},{"text":" ","type":"text"},{"text":"primary text in a ","type":"text"},{"type":"codeVoice","code":"GtkMessageDialog"},{"type":"text","text":"."}]},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"show-unmount-progress"},{"type":"text","text":" signal"}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"abstract":[{"text":"Emitted when an unmount operation has been busy for more than some time","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(typically 1.5 seconds)."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/mountoperat