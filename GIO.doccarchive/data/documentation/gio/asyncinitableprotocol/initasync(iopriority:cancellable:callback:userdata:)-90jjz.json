{"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AsyncInitableProtocol"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"initAsync","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_async_initable_new_async()"},{"text":" should typically be used instead.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When the initialization is finished, ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called. You can"},{"type":"text","text":" "},{"type":"text","text":"then call "},{"type":"codeVoice","code":"g_async_initable_init_finish()"},{"text":" to get the result of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initialization."}],"type":"paragraph"},{"inlineContent":[{"text":"Implementations may also support cancellation. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not","type":"text"},{"type":"text","text":" "},{"code":"nil","type":"codeVoice"},{"text":", then initialization can be cancelled by triggering the cancellable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object from another thread. If the operation was cancelled, the error"},{"text":" ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the object doesn’t support cancellable initialization, the error"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As with "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"type":"text","text":", if the object is not initialized, or initialization"},{"type":"text","text":" "},{"type":"text","text":"returns with an error, then all operations on the object except"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_ref()"},{"text":" and ","type":"text"},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" are considered to be invalid, and"},{"type":"text","text":" "},{"type":"text","text":"have undefined behaviour. They will often fail with "},{"type":"codeVoice","code":"g_critical()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"g_warning()","type":"codeVoice"},{"type":"text","text":", but this must not be relied on."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable"},{"type":"text","text":" can"},{"text":" ","type":"text"},{"type":"text","text":"be initialized multiple times; for more information, see "},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"If a class explicitly supports being initialized multiple times,","type":"text"},{"text":" ","type":"text"},{"text":"implementation requires yielding all subsequent calls to ","type":"text"},{"code":"init_async()","type":"codeVoice"},{"type":"text","text":" on the"},{"type":"text","text":" "},{"text":"results of the first call.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For classes that also support the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":" interface, the default"},{"text":" ","type":"text"},{"text":"implementation of this method will run the ","type":"text"},{"code":"g_initable_init()","type":"codeVoice"},{"text":" function","type":"text"},{"type":"text","text":" "},{"text":"in a thread, so if you want to support asynchronous initialization via","type":"text"},{"type":"text","text":" "},{"text":"threads, just implement the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable"},{"type":"text","text":" interface without overriding"},{"type":"text","text":" "},{"type":"text","text":"any interface methods."}]}]}],"abstract":[{"type":"text","text":"Starts asynchronous initialization of the object implementing the"},{"type":"text","text":" "},{"text":"interface. This must be done before any real use of the object after","type":"text"},{"type":"text","text":" "},{"text":"initial construction. If the object also implements ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"text":" you can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"optionally call "},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":" instead."}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"initAsync","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"role":"symbol","roleHeading":"Instance Method","title":"initAsync(ioPriority:cancellable:callback:userData:)","externalID":"s:3GIO21AsyncInitableProtocolPAAE04initB010ioPriority11cancellable8callback8userDataySi_qd__SgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgARtAA011CancellableD0Rd__lF","modules":[{"name":"GIO"}],"symbolKind":"method","extendedModule":"GIO"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitableProtocol\/initAsync(ioPriority:cancellable:callback:userData:)-90jjz","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"p