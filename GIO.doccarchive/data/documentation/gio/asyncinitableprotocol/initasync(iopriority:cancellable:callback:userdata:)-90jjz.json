type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/AsyncInitableProtocol/initAsync(ioPriority:cancellable:callback:userData:)-90jjz":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"initAsync","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":"?, "},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"role":"symbol","title":"initAsync(ioPriority:cancellable:callback:userData:)","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitableProtocol\/initAsync(ioPriority:cancellable:callback:userData:)-90jjz","abstract":[{"text":"Starts asynchronous initialization of the object implementing the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interface. This must be done before any real use of the object after"},{"type":"text","text":" "},{"type":"text","text":"initial construction. If the object also implements "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":" you can"},{"type":"text","text":" "},{"type":"text","text":"optionally call "},{"type":"codeVoice","code":"g_initable_init()"},{"text":" instead.