{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"text","text":"Starts asynchronous initialization of the object implementing the"},{"type":"text","text":" "},{"text":"interface. This must be done before any real use of the object after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initial construction. If the object also implements "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":" you can"},{"type":"text","text":" "},{"type":"text","text":"optionally call "},{"type":"codeVoice","code":"g_initable_init()"},{"text":" instead.","type":"text"}],"metadata":{"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"initAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","kind":"typeIdentifier","text":"GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"extendedModule":"GIO","role":"symbol","title":"initAsync(ioPriority:cancellable:callback:userData:)","modules":[{"name":"GIO"}],"symbolKind":"method","externalID":"s:3GIO21AsyncInitableProtocolPAAE04initB010ioPriority11cancellable8callback8userDataySi_AA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgATtF"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AsyncInitableProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitableProtocol\/initAsync(ioPriority:cancellable:callback:userData:)-6ygaj"},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/gio\/asyncinitableprotocol\/initasync(iopriority:cancellable:callback:userdata:)-6ygaj"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"initAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","kind":"typeIdentifier","text":"GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_async_initable_new_async()"},{"text":" should typically be used instead.","type":"text"}]},{"inlineContent":[{"text":"When the initialization is finished, ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called. You can"},{"text":" ","type":"text"},{"text":"then call ","type":"text"},{"code":"g_async_initable_init_finish()","type":"codeVoice"},{"text":" to get the result of the","type":"text"},{"type":"text","text":" "},{"text":"initialization.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then initialization can be cancelled by triggering the cancellable"},{"type":"text","text":" "},{"text":"object from another thread. If the operation was cancelled, the error","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"text":"the object doesn’t support cancellable initialization, the error","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":", if the object is not initialized, or initialization"},{"text":" ","type":"text"},{"text":"returns with an error, then all operations on the object except","type":"text"},{"text":" ","type":"text"},{"code":"g_object_ref()","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" are considered to be invalid, and"},{"text":" ","type":"text"},{"text":"have undefined behaviour. They will often fail with ","type":"text"},{"type":"codeVoice","code":"g_critical()"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_warning()"},{"type":"text","text":", but this must not be relied on."}]},{"type":"paragraph","inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference","isActive":true},{"type":"text","text":" can"},{"text":" ","type":"text"},{"text":"be initialized multiple times; for more information, see ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"If a class explicitly supports being initialized multiple times,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation requires yielding all subsequent calls to "},{"code":"init_async()","type":"codeVoice"},{"text":" on the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"results of the first call."}]},{"inlineContent":[{"type":"text","text":"For classes that also support the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" interface, the default"},{"type":"text","text":" "},{"text":"implementation of this method will run the ","type":"text"},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":" function"},{"type":"text","text":" "},{"text":"in a thread, so if you want to support asynchronous initialization via","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"threads, just implement the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true,"type":"reference"},{"type":"text","text":" interface without overriding"},{"text":" ","type":"text"},{"type":"text","text":"any interface methods."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/AsyncInitableProtocol/initAsync(ioPriority:cancellable:callback:userData:)-6ygaj":{"title":"initAsync(ioPriority:cancellable:callback:use