adding [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true},{"text":"] instances to it.","type":"text"}],"title":"MenuProtocol","role":"symbol","navigatorTitle":[{"text":"MenuProtocol","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuProtocol","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuProtocol","type":"topic","url":"\/documentation\/gio\/menuprotocol","kind":"symbol"},"https://docs.gtk.org/gtk4/class.Application.html":{"url":"https:\/\/docs.gtk.org\/gtk4\/class.Application.html","title":"GtkApplication","type":"link","titleInlineContent":[{"code":"GtkApplication","type":"codeVoice"}],"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Application.html"},"doc://GIO/documentation/GIO/DBusMenuModel":{"title":"DBusMenuModel","type":"topic","navigatorTitle":[{"text":"DBusMenuModel","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusMenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDBusMenuModel"},{"type":"text","text":" is an implementation of [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"type":"text","text":"] that can be"},{"type":"text","text":" "},{"text":"used as a proxy for a menu model that is exported over D-Bus with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.DBusConnection.export_menu_model","type":"codeVoice"},{"text":"].","type":"text"}],"url":"\/documentation\/gio\/dbusmenumodel","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel","role":"symbol"},"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},"doc://GIO/documentation/GIO/MenuModelProtocol/getItemAttributeValue(itemIndex:attribute:expectedType:)-68z92":{"role":"symbol","abstract":[{"type":"text","text":"Queries the item at position "},{"type":"codeVoice","code":"itemIndex"},{"type":"text","text":" in "},{"type":"codeVoice","code":"model"},{"text":" for the attribute","type":"text"},{"type":"text","text":" "},{"text":"specified by ","type":"text"},{"type":"codeVoice","code":"attribute"},{"type":"text","text":"."}],"title":"getItemAttributeValue(itemIndex:attribute:expectedType:)","type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/getItemAttributeValue(itemIndex:attribute:expectedType:)-68z92","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getItemAttributeValue","kind":"identifier"},{"text":"(","kind":"text"},{"text":"itemIndex","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"attribute"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"expectedType"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib14VariantTypeRefV","text":"VariantTypeRef"},{"text":"?) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"!"}],"url":"\/documentation\/gio\/menumodelprotocol\/getitemattributevalue(itemindex:attribute:expectedtype:)-68z92"},"doc://GIO/4GLib14PointerWrapperP":{"identifier":"doc:\/\/GIO\/4GLib14PointerWrapperP","title":"GLib.PointerWrapper","type":"unresolvable"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModelProtocol/getItemAttributeValue(itemIndex:attribute:expectedType:)-tmnl":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getItemAttributeValue","kind":"identifier"},{"kind":"text","text":"<"},{"text":"GLibVariantTypeT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"itemIndex"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"attribute"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"text":"expectedType","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GLibVariantTypeT"},{"text":"