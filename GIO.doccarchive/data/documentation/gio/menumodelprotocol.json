{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"metadata":{"title":"MenuModelProtocol","symbolKind":"protocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}],"externalID":"s:3GIO17MenuModelProtocolP","navigatorTitle":[{"kind":"identifier","text":"MenuModelProtocol"}],"role":"symbol","roleHeading":"Protocol","modules":[{"name":"GIO"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"kind":"relationships","title":"Inherits From"},{"kind":"relationships","title":"Inherited By","type":"inheritedBy","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelProtocol","doc:\/\/GIO\/documentation\/GIO\/MenuProtocol"]},{"kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel","doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelRef","doc:\/\/GIO\/documentation\/GIO\/Menu","doc:\/\/GIO\/documentation\/GIO\/MenuModel","doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","doc:\/\/GIO\/documentation\/GIO\/MenuRef"],"title":"Conforming Types","type":"conformingTypes"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MenuModelProtocol"},{"kind":"text","text":" : "},{"text":"ObjectProtocol","preciseIdentifier":"s:10GLibObject0B8ProtocolP","kind":"typeIdentifier"}]}]},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"inlineContent":[{"text":"The conceptual model of menus in ","type":"text"},{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" is hierarchical:"},{"type":"text","text":" "},{"text":"sections and submenus are again represented by ","type":"text"},{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":"s."},{"type":"text","text":" "},{"type":"text","text":"Menus themselves do not define their own roles. Rather, the role"},{"text":" ","type":"text"},{"type":"text","text":"of a particular "},{"type":"codeVoice","code":"GMenuModel"},{"text":" is defined by the item that references","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it (or, in the case of the ‘root’ menu, is defined by the context"},{"type":"text","text":" "},{"text":"in which it is used).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an example, consider the visible portions of this menu:"}]},{"level":2,"text":"An example menu","type":"heading","anchor":"An-example-menu"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"While this kind of deeply nested menu is no longer considered good UI","type":"text"},{"text":" ","type":"text"},{"text":"practice, it serves as a good example of the concepts in ","type":"text"},{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"There are 8 ‘menus’ visible in the screenshot: one menubar, two"},{"type":"text","text":" "},{"type":"text","text":"submenus and 5 sections:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"the toplevel menubar (containing 4 items)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"the View submenu (containing 3 sections)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"the first section of the View submenu (containing 2 items)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the second section of the View submenu (containing 1 item)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the final section of the View submenu (containing 1 item)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the Highlight Mode submenu (containing 2 sections)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the Sources section (containing 2 items)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"the Markup section (containing 2 items)","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"#a-menu-example","isActive":true},{"type":"text","text":" illustrates the conceptual connection between"},{"text":" ","type":"text"},{"text":"these 8 menus. Each large block in the figure represents a menu and the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"smaller blocks within the large block represent items in that menu. Some"},{"type":"text","text":" "},{"text":"items contain references to other menus.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"A menu example","level":2,"anchor":"A-menu-example"},{"inlineContent":[{"type":"text","text":"Notice that the separators visible in the "},{"identifier":"#an-example-menu","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"appear nowhere in the ","type":"text"},{"type":"reference","isActive":true,"overridingTitleInlineContent":[{"type":"text","text":"menu model"}],"identifier":"#a-menu-example","overridingTitle":"menu model"},{"text":". This is because","type":"text"},{"type":"text","text":" "},{"type":"text","text":"separators are not explicitly represented in the menu model. Instead,"},{"type":"text","text":" "},{"type":"text","text":"a separator is inserted between any two non-empty sections of a menu."},{"text":" ","type":"text"},{"type":"text","text":"Section items can have labels just like any other item. In that case,"},{"text":" ","type":"text"},{"text":"a display system may show a section header instead of a separator.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The motivation for this abstract model of application controls is"},{"type":"text","text":" "},{"type":"text","text":"that modern user interfaces tend to make these controls available"},{"type":"text","text":" "},{"text":"outside the application. Examples include global menus, jumplists,","type":"text"},{"type":"text","text":" "},{"text":"dash boards, etc. To support such uses, it is necessary to ‘export’","type":"text"},{"type":"text","text":" "},{"text":"information about actions and their representation in menus, which","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is exactly what the action group exporter and the menu model exporter do for"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup"},{"text":"] and [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference","isActive":true},{"type":"text","text":"]. The client-side"},{"type":"text","text":" "},{"text":"counterparts to make use of the exported information are","type":"text"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusActionGroup"},{"type":"text","text":"] and [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The API of "},{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" is very generic, with iterators for the"},{"text":" ","type":"text"},{"text":"attributes and links of an item, see","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.MenuModel.iterate_item_attributes","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.MenuModel.iterate_item_links","type":"codeVoice"},{"text":"]. The ‘standard’ attributes and","type":"text"},{"type":"text","text":" "},{"text":"link types have predefined names: ","type":"text"},{"type":"codeVoice","code":"G_MENU_ATTRIBUTE_LABEL"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"G_MENU_ATTRIBUTE_ACTION","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"G_MENU_ATTRIBUTE_TARGET"},{"text":", ","type":"text"},{"code":"G_MENU_LINK_SECTION","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"G_MENU_LINK_SUBMENU","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Items in a "},{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represent active controls if they refer to"},{"text":" ","type":"text"},{"type":"text","text":"an action that can get activated when the user interacts with the"},{"type":"text","text":" "},{"type":"text","text":"menu item. The reference to the action is encoded by the string ID"},{"type":"text","text":" "},{"type":"text","text":"in the "},{"code":"G_MENU_ATTRIBUTE_ACTION","type":"codeVoice"},{"type":"text","text":" attribute. An action ID uniquely"},{"type":"text","text":" "},{"text":"identifies an action in an action group. Which action ","type":"text"},{"code":"group(s)","type":"codeVoice"},{"type":"text","text":" provide"},{"text":" ","type":"text"},{"text":"actions depends on the context in which the menu model is used.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"E.g. when the model is exported as the application menu of a"},{"type":"text","text":" "},{"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Application.html","type":"reference","isActive":true},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"actions can be application-wide or window-specific (and thus come from"},{"text":" ","type":"text"},{"text":"two different action groups). By convention, the application-wide actions","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have names that start with "},{"code":"app.","type":"codeVoice"},{"type":"text","text":", while the names of window-specific"},{"type":"text","text":" "},{"type":"text","text":"actions start with "},{"type":"codeVoice","code":"win."},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"While a wide variety of stateful actions is possible, the following"},{"type":"text","text":" "},{"type":"text","text":"is the minimum that is expected to be supported by all users of exported"},{"type":"text","text":" "},{"type":"text","text":"menu information:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"an action with no parameter type and no state"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"an action with no parameter type and boolean state"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"an action with string parameter type and string state"}]}]}],"type":"unorderedList"},{"text":"Stateless","anchor":"Stateless","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"A stateless action typically corresponds to an ordinary menu item."}],"type":"paragraph"},{"inlineContent":[{"text":"Selecting such a menu item will activate the action (with no parameter).","type":"text"}],"type":"paragraph"},{"text":"Boolean State","type":"heading","level":2,"anchor":"Boolean-State"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An action with a boolean state will most typically be used with a ‘toggle’"},{"type":"text","text":" "},{"text":"or ‘switch’ menu item. The state can be set directly, but activating the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"action (with no parameter) results in the state being toggled."}]},{"type":"paragraph","inlineContent":[{"text":"Selecting a toggle menu item will activate the action. The menu item should","type":"text"},{"text":" ","type":"text"},{"text":"be rendered as ‘checked’ when the state is true.","type":"text"}]},{"level":2,"text":"String Parameter and State","type":"heading","anchor":"String-Parameter-and-State"},{"type":"paragraph","inlineContent":[{"text":"Actions with string parameters and state will most typically be used to","type":"text"},{"type":"text","text":" "},{"text":"represent an enumerated choice over the items available for a group of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"radio menu items. Activating the action with a string parameter is"},{"text":" ","type":"text"},{"text":"equivalent to setting that parameter as the state.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Radio menu items, in addition to being associated with the action, will"},{"text":" ","type":"text"},{"text":"have a target value. Selecting that menu item will result in activation","type":"text"},{"type":"text","text":" "},{"text":"of the action with the target value as the parameter. The menu item should","type":"text"},{"type":"text","text":" "},{"text":"be rendered as ‘selected’ when the state of the action is equal to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"target value of the menu item."}]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","isActive":true,"type":"reference"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"text":"state it has) can influence the representation of the item.","type":"text"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","interfaceLanguage":"swift"},"kind":"symbol","topicSections":[{"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/isMutable","doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/menu_model_ptr-6egw9","doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/nItems","doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/parentInstance"],"title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/connect(signal:flags:data:destroyData:signalHandler:)","doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/connect(signal:flags:handler:)","doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/getItemAttributeValue(itemIndex:attribute:expectedType:)-68z92","doc:\/\/GIO\/docu