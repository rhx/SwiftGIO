{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Converter","doc:\/\/GIO\/documentation\/GIO\/Converter\/ConverterProtocol-Implementations"]]},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"convert"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"inbufSize"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"outbuf"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"outbufSize"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14ConverterFlagsV","kind":"typeIdentifier","text":"ConverterFlags"},{"kind":"text","text":", "},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier","text":"gsize"},{"text":">!, ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult","text":"GConverterResult"}],"extendedModule":"GIO","symbolKind":"method","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","externalID":"s:3GIO17ConverterProtocolPAAE7convert5inbuf0E4Size6outbuf0gF05flags9bytesRead0I7WrittenSo16GConverterResultaSvSg_SiANSiAA0B5FlagsVSpySuGSgARtKF::SYNTHESIZED::s:3GIO9ConverterC","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)"},"abstract":[{"text":"This is the main operation used when converting data. It is to be called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multiple times in a loop, and each time it will do some work, i.e."},{"text":" ","type":"text"},{"type":"text","text":"producing some output (in "},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"text":") or","type":"text"},{"text":" ","type":"text"},{"text":"both. If its not possible to do any work an error is returned.","type":"text"}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Converter\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"convert","kind":"identifier"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"outbuf","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV","kind":"typeIdentifier","text":"ConverterFlags"},{"text":", ","kind":"text"},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier","text":"gsize"},{"text":">!, ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"text":">!) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult","text":"GConverterResult"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Note that a single call may not consume all input (or any input at all)."},{"type":"text","text":" "},{"text":"Also a call may produce output even if given no input, due to state stored","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the converter producing output."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If any data was either produced or consumed, and then an error happens, then"},{"text":" ","type":"text"},{"type":"text","text":"only the successful conversion is reported and the error is returned on the"},{"type":"text","text":" "},{"text":"next call.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A full conversion loop involves calling this method repeatedly, each time"},{"text":" ","type":"text"},{"type":"text","text":"giving it new input and space output space. When there is no more input"},{"type":"text","text":" "},{"type":"text","text":"data after the data in "},{"code":"inbuf","type":"codeVoice"},{"type":"text","text":", the flag "},{"code":"inputAtEnd","type":"codeVoice"},{"type":"text","text":" must be set."},{"type":"text","text":" "},{"type":"text","text":"The loop will be (unless some error happens) returning "},{"type":"codeVoice","code":"converted"},{"type":"text","text":" "},{"text":"each time until all data is consumed and all output is produced, then","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"finished"},{"text":" is returned instead. Note, that ","type":"text"},{"type":"codeVoice","code":"finished"},{"text":" ","type":"text"},{"type":"text","text":"may be returned even if "},{"type":"codeVoice","code":"inputAtEnd"},{"text":" is not set, for instance","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in a decompression converter where the end of data is detectable from the"},{"type":"text","text":" "},{"text":"data (and there might even be other data after the end of the compressed data).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When some data has successfully been converted ","type":"text"},{"type":"codeVoice","code":"bytesRead"},{"text":" and is set to","type":"text"},{"type":"text","text":" "},{"text":"the number of bytes read from ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"text":", and ","type":"text"},{"code":"bytesWritten","type":"codeVoice"},{"text":" is set to indicate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"how many bytes was written to "},{"code":"outbuf","type":"codeVoice"},{"text":". If there are more data to output","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or consume (i.e. unless the "},{"type":"codeVoice","code":"inputAtEnd"},{"text":" is specified) then","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"converted"},{"text":" is returned, and if no more data is to be output","type":"text"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"finished"},{"type":"text","text":" is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is returned and "},{"code":"error","type":"codeVoice"},{"text":" is set accordingly.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Some errors need special handling:"}]},{"inlineContent":[{"type":"codeVoice","code":"noSpace"},{"text":" is returned if there is not enough space","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to write the resulting converted data, the application should"},{"text":" ","type":"text"},{"type":"text","text":"call the function again with a larger "},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":" to continue."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"partialInput"},{"text":" is returned if there is not enough","type":"text"},{"type":"text","text":" "},{"type":"text","text":"input to fully determine what the conversion should produce,"},{"type":"text","text":" "},{"text":"and the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"text":" flag is not set. This happens for","type":"text"},{"type":"text","text":" "},{"text":"example with an incomplete multibyte sequence when converting text,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or when a regexp matches up to the end of the input (and may match"},{"type":"text","text":" "},{"type":"text","text":"further input). It may also happen when "},{"type":"codeVoice","code":"inbufSize"},{"text":" is zero and","type":"text"},{"text":" ","type":"text"},{"text":"there is no more data to produce.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When this happens the application should read more input and then","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call the function again. If further input shows that there is no"},{"text":" ","type":"text"},{"type":"text","text":"more data call the function again with the same data but with"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" flag set. This may cause the conversion"},{"text":" ","type":"text"},{"text":"to finish as e.g. in the regexp match case (or, to fail again with","type":"text"},{"type":"text","text":" "},{"code":"partialInput","type":"codeVoice"},{"text":" in e.g. a charset conversion where the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"input is actually partial)."}]},{"inlineContent":[{"text":"After ","type":"text"},{"type":"codeVoice","code":"g_converter_convert()"},{"text":" has returned ","type":"text"},{"code":"finished","type":"codeVoice"},{"text":" the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"converter object is in an invalid state where its not allowed"},{"text":" ","type":"text"},{"text":"to call ","type":"text"},{"code":"g_converter_convert()","type":"codeVoice"},{"text":" anymore. At this time you can only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"free the object or call "},{"code":"g_converter_reset()","type":"codeVoice"},{"type":"text","text":" to reset it to the"},{"text":" ","type":"text"},{"text":"initial state.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the flag ","type":"text"},{"code":"flush","type":"codeVoice"},{"text":" is set then conversion is modified","type":"text"},{"type":"text","text":" "},{"text":"to try to write out all internal state to the output. The application","type":"text"},{"text":" ","type":"text"},{"text":"has to call the function multiple times with the flag set, and when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the available input has been consumed and all internal state has"},{"type":"text","text":" "},{"text":"been produced then ","type":"text"},{"type":"codeVoice","code":"flushed"},{"type":"text","text":" (or "},{"type":"codeVoice","code":"finished"},{"text":" if","type":"text"},{"type":"text","text":" "},{"text":"really at the end) is returned instead of ","type":"text"},{"code":"converted","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This is somewhat similar to what happens at the end of the input stream,"},{"type":"text","text":" "},{"text":"but done in the middle of the data.","type":"text"}]},{"inlineContent":[{"text":"This has different meanings for different conversions. For instance","type":"text"},{"type":"text","text":" "},{"text":"in a compression converter it would mean that we flush all the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"compression state into output such that if you uncompress the"},{"type":"text","text":" "},{"type":"text","text":"compressed data you get back all the input data. Doing this may"},{"type":"text","text":" "},{"text":"make the final file larger due to padding though. Another example","type":"text"},{"type":"text","text":" "},{"text":"is a regexp conversion, where if you at the end of the flushed data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have a match, but there is also a potential longer match. In the"},{"type":"text","text":" "},{"text":"non-flushed case we would ask for more input, but when flushing we","type":"text"},{"text":" ","type":"text"},{"text":"treat this as the end of input and do the match.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Flushing is not always possible (like if a charset converter flushes"},{"type":"text","text":" "},{"type":"text","text":"at a partial multibyte sequence). Converters are supposed to try"},{"type":"text","text":" "},{"type":"text","text":"to produce as much output as possible and then return an error"},{"type":"text","text":" "},{"text":"(typically ","type":"text"},{"code":"partialInput","type":"codeVoice"},{"type":"text","text":")."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/converter\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)"]}],"references":{"doc://GIO/documentation/GIO/Converter/ConverterProtocol-Implementations":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter\/ConverterProtocol-Implementations","url":"\/documentation\/gio\/converter\/converterprotocol-implementations","role":"collectionGroup","kind":"article","title":"ConverterProtocol Implementations"},"doc://GIO/documentation/GIO/Converter":{"kind":"symbol","type":"topic","title":"Converter","role":"symbol","abstract":[{"type":"codeVoice","code":"GConverter"},{"type":"text","text":" is an interface for streaming conversions."}],"url":"\/documentation\/gio\/converter","identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Converter","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Converter"}]},"doc://GIO/documentation/GIO/ConverterFlags":{"abstract":[{"type":"text","text":"Flags used when calling a "},{"type":"codeVoice","code":"g_converter_convert()"},{"text":".","type":"text"}],"title":"ConverterFlags","url":"\/documentation\/gio\/converterflags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConverterFlags"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","kind":"symbol","navigatorTitle":[{"text":"ConverterFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Converter/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)":{"type":"topic","kind":"symbol","url":"\/documentation\/gio\/converter\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","abstract":[{"type":"text","text":"This is the main operation used when converting data. It is to be called"},{"type":"text","text":" "},{"text":"multiple times in a loop, and each time it will do some work, i.e.","type":"text"},{"type":"text","text":" "},{"text":"producing some output (in ","type":"text"},{"code":"outbuf","type":"codeVoice"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":") or"},{"type":"text","text":" "},{"type":"text","text":"both. If its not possible to do any work an error is returned."}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"convert","kind":"identifier"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"outbuf"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14ConverterFlagsV","text":"ConverterFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"bytesRead"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"bytesWritten"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:@EA@GConverterResult","text":"GConverterResult","kind":"typeIdentifier"}]}}}