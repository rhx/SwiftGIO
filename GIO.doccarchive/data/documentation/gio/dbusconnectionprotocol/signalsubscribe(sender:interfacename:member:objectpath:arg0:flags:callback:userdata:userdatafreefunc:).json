"kind":"typeIdentifier"},{"text":">? = nil, ","kind":"text"},{"kind":"externalParam","text":"member"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">? = nil, ","kind":"text"},{"text":"objectPath","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">? = nil, "},{"text":"arg0","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">? = nil, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO15DBusSignalFlagsV","kind":"typeIdentifier","text":"DBusSignalFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusSignalFlags"},{"kind":"text","text":", "},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GDBusSignalCallback","text":"GDBusSignalCallback","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userDataFreeFunc"},{"text":": ","kind":"text"},{"text":"GDestroyNotify","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@GDestroyNotify"},{"kind":"text","text":"? = nil) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If "},{"code":"connection","type":"codeVoice"},{"text":" is not a message bus connection, ","type":"text"},{"type":"codeVoice","code":"sender"},{"type":"text","text":" must be"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"sender"},{"type":"text","text":" is a well-known name note that "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" is invoked with"},{"type":"text","text":" "},{"text":"the unique name for the owner of ","type":"text"},{"type":"codeVoice","code":"sender"},{"type":"text","text":", not the well-known name"},{"type":"text","text":" "},{"type":"text","text":"as one would expect. This is because the message bus rewrites the"},{"type":"text","text":" "},{"type":"text","text":"name. As such, to avoid certain race conditions, users should be"},{"type":"text","text":" "},{"type":"text","text":"tracking the name owner of the well-known name and use that when"},{"type":"text","text":" "},{"text":"processing the received signal.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If one of ","type":"text"},{"code":"matchArg0Namespace","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"matchArg0Path"},{"type":"text","text":" are given, "},{"code":"arg0","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"interpreted as part of a namespace or path.  The first argument"},{"type":"text","text":" "},{"text":"of a signal is matched against that part as specified by D-Bus.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"userDataFreeFunc","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", it will be called (in the"},{"type":"text","text":" "},{"text":"thread-default main context of the thread you are calling this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method from) at some point after "},{"type":"codeVoice","code":"userData"},{"text":" is no longer","type":"text"},{"type":"text","text":" "},{"text":"needed. (It is not guaranteed to be called synchronously when the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"signal is unsubscribed from, and may be called after "},{"type":"codeVoice","code":"connection"},{"text":" ","type":"text"},{"type":"text","text":"has been destroyed.)"}]},{"inlineContent":[{"type":"text","text":"As "},{"type":"codeVoice","code":"callback"},{"text":" is potentially invoked in a different thread from where it’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"emitted, it’s possible for this to happen after"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_dbus_connection_signal_unsubscribe()"},{"type":"text","text":" has been called in another thread."},{"type":"text","text":" "},{"type":"text","text":"Due to this, "},{"type":"codeVoice","code":"userData"},{"text":" should have a strong reference which is freed with","type":"text"},{"type":"text","text":" "},{"code":"userDataFreeFunc","type":"codeVoice"},{"text":", rather than pointing to data whose lifecycle is tied","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to the signal subscription. For example, if a [Object](\/\/documentation\/gobject\/object is used to store the"},{"text":" ","type":"text"},{"text":"subscription ID from ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_signal_subscribe()"},{"text":", a strong reference","type":"text"},{"type":"text","text":" "},{"text":"to that [Object](\/\/documentation\/gobject\/object must be passed to ","type":"text"},{"code":"userData","type":"codeVoice"},{"type":"text","text":", and "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" passed to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"userDataFreeFunc"},{"text":". You are responsible for breaking the resulting","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference count cycle by explicitly unsubscribing from the signal when"},{"type":"text","text":" "},{"type":"text","text":"dropping the last external reference to the [Object](\/\/documentation\/gobject\/object. Alternatively, a weak"},{"text":" ","type":"text"},{"text":"reference may be used.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It is guaranteed that if you unsubscribe from a signal using","type":"text"},{"text":" ","type":"text"},{"code":"g_dbus_connection_signal_unsubscribe()","type":"codeVoice"},{"type":"text","text":" from the same thread which made the"},{"type":"text","text":" "},{"type":"text","text":"corresponding "},{"type":"codeVoice","code":"g_dbus_connection_signal_subscribe()"},{"text":" call, ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will not"},{"text":" ","type":"text"},{"type":"text","text":"be invoked after "},{"type":"codeVoice","code":"g_dbus_connection_signal_unsubscribe()"},{"text":" returns.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The returned subscription identifier is an opaque value which is guaranteed"},{"type":"text","text":" "},{"text":"to never be zero.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This function can never fail.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"text":"Subscribes to signals on ","type":"text"},{"code":"connection","type":"codeVoice"},{"type":"text","text":" and invokes "},{"type":"codeVoice","code":"callback"},{"text":" whenever","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the signal is received. Note that "},{"type":"codeVoice","code":"callback"},{"text":" will be invoked in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"thread-default main context (see [method"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"type":"text","text":"])"},{"text":" ","type":"text"},{"text":"of the thread you are calling this method from.","type":"text"}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/dbusconnectionprotocol\/signalsubscribe(sender:interfacename:member:objectpath:arg0:flags:callback:userdata:userdatafreefunc:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusConnectionProtocol/signalSubscribe(sender:interfaceName:member:objectPath:arg0:flags:callback:userData:userDataFreeFunc:)":{"abstract":[{"text":"Subscribes to signals on ","type":"text"},{"code":"connection","type":"codeVoice"},{"type":"text","text":" and invokes "},{"type":"codeVoice","code":"callback"},{"text":" whenever","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the signal is received. Note that "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be invoked in the"},{"type":"text","text":" "},{"type":"text","text":"thread-default main context (see [method"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"type":"text","text":"])"},{"type":"text","text":" "},{"text":"of the thread you are calling this method from.","type":"text"}],"role":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"signalSubscribe","kind":"identifier"},{"text":"(","kind":"text"},{"text":"sender","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">?, "