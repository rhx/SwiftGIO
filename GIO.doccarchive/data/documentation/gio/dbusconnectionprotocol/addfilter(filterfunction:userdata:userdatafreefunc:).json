oc://GIO/documentation/GIO/DBusConnectionProtocol":{"title":"DBusConnectionProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionProtocol","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"code":"GDBusConnection","type":"codeVoice"},{"type":"text","text":" type is used for D-Bus connections to remote"},{"text":" ","type":"text"},{"type":"text","text":"peers such as a message buses."}],"url":"\/documentation\/gio\/dbusconnectionprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusConnectionProtocol"}],"kind":"symbol","navigatorTitle":[{"text":"DBusConnectionProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}