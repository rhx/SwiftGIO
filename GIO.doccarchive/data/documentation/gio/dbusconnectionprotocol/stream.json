n accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/DBusConnectionProtocol":{"title":"DBusConnectionProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionProtocol","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"code":"GDBusConnection","type":"codeVoice"},{"type":"text","text":" type is used for D-Bus connections to remote"},{"text":" ","type":"text"},{"type":"text","text":"peers such as a message buses."}],"url":"\/documentation\/gio\/dbusconnectionprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusConnectionProtocol"}],"kind":"symbol","navigatorTitle":[{"text":"DBusConnectionProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO/IOStreamRef":{"role":"symbol","abstract":[{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"text":" ","type":"text"},{"text":"but they share some common resources and state. For instance, for","type":"text"},{"text":" ","type":"text"},{"text":"seekable streams, both streams may use the same position.","type":"text"}],"url":"\/documentation\/gio\/iostreamref","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStreamRef"}],"title":"IOStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef","navigatorTitle":[{"text":"IOStreamRef","kind":"identifier"}],"type":"topic"},"doc://GIO/documentation/GIO/SocketListener":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"topic","url":"\/documentation\/gio\/socketlistener","kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GSocketListener","type":"codeVoice"},{"text":" is an object that keeps track of a set","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of server sockets and helps you accept sockets from any of the"},{"text":" ","type":"text"},{"type":"text","text":"socket, either sync or async."}],"title":"SocketListener","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketListener"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketListener"}]},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClient"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","abstract":[{"type":"codeVoice","code":"GSocketClient"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"title":"SocketClient","role":"symbol","url":"\/documentation\/gio\/socketclient","navigatorTitle":[{"kind":"identifier","text":"SocketClient"}]},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"}}}