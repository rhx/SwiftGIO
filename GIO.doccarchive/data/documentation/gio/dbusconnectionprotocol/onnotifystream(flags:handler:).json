text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::stream","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"type":"aside"}],"