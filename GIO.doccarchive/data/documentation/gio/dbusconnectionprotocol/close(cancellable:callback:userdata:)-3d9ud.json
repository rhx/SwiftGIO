{"kind":"symbol","abstract":[{"type":"text","text":"Closes "},{"code":"connection","type":"codeVoice"},{"type":"text","text":". Note that this never causes the process to"},{"type":"text","text":" "},{"type":"text","text":"exit (this might only happen if the other end of a shared message"},{"text":" ","type":"text"},{"text":"bus connection disconnects, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection"},{"type":"text","text":")."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusConnectionProtocol"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"title":"close(cancellable:callback:userData:)","modules":[{"name":"GIO"}],"role":"symbol","symbolKind":"method","externalID":"s:3GIO22DBusConnectionProtocolPAAE5close11cancellable8callback8userDatayAA14CancellableRefVSg_ySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgAStF","roleHeading":"Instance Method","extendedModule":"GIO"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionProtocol\/close(cancellable:callback:userData:)-3d9ud"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"