ndler:)"},{"text":" ","type":"text"},{"type":"text","text":"signal is emitted in the thread-default main context"},{"type":"text","text":" "},{"text":"(see [method","type":"text"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"type":"text","text":"])"},{"text":" ","type":"text"},{"type":"text","text":"of the thread that "},{"code":"connection","type":"codeVoice"},{"type":"text","text":" was constructed in."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is an asynchronous method. When the operation is finished,"},{"type":"text","text":" "},{"type":"codeVoice","code":"callback"},{"text":" will be invoked in the thread-default main context","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(see [method"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"text":"])","type":"text"},{"type":"text","text":" "},{"text":"of the thread you are calling this method from. You can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then call "},{"type":"codeVoice","code":"g_dbus_connection_close_finish()"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"type":"text","text":"operation. See "},{"type":"codeVoice","code":"g_dbus_connection_close_sync()"},{"type":"text","text":" for the synchronous"},{"type":"text","text":" "},{"type":"text","text":"version."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/dbusconnectionprotocol\/close(cancellable:callback:userdata:)-3d9ud"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/DBusConnectionProtocol/close(cancellable:callback:userData:)-3d9ud":{"url":"\/documentation\/gio\/dbusconnectionprotocol\/close(cancellable:callback:userdata:)-3d9ud","kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionProtocol\/close(cancellable:callback:userData:)-3d9ud","abstract":[{"type":"text","text":"Closes "},{"type":"codeVoi