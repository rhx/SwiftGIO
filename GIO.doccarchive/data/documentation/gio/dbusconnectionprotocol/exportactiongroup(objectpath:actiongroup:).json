_group"},{"type":"text","text":"] with the return value of"},{"type":"text","text":" "},{"text":"this function.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The thread default main context is taken at the time of this call."},{"type":"text","text":" "},{"text":"All incoming action activations and state change requests are","type":"text"},{"text":" ","type":"text"},{"text":"reported from this context.  Any changes on the action group that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"cause it to emit signals must also come from this same context."},{"text":" ","type":"text"},{"type":"text","text":"Since incoming action activations and state change requests are"},{"type":"text","text":" "},{"type":"text","text":"rather likely to cause changes on the action group, this effectively"},{"text":" ","type":"text"},{"type":"text","text":"limits a given action group to being exported from only one main"},{"text":" ","type":"text"},{"text":"context.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/DBusConnectionProtocol":{"title":"DBusConnectionProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnectionProtocol","role":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"code":"GDBusConnection","type":"codeVoice"},{"type":"text","text":" type is used for D-Bus connections to remote"},{"text":" ","type":"text"},{"type":"text","text":"peers such as a message buses."}],"url":"\/documentation\/gio\/dbusconnectionprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusConnectionProtocol"}],"kind":"symbol","navigatorTitle":[{"text":"DBusConnectionProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO/DBusConnectionProtocol/exportActionGroup(objectPath:actionGroup:)":{"abstract":[{"text":"Exports ","type":"text"},{"code":"actionGroup","type":"codeVoice"},{"text":" on ",