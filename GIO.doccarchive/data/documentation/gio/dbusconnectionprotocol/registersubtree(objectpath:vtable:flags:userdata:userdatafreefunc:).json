umentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusConnectionProtocol"]]},"sections":[],"abstract":[{"type":"text","text":"Registers a whole subtree of dynamic objects."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"registerSubtree","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"DBusSubtreeVTableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"objectPath"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!, "},{"text":"vtable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"DBusSubtreeVTableT"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusSubtreeFlags","kind":"typeIdentifier","text":"DBusSubtreeFlags","preciseIdentifier":"s:3GIO16DBusSubtreeFlagsV"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil, ","kind":"text"},{"text":"userDataFreeFunc","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@GDestroyNotify","text":"GDestroyNotify","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"DBusSubtreeVTableT"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO25DBusSubtreeVTableProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusSubtreeVTableProtocol","kind":"typeIdentifier","text":"DBusSubtreeVTableProtocol"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"enumerate"},{"type":"text","text":" and "},{"type":"codeVoice","code":"introspection"},{"type":"text","text":" functions in "},{"code":"vtable","type":"codeVoice"},{"type":"text","text":" are used to"},{"type":"text","text":" "},{"type":"text","text":"convey, to remote callers, what nodes exist in the subtree rooted"},{"type":"text","text":" "},{"type":"text","text":"by "},{"type":"codeVoice","code":"objectPath"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"When handling remote calls into any node in the subtree, first the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"enumerate"},{"type":"text","text":" function is used to check if the node exists. If the node exists"},{"text":" ","type":"text"},{"type":"text","text":"or the "},{"code":"dispatchToUnenumeratedNodes","type":"codeVoice"},{"type":"text","text":" flag is set"},{"type":"text","text":" "},{"type":"text","text":"the "},{"code":"introspection","type":"codeVoice"},{"type":"text","text":" function is used to check if the node supports the"},{"text":" ","type":"text"},{"type":"text","text":"requested method. If so, the "},{"type":"codeVoice","code":"dispatch"},{"text":" function is used to determine","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"where to dispatch the call. The collected "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","type":"reference","isActive":true},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"gpointer"},{"text":" will be used to call into the interface vtable for processing","type":"text"},{"type":"text","text":" "},{"text":"the request.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"All calls into user-provided code will be invoked in the thread-default","type":"text"},{"type":"text","text":" "},{"text":"main context (see [method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"text":"])","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the thread you are calling this method from."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If an existing subtree is already registered at "},{"type":"codeVoice","code":"objectPath"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then "},{"type":"codeVoice","code":"error"},{"text":" is set to ","type":"text"},{"code":"exists","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"Note that it is valid to register regular objects (using","type":"text"},{"text":" ","type":"text"},{"code":"g_dbus_connection_register_object()","type":"codeVoice"},{"text":") in a subtree registered with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_dbus_connection_register_subtree()"},{"text":" - if so, the subtree handler","type":"text"},{"text":" ","type":"text"},{"text":"is tried as the last resort. One way to think about a subtree","type":"text"},{"type":"text","text":" "},{"text":"handler is to consider it a fallback handler for object paths not","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"registered via "},{"type":"codeVoice","code":"g_dbus_connection_register_object()"},{"type":"text","text":" or other bindings."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that "},{"code":"vtable","type":"codeVoice"},{"text":" will be copied so you cannot change it after","type":"text"},{"text":" ","type":"text"},{"text":"registration.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See this ","type":"text"},{"isActive":true,"type":"reference","identifier":"#class@Gio.DBusConnection#an-example-for-exporting-a-subtree"},{"type":"text","text":" "},{"text":"for an example of how to use this method.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusconnectionprotocol\/registersubtree(objectpath:vtable:flags:userdata:userdatafreefunc:)"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","references":{"#class@Gio.DBusConnection#an-example-for-exporting-a-subtree":{"titleInlineContent":[{"type":"text","text":"server"}],"url":"#class@Gio.DBusConnection#an-example-for-exporting-a-subtree","type":"link","title":"server","identifier":"#class@Gio.DBusConnection#an-example-for-exporting-a-subtree"},"doc://GIO/documentation/GIO/DBusSubtreeFlags":{"url":"\/documentation\/gio\/dbussubtreeflags","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusSubtreeFlags"}],"kind":"symbol","navigatorTitle":[{"text":"DBusSubtreeFlags","kind":"identifier"}],"abstract":[{"text":"Flags passed to ","type":"text"},{"code":"g_dbus_connection_register_subtree()","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","title":"DBusSubtreeFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusSubtreeFlags","role":"symbol"},"doc://GIO/documentation/GIO/DBusConnectionProtocol/registerSubtree(objectPath:vtable:flags:userData:userDataFreeFunc:)":{"abstract":[{"type":"text","text":"Registers a whole subtree of dynamic objects."}],"role":"symbol","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"registerSubtree","kind":"identifier"},{"kind":"text","text":"<"},{"text":"DBusSubtreeVTableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"objectPath"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeId