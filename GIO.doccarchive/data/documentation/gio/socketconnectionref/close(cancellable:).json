{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef\/close(cancellable:)"},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef","doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef\/IOStreamProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"text":" ","type":"text"},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"type":"text","text":" "},{"type":"text","text":"closed."}],"variants":[{"paths":["\/documentation\/gio\/socketconnectionref\/close(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"roleHeading":"Instance Method","role":"symbol","title":"close(cancellable:)","extendedModule":"GIO","externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO19SocketConnectionRefV","modules":[{"name":"GIO"}],"symbolKind":"method"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return"},{"type":"text","text":" "},{"code":"closed","type":"codeVoice"},{"type":"text","text":". Closing a stream multiple times will not"},{"type":"text","text":" "},{"type":"text","text":"return an error."}]},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in the stream."}]},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"text":" ","type":"text"},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"descriptor) open after the stream is closed. See the documentation for"},{"type":"text","text":" "},{"type":"text","text":"the individual stream for details."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On failure the first error that happened will be reported, but the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"close operation will finish as much as possible. A stream that failed"},{"text":" ","type":"text"},{"type":"text","text":"to close will still return "},{"code":"closed","type":"codeVoice"},{"text":" for all operations.","type":"text"},{"type":"text","text":" "},{"text":"Still, it is important to check and report the error to the user,","type":"text"},{"type":"text","text":" "},{"text":"otherwise there might be a loss of data as all data might not be written.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not NULL, then the operation can be cancelled by","type":"text"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default implementation of this method just calls close on the"},{"type":"text","text":" "},{"type":"text","text":"individual input\/output streams."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO/SocketConnectionRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef","type":"topic","url":"\/documentation\/gio\/socketconnectionref","kind":"symbol","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"text":" is a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","type":"reference","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be created either by [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"type":"text","text":"or by [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnectionRef","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketConnectionRef"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SocketConnectionRef"}]},"doc://GIO/documentation/GIO/SocketListener":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"topic","url":"\/documentation\/gio\/socketlistener","kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GSocketListener","type":"codeVoice"},{"text":" is an object that keeps track of a set","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of server sockets and helps you accept sockets from any of the"},{"text":" ","type":"text"},{"type":"text","text":"socket, either sync or async."}],"title":"SocketListener","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketListener"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketListener"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClient"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","abstract":[{"type":"codeVoice","code":"GSocketClient"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"title":"SocketClient","role":"symbol","url":"\/documentation\/gio\/socketclient","navigatorTitle":[{"kind":"identifier","text":"SocketClient"}]},"doc://GIO/documentation/GIO/SocketConnectionRef/IOStreamProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef\/IOStreamProtocol-Implementations","title":"IOStreamProtocol Implementations","abstract":[],"kind":"article","url":"\/documentation\/gio\/socketconnectionref\/iostreamprotocol-implementations","type":"topic","role":"collectionGroup"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/SocketConnectionRef/close(cancellable:)":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef\/close(cancellable:)","kind":"symbol","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"type":"text","text":" "},{"text":"close the individual input and output streams, if they are not already","type":"text"},{"type":"text","text":" "},{"text":"closed.","type":"text"}],"title":"close(cancellable:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/gio\/socketconnectionref\/close(cancellable:)"}}}