ol","role":"symbol","url":"\/documentation\/gio\/menumodelprotocol","navigatorTitle":[{"text":"MenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}