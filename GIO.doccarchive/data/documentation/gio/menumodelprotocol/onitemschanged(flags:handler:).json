{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol"]]},"abstract":[{"text":"Emitted when a change has occurred to the menu.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onItemsChanged"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","preciseIdentifier":"s:3GIO12MenuModelRefV","text":"MenuModelRef"},{"kind":"text","text":", "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"languages":["swift"]}]},{"parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"code":"itemsChanged","type":"codeVoice"},{"text":" signal is emitted","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"The only changes that can occur to a menu is that items are removed"},{"type":"text","text":" "},{"type":"text","text":"or added.  Items may not change (except by being removed and added"},{"type":"text","text":" "},{"text":"back in the same location).  This signal is capable of describing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"both of those changes (at the same time)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The signal means that starting at the index ","type":"text"},{"code":"position","type":"codeVoice"},{"type":"text","text":", "},{"code":"removed","type":"codeVoice"},{"text":" ","type":"text"},{"text":"items were removed and ","type":"text"},{"type":"codeVoice","code":"added"},{"type":"text","text":" items were added in their place.  If"},{"type":"text","text":" "},{"type":"codeVoice","code":"removed"},{"text":" is zero then only items were added.  If ","type":"text"},{"code":"added","type":"codeVoice"},{"text":" is zero","type":"text"},{"type":"text","text":" "},{"text":"then only items were removed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"As an example, if the menu contains items a, b, c, d (in that"},{"text":" ","type":"text"},{"type":"text","text":"order) and the signal (2, 1, 3) occurs then the new composition of"},{"type":"text","text":" "},{"text":"the menu will be a, b, _, _, _, d (with each _ representing some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"new item)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Signal handlers may query the model (particularly the added items)"},{"text":" ","type":"text"},{"text":"and expect to see the results of the modification that is being","type":"text"},{"text":" ","type":"text"},{"text":"reported.  The signal is emitted after the modification.","type":"text"}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"items-changed","type":"codeVoice"},{"text":" signal","type":"text"}]}],"name":"Note","type":"aside"}]}],"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/onItemsChanged(flags:handler:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menumodelprotocol\/onitemschanged(flags:handler:)"]}],"metadata":{"modules":[{"name":"GIO"}],"externalID":"s:3GIO17MenuModelProtocolPAAE14onItemsChanged5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_S3itctF","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onItemsChanged"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO12MenuModelRefV","text":"MenuModelRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"extendedModule":"GIO","roleHeading":"Instance Method","role":"symbol","title":"onItemsChanged(flags:handler:)"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},"doc://GIO/documentation/GIO/MenuModelProtocol/onItemsChanged(flags:handler:)":{"role":"symbol","url":"\/documentation\/gio\/menumodelprotocol\/onitemschanged(flags:handler:)","type":"topic","kind":"symbol","title":"onItemsChanged(flags:handler:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol\/onItemsChanged(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onItemsChanged","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO12MenuModelRefV","text":"MenuModelRef"},{"text":", ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"abstract":[{"text":"Emitted when a change has occurred to the menu.","type":"text"}]},"doc://GIO/documentation/GIO/MenuModelProtocol":{"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/menumodelprotocol","navigatorTitle":[{"text":"MenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]}}}