{"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusobjectmanagerclientref\/onnotifygetproxytypefunc(flags:handler:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef\/onNotifyGetProxyTypeFunc(flags:handler:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyGetProxyTypeFunc","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","text":"DBusObjectManagerClientRef","preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"role":"symbol","symbolKind":"method","roleHeading":"Instance Method","externalID":"s:3GIO31DBusObjectManagerClientProtocolPAAE24onNotifyGetProxyTypeFunc5flags7handlerSi04GLibC012ConnectFlagsV_yAA0bcdE3RefV_AG09ParamSpecR0VtctF::SYNTHESIZED::s:3GIO26DBusObjectManagerClientRefV","title":"onNotifyGetProxyTypeFunc(flags:handler:)","extendedModule":"GIO"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyGetProxyTypeFunc","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV","text":"DBusObjectManagerClientRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"text":" ","type":"text"},{"text":"Run the given callback whenever the ","type":"text"},{"code":"notifyGetProxyTypeFunc","type":"codeVoice"},{"text":" signal is emitted","type":"text"}],"type":"paragraph"}],"name":"handler"}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"text":" ","type":"text"},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"text":" call, like this:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"notify::get-proxy-type-func","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"type":"aside"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef\/DBusObjectManagerClientProtocol-Implementations"]]},"references":{"#class@GObject.ParamSpec#parameter-names":{"title":"canonical parameter names","titleInlineContent":[{"text":"canonical parameter names","type":"text"}],"url":"#class@GObject.ParamSpec#parameter-names","identifier":"#class@GObject.ParamSpec#parameter-names","type":"link"},"doc://GIO/documentation/GIO/DBusObjectManagerClientRef/DBusObjectManagerClientProtocol-Implementations":{"url":"\/documentation\/gio\/dbusobjectmanagerclientref\/dbusobjectmanagerclientprotocol-implementations","abstract":[],"title":"DBusObjectManagerClientProtocol Implementations","role":"collectionGroup","kind":"article","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef\/DBusObjectManagerClientProtocol-Implementations"},"doc://GIO/documentation/GIO/DBusObjectManagerClientRef":{"abstract":[{"code":"GDBusObjectManagerClient","type":"codeVoice"},{"text":" is used to create, monitor and delete object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"proxies for remote objects exported by a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","isActive":true,"type":"reference"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(or any code implementing the","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectma