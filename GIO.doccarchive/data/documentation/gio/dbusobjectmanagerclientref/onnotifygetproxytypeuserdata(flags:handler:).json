{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef","doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef\/DBusObjectManagerClientProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyGetProxyTypeUserData","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":" = ConnectFlags(0), "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"text":"DBusObjectManagerClientRef","preciseIdentifier":"s:3GIO26DBusObjectManagerClientRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier","text":"ParamSpecRef"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}],"name":"flags"},{"name":"handler","content":[{"inlineContent":[{"text":"The signal handler to call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyGetProxyTypeUserData"},{"text":" signal is emitted","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing","syntax":"C"},{"in