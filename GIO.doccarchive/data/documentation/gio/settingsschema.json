{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingsschema"]}],"kind":"symbol","abstract":[{"type":"text","text":"The [struct"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSource","isActive":true},{"type":"text","text":"] and "},{"code":"GSettingsSchema","type":"codeVoice"},{"type":"text","text":" APIs provide a"},{"text":" ","type":"text"},{"type":"text","text":"mechanism for advanced control over the loading of schemas and a"},{"text":" ","type":"text"},{"text":"mechanism for introspecting their content.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchema","interfaceLanguage":"swift"},"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SettingsSchema","kind":"identifier"}],"title":"SettingsSchema","externalID":"s:3GIO14SettingsSchemaC","symbolKind":"class","roleHeading":"Class","navigatorTitle":[{"text":"SettingsSchema","kind":"identifier"}],"role":"symbol","modules":[{"name":"GIO"}]},"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(_:)-2rvty","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(_:)-34bw6","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(_:)-45mn9","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(_:)-coda","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(_:)-hcfd","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(raw:)-14twf","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(raw:)-5i4dg","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(retainingRaw:)-5wd6h","doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/init(retainingRaw:)-zx05"],"generated":true},{"generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/ptr"],"title":"Instance Properties"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/SettingsSchemaProtocol-Implementations"],"title":"Default Implementations","generated":true,"anchor":"Default-Implementations"}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaProtocol"],"title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchema"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Plugin loading systems that wish to provide plugins a way to access"},{"text":" ","type":"text"},{"type":"text","text":"settings face the problem of how to make the schemas for these"},{"type":"text","text":" "},{"type":"text","text":"settings visible to GSettings.  Typically, a plugin will want to ship"},{"type":"text","text":" "},{"text":"the schema along with itself and it won’t be installed into the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"standard system directories for schemas."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[struct"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSource"},{"type":"text","text":"] provides a mechanism for dealing with this"},{"text":" ","type":"text"},{"type":"text","text":"by allowing the creation of a new ‘schema source’ from which schemas can"},{"type":"text","text":" "},{"type":"text","text":"be acquired.  This schema source can then become part of the metadata"},{"type":"text","text":" "},{"text":"associated with the plugin and queried whenever the plugin requires","type":"text"},{"type":"text","text":" "},{"type":"text","text":"access to some settings."}]},{"type":"paragraph","inlineContent":[{"text":"Consider the following example:","type":"text"}]},{"type":"codeListing","code":["typedef struct","{","   …","   GSettingsSchemaSource *schema_source;","   …","} Plugin;","","Plugin *","initialise_plugin (const gchar *dir)","{","  Plugin *plugin;","","  …","","  plugin->schema_source =","    g_settings_schema_source_new_from_directory (dir,","      g_settings_schema_source_get_default (), FALSE, NULL);","","  …","","  return plugin;","}","","…","","GSettings *","plugin_get_settings (Plugin      *plugin,","                     const gchar *schema_id)","{","  GSettingsSchema *schema;","","  if (schema_id == NULL)","    schema_id = plugin->identifier;","","  schema = g_settings_schema_source_lookup (plugin->schema_source,","                                            schema_id, FALSE);","","  if (schema == NULL)","    {","      … disable the plugin or abort, etc …","    }","","  return g_settings_new_full (schema, NULL, NULL);","}"],"syntax":"c"},{"inlineContent":[{"text":"The code above shows how hooks should be added to the code that","type":"text"},{"text":" ","type":"text"},{"text":"initialises (or enables) the plugin to create the schema source and","type":"text"},{"type":"text","text":" "},{"text":"how an API can be added to the plugin system to provide a convenient","type":"text"},{"type":"text","text":" "},{"type":"text","text":"way for the plugin to access its settings, using the schemas that it"},{"text":" ","type":"text"},{"type":"text","text":"ships."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"From the standpoint of the plugin, it would need to ensure that it","type":"text"},{"type":"text","text":" "},{"text":"ships a gschemas.compiled file as part of itself, and then simply do","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the following:"}]},{"syntax":"c","code":["{","  GSettings *settings;","  gint some_value;","","  settings = plugin_get_settings (self, NULL);","  some_value = g_settings_get_int (settings, \"some-value\");","  …","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It’s also possible that the plugin system expects the schema source"},{"type":"text","text":" "},{"text":"files (ie: ","type":"text"},{"code":".gschema.xml","type":"codeVoice"},{"text":" files) instead of a ","type":"text"},{"type":"codeVoice","code":"gschemas.compiled"},{"text":" file.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"In that case, the plugin loading system must compile the schemas for"},{"type":"text","text":" "},{"text":"itself before attempting to create the settings source.","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchema","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GSettingsSchema","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaProtocol","type":"reference","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchema"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GSettingsSchema","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchema","type":"reference","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GSettingsSchema"},{"text":" instance.","type":"text"}],"type":"paragraph"}]}]}],"references":{"doc://GIO/documentation/GIO/SettingsSchemaProtocol/settings_schema_ptr-9ce3j":{"required":true,"title":"settings_schema_ptr","defaultImplementations":1,"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"settings_schema_ptr","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"GSettingsSchema","kind":"typeIdentifier"},{"text":">!","kind":"text"}],"url":"\/documentation\/gio\/settingsschemaprotocol\/settings_schema_ptr-9ce3j","abstract":[{"text":"Typed pointer to the underlying ","type":"text"},{"type":"codeVoice","code":"GSettingsSchema"},{"type":"text","text":" instance."}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaProtocol\/settings_schema_ptr-9ce3j"},"doc://GIO/documentation/GIO/SettingsSchema/ptr":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchema\/ptr","url":"\/documentation\/gio\/settingsschema\/ptr","title":"ptr","abstract":[{"type":"text","text":"Untyped pointer to the underlying "},{"code":"GSettingsSchema","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"For type-safe access, use the generated, typed pointer "