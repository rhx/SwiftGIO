{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusSignalName"]]},"abstract":[{"type":"text","text":"Emitted when a D-Bus peer is trying to change the debug settings and used"},{"text":" ","type":"text"},{"type":"text","text":"to determine if that is authorized."}],"metadata":{"roleHeading":"Case","role":"symbol","modules":[{"name":"GIO"}],"title":"DebugControllerDBusSignalName.authorize","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"authorize","kind":"identifier"}],"externalID":"s:3GIO29DebugControllerDBusSignalNameO9authorizeyA2CmF","symbolKind":"case"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"authorize"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This signal is emitted in a dedicated worker thread, so handlers are","type":"text"},{"text":" ","type":"text"},{"text":"allowed to perform blocking I\/O. This means that, for example, it is","type":"text"},{"type":"text","text":" "},{"text":"appropriate to call ","type":"text"},{"code":"polkit_authority_check_authorization_sync()","type":"codeVoice"},{"text":" to check","type":"text"},{"type":"text","text":" "},{"type":"text","text":"authorization using polkit."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned then no further handlers are run and the request to"},{"type":"text","text":" "},{"text":"change the debug settings is rejected.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Otherwise, if "},{"type":"codeVoice","code":"true"},{"type":"text","text":" is returned, signal emission continues. If no handlers"},{"type":"text","text":" "},{"type":"text","text":"return "},{"code":"false","type":"codeVoice"},{"text":", then the debug settings are allowed to be changed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Signal handlers must not modify "},{"type":"codeVoice","code":"invocation"},{"type":"text","text":", or cause it to return a value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default class handler just returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/debugcontrollerdbussignalname\/authorize"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusSignalName\/authorize","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"references":{"doc://GIO/documentation/GIO/DebugControllerDBusSignalName":{"title":"DebugControllerDBusSignalName","type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusSignalName","abstract":[],"url":"\/documentation\/gio\/debugcontrollerdbussignalname","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DebugControllerDBusSignalName","kind":"identifier"}],"navigatorTitle":[{"text":"DebugControllerDBusSignalName","kind":"identifier"}]},"doc://GIO/documentation/GIO/DebugControllerDBusSignalName/authorize":{"abstract":[{"type":"text","text":"Emitted when a D-Bus peer is trying to change the debug settings and used"},{"type":"text","text":" "},{"type":"text","text":"to determine if that is authorized."}],"kind":"symbol","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"authorize","kind":"identifier"}],"type":"topic","url":"\/documentation\/gio\/debugcontrollerdbussignalname\/authorize","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusSignalName\/authorize","title":"DebugController