{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef","doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef\/InitableProtocol-Implementations"]]},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"extendedModule":"GIO","symbolKind":"method","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","title":"init_(cancellable:)","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO19CharsetConverterRefV"},"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef\/init_(cancellable:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_initable_new()"},{"type":"text","text":" should typically be used instead."}]},{"type":"paragraph","inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"construction, either with this function or "},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"type":"text","text":" "},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"text":" ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"type":"text","text":" "},{"code":"notSupported","type":"codeVoice"},{"text":" will be returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the object is not initialized, or initialization returns with an","type":"text"},{"type":"text","text":" "},{"text":"error, then all operations on the object except ","type":"text"},{"code":"g_object_ref()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"text":" ","type":"text"},{"text":"behaviour. See the ","type":"text"},{"type":"reference","identifier":"#iface@Gio.Initable#description","isActive":true},{"type":"text","text":" for more details."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"text":" can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"type":"text","text":" "},{"type":"text","text":"supporting this. Generally, a class’ implementation of "},{"code":"init()","type":"codeVoice"},{"text":" can assume","type":"text"},{"text":" ","type":"text"},{"text":"(and assert) that it will only be called once. Previously, this documentation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended all "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"text":" implementations should be idempotent; that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}]},{"type":"paragraph","inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"text":" ","type":"text"},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"text":" ","type":"text"},{"type":"text","text":"the object; further calls return the result of the first call."}]},{"inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"text":" ","type":"text"},{"text":"it is designed to be used via the singleton pattern, with a","type":"text"},{"text":" ","type":"text"},{"code":"GObjectClass.constructor","type":"codeVoice"},{"text":" that sometimes returns an existing instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"In this pattern, a caller would expect to be able to call "},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"type":"text","text":"on the result of "},{"type":"codeVoice","code":"g_object_new()"},{"type":"text","text":", regardless of whether it is in fact a new"},{"type":"text","text":" "},{"text":"instance.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/charsetconverterref\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"#iface@Gio.Initable#description":{"identifier":"#iface@Gio.Initable#description","title":"description","titleInlineContent":[{"text":"description","type":"text"}],"url":"#iface@Gio.Initable#description","type":"link"},"doc://GIO/documentation/GIO/CharsetConverterRef/init_(cancellable:)":{"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef\/init_(cancellable:)","role":"symbol","type":"topic","title":"init_(cancellable:)","url":"\/documentation\/gio\/charsetconverterref\/init_(cancellable:)"},"doc://GIO/documentation/GIO/CharsetConverterRef/InitableProtocol-Implementations":{"type":"topic","kind":"article","url":"\/documentation\/gio\/charsetconverterref\/initableprotocol-implementations","title":"InitableProtocol Implementations","abstract":[],"role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef\/InitableProtocol-Implementations"},"doc://GIO/documentation/GIO/Converter":{"kind":"symbol","type":"topic","title":"Converter","role":"symbol","abstract":[{"type":"codeVoice","code":"GConverter"},{"type":"text","text":" is an interface for streaming conversions."}],"url":"\/documentation\/gio\/converter","identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Converter","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Converter"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/CharsetConverterRef":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"CharsetConverterRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef","abstract":[{"type":"codeVoice","code":"GCharsetConverter"},{"type":"text","text":" is an implementation of [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter"},{"text":"] based on","type":"text"},{"type":"text","text":" "},{"text":"[struct[IConv](\/\/documentation\/glib\/iconv].","type":"text"}],"url":"\/documentation\/gio\/charsetconverterref","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CharsetConverterRef","kind":"identifier"}],"type":"topic","title":"CharsetConverterRef"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]}}}