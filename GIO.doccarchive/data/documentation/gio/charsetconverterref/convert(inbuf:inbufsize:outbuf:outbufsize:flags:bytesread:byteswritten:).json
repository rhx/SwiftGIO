{"variants":[{"paths":["\/documentation\/gio\/charsetconverterref\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef","doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef\/ConverterProtocol-Implementations"]]},"kind":"symbol","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"convert"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"outbuf"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"outbufSize"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ConverterFlagsV","text":"ConverterFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"bytesRead"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"bytesWritten"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"text":">!) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"GConverterResult","preciseIdentifier":"c:@EA@GConverterResult","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that a single call may not consume all input (or any input at all)."},{"type":"text","text":" "},{"type":"text","text":"Also a call may produce output even if given no input, due to state stored"},{"type":"text","text":" "},{"type":"text","text":"in the converter producing output."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If any data was either produced or consumed, and then an error happens, then"},{"type":"text","text":" "},{"type":"text","text":"only the successful conversion is reported and the error is returned on the"},{"text":" ","type":"text"},{"text":"next call.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A full conversion loop involves calling this method repeatedly, each time"},{"type":"text","text":" "},{"text":"giving it new input and space output space. When there is no more input","type":"text"},{"type":"text","text":" "},{"type":"text","text":"data after the data in "},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", the flag "},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" must be set."},{"text":" ","type":"text"},{"type":"text","text":"The loop will be (unless some error happens) returning "},{"type":"codeVoice","code":"converted"},{"type":"text","text":" "},{"type":"text","text":"each time until all data is consumed and all output is produced, then"},{"text":" ","type":"text"},{"code":"finished","type":"codeVoice"},{"type":"text","text":" is returned instead. Note, that "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"may be returned even if "},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" is not set, for instance"},{"text":" ","type":"text"},{"type":"text","text":"in a decompression converter where the end of data is detectable from the"},{"type":"text","text":" "},{"text":"data (and there might even be other data after the end of the compressed data).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When some data has successfully been converted "},{"code":"bytesRead","type":"codeVoice"},{"text":" and is set to","type":"text"},{"text":" ","type":"text"},{"text":"the number of bytes read from ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", and "},{"type":"codeVoice","code":"bytesWritten"},{"text":" is set to indicate","type":"text"},{"text":" ","type":"text"},{"text":"how many bytes was written to ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":". If there are more data to output"},{"type":"text","text":" "},{"text":"or consume (i.e. unless the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" is specified) then"},{"type":"text","text":" "},{"type":"codeVoice","code":"converted"},{"text":" is returned, and if no more data is to be output","type":"text"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"type":"codeVoice","code":"finished"},{"text":" is returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error "},{"code":"error","type":"codeVoice"},{"text":" is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly."},{"type":"text","text":" "},{"text":"Some errors need special handling:","type":"text"}]},{"inlineContent":[{"code":"noSpace","type":"codeVoice"},{"text":" is returned if there is not enough space","type":"text"},{"text":" ","type":"text"},{"text":"to write the resulting converted data, the application should","type":"text"},{"type":"text","text":" "},{"text":"call the function again with a larger ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"text":" to continue.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"partialInput","type":"codeVoice"},{"text":" is returned if there is not enough","type":"text"},{"type":"text","text":" "},{"text":"input to fully determine what the conversion should produce,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and the "},{"code":"inputAtEnd","type":"codeVoice"},{"text":" flag is not set. This happens for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"example with an incomplete multibyte sequence when converting text,"},{"type":"text","text":" "},{"text":"or when a regexp matches up to the end of the input (and may match","type":"text"},{"type":"text","text":" "},{"text":"further input). It may also happen when ","type":"text"},{"code":"inbufSize","type":"codeVoice"},{"type":"text","text":" is zero and"},{"type":"text","text":" "},{"text":"there is no more data to produce.","type":"text"}]},{"inlineContent":[{"type":"text","text":"When this happens the application should read more input and then"},{"type":"text","text":" "},{"type":"text","text":"call the function again. If further input shows that there is no"},{"type":"text","text":" "},{"type":"text","text":"more data call the function again with the same data but with"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"text":" flag set. This may cause the conversion","type":"text"},{"text":" ","type":"text"},{"text":"to finish as e.g. in the regexp match case (or, to fail again with","type":"text"},{"text":" ","type":"text"},{"code":"partialInput","type":"codeVoice"},{"type":"text","text":" in e.g. a charset conversion where the"},{"type":"text","text":" "},{"type":"text","text":"input is actually partial)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After "},{"type":"codeVoice","code":"g_converter_convert()"},{"type":"text","text":" has returned "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" the"},{"type":"text","text":" "},{"text":"converter object is in an invalid state where its not allowed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to call "},{"code":"g_converter_convert()","type":"codeVoice"},{"text":" anymore. At this time you can only","type":"text"},{"type":"text","text":" "},{"text":"free the object or call ","type":"text"},{"code":"g_converter_reset()","type":"codeVoice"},{"type":"text","text":" to reset it to the"},{"type":"text","text":" "},{"text":"initial state.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the flag ","type":"text"},{"type":"codeVoice","code":"flush"},{"type":"text","text":" is set then conversion is modified"},{"text":" ","type":"text"},{"type":"text","text":"to try to write out all internal state to the output. The application"},{"type":"text","text":" "},{"type":"text","text":"has to call the function multiple times with the flag set, and when"},{"text":" ","type":"text"},{"type":"text","text":"the available input has been consumed and all internal state has"},{"type":"text","text":" "},{"type":"text","text":"been produced then "},{"code":"flushed","type":"codeVoice"},{"type":"text","text":" (or "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" if"},{"text":" ","type":"text"},{"type":"text","text":"really at the end) is returned instead of "},{"code":"converted","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This is somewhat similar to what happens at the end of the input stream,"},{"type":"text","text":" "},{"type":"text","text":"but done in the middle of the data."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This has different meanings for different conversions. For instance"},{"text":" ","type":"text"},{"text":"in a compression converter it would mean that we flush all the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"compression state into output such that if you uncompress the"},{"type":"text","text":" "},{"type":"text","text":"compressed data you get back all the input data. Doing this may"},{"type":"text","text":" "},{"type":"text","text":"make the final file larger due to padding though. Another example"},{"type":"text","text":" "},{"text":"is a regexp conversion, where if you at the end of the flushed data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have a match, but there is also a potential longer match. In the"},{"text":" ","type":"text"},{"text":"non-flushed case we would ask for more input, but when flushing we","type":"text"},{"type":"text","text":" "},{"type":"text","text":"treat this as the end of input and do the match."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Flushing is not always possible (like if a charset converter flushes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"at a partial multibyte sequence). Converters are supposed to try"},{"text":" ","type":"text"},{"type":"text","text":"to produce as much output as possible and then return an error"},{"text":" ","type":"text"},{"type":"text","text":"(typically "},{"code":"partialInput","type":"codeVoice"},{"type":"text","text":")."}]}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","role":"symbol","externalID":"s:3GIO17ConverterProtocolPAAE7convert5inbuf0E4Size6outbuf0gF05flags9bytesRead0I7WrittenSo16GConverterResultaSvSg_SiANSiAA0B5FlagsVSpySuGSgARtKF::SYNTHESIZED::s:3GIO19CharsetConverterRefV","fragmen