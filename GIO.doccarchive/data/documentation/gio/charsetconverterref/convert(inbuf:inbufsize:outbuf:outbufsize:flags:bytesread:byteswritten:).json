data. It is to be called"},{"type":"text","text":" "},{"text":"multiple times in a loop, and each time it will do some work, i.e.","type":"text"},{"text":" ","type":"text"},{"text":"producing some output (in ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"text":") or","type":"text"},{"type":"text","text":" "},{"text":"both. If its not possible to do any work an error is returned.","type":"text"}],"references":{"doc://GIO/documentation/GIO/CharsetConverterRef":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"CharsetConverterRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverterRef","abstract":[{"type":"codeVoice","code":"GCharsetConverter"},{"type":"text","text":" is an implementation of [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter"},{"text":"] based on","type":"text"},{"type":"text","text":" "},{"text":"[struct[IConv](\/\/documentation\/glib\/iconv].","type":"text"}],"url":"\/documentation\/gio\/charsetconverterref","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CharsetConverterRef","kind":"identifier"}],"type":"topic","title":"CharsetConverterRef"},"doc://GIO/documentation/GIO/CharsetConverterRef/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)":{"title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","url":"\/documentation\/gio\/charsetconverterref\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)","abstract":[{"text":"This is the main operation used when converting data. It is to be called","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multiple times in a loop, and each time it will do some work, i.e."},{"type":"text","text":" "},{"type":"text","text":"producing some output (in "},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":") or"},{"type":"text","text":" "},{"text":"both. If its not possible to do any work an error is returned.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"convert","kind":"identifier"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"text":"inbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"outbuf"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14ConverterFlagsV","text":"ConverterFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"bytesRead","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"gsize","preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"GConverterResult","kind":"typeIdentifier","preciseIdentifier":"c