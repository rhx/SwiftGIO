ority_check_authorization_sync()","type":"codeVoice"},{"type":"text","text":" to check"},{"type":"text","text":" "},{"text":"authorization using polkit.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":" is returned then no further handlers are run and the request to"},{"type":"text","text":" "},{"text":"change the debug settings is rejected.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Otherwise, if "},{"code":"true","type":"codeVoice"},{"type":"text","text":" is returned, signal emission continues. If no handlers"},{"type":"text","text":" "},{"text":"return ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", then the debug settings are allowed to be changed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Signal handlers must not modify "},{"code":"invocation","type":"codeVoice"},{"text":", or cause it to return a value.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The default class handler just returns "},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"authorize"},{"type":"text","text":" signal"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/debugcontrollerdbusref\/onauthorize(flags:handler:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef\/onAuthorize(flags:handler:)"},"references":{"doc://GIO/documentation/GIO/DebugControllerDBusRef/onAuthorize(flags:handler:)":{"title":"onAuthorize(flags:handler:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onAuthorize","kind":"identifier"},{"kind":"text","text":"("},{"text":"fl