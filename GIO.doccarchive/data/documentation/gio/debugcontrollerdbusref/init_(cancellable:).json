{"sections":[],"variants":[{"paths":["\/documentation\/gio\/debugcontrollerdbusref\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"type":"text","text":" "},{"code":"g_initable_new()","type":"codeVoice"},{"type":"text","text":" should typically be used instead."}]},{"inlineContent":[{"type":"text","text":"The object must be initialized before any real use after initial"},{"type":"text","text":" "},{"text":"construction, either with this function or ","type":"text"},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"type":"text","text":" "},{"text":"from another thread. If the operation was cancelled, the error","type":"text"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"type":"text","text":" "},{"code":"notSupported","type":"codeVoice"},{"type":"text","text":" will be returned."}]},{"type":"paragraph","inlineContent":[{"text":"If the object is not initialized, or initialization returns with an","type":"text"},{"type":"text","text":" "},{"text":"error, then all operations on the object except ","type":"text"},{"type":"codeVoice","code":"g_object_ref()"},{"text":" and","type":"text"},{"type":"text","text":" "},{"code":"g_object_unref()","type":"codeVoice"},{"text":" are considered to be invalid, and have undefined","type":"text"},{"type":"text","text":" "},{"text":"behaviour. See the ","type":"text"},{"isActive":true,"type":"reference","identifier":"#iface@Gio.Initable#description"},{"type":"text","text":" for more details."}]},{"inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"text":" can be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"text":" ","type":"text"},{"type":"text","text":"supporting this. Generally, a class’ implementation of "},{"code":"init()","type":"codeVoice"},{"text":" can assume","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"type":"text","text":" "},{"text":"recommended all ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" implementations should be idempotent; that"},{"type":"text","text":" "},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a class explicitly supports being initialized multiple times, it is"},{"text":" ","type":"text"},{"text":"recommended that the method is idempotent: multiple calls with the same","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"type":"text","text":" "},{"text":"the object; further calls return the result of the first call.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"type":"text","text":" "},{"text":"it is designed to be used via the singleton pattern, with a","type":"text"},{"text":" ","type":"text"},{"code":"GObjectClass.constructor","type":"codeVoice"},{"type":"text","text":" that sometimes returns an existing instance."},{"type":"text","text":" "},{"text":"In this pattern, a caller would expect to be able to call ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"text":" ","type":"text"},{"type":"text","text":"on the result of "},{"type":"codeVoice","code":"g_object_new()"},{"text":", regardless of whether it is in fact a new","type":"text"},{"text":" ","type":"text"},{"text":"instance.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef\/InitableProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef\/init_(cancellable:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","title":"init_(cancellable:)","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO22DebugControllerDBusRefV","role":"symbol","extendedModule":"GIO"},"kind":"symbol","references":{"doc://GIO/documentation/GIO/DebugControllerDBusRef/init_(cancellable:)":{"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef\/init_(cancellable:)","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"init_(cancellable:)","url":"\/documentation\/gio\/debugcontrollerdbusref\/init_(cancellable:)"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/DebugController":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"DebugController"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","url":"\/documentation\/gio\/debugcontroller","title":"DebugController","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DebugController","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDebugController"},{"type":"text","text":" is an interface to expose control of debugging features and"},{"type":"text","text":" "},{"text":"debug output.","type":"text"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DebugControllerDBusRef":{"url":"\/documentation\/gio\/debugcontrollerdbusref","navigatorTitle":[{"kind":"identifier","text":"DebugControllerDBusRef"}],"abstract":[{"type":"codeVoice","code":"GDebugControllerDBus"},{"type":"text","text":" is an implementation of [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","isActive":true},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which exposes debug settings as a D-Bus object."}],"title":"DebugControllerDBusRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef","role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"DebugControllerDBusRef","kind":"identifier"}],"type":"topic"},"#iface@Gio.Initable#description":{"type":"link","identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description","title":"description","titleInlineContent":[{"text":"description","type":"text"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/DebugControllerDBusRef/InitableProtocol-Implementations":{"url":"\/documentation\/gio\/debugcontrollerdbusref\/initableprotocol-implementations","role":"collectionGroup","abstract":[],"title":"InitableProtocol Implementations","kind":"article","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef\/InitableProtocol-Implementations"}}}