xt","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"text":" ","type":"text"},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"type":"text","text":" "},{"text":"when they explicitly call ","type":"text"},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"code":"g_signal_connect()","type":"codeVoice"},{"text":" call, like this:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"notify::authentication-observer","type":"codeVoice"},{"type":"text","text":" signal"}]}],"name":"Note","type":"aside","style":"note"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"modules":[{"name":"GIO"}],"symbolKind":"method","title":"onNotifyAuthenticationObserver(flags:handler:)","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onNotifyAuthenticationObserver","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17DBusConnectionRefV","text":"DBusConnectionRef"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"externalID":"s:3GIO22DBusConnectionProtocolPAAE30onNotifyAuthenticationObserver5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecO0VtctF::SYNTHESIZED::s:3GIO14DBusConnectionC","extendedModule":"GIO"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/onNotifyAuthenticationObserver(flags:handler:)","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusConnection","doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/DBusConnectionProtocol-Implementations"]]},"abstrac