"type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.DBusConnection.unexport_action_group"},{"text":"] with the return value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The thread default main context is taken at the time of this call."},{"type":"text","text":" "},{"type":"text","text":"All incoming action activations and state change requests are"},{"type":"text","text":" "},{"text":"reported from this context.  Any changes on the action group that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cause it to emit signals must also come from this same context."},{"type":"text","text":" "},{"text":"Since incoming action activations and state change requests are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"rather likely to cause changes on the action group, this effectively"},{"text":" ","type":"text"},{"type":"text","text":"limits a given action group to being exported from only one main"},{"type":"text","text":" "},{"type":"text","text":"context."}]}]}],"references":{"doc://GIO/documentation/GIO/DBusConnection/DBusConnectionProtocol-Implementations":{"title":"DBusConnectionProtocol Implementations","role":"collectionGroup","url":"\/documentation\/gio\/dbusconnection\/dbusconnectionprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/DBusConnectionProtocol-Implementations","type":"topic","kind":"article","abstract":[]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusConnection":{"type":"topic","navigatorTitle":[{"text":"DBusConnection","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection","