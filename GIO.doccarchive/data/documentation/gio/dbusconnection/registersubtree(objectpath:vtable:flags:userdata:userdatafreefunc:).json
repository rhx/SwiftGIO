tation\/GIO\/DBusConnection","doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/DBusConnectionProtocol-Implementations"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"registerSubtree"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"DBusSubtreeVTableT"},{"text":">(","kind":"text"},{"text":"objectPath","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"vtable"},{"text":": ","kind":"text"},{"text":"DBusSubtreeVTableT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO16DBusSubtreeFlagsV","text":"DBusSubtreeFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusSubtreeFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"userDataFreeFunc"},{"text":": ","kind":"text"},{"text":"GDestroyNotify","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@GDestroyNotify"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"DBusSubtreeVTableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusSubtreeVTableProtocol","preciseIdentifier":"s:3GIO25DBusSubtreeVTableProtocolP","text":"DBusSubtreeVTableProtocol","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"enumerate"},{"type":"text","text":" and "},{"type":"codeVoice","code":"introspection"},{"text":" functions in ","type":"text"},{"type":"codeVoice","code":"vtable"},{"text":" are used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"convey, to remote callers, what nodes exist in the subtree rooted"},{"type":"text","text":" "},{"type":"text","text":"by "},{"code":"objectPath","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When handling remote calls into any node in the subtree, first the","type":"text"},{"text":" ","type":"text"},{"code":"enumerate","type":"codeVoice"},{"text":" function is used to check if the node exists. If the node exists","type":"text"},{"text":" ","type":"text"},{"text":"or the ","type":"text"},{"code":"dispatchToUnenumeratedNodes","type":"codeVoice"},{"type":"text","text":" flag is set"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"codeVoice","code":"introspection"},{"text":" function is used to check if the node supports the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requested method. If so, the "},{"code":"dispatch","type":"codeVoice"},{"text":" function is used to determine","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"where to dispatch the call. The collected "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"gpointer"},{"type":"text","text":" will be used to call into the interface vtable for processing"},{"type":"text","text":" "},{"type":"text","text":"the request."}]},{"inlineContent":[{"type":"text","text":"All calls into user-provided code will be invoked in the thread-default"},{"type":"text","text":" "},{"type":"text","text":"main context (see [method"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"type":"text","text":"])"},{"text":" ","type":"text"},{"text":"of the thread you are calling this method from.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If an existing subtree is already registered at "},{"type":"codeVoice","code":"objectPath"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"text","text":"then "},{"code":"error","type":"codeVoice"},{"text":" is set to ","type":"text"},{"code":"exists","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Note that it is valid to register regular objects (using"},{"text":" ","type":"text"},{"code":"g_dbus_connection_register_object()","type":"codeVoice"},{"text":") in a subtree registered with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_dbus_connection_register_subtree()"},{"type":"text","text":" - if so, the subtree handler"},{"text":" ","type":"text"},{"text":"is tried as the last resort. One way to think about a subtree","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handler is to consider it a fallback handler for object paths not"},{"type":"text","text":" "},{"type":"text","text":"registered via "},{"type":"codeVoice","code":"g_dbus_connection_register_object()"},{"text":" or other bindings.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that ","type":"text"},{"type":"codeVoice","code":"vtable"},{"type":"text","text":" will be copied so you cannot change it after"},{"text":" ","type":"text"},{"text":"registration.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See this "},{"identifier":"#class@Gio.DBusConnection#an-example-for-exporting-a-subtree","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"for an example of how to use this method."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/dbusconnection\/registersubtree(objectpath:vtable:flags:userdata:userdatafreefunc:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/registerSubtree(objectPath:vtable:flags:userData:userDataFreeFunc:)","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/DBusInterfaceVTable":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"DBusInterfaceVTable","kind":"identifier"}],"navigatorTitle":[{"text":"DBusInterfaceVTable","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","type":"topic","abstract":[{"type":"text","text":"Virtual table for handling properties and method calls for a D-Bus"},{"text":" ","type":"text"},{"text":"interface.","type":"text"}],"title":"DBusInterfaceVTable","url":"\/documentation\/gio\/dbusinterfacevtable","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/DBusSubtreeVTableProtocol":{"navigatorTitle":[{"text":"DBusSubtreeVTableProtocol","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusSubtreeVTableProtocol","url":"\/documentation\/gio\/dbussubtreevtableprotocol","abstract":[{"type":"text","text":"Virtual table for handling subtrees registered with "},{"code":"g_dbus_connection_register_subtree()","type":"codeVoice"},{"type":"text","text":"."}],"title":"DBusSubtreeVTableProtocol","type":"topic","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"DBusSubtreeVTableProtocol","kind":"identifier"}]},"doc://GIO/documentation/GIO/DBusSubtreeFlags":{"url":"\/documentation\/gio\/dbussubtreeflags","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusS