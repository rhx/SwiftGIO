ocumentation\/glib\/maincontext after this","type":"text"},{"text":" ","type":"text"},{"text":"function has returned. You should continue to iterate the [MainContext](\/\/documentation\/glib\/maincontext","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"until the [DestroyNotify](\/\/documentation\/glib\/destroynotify function passed to"},{"type":"text","text":" "},{"code":"g_dbus_connection_signal_subscribe()","type":"codeVoice"},{"type":"text","text":" is called, in order to avoid memory"},{"type":"text","text":" "},{"type":"text","text":"leaks through callbacks queued on the [MainContext](\/\/documentation\/glib\/maincontext after it’s stopped being"},{"type":"text","text":" "},{"type":"text","text":"iterated."},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, any idle source with a priority lower than [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default"},{"text":" ","type":"text"},{"type":"text","text":"that was scheduled after unsubscription, also indicates that all resources"},{"type":"text","text":" "},{"text":"of this subscription are released.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusConnection/signalUnsubscribe(subscriptionID:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/signalUnsubscribe(subscriptionID:)","title":"signalUnsubscribe(subscriptionID:)","url":"\/documentation\/gio\/dbusconnection\/signalunsubscribe(subscriptionid:)","kind":"symbol","abstract":[{"text":"Unsubscribes from signals.","type":"text"}],"type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"signalUnsubscribe","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"subscriptionID"},{"kind":"text","text":": "},{"kind":