{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusConnection","doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/InitableProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_initable_new()"},{"text":" should typically be used instead.","type":"text"}]},{"inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"type":"text","text":" "},{"text":"construction, either with this function or ","type":"text"},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Implementations may also support cancellation. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"type":"text","text":" "},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"type":"text","text":" "},{"code":"notSupported","type":"codeVoice"},{"type":"text","text":" will be returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the object is not initialized, or initialization returns with an"},{"text":" ","type":"text"},{"type":"text","text":"error, then all operations on the object except "},{"type":"codeVoice","code":"g_object_ref()"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"text":" ","type":"text"},{"text":"behaviour. See the ","type":"text"},{"identifier":"#iface@Gio.Initable#description","isActive":true,"type":"reference"},{"type":"text","text":" for more details."}]},{"inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"text":" can be","type":"text"},{"type":"text","text":" "},{"text":"initialized multiple times, unless the class explicitly documents itself as","type":"text"},{"text":" ","type":"text"},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"type":"codeVoice","code":"init()"},{"type":"text","text":" can assume"},{"type":"text","text":" "},{"text":"(and assert) that it will only be called once. Previously, this documentation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended all "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"type":"text","text":" implementations should be idempotent; that"},{"type":"text","text":" "},{"text":"recommendation was relaxed in GLib 2.54.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a class explicitly supports being initialized multiple times, it is"},{"type":"text","text":" "},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"text":" ","type":"text"},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"type":"text","text":" "},{"type":"text","text":"the object; further calls return the result of the first call."}]},{"inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"text":" ","type":"text"},{"text":"it is designed to be used via the singleton pattern, with a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GObjectClass.constructor"},{"type":"text","text":" that sometimes returns an existing instance."},{"type":"text","text":" "},{"text":"In this pattern, a caller would expect to be able to call ","type":"text"},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":" "},{"text":"on the result of ","type":"text"},{"type":"codeVoice","code":"g_object_new()"},{"text":", regardless of whether it is in fact a new","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instance."}],"type":"paragraph"}]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"modules":[{"name":"GIO"}],"title":"init_(cancellable:)","extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"method","role":"symbol","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO14DBusConnectionC"},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/init_(cancellable:)"},"variants":[{"paths":["\/documentation\/gio\/dbusconnection\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusConnection":{"type":"topic","navigatorTitle":[{"text":"DBusConnection","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection","url":"\/documentation\/gio\/dbusconnection","title":"DBusConnection","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DBusConnection"}],"abstract":[{"text":"The ","type":"text"},{"code":"GDBusConnection","type":"codeVoice"},{"type":"text","text":" type is used for D-Bus connections to remote"},{"text":" ","type":"text"},{"type":"text","text":"peers such as a message buses."}]},"#iface@Gio.Initable#description":{"title":"description","type":"link","identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description","titleInlineContent":[{"type":"text","text":"description"}]},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/DBusConnection/init_(cancellable:)":{"type":"topic","title":"init_(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/init_(cancellable:)","abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"url":"\/documentation\/gio\/dbusconnection\/init_(cancellable:)","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/DBusConnection/InitableProtocol-Implementations":{"abstract":[],"role":"collectionGroup","kind":"article","title":"InitableProtocol Implementations","url":"\/documentation\/gio\/dbusconnection\/initableprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusConnection\/InitableProtocol-Implementations","type":"topic"}}}