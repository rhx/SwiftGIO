. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]},"doc://GIO/documentation/GIO/menuExporterMaxSectionSize":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuExporterMaxSectionSize","type":"topic","url":"\/documentation\/gio\/menuexportermaxsectionsize","fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"menuExporterMaxSectionSize"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"abstract":[{"type":"text","text":"The maximum number of entries in a menu section supported by"},{"type":"text","text":" "},{"code":"g_dbus_connection_export_menu_model()","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","title":"menuExporterMaxSectionSize","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusConnection/exportMenuModel(objectPath:menu:)":{"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/dbusconnection\/exportmenumodel(objectpath:menu:)","ab