The implemented D-Bus API should be considered private."},{"type":"text","text":" "},{"type":"text","text":"It is subject to change in the future."}],"type":"paragraph"},{"inlineContent":[{"text":"An object path can only have one menu model exported on it. If this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constraint is violated, the export will fail and 0 will be"},{"text":" ","type":"text"},{"type":"text","text":"returned (with "},{"code":"error","type":"codeVoice"},{"type":"text","text":" set accordingly)."}],"type":"paragraph"},{"inlineContent":[{"text":"Exporting menus with sections containing more than","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/menuExporterMaxSectionSize"},{"type":"text","text":" items is not supported and results in"},{"text":" ","type":"text"},{"type":"text","text":"undefined behavior."}],"type":"paragraph"},{"inlineContent":[{"text":"You can unexport the menu model using","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_unexport_menu_model()"},{"type":"text","text":" with the return value of"},{"text":" ","type":"text"},{"type":"text","text":"this function."}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusconnection\/exportmenumodel(objectpath:menu:)"]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"exportMenuModel"},{"kind":"text","text":"<"},{"text":"MenuModelT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"objectPath","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"menu","kind":"externalParam