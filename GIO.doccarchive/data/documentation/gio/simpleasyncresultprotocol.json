{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol"},"abstract":[{"type":"text","text":"As of GLib 2.46, "},{"code":"GSimpleAsyncResult","type":"codeVoice"},{"type":"text","text":" is deprecated in favor of"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Task","isActive":true},{"type":"text","text":"], which provides a simpler API."}],"kind":"symbol","topicSections":[{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/opResGboolean","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/opResGpointer","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/opResGssize","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/simple_async_result_ptr-414d6","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/sourceTag"]},{"generated":true,"title":"Instance Methods","anchor":"Instance-Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/complete()","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/completeInIdle()","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/getOpResGboolean()","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/getOpResGpointer()","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/getOpResGssize()","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/getSourceTag()","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/propagateError()","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/runInThread(func:ioPriority:cancellable:)-340aw","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/runInThread(func:ioPriority:cancellable:)-3w313","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/set(checkCancellable:)-4c07x","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/set(checkCancellable:)-9ulqv","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/set(handleCancellation:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/setErrorVa(domain:code:format:args:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/setFrom(error:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/setOpResGboolean(opRes:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/setOpResGpointer(opRes:destroyOpRes:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/setOpResGssize(opRes:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/take(error:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AsyncResultProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"]},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResult","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef"],"title":"Conforming Types","type":"conformingTypes","kind":"relationships"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"SimpleAsyncResultProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultProtocol","preciseIdentifier":"s:3GIO19AsyncResultProtocolP","text":"AsyncResultProtocol"},{"kind":"text","text":", "},{"preciseIdentifier":"s:10GLibObject0B8ProtocolP","kind":"typeIdentifier","text":"ObjectProtocol"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"code":"GSimpleAsyncResult","type":"codeVoice"},{"text":" implements [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","isActive":true},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GSimpleAsyncResult"},{"text":" handles [type","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","type":"reference","isActive":true},{"type":"text","text":"]s, error"},{"type":"text","text":" "},{"text":"reporting, operation cancellation and the final state of an operation,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"completely transparent to the application. Results can be returned"},{"type":"text","text":" "},{"text":"as a pointer e.g. for functions that return data that is collected","type":"text"},{"text":" ","type":"text"},{"text":"asynchronously, a boolean value for checking the success or failure","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of an operation, or a "},{"type":"codeVoice","code":"gssize"},{"text":" for operations which return the number","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of bytes modified by the operation; all of the simple return cases"},{"type":"text","text":" "},{"text":"are covered.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most of the time, an application will not need to know of the details"},{"text":" ","type":"text"},{"type":"text","text":"of this API; it is handled transparently, and any necessary operations"},{"type":"text","text":" "},{"type":"text","text":"are handled by [iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult"},{"text":"]’s interface. However, if implementing","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a new GIO module, for writing language bindings, or for complex"},{"text":" ","type":"text"},{"type":"text","text":"applications that need better control of how asynchronous operations"},{"type":"text","text":" "},{"type":"text","text":"are completed, it is important to understand this functionality."}]},{"inlineContent":[{"code":"GSimpleAsyncResult","type":"codeVoice"},{"type":"text","text":"s are tagged with the calling function to ensure"},{"type":"text","text":" "},{"text":"that asynchronous functions and their finishing functions are used","type":"text"},{"type":"text","text":" "},{"type":"text","text":"together correctly."}],"type":"paragraph"},{"inlineContent":[{"text":"To create a new ","type":"text"},{"code":"GSimpleAsyncResult","type":"codeVoice"},{"text":", call [ctor","type":"text"},{"code":"Gio.SimpleAsyncResult.new","type":"codeVoice"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"If the result needs to be created for a "},{"type":"codeVoice","code":"GError"},{"type":"text","text":", use"},{"text":" ","type":"text"},{"type":"text","text":"[ctor"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.new_from_error"},{"text":"] or","type":"text"},{"type":"text","text":" "},{"text":"[ctor","type":"text"},{"code":"Gio.SimpleAsyncResult.new_take_error","type":"codeVoice"},{"type":"text","text":"]. If a "},{"type":"codeVoice","code":"GError"},{"type":"text","text":" is not available"},{"text":" ","type":"text"},{"text":"(e.g. the asynchronous operation doesn’t take a ","type":"text"},{"code":"GError","type":"codeVoice"},{"type":"text","text":" argument),"},{"text":" ","type":"text"},{"type":"text","text":"but the result still needs to be created for an error condition, use"},{"type":"text","text":" "},{"type":"text","text":"[ctor"},{"code":"Gio.SimpleAsyncResult.new_error","type":"codeVoice"},{"type":"text","text":"] (or"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.set_error_va"},{"type":"text","text":"] if your application or binding"},{"text":" ","type":"text"},{"type":"text","text":"requires passing a variable argument list directly), and the error can then"},{"text":" ","type":"text"},{"text":"be propagated through the use of","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.SimpleAsyncResult.propagate_error","type":"codeVoice"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An asynchronous operation can be made to ignore a cancellation event by","type":"text"},{"type":"text","text":" "},{"text":"calling [method","type":"text"},{"code":"Gio.SimpleAsyncResult.set_handle_cancellation","type":"codeVoice"},{"type":"text","text":"] with a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"text":" for the operation and ","type":"text"},{"type":"codeVoice","code":"FALSE"},{"text":". This is useful for","type":"text"},{"type":"text","text":" "},{"text":"operations that are dangerous to cancel, such as close (which would","type":"text"},{"type":"text","text":" "},{"text":"cause a leak if cancelled before being run).","type":"text"}]},{"type":"paragraph","inlineContent":[{"code":"GSimpleAsyncResult","type":"codeVoice"},{"type":"text","text":" can integrate into GLib’s event loop,"},{"type":"text","text":" "},{"type":"text","text":"[type[MainLoop](\/\/documentation\/glib\/mainloop], or it can use [type[Thread](\/\/documentation\/glib\/thread]s."},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.SimpleAsyncResult.complete","type":"codeVoice"},{"text":"] will finish an I\/O task directly","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from the point where it is called."},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.complete_in_idle"},{"text":"] will finish it from an idle","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handler in the  thread-default main context (see"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"]) where the ","type":"text"},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"text":" ","type":"text"},{"type":"text","text":"was created. [method"},{"code":"Gio.SimpleAsyncResult.run_in_thread","type":"codeVoice"},{"text":"] will run the job in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a separate thread and then use"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.complete_in_idle"},{"text":"] to deliver the result.","type":"text"}]},{"inlineContent":[{"text":"To set the results of an asynchronous function,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.SimpleAsyncResult.set_op_res_gpointer","type":"codeVoice"},{"type":"text","text":"],"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.set_op_res_gboolean"},{"text":"], and","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.SimpleAsyncResult.set_op_res_gssize","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"are provided, setting the operation’s result to a "},{"code":"gpointer","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"gboolean"},{"text":", or","type":"text"},{"text":" ","type":"text"},{"code":"gssize","type":"codeVoice"},{"text":", respectively.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Likewise, to get the result of an asynchronous function,"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.get_op_res_gpointer"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.get_op_res_gboolean"},{"type":"text","text":"], and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.SimpleAsyncResult.get_op_res_gssize","type":"codeVoice"},{"type":"text","text":"] are"},{"type":"text","text":" "},{"text":"provided, getting the operation’s result as a ","type":"text"},{"type":"codeVoice","code":"gpointer"},{"type":"text","text":", "},{"code":"gboolean","type":"codeVoice"},{"text":", and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"gssize"},{"type":"text","text":", respectively."}]},{"type":"paragraph","inlineContent":[{"text":"For the details of the requirements implementations must respect, see","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","type":"reference","isActive":true},{"text":"].  A typical implementation of an asynchronous","type":"text"},{"text":" ","type":"text"},{"text":"operation using ","type":"text"},{"code":"GSimpleAsyncResult","type":"codeVoice"},{"type":"text","text":" looks something like this:"}]},{"code":["static void","baked_cb (Cake    *cake,","          gpointer user_data)","{","  \/\/ In this example, this callback is not given a reference to the cake,","  \/\/ so the GSimpleAsyncResult has to take a reference to it.","  GSimpleAsyncResult *result = user_data;","","  if (cake == NULL)","    g_simple_async_result_set_error (result,","                                     BAKER_ERRORS,","                                     BAKER_ERROR_NO_FLOUR,","                                     \"Go to the supermarket\");","  else","    g_simple_async_result_set_op_res_gpointer (result,","                                               g_object_ref (cake),","                                               g_object_unref);","","","  \/\/ In this example, we assume that baked_cb is called as a callback from","  \/\/ the mainloop, so it's safe to complete the operation synchronously here.","  \/\/ If, however, _baker_prepare_cake () might call its callback without","  \/\/ first returning to the mainloop — inadvisable, but some APIs do so —","  \/\/ we would need to use `g_simple_async_result_complete_in_idle()`.","  g_simple_async_result_complete (result);","  g_object_unref (result);","}","","void","baker_bake_cake_async (Baker              *self,","                       guint               radius,","                       GAsyncReadyCallback callback,","                       gpointer            user_data)","{","  GSimpleAsyncResult *simple;","  Cake               *cake;","","  if (radius < 3)","    {","      g_simple_async_report_error_in_idle (G_OBJECT (self),","                                           callback,","                                           user_data,","                                           BAKER_ERRORS,","                                           BAKER_ERROR_TOO_SMALL,","                                           \"`ucm` radius cakes are silly\",","                                           radius);","      return;","    }","","  simple = g_simple_async_result_new (G_OBJECT (self),","                                      callback,","                                      user_data,","                                      baker_bake_cake_async);","  cake = _baker_get_cached_cake (self, radius);","","  if (cake != NULL)","    {","      g_simple_async_result_set_op_res_gpointer (simple,","                                                 g_object_ref (cake),","                                                 g_object_unref);","      g_simple_async_result_complete_in_idle (simple);","      g_object_unref (simple);","      \/\/ Drop the reference returned by `_baker_get_cached_cake()`;","      \/\/ the GSimpleAsyncResult has taken its own reference.","      g_object_unref (cake);","      return;","    }","","  _baker_prepare_cake (self, radius, baked_cb, simple);","}","","Cake *","baker_bake_cake_finish (Baker        *self,","                        GAsyncResult *result,","                        GError      **error)","{","  GSimpleAsyncResult *simple;","  Cake               *cake;","","  g_return_val_if_fail (g_simple_async_result_is_valid (result,","                                                        G_OBJECT (self),","                                                        baker_bake_cake_async),","                        NULL);","","  simple = (GSimpleAsyncResult *) result;","","  if (g_simple_async_result_propagate_error (simple, error))","    return NULL;","","  cake = CAKE (g_simple_async_result_get_op_res_gpointer (simple));","  return g_object_ref (cake);","}"],"type":"codeListing","syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol","isActive":true,"type":"reference"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResult","type":"reference"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Alternatively, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef"},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/simpleasyncresultprotocol"]}],"metadata":{"modules":[{"name":"GIO"}],"navigatorTitle":[{"kind":"identifier","text":"SimpleAsyncResultProtocol"}],"symbolKind":"protocol","roleHeading":"Protocol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"SimpleAsyncResultProtocol","kind":"identifier"}],"externalID":"s:3GIO25SimpleAsyncResultProtocolP","title":"SimpleAsyncResultProtocol"},"references":{"doc://GIO/documentation/GIO/SimpleAsyncResultProtocol/set(checkCancellable:)-9ulqv":{"abstract":[{"type":"text","text":"Sets a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Cancellable","type":"reference","isActive":true},{"text":" to check before dispatching results.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/gio\/simpleasyncresultprotocol\/set(checkcancellable:)-9ulqv","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/set(checkCancellable:)-9ulqv","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"checkCancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?)","kind":"text"}],"deprecated":true,"title":"set(checkCancellable:)"},"doc://GIO/documentation/GIO/SimpleAsyncResultProtocol/getSourceTag()":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getSourceTag","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"?","kind":"text"}],"abstract":[{"text":"Gets the source tag for the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResult","isActive":true},{"type":"text","text":"."}],"title":"getSourceTag()","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/getSourceTag()","url":"\/documentation\/gio\/simpleasyncresultprotocol\/getsourcetag()","deprecated":true,"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/AsyncReadyCallback":{"navigatorTitle":[{"kind":"identifier","text":"AsyncReadyCallback"}],"title":"AsyncReadyCallback","abstract":[{"text":"Type definition for a function that will be called back when an asynchronous","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation within GIO has been completed. "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"callbacks from "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"text":" are guaranteed to be invoked in a later","type":"text"},{"type":"text","text":" "},{"text":"iteration of the thread-default main context","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(see [method"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"])","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"type":"text","text":" was created. All other users of"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","isActive":true,"type":"reference"},{"type":"text","text":" must likewise call it asynchronously in a"},{"text":" ","type":"text"},{"text":"later iteration of the main context.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AsyncReadyCallback"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","url":"\/documentation\/gio\/asyncreadycallback"},"doc://GIO/documentation/GIO/SimpleAsyncResultProtocol/take(error:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol\/take(error:)","title":"take(error:)","abstract":[{"text":"Sets the result from ","type":"text"},{"type":"codeVoice","code":"error"},{"text":", and takes over the caller’s ownership","type":"text"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":", so the caller does not need to free it any more."}],"type":"topic","url":"\/documentation\/gio\/simpleasyncresultprotocol\/take(error:)","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"take","kind":"identifier"},{"text":"<","kind":"text"},{"text":"GLibGLibErrorT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"error","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GLibGLibErrorT"},{"text":")","kind":"text"}],"deprecated":true},"doc://GIO/documentation/GIO/SimpleAsyncResultProtocol/runInThread(func:ioPriority:cancellable:)-340aw":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"runInThread"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"func"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSimpleAsyncThreadFunc","text":"GSimpleAsyncThreadFunc"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"url":"\/documentation\/gio\/simpleasyncresultprotocol\/runinthread(func:iopriority:cancellable:)-340aw","title":"runInThread(func:ioPriority:cancellable:)","kind":"symbol","type":"topic","role":"symbol","deprecated":true,"abstract":[{"type":"text","text":"Runs the asynchronous job in a separate thread and then calls"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_simple_async_result_complete_in_idle()"},{"text":" on ","type":"text"},{"code":"simple","type":"codeVoice"},{"type":"text","text":" to return"},{"text":" ",