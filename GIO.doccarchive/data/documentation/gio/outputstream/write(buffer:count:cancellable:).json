xt"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"gssize","preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If count is 0, returns 0 and does nothing. A value of "},{"type":"codeVoice","code":"count"},{"text":" ","type":"text"},{"text":"larger than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a "},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"text":" ","type":"text"},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"text":" ","type":"text"},{"text":"can happen e.g. on a partial I\/O error, or if there is not enough","type":"text"},{"type":"text","text":" "},{"text":"storage in the stream. All writes block until at least one byte","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"type":"text","text":" "},{"code":"count","type":"codeVoice"},{"text":" is 0).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"text":"partial result will be returned, without an error.","type":"text"}]},{"inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}],"type":"paragraph"}]}],"abstract":[{"text":"Tries to write ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from "},{"type":"codeVoice","code":"buffer"},{"text":" into the stream. Will block","type":"text"},{"type":"text","text":" "},{"type":"text","text":"during the operation."}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/OutputStream\/write(buffer:count:cancellable:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStream","doc:\/\/GIO\/documentation\/GIO\/OutputStream\/OutputStreamProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/OutputStream/write(buffer:count:cancellable:)":{"title":"write(buffer:count:cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream\/write(buffer:count:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"write"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","kind":"typeIdentifier","text":"UnsafeMutableRawPointer"},{"kind":"text","text":"!, "},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14Cancellabl