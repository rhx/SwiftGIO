s from ","type":"text"},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" into"},{"type":"text","text":" "},{"text":"the stream. When the operation is finished ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"text":"You can then call ","type":"text"},{"type":"codeVoice","code":"g_output_stream_write_finish()"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"text":"operation.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/OutputStream\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"writeAsync"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"During an async request no other sync and async calls are allowed,"},{"text":" ","type":"text"},{"type":"text","text":"and will result in "},{"type":"codeVoice","code":"pending"},{"text":" errors.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A value of ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"type":"text","text":" "},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written will be passed to the"},{"text":" ","type":"text"},{"code":"callback","type":"codeVoice"},{"text":". It is not an error if this is not the same as the","type":"text"},{"type":"text","text":" "},{"text":"requested size, as it can happen e.g. on a partial I\/O error,","type":"text"},{"type":"text","text":" "},{"text":"but generally we try to write as many bytes as requested.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You are guaranteed that this method will never fail with"},{"text":" ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"text":" - if ","type":"text"},{"code":"stream","type":"codeVoice"},{"text":" can’t accept more data, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"method will just wait until this changes."}]},{"type":"paragraph","inlineContent":[{"text":"Any outstanding I\/O request with higher priority (lower numerical","type":"text"},{"text":" ","type":"text"},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads"},{"text":" ","type":"text"},{"type":"text","text":"to implement asynchronicity, so they are optional for inheriting"},{"text":" ","type":"text"},{"text":"classes. However, if you override one you must override all.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"text":" ","type":"text"},{"code":"g_output_stream_write()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that no copy of ","type":"text"},{"type":"codeVoice","code":"buffer"},{"text":" will be made, so it must stay valid","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"until "},{"code":"callback","type":"codeVoice"},{"text":" is called. See ","type":"text"},{"type":"codeVoice","code":"g_output_stream_write_bytes_async()"},{"text":" ","type":"text"},{"type":"text","text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to"},{"type":"text","text":" "},{"type":"text","text":"the contents (without copying) for the duration of the call."}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStream","doc:\/\/GIO\/documentation\/GIO\/OutputStream\/OutputStreamProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO/OutputStream/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)":{"type":"topic","role":"symbol","title":"writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","abstract":[{"text":"Request an asynchronous write of ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from 