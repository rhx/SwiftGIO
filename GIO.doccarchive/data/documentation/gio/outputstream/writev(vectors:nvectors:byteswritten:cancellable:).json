tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"writev","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"vectors"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GOutputVector","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"nVectors"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"bytesWritten","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">! = nil, "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"If "},{"code":"nVectors","type":"codeVoice"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is 0, returns 0 and"},{"type":"text","text":" "},{"type":"text","text":"does nothing."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"type":"text","text":" "},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"type":"text","text":" "},{"text":"can happen e.g. on a partial I\/O error, or if there is not enough","type":"text"},{"type":"text","text":" "},{"text":"storage in the stream. All writes block until at least one byte","type":"text"},{"text":" ","type":"text"},{"text":"is written or an error occurs; 0 is never returned (unless","type":"text"},{"type":"text","text":" "},{"code":"nVectors","type":"codeVoice"},{"text":" is 0 or the sum of all bytes in ","type":"text"},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is 0)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If an","type":"text"},{"type":"text","text":" "},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"partial result will be returned, without an error."}]},{"inlineContent":[{"type":"text","text":"Some implementations of "},{"code":"g_output_stream_writev()","type":"codeVoice"},{"text":" may have limitations on the","type":"text"},{"text":" ","type":"text"},{"text":"aggregate buffer size, and will return ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" if these"},{"type":"text","text":" "},{"type":"text","text":"are exceeded. For example, when writing to a local file on UNIX platforms,"},{"text":" ","type":"text"},{"type":"text","text":"the aggregate buffer size must not exceed "},{"code":"G_MAXSSIZE","type":"codeVoice"},{"text":" bytes.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","abstract":[{"type":