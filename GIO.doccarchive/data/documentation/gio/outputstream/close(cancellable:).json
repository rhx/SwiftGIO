{"sections":[],"metadata":{"symbolKind":"method","title":"close(cancellable:)","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"role":"symbol","externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO12OutputStreamC","roleHeading":"Instance Method","extendedModule":"GIO"},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"variants":[{"paths":["\/documentation\/gio\/outputstream\/close(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/OutputStream\/close(cancellable:)","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Closing a stream multiple times will not return an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"stream."}]},{"inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"type":"text","text":" "},{"text":"stream for details.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"text":"operation will finish as much as possible. A stream that failed to","type":"text"},{"text":" ","type":"text"},{"text":"close will still return ","type":"text"},{"code":"closed","type":"codeVoice"},{"text":" for all operations. Still, it","type":"text"},{"type":"text","text":" "},{"text":"is important to check and report the error to the user, otherwise","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"there might be a loss of data as all data might not be written."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"text":"Cancelling a close will still leave the stream closed, but there some streams","type":"text"},{"type":"text","text":" "},{"text":"can use a faster close that doesn’t block to e.g. check errors. On","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"text":"data will reach the target.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStream","doc:\/\/GIO\/documentation\/GIO\/OutputStream\/OutputStreamProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/OutputStream/OutputStreamProtocol-Implementations":{"url":"\/documentation\/gio\/outputstream\/outputstreamprotocol-implementations","abstract":[],"kind":"article","type":"topic","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream\/OutputStreamProtocol-Implementations","title":"OutputStreamProtocol Implementations"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/OutputStream/close(cancellable:)":{"title":"close(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream\/close(cancellable:)","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"url":"\/documentation\/gio\/outputstream\/close(cancellable:)","kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}