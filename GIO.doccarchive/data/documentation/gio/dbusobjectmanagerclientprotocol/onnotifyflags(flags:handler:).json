ng the standardized"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},{"text":" ","type":"text"},{"text":"interface. For example, remote D-Bus clients can get all objects","type":"text"},{"type":"text","text":" "},{"text":"and properties in a single call. Additionally, any change in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object hierarchy is broadcast using signals. This means that D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"clients can keep caches up to date by only listening to D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"signals."}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"DBusObjectManagerServer","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer","role":"symbol","navigatorTitle":[{"text":"DBusObjectManagerServer","kind":"identifier"}]},"doc://GIO/documentation/GIO/DBusObjectManagerClientProtocol":{"role":"symbol","abstract":[{"code":"GDBusObjectManagerClient","type":"codeVoice"},{"type":"text","text":" is used to create, monitor and delete object"},{"text":" ","type":"text"},{"text":"proxies for remote objects exported by a [class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(or any code implementing the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},{"type":"text","text":" "},{"type":"text","text":"interface)."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientProtocol","url":"\/documentation\/gio\/dbusobjectmanagerclientprotocol","fragments":[{"kind":"keyword","text"