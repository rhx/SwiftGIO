"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"type":"text","text":" "},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names"},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::get-proxy-type-destroy-notify"},{"text":" signal","type":"text"}]}],"name":"Note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusobjectmanagerclientprotocol\/onnotifygetproxytypedestroynotify(flags:handler:)"]}],"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"text":"its value set through ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"references":{"http://dbus.freedesktop.org/doc/dbus-specification.html#standard-interfaces-objectmanager":{"title":"org.freedesktop.DBus.ObjectManager","titleInlineContent":[{"type":"text","text":"org.freedesktop.DBus.ObjectManager"}],"url":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager","type":"link","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},"doc://GIO/documentation/GIO/DBusObjectManagerClientProtocol":{"role":"symbol","abstract":[{"code":"GDBusObjectManagerClient","type":"codeVoice"},{"type":"text","text":" is used to create, monitor and delete object"},{"text":" ","type":"text"},{"text":"proxies for remote objects exported by a [class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerServer"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(or any code implementing the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-objectmanager"},{"type":"text","text":" "},{"type":"text","text":"interface)."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectManagerClientProtocol","url":"\/documentation\/gio\/dbusobjectmanagerclientprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","te