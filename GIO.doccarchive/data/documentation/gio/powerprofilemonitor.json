{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"codeVoice","code":"GPowerProfileMonitor"},{"text":" makes it possible for applications as well as OS","type":"text"},{"type":"text","text":" "},{"text":"components to monitor system power profiles and act upon them. It currently","type":"text"},{"type":"text","text":" "},{"text":"only exports whether the system is in “Power Saver” mode (known as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“Low Power” mode on some systems)."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PowerProfileMonitor","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"When in “Low Power” mode, it is recommended that applications:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"disable automatic downloads;","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"reduce the rate of refresh from online sources such as calendar or"},{"type":"text","text":" "},{"type":"text","text":"email synchronisation;"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"reduce the use of expensive visual effects."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also likely that OS components providing services to applications will"},{"text":" ","type":"text"},{"text":"lower their own background activity, for the sake of the system.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There are a variety of tools that exist for power consumption analysis, but those","type":"text"},{"type":"text","text":" "},{"type":"text","text":"usually depend on the OS and hardware used. On Linux, one could use "},{"code":"upower","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"monitor the battery discharge rate, ","type":"text"},{"code":"powertop","type":"codeVoice"},{"text":" to check on the background activity","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or activity at all), "},{"type":"codeVoice","code":"sysprof"},{"type":"text","text":" to inspect CPU usage, and "},{"code":"intel_gpu_time","type":"codeVoice"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"profile GPU usage.","type":"text"}]},{"inlineContent":[{"text":"Don’t forget to disconnect the [signal[Object](\/\/documentation\/gobject\/object\/onnotify(flags:handler:)] signal for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[property"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor","isActive":true},{"text":"], and unref the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GPowerProfileMonitor"},{"text":" itself when exiting.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor","isActive":true},{"type":"text","text":" type acts as an owner of an underlying "},{"type":"codeVoice","code":"GPowerProfileMonitor"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitorProtocol","isActive":true},{"text":" conformance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor","isActive":true},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GPowerProfileMonitor"},{"text":" instance.","type":"text"}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitorRef"},{"text":" (instead of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GPowerProfileMonitor"},{"text":" instance.","type":"text"}]}],"type":"aside","name":"Note"}]}],"topicSections":[{"generated":true,"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(_:)-1ymf8","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(_:)-4ltym","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(_:)-4suil","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(_:)-lybj","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(powerProfileMonitor:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(raw:)-5d7bh","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(raw:)-9qhuc","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(retainingRaw:)-1paf7","doc:\/\/GIO\/documentation\/GIO\/PowerProfileMonitor\/init(retainingRaw:)-5k55a"],"anchor":"Initializers"},{"title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/PowerProfileMo