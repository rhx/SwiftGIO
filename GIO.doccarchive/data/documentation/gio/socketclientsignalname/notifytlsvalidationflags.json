{"abstract":[{"text":"The TLS validation flags used when creating TLS connections. The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"default value is "},{"code":"validateAll","type":"codeVoice"},{"text":".","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketclientsignalname\/notifytlsvalidationflags"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notifyTLSValidationFlags"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"text":" ","type":"text"},{"text":"flag will be set, but it does not guarantee that all possible flags","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be set. Accordingly, you may not safely decide to ignore any"},{"text":" ","type":"text"},{"type":"text","text":"particular type of error. For example, it would be incorrect to mask"},{"type":"text","text":" "},{"type":"codeVoice","code":"expired"},{"text":" if you want to allow expired certificates,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"because this could potentially be the only error flag set even if"},{"type":"text","text":" "},{"type":"text","text":"other problems exist with the certificate. Therefore, there is no"},{"type":"text","text":" "},{"type":"text","text":"safe way to use this property. This is not a horrible problem,"},{"type":"text","text":" "},{"text":"though, because you should not be attempting to ignore validation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"errors anyway. If you really must ignore TLS certificate errors,"},{"text":" ","type":"text"},{"type":"text","text":"connect to the [SocketClient](\/\/documentation\/gio\/socketclient\/onevent(flags:handler:) signal, wait for it to be"},{"type":"text","text":" "},{"text":"emitted with ","type":"text"},{"type":"codeVoice","code":"tlsHandshaking"},{"text":", and use that to","type":"text"},{"type":"text","text":" "},{"text":"connect to [TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"tls-validation-flags is deprecated:"}],"type":"strong"},{"text":" ","type":"text"},{"text":"Do not attempt to ignore validation errors.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"notifyTLSValidationFlags","kind":"identifier"}],"symbolKind":"case","modules":[{"name":"GIO"}],"externalID":"s:3GIO22SocketClientSignalNameO24notifyTLSValidationFlagsyA2CmF","title":"SocketClientSignalName.notifyTLSValidationFlags","role":"symbol","roleHeading":"Case"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketClientSignalName"]]},"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketClientSignalName\/notifyTLSValidationFlags","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/SocketClientSignalName":{"navigatorTitle":[{"text":"SocketClientSignalName","kind":"identifier"}],"role":"symbol","abstract":[],"title":"SocketClientSignalName","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SocketClientSignalName","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientSignalName","type":"topic","url":"\/documentation\/gio\/socketclientsignalname","kind":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SocketClientSignalName/notifyTLSValidationFlags":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientSignalName\/notifyTLSValidationFlags","type":"topic","url":"\/documentation\/gio\/socketclientsignalname\/notifytlsvalidationflags","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notifyTLSValidationFlags","kind":"identifier"}],"abstract":[{"type":"text","text":"The TLS validation flags used when creating TLS connections. The"},{"text":" ","type":"text"},{"text":"default value is ","type":"text"},{"type":"codeVoice","code":"validateAll"},{"type":"text","text":"."}],"kind":"symbol","title":"SocketClientSignalName.notifyTLSValidationFlags","role":"symbol"}}}