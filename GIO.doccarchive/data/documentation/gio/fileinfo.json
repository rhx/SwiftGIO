{"abstract":[{"text":"Stores information about a file system object referenced by a [iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},{"text":"].","type":"text"}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"FileInfo","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"FileInfo"}],"symbolKind":"class","title":"FileInfo","modules":[{"name":"GIO"}],"role":"symbol","roleHeading":"Class","externalID":"s:3GIO8FileInfoC"},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/GIO\/10GLibObject0B0C"],"title":"Inherits From","type":"inheritsFrom"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/FileInfoProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileInfo"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Functionality for manipulating basic metadata for files. ","type":"text"},{"code":"GFileInfo","type":"codeVoice"},{"text":" ","type":"text"},{"text":"implements methods for getting information that all files should","type":"text"},{"type":"text","text":" "},{"text":"contain, and allows for manipulation of extended attributes.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See the "},{"isActive":true,"type":"reference","identifier":"file-attributes.html"},{"type":"text","text":" document for more"},{"type":"text","text":" "},{"type":"text","text":"information on how GIO handles file attributes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To obtain a "},{"type":"codeVoice","code":"GFileInfo"},{"type":"text","text":" for a [iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},{"type":"text","text":"], use"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.File.query_info"},{"text":"] (or its async variant). To obtain a ","type":"text"},{"type":"codeVoice","code":"GFileInfo"},{"text":" ","type":"text"},{"type":"text","text":"for a file input or output stream, use [method"},{"code":"Gio.FileInputStream.query_info","type":"codeVoice"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"or [method"},{"code":"Gio.FileOutputStream.query_info","type":"codeVoice"},{"type":"text","text":"] (or their async variants)."}]},{"inlineContent":[{"text":"To change the actual attributes of a file, you should then set the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"attribute in the "},{"type":"codeVoice","code":"GFileInfo"},{"type":"text","text":" and call [method"},{"type":"codeVoice","code":"Gio.File.set_attributes_from_info"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"or [method","type":"text"},{"type":"codeVoice","code":"Gio.File.set_attributes_async"},{"type":"text","text":"] on a "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"However, not all attributes can be changed in the file. For instance,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the actual size of a file cannot be changed via [method"},{"code":"Gio.FileInfo.set_size","type":"codeVoice"},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"You may call [method","type":"text"},{"code":"Gio.File.query_settable_attributes","type":"codeVoice"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.File.query_writable_namespaces"},{"type":"text","text":"] to discover the settable attributes"},{"type":"text","text":" "},{"text":"of a particular file at runtime.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The direct accessors, such as [method"},{"type":"codeVoice","code":"Gio.FileInfo.get_name"},{"type":"text","text":"], are slightly more"},{"text":" ","type":"text"},{"text":"optimized than the generic attribute accessors, such as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.FileInfo.get_attribute_byte_string","type":"codeVoice"},{"type":"text","text":"].This optimization will matter"},{"type":"text","text":" "},{"type":"text","text":"only if calling the API in a tight loop."}]},{"inlineContent":[{"type":"text","text":"It is an error to call these accessors without specifying their required file"},{"text":" ","type":"text"},{"type":"text","text":"attributes when creating the "},{"type":"codeVoice","code":"GFileInfo"},{"text":". Use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.FileInfo.has_attribute"},{"type":"text","text":"] or [method"},{"type":"codeVoice","code":"Gio.FileInfo.list_attributes"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to check what attributes are specified for a "},{"type":"codeVoice","code":"GFileInfo"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"[struct"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileAttributeMatcher","type":"reference"},{"type":"text","text":"] allows for searching through a "},{"type":"codeVoice","code":"GFileInfo"},{"type":"text","text":" "},{"type":"text","text":"for attributes."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"type":"codeVoice","code":"GFileInfo"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true,"type":"reference"},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GFileInfo"},{"type":"text","text":" instance."}]},{"content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true,"type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GFileInfo","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileinfo"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/FileInfo\/init()","doc:\/\/GIO\/documentation\/GIO\/FileInfo\/init(_:)-48nki","doc:\/\/GIO\/documentation\/GIO\/FileInfo\/init(_:)-55rp7","doc:\/\/GIO\/documentation\/GIO\/FileInfo\/init(_:)-5iw04","doc:\/\/GIO\/documentation\/GIO\/FileInfo\/init(_:)-6ha9p","doc:\/\/GIO\/documentation\/GIO\/FileInfo\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/FileInfo\/init(fileInfo:)","doc:\/\/GIO\/documentation\/GIO\/F