{"kind":"symbol","sections":[],"metadata":{"symbolKind":"case","externalID":"s:3GIO29TLSServerConnectionSignalNameO17acceptCertificateyA2CmF","title":"TLSServerConnectionSignalName.acceptCertificate","role":"symbol","roleHeading":"Case","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"acceptCertificate","kind":"identifier"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsserverconnectionsignalname\/acceptcertificate"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionSignalName\/acceptCertificate","interfaceLanguage":"swift"},"abstract":[{"text":"Emitted during the TLS handshake after the peer certificate has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been received. You can examine "},{"code":"peerCert","type":"codeVoice"},{"text":"’s certification path by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_tls_certificate_get_issuer()"},{"text":" on it.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionSignalName"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"acceptCertificate"}]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a client-side connection, "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" is the server’s"},{"text":" ","type":"text"},{"type":"text","text":"certificate, and the signal will only be emitted if the"},{"text":" ","type":"text"},{"type":"text","text":"certificate was not acceptable according to "},{"code":"conn","type":"codeVoice"},{"text":"’s","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection"},{"text":". If you would like the","type":"text"},{"type":"text","text":" "},{"text":"certificate to be accepted despite ","type":"text"},{"code":"errors","type":"codeVoice"},{"type":"text","text":", return "},{"type":"codeVoice","code":"true"},{"text":" from the","type":"text"},{"type":"text","text":" "},{"text":"signal handler. Otherwise, if no handler accepts the certificate,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the handshake will fail with "},{"type":"codeVoice","code":"badCertificate"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, this signal"},{"text":" ","type":"text"},{"text":"will be emitted with at least one error will be set in ","type":"text"},{"type":"codeVoice","code":"errors"},{"text":", but","type":"text"},{"text":" ","type":"text"},{"text":"it does not guarantee that all possible errors will be set.","type":"text"},{"type":"text","text":" "},{"text":"Accordingly, you may not safely decide to ignore any particular","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"type":"text","text":" "},{"code":"expired","type":"codeVoice"},{"text":" if you want to allow expired","type":"text"},{"type":"text","text":" "},{"text":"certificates, because this could potentially be the only error flag","type":"text"},{"text":" ","type":"text"},{"text":"set even if other problems exist with the certificate.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a server-side connection, "},{"type":"codeVoice","code":"peerCert"},{"text":" is the certificate","type":"text"},{"text":" ","type":"text"},{"text":"presented by the client, if this was requested via the server’s","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection"},{"type":"text","text":". On the server side,"},{"text":" ","type":"text"},{"type":"text","text":"the signal is always emitted when the client presents a"},{"text":" ","type":"text"},{"type":"text","text":"certificate, and the certificate will only be accepted if a"},{"text":" ","type":"text"},{"text":"handler returns ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"text":" ","type":"text"},{"text":"in the main thread, then you should not attempt to interact with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user before returning from the signal handler. If you want to"},{"text":" ","type":"text"},{"type":"text","text":"let the user decide whether or not to accept the certificate, you"},{"text":" ","type":"text"},{"text":"would have to return ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" from the signal handler on the first"},{"type":"text","text":" "},{"text":"attempt, and then after the connection attempt returns a","type":"text"},{"type":"text","text":" "},{"code":"badCertificate","type":"codeVoice"},{"type":"text","text":", you can interact with the user, and"},{"text":" ","type":"text"},{"text":"if the user decides to accept the certificate, remember that fact,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"create a new connection, and return "},{"code":"true","type":"codeVoice"},{"type":"text","text":" from the signal handler"},{"type":"text","text":" "},{"type":"text","text":"the next time."}]},{"type":"paragraph","inlineContent":[{"text":"If you are doing I\/O in another thread, you do not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"need to worry about this, and can simply block in the signal"},{"type":"text","text":" "},{"text":"handler until the UI thread returns an answer.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a server-side TLS connection.","type":"text"}]},"doc://GIO/documentation/GIO/TLSServerConnectionSignalName/acceptCertificate":{"kind":"symbol","title":"TLSServerConnectionSignalName.acceptCertificate","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionSignalName\/acceptCertificate","abstract":[{"text":"Emitted during the TLS handshake after the peer certificate has","type":"text"},{"type":"text","text":" "},{"text":"been received. You can examine ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"text":"’s certification path by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_tls_certificate_get_issuer()"},{"type":"text","text":" on it."}],"url":"\/documentation\/gio\/tlsserverconnectionsignalname\/acceptcertificate","role":"symbol","fragments":[{"text":"case"