{"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionSignalName\/notifyPeerCertificateErrors"},"metadata":{"roleHeading":"Case","role":"symbol","externalID":"s:3GIO29TLSServerConnectionSignalNameO27notifyPeerCertificateErrorsyA2CmF","symbolKind":"case","title":"TLSServerConnectionSignalName.notifyPeerCertificateErrors","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"notifyPeerCertificateErrors"}]},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionSignalName"]]},"abstract":[{"type":"text","text":"The errors noticed while verifying"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true,"type":"reference"},{"type":"text","text":". Normally this should be 0, but"},{"type":"text","text":" "},{"type":"text","text":"it may not be if "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","type":"reference","isActive":true},{"type":"text","text":" is not"},{"text":" ","type":"text"},{"type":"codeVoice","code":"validateAll"},{"type":"text","text":", or if"},{"type":"text","text":" "},{"text":"[TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:) overrode the default","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behavior."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsserverconnectionsignalname\/notifypeercertificateerrors"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notifyPeerCertificateErrors"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least"},{"type":"text","text":" "},{"type":"text","text":"one error will be set, but it does not guarantee that all possible"},{"type":"text","text":" "},{"text":"errors will be set. Accordingly, you may not safely decide to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ignore any particular type of error. For example, it would be"},{"type":"text","text":" "},{"type":"text","text":"incorrect to mask "},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow"},{"text":" ","type":"text"},{"type":"text","text":"expired certificates, because this could potentially be the only"},{"text":" ","type":"text"},{"type":"text","text":"error flag set even if other problems exist with the certificate."}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSServerConnectionSignalName":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TLSServerConnectionSignalName"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionSignalName","url":"\/documentation\/gio\/tlsserverconnectionsignalname","abstract":[],"role":"symbol","navigatorTitle":[{"text":"TLSServerConnectionSignalName","kind":"identifier"}],"title":"TLSServerConnectionSignalName"},"doc://GIO/documentation/GIO/TLSServerConnectionSignalName/notifyPeerCertificateErrors":{"abstract":[{"type":"text","text":"The errors noticed while verifying"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"text":". Normally this should be 0, but","type":"text"},{"text":" ","type":"text"},{"type":"text","text":