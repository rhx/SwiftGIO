{"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"validationFlags","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"GLib guarantees that if certificate verification fails, at least one","type":"text"},{"type":"text","text":" "},{"type":"text","text":"flag will be set, but it does not guarantee that all possible flags"},{"text":" ","type":"text"},{"text":"will be set. Accordingly, you may not safely decide to ignore any","type":"text"},{"type":"text","text":" "},{"text":"particular type of error. For example, it would be incorrect to mask","type":"text"},{"type":"text","text":" "},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow expired certificates,"},{"text":" ","type":"text"},{"type":"text","text":"because this could potentially be the only error flag set even if"},{"type":"text","text":" "},{"type":"text","text":"other problems exist with the certificate. Therefore, there is no"},{"type":"text","text":" "},{"type":"text","text":"safe way to use this property. This is not a horrible problem,"},{"type":"text","text":" "},{"text":"though, because you should not be attempting to ignore validation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"errors anyway. If you really must ignore TLS certificate errors,"},{"type":"text","text":" "},{"type":"text","text":"connect to [DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:)."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"validation-flags is deprecated:","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"Do not attempt to ignore validation errors."}],"type":"paragraph"}]}],"kind":"symbol","metadata":{"roleHeading":"Case","title":"DtlsClientConnectionPropertyName.validationFlags","role":"symbol","externalID":"s:3GIO32DtlsClientConnectionPropertyNameO15validationFlagsyA2CmF","symbolKind":"case","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"validationFlags","kind":"identifier"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionPropertyName\/validationFlags","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionPropertyName"]]},"abstract":[{"text":"What steps to perform when validating a certificate received from","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a server. Server certificates that fail to validate in any of the"},{"type":"text","text":" "},{"text":"ways indicated here will be rejected unless the application","type":"text"},{"text":" ","type":"text"},{"text":"overrides the default via [DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:).","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsclientconnectionpropertyname\/validationflags"]}],"references":{"doc://GIO/documentation/GIO/DtlsClientConnectionPropertyName":{"type":"topic","kind":"symbol","navigatorTitle":[{"text":"DtlsClientConnectionPropertyName","kind":"identifier"}],"url":"\/documentation\/gio\/dtlsclientconnectionpropertyname","role":"symbol","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionPropertyName","title":"DtlsClientConnectionPropertyName","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DtlsClientConnectionPropertyName"}]},"doc://GIO/documentation/GIO/DtlsClientConnectionPropertyName/validationFlags":{"kind":"symbol","title":"DtlsClientConnectionPropertyName.validationFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionPropertyName\/validationFlags","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"validationFlags"}],"abstract":[{"type":"text","text":"What steps to perform when validating a certificate received from"},{"type":"text","text":" "},{"text":"a server. Server certificates that fail to validate in any of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ways indicated here will be rejected unless the application"},{"type":"text","text":" "},{"type":"text","text":"overrides the default via [DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:)."}],"url":"\/documentation\/gio\/dtlsclientconnectionpropertyname\/validationflags","role":"symbol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}