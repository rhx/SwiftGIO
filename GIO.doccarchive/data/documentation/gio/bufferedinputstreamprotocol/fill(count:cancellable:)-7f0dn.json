{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamProtocol"]]},"metadata":{"symbolKind":"method","externalID":"s:3GIO27BufferedInputStreamProtocolPAAE4fill5count11cancellableS2i_AA14CancellableRefVSgtKF","extendedModule":"GIO","title":"fill(count:cancellable:)","role":"symbol","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fill"},{"kind":"text","text":"("},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"text":"gssize","preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize"}]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"fill","kind":"identifier"},{"kind":"text","text":"("},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier","text":"gssize"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"gssize","preciseIdentifier":"c:glibconfig.h@T@gssize"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" is zero, returns zero and does nothing. A value of "},{"code":"count","type":"codeVoice"},{"text":" ","type":"text"},{"text":"larger than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"text":" will cause a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[error"},{"type":"codeVoice","code":"Gio.IOErrorEnum.INVALID_ARGUMENT"},{"type":"text","text":"] error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On success, the number of bytes read into the buffer is returned."},{"text":" ","type":"text"},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"type":"text","text":" "},{"text":"can happen e.g. near the end of a file. Zero is returned on end of file","type":"text"},{"type":"text","text":" "},{"text":"(or if ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" is zero),  but never otherwise.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"count","type":"codeVoice"},{"type":"text","text":" is -1 then the attempted read size is equal to the number of"},{"text":" ","type":"text"},{"type":"text","text":"bytes that are required to fill the buffer."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"text":"was cancelled, the error [error","type":"text"},{"type":"codeVoice","code":"Gio.IOErrorEnum.CANCELLED"},{"text":"] will be returned.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If an operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"text":"partial result will be returned, without an error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On error "},{"type":"codeVoice","code":"-1"},{"text":" is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For the asynchronous, non-blocking, version of this function, see","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.BufferedInputStream.fill_async"},{"text":"].","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/bufferedinputstreamprotocol\/fill(count:cancellable:)-7f0dn"]}],"abstract":[{"type":"text","text":"Tries to read "},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from the stream into the buffer."},{"text":" ","type":"text"},{"type":"text","text":"Will block during this read."}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamProtocol\/fill(count:cancellable:)-7f0dn","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/BufferedInputStreamProtocol":{"kind":"symbol","navigatorTitle":[{"text":"BufferedInputStreamProtocol","kind":"identifier"}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"BufferedInputStreamProtocol","kind":"identifier"}],"title":"BufferedInputStreamProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamProtocol","url":"\/documentation\/gio\/bufferedinputstreamprotocol","abstract":[{"type":"text","text":"Buffered input stream implements [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStream","isActive":true,"type":"reference"},{"type":"text","text":"] and provides"},{"type":"text","text":" "},{"text":"for buffered reads.","type":"text"}],"type":"topic"},"doc://GIO/documentation/GIO/FilterInputStream":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStream","role":"symbol","url":"\/documentation\/gio\/filterinputstream","abstract":[{"type":"text","text":"Base class for input stream implementations that perform some"},{"text":" ","type":"text"},{"text":"kind of filtering operation on a base stream. Typical examples","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of filtering operations are character set conversion, compression"},{"type":"text","text":" "},{"text":"and byte order flipping.","type":"text"}],"navigatorTitle":[{"text":"FilterInputStream","kind":"identifier"}],"title":"FilterInputStream","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FilterInputStream"}],"type":"topic"},"doc://GIO/documentation/GIO/BufferedInputStreamProtocol/fill(count:cancellable:)-7f0dn":{"url":"\/documentation\/gio\/bufferedinputstreamprotocol\/fill(count:cancellable:)-7f0dn","type":"topic","role":"symbol","kind":"symbol","abstract":[{"text":"Tries to read ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from the stream into the buffer."},{"text":" ","type":"text"},{"type":"text","text":"Will block during this read."}],"title":"fill(count:cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamProtocol\/fill(count:cancellable:)-7f0dn","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"fill","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14Cancellab