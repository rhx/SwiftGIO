"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" is -1 then the attempted read size is equal to the number of"},{"type":"text","text":" "},{"text":"bytes that are required to fill the buffer.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error [error"},{"code":"Gio.IOErrorEnum.CANCELLED","type":"codeVoice"},{"text":"] will be returned.","type":"text"},{"type":"text","text":" "},{"text":"If an operation was partially finished when the operation was cancelled the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}]},{"inlineContent":[{"type":"text","text":"On error "},{"type":"codeVoice","code":"-1"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the asynchronous, non-blocking, version of this function, see"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.BufferedInputStream.fill_async"},{"type":"text","text":"]."}]}]}],"references":{"doc://GIO/documentation/GIO/BufferedInputStreamProtocol":{"kind":"symbol","navigatorTitle":[{"text":"BufferedInputStreamProtocol","kind":"identifier"}],"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"BufferedInputStreamProtocol","kind":"identifier"}],"title":"BufferedInputStreamProtocol","identifier":"doc:\/\/GIO\/docum