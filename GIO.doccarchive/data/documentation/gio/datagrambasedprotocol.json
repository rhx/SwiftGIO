"text","text":" "},{"text":"[Source](\/\/documentation\/glib\/source keeps a reference to the ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":"."}]},"doc://GIO/documentation/GIO/DatagramBasedProtocol/dtlsClientConnectionNew(serverIdentity:)-8xcfh":{"abstract":[{"text":"Creates a new ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection"},{"text":" wrapping ","type":"text"},{"code":"baseSocket","type":"codeVoice"},{"type":"text","text":" which is"},{"type":"text","text":" "},{"type":"text","text":"assumed to communicate with the server identified by "},{"type":"codeVoice","code":"serverIdentity"},{"type":"text","text":"."}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/dtlsClientConnectionNew(serverIdentity:)-8xcfh","role":"symbol","url":"\/documentation\/gio\/datagrambasedprotocol\/dtlsclientconnectionnew(serveridentity:)-8xcfh","title":"dtlsClientConnectionNew(serverIdentity:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"dtlsClientConnectionNew","kind":"identifier"},{"kind":"text","text":"<"},{"text":"SocketConnectableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"serverIdentity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"SocketConnectableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"DtlsClientConnectionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO23DtlsClientConnectionRefV"},{"kind":"text","text":"!"}],"kind":"symbol"},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/DatagramBasedProtocol/receive(messages:numMessages:flags:timeout:cancellable:)-2w81h":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/receive(messages:numMessages:flags:timeout:cancellable:)-2w81h","url":"\/documentation\/gio\/datagrambasedprotocol\/receive(messages:nummessages:flags:timeout:cancellable:)-2w81h","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"receive"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64","text":"gint64"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"type":"topic","role":"symbol","title":"receive(messages:numMessages:flags:timeout:cancellable:)","abstract":[{"text":"Receive one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"text":" in one go.","type":"text"}]},"doc://GIO/documentation/GIO/DtlsConnection":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DtlsConnection","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"DtlsConnection"}],"abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"type":"text","text":" is the base DTLS connection class type, which wraps"},{"text":" ","type":"text"},{"text":"a [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"text":"] and provides DTLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"text":"subclasses, [iface","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection"},{"text":"] and","type":"text"},{"type":"text","text":" "},{"text":"[iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","isActive":true,"type":"reference"},{"text":"], implement client-side and server-side DTLS,","type":"text"},{"text":" ","type":"text"},{"text":"respectively.","type":"text"}],"title":"DtlsConnection","url":"\/documentation\/gio\/dtlsconnection"},"doc://GIO/documentation/GIO/DatagramBasedProtocol/conditionWait(condition:timeout:cancellable:)-9pwak":{"role":"symbol","kind":"symbol","title":"conditionWait(condition:timeout:cancellable:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"condi