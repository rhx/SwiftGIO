{"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/gio\/datagrambasedprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"protocol","navigatorTitle":[{"text":"DatagramBasedProtocol","kind":"identifier"}],"externalID":"s:3GIO21DatagramBasedProtocolP","role":"symbol","modules":[{"name":"GIO"}],"title":"DatagramBasedProtocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DatagramBasedProtocol"}],"roleHeading":"Protocol"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Interface for socket-like objects with datagram semantics."}],"topicSections":[{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/datagram_based_ptr-9b0pk"],"generated":true},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/conditionCheck(condition:)","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/conditionWait(condition:timeout:cancellable:)-2bi1f","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/conditionWait(condition:timeout:cancellable:)-9pwak","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/createSource(condition:cancellable:)-6ktoj","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/createSource(condition:cancellable:)-7zbag","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/dtlsClientConnectionNew(serverIdentity:)-62a72","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/dtlsClientConnectionNew(serverIdentity:)-8xcfh","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/dtlsServerConnectionNew(certificate:)-6l5dc","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/dtlsServerConnectionNew(certificate:)-qz52","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/receive(messages:numMessages:flags:timeout:cancellable:)-2w81h","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/receive(messages:numMessages:flags:timeout:cancellable:)-4crmz","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/send(messages:numMessages:flags:timeout:cancellable:)-5ji3h","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol\/send(messages:numMessages:flags:timeout:cancellable:)-5yayj"],"title":"Instance Methods","anchor":"Instance-Methods"}],"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP"],"kind":"relationships","type":"inheritsFrom","title":"Inherits From"},{"title":"Inherited By","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionProtocol","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol","doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnectionProtocol","doc:\/\/GIO\/documentation\/GIO\/SocketProtocol"],"type":"inheritedBy","kind":"relationships"},{"title":"Conforming Types","type":"conformingTypes","kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DatagramBased","doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef","doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnectionRef","doc:\/\/GIO\/documentation\/GIO\/Socket","doc:\/\/GIO\/documentation\/GIO\/SocketRef"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DatagramBasedProtocol","kind":"identifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4GLib14PointerWrapperP","text":"PointerWrapper","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"text","text":"A "},{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":" is a networking interface for representing datagram-based"},{"type":"text","text":" "},{"type":"text","text":"communications. It is a more or less direct mapping of the core parts of the"},{"type":"text","text":" "},{"text":"BSD socket API in a portable GObject interface. It is implemented by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true,"type":"reference"},{"type":"text","text":"], which wraps the UNIX socket API on UNIX and winsock2 on Windows."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":" is entirely platform independent, and is intended to be used"},{"type":"text","text":" "},{"text":"alongside higher-level networking APIs such as [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"It uses vectored scatter\/gather I\/O by default, allowing for many messages"},{"text":" ","type":"text"},{"text":"to be sent or received in a single call. Where possible, implementations of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the interface should take advantage of vectored I\/O to minimise processing"},{"type":"text","text":" "},{"text":"or system calls. For example, ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"text":" uses ","type":"text"},{"type":"codeVoice","code":"recvmmsg()"},{"type":"text","text":" and "},{"code":"sendmmsg()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"where possible. Callers should take advantage of scatter\/gather I\/O (the use of"},{"type":"text","text":" "},{"type":"text","text":"multiple buffers per message) to avoid unnecessary copying of data to"},{"type":"text","text":" "},{"type":"text","text":"assemble or disassemble a message."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each "},{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":" operation has a timeout parameter which may be negative"},{"type":"text","text":" "},{"type":"text","text":"for blocking behaviour, zero for non-blocking behaviour, or positive for"},{"text":" ","type":"text"},{"text":"timeout behaviour. A blocking operation blocks until finished or there is an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"error. A non-blocking operation will return immediately with a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_IO_ERROR_WOULD_BLOCK"},{"text":" error if it cannot make progress. A timeout operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will block until the operation is complete or the timeout expires; if the"},{"type":"text","text":" "},{"text":"timeout expires it will return what progress it made, or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_IO_ERROR_TIMED_OUT"},{"text":" if no progress was made. To know when a call would","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"successfully run you can call [method"},{"code":"Gio.DatagramBased.condition_check","type":"codeVoice"},{"text":"] or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.DatagramBased.condition_wait"},{"type":"text","text":"]. You can also use"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.DatagramBased.create_source"},{"text":"] and attach it to a [struct[MainContext](\/\/documentation\/glib\/maincontext]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to get callbacks when I\/O is possible."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When running a non-blocking operation applications should always be able to"},{"text":" ","type":"text"},{"text":"handle getting a ","type":"text"},{"code":"G_IO_ERROR_WOULD_BLOCK","type":"codeVoice"},{"type":"text","text":" error even when some other function"},{"type":"text","text":" "},{"type":"text","text":"said that I\/O was possible. This can easily happen in case of a race"},{"type":"text","text":" "},{"text":"condition in the application, but it can also happen for other reasons. For","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instance, on Windows a socket is always seen as writable until a write"},{"text":" ","type":"text"},{"type":"text","text":"returns "},{"type":"codeVoice","code":"G_IO_ERROR_WOULD_BLOCK"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As with "},{"type":"codeVoice","code":"GSocket"},{"text":", ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":"s can be either connection oriented (for"},{"text":" ","type":"text"},{"type":"text","text":"example, SCTP) or connectionless (for example, UDP). "},{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":"s must be"},{"text":" ","type":"text"},{"type":"text","text":"datagram-based, not stream-based. The interface does not cover connection"},{"type":"text","text":" "},{"type":"text","text":"establishment — use methods on the underlying type to establish a connection"},{"text":" ","type":"text"},{"type":"text","text":"before sending and receiving data through the "},{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":" API. For"},{"type":"text","text":" "},{"type":"text","text":"connectionless socket types the target\/source address is specified or"},{"text":" ","type":"text"},{"text":"received in each I\/O operation.","type":"text"}]},{"inlineContent":[{"text":"Like most other APIs in GLib, ","type":"text"},{"code":"GDatagramBased","type":"codeVoice"},{"type":"text","text":" is not inherently thread safe."},{"text":" ","type":"text"},{"type":"text","text":"To use a "},{"type":"codeVoice","code":"GDatagramBased"},{"text":" concurrently from multiple threads, you must","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implement your own locking."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedProtocol"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GDatagramBased"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true,"type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBasedRef","isActive":true},{"text":" as a lighweight, ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/DatagramBasedProtocol/datagram_based_ptr-9b0pk":{"required":true,"type":"topic","kind":"symbol","url":"\/documentation\/gio\/datagrambasedprotocol\/datagram_based_ptr-9b0pk","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"datagram_based_ptr","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GDatagramBased"},{"kind":"text","text":">!"}],"identifier":"doc:\/\/GIO\/documentati