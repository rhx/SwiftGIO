{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/bufferedinputstreamref\/fill(count:cancellable:)"]}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"GIO"}],"title":"fill(count:cancellable:)","externalID":"s:3GIO27BufferedInputStreamProtocolPAAE4fill5count11cancellableS2i_AA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO22BufferedInputStreamRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"fill","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize"}],"extendedModule":"GIO","role":"symbol","symbolKind":"method","roleHeading":"Instance Method"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamRef\/fill(count:cancellable:)"},"kind":"symbol","abstract":[{"type":"text","text":"Tries to read "},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from the stream into the buffer."},{"type":"text","text":" "},{"type":"text","text":"Will block during this read."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fill"},{"kind":"text","text":"("},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externa