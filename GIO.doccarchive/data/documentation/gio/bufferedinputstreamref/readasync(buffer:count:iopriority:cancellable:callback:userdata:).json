{"abstract":[{"type":"text","text":"Request an asynchronous read of "},{"type":"codeVoice","code":"count"},{"text":" bytes from the stream into the buffer","type":"text"},{"type":"text","text":" "},{"type":"text","text":"starting at "},{"type":"codeVoice","code":"buffer"},{"type":"text","text":". When the operation is finished "},{"type":"codeVoice","code":"callback"},{"text":" will be called.","type":"text"},{"text":" ","type":"text"},{"text":"You can then call ","type":"text"},{"code":"g_input_stream_read_finish()","type":"codeVoice"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"text":"operation.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamRef\/readAsync(buffer:count:ioPriority:cancellable:callback:userData:)","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAsync"},{"kind":"text","text":"("},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"kind":"text","text":"!, "},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","p