{"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"readBytes","kind":"identifier"},{"kind":"text","text":"("},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef"},{"text":"!","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If count is zero, returns a zero-length [Bytes](\/\/documentation\/glib\/bytes and does nothing. A"},{"type":"text","text":" "},{"type":"text","text":"value of "},{"code":"count","type":"codeVoice"},{"text":" larger than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"type":"text","text":" "},{"code":"invalidArgument","type":"codeVoice"},{"type":"text","text":" error."}]},{"inlineContent":[{"text":"On success, a new [Bytes](\/\/documentation\/glib\/bytes is returned. It is not an error if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"size of this object is not the same as the requested size, as it"},{"type":"text","text":" "},{"type":"text","text":"can happen e.g. near the end of a file. A zero-length [Bytes](\/\/documentation\/glib\/bytes is"},{"type":"text","text":" "},{"type":"text","text":"returned on end of file (or if "},{"type":"codeVoice","code":"count"},{"text":" is zero), but never","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"otherwise."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If an","type":"text"},{"text":" ","type":"text"},{"text":"operation was partially finished when the operation was cancelled the","type":"text"},{"text":" ","type":"text"},{"text":"partial result will be returned, without an error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On error "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}],"type":"paragraph"}]}],"metadata":{"title":"readBytes(count:cancellable:)","roleHeading":"Instance Method","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","externalID":"s:3GIO19InputStreamProtocolPAAE9readBytes5count11cancellable4GLib0F3RefVSgSi_AA011CancellableJ0VSgtKF::SYNTHESIZED::s:3GIO22BufferedInputStreamRefV","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readBytes"},{"text":"(","kind":"text"},{"text":"count","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}]},"abstract":[{"text":"Like ","type":"text"},{"code":"g_input_stream_read()","type":"codeVoice"},{"type":"text","text":", this tries to read "},{"code":"count","type":"codeVoice"},{"text":" bytes from","type":"text"},{"text":" ","type":"text"},{"text":"the stream in a blocking fashion. However, rather than reading into","type":"text"},{"type":"text","text":" "},{"text":"a user-supplied buffer, this will create a new [Bytes](\/\/documentation\/glib\/bytes containing","type":"text"},{"text":" ","type":"text"},{"text":"the data that was read. This may be easier to use from language","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"bindings."}],"variants":[{"paths":["\/documentation\/gio\/bufferedinputstreamref\/readbytes(count:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamRef\/readBytes(count:cancellable:)","interfaceLanguage":"swift"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamRef\/InputStreamProtocol-Implementations"]]},"kind":"symbol","references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/BufferedInputStreamRef/InputStreamProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStreamRef\/InputStreamProtocol-Implementations","url":"\/documentation\/gio\/bufferedinputstreamref\/inputstreamprotocol-implementations","abstract":[],"title":"InputStreamProtocol Implementations","type":"topic","role":"collectionGroup","kind":"article"},"doc://GIO/documentation/GIO/FilterInputStream