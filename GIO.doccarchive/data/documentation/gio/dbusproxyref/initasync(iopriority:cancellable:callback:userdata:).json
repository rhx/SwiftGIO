{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/AsyncInitableProtocol-Implementations"]]},"metadata":{"role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"initAsync","kind":"identifier"},{"kind":"text","text":"("},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"?)","kind":"text"}],"title":"initAsync(ioPriority:cancellable:callback:userData:)","extendedModule":"GIO","externalID":"s:3GIO21AsyncInitableProtocolPAAE04initB010ioPriority11cancellable8callback8userDataySi_AA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgATtF::SYNTHESIZED::s:3GIO12DBusProxyRefV","roleHeading":"Instance Method","modules":[{"name":"GIO"}]},"kind":"symbol","sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"initAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_async_initable_new_async()"},{"type":"text","text":" should typically be used instead."}]},{"inlineContent":[{"type":"text","text":"When the initialization is finished, "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called. You can"},{"type":"text","text":" "},{"text":"then call ","type":"text"},{"type":"codeVoice","code":"g_async_initable_init_finish()"},{"text":" to get the result of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialization."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then initialization can be cancelled by triggering the cancellable"},{"text":" ","type":"text"},{"type":"text","text":"object from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", and"},{"text":" ","type":"text"},{"type":"text","text":"the object doesn’t support cancellable initialization, the error"},{"text":" ","type":"text"},{"code":"notSupported","type":"codeVoice"},{"type":"text","text":" will be returned."}]},{"inlineContent":[{"text":"As with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":", if the object is not initialized, or initialization"},{"type":"text","text":" "},{"text":"returns with an error, then all operations on the object except","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref()"},{"type":"text","text":" and "},{"code":"g_object_unref()","type":"codeVoice"},{"text":" are considered to be invalid, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have undefined behaviour. They will often fail with "},{"type":"codeVoice","code":"g_critical()"},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"g_warning()","type":"codeVoice"},{"text":", but this must not be relied on.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference","isActive":true},{"type":"text","text":" can"},{"text":" ","type":"text"},{"text":"be initialized multiple times; for more information, see ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"If a class explicitly supports being initialized multiple times,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation requires yielding all subsequent calls to "},{"type":"codeVoice","code":"init_async()"},{"type":"text","text":" on the"},{"text":" ","type":"text"},{"type":"text","text":"results of the first call."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For classes that also support the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"text":" interface, the default","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation of this method will run the "},{"code":"g_initable_init()","type":"codeVoice"},{"text":" function","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in a thread, so if you want to support asynchronous initialization via"},{"type":"text","text":" "},{"type":"text","text":"threads, just implement the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true,"type":"reference"},{"type":"text","text":" interface without overriding"},{"text":" ","type":"text"},{"type":"text","text":"any interface methods."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusproxyref\/initasync(iopriority:cancellable:callback:userdata:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/initAsync(ioPriority:cancellable:callback:userData:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"Starts asynchronous initialization of the object implementing the","type":"text"},{"text":" ","type":"text"},{"text":"interface. This must be done before any real use of the object after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initial construction. If the object also implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"type":"text","text":" you can"},{"text":" ","type":"text"},{"text":"optionally call ","type":"text"},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":" instead."}],"references":{"doc://GIO/documentation/GIO/DBusProxyRef":{"role":"symbol","title":"DBusProxyRef","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef","abstract":[{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":" is a base class used for proxies to access a D-Bus"},{"type":"text","text":" "},{"text":"interface on a remote object. A ","type":"text"},{"type":"codeVoice","code":"GDBusProxy"},{"type":"text","text":" can be constructed for"},{"text":" ","type":"text"},{"type":"text","text":"both well-known and unique names."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusProxyRef"}],"navigatorTitle":[{"kind":"identifier","text":"DBusProxyRef"}],"url":"\/documentation\/gio\/dbusproxyref"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol"