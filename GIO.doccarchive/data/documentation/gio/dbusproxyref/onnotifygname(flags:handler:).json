{"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusproxyref\/onnotifygname(flags:handler:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef","doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/DBusProxyProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onNotifyGName"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier","text":"ConnectFlags"},{"kind":"text","text":" = ConnectFlags(0), "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:3GIO12DBusProxyRefV","text":"DBusProxyRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}]},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"text":" ","type":"text"},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"notifyGName"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}],"name":"handler"}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"text":" as","type":"text"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::g-name"},{"type":"text","text":" signal"}]}],"style":"note","name":"Note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusProxyRef\/onNotifyGName(flags:handler:)","interfaceLanguage":"swift"},"sections":[],"metadata":{"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyGName","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO12DBusProxyRefV","text":"DBusProxyRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"role":"symbol","modules":[{"name":"GI