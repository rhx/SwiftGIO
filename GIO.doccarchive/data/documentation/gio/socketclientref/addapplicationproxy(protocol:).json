 has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/InetSocketAddress":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InetSocketAddress"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress","abstract":[{"text":"An IPv4 or IPv6 socket address. That is, the combination of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddress","isActive":true,"type":"reference"},{"type":"text","text":"] and a port number."}],"url":"\/documentation\/gio\/inetsocketaddress","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"InetSocketAddress","kind":"identifier"}],"type":"topic","title":"InetSocketAddress"},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","url":"\/documentation\/gio\/socketconnection","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"type":"text","text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"