{"variants":[{"paths":["\/documentation\/gio\/socketclientref\/addapplicationproxy(protocol:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Enable proxy protocols to be handled by the application. When the"},{"text":" ","type":"text"},{"type":"text","text":"indicated proxy protocol is returned by the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyResolver"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":" will consider this protocol as supported but will","type":"text"},{"text":" ","type":"text"},{"text":"not try to find a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Proxy"},{"type":"text","text":" instance to handle handshaking. The"},{"type":"text","text":" "},{"text":"application must check for this case by calling","type":"text"},{"type":"text","text":" "},{"code":"g_socket_connection_get_remote_address()","type":"codeVoice"},{"text":" on the returned","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference"},{"text":", and seeing if it’s a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ProxyAddress"},{"type":"text","text":" of the"},{"text":" ","type":"text"},{"type":"text","text":"appropriate type, to determine whether or not it needs to handle"},{"type":"text","text":" "},{"text":"the proxy handshaking itself.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addApplicationProxy","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"protocol"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typ