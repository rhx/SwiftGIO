ntentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"connectToHost"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"hostAndPort"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"defaultPort","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"guint16","kind":"typeIdentifier","preciseIdentifier":"c:@T@guint16"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectionRef","preciseIdentifier":"s:3GIO19SocketConnectionRefV","text":"SocketConnectionRef"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"Attempts to create a TCP connection to the named host.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"hostAndPort"},{"type":"text","text":" may be in any of a number of recognized formats; an IPv6"},{"type":"text","text":" "},{"text":"address, an IPv4 address, or a domain name (in which case a DNS","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lookup is performed).  Quoting with [] is supported for all address"},{"text":" ","type":"text"},{"type":"text","text":"types.  A port override may be specified in the usual way with a"},{"type":"text","text":" "},{"text":"colon.  Ports may be given as decimal numbers or symbolic names (in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which case an \/etc\/services lookup is performed)."}]},{"inlineContent":[{"type":"text","text":"If no port override is given in "},{"type":"codeVoice","code":"hostAndPort"},{"text":" then ","type":"text"},{"code":"defaultPort","type":"codeVoice"},{"text":" will be","type":"text"},{"type":"text","text":" "},{"text":"used as the port number to connect to.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In general, ","type":"text"},{"type":"codeVoice","code":"hostAndPort"},{"type":"text","text":" is expected to be provided by the user (allowing"},{"type":"text","text":" "},{"type":"text","text":"them to give the hostname, and a port override if necessary) and"},{"type":"text","text":" "},{"code":"defaultPort","type":"codeVoice"},{"type":"text","text":" is expected to be provided by the application."}]},{"type":"paragraph","inlineContent":[{"text":"In the case that an IP address is given, a single connection","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"attempt is made.  In the case that a name is given, multiple"},{"type":"text","text":" "},{"type":"text","text":"connection attempts may be made, in turn and according to the"},{"text":" ","type":"text"},{"type":"text","text":"number of address records in DNS, until a connection succeeds."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Upon a successful connection, a new "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference","isActive":true},{"text":" is constructed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and returned.  The caller owns this new object and must drop their"},{"text":" ","type":"text"},{"text":"reference to it when finished with it.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In the event of any failure (DNS error, service not found, no hosts"},{"type":"text","text":" "},{"type":"text","text":"connectable) "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"text":" (if non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":") is set","type":"text"},{"text":" ","type":"text"},{"text":"accordingly.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"This is a helper function for "},{"code":"g_socket_client_connect()","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/SocketListener":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"topic","url":"\/documentation\/gio\/socketlistener","kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GSocketListener","type":"codeVoice"},{"text":" is an object that keeps track of a set","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of server sockets and helps you accept sockets from any of the"},{"text":" ","type":"text"},{"type":"text","text":"socket, either sync or async."}],"title":"SocketLis