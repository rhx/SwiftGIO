,"doc:\/\/GIO\/documentation\/GIO\/SocketClientRef\/SocketClientProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyProtocol"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"text":"SocketClientRef","preciseIdentifier":"s:3GIO15SocketClientRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The signal handler to call"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyProtocol"},{"text":" signal is emitted","type":"text"}]}],"name":"handler"}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names"},{"text":" as","type":"text"},{"text":" ","type":"text"},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::protocol"},{"text":" signal","type":"text"}]}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SocketClientRef":{"title":"SocketClientRef","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClientRef"}],"navigatorTitle":[{"kind":"identifier","text":"SocketClientRef"}],"url":"\/documentation\/gio\/socketclientref","type":"topic","abstract":[{"code":"GSocketClient","type":"codeVoice"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientRef","role":"symbol"},"#class@GObject.ParamSpec#parameter-names":{"titleInlineContent":[{"text":"canonical parameter names","type":"text"}],"type":"link","identifier":"#class@GObject.ParamSpec#parameter-names","title":"canonical parameter names","url":"#class@GObject.ParamSpec#parameter-names"},"doc://GIO/documentation/GIO/SocketClientRef/SocketClientProtocol-Implementations":{"abstract":[],"url":"\/documentation\/gio\/socketclientref\/socketclientprotocol-implementations","type":"topic","kind":"article","title":"SocketClientProtocol Implementations","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClientRef\/SocketClientProtocol-Implementations"},"doc://GIO/documentation/GIO/SocketClientRef/onNotifyProtocol(flags:handler:)":{"url"