{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/debugcontrollerdbusref"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DebugControllerDBusRef"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"text":"It is a [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"text":"] object, and will register an object at","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\/org\/gtk\/Debugging"},{"type":"text","text":" on the bus given as"},{"type":"text","text":" "},{"text":"[property","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","isActive":true,"type":"reference"},{"text":"] once it’s initialized. The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object will be unregistered when the last reference to the"},{"text":" ","type":"text"},{"code":"GDebugControllerDBus","type":"codeVoice"},{"text":" is dropped.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This D-Bus object can be used by remote processes to enable or disable debug"},{"text":" ","type":"text"},{"text":"output in this process. Remote processes calling","type":"text"},{"type":"text","text":" "},{"code":"org.gtk.Debugging.SetDebugEnabled()","type":"codeVoice"},{"type":"text","text":" will affect the value of"},{"text":" ","type":"text"},{"text":"[property","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","type":"reference","isActive":true},{"type":"text","text":"] and, by default,"},{"text":" ","type":"text"},{"type":"text","text":"[func"},{"code":"GLib.log_get_debug_enabled","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, no processes are allowed to call "},{"type":"codeVoice","code":"SetDebugEnabled()"},{"type":"text","text":" unless a"},{"text":" ","type":"text"},{"type":"text","text":"[signal[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:)] signal handler is installed. This"},{"type":"text","text":" "},{"type":"text","text":"is because the process may be privileged, or might expose sensitive"},{"type":"text","text":" "},{"text":"information in its debug output. You may want to restrict the ability to","type":"text"},{"type":"text","text":" "},{"text":"enable debug output to privileged users or processes.","type":"text"}]},{"inlineContent":[{"type":"text","text":"One option is to install a D-Bus security policy which restricts access to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"SetDebugEnabled()"},{"type":"text","text":", installing something like the following in"},{"text":" ","type":"text"},{"code":"$datadir\/dbus-1\/system.d\/","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["<?xml version=\"1.0\"?> <!--*-nxml-*-->","<!DOCTYPE busconfig PUBLIC \"-\/\/freedesktop\/\/DTD D-BUS Bus Configuration 1.0\/\/EN\"","     \"http:\/\/www.freedesktop.org\/standards\/dbus\/1.0\/busconfig.dtd\">","<busconfig>","  <policy user=\"root\">","    <allow send_destination=\"com.example.MyService\" send_interface=\"org.gtk.Debugging\"\/>","  <\/policy>","  <policy context=\"default\">","    <deny send_destination=\"com.example.MyService\" send_interface=\"org.gtk.Debugging\"\/>","  <\/policy>","<\/busconfig>"],"syntax":"xml"},{"inlineContent":[{"text":"This will prevent the ","type":"text"},{"code":"SetDebugEnabled()","type":"codeVoice"},{"type":"text","text":" method from being called by all"},{"type":"text","text":" "},{"text":"except root. It will not prevent the ","type":"text"},{"code":"DebugEnabled","type":"codeVoice"},{"type":"text","text":" property from being read,"},{"type":"text","text":" "},{"type":"text","text":"as it’s accessed through the "},{"code":"org.freedesktop.DBus.Properties","type":"codeVoice"},{"type":"text","text":" interface."}],"type":"paragraph"},{"inlineContent":[{"text":"Another option is to use polkit to allow or deny requests on a case-by-case","type":"text"},{"type":"text","text":" "},{"type":"text","text":"basis, allowing for the possibility of dynamic authorisation. To do this,"},{"text":" ","type":"text"},{"type":"text","text":"connect to the [signal[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:)] signal and query"},{"text":" ","type":"text"},{"text":"polkit in it:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["  `g_autoptr(GError)` child_error = NULL;","  `g_autoptr(GDBusConnection)` connection = g_bus_get_sync (G_BUS_TYPE_SYSTEM, NULL, NULL);","  gulong debug_controller_authorize_id = 0;","","  \/\/ Set up the debug controller.","  debug_controller = G_DEBUG_CONTROLLER (g_debug_controller_dbus_new (priv->connection, NULL, &child_error));","  if (debug_controller == NULL)","    {","      g_error (\"Could not register debug controller on bus: `s`\",","               child_error->message);","    }","","  debug_controller_authorize_id = g_signal_connect (debug_controller,","                                                    \"authorize\",","                                                    G_CALLBACK (debug_controller_authorize_cb),","                                                    self);","","  static gboolean","  debug_controller_authorize_cb (GDebugControllerDBus  *debug_controller,","                                 GDBusMethodInvocation *invocation,","                                 gpointer               user_data)","  {","    `g_autoptr(PolkitAuthority)` authority = NULL;","    `g_autoptr(PolkitSubject)` subject = NULL;","    `g_autoptr(PolkitAuthorizationResult)` auth_result = NULL;","    `g_autoptr(GError)` local_error = NULL;","    GDBusMessage *message;","    GDBusMessageFlags message_flags;","    PolkitCheckAuthorizationFlags flags = POLKIT_CHECK_AUTHORIZATION_FLAGS_NONE;","","    message = g_dbus_method_invocation_get_message (invocation);","    message_flags = g_dbus_message_get_flags (message);","","    authority = polkit_authority_get_sync (NULL, &local_error);","    if (authority == NULL)","      {","        g_warning (\"Failed to get polkit authority: `s`\", local_error->message);","        return FALSE;","      }","","    if (message_flags & G_DBUS_MESSAGE_FLAGS_ALLOW_INTERACTIVE_AUTHORIZATION)","      flags |= POLKIT_CHECK_AUTHORIZATION_FLAGS_ALLOW_USER_INTERACTION;","","    subject = polkit_system_bus_name_new (g_dbus_method_invocation_get_sender (invocation));","","    auth_result = polkit_authority_check_authorization_sync (authority,","                                                             subject,","                                                             \"com.example.MyService.set-debug-enabled\",","                                                             NULL,","                                                             flags,","                                                             NULL,","                                                             &local_error);","    if (auth_result == NULL)","      {","        g_warning (\"Failed to get check polkit authorization: `s`\", local_error->message);","        return FALSE;","      }","","    return polkit_authorization_result_get_is_authorized (auth_result);","  }"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GDebugControllerDBus"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GDebugControllerDBus","type":"codeVoice"},{"type":"text","text":" instance."}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus"},{"text":" (instead of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GDebugControllerDBus"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"}],"kind":"content"}],"kind":"symbol","relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol","doc:\/\/GIO\/documentation\/GIO\/DebugControllerProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/InitableProtocol"],"type":"conformsTo","kind":"relationships"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"metadata":{"navigatorTitle":[{"text":"DebugControllerDBusRef","kind":"identifier"}],"modules":[{"name":"GIO"}],"roleHeading":"Structure","role":"symbol","externalID":"s:3GIO22DebugControllerDBusRefV","title":"DebugControllerDBusRef","symbolKind":"struct","fragments":[{"text":"struct","kind":"keywo