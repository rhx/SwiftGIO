lename:rootpath:rootgroup:)"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"keyfileSettingsBackendNew"},{"kind":"text","text":"("},{"kind":"externalParam","text":"filename"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"rootPath"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"rootGroup","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">? = nil) -> ","kind":"text"},{"kind":"typeIdentifier","text":"SettingsBackendRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsBackendRef","preciseIdentifier":"s:3GIO18SettingsBackendRefV"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"The filename of the keyfile to use is given by ","type":"text"},{"type":"codeVoice","code":"filename"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All settings read to or written from the backend must fall under the"},{"type":"text","text":" "},{"type":"text","text":"path given in "},{"code":"rootPath","type":"codeVoice"},{"text":" (which must start and end with a slash and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not contain two consecutive slashes).  "},{"code":"rootPath","type":"codeVoice"},{"type":"text","text":" may be "},{"type":"codeVoice","code":"\"\/\""},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"rootGroup","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" then it specifies the name of the keyfile"},{"text":" ","type":"text"},{"text":"group used for keys that are written directly below ","type":"text"},{"type":"codeVoice","code":"rootPath"},{"type":"text","text":".  For"},{"type":"text","text":" "},{"text":"example, if ","type":"text"},{"type":"codeVoice","code":"rootPath"},{"type":"text","text":" is "},{"type":"codeVoice","code":"\"\/apps\/example\/\""},{"type":"text","text":" and "},{"type":"codeVoice","code":"rootGroup"},{"type":"text","text":" is"},{"type":"text","text":" "},{"code":"\"toplevel\"","type":"codeVoice"},{"type":"text","text":", then setting the key "},{"code":"\"\/apps\/example\/enabled\"","type":"codeVoice"},{"type":"text","text":" to true will"},{"type":"text","text":" "},{"type":"text","text":"cause the following to appear in the keyfile:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["[toplevel]","enabled=true"]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"rootGroup","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"NULL"},{"text":" then it is not permitted to store keys","type":"text"},{"type":"text","text":" "},{"text":"directly below the ","type":"text"},{"code":"rootPath","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For keys not stored directly below "},{"type":"codeVoice","code":"rootPath"},{"type":"text","text":" (ie: in a sub-path),"},{"type":"text","text":" "},{"type":"text","text":"the name of the subpath (with the final slash stripped) is used as"},{"text":" ","type":"text"},{"text":"the name of the keyfile group.  To continue the example, if","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"\/apps\/example\/profiles\/default\/font-size\""},{"text":" were set to","type":"text"},{"text":" ","type":"text"},{"code":"12","type":"codeVoice"},{"type":"text","text":" then the following would appear in the keyfile:"}]},{"code":["[profiles\/default]","font-size=12"],"type":"codeListing","syntax":null},{"type":"paragraph","inlineContent":[{"type":"text","text":"The backend will refuse writes (and return writability as being"},{"type":"text","text":" "},{"text":"false) for keys outside of ","type":"text"},{"type":"codeVoice","code":"rootPath"},{"text":" and, in the event that","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"rootGroup"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":", also for keys directly under ","type":"text"},{"code":"rootPath","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"Writes will also be refused if the backend detects that it has the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"inability to rewrite the keyfile (ie: the containing directory is not"},{"text":" ","type":"text"},{"type":"text","text":"writable)."}]},{"type":"paragraph","inlineContent":[{"text":"There is no checking done for your key namespace clashing with the","type":"text"},{"type":"text","text":" "},{"text":"syntax of the key file format.  For example, if you have ","type":"text"},{"type":"codeVoice","code":"["},{"type":"text","text":" or "},{"type":"codeVoice","code":"]"},{"text":" ","type":"text"},{"text":"characters in your path names or ","type":"text"},{"type":"codeVoice","code":"="},{"type":"text","text":" in your key names you may be in"},{"type":"text","text":" "},{"text":"trouble.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The backend reads default values from a keyfile called "},{"code":"defaults","type":"codeVoice"},{"text":" in","type":"text"},{"text":" ","type":"text"},{"text":"the directory specified by the ","type":"text"},{"type":"codeVoice","code":"GKeyfileSettingsBackend:defaults-dir"},{"type":"text","text":" "},{"text":"property, and a list of locked keys from a text file with the name ","type":"text"},{"code":"locks","type":"codeVoice"},{"type":"text","text":" in"},{"text":" ","type":"text"},{"type":"text","text":"the same location."}]}],"kind":"content"}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/Settings":{"title":"Settings","kind":"symbol","url":"\/documentation\/gio\/settings","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSettings"},{"type":"text","text":" class provides a convenient API for storing and retrieving"},{"type":"text","text":" "},{"type":"text","text":"application settings."}],"type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Settings"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","role":"symbol","navigatorTitle":[{"text":"Settings","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SettingsBackendRef":{"role":"symbol","title":"SettingsBackendRef","navigatorTitle":[{"kind":"identifier","text":"SettingsBackendRef"}],"type":"topic","url":"\/documentation\/gio\/settingsbackendref","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GSettingsBackend"},{"text":" interface defines a generic interface for","type":"text"},{"type":"text","text":" "},{"text":"non-strictly-typed data that is stored in a hierarchy. To implement","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"an alternative storage backend for [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","isActive":true},{"type":"text"