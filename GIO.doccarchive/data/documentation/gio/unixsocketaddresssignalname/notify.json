{"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"notify","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}]},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/unixsocketaddresssignalname\/notify"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddressSignalName"]]},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/UnixSocketAddressSignalName\/notify","interfaceLanguage":"swift"},"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"symbolKind":"case","externalID":"s:3GIO27UnixSocketAddressSignalNameO6notifyyA2CmF","title":"UnixSocketAddressSignalName.notify","roleHeading":"Case","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}]},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"#class@GObject.Param