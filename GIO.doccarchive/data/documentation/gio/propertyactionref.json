{"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ActionProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/PropertyActionProtocol"],"kind":"relationships"}],"topicSections":[{"generated":true,"anchor":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(_:)-1vmny","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(_:)-3s4ok","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(_:)-47iw4","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(_:)-59s33","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(_:)-6oicr","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(name:object:propertyName:)","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/init(opaquePointer:)"],"title":"Initializers"},{"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/ptr"],"generated":true,"title":"Instance Properties"},{"anchor":"Type-Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/unowned(_:)"],"generated":true,"title":"Type Methods"},{"generated":true,"title":"Default Implementations","anchor":"Default-Implementations","identifiers":["doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/ActionProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/GWeakCapturing-Implementations","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/ObjectProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/PropertyActionProtocol-Implementations"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef"},"metadata":{"title":"PropertyActionRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PropertyActionRef"}],"roleHeading":"Structure","symbolKind":"struct","externalID":"s:3GIO17PropertyActionRefV","navigatorTitle":[{"kind":"identifier","text":"PropertyActionRef"}],"modules":[{"name":"GIO"}],"role":"symbol"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/propertyactionref"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"PropertyActionRef","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","type":"heading","text":"Overview"},{"inlineContent":[{"text":"The state of the action will correspond to the value of the property.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Changing it will change the property (assuming the requested value"},{"type":"text","text":" "},{"text":"matches the requirements as specified in the [type","type":"text"},{"identifier":"\/\/documentation\/gobject\/paramspec]","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only the most common types are presently supported.  Booleans are"},{"text":" ","type":"text"},{"type":"text","text":"mapped to booleans, strings to strings, signed\/unsigned integers to"},{"text":" ","type":"text"},{"type":"text","text":"int32\/uint32 and floats and doubles to doubles."}]},{"inlineContent":[{"text":"If the property is an enum then the state will be string-typed and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"conversion will automatically be performed between the enum value and"},{"text":" ","type":"text"},{"text":"‘nick’ string as per the [type[EnumValue](\/\/documentation\/gobject\/enumvalue] table.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Flags types are not currently supported.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Properties of object types, boxed types and pointer types are not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"supported and probably never will be."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Properties of [type[Variant](\/\/documentation\/glib\/variant] types are not currently supported."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the property is boolean-valued then the action will have a "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" "},{"text":"parameter type, and activating the action (with no parameter) will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"toggle the value of the property."}]},{"type":"paragraph","inlineContent":[{"text":"In all other cases, the parameter type will correspond to the type of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the property."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The general idea here is to reduce the number of locations where a"},{"type":"text","text":" "},{"text":"particular piece of state is kept (and therefore has to be synchronised","type":"text"},{"type":"text","text":" "},{"text":"between). ","type":"text"},{"type":"codeVoice","code":"GPropertyAction"},{"type":"text","text":" does not have a separate state that is kept"},{"text":" ","type":"text"},{"type":"text","text":"in sync with the property value — its state is the property value."}]},{"inlineContent":[{"text":"For example, it might be useful to create a [iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action"},{"text":"] corresponding","type":"text"},{"type":"text","text":" "},{"text":"to the ","type":"text"},{"type":"codeVoice","code":"visible-child-name"},{"type":"text","text":" property of a "},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Stack.html"},{"type":"text","text":" "},{"type":"text","text":"so that the current page can be switched from a menu.  The active radio"},{"text":" ","type":"text"},{"text":"indication in the menu is then directly determined from the active page of","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"GtkStack"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"An anti-example would be binding the ","type":"text"},{"type":"codeVoice","code":"active-id"},{"text":" property on a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/docs.gtk.org\/gtk4\/class.ComboBox.html","isActive":true},{"type":"text","text":". This is"},{"type":"text","text":" "},{"type":"text","text":"because the state of the combo box itself is probably uninteresting and is"},{"type":"text","text":" "},{"text":"actually being used to control something else.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Another anti-example would be to bind to the "},{"type":"codeVoice","code":"visible-child-name"},{"type":"text","text":" "},{"type":"text","text":"property of a "},{"type":"reference","identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Stack.html","overridingTitle":"GtkStack","overridingTitleInlineContent":[{"type":"codeVoice","code":"GtkStack"}],"isActive":true},{"type":"text","text":" if"},{"text":" ","type":"text"},{"text":"this value is actually stored in [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","type":"reference","isActive":true},{"text":"].  In that case, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"real source of the value is* [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","isActive":true},{"text":"].  If you want","type":"text"},{"type":"text","text":" "},{"text":"a [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true,"type":"reference"},{"text":"] to control a setting stored in [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","type":"reference","isActive":true},{"type":"text","text":"],"},{"type":"text","text":" "},{"text":"see [method","type":"text"},{"type":"codeVoice","code":"Gio.Settings.create_action"},{"type":"text","text":"] instead, and possibly combine its"},{"text":" ","type":"text"},{"type":"text","text":"use with [method"},{"type":"codeVoice","code":"Gio.Settings.bind"},{"type":"text","text":"]."}]},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef","type":"reference","isActive":true},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"code":"GPropertyAction","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionProtocol","type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef"},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GPropertyAction"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyAction"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GPropertyAction"},{"text":" instance.","type":"text"}]}]}]}],"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GPropertyAction"},{"text":" is a way to get a [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true,"type":"reference"},{"text":"] with a state value","type":"text"},{"type":"text","text":" "},{"text":"reflecting and controlling the value of a [class[Object](\/\/documentation\/gobject\/object] property.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"references":{"doc://GIO/documentation/GIO/Action":{"url":"\/documentation\/gio\/action","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action"}],"navigatorTitle":[{"text":"Action","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","title":"Action","role":"symbol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO/PropertyActionRef/PropertyActionProtocol-Implementations":{"kind":"article","abstract":[],"url":"\/documentation\/gio\/propertyactionref\/propertyactionprotocol-implementations","role":"collectionGroup","type":"topic","title":"PropertyActionProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/PropertyActionProtocol-Implementations"},"doc://GIO/documentation/GIO/ActionProtocol":{"role":"symbol","title":"ActionProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"ActionP