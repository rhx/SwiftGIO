{"abstract":[{"type":"text","text":"Invoke the interaction to ask the user for a password. It invokes this"},{"type":"text","text":" "},{"type":"text","text":"interaction in the main loop, specifically the [MainContext](\/\/documentation\/glib\/maincontext returned by"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_main_context_get_thread_default()"},{"type":"text","text":" when the interaction is created. This"},{"type":"text","text":" "},{"type":"text","text":"is called by called by "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","type":"reference","isActive":true},{"type":"text","text":" or "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","isActive":true},{"text":" to ask the user","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for a password."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSInteraction","doc:\/\/GIO\/documentation\/GIO\/TLSInteraction\/TLSInteractionProtocol-Implementations"]]},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSInteraction\/invokeAsk(password:cancellable:)-3zpw5"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsinteraction\/invokeask(password:cancellable:)-3zpw5"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"invokeAsk","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"CancellableT"},{"text":", ","kind":"text"},{"text":"TLSPasswordT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"password"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TLSPasswordT"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Cance