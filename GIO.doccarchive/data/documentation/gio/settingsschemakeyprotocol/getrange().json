{"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getRange","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This function will return a [Variant](\/\/documentation\/glib\/variant that fully describes the range","type":"text"},{"type":"text","text":" "},{"text":"of values that are valid for ","type":"text"},{"type":"codeVoice","code":"key"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"The type of [Variant](\/\/documentation\/glib\/variant returned is "},{"code":"(sv)","type":"codeVoice"},{"text":". The string describes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the type of range restriction in effect. The type and meaning of"},{"text":" ","type":"text"},{"text":"the value contained in the variant depends on the string.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the string is "},{"type":"codeVoice","code":"'type'"},{"type":"text","text":" then the variant contains an empty array."},{"text":" ","type":"text"},{"type":"text","text":"The element type of that empty array is the expected type of value"},{"type":"text","text":" "},{"text":"and all values of that type are valid.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the string is "},{"code":"'enum'","type":"codeVoice"},{"type":"text","text":" then the variant contains an array"},{"text":" ","type":"text"},{"text":"enumerating the possible values. Each item in the array is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a possible valid value and no other values are valid."}]},{"inlineContent":[{"text":"If the string is ","type":"text"},{"type":"codeVoice","code":"'flags'"},{"text":" then the variant contains an array. Each","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"item in the array is a value that may appear zero or one times in an"},{"type":"text","text":" "},{"type":"text","text":"array to be used as the value for this key. For example, if the"},{"type":"text","text":" "},{"type":"text","text":"variant contained the array "},{"code":"['x', 'y']","type":"codeVoice"},{"type":"text","text":" then the valid values for"},{"text":" ","type":"text"},{"type":"text","text":"the key would be "},{"code":"[]","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"['x']"},{"text":", ","type":"text"},{"code":"['y']","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"['x', 'y']"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"['y', 'x']"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, if the string is "},{"type":"codeVoice","code":"'range'"},{"type":"text","text":" then the variant contains a pair"},{"type":"text","text":" "},{"text":"of like-typed values – the minimum and maximum permissible values","type":"text"},{"text":" ","type":"text"},{"text":"for this key.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This information should not be used by normal programs.  It is","type":"text"},{"text":" ","type":"text"},{"text":"considered to be a hint for introspection purposes.  Normal programs","type":"text"},{"type":"text","text":" "},{"type":"text","text":"should already know what is permitted by their own schema.  The"},{"type":"text","text":" "},{"type":"text","text":"format may change in any way in the future – but particularly, new"},{"type":"text","text":" "},{"type":"text","text":"forms may be added to the possibilities described above."}]},{"inlineContent":[{"type":"text","text":"You should free the returned value with "},{"code":"g_variant_unref()","type":"codeVoice"},{"type":"text","text":" when it is"},{"type":"text","text":" "},{"text":"no longer needed.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol"]]},"abstract":[{"type":"text","text":"Queries the range of a key."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol\/getRange()"},"metadata":{"roleHeading":"Instance Method","title":"getRange()","extendedModule":"GIO","symbolKind":"method","externalID":"s:3GIO25SettingsSchemaKeyProtocolPAAE8getRange4GLib10VariantRefVSgyF","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getRange"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}]},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/settingsschemakeyprotocol\/getrange()"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/SettingsSchemaKeyProtocol":{"abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","type":"reference","isActive":true},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"type":"text","text":" "},{"text":"using the following functions.","type":"text"}],"url":"\/documentation\/gio\/settingsschemakeyprotocol","type":"topic","kind":"symbol","title":"SettingsSchemaKeyProtocol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchemaKeyProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"SettingsSchemaKeyProtocol"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol"},"doc://GIO/documentation/GIO/SettingsSchemaKey":{"abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","isActive":true,"type":"reference"},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"text":" ","type":"text"},{"type":"text","text":"using the following functions."}],"url":"\/documentation\/gio\/settingsschemakey","type":"topic","kind":"symbol","title":"SettingsSchemaKey","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchemaKey"}],"navigatorTitle":[{"text":"SettingsSchemaKey","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SettingsSchemaKeyProtocol/getRange()":{"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol\/getRange()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getRange"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"url":"\/documentation\/gio\/settingsschemakeyprotocol\/getrange()","title":"getRange()","kind":"symbol","abstract":[{"text":"Queries the range of a key.","type":"text"}]}}}