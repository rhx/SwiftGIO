{"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"extendedModule":"GIO","roleHeading":"Instance Property","title":"range","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"range","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"modules":[{"name":"GIO"}],"externalID":"s:3GIO25SettingsSchemaKeyProtocolPAAE5range4GLib10VariantRefVSgvp","symbolKind":"property","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol"]]},"abstract":[{"type":"text","text":"Queries the range of a key."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"range","kind":"identifier"},{"kind":"text","text":": "},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"kind":"text","text":"! { "},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"This function will return a [Variant](\/\/documentation\/glib\/variant that fully describes the range","type":"text"},{"type":"text","text":" "},{"text":"of values that are valid for ","type":"text"},{"type":"codeVoice","code":"key"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The type of [Variant](\/\/documentation\/glib\/variant returned is "},{"code":"(sv)","type":"codeVoice"},{"type":"text","text":". The string describes"},{"text":" ","type":"text"},{"text":"the type of range restriction in effect. The type and meaning of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the value contained in the variant depends on the string."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the string is "},{"type":"codeVoice","code":"'type'"},{"type":"text","text":" then the variant contains an empty array."},{"text":" ","type":"text"},{"type":"text","text":"The element type of that empty array is the expected type of value"},{"type":"text","text":" "},{"type":"text","text":"and all values of that type are valid."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the string is "},{"code":"'enum'","type":"codeVoice"},{"text":" then the variant contains an array","type":"text"},{"text":" ","type":"text"},{"text":"enumerating the possible values. Each item in the array is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a possible valid value and no other values are valid."}]},{"inlineContent":[{"type":"text","text":"If the string is "},{"code":"'flags'","type":"codeVoice"},{"text":" then the variant contains an array. Each","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"item in the array is a value that may appear zero or one times in an"},{"text":" ","type":"text"},{"text":"array to be used as the value for this key. For example, if the","type":"text"},{"type":"text","text":" "},{"text":"variant contained the array ","type":"text"},{"code":"['x', 'y']","type":"codeVoice"},{"type":"text","text":" then the valid values for"},{"type":"text","text":" "},{"type":"text","text":"the key would be "},{"type":"codeVoice","code":"[]"},{"type":"text","text":", "},{"type":"codeVoice","code":"['x']"},{"text":", ","type":"text"},{"code":"['y']","type":"codeVoice"},{"text":", ","type":"text"},{"code":"['x', 'y']","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"['y', 'x']"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, if the string is "},{"code":"'range'","type":"codeVoice"},{"text":" then the variant contains a pair","type":"text"},{"text":" ","type":"text"},{"text":"of like-typed values – the minimum and maximum permissible values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for this key."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This information should not be used by normal programs.  It is"},{"type":"text","text":" "},{"type":"text","text":"considered to be a hint for introspection purposes.  Normal programs"},{"text":" ","type":"text"},{"type":"text","text":"should already know what is permitted by their own schema.  The"},{"text":" ","type":"text"},{"text":"format may change in any way in the future – but particularly, new","type":"text"},{"type":"text","text":" "},{"type":"text","text":"forms may be added to the possibilities described above."}]},{"inlineContent":[{"text":"You should free the returned value with ","type":"text"},{"type":"codeVoice","code":"g_variant_unref()"},{"text":" when it is","type":"text"},{"type":"text","text":" "},{"text":"no longer needed.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/settingsschemakeyprotocol\/range"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol\/range"},"sections":[],"references":{"doc://GIO/documentation/GIO/SettingsSchemaKeyProtocol":{"abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","type":"reference","isActive":true},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"type":"text","text":" "},{"text":"using the following functions.","type":"text"}],"url":"\/documentation\/gio\/settingsschemakeyprotocol","type":"topic","kind":"symbol","title":"SettingsSchemaKeyProtocol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchemaKeyProtocol"}],"navigatorTitle":[{"kind":"identifier","text":"SettingsSchemaKeyProtocol"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol"},"doc://GIO/documentation/GIO/SettingsSchemaKey":{"abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","isActive":true,"type":"reference"},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"text":" ","type":"text"},{"type":"text","text":"using the following functions."}],"url":"\/documentation\/gio\/settingsschemakey","type":"topic","kind":"symbol","title":"SettingsSchemaKey","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchemaKey"}],"navigatorTitle":[{"text":"SettingsSchemaKey","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey"},"doc://GIO/documentation/GIO/SettingsSchemaKeyProtocol/range":{"title":"range","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"range","kind":"identifier"},{"kind":"text","text":": "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"abstract":[{"type":"text","text":"Queries the range of a key."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKeyProtocol\/range","url":"\/documentation\/gio\/settingsschemakeyprotocol\/range","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}