{"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeletonSignalName\/gAuthorizeMethod"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeletonSignalName"]]},"sections":[],"kind":"symbol","metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Case","externalID":"s:3GIO31DBusInterfaceSkeletonSignalNameO16gAuthorizeMethodyA2CmF","symbolKind":"case","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"gAuthorizeMethod","kind":"identifier"}],"title":"DBusInterfaceSkeletonSignalName.gAuthorizeMethod"},"abstract":[{"text":"Emitted when a method is invoked by a remote caller and used to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"determine if the method call is authorized."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusinterfaceskeletonsignalname\/gauthorizemethod"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"gAuthorizeMethod","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"Note that this signal is emitted in a thread dedicated to"},{"text":" ","type":"text"},{"type":"text","text":"handling the method call so handlers are allowed to perform"},{"text":" ","type":"text"},{"text":"blocking IO. This means that it is appropriate to call e.g.","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#polkit-authority-check-authorization-sync","isActive":true},{"type":"text","text":" "},{"text":"with the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#POLKIT-CHECK-AUTHORIZATION-FLAGS-ALLOW-USER-INTERACTION:CAPS"},{"type":"text","text":" "},{"text":"flag set.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"false","type":"codeVoice"},{"type":"text","text":" is returned then no further handlers are run and the"},{"type":"text","text":" "},{"type":"text","text":"signal handler must take a reference to "},{"type":"codeVoice","code":"invocation"},{"type":"text","text":" and finish"},{"type":"text","text":" "},{"text":"handling the call (e.g. return an error via","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_dbus_method_invocation_return_error()"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Otherwise, if "},{"code":"true","type":"codeVoice"},{"type":"text","text":" is returned, signal emission continues. If no"},{"type":"text","text":" "},{"text":"handlers return ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", then the method is dispatched. If","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"interface"},{"type":"text","text":" has an enclosing "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeleton"},{"text":", then the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[DBusObjectSkeleton](\/\/documentation\/gio\/dbusobjectskeleton\/onauthorizemethod(flags:handler:) signal handlers run before"},{"type":"text","text":" "},{"type":"text","text":"the handlers for this signal."}],"type":"paragraph"},{"inlineContent":[{"text":"The default class handler just returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Please note that the common case is optimized: if no signals","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handlers are connected and the default class handler isn’t"},{"type":"text","text":" "},{"text":"overridden (for both ","type":"text"},{"code":"interface","type":"codeVoice"},{"type":"text","text":" and the enclosing"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeleton","isActive":true},{"type":"text","text":", if any) and "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeleton","isActive":true,"type":"reference"},{"text":" does","type":"text"},{"type":"text","text":" "},{"text":"not have the","type":"text"},{"text":" ","type":"text"},{"code":"handleMethodInvocationsInThread","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"flags set, no dedicated thread is ever used and the call will be"},{"type":"text","text":" "},{"type":"text","text":"handled in the same thread as the object that "},{"type":"codeVoice","code":"interface"},{"text":" belongs","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to was exported in."}]}]}],"references":{"doc://GIO/documentation/GIO/DBusInterfaceSkeletonSignalName":{"url":"\/documentation\/gio\/dbusinterfaceskeletonsignalname","type":"topic","role":"symbol","title":"DBusInterfaceSkeletonSignalName","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusInterfaceSkeletonSignalName"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeletonSignalName","abstract":[],"navigatorTitle":[{"text":"DBusInterfaceSkeletonSignalName","kind":"identifier"}]},"http://hal.freedesktop.org/docs/polkit/PolkitAuthority.html#POLKIT-CHECK-AUTHORIZATION-FLAGS-ALLOW-USER-INTERACTION:CAPS":{"type":"link","identifier":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#POLKIT-CHECK-AUTHORIZATION-FLAGS-ALLOW-USER-INTERACTION:CAPS","url":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#POLKIT-CHECK-AUTHORIZATION-FLAGS-ALLOW-USER-INTERACTI