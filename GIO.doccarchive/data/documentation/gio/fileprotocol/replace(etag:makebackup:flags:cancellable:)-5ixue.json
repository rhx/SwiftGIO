{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/replace(etag:makeBackup:flags:cancellable:)-5ixue"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileprotocol\/replace(etag:makebackup:flags:cancellable:)-5ixue"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Returns an output stream for overwriting the file, possibly"},{"type":"text","text":" "},{"type":"text","text":"creating a backup copy of the file first. If the file doesn’t exist,"},{"type":"text","text":" "},{"type":"text","text":"it will be created."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileProtocol"]]},"metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"replace","kind":"identifier"},{"kind":"text","text":"("},{"text":"etag","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"text":">?, ","kind":"text"},{"text":"makeBackup","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"FileCreateFlags","preciseIdentifier":"s:3GIO15FileCreateFlagsV"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"FileOutputStreamRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19FileOutputStreamRefV"},{"text":"!","kind":"text"}],"extendedModule":"GIO","modules":[{"name":"GIO"}],"title":"replace(etag:makeBackup:flags:cancellable:)","externalID":"s:3GIO12FileProtocolPAAE7replace4etag10makeBackup5flags11cancellableAA0B15OutputStreamRefVSgSPys4Int8VGSg_SbAA0B11CreateFlagsVAA011CancellableL0VSgtKF","symbolKind":"method","roleHeading":"Instance Method"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"replace"},{"kind":"text","text":"("},{"kind":"externalParam","text":"etag"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"CChar","preciseIdentifier":"s:s5CChara"},{"kind":"text","text":">? = nil, "},{"text":"makeBackup","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags","preciseIdentifier":"s:3GIO15FileCreateFlagsV","kind":"typeIdentifier","text":"FileCreateFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:3GIO19FileOutputStreamRefV","kind":"typeIdentifier","text":"FileOutputStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef"},{"kind":"text","text":"!"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This will try to replace the file in the safest way possible so"},{"text":" ","type":"text"},{"type":"text","text":"that any errors during the writing will not affect an already"},{"type":"text","text":" "},{"type":"text","text":"existing copy of the file. For instance, for local files it"},{"type":"text","text":" "},{"type":"text","text":"may write to a temporary file and then atomically rename over"},{"type":"text","text":" "},{"text":"the destination when the stream is closed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"By default files created are generally readable by everyone,"},{"type":"text","text":" "},{"type":"text","text":"but if you pass "},{"type":"codeVoice","code":"private"},{"type":"text","text":" in "},{"type":"codeVoice","code":"flags"},{"text":" the file","type":"text"},{"type":"text","text":" "},{"text":"will be made readable only to the current user, to the level that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is supported on the target filesystem."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled","type":"text"},{"type":"text","text":" "},{"type":"text","text":"by triggering the cancellable object from another thread. If the"},{"text":" ","type":"text"},{"text":"operation was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"inlineContent":[{"text":"If you pass in a non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" "},{"code":"etag","type":"codeVoice"},{"type":"text","text":" value and "},{"code":"file","type":"codeVoice"},{"text":" already exists, then","type":"text"},{"type":"text","text":" "},{"text":"this value is compared to the current entity tag of the file, and if","type":"text"},{"type":"text","text":" "},{"text":"they differ an ","type":"text"},{"code":"wrongEtag","type":"codeVoice"},{"type":"text","text":" error is returned. This"},{"text":" ","type":"text"},{"type":"text","text":"generally means that the file has been changed since you last read"},{"type":"text","text":" "},{"text":"it. You can get the new etag from ","type":"text"},{"type":"codeVoice","code":"g_file_output_stream_get_etag()"},{"type":"text","text":" "},{"type":"text","text":"after you’ve finished writing and closed the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStream","isActive":true},{"text":". When","type":"text"},{"text":" ","type":"text"},{"text":"you load a new file you can use ","type":"text"},{"code":"g_file_input_stream_query_info()","type":"codeVoice"},{"text":" to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"get the etag of the file."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"makeBackup","type":"codeVoice"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":", this function will attempt to make a"},{"type":"text","text":" "},{"text":"backup of the current file before overwriting it. If this fails","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a "},{"type":"codeVoice","code":"cantCreateBackup"},{"text":" error will be returned. If you","type":"text"},{"text":" ","type":"text"},{"text":"want to replace anyway, try again with ","type":"text"},{"code":"makeBackup","type":"codeVoice"},{"type":"text","text":" set to "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the file is a directory the "},{"type":"codeVoice","code":"isDirectory"},{"text":" error will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be returned, and if the file is some other form of non-regular file"},{"type":"text","text":" "},{"type":"text","text":"then a "},{"code":"notRegularFile","type":"codeVoice"},{"type":"text","text":" error will be returned. Some"},{"text":" ","type":"text"},{"text":"file systems don’t allow all file names, and may return an","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"invalidFilename"},{"text":" error, and if the name is to long","type":"text"},{"type":"text","text":" "},{"code":"filenameTooLong","type":"codeVoice"},{"type":"text","text":" will be returned. Other errors are"},{"type":"text","text":" "},{"text":"possible too, and depend on what kind of filesystem the file is on.","type":"text"}]}]}],"references":{"doc://GIO/documentation/GIO/FileProtocol":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileProtocol"}],"type":"topic","role":"symbol","url":"\/documentation\/gio\/fileprotocol","navigatorTitle":[{"kind":"identifier","text":"FileProtocol"}],"abstract":[{"type":"codeVoice","code":"GFile"},{"text":" is a high level abstraction for manipulating files on a","type":"text"},{"type":"text","text":" "},{"text":"virtual file system. ","type":"text"},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"text":"that do no I\/O upon creation. It is necessary to understand that","type":"text"},{"type":"text","text":" "},{"code":"GFile","type":"codeVoice"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"type":"text","text":" "},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"type":"text","text":"(see [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"type":"text","text":"] and [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"title":"FileProtocol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileProtocol/replace(etag:makeBackup:flags:cancellable:)-5ixue":{"url":"\/documentation\/gio\/fileprotocol\/replace(etag:makebackup:flags:cancellable:)-5ixue","abstract":[{"text":"Returns an output stream for overwriting the file, possibly","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"creating a backup copy of the file first. If the file doesn’t exist,"},{"text":" ","type":"text"},{"text":"it will be created.","type":"text"}],"kind":"symbol","title":"replace(etag:makeBackup:flags:cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/replace(etag:makeBackup:flags:cancellable:)-5ixue","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"replace"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"etag"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"text":">?, ","kind":"text"},{"text":"makeBackup","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","kind":"typeIdentifier","text":"FileCreateFlags"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:3GIO19FileOutputStreamRefV","text":"FileOutputStreamRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}]},"doc://GIO/documentation/GIO/FileOutputStreamRef":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileOutputStreamRef"}],"url":"\/documentation\/gio\/fileoutputstreamref","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileOutputStreamRef"}],"title":"FileOutputStreamRef","kind":"symbol","abstract":[{"type":"codeVoice","code":"GFileOutputStream"},{"text":" provides output streams that write their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"content to a file."}]},"doc://GIO/documentation/GIO/FileOutputStream":{"navigatorTitle":[{"text":"FileOutputStream","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileOutputStream"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStream","url":"\/documentation\/gio\/fileoutputstream","title":"FileOutputStream","abstract":[{"code":"GFileOutputStream","type":"codeVoice"},{"text":" provides output streams that write their","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"content to a file."}],"kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/FileCreateFlags":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags","navigatorTitle":[{"text":"FileCreateFlags","kind":"identifier"}],"abstract":[{"text":"Flags used when an operation may create a file.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileCreateFlags"}],"url":"\/documentation\/gio\/filecreateflags","type":"topic","kind":"symbol","title":"FileCreateFlags"}}}