ancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled","type":"text"},{"type":"text","text":" "},{"text":"by triggering the cancellable object from another thread. If the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operation was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"text":" will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"inlineContent":[{"text":"Some file systems don’t allow all file names, and may return an","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"invalidFilename"},{"text":" error. If the file is a directory the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"isDirectory"},{"text":" error will be returned. Other errors are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible too, and depend on what kind of filesystem the file is on."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/fileprotocol\/appendto(flags:cancellable:)-25nao"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/appendTo(flags:cancellable:)-25nao","interfaceLanguage":"swift"},"abstract":[{"text":"Gets an output stream for appending data to the file.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the file doesn’t already exist it is created."}],"kind":"symbol","metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"appendTo"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancel