pe":"text"},{"text":" ","type":"text"},{"type":"text","text":"kind of filesystem the file is on."}]},{"inlineContent":[{"text":"Note that in many non-local file cases read and write streams are","type":"text"},{"type":"text","text":" "},{"text":"not supported, so make sure you really need to do read and write","type":"text"},{"type":"text","text":" "},{"type":"text","text":"streaming, rather than just opening for reading or writing."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/createReadwrite(flags:cancellable:)-53vnt"},"sections":[],"abstract":[{"type":"text","text":"Creates a new file and returns a stream for reading and"},{"text":" ","type":"text"},{"text":"writing to it. The file must not already exist.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileProtocol"]]},"variants":[{"paths":["\/documentation\/gio\/fileprotocol\/createreadwrite(flags:cancellable:)-53vnt"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/FileProtocol/createReadwrite(flags:cancellable:)-53vnt":{"type":"topic","kind":"symbol","abstract":[{"text":"Creates a new file and returns a stream for reading and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"writing to it. The file must not already exist."}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"createReadwrite"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"t