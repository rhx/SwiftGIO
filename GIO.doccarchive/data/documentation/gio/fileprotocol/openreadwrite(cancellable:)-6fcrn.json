{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/openReadwrite(cancellable:)-6fcrn"},"abstract":[{"type":"text","text":"Opens an existing file for reading and writing. The result is"},{"type":"text","text":" "},{"text":"a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStream","type":"reference"},{"text":" that can be used to read and write the contents","type":"text"},{"type":"text","text":" "},{"text":"of the file.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileprotocol\/openreadwrite(cancellable:)-6fcrn"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"openReadwrite","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileIOStreamRefV","text":"FileIOStreamRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStreamRef"},{"text":"! ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO19CancellableProtocolP","text":"CancellableProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","