{"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileProtocol"]]},"abstract":[{"text":"Returns an output stream for overwriting the file, possibly","type":"text"},{"type":"text","text":" "},{"text":"creating a backup copy of the file first. If the file doesn’t exist,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it will be created."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"replace"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"etag"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5CChara","text":"CChar"},{"text":">? = nil, ","kind":"text"},{"kind":"externalParam","text":"makeBackup"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileCreateFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileCreateFlagsV"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:3GIO19FileOutputStreamRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","text":"FileOutputStreamRef","kind":"typeIdentifier"},{"text":"! ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"text":"CancellableProtocol","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"This will try to replace the file in the safest way possible so","type":"text"},{"type":"text","text":" "},{"text":"that any errors during the writing will not affect an already","type":"text"},{"type":"text","text":" "},{"type":"text","text":"existing copy of the file. For instance, for local files it"},{"type":"text","text":" "},{"text":"may write to a temporary file and then atomically rename over","type":"text"},{"text":" ","type":"text"},{"text":"the destination when the stream is closed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default files created are generally readable by everyone,"},{"type":"text","text":" "},{"type":"text","text":"but if you pass "},{"type":"codeVoice","code":"private"},{"type":"text","text":" in "},{"type":"codeVoice","code":"flags"},{"type":"text","text":" the file"},{"type":"text","text":" "},{"type":"text","text":"will be made readable only to the current user, to the level that"},{"text":" ","type":"text"},{"type":"text","text":"is supported on the target filesystem."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", then the operation can be cancelled","type":"text"},{"type":"text","text":" "},{"text":"by triggering the cancellable object from another thread. If the","type":"text"},{"text":" ","type":"text"},{"text":"operation was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you pass in a non-"},{"type":"codeVoice","code":"nil"},{"text":" ","type":"text"},{"type":"codeVoice","code":"etag"},{"type":"text","text":" value and "},{"type":"codeVoice","code":"file"},{"type":"text","text":" already exists, then"},{"type":"text","text":" "},{"type":"text","text":"this value is compared to the current entity tag of the file, and if"},{"type":"text","text":" "},{"text":"they differ an ","type":"text"},{"type":"codeVoice","code":"wrongEtag"},{"type":"text","text":" error is returned. This"},{"text":" ","type":"text"},{"text":"generally means that the file has been changed since you last read","type":"text"},{"type":"text","text":" "},{"text":"it. You can get the new etag from ","type":"text"},{"code":"g_file_output_stream_get_etag()","type":"codeVoice"},{"type":"text","text":" "},{"text":"after you’ve finished writing and closed the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStream"},{"text":". When","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"you load a new file you can use "},{"type":"codeVoice","code":"g_file_input_stream_query_info()"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"type":"text","text":"get the etag of the file."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"makeBackup"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":", this function will attempt to make a","type":"text"},{"type":"text","text":" "},{"text":"backup of the current file before overwriting it. If this fails","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a "},{"code":"cantCreateBackup","type":"codeVoice"},{"type":"text","text":" error will be returned. If you"},{"text":" ","type":"text"},{"type":"text","text":"want to replace anyway, try again with "},{"type":"codeVoice","code":"makeBackup"},{"type":"text","text":" set to "},{"type":"codeVoice","code":"false"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the file is a directory the "},{"code":"isDirectory","type":"codeVoice"},{"type":"text","text":" error will"},{"text":" ","type":"text"},{"text":"be returned, and if the file is some other form of non-regular file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then a "},{"type":"codeVoice","code":"notRegularFile"},{"text":" error will be returned. Some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file systems don’t allow all file names, and may return an"},{"text":" ","type":"text"},{"code":"invalidFilename","type":"codeVoice"},{"type":"text","text":" error, and if the name is to long"},{"text":" ","type":"text"},{"code":"filenameTooLong","type":"codeVoice"},{"text":" will be returned. Other errors are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"possible too, and depend on what kind of filesystem the file is on."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileprotocol\/replace(etag:makebackup:flags:cancellable:)-88jgh"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/replace(etag:makeBackup:flags:cancellable:)-88jgh","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"metadata":{"modules":[{"name":"GIO"}],"extendedModule":"GIO","role":"symbol","externalID":"s:3GIO12FileProtocolPAAE7replace4etag10makeBackup5flags11cancellableAA0B15OutputStreamRefVSgSPys4Int8VGSg_SbAA0B11CreateFlagsVqd__SgtKAA011CancellableC0Rd__lF","title":"replace(etag:makeBackup:flags:cancellable:)","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"replace","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"etag","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"makeBackup"},{"kind":"text","text":": "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"FileCreateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO15FileCreateFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"FileOutputStreamRef","preciseIdentifier":"s:3GIO19FileOutputStreamRefV"},{"text":"!","kind":"text"}]},"references":{"doc://GIO/documentation/GIO/FileProtocol/replace(etag:makeBackup:flags:cancellable:)-88jgh":{"type":"topic","kind":"symbol","abstract":[{"text":"Returns an output stream for overwriting the file, possibly","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"creating a backup copy of the file first. If the file doesn’t exist,"},{"text":" ","type":"text"},{"text":"it will be created.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"replace"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"etag"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"text":">?, ","kind":"text"},{"text":"makeBackup","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO15FileCreateFlagsV","text":"FileCreateFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:3GIO19FileOutputStreamRefV","kind":"typeIdentifier","text":"FileOutputStreamRef"},{"text":"!","kind":"text"}],"title":"replace(etag:makeBackup:flags:cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/replace(etag:makeBackup:flags:cancellable:)-88jgh","url":"\/documentation\/gio\/fileprotocol\/replace(etag:makebackup:flags:cancellable:)-88jgh"},"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"},"doc://GIO/documentation/GIO/FileCreateFlags":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileCreateFlags","navigatorTitle":[{"text":"FileCreateFlags","kind":"identifier"}],"abstract":[{"text":"Flags used when an operation may create a file.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileCreateFlags"}],"url":"\/documentation\/gio\/filecreateflags","type":"topic","kind":"symbol","title":"FileCreateFlags"},"doc://GIO/documentation/GIO/FileOutputStream":{"navigatorTitle":[{"text":"FileOutputStream","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileOutputStream"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStream","url":"\/documentation\/gio\/fileoutputstream","title":"FileOutputStream","abstract":[{"code":"GFileOutputStream","type":"codeVoice"},{"text":" provides output streams that write their","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"content to a file."}],"kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/FileOutputStreamRef":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileOutputStreamRef"}],"url":"\/documentation\/gio\/fileoutputstreamref","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileOutputStreamRef"}],"title":"FileOutputStreamRef","kind":"symbol","abstract":[{"type":"codeVoice","code":"GFileOutputStream"},{"text":" provides output streams that write their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"content to a file."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/FileProtocol":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileProtocol"}],"type":"topic","role":"symbol","url":"\/documentation\/gio\/fileprotocol","navigatorTitle":[{"kind":"identifier","text":"FileProtocol"}],"abstract":[{"type":"codeVoice","code":"GFile"},{"text":" is a high level abstraction for manipulating files on a","type":"text"},{"type":"text","text":" "},{"text":"virtual file system. ","type":"text"},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"text":"that do no I\/O upon creation. It is necessary to understand that","type":"text"},{"type":"text","text":" "},{"code":"GFile","type":"codeVoice"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"type":"text","text":" "},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"type":"text","text":"(see [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"type":"text","text":"] and [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"title":"FileProtocol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol"}}}