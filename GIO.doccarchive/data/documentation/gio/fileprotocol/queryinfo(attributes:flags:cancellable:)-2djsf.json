{"sections":[],"variants":[{"paths":["\/documentation\/gio\/fileprotocol\/queryinfo(attributes:flags:cancellable:)-2djsf"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"externalID":"s:3GIO12FileProtocolPAAE9queryInfo10attributes5flags11cancellableAA0bE3RefVSgSPys4Int8VGSg_AA0b5QueryE5FlagsVAA011CancellableI0VSgtKF","title":"queryInfo(attributes:flags:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"queryInfo","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"attributes"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"FileQueryInfoFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO18FileQueryInfoFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"FileInfoRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO11FileInfoRefV"},{"kind":"text","text":"!"}],"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","extendedModule":"GIO","role":"symbol","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"queryInfo","kind":"identifier"},{"text":"(","kind":"text"},{"text":"attributes","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:s5CChara","kind":"typeIdentifier","text":"CChar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"FileQueryInfoFlags","preciseIdentifier":"s:3GIO18FileQueryInfoFlagsV","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileQueryInfoFlags"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"FileInfoRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO11FileInfoRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef"},{"kind":"text","text":"!"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The result is a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true,"type":"reference"},{"type":"text","text":"] object that contains key-value"},{"type":"text","text":" "},{"text":"attributes (such as the type or size of the file).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"attributes"},{"text":" value is a string that specifies the file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"attributes that should be gathered. It is not an error if"},{"type":"text","text":" "},{"type":"text","text":"it’s not possible to read a particular requested attribute"},{"text":" ","type":"text"},{"text":"from a file — it just won’t be set. In particular this means that if a file","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is inaccessible (due to being in a folder with restrictive permissions), for"},{"text":" ","type":"text"},{"type":"text","text":"example, you can expect the returned [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","type":"reference","isActive":true},{"type":"text","text":"] to have very few"},{"text":" ","type":"text"},{"type":"text","text":"attributes set. You should check whether an attribute is set using"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.FileInfo.has_attribute"},{"type":"text","text":"] before trying to retrieve its value."}]},{"inlineContent":[{"type":"text","text":"It is guaranteed that if any of the following attributes are listed in"},{"type":"text","text":" "},{"type":"codeVoice","code":"attributes"},{"type":"text","text":", they will always be set in the returned [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true},{"text":"],","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"even if the user doesn’t have permissions to access the file:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"[const"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName","type":"reference","isActive":true},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"[const"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardDisplayName","type":"reference"},{"type":"text","text":"]"}]}]}]},{"type":"paragraph","inlineContent":[{"code":"attributes","type":"codeVoice"},{"type":"text","text":" should be a comma-separated list of attributes or attribute"},{"type":"text","text":" "},{"type":"text","text":"wildcards. The wildcard "},{"code":"\"*\"","type":"codeVoice"},{"type":"text","text":" means all attributes, and a wildcard like"},{"text":" ","type":"text"},{"type":"codeVoice","code":"\"standard``*\""},{"text":" means all attributes in the standard namespace.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"An example attribute query might be "},{"type":"codeVoice","code":"\"standard``*,owner"},{"text":"user","type":"text"},{"type":"codeVoice","code":"\""},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"The standard attributes are available as defines, like","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[const"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName","type":"reference"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"NULL","type":"codeVoice"},{"text":", then the operation can be cancelled","type":"text"},{"type":"text","text":" "},{"type":"text","text":"by triggering the cancellable object from another thread. If the"},{"text":" ","type":"text"},{"type":"text","text":"operation was cancelled, the error [error"},{"type":"codeVoice","code":"Gio.IOErrorEnum.CANCELLED"},{"text":"] will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For symlinks, normally the information about the target of the"},{"type":"text","text":" "},{"text":"symlink is returned, rather than information about the symlink","type":"text"},{"type":"text","text":" "},{"type":"text","text":"itself. However if you pass [flags"},{"type":"codeVoice","code":"Gio.FileQueryInfoFlags.NOFOLLOW_SYMLINKS"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"flags","type":"codeVoice"},{"type":"text","text":" the information about the symlink itself will be returned."},{"text":" ","type":"text"},{"text":"Also, for symlinks that point to non-existing files the information","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"about the symlink itself will be returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the file does not exist, the [error"},{"type":"codeVoice","code":"Gio.IOErrorEnum.NOT_FOUND"},{"type":"text","text":"] error will be"},{"text":" ","type":"text"},{"text":"returned. Other errors are possible too, and depend on what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file system the file is on."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/queryInfo(attributes:flags:cancellable:)-2djsf"},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileProtocol"]]},"abstract":[{"type":"text","text":"Gets the requested information about specified "},{"type":"codeVoice","code":"file"},{"text":".","type":"text"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileProtocol":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileProtocol"}],"type":"topic","role":"symbol","url":"\/documentation\/gio\/fileprotocol","navigatorTitle":[{"kind":"identifier","text":"FileProtocol"}],"abstract":[{"type":"codeVoice","code":"GFile"},{"text":" is a high level abstraction for manipulating files on a","type":"text"},{"type":"text","text":" "},{"text":"virtual file system. ","type":"text"},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"text":"that do no I\/O upon creation. It is necessary to understand that","type":"text"},{"type":"text","text":" "},{"code":"GFile","type":"codeVoice"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"type":"text","text":" "},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"type":"text","t