iseIdentifier":"s:3GIO12FileProtocolP"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If the flag "},{"type":"codeVoice","code":"overwrite"},{"type":"text","text":" is specified an already"},{"type":"text","text":" "},{"type":"text","text":"existing "},{"code":"destination","type":"codeVoice"},{"type":"text","text":" file is overwritten."}],"type":"paragraph"},{"inlineContent":[{"text":"If the flag ","type":"text"},{"code":"nofollowSymlinks","type":"codeVoice"},{"type":"text","text":" is specified then symlinks"},{"text":" ","type":"text"},{"text":"will be copied as symlinks, otherwise the target of the","type":"text"},{"type":"text","text":" "},{"code":"source","type":"codeVoice"},{"type":"text","text":" symlink will be copied."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the flag "},{"code":"allMetadata","type":"codeVoice"},{"type":"text","text":" is specified then all the metadata"},{"text":" ","type":"text"},{"type":"text","text":"that is possible to copy is copied, not just the default subset (which,"},{"text":" ","type":"text"},{"type":"text","text":"for instance, does not include the owner, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"progressCallback"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be monitored"},{"text":" ","type":"text"},{"text":"by setting this to a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProgressCallback","isActive":true},{"text":" function.","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"progressCallbackData"},{"text":" will be passed to this function. It is guaranteed","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that this callback will be called after all data has been transferred with"},{"text":" ","type":"text"},{"text":"the total number of bytes copied during the operation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the "},{"code":"source","type":"codeVoice"},{"type":"text","text":" file does not exist, then the "},{"type":"codeVoice","code":"notFound"},{"type":"text","text":" error"},{"type":"text","text":" "},{"type":"text","text":"is returned, independent on the status of the "},{"type":"codeVoice","code":"destination"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"overwrite"},{"type":"text","text":" is not specified and the target exists, then"},{"text":" ","type":"text"},{"text":"the error ","type":"text"},{"code":"exists","type":"codeVoice"},{"type":"text","text":" is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If trying to overwrite a file over a directory, the "},{"type":"codeVoice","code":"isDirectory"},{"type":"text","text":" "},{"type":"text","text":"error is returned. If trying to overwrite a directory with a directory the"},{"type":"text","text":" "},{"code":"wouldMerge","type":"codeVoice"},{"type":"text","text":" error is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the source is a directory and the target does not exist, or"},{"type":"text","text":" "},{"type":"codeVoice","code":"overwrite"},{"type":"text","text":" is specified and the target is a file, then the"},{"type":"text","text":" "},{"code":"wouldRecurse","type":"codeVoice"},{"type":"text","text":" error is returned."}]},{"inlineContent":[{"type":"text","text":"If you are interested in copying the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/File","type":"reference","isActive":true},{"type":"text","text":" object itself (not the on-disk"},{"text":" ","type":"text"},{"text":"file), see ","type":"text"},{"type":"codeVoice","code":"g_file_dup()"},{"type":"text","text":"."}],"type":"paragraph"}]}],"kind":"symbol","metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"copy","kind":"identifier"},{"text":"<","kind":"text"},{"text":"FileT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"destination"},{"text":": ","kind":"text"},{"text":"FileT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO13FileCopyFlagsV","text":"FileCopyFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"progressCallback"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GFileProgressCallback","text":"GFileProgressCallback","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"progressCallbackData"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"externalID":"s:3GIO12FilePro