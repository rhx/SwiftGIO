{"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Checks whether "},{"type":"codeVoice","code":"file"},{"text":" has the prefix specified by ","type":"text"},{"type":"codeVoice","code":"prefix"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"hasPrefix","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"FileT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"prefix"},{"text":": ","kind":"text"},{"text":"FileT","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"FileT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:3GIO12FileProtocolP","text":"FileProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol","kind":"typeIdentifier"}]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In other words, if the names of initial elements of ","type":"text"},{"type":"codeVoice","code":"file"},{"type":"text","text":"’s"},{"type":"text","text":" "},{"type":"text","text":"pathname match "},{"code":"prefix","type":"codeVoice"},{"type":"text","text":". Only full pathname elements are matched,"},{"text":" ","type":"text"},{"text":"so a path like \/foo is not considered a prefix of \/foobar, only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of \/foo\/bar."}]},{"inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"text":" is not a prefix of itself. If you want to check for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"equality, use "},{"type":"codeVoice","code":"g_file_equal()"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"This call does no I\/O, as it works purely on names. As such it can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"sometimes return "},{"code":"false","type":"codeVoice"},{"type":"text","text":" even if "},{"type":"codeVoice","code":"file"},{"text":" is inside a ","type":"text"},{"type":"codeVoice","code":"prefix"},{"text":" (from a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"filesystem point of view), because the prefix of "},{"type":"codeVoice","code":"file"},{"type":"text","text":" is an alias"},{"type":"text","text":" "},{"type":"text","text":"of "},{"code":"prefix","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"extendedModule":"GIO","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"hasPrefix"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"FileT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"prefix"},{"text":": ","kind":"text"},{"text":"FileT","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"roleHeading":"Instance Method","externalID":"s:3GIO12FileProtocolPAAE9hasPrefix6prefixSbqd___tAaBRd__lF","title":"hasPrefix(prefix:)","role":"symbol","symbolKind":"method"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileProtocol"]]},"variants":[{"paths":["\/documentation\/gio\/fileprotocol\/hasprefix(prefix:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/hasPrefix(prefix:)","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO/FileProtocol":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"k