will be"},{"type":"text","text":" "},{"text":"returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the file does not exist, the ","type":"text"},{"code":"notFound","type":"codeVoice"},{"text":" error will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be returned. Other errors are possible too, and depend on what"},{"text":" ","type":"text"},{"text":"kind of filesystem the file is on.","type":"text"}]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/fileprotocol\/queryfilesysteminfo(attributes:cancellable:)-8n53r"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"queryFilesystemInfo","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"attributes"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"CChar","preciseIdentifier":"s:s5CChara"},{"text":">!, ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"FileInfoRef","preciseIdentifier":"s:3GIO11FileInfoRefV","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"role":"symbol","title":"queryFilesystemInfo(attributes:cancellable:)","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","symbolKind":"method","externalID":"s:3GIO12FileProtocolPAAE19queryFilesystemInfo10attributes11cancellableAA0bF3RefVSgSPys4Int8VGSg_qd__SgtKAA011CancellableC0Rd__lF"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO",