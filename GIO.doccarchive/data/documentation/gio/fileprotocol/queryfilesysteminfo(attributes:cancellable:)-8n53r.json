{"abstract":[{"text":"Similar to ","type":"text"},{"code":"g_file_query_info()","type":"codeVoice"},{"type":"text","text":", but obtains information"},{"type":"text","text":" "},{"type":"text","text":"about the filesystem the "},{"code":"file","type":"codeVoice"},{"type":"text","text":" is on, rather than the file itself."},{"type":"text","text":" "},{"text":"For instance the amount of space available and the type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the filesystem."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileProtocol"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/queryFilesystemInfo(attributes:cancellable:)-8n53r"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"queryFilesystemInfo"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"attributes","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5CChara","kind":"typeIdentifier","text":"CChar"},{"kind":"text","text":">!, "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef","preciseIdentifier":"s:3GIO11FileInfoRefV","text":"FileInfoRef","kind":"typeIdentifier"},{"kind":"text","text":"! "},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier","text":"CancellableProtoco