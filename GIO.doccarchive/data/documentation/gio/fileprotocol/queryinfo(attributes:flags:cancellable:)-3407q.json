{"variants":[{"paths":["\/documentation\/gio\/fileprotocol\/queryinfo(attributes:flags:cancellable:)-3407q"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"queryInfo"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"attributes"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO18FileQueryInfoFlagsV","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileQueryInfoFlags","text":"FileQueryInfoFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef","text":"FileInfoRef","preciseIdentifier":"s:3GIO11FileInfoRefV"},{"kind":"text","text":"! "},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP","text":"CancellableProtocol","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"The result is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true},{"type":"text","text":"] object that contains key-value"},{"type":"text","text":" "},{"text":"attributes (such as the type or size of the file).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"attributes","type":"codeVoice"},{"type":"text","text":" value is a string that specifies the file"},{"type":"text","text":" "},{"text":"attributes that should be gathered. It is not an error if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it’s not possible to read a particular requested attribute"},{"type":"text","text":" "},{"text":"from a file — it just won’t be set. In particular this means that if a file","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is inaccessible (due to being in a folder with restrictive permissions), for"},{"text":" ","type":"text"},{"text":"example, you can expect the returned [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","type":"reference"},{"type":"text","text":"] to have very few"},{"type":"text","text":" "},{"text":"attributes set. You should check whether an attribute is set using","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.FileInfo.has_attribute"},{"text":"] before trying to retrieve its value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is guaranteed that if any of the following attributes are listed in"},{"type":"text","text":" "},{"type":"codeVoice","code":"attributes"},{"type":"text","text":", they will always be set in the returned [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"text":"],","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"even if the user doesn’t have permissions to access the file:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"[const","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName"},{"type":"text","text":"]"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"[const"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardDisplayName","isActive":true},{"text":"]","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"code":"attributes","type":"codeVoice"},{"text":" should be a comma-separated list of attributes or attribute","type":"text"},{"type":"text","text":" "},{"type":"text","text":"wildcards. The wildcard "},{"code":"\"*\"","type":"codeVoice"},{"type":"text","text":" means all attributes, and a wildcard like"},{"type":"text","text":" "},{"type":"codeVoice","code":"\"standard``*\""},{"text":" means all attributes in the standard namespace.","type":"text"},{"text":" ","type":"text"},{"text":"An example attribute query might be ","type":"text"},{"type":"codeVoice","code":"\"standard``*,owner"},{"type":"text","text":"user"},{"type":"codeVoice","code":"\""},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"The standard attributes are available as defines, like","type":"text"},{"type":"text","text":" "},{"text":"[const","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName","isActive":true},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"NULL","type":"codeVoice"},{"text":", then the operation can be cancelled","type":"text"},{"type":"text","text":" "},{"type":"text","text":"by triggering the cancellable object from another thread. If the"},{"type":"text","text":" "},{"text":"operation was cancelled, the error [error","type":"text"},{"code":"Gio.IOErrorEnum.CANCELLED","type":"codeVoice"},{"type":"text","text":"] will be"},{"type":"text","text":" "},{"type":"text","text":"returned."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For symlinks, normally the information about the target of the"},{"text":" ","type":"text"},{"type":"text","text":"symlink is returned, rather than information about the symlink"},{"text":" ","type":"text"},{"type":"text","text":"itself. However if you pass [flags"},{"type":"codeVoice","code":"Gio.FileQueryInfoFlags.NOFOLLOW_SYMLINKS"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"in "},{"code":"flags","type":"codeVoice"},{"type":"text","text":" the information about the symlink itself will be returned."},{"text":" ","type":"text"},{"text":"Also, for symlinks that point to non-existing files the information","type":"text"},{"type":"text","text":" "},{"type":"text","text":"about the symlink itself will be returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the file does not exist, the [error","type":"text"},{"type":"codeVoice","code":"Gio.IOErrorEnum.NOT_FOUND"},{"text":"] error will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned. Other errors are possible too, and depend on what kind of"},{"text":" ","type":"text"},{"text":"file system the file is on.","type":"text"}]}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileProtocol"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/queryInfo(attributes:flags:cancellable:)-3407q","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"symbolKind":"method","externalID":"s:3GIO12FileProtocolPAAE9queryInfo10attributes5flags11cancellableAA0bE3RefVSgSPys4Int8VGSg_AA0b5QueryE5FlagsVqd__SgtKAA011CancellableC0Rd__lF","role":"symbol","title":"queryInfo(attributes:flags:cancellable:)","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"queryInfo"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"text":">(","kind":"text"},{"text":"attributes","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"FileQueryInfoFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO18FileQueryInfoFlagsV"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"FileInfoRef","preciseIdentifier":"s:3GIO11FileInfoRefV"},{"text":"!","kind":"text"}]},"abstract":[{"text":"Gets the requested information about specified ","type":"text"},{"code":"file","type":"codeVoice"},{"type":"text","text":"."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://GIO/documentation/GIO/FileInfo":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileInfo"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","url":"\/documentation\/gio\/fileinfo","title":"FileInfo","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileInfo"}],"abstract":[{"text":"Stores information about a file system object referenced by a [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"]."}]},"doc://GIO/documentation/GIO/FileQueryInfoFlags":{"kind":"symbol","url":"\/documentation\/gio\/filequeryinfoflags","abstract":[{"type":"text","text":"Flags used when querying a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"topic","navigatorTitle":[{"text":"FileQueryInfoFlags","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"FileQueryInfoFlags","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileQueryInfoFlags","title":"FileQueryInfoFlags"},"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"},"doc://GIO/documentation/GIO/fileAttributeStandardDisplayName":{"type":"topic","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"text":"fileAttributeStandardDisplayName","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"}],"title":"fileAttributeStandardDisplayName","abstract":[{"text":"A key in the “standard” namespace for getting the display name of the file.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardDisplayName","kind":"symbol","url":"\/documentation\/gio\/fileattributestandarddisplayname","role":"symbol"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/fileAttributeStandardName":{"abstract":[{"type":"text","text":"A key in the “standard” namespace for getting the name of the file."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/fileAttributeStandardName","role":"symbol","kind":"symbol","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fileAttributeStandardName"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"title":"fileAttributeStandardName","type":"topic","url":"\/documentation\/gio\/fileattributestandardname"},"doc://GIO/documentation/GIO/FileInfoRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfoRef","title":"FileInfoRef","url":"\/documentation\/gio\/fileinforef","abstract":[{"type":"text","text":"Stores information about a file system object referenced by a [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"]."}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"FileInfoRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"FileInfoRef","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/File":{"abstract":[{"type":"codeVoice","code":"GFile"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"type":"text","text":"that do no I\/O upon creation. It is necessary to understand that"},{"type":"text","text":" "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"text":" ","type":"text"},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"text":"(see [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"text":"] and [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","url":"\/documentation\/gio\/file","title":"File","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"File","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"File"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/FileProtocol/queryInfo(attributes:flags:cancellable:)-3407q":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"queryInfo","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"kind":"text","text":">("},{"text":"attributes","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"FileQueryInfoFlags","preciseIdentifier":"s:3GIO18FileQueryInfoFlagsV"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"FileInfoRef","preciseIdentifier":"s:3GIO11FileInfoRefV"},{"text":"!","kind":"text"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol\/queryInfo(attributes:flags:cancellable:)-3407q","url":"\/documentation\/gio\/fileprotocol\/queryinfo(attributes:flags:cancellable:)-3407q","title":"queryInfo(attributes:flags:cancellable:)","abstract":[{"type":"text","text":"Gets the requested information about specified "},{"code":"file","type":"codeVoice"},{"type":"text","text":"."}],"kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/FileProtocol":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileProtocol"}],"type":"topic","role":"symbol","url":"\/documentation\/gio\/fileprotocol","navigatorTitle":[{"kind":"identifier","text":"FileProtocol"}],"abstract":[{"type":"codeVoice","code":"GFile"},{"text":" is a high level abstraction for manipulating files on a","type":"text"},{"type":"text","text":" "},{"text":"virtual file system. ","type":"text"},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"text":"that do no I\/O upon creation. It is necessary to understand that","type":"text"},{"type":"text","text":" "},{"code":"GFile","type":"codeVoice"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"type":"text","text":" "},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"type":"text","text":"(see [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"type":"text","text":"] and [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"title":"FileProtocol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileProtocol"}}}