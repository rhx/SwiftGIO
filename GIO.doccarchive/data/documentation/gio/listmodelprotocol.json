{"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP"],"kind":"relationships","title":"Inherits From","type":"inheritsFrom"},{"type":"inheritedBy","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListStoreProtocol"],"kind":"relationships","title":"Inherited By"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModel","doc:\/\/GIO\/documentation\/GIO\/ListModelRef","doc:\/\/GIO\/documentation\/GIO\/ListStore","doc:\/\/GIO\/documentation\/GIO\/ListStoreRef"],"type":"conformingTypes","kind":"relationships","title":"Conforming Types"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"sections":[],"topicSections":[{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/itemType","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/list_model_ptr-2eo93","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/nItems"]},{"anchor":"Instance-Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/connect(signal:flags:data:destroyData:signalHandler:)","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/connect(signal:flags:handler:)","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/getItem(position:)","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/getItemType()","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/getNItems()","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/getObject(position:)","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/itemsChanged(position:removed:added:)","doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/onItemsChanged(flags:handler:)"],"generated":true,"title":"Instance Methods"},{"title":"Type Properties","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/itemsChangedSignal"],"anchor":"Type-Properties"}],"metadata":{"externalID":"s:3GIO17ListModelProtocolP","modules":[{"name":"GIO"}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"ListModelProtocol","kind":"identifier"}],"role":"symbol","title":"ListModelProtocol","roleHeading":"Protocol","navigatorTitle":[{"text":"ListModelProtocol","kind":"identifier"}],"symbolKind":"protocol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ListModelProtocol"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP","text":"PointerWrapper"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"Each object in the list may also report changes in itself via some"},{"text":" ","type":"text"},{"type":"text","text":"mechanism (normally the [signal[Object](\/\/documentation\/gobject\/object\/onnotify(flags:handler:)] signal).  Taken"},{"type":"text","text":" "},{"text":"together with the [signal[ListModel](\/\/documentation\/gio\/listmodel\/onitemschanged(flags:handler:)] signal, this provides","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for a list that can change its membership, and in which the members can"},{"text":" ","type":"text"},{"text":"change their individual properties.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A good example would be the list of visible wireless network access"},{"text":" ","type":"text"},{"text":"points, where each access point can report dynamic properties such as","type":"text"},{"type":"text","text":" "},{"text":"signal strength.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that the "},{"code":"GListModel","type":"codeVoice"},{"type":"text","text":" itself does not report"},{"type":"text","text":" "},{"text":"changes to the individual items.  It only reports changes to the list","type":"text"},{"type":"text","text":" "},{"type":"text","text":"membership.  If you want to observe changes to the objects themselves"},{"text":" ","type":"text"},{"text":"then you need to connect signals to the objects that you are","type":"text"},{"type":"text","text":" "},{"text":"interested in.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"All items in a "},{"type":"codeVoice","code":"GListModel"},{"type":"text","text":" are of (or derived from) the same type."},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.ListModel.get_item_type"},{"type":"text","text":"] returns that type.  The type may be an"},{"type":"text","text":" "},{"text":"interface, in which case all objects in the list must implement it.","type":"text"}]},{"inlineContent":[{"text":"The semantics are close to that of an array:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.ListModel.get_n_items"},{"type":"text","text":"] returns the number of items in the list"},{"text":" ","type":"text"},{"type":"text","text":"and [method"},{"type":"codeVoice","code":"Gio.ListModel.get_item"},{"type":"text","text":"] returns an item at a (0-based) position."},{"text":" ","type":"text"},{"text":"In order to allow implementations to calculate the list length lazily,","type":"text"},{"type":"text","text":" "},{"text":"you can also iterate over items: starting from 0, repeatedly call","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.ListModel.get_item","type":"codeVoice"},{"type":"text","text":"] until it returns "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"An implementation may create objects lazily, but must take care to","type":"text"},{"type":"text","text":" "},{"text":"return the same object for a given position until all references to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it are gone."}]},{"inlineContent":[{"type":"text","text":"On the other side, a consumer is expected only to hold references on"},{"text":" ","type":"text"},{"text":"objects that are currently ‘user visible’, in order to facilitate the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"maximum level of laziness in the implementation of the list and to"},{"type":"text","text":" "},{"type":"text","text":"reduce the required number of signal connections at a given time."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This interface is intended only to be used from a single thread.  The"},{"type":"text","text":" "},{"text":"thread in which it is appropriate to use it depends on the particular","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implementation, but typically it will be from the thread that owns"},{"text":" ","type":"text"},{"type":"text","text":"the thread-default main context (see"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"text":"]) in effect at the time that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"model was created."}]},{"inlineContent":[{"type":"text","text":"Over time, it has established itself as good practice for list model"},{"type":"text","text":" "},{"text":"implementations to provide properties ","type":"text"},{"type":"codeVoice","code":"item-type"},{"type":"text","text":" and "},{"type":"codeVoice","code":"n-items"},{"type":"text","text":" to"},{"type":"text","text":" "},{"text":"ease working with them. While it is not required, it is recommended","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that implementations provide these two properties. They should return"},{"type":"text","text":" "},{"type":"text","text":"the values of [method"},{"code":"Gio.ListModel.get_item_type","type":"codeVoice"},{"text":"] and","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.ListModel.get_n_items","type":"codeVoice"},{"type":"text","text":"] respectively and be defined as such:"}],"type":"paragraph"},{"syntax":"c","code":["properties[PROP_ITEM_TYPE] =","  g_param_spec_gtype (\"item-type\", NULL, NULL, G_TYPE_OBJECT,","                      G_PARAM_CONSTRUCT_ONLY | G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS);","properties[PROP_N_ITEMS] =","  g_param_spec_uint (\"n-items\", NULL, NULL, 0, G_MAXUINT, 0,","                     G_PARAM_READABLE | G_PARAM_STATIC_STRINGS);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol","type":"reference"},{"text":" protocol exposes the methods and properties of an underlying ","type":"text"},{"code":"GListModel","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"The default implementation of these can be found in the protocol extension below."},{"type":"text","text":" "},{"text":"For a concrete class that implements these methods and properties, see ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Alternatively, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModelRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"text":" reference if you already have an instance you just want to use.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/listmodelprotocol"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol"},"kind":"symbol","abstract":[{"type":"codeVoice","code":"GListModel"},{"text":" is an interface that represents a mutable list of","type":"text"},{"type":"text","text":" "},{"text":"[class[Object](\/\/documentation\/gobject\/object]. Its main intention is as a model for various widgets","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in user interfaces, such as list views, but it can also be used as a"},{"type":"text","text":" "},{"type":"text","text":"convenient method of returning lists of data, with support for"},{"type":"text","text":" "},{"type":"text","text":"updates."}],"references":{"doc://GIO/documentation/GIO/ListStoreProtocol":{"navigatorTitle":[{"text":"ListStoreProtocol","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListStoreProtocol","title":"ListStoreProtocol","url":"\/documentation\/gio\/liststoreprotocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ListStoreProtocol"}],"abstract":[{"type":"codeVoice","code":"GListStore"},{"type":"text","text":" is a simple implementation of [iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModel","type":"reference"},{"type":"text","text":"] that stores"},{"text":" ","type":"text"},{"type":"text","text":"all items in memory."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/ListModelProtocol/connect(signal:flags:data:destroyData:signalHandler:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/connect(signal:flags:data:destroyData:signalHandler:)","abstract":[{"text":"Connect a C signal handler to the given, typed ","type":"text"},{"code":"ListModelSignalName","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"topic","role":"symbol","title":"connect(signal:flags:data:destroyData:signalHandler:)","url":"\/documentation\/gio\/listmodelprotocol\/connect(signal:flags:data:destroydata:signalhandler:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"con