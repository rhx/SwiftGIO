xt","text":"updates."}],"title":"ListModelRef","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ListModelRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"ListModelRef","kind":"identifier"}],"url":"\/documentation\/gio\/listmodelref"},"doc://GIO/documentation/GIO/ListModelProtocol/list_model_ptr-2eo93":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/list_model_ptr-2eo93","abstract":[{"type":"text","text":"Typed pointer to the underlying "},{"code":"GListModel","type":"codeVoice"},{"text":" instance.","type":"text"}],"required":true,"title":"list_model_ptr","type":"topic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"list_model_ptr","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"GListModel","kind":"typeIdentifier"},{"text":">!","kind":"text"}],"kind":"symbol","defaultImplementations":1,"url":"\/documentation\/gio\/listmodelprotocol\/list_model_ptr-2eo93"},"doc://GIO/documentation/GIO/ListModelProtocol/getObject(position:)":{"abstract":[{"text":"Get the item at ","type":"text"},{"type":"codeVoice","code":"position"},{"text":".","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getObject","kind":"identifier"},{"text":"(","kind":"text"},{"text":"position","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/listmodelprotocol\/getobject(position:)","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ListModelProtocol\/getObject(position:)","title":"getObject(position:)"}}}