{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/DebugControllerDBusProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/stop()","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"stop"},{"text":"()","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Any pending method calls to the object will complete successfully, but new"},{"text":" ","type":"text"},{"text":"ones will return an error. This method will block until all pending","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:) signals have been handled. This is expected"},{"text":" ","type":"text"},{"type":"text","text":"to not take long, as it will just be waiting for threads to join. If any"},{"type":"text","text":" "},{"type":"text","text":"[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:) signal handlers are still executing in other"},{"type":"text","text":" "},{"type":"text","text":"threads, this will block until after they have returned."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This method will be called automatically when the final reference to the"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus"},{"type":"text","text":" is dropped. You may want to call it explicitly to know"},{"text":" ","type":"text"},{"type":"text","text":"when the controller has been fully removed from the bus, or to break"},{"type":"text","text":" "},{"type":"text","text":"reference count cycles."}],"type":"paragraph"},{"inlineContent":[{"text":"Calling this method from within a [DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:) signal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handler will cause a deadlock and must not be done."}],"type":"paragraph"}]}],"metadata":{"extendedModule":"GIO","externalID":"s:3GIO27DebugControllerDBusProtocolPAAE4stopyyF::SYNTHESIZED::s:3GIO19DebugControllerDBusC","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stop"},{"kind":"text","text":"()"}],"title":"stop()","modules":[{"name":"GIO"}],"roleHeading":"Instance Method"},"abstract":[{"type":"text","text":"Stop the debug controller, unregistering its object from the bus."}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/debugcontrollerdbus\/stop()"]}],"sections":[],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DebugControllerDBus/DebugControllerDBusProtocol-Implementations":{"url":"\/documentation\/gio\/debugcontrollerdbus\/debugcontrollerdbusprotocol-implementations","type":"topic","title":"DebugControllerDBusProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/DebugControllerDBusProtocol-Implementations"},"doc://GIO/documentation/GIO/DebugController":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"DebugController"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","url":"\/documentation\/gio\/debugcontroller",