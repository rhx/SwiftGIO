{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/InitableProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"roleHeading":"Instance Method","modules":[{"name":"GIO"}],"extendedModule":"GIO","title":"init_(cancellable:)","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO19DebugControllerDBusC","role":"symbol","symbolKind":"method"},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init_(cancellable:)"},"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"type":"text","text":" "},{"code":"g_initable_new()","type":"codeVoice"},{"text":" should typically be used instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The object must be initialized before any real use after initial"},{"type":"text","text":" "},{"text":"construction, either with this function or ","type":"text"},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"text":" ","type":"text"},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and"},{"type":"text","text":" "},{"text":"the object doesn’t support cancellable initialization the error","type":"text"},{"text":" ","type":"text"},{"code":"notSupported","type":"codeVoice"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"inlineContent":[{"text":"If the object is not initialized, or initialization returns with an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"error, then all operations on the object except "},{"code":"g_object_ref()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_unref()"},{"text":" are considered to be invalid, and have undefined","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"behaviour. See the "},{"type":"reference","isActive":true,"identifier":"#iface@Gio.Initable#description"},{"text":" for more details.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"type":"text","text":" can be"},{"type":"text","text":" "},{"text":"initialized multiple times, unless the class explicitly documents itself as","type":"text"},{"text":" ","type":"text"},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"code":"init()","type":"codeVoice"},{"type":"text","text":" can assume"},{"text":" ","type":"text"},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"type":"text","text":" "},{"type":"text","text":"recommended all "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"type":"text","text":" implementations should be idempotent; that"},{"text":" ","type":"text"},{"text":"recommendation was relaxed in GLib 2.54.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"text":" ","type":"text"},{"text":"recommended that the method is idempotent: multiple calls with the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"text":" ","type":"text"},{"type":"text","text":"the object; further calls return the result of the first call."}]},{"inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"text":" ","type":"text"},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"text":" ","type":"text"},{"code":"GObjectClass.constructor","type":"codeVoice"},{"text":" that sometimes returns an existing instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"In this pattern, a caller would expect to be able to call "},{"type":"codeVoice","code":"g_initable_init()"},{"text":" ","type":"text"},{"text":"on the result of ","type":"text"},{"code":"g_object_new()","type":"codeVoice"},{"type":"text","text":", regardless of whether it is in fact a new"},{"type":"text","text":" "},{"text":"instance.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/debugcontrollerdbus\/init_(cancellable:)"]}],"references":{"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/DebugController":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"DebugController"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","url":"\/documentation\/gio\/debugcontroller","title":"DebugController","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DebugController","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDebugController"},{"type":"text","text":" is an interface to expose control of debugging features and"},{"type":"text","text":" "},{"text":"debug output.","type":"text"}]},"#iface@Gio.Initable#description":{"type":"link","title":"description","titleInlineContent":[{"text":"description","type":"text"}],"url":"#iface@Gio.Initable#description","identifier":"#iface@Gio.Initable#description"},"doc://GIO/documentation/GIO/DebugControllerDBus/init_(cancellable:)":{"role":"symbol","title":"init_(cancellable:)","abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/init_(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"url":"\/documentation\/gio\/debugcontrollerdbus\/init_(cancellable:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/DebugControllerDBus":{"kind":"symbol","abstract":[{"type":"codeVoice","code":"GDebugControllerDBus"},{"type":"text","text":" is an implementation of [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"which exposes debug settings as a D-Bus object.","type":"text"}],"url":"\/documentation\/gio\/debugcontrollerdbus","type":"topic","navigatorTitle":[{"kind":"identifier","text":"DebugControllerDBus"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","title":"DebugControllerDBus","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DebugControllerDBus"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/DebugControllerDBus/InitableProtocol-Implementations":{"url":"\/documentation\/gio\/debugcontrollerdbus\/initableprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/InitableProtocol-Implementations","abstract":[],"role":"collectionGroup","title":"InitableProtocol Implementations","type":"topic","kind":"article"}}}