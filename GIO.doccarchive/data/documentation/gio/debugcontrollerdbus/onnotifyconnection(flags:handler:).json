{"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"sections":[],"variants":[{"paths":["\/documentation\/gio\/debugcontrollerdbus\/onnotifyconnection(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Instance Method","symbolKind":"method","externalID":"s:3GIO27DebugControllerDBusProtocolPAAE18onNotifyConnection5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bcD3RefV_AG09ParamSpecO0VtctF::SYNTHESIZED::s:3GIO19DebugControllerDBusC","extendedModule":"GIO","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyConnection","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO22DebugControllerDBusRefV","text":"DebugControllerDBusRef"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"title":"onNotifyConnection(flags:handler:)","modules":[{"name":"GIO"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyConnection"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"kind":"text","text":" = ConnectFlags(0), "},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:3GIO22DebugControllerDBusRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusRef","text":"DebugControllerDBusRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier","text":"ParamSpecRef"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"text":") -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"notifyConnection"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}],"name":"handler"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to ","type":"text"},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}]},{"content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::connection"},{"type":"text","text":" signal"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/DebugControllerDBusProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/onNotifyConnection(flags:handler:)"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DebugControllerDBus/onNotifyConnection(flags:handler:)":{"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"type":"text","text":", et al."}],"url":"\/documentation\/gio\/debugcontrollerdbus\/onnotifyconnection(flags:handler:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus\/onNotifyConnection(flags:handler:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyConnection","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO22DebugControllerDBusRefV","text":"DebugControllerDBusRef"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},