{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroupSignalName\/notify","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"code":"g_object_set()","type":"codeVoice"},{"text":", et al.","type":"text"}],"metadata":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notify"}],"title":"SimpleActionGroupSignalName.notify","externalID":"s:3GIO27SimpleActionGroupSignalNameO6notifyyA2CmF","modules":[{"name":"GIO"}],"symbolKind":"case","roleHeading":"Case","role":"symbol"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroupSignalName"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/simpleactiongroupsignalname\/notify"]}],"sections":[],"kind":"symbol","references":{"doc://GIO/documentation/GIO/SimpleActionGroupSignalName":{"type":"topic","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"SimpleActionGroupSignalName"}],"title":"SimpleActionGroupSignalName","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroupSignalName","kind":"symbol","url":"\/documentation\/gio\/simpleactiongroupsignalname","role":"symbol","navigatorTitle":[{"text":"SimpleActionGroupSignalName","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SimpleActionGroupSignalName/notify":{"abstract":[{"text":"The notify signal is emitted on an object when one of its properties has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"code":"g_object_set()","type":"codeVoice"},{"type":"text","text":", et al."}],"title":"SimpleActionGroupSignalName.notify","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroupSignalName\/notify","role":"symbol","url":"\/documentation\/gio\/simpleactiongroupsignalname\/notify","kind":"symbol","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}]},"#class@GObject.ParamSpec#parameter-names":{"type":"link","titleInlineContent":[{"type":"text","text":"canonical parameter names"}],"title":"canonical parameter names","url":"#class@GObject.ParamSpec#parameter-names","identifier":"#class@GObject.ParamSpec#parameter-names"}}}