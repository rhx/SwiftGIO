{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/asyncinitableref\/initasync(iopriority:cancellable:callback:userdata:)"]}],"kind":"symbol","abstract":[{"text":"Starts asynchronous initialization of the object implementing the","type":"text"},{"text":" ","type":"text"},{"text":"interface. This must be done before any real use of the object after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initial construction. If the object also implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true,"type":"reference"},{"text":" you can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"optionally call "},{"type":"codeVoice","code":"g_initable_init()"},{"text":" instead.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AsyncInitableRef","doc:\/\/GIO\/documentation\/GIO\/AsyncInitableRef\/AsyncInitableProtocol-Implementations"]]},"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"initAsync","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"kind":"text","text":"? = nil, "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_async_initable_new_async()"},{"type":"text","text":" should typically be used instead."}]},{"inlineContent":[{"type":"text","text":"When the initialization is finished, "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called. You can"},{"text":" ","type":"text"},{"type":"text","text":"then call "},{"type":"codeVoice","code":"g_async_initable_init_finish()"},{"text":" to get the result of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialization."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not"},{"type":"text","text":" "},{"code":"nil","type":"codeVoice"},{"text":", then initialization can be cancelled by triggering the cancellable","type":"text"},{"text":" ","type":"text"},{"text":"object from another thread. If the operation was cancelled, the error","type":"text"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"text":"the object doesn’t support cancellable initialization, the error","type":"text"},{"type":"text","text":" "},{"code":"notSupported","type":"codeVoice"},{"type":"text","text":" will be returned."}]},{"inlineContent":[{"text":"As with ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":", if the object is not initialized, or initialization"},{"text":" ","type":"text"},{"type":"text","text":"returns with an error, then all operations on the object except"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_ref()"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"text":" are considered to be invalid, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have undefined behaviour. They will often fail with "},{"code":"g_critical()","type":"codeVoice"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_warning()"},{"type":"text","text":", but this must not be relied on."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","isActive":true,"type":"reference"},{"type":"text","text":" can"},{"text":" ","type":"text"},{"type":"text","text":"be initialized multiple times; for more information, see "},{"code":"g_initable_init()","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"If a class explicitly supports being initialized multiple times,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implementation requires yielding all subsequent calls to "},{"code":"init_async()","type":"codeVoice"},{"text":" on the","type":"text"},{"text":" ","type":"text"},{"text":"results of the first call.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For classes that also support the "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference"},{"text":" interface, the default","type":"text"},{"text":" ","type":"text"},{"text":"implementation of this method will run the ","type":"text"},{"code":"g_initable_init()","type":"codeVoice"},{"text":" function","type":"text"},{"type":"text","text":" "},{"text":"in a thread, so if you want to support asynchronous initialization via","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads, just implement the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference","isActive":true},{"text":" interface without overriding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"any interface methods."}],"type":"paragraph"}]}],"metadata":{"externalID":"s:3GIO21AsyncInitableProtocolPAAE04initB010ioPriority11cancellable8callback8userDataySi_AA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgATtF::SYNTHESIZED::s:3GIO16AsyncInitableRefV","role":"symbol","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"initAsync"},{"text":"(","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}],"modules":[{"name":"GIO"}],"extendedModule":"GIO","title":"initAsync(ioPriority:cancellable:callback:userData:)"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitableRef\/initAsync(ioPriority:cancellable:callback:userData:)"},"references":{"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type"