should contain a file called ","type":"text"},{"type":"codeVoice","code":"gschemas.compiled"},{"text":" as","type":"text"},{"text":" ","type":"text"},{"text":"produced by the ","type":"text"},{"type":"reference","identifier":"#glib-compile-schemas","isActive":true},{"text":" tool.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"trusted"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" then "},{"type":"codeVoice","code":"gschemas.compiled"},{"text":" is trusted not to be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"corrupted. This assumption has a performance advantage, but can result"},{"type":"text","text":" "},{"type":"text","text":"in crashes or inconsistent behaviour in the case of a corrupted file."},{"text":" ","type":"text"},{"type":"text","text":"Generally, you should set "},{"code":"trusted","type":"codeVoice"},{"type":"text","text":" to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" for files installed by the"},{"text":" ","type":"text"},{"text":"system and to ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" for files in the home directory."}],"type":"paragraph"},{"inlineContent":[{"text":"In either case, an empty file or some types of corruption in the file will","type":"text"},{"type":"text","text":" "},{"text":"result in [inval](\/\/documentation\/glib\/inval being returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"parent"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" then there are two effects.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"First, if "},{"type":"codeVoice","code":"g_settings_schema_source_lookup()"},{"type":"text","text":" is called with the"},{"type":"text","text":" "},{"code":"recursive","type":"codeVoice"},{"type":"text","text":" flag set to "},{"type":"codeVoice","code":"true"},{"text":" and the schema can not be found in the","type":"text"},{"type":"text","text":" "},{"text":"source, the lookup will recurse to the parent.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Second, any references to other schemas specified within this"},{"text":" ","type":"text"},{"type":"text","text":"source (ie: "},{"type":"codeVoice","code":"child"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"extends"},{"text":") references may be resolved","type":"text"},{"text":" ","type":"text"},{"text":"from the ","type":"text"},{"type":"codeVoice","code":"parent"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For this second reason, except in very unusual situations, the","type":"text"},{"type":"text","text":" "},{"code":"parent","type":"codeVoice"},{"type":"text","text":" should probably be given as the default schema source, as"},{"type":"text","text":" "},{"type":"text","text":"returned by "},{"type":"codeVoice","code":"g_settings_schema_source_get_default()"},{"text":".","type":"text"}]}]}],"abstract":[{"text":"Attempts to create a new schema source corresponding to the contents","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the given directory."}],"metadata":{"role":"symbol","roleHeading":"Initializer","symbolKind":"init","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SettingsSchemaSourceT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"directory","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"parent","kind":"externalParam"},{"kind":"text","text":": "},{"text":"SettingsSchemaSourceT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"trusted","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"}],"title":"init(directory:parent:trusted:)","extendedModule":"GIO","externalID":"s:3GIO23SettingsSchemaSourceRefV9directory6parent7trustedACSPys4Int8VGSg_xSgSbtKcAA0bcD8ProtocolRzlufc","modules":[{"name":"GIO"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceRef"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingsschemasourceref\/init(directory:parent:trusted:)"]}],"references":{"doc://GIO/documentation/GIO/Settings":{"title":"Settings","kind":"symbol","url":"\/documentation\/gio\/settings","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSettings"},{"type":"text","text":" class provides a convenient API for storing and retrieving"},{"type":"text","text":" "},{"type":"text","text":"application settings."}],"type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Settings"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","role":"symbol","navigatorTitle":[{"text":"Settings","kind":"identifier"}]},"doc://GIO/documentation/GIO/SettingsSchemaSourceProtocol":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceProtocol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SettingsSchemaSourceProtocol"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SettingsSchemaSourceProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/settingsschemasourceprotocol","title":"SettingsSchemaSourceProtocol","abstract":[{"text":"This is an opaque structure type.  You may not access it directly.","type":"text"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc: