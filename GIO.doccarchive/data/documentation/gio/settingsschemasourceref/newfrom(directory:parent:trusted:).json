{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceRef\/newFrom(directory:parent:trusted:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingsschemasourceref\/newfrom(directory:parent:trusted:)"]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"newFrom"},{"text":"<","kind":"text"},{"text":"SettingsSchemaSourceT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"directory","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"text":"parent","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"SettingsSchemaSourceT"},{"kind":"text","text":"?, "},{"text":"trusted","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"SettingsSchemaSourceRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO23SettingsSchemaSourceRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceRef"},{"text":"! ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SettingsSchemaSourceT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceProtocol","text":"SettingsSchemaSourceProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO28SettingsSchemaSourceProtocolP"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This function is not required for normal uses of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","isActive":true,"type":"reference"},{"type":"text","text":" but it"},{"text":" ","type":"text"},{"text":"may be useful to authors of plugin management systems.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The directory should contain a file called ","type":"text"},{"code":"gschemas.compiled","type":"codeVoice"},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"type":"reference","identifier":"#glib-compile-schemas","isActive":true},{"text":" tool.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"trusted","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":" then ","type":"text"},{"type":"codeVoice","code":"gschemas.compiled"},{"text":" is trusted not to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"corrupted. This assumption has a performance advantage, but can result"},{"text":" ","type":"text"},{"type":"text","text":"in crashes or inconsistent behaviour in the case of a corrupted file."},{"type":"text","text":" "},{"type":"text","text":"Generally, you should set "},{"type":"codeVoice","code":"trusted"},{"type":"text","text":" to "},{"code":"true","type":"codeVoice"},{"text":" for files installed by the","type":"text"},{"text":" ","type":"text"},{"text":"system and to ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" for files in the home directory."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In either case, an empty file or some types of corruption in the file will"},{"type":"text","text":" "},{"type":"text","text":"result in [inval](\/\/documentation\/glib\/inval being returned."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"parent"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then there are two effects."}],"type":"paragraph"},{"inlineContent":[{"text":"First, if ","type":"text"},{"code":"g_settings_schema_source_lookup()","type":"codeVoice"},{"type":"text","text":" is called with the"},{"type":"text","text":" "},{"code":"recursive","type":"codeVoice"},{"type":"text","text":" flag set to "},{"type":"codeVoice","code":"true"},{"text":" and the schema can not be found in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source, the lookup will recurse to the parent."}],"type":"paragraph"},{"inlineContent":[{"text":"Second, any references to other schemas specified within this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source (ie: "},{"code":"child","type":"codeVoice"},{"type":"text","text":" or "},{"code":"extends","type":"codeVoice"},{"text":") references may be resolved","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from the "},{"type":"codeVoice","code":"parent"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For this second reason, except in very unusual situations, the"},{"type":"text","text":" "},{"type":"codeVoice","code":"parent"},{"type":"text","text":" should probably be given as the default schema source, as"},{"type":"text","text":" "},{"text":"returned by ","type":"text"},{"code":"g_settings_schema_source_get_default()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceRef"]]},"metadata":{"title":"newFrom(directory:parent:trusted:)","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"newFrom","kind":"identifier"},{"text":"<","kind":"text