{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The "},{"code":"GCredentials","type":"codeVoice"},{"type":"text","text":" type is a reference-counted wrapper for native"},{"type":"text","text":" "},{"text":"credentials.","type":"text"}],"variants":[{"paths":["\/documentation\/gio\/credentialsprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"title":"CredentialsProtocol","roleHeading":"Protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CredentialsProtocol"}],"symbolKind":"protocol","navigatorTitle":[{"text":"CredentialsProtocol","kind":"identifier"}],"role":"symbol","modules":[{"name":"GIO"}],"externalID":"s:3GIO19CredentialsProtocolP"},"sections":[],"relationshipsSections":[{"title":"Inherits From","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"kind":"relationships","type":"inheritsFrom"},{"title":"Conforming Types","kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/Credentials","doc:\/\/GIO\/documentation\/GIO\/CredentialsRef"],"type":"conformingTypes"}],"kind":"symbol","topicSections":[{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol\/credentials_ptr-896kv","doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol\/unixPid","doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol\/unixUser"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol\/getNative(nativeType:)","doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol\/getUnixPid()","doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol\/getUnixUser()","doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol\/isSameUser(otherCredentials:)","doc:\/