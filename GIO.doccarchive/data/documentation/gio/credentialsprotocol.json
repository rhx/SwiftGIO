"text":"] for details."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Linux, the native credential type is a "},{"code":"struct ucred","type":"codeVoice"},{"type":"text","text":" - see the"},{"text":" ","type":"text"},{"type":"reference","identifier":"man:unix(7)","isActive":true},{"text":" for details. This corresponds to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_CREDENTIALS_TYPE_LINUX_UCRED"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Apple operating systems (including iOS, tvOS, and macOS), the native credential"},{"text":" ","type":"text"},{"type":"text","text":"type is a "},{"type":"codeVoice","code":"struct xucred"},{"type":"text","text":". This corresponds to "},{"type":"codeVoice","code":"G_CREDENTIALS_TYPE_APPLE_XUCRED"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"On FreeBSD, Debian GNU\/kFreeBSD, and GNU\/Hurd, the native credential type is a"},{"type":"text","text":" "},{"type":"codeVoice","code":"struct cmsgcred"},{"type":"text","text":". This corresponds to "},{"code":"G_CREDENTIALS_TYPE_FREEBSD_CMSGCRED","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On NetBSD, the native credential type is a ","type":"text"},{"type":"codeVoice","code":"struct unpcbid"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"This corresponds to "},{"type":"codeVoice","code":"G_CREDENTIALS_TYPE_NETBSD_UNPCBID"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"On OpenBSD, the native credential type is a ","type":"text"},{"code":"struct sockpeercred","type":"codeVoice"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"This corresponds to "},{"code":"G_CREDENTIALS_TYPE_OPENBSD_SOCKPEERCRED","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On Solaris (including OpenSolaris and its derivatives), the native credential type"},{"type":"text","text":" "},{"text":"is a ","type":"text"},{"code":"ucred_t","type":"codeVoice"},{"text":". This corresponds to ","type":"text"},{"type":"codeVoice","code":"G_CREDENTIALS_TYPE_SOLARIS_UCRED"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Since GLib 2.72, on Windows, the native credentials may contain the PID of a","type":"text"},{"text":" ","type":"text"},{"text":"process. This corresponds to ","type":"text"},{"type":"codeVoice","code":"G_CREDENTIALS_TYPE_WIN32_PID"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/CredentialsProtocol"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GCredentials","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Credentials","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/CredentialsRef","isActive":true},{"type":"text","text":" as a lighweight, "},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}]}],"references":{"doc://GIO/4GLib14PointerWrapperP":{"identifier":"doc:\/\/GIO\/4GLib14PointerWrapperP","type":"unresolvable","title":"GLib.PointerWrapper"},"doc://GIO/documentation/GIO/CredentialsRef":{"type":"topic","kind":"symbol","navigatorTitle":[{"text":"CredentialsRef","kind":"identifier"