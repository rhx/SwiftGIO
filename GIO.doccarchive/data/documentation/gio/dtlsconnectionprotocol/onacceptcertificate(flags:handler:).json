{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol\/onAcceptCertificate(flags:handler:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Emitted during the TLS handshake after the peer certificate has"},{"type":"text","text":" "},{"type":"text","text":"been received. You can examine "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":"’s certification path by"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"code":"g_tls_certificate_get_issuer()","type":"codeVoice"},{"type":"text","text":" on it."}],"variants":[{"paths":["\/documentation\/gio\/dtlsconnectionprotocol\/onacceptcertificate(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onAcceptCertificate","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":" = ConnectFlags(0), "},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:3GIO17DtlsConnectionRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionRef","text":"DtlsConnectionRef"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSCertificateRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","text":"TLSCertificateRef"},{"kind":"text","text":", "},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","text":"TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}],"name":"flags"},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"true"},{"text":" to accept ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"text":" (which will also immediately end the signal emission). ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" to allow the signal emission to continue, which will cause the handshake to fail if no one else overrides it.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"acceptCertificate"},{"text":" signal is emitted","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"For a client-side connection, ","type":"text"},{"type":"codeVoice","code":"peerCert"},{"type":"text","text":" is the server’s"},{"text":" ","type":"text"},{"type":"text","text":"certificate, and the signal will only be emitted if the"},{"type":"text","text":" "},{"type":"text","text":"certificate was not acceptable according to "},{"code":"conn","type":"codeVoice"},{"type":"text","text":"’s"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","isActive":true},{"type":"text","text":". If you would like the"},{"type":"text","text":" "},{"text":"certificate to be accepted despite ","type":"text"},{"code":"errors","type":"codeVoice"},{"type":"text","text":", return "},{"type":"codeVoice","code":"true"},{"text":" from the","type":"text"},{"type":"text","text":" "},{"text":"signal handler. Otherwise, if no handler accepts the certificate,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the handshake will fail with "},{"type":"codeVoice","code":"badCertificate"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, this signal"},{"type":"text","text":" "},{"type":"text","text":"will be emitted with at least one error will be set in "},{"type":"codeVoice","code":"errors"},{"text":", but","type":"text"},{"text":" ","type":"text"},{"text":"it does not guarantee that all possible errors will be set.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Accordingly, you may not safely decide to ignore any particular"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"text":" ","type":"text"},{"type":"codeVoice","code":"expired"},{"type":"text","text":" if you want to allow expired"},{"text":" ","type":"text"},{"text":"certificates, because this could potentially be the only error flag","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"set even if other problems exist with the certificate."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For a server-side connection, "},{"type":"codeVoice","code":"peerCert"},{"type":"text","text":" is the certificate"},{"text":" ","type":"text"},{"type":"text","text":"presented by the client, if this was requested via the server’s"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","type":"reference","isActive":true},{"type":"text","text":". On the server side,"},{"text":" ","type":"text"},{"type":"text","text":"the signal is always emitted when the client presents a"},{"text":" ","type":"text"},{"type":"text","text":"certificate, and the certificate will only be accepted if a"},{"type":"text","text":" "},{"text":"handler returns ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"type":"text","text":" "},{"text":"in the main thread, then you should not attempt to interact with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the user before returning from the signal handler. If you want to"},{"type":"text","text":" "},{"type":"text","text":"let the user decide whether or not to accept the certificate, you"},{"text":" ","type":"text"},{"type":"text","text":"would have to return "},{"type":"codeVoice","code":"false"},{"text":" from the signal handler on the first","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"attempt, and then after the connection attempt returns a"},{"text":" ","type":"text"},{"code":"badCertificate","type":"codeVoice"},{"text":", you can interact with the user, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"if the user decides to accept the certificate, remember that fact,"},{"text":" ","type":"text"},{"type":"text","text":"create a new connection, and return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the signal handler"},{"type":"text","text":" "},{"type":"text","text":"the next time."}]},{"type":"paragraph","inlineContent":[{"text":"If you are doing I\/O in another thread, you do not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"need to worry about this, and can simply block in the signal"},{"text":" ","type":"text"},{"text":"handler until the UI thread returns an answer.","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"accept-certificate"},{"text":" signal","type":"text"}],"type":"paragraph"}]}]}],"metadata":{"symbolKind":"method","title":"onAcceptCertificate(flags:handler:)","externalID":"s