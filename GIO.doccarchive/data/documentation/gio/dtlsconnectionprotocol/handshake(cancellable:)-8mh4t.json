{"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"handshake"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"On the client side, it is never necessary to call this method;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"although the connection needs to perform a handshake after"},{"text":" ","type":"text"},{"type":"text","text":"connecting, "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","type":"reference","isActive":true},{"text":" will handle this for you automatically","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when you try to send or receive data on the connection. You can call"},{"text":" ","type":"text"},{"code":"g_dtls_connection_handshake()","type":"codeVoice"},{"type":"text","text":" manually if you want to know whether"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake succeeded or failed (as opposed to just"},{"type":"text","text":" "},{"type":"text","text":"immediately trying to use "},{"code":"conn","type":"codeVoice"},{"text":" to read or write, in which case,","type":"text"},{"type":"text","text":" "},{"text":"if it fails, it may not be possible to tell if it failed before","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or after completing the handshake), but beware that servers may reject"},{"text":" ","type":"text"},{"type":"text","text":"client authentication after the handshake has completed, so a"},{"text":" ","type":"text"},{"text":"successful handshake does not indicate the connection will be usable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Likewise, on the server side, although a handshake is necessary at","type":"text"},{"text":" ","type":"text"},{"text":"the beginning of the communication, you do not need to call this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"function explicitly unless you want clearer error reporting."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Previously, calling "},{"code":"g_dtls_connection_handshake()","type":"codeVoice"},{"type":"text","text":" after the initial"},{"text":" ","type":"text"},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"type":"text","text":" "},{"type":"text","text":"deprecated in GLib 2.60 because rehandshaking was removed from the"},{"type":"text","text":" "},{"text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake will no longer do anything."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the"},{"type":"text","text":" "},{"type":"text","text":"handshake."}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/gio\/dtlsconnectionprotocol\/handshake(cancellable:)-8mh4t"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","title":"handshake(cancellable:)","extendedModule":"GIO","externalID":"s:3GIO22DtlsConnectionP