":"text","text":".  The "},{"code":"data","type":"codeVoice"},{"type":"text","text":" is resized by the callee"},{"text":" ","type":"text"},{"text":"using [ByteArray](\/\/documentation\/glib\/bytearray buffer management and will be freed when the ","type":"text"},{"code":"data","type":"codeVoice"},{"type":"text","text":" "},{"text":"is destroyed by ","type":"text"},{"code":"g_byte_array_unref()","type":"codeVoice"},{"type":"text","text":". If "},{"code":"data","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", it will only"},{"text":" ","type":"text"},{"type":"text","text":"check whether TLS backend is able to fetch the data (e.g. whether "},{"code":"type","type":"codeVoice"},{"text":" ","type":"text"},{"text":"is supported by the TLS backend). It does not guarantee that the data","type":"text"},{"type":"text","text":" "},{"text":"will be available though.  That could happen if TLS connection does not","type":"text"},{"text":" ","type":"text"},{"text":"support ","type":"text"},{"type":"codeVoice","code":"type"},{"type":"text","text":" or the binding data is not available yet due to additional"},{"type":"text","text":" "},{"text":"negotiation or input required.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/dtlsconnectionprotocol\/getchannelbindingdata(type:data:)-6pbis"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol\/getChannelBindingData(type:data:)-6pbis","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol"]]},"metadata":{"title":"getChannelBindingData(type:data:)","roleHeading":"Instance Method","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getChannelBindingData"},{"text":"<","kind":"text"},{"kind":"g