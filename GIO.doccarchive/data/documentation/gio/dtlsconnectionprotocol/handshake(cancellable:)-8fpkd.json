{"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol\/handshake(cancellable:)-8fpkd","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"handshake","kind":"identifier"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CancellableT"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","text":"CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"On the client side, it is never necessary to call this method;"},{"type":"text","text":" "},{"text":"although the connection needs to perform a handshake after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connecting, "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","type":"reference","isActive":true},{"type":"text","text":" will handle this for you automatically"},{"type":"text","text":" "},{"type":"text","text":"when you try to send or receive data on the connection. You can call"},{"text":" ","type":"text"},{"code":"g_dtls_connection_handshake()","type":"codeVoice"},{"t