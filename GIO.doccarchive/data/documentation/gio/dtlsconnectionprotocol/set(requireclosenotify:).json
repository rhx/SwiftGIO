{"sections":[],"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","externalID":"s:3GIO22DtlsConnectionProtocolPAAE3set18requireCloseNotifyySb_tF","extendedModule":"GIO","role":"symbol","symbolKind":"method","title":"set(requireCloseNotify:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"requireCloseNotify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}]},"abstract":[{"text":"Sets whether or not ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":" expects a proper TLS close notification"},{"type":"text","text":" "},{"type":"text","text":"before the connection is closed. If this is "},{"code":"true","type":"codeVoice"},{"text":" (the default),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then "},{"type":"codeVoice","code":"conn"},{"type":"text","text":" will expect to receive a TLS close notification from its"},{"text":" ","type":"text"},{"type":"text","text":"peer before the connection is closed, and will return a"},{"type":"text","text":" "},{"type":"codeVoice","code":"eof"},{"type":"text","text":" error if the connection is closed without proper"},{"type":"text","text":" "},{"type":"text","text":"notification (since this may indicate a network error, or"},{"type":"text","text":" "},{"text":"man-in-the-middle attack).","type":"text"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol\/set(requireCloseNotify:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"requireCloseNotify"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In some protocols, the application will know whether or not the"},{"text":" ","type":"text"},{"type":"text","text":"connection was closed cleanly based on application-level data"},{"type":"text","text":" "},{"text":"(because the application-level data includes a length field, or is","type":"text"},{"type":"text","text":" "},{"text":"somehow self-delimiting); in this case, the close notify is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"redundant and may be omitted. You"},{"text":" ","type":"text"},{"type":"text","text":"can use "},{"code":"g_dtls_connection_set_require_close_notify()","type":"codeVoice"},{"type":"text","text":" to tell "},{"type":"codeVoice","code":"conn"},{"type":"text","text":" "},{"text":"to allow an “unannounced” connection close, in which case the close","type":"text"},{"text":" ","type":"text"},{"text":"will show up as a 0-length read, as in a non-TLS","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased"},{"text":", and it is up to the application to check that","type":"text"},{"text":" ","type":"text"},{"text":"the data has been fully received.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this only affects the behavior when the peer closes the"},{"type":"text","text":" "},{"type":"text","text":"connection; when the application calls "},{"type":"codeVoice","code":"g_dtls_connection_close_async()"},{"type":"text","text":" on"},{"text":" ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":" itself, this will send a close notification regardless of the"},{"type":"text","text":" "},{"type":"text","text":"setting of this property. If you explicitly want to do an unclean"},{"type":"text","text":" "},{"type":"text","text":"close, you can close "},{"type":"codeVoice","code":"conn"},{"text":"’s ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"text":" rather","type":"text"},{"type":"text","text":" "},{"text":"than closing ","type":"text"},{"type":"codeVoice","code":"conn"},{"text":" itself.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/gio\/dtlsconnectionprotocol\/set(requireclosenotify:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol"]]},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GIO/documentation/GIO/DatagramBased":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/datagrambased","abstract":[{"type":"text","text":"Interface for socket-like objects with datagram semantics."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBased"}],"title":"DatagramBased","navigatorTitle":[{"text":"DatagramBased","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsConnectionProtocol":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol","kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DtlsConnectionProtocol"}],"navigatorTitle":[{"text":"DtlsConnectionProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/dtlsconnectionprotocol","abstract":[{"type":"codeVoice","code":"GDtlsConnection"},{"text":" is the base DTLS connection class type, which wraps","type":"text"},{"type":"text","text":" "},{"text":"a [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true,"type":"reference"},{"type":"text","text":"] and provides DTLS encryption on top of it. Its"},{"text":" ","type":"text"},{"text":"subclasses, [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","isActive":true,"type":"reference"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","isActive":true,"type":"reference"},{"text":"], implement client-side and server-side DTLS,","type":"text"},{"text":" ","type":"text"},{"text":"respectively.","type":"text"}],"role":"symbol","title":"DtlsConnectionProtocol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DtlsServerConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsserverconnection","abstract":[{"type":"codeVoice","code":"GDtlsServerConnection"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"type":"text","text":"], representing a server-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsServerConnection","kind":"identifier"}],"title":"DtlsServerConnection","navigatorTitle":[{"text":"DtlsServerConnection","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsClientConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsclientconnection","abstract":[{"code":"GDtlsClientConnection","type":"codeVoice"},{"text":" is the client-side subclass of","type":"text"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection"},{"type":"text","text":"], representing a client-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DtlsClientConnection"}],"title":"DtlsClientConnection","navigatorTitle":[{"kind":"identifier","text":"DtlsClientConnection"}]},"doc://GIO/documentation/GIO/DtlsConnectionProtocol/set(requireCloseNotify:)":{"abstract":[{"type":"text","text":"Sets whether or not "},{"code":"conn","type":"codeVoice"},{"text":" expects a proper TLS close notification","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"before the connection is closed. If this is "},{"code":"true","type":"codeVoice"},{"text":" (the default),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then "},{"type":"codeVoice","code":"conn"},{"text":" will expect to receive a TLS close notification from its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"peer before the connection is closed, and will return a"},{"type":"text","text":" "},{"code":"eof","type":"codeVoice"},{"text":" error if the connection is closed without proper","type":"text"},{"text":" ","type":"text"},{"text":"notification (since this may indicate a network error, or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"man-in-the-middle attack)."}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnectionProtocol\/set(requireCloseNotify:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"requireCloseNotify","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":")"}],"url":"\/documentation\/gio\/dtlsconnectionprotocol\/set(requireclosenotify:)","title":"set(requireCloseNotify:)","type":"topic"},"d