{"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"extendedModule":"GIO","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"symbolKind":"method","title":"close(cancellable:)","externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO18FileInputStreamRefV"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef\/InputStreamProtocol-Implementations"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef\/close(cancellable:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileinputstreamref\/close(cancellable:)"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Once the stream is closed, all other operations will return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."},{"text":" ","type":"text"},{"type":"text","text":"Closing a stream multiple times will not return an error."}]},{"type":"paragraph","inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"type":"text","text":" "},{"type":"text","text":"resources are released as early as possible."}]},{"type":"paragraph","inlineContent":[{"text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)","type":"text"},{"text":" ","type":"text"},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"type":"text","text":" "},{"text":"stream for details.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"text":"close will still return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":" for all operations. Still, it"},{"type":"text","text":" "},{"type":"text","text":"is important to check and report the error to the user."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"text":" ","type":"text"},{"text":"Cancelling a close will still leave the stream closed, but some streams","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}]}],"kind":"content"}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/FileInputStreamRef/close(cancellable:)":{"url":"\/documentation\/gio\/fileinputstreamref\/close(cancellable:)","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"title":"close(cancellable:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef\/close(cancellable:)","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/FileInputStreamRef":{"abstract":[{"code":"GFileInputStream","type":"codeVoice"},{"text":" provides input streams that take their","type":"text"},{"text":" ","type":"text"},{"text":"content from a file.","type":"text"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"FileInputStreamRef"}],"title":"FileInputStreamRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileInputStreamRef"}],"url":"\/documentation\/gio\/fileinputstreamref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef"},"doc://GIO/documentation/GIO/FileInputStreamRef/InputStreamProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef\/InputStreamProtocol-Implementations","url":"\/documentation\/gio\/fileinputstreamref\/inputstreamprotocol-implementations","title":"InputStreamProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}