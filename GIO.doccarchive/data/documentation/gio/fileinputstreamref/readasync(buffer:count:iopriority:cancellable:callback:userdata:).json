iority:cancellable:callback:userData:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Request an asynchronous read of "},{"type":"codeVoice","code":"count"},{"text":" bytes from the stream into the buffer","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"starting at "},{"type":"codeVoice","code":"buffer"},{"text":". When the operation is finished ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"type":"text","text":"You can then call "},{"code":"g_input_stream_read_finish()","type":"codeVoice"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"text":"operation.","type":"text"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef\/InputStreamProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"readAsync"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"call