"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and will result in "},{"code":"pending","type":"codeVoice"},{"text":" errors.","type":"text"}]},{"inlineContent":[{"type":"text","text":"A value of "},{"code":"count","type":"codeVoice"},{"text":" larger than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a "},{"code":"invalidArgument","type":"codeVoice"},{"text":" error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes skipped will be passed to the callback.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"type":"text","text":" "},{"text":"can happen e.g. near the end of a file, but generally we try to skip","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as many bytes as requested. Zero is returned on end of file"},{"type":"text","text":" "},{"text":"(or if ","type":"text"},{"type":"codeVoice","code":"count"},{"type":"text","text":" is zero), but never otherwise."}]},{"inlineContent":[{"text":"Any outstanding i\/o request with higher priority (lower numerical value)","type":"text"},{"type":"text","text":" "},{"text":"will be executed before an outstanding request with lower priority.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads to"},{"type":"text","text":" "},{"text":"implement asynchronicity, so they are optional for inheriting classes.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"However, if you override one, you must override all."}]}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/FileInputStreamRef/InputStreamProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef\/InputStreamProtocol-Implementations","url":"\/documentation\/gio\/fileinputstreamref\/inputstreamprotocol-implementations","title":"InputStreamProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileInputStreamRef":{"abstract":[{"code":"GFileInputStream","type":"codeVoice"},{"text":" provides input streams that take their","type":"text"},{"text":" ","type":"text"},{"text":"content from a file.","type":"text"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"FileInputStreamRef"}],"title":"FileInputStreamRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"FileInputStreamRef"}],"url":"\/documentation\/gio\/fileinputstreamref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInputStreamRef"},"doc://GIO/documentation/GIO/FileInputStreamRef/skipAsync(count:ioPriority:cancellable:callback:userData:)":{"url":"\/documentation\/gio\/fileinputstreamref\/skipasync(count:iopriority:cancellable:callback:userdata:)","fragme