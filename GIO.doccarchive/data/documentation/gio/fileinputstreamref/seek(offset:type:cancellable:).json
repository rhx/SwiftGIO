 is resizable then seeking past the end and then writing"},{"type":"text","text":" "},{"type":"text","text":"will result in zeros filling the empty space.  Seeking past the end"},{"text":" ","type":"text"},{"type":"text","text":"of a resizable stream and reading will result in EOF.  Seeking past"},{"type":"text","text":" "},{"text":"the end of a fixed-sized stream will fail.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any operation that would result in a negative offset will fail."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileinputstreamref\/seek(offset:type:cancellable:)"]}],"sections":[],"metadata":{"extendedModule":"GIO","symbolKind":"method","externalID":"s:3GIO16SeekableProtocolPAAE4seek6offset4type11cancellableSbs5Int64V_So9GSeekTypeaAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO18FileInputStreamRefV","modules":[{"name":"GIO"}],"role":"symbol","roleHeading":"Instance Method","title":"seek(offset:type:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"seek","kind":"identifier"},{"text":"(","kind":"text"},{"text":"offset","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:glibconfig.h@T@goffset","text":"goffset","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"type"},{"text":": ","kind":"text"},{"text":"GSeekType","kind":"