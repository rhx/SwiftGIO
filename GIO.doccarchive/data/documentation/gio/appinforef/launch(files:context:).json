{"metadata":{"title":"launch(files:context:)","extendedModule":"GIO","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"externalID":"s:3GIO15AppInfoProtocolPAAE6launch5files7contextSb4GLib7ListRefVSg_AA0b13LaunchContextJ0VSgtKF::SYNTHESIZED::s:3GIO10AppInfoRefV","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"launch","kind":"identifier"},{"text":"(","kind":"text"},{"text":"files","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib7ListRefV","text":"ListRef"},{"text":"?, ","kind":"text"},{"text":"context","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"AppLaunchContextRef","preciseIdentifier":"s:3GIO19AppLaunchContextRefV"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"symbolKind":"method"},"sections":[],"abstract":[{"text":"Launches the application. Passes ","type":"text"},{"code":"files","type":"codeVoice"},{"type":"text","text":" to the launched application"},{"type":"text","text":" "},{"type":"text","text":"as arguments, using the optional "},{"type":"codeVoice","code":"context"},{"type":"text","text":" to get information"},{"type":"text","text":" "},{"type":"text","text":"about the details of the launcher (like what screen it is on)."},{"text":" ","type":"text"},{"type":"text","text":"On error, "},{"type":"codeVoice","code":"error"},{"type":"text","text":" will be set accordingly."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"launch"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"files"},{"text":": ","kind":"text"},{"text":"ListRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib7ListRefV"},{"kind":"text","text":"? = nil, "},{"kind":"ext