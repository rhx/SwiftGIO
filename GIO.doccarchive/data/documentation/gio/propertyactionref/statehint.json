{"abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of"},{"type":"text","text":" "},{"type":"codeVoice","code":"action"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/gio\/propertyactionref\/statehint"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/stateHint","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"roleHeading":"Instance Property","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stateHint"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"externalID":"s:3GIO14ActionProtocolPAAE9stateHint4GLib10VariantRefVSgvp::SYNTHESIZED::s:3GIO17PropertyActionRefV","title":"stateHint","symbolKind":"property","extendedModule":"GIO"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stateHint"},{"kind":"text","text":": "},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"text":"! { ","kind":"text"},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" is returned it either means that the action is not stateful"},{"type":"text","text":" "},{"type":"text","text":"or that there is no hint about the valid range of values for the"},{"type":"text","text":" "},{"text":"state of the action.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a"},{"type":"text","text":" "},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"text":" ","type":"text"},{"type":"text","text":"returned then the tuple specifies the inclusive lower and upper bound"},{"type":"text","text":" "},{"type":"text","text":"of valid values for the state."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In any case, the information is merely a hint.  It may be possible to"},{"type":"text","text":" "},{"text":"have a state value outside of the hinted range and setting a value","type":"text"},{"type":"text","text":" "},{"type":"text","text":"within the range may fail."}]},{"inlineContent":[{"type":"text","text":"The return value (if non-"},{"type":"codeVoice","code":"NULL"},{"text":") should be freed with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"type":"text","text":"] when it is no longer required."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/ActionProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/PropertyActionRef":{"type":"topic","navigatorTitle":[{"text":"PropertyActionRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef","url":"\/documentation\/gio\/propertyactionref","title":"PropertyActionRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PropertyActionRef"}],"abstract":[{"text":"A ","type":"text"},{"code":"GPropertyAction","type":"codeVoice"},{"type":"text","text":" is a way to get a [iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action"},{"type":"text","text":"] with a state value"},{"text":" ","type":"text"},{"type":"text","text":"reflecting and controlling the value of a [class[Object](\/\/documentation\/gobject\/object] property."}]},"doc://GIO/documentation/GIO/Action":{"url":"\/documentation\/gio\/action","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action"}],"navigatorTitle":[{"text":"Action","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","title":"Action","role":"symbol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO/PropertyActionRef/ActionProtocol-Implementations":{"url":"\/documentation\/gio\/propertyactionref\/actionprotocol-implementations","kind":"article","title":"ActionProtocol Implementations","abstract":[],"role":"collectionGroup","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/ActionProtocol-Implementations"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/PropertyActionRef/stateHint":{"kind":"symbol","url":"\/documentation\/gio\/propertyactionref\/statehint","abstract":[{"text":"Requests a hint about the valid range of values for the state of","type":"text"},{"text":" ","type":"text"},{"code":"action","type":"codeVoice"},{"text":".","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"stateHint","kind":"identifier"},{"kind":"text","text":": "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"kind":"text","text":"!"}],"title":"stateHint","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/stateHint"}}}