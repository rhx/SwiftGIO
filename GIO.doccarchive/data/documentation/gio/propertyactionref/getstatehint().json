{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef","doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/ActionProtocol-Implementations"]]},"metadata":{"roleHeading":"Instance Method","extendedModule":"GIO","role":"symbol","title":"getStateHint()","symbolKind":"method","externalID":"s:3GIO14ActionProtocolPAAE12getStateHint4GLib10VariantRefVSgyF::SYNTHESIZED::s:3GIO17PropertyActionRefV","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getStateHint"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/propertyactionref\/getstatehint()"]}],"kind":"symbol","abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of"},{"type":"text","text":" "},{"code":"action","type":"codeVoice"},{"type":"text","text":"."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/getStateHint()"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getStateHint","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" is returned it either means that the action is not stateful"},{"type":"text","text":" "},{"text":"or that there is no hint about the valid range of values for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state of the action."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a"},{"text":" ","type":"text"},{"text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is","type":"text"},{"text":" ","type":"text"},{"text":"returned then the tuple specifies the inclusive lower and upper bound","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of valid values for the state."}],"type":"paragraph"},{"inlineContent":[{"text":"In any case, the information is merely a hint.  It may be possible to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have a state value outside of the hinted range and setting a value"},{"text":" ","type":"text"},{"text":"within the range may fail.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The return value (if non-","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":") should be freed with"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.Variant.unref","type":"codeVoice"},{"text":"] when it is no longer required.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/PropertyActionRef/getStateHint()":{"kind":"symbol","url":"\/documentation\/gio\/propertyactionref\/getstatehint()","abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of"},{"type":"text","text":" "},{"type":"codeVoice","code":"action"},{"type":"text","text":"."}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getStateHint","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"type":"topic","title":"getStateHint()","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/getStateHint()"},"doc://GIO/documentation/GIO/Action":{"url":"\/documentation\/gio\/action","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action"}],"navigatorTitle":[{"text":"Action","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","title":"Action","role":"symbol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO/PropertyActionRef":{"type":"topic","navigatorTitle":[{"text":"PropertyActionRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef","url":"\/documentation\/gio\/propertyactionref","title":"PropertyActionRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PropertyActionRef"}],"abstract":[{"text":"A ","type":"text"},{"code":"GPropertyAction","type":"codeVoice"},{"type":"text","text":" is a way to get a [iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action"},{"type":"text","text":"] with a state value"},{"text":" ","type":"text"},{"type":"text","text":"reflecting and controlling the value of a [class[Object](\/\/documentation\/gobject\/object] property."}]},"doc://GIO/documentation/GIO/PropertyActionRef/ActionProtocol-Implementations":{"url":"\/documentation\/gio\/propertyactionref\/actionprotocol-implementations","kind":"article","title":"ActionProtocol Implementations","abstract":[],"role":"collectionGroup","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef\/ActionProtocol-Implementations"}}}