{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MountOperation","doc:\/\/GIO\/documentation\/GIO\/MountOperation\/MountOperationProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MountOperation\/onNotifyChoice(flags:handler:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyChoice"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MountOperationRef","preciseIdentifier":"s:3GIO17MountOperationRefV","kind":"typeIdentifier","text":"MountOperationRef"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}]},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"code":"notifyChoice","type":"codeVoice"},{"text":" signal is emitted","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in "},{"code":"notify","type":"codeVoice"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"text":" call, like this:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"notify::choice","type":"codeVoice"},{"type":"text","text":" signal"}]}],"name":"Note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/mountoperation\/onnotifychoice(flags:handler:)"]}],"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol","title":"onNotifyChoice(flags:handler:)","extendedModule":"GIO","externalID":"s:3GIO22MountOperationProtocolPAAE14onNotifyChoice5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecN0VtctF::SYNTHESIZED::s:3GIO14MountOperationC","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onNotifyChoice"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:3GIO17MountOperationRefV","text":"MountOperationRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"