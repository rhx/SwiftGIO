 "},{"text":"throughout. For example, ","type":"text"},{"type":"codeVoice","code":"libgiognutls-helper.so"},{"type":"text","text":" becomes "},{"code":"gnutls_helper","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Using the new symbol names avoids name clashes when building modules"},{"type":"text","text":" "},{"text":"statically. The old symbol names continue to be supported, but cannot be used","type":"text"},{"type":"text","text":" "},{"text":"for static builds.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/iomodule\/unload()"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO/IOModule/IOModuleProtocol-Implementations":{"type":"topic","url":"\/documentation\/gio\/iomodule\/iomoduleprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOModule\/IOModuleProtocol-Implementations","abstract":[],"title":"IOModuleProtocol Implementations","role":"collectionGroup","kind":"article"},"doc://GIO/documentation/GIO/IOModule/unload()":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOModule\/unload()","url":"\/documentation\/gio\/iomodule\/unload()","role":"symbol","type":"topic","abstract":[{"text":"Required API for GIO modules to implement.","type":"text"}],"title":"unload()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"unload"},{"kind":"text","text":"()"}],"kind":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/IOModule":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOModule","navigatorTitle":[{"kind":"identifier","text":"IOModule"}],"abstract":[{"text":"Provides an interface and default functions for loading and unloading","type":"text"},{"type":"text"