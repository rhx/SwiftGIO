},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"text":" ","type":"text"},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::g-flags"},{"type":"text","text":" signal"}]}],"style":"note","type":"aside","name":"Note"}]}],"metadata":{"roleHeading":"Instance Method","extendedModule":"GIO","externalID":"s:3GIO17DBusProxyProtocolPAAE14onNotifyGFlags5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecN0VtctF","modules":[{"name":"GIO"}],"title":"onNotifyGFlags(flags:handler:)","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onNotifyGFlags","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO12DBusProxyRefV","text":"DBusProxyRef"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":