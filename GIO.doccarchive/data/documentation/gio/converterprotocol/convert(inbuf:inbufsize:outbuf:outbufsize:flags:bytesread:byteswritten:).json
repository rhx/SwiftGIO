{"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ConverterProtocol\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ConverterProtocol"]]},"sections":[],"kind":"symbol","metadata":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"convert"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"text":"inbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"outbuf"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"bytesRead"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","preciseIdentifier":"c:@T@gsize","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"bytesWritten"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"GConverterResult","preciseIdentifier":"c:@EA@GConverterResult"}],"externalID":"s:3GIO17ConverterProtocolPAAE7convert5inbuf0E4Size6outbuf0gF05flags9bytesRead0I7WrittenSo16GConverterResultaSvSg_SiANSiAA0B5FlagsVSpySuGSgARtKF","roleHeading":"Instance Method","extendedModule":"GIO","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","modules":[{"name":"GIO"}],"symbolKind":"method"},"abstract":[{"text":"This is the main operation used when converting data. It is to be called","type":"text"},{"type":"text","text":" "},{"text":"multiple times in a loop, and each time it will do some work, i.e.","type":"text"},{"text":" ","type":"text"},{"text":"producing some output (in ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"text":") or consuming some input (from ","type":"text"},{"code":"inbuf","type":"codeVoice"},{"type":"text","text":") or"},{"type":"text","text":" "},{"text":"both. If its not possible to do any work an error is returned.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/converterprotocol\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"convert"},{"kind":"text","text":"("},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"inbufSize"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"outbuf","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"kind":"text","text":"!, "},{"text":"outbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV","kind":"typeIdentifier","text":"ConverterFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"bytesRead"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gsize","preciseIdentifier":"c:@T@gsize"},{"text":">!, ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"GConverterResult","preciseIdentifier":"c:@EA@GConverterResult","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that a single call may not consume all input (or any input at all).","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Also a call may produce output even if given no input, due to state stored"},{"type":"text","text":" "},{"type":"text","text":"in the converter producing output."}]},{"inlineContent":[{"type":"text","text":"If any data was either produced or consumed, and then an error happens, then"},{"type":"text","text":" "},{"type":"text","text":"only the successful conversion is reported and the error is returned on the"},{"type":"text","text":" "},{"type":"text","text":"next call."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A full conversion loop involves calling this method repeatedly, each time"},{"type":"text","text":" "},{"text":"giving it new input and space output space. When there is no more input","type":"text"},{"text":" ","type":"text"},{"text":"data after the data in ","type":"text"},{"code":"inbuf","type":"codeVoice"},{"type":"text","text":", the flag "},{"code":"inputAtEnd","type":"codeVoice"},{"text":" must be set.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The loop will be (unless some error happens) returning "},{"code":"converted","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"each time until all data is consumed and all output is produced, then"},{"type":"text","text":" "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" is returned instead. Note, that "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" "},{"text":"may be returned even if ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" is not set, for instance"},{"type":"text","text":" "},{"type":"text","text":"in a decompression converter where the end of data is detectable from the"},{"type":"text","text":" "},{"type":"text","text":"data (and there might even be other data after the end of the compressed data)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When some data has successfully been converted "},{"type":"codeVoice","code":"bytesRead"},{"type":"text","text":" and is set to"},{"text":" ","type":"text"},{"text":"the number of bytes read from ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", and "},{"code":"bytesWritten","type":"codeVoice"},{"text":" is set to indicate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"how many bytes was written to "},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":". If there are more data to output"},{"text":" ","type":"text"},{"text":"or consume (i.e. unless the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" is specified) then"},{"text":" ","type":"text"},{"type":"codeVoice","code":"converted"},{"type":"text","text":" is returned, and if no more data is to be output"},{"text":" ","type":"text"},{"text":"then ","type":"text"},{"code":"finished","type":"codeVoice"},{"type":"text","text":" is returned."}]},{"type":"paragraph","inlineContent":[{"text":"On error ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Some errors need special handling:"}]},{"type":"paragraph","inlineContent":[{"code":"noSpace","type":"codeVoice"},{"type":"text","text":" is returned if there is not enough space"},{"text":" ","type":"text"},{"text":"to write the resulting converted data, the application should","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"call the function again with a larger "},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":" to continue."}]},{"type":"paragraph","inlineContent":[{"code":"partialInput","type":"codeVoice"},{"type":"text","text":" is returned if there is not enough"},{"type":"text","text":" "},{"type":"text","text":"input to fully determine what the conversion should produce,"},{"text":" ","type":"text"},{"type":"text","text":"and the "},{"code":"inputAtEnd","type":"codeVoice"},{"type":"text","text":" flag is not set. This happens for"},{"text":" ","type":"text"},{"type":"text","text":"example with an incomplete multibyte sequence when converting text,"},{"text":" ","type":"text"},{"type":"text","text":"or when a regexp matches up to the end of the input (and may match"},{"text":" ","type":"text"},{"type":"text","text":"further input). It may also happen when "},{"type":"codeVoice","code":"inbufSize"},{"text":" is zero and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"there is no more data to produce."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When this happens the application should read more input and then"},{"text":" ","type":"text"},{"text":"call the function again. If further input shows that there is no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"more data call the function again with the same data but with"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"text":" flag set. This may cause the conversion","type":"text"},{"text":" ","type":"text"},{"text":"to finish as e.g. in the regexp match case (or, to fail again with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"partialInput"},{"text":" in e.g. a charset conversion where the","type":"text"},{"type":"text","text":" "},{"text":"input is actually partial).","type":"text"}]},{"inlineContent":[{"type":"text","text":"After "},{"type":"codeVoice","code":"g_converter_convert()"},{"text":" has returned ","type":"text"},{"type":"codeVoice","code":"finished"},{"type":"text","text":" the"},{"text":" ","type":"text"},{"text":"converter object is in an invalid state where its not allowed","type":"text"},{"type":"text","text":" "},{"text":"to call ","type":"text"},{"type":"codeVoice","code":"g_converter_convert()"},{"text":" anymore. At this time you can only","type":"text"},{"type":"text","text":" "},{"text":"free the object or call ","type":"text"},{"type":"codeVoice","code":"g_converter_reset()"},{"type":"text","text":" to reset it to the"},{"type":"text","text":" "},{"type":"text","text":"initial state."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the flag "},{"code":"flush","type":"codeVoice"},{"type":"text","text":" is set then conversion is modified"},{"type":"text","text":" "},{"type":"text","text":"to try to write out all internal state to the output. The application"},{"type":"text","text":" "},{"text":"has to call the function multiple times with the flag set, and when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the available input has been consumed and all internal state has"},{"type":"text","text":" "},{"text":"been produced then ","type":"text"},{"code":"flushed","type":"codeVoice"},{"text":" (or ","type":"text"},{"type":"codeVoice","code":"finished"},{"text":" if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"really at the end) is returned instead of "},{"type":"codeVoice","code":"converted"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is somewhat similar to what happens at the end of the input stream,"},{"text":" ","type":"text"},{"type":"text","text":"but done in the middle of the data."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This has different meanings for different conversions. For instance"},{"type":"text","text":" "},{"text":"in a compression converter it would mean that we flush all the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"compression state into output such that if you uncompress the"},{"type":"text","text":" "},{"type":"text","text":"compressed data you get back all the input data. Doing this may"},{"type":"text","text":" "},{"type":"text","text":"make the final file larger due to padding though. Another example"},{"type":"text","text":" "},{"type":"text","text":"is a regexp conversion, where if you at the end of the flushed data"},{"type":"text","text":" "},{"type":"text","text":"have a match, but there is also a potential longer match. In the"},{"type":"text","text":" "},{"text":"non-flushed case we would ask for more input, but when flushing we","type":"text"},{"type":"text","text":" "},{"text":"treat this as the end of input and do the match.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Flushing is not always possible (like if a charset converter flushes","type":"text"},{"type":"text","text":" "},{"text":"at a partial multibyte sequence). Converters are supposed to try","type":"text"},{"text":" ","type":"text"},{"text":"to produce as much output as possible and then return an error","type":"text"},{"type":"text","text":" "},{"text":"(typically ","type":"text"},{"type":"codeVoice","code":"partialInput"},{"text":").","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/ConverterProtocol/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterProtocol\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","type":"topic","url":"\/documentation\/gio\/converterprotocol\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"convert"},{"text":"(","kind":"text"},{"text":"inbuf","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"outbuf","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"outbufSize"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ConverterFlagsV","text":"ConverterFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"bytesRead"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gsize","preciseIdentifier":"c:@T@gsize"},{"text":">!, ","kind":"text"},{"text":"bytesWritten","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:@EA@GConverterResult","text":"GConverterResult","kind":"typeIdentifier"}],"kind":"symbol","role":"symbol","title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","abstract":[{"type":"text","text":"This is the main operation used when converting data. It is to be called"},{"type":"text","text":" "},{"text":"multiple times in a loop, and each time it will do some work, i.e.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"producing some output (in "},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":") or"},{"type":"text","text":" "},{"text":"both. If its not possible to do any work an error is returned.","type":"text"}]},"doc://GIO/documentation/GIO/ConverterFlags":{"abstract":[{"type":"text","text":"Flags used when calling a "},{"type":"codeVoice","code":"g_converter_convert()"},{"text":".","type":"text"}],"title":"ConverterFlags","url":"\/documentation\/gio\/converterflags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConverterFlags"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","kind":"symbol","navigatorTitle":[{"text":"ConverterFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/ConverterProtocol":{"type":"topic","abstract":[{"type":"codeVoice","code":"GConverter"},{"text":" is an interface for streaming conversions.","type":"text"}],"navigatorTitle":[{"text":"ConverterProtocol","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterProtocol","role":"symbol","url":"\/documentation\/gio\/converterprotocol","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"ConverterProtocol","kind":"identifier"}],"title":"ConverterProtocol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}