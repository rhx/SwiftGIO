laim ","type":"text"},{"code":"connection","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"false"},{"text":" to let other handlers run.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"newConnection"},{"text":" signal is emitted","type":"text"}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"If you want to accept the connection, take a reference to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"connection"},{"type":"text","text":" object and return "},{"code":"true","type":"codeVoice"},{"type":"text","text":". When you are done with the"},{"text":" ","type":"text"},{"type":"text","text":"connection call "},{"type":"codeVoice","code":"g_dbus_connection_close()"},{"type":"text","text":" and give up your"},{"type":"text","text":" "},{"text":"reference. Note that the other peer may disconnect at any time -","type":"text"},{"text":" ","type":"text"},{"text":"a typical thing to do when accepting a connection is to listen to","type":"text"},{"text":" ","type":"text"},{"text":"the [DBusConnection](\/\/documentation\/gio\/dbusconnection\/onclosed(flags:handler:) signal.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServer","isActive":true},{"text":" contains ","type":"text"},{"type":"codeVoice","code":"runInThread"},{"text":" ","type":"text"},{"text":"then the signal is emitted in a new thread dedicated to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"connection. Otherwise the signal is emitted in the thread-default"},{"text":" ","type":"text"},{"text":"main context (see [method","type":"text"},{"type":"codeVoice","code":"GLib.MainContext.push_thread_default"},{"type":"text","text":"])"},{"type":"text","text":" "},{"text":"of the thread that ","type":"text"},{"type":"codeVoice","code":"server"},{"text":" was constructed in.","type":"text"}]},{"inlineContent":[{"type":"text","text":"You are guaranteed that signal handlers for this signal runs"},{"type":"text","text":" "},{"text":"before incoming messages on ","type":"text"},{"code":"connection","type":"codeVoice"},{"type":"text","text":" are processed. This means"},{"type":"text","text":" "},{"type":"text","text":"that it’s suitable to call "},{"type":"codeVoice","code":"g_dbus_connection_register_object()"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"text","text":"similar from the signal handler."}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"new-connection"},{"text":" signal","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusserverref\/onnewconnection(flags:handler:)"]}],"kind":"symbol","sections":[],"metadata":{"title":"onNewConnection(flags:handler:)","roleHeading":"Instance Method","extendedModule":"GIO","symbolKind":"method","externalID":"s:3GIO18DBusServerProtocolPAAE15onNewConnection5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0bC3RefV_AA0bgN0VtctF::SYNTHESIZED::s:3GIO13DBusServerRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNewConnection","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"DBusServerRef","preciseIdentifier":"s:3GIO13DBusServerRefV"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"DBusConnec