set_property()","type":"codeVoice"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"notify","type":"codeVoice"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"notify::client-address","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"para