{"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/gio\/dbusserverref\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusServerRef\/init_(cancellable:)","interfaceLanguage":"swift"},"abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"metadata":{"symbolKind":"method","roleHeading":"Instance Method","role":"symbol","title":"init_(cancellable:)","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO13DBusServerRefV","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"extendedModule":"GIO","modules":[{"name":"GIO"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}]}]},{"content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_initable_new()"},{"type":"text","text":" should typically be used instead."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"type":"text","text":" "},{"text":"construction, either with this function or ","type":"text"},{"code":"g_async_initable_init_async()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Implementations may also support cancellation. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"text":" ","type":"text"},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":" and","type":"text"},{"type":"text","text":" "},{"text":"the object doesn’t support cancellable initialization the error","type":"text"},{"text":" ","type":"text"},{"code":"notSupported","type":"codeVoice"},{"text":" will be returned.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the object is not initialized, or initialization returns with an"},{"text":" ","type":"text"},{"type":"text","text":"error, then all operations on the object except "},{"code":"g_object_ref()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"text":" ","type":"text"},{"type":"text","text":"behaviour. See the "},{"isActive":true,"identifier":"#iface@Gio.Initable#description","type":"reference"},{"type":"text","text":" for more details."}]},{"inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":" can be"},{"text":" ","type":"text"},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"type":"text","text":" "},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"code":"init()","type":"codeVoice"},{"type":"text","text":" can assume"},{"text":" ","type":"text"},{"text":"(and assert) that it will only be called once. Previously, this documentation","type":"text"},{"text":" ","type":"text"},{"text":"recommended all ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"text":" implementations should be idempotent; that","type":"text"},{"type":"text","text":" "},{"text":"recommendation was relaxed in GLib 2.54.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a class explicitly supports being initialized multiple times, it is"},{"text":" ","type":"text"},{"text":"recommended that the method is idempotent: multiple calls with the same","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"type":"text","text":" "},{"type":"text","text":"the object; further calls return the result of the first call."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"type":"text","text":" "},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"type":"text","text":" "},{"type":"codeVoice","code":"GObjectClass.constructor"},{"text":" that sometimes returns an existing instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"In this pattern, a caller would expect to be able to call "},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"text":"on the result of ","type":"text"},{"code":"g_object_new()","type":"codeVoice"},{"text":", regardless of whether it is in fact a new","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusServerRef","doc:\/\/GIO\/documentation\/GIO\/DBusServerRef\/InitableProtocol-Implementations"]]},"references":{"#iface@Gio.Initable#description":{"title":"description","titleInlineContent":[{"type":"text","text":"description"}],"identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description","type":"link"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/DBusServerRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServerRef","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"DBusServerRef","kind":"identifier"}],"type":"topic","abstract":[{"code":"GDBusServer","type":"codeVoice"},{"type":"text","text":" is a helper for listening to and accepting D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"connections. This can be used to create a new D-Bus server, allowing two"},{"text":" ","type":"text"},{"type":"text","text":"peers to use the D-Bus protocol for their own specialized communication."},{"type":"text","text":" "},{"type":"text","text":"A server instance provided in this way will not perform message routing or"},{"type":"text","text":" "},{"type":"text","text":"implement the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#message-bus-messages"},{"text":".","type":"text"}],"role":"symbol","kind":"symbol","title":"DBusServerRef","url":"\/documentation\/gio\/dbusserverref","navigatorTitle":[{"text":"DBusServerRef","kind":"identifier"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusServerRef/init_(cancellable:)":{"role":"symbol","title":"init_(cancellable:)","abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServerRef\/init_(cancellable:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"url":"\/documentation\/gio\/dbusserverref\/init_(cancellable:)"},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"https://dbus.freedesktop.org/doc/dbus-specification.html#message-bus-messages":{"title":"org.freedesktop.DBus interface","titleInlineContent":[{"type":"codeVoice","code":"org.freedesktop.DBus"},{"text":" interface","type":"text"}],"identifier":"https:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#message-bus-messages","url":"https:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#message-bus-messages","type":"link"},"doc://GIO/documentation/GIO/DBusServerRef/InitableProtocol-Implementations":{"kind":"article","abstract":[],"type":"topic","title":"InitableProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServerRef\/InitableProtocol-Implementations","url":"\/documentation\/gio\/dbusserverref\/initableprotocol-implementations","role":"collectionGroup"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]}}}