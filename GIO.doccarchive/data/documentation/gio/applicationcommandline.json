{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationcommandline"]}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ApplicationCommandLine"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"It is created by [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","isActive":true,"type":"reference"},{"text":"] and emitted","type":"text"},{"type":"text","text":" "},{"text":"in the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] signal and virtual function.","type":"text"}]},{"inlineContent":[{"text":"The class contains the list of arguments that the program was invoked","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with. It is also possible to query if the commandline invocation was"},{"type":"text","text":" "},{"type":"text","text":"local (ie: the current process is running in direct response to the"},{"type":"text","text":" "},{"type":"text","text":"invocation) or remote (ie: some other process forwarded the"},{"type":"text","text":" "},{"type":"text","text":"commandline to this process)."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GApplicationCommandLine"},{"type":"text","text":" object can provide the "},{"type":"codeVoice","code":"argc"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"argv"},{"type":"text","text":" "},{"text":"parameters for use with the [struct[OptionContext](\/\/documentation\/glib\/optioncontext] command-line parsing API,","type":"text"},{"type":"text","text":" "},{"text":"with the [method","type":"text"},{"type":"codeVoice","code":"Gio.ApplicationCommandLine.get_arguments"},{"text":"] function. See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c","type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"for an example."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The exit status of the originally-invoked process may be set and"},{"text":" ","type":"text"},{"type":"text","text":"messages can be printed to stdout or stderr of that process."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For remote invocation, the originally-invoked process exits when","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.ApplicationCommandLine.done"},{"type":"text","text":"] method is called. This method is"},{"text":" ","type":"text"},{"type":"text","text":"also automatically called when the object is disposed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The main use for "},{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" (and the","type":"text"},{"type":"text","text":" "},{"text":"[signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] signal) is ‘Emacs server’ like use cases:","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"You can set the "},{"type":"codeVoice","code":"EDITOR"},{"type":"text","text":" environment variable to have e.g. git use"},{"text":" ","type":"text"},{"text":"your favourite editor to edit commit messages, and if you already","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have an instance of the editor running, the editing will happen"},{"text":" ","type":"text"},{"type":"text","text":"in the running instance, instead of opening a new one. An important"},{"text":" ","type":"text"},{"text":"aspect of this use case is that the process that gets started by git","type":"text"},{"type":"text","text":" "},{"type":"text","text":"does not return until the editing is done."}]},{"type":"paragraph","inlineContent":[{"text":"Normally, the commandline is completely handled in the","type":"text"},{"text":" ","type":"text"},{"text":"[signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler. The launching instance exits","type":"text"},{"text":" ","type":"text"},{"text":"once the signal handler in the primary instance has returned, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the return value of the signal handler becomes the exit status"},{"type":"text","text":" "},{"text":"of the launching instance.","type":"text"}]},{"syntax":"c","type":"codeListing","code":["static int","command_line (GApplication            *application,","              GApplicationCommandLine *cmdline)","{","  gchar **argv;","  gint argc;","  gint i;","","  argv = g_application_command_line_get_arguments (cmdline, &argc);","","  g_application_command_line_print (cmdline,","                                    \"This text is written back\\n\"","                                    \"to stdout of the caller\\n\");","","  for (i = 0; i < argc; i++)","    g_print (\"argument `d:` `s`\\n\", i, argv[i]);","","  g_strfreev (argv);","","  return 0;","}"]},{"inlineContent":[{"text":"The complete example can be found here:","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline.c","isActive":true}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In more complicated cases, the handling of the commandline can be"},{"text":" ","type":"text"},{"type":"text","text":"split between the launcher and the primary instance."}],"type":"paragraph"},{"syntax":"c","code":["static gboolean"," test_local_cmdline (GApplication   *application,","                     gchar        ***arguments,","                     gint           *exit_status)","{","  gint i, j;","  gchar **argv;","","  argv = *arguments;","","  if (argv[0] == NULL)","    {","      *exit_status = 0;","      return FALSE;","    }","","  i = 1;","  while (argv[i])","    {","      if (g_str_has_prefix (argv[i], \"--local-\"))","        {","          g_print (\"handling argument `s` locally\\n\", argv[i]);","          g_free (argv[i]);","          for (j = i; argv[j]; j++)","            argv[j] = argv[j + 1];","        }","      else","        {","          g_print (\"not handling argument `s` locally\\n\", argv[i]);","          i++;","        }","    }","","  *exit_status = 0;","","  return FALSE;","}","","static void","test_application_class_init (TestApplicationClass *class)","{","  G_APPLICATION_CLASS (class)->local_command_line = test_local_cmdline;","","  ...","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"In this example of split commandline handling, options that start"},{"text":" ","type":"text"},{"text":"with ","type":"text"},{"code":"--local-","type":"codeVoice"},{"type":"text","text":" are handled locally, all other options are passed"},{"text":" ","type":"text"},{"text":"to the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler which runs in the primary","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instance."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The complete example can be found here:"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If handling the commandline requires a lot of work, it may be better to defer it."}]},{"syntax":"c","type":"codeListing","code":["static gboolean","my_cmdline_handler (gpointer data)","{","  GApplicationCommandLine *cmdline = data;","","  \/\/ do the heavy lifting in an idle","","  g_application_command_line_set_exit_status (cmdline, 0);","  g_object_unref (cmdline); \/\/ this releases the application","","  return G_SOURCE_REMOVE;","}","","static int","command_line (GApplication            *application,","              GApplicationCommandLine *cmdline)","{","  \/\/ keep the application running until we are done with this commandline","  g_application_hold (application);","","  g_object_set_data_full (G_OBJECT (cmdline),","                          \"application\", application,","                          (GDestroyNotify)g_application_release);","","  g_object_ref (cmdline);","  g_idle_add (my_cmdline_handler, cmdline);","","  return 0;","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example the commandline is not completely handled before"},{"text":" ","type":"text"},{"type":"text","text":"the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler returns. Instead, we keep"},{"text":" ","type":"text"},{"type":"text","text":"a reference to the "},{"type":"codeVoice","code":"GApplicationCommandLine"},{"text":" object and handle it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"later (in this example, in an idle). Note that it is necessary to"},{"type":"text","text":" "},{"text":"hold the application until you are done with the commandline.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The complete example can be found here:"},{"text":" ","type":"text"},{"type":"reference","overridingTitleInlineContent":[{"type":"text","text":"gapplication-example-cmdline3.c"}],"overridingTitle":"gapplication-example-cmdline3.c","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c","isActive":true}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GApplicationCommandLine","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol","type":"reference"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GApplicationCommandLine"},{"text":" instance.","type":"text"}]}],"type":"aside"}]}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/GIO\/10GLibObject0B0C"],"type":"inheritsFrom"},{"type":"conformsTo","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"kind":"relationships","title":"Conforms To"}],"topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/init(_:)-1izrl","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/init(_:)-2g2t6","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/init(_:)-40zxm","doc:\/\/GIO\/docu