":"text"},{"type":"text","text":" "},{"type":"text","text":"the underlying "},{"code":"C","type":"codeVoice"},{"text":" data type.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"type":"text","text":" "},{"type":"text","text":"i.e., ownership is transferred to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine"},{"type":"text","text":" instance."}],"url":"\/documentation\/gio\/applicationcommandline\/init(gconstpointer:)"},"doc://GIO/4GLib14PointerWrapperP":{"type":"unresolvable","identifier":"doc:\/\/GIO\/4GLib14PointerWrapperP","title":"GLib.PointerWrapper"},"doc://GIO/10GLibObject0B8ProtocolP":{"type":"unresolvable","identifier":"doc:\/\/GIO\/10GLibObject0B8ProtocolP","title":"GLibObject.ObjectProtocol"},"https://gitlab.gnome.org/GNOME/glib/-/blob/HEAD/gio/tests/gapplication-example-cmdline2.c":{"title":"gapplication-example-cmdline2.c","url":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c","type":"link","titleInlineContent":[{"text":"gapplication-example-cmdline2.c","type":"text"}],"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c"},"doc://GIO/documentation/GIO/ApplicationCommandLine":{"title":"ApplicationCommandLine","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApplicationCommandLine","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"ApplicationCommandLine"}],"url":"\/documentation\/gio\/applicationcommandline","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","abstract":[{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" represents a command-line invocation of","type":"text"},{"type":"text","text":" "},{"text":"an application.","type":"text"}],"role":"symbol"},"doc://GIO/documentation/GIO/Application":{"navigatorTitle":[{"kind":"identifier","text":"Application"}],"title":"Application","abstract":[{"type":"codeVoice","code":"GApplication"},{"type":"text","text":" is the core class for application support."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Application","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","url":"\/documentation\/gio\/application"},"doc://GIO/documentation/GIO/ApplicationCommandLine/init(raw:)-267bz":{"type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/init(raw:)-267bz","title":"init(raw:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"raw","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeRawPointer","preciseIdentifier":"s:SV","kind":"typeIdentifier"},{"kind":"text","text":")"}],"kind":"symbol","abstract":[{"text":"Unsafe untyped initialiser.","type":"text"},{"type":"text","text":" "},{"inlineContent":[{"type":"text","text":"Do not use unless you know the underlying data type the pointer points to conforms to "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol","isActive":true},{"type":"text","text":"."}],"type":"strong"}],"url":"\/documentation\/gio\/applicationcommandline\/init(raw:)-267bz"},"doc://GIO/10GLibObject0B0C":{"identifier":"doc:\/\/GIO\/10GLibObject0B0C","title":"GLibObject.Object","type":"unresolvable"},"doc://GIO/documentation/GIO/ApplicationCommandLine/init(gpointer:)":{"type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine\/init(gpointer:)","title":"init(gpointer:)","fragments":[{"kind":"identifier","text":"init"},{"text":"!(","kind":"text"},{"text":"gpointer","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@