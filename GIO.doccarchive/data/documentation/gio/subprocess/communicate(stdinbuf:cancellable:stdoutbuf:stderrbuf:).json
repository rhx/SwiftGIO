{"variants":[{"paths":["\/documentation\/gio\/subprocess\/communicate(stdinbuf:cancellable:stdoutbuf:stderrbuf:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/communicate(stdinBuf:cancellable:stdoutBuf:stderrBuf:)"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"communicate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"stdinBuf","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"BytesRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8BytesRefV"},{"text":"? = nil, ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"stdoutBuf"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GBytes"},{"text":">?>? = nil, ","kind":"text"},{"text":"stderrBuf","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GBytes","kind":"typeIdentifier"},{"text":">?>? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"stdinBuf","type":"codeVoice"},{"text":" is given, the subprocess must have been created with","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/stdinPipe","isActive":true},{"text":".  The given data is fed to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stdin of the subprocess and the pipe is closed (ie: EOF)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time (as not to cause blocking when dealing with large"},{"type":"text","text":" "},{"text":"amounts of data), if ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/stdoutPipe","isActive":true,"type":"reference"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/stderrPipe","isActive":true,"type":"reference"},{"type":"text","text":" were used, reads from those"},{"text":" ","type":"text"},{"text":"streams.  The data that was read is returned in ","type":"text"},{"type":"codeVoice","code":"stdout"},{"text":" and\/or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"stderr"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"If the subprocess was created with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/stdoutPipe","type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stdoutBuf"},{"text":" will contain the data read from stdout.  Otherwise, for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subprocesses not created with "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/stdoutPipe","type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"stdoutBuf","type":"codeVoice"},{"type":"text","text":" will be set to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":".  Similar provisions apply to"},{"type":"text","text":" "},{"type":"codeVoice","code":"stderrBuf"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/stderrPipe"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As usual, any output variable may be given as "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" to ignore it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you desire the stdout and stderr data to be interleaved, create"},{"text":" ","type":"text"},{"text":"the subprocess with ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess\/stdoutPipe","isActive":true},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"stderrMerge"},{"text":".  The merged result will be returned","type":"text"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"code":"stdoutBuf","type":"codeVoice"},{"type":"text","text":" and "},{"code":"stderrBuf","type":"codeVoice"},{"type":"text","text":" will be set to "},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In case of any error (including cancellation), "},{"type":"codeVoice","code":"false"},{"text":" will be","type":"text"},{"text":" ","type":"text"},{"text":"returned with ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" set.  Some or all of the stdin data may have"},{"text":" ","type":"text"},{"type":"text","text":"been written.  Any stdout or stderr data that has been read will be"},{"type":"text","text":" "},{"type":"text","text":"discarded. None of the out variables (aside from "},{"type":"codeVoice","code":"error"},{"type":"text","text":") will have"},{"text":" ","type":"text"},{"type":"text","text":"been set to anything in particular and should not be inspected."}]},{"type":"paragraph","inlineContent":[{"text":"In the case that ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" is returned, the subprocess has exited and the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"exit status inspection APIs (eg: "},{"code":"g_subprocess_get_if_exited()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_subprocess_get_exit_status()"},{"type":"text","text":") may be used."}]},{"type":"paragraph","inlineContent":[{"text":"You should not attempt to use any of the subprocess pipes after","type":"text"},{"type":"text","text":" "},{"type":"text","text":"starting this function, since they may be left in strange states,"},{"type":"text","text":" "},{"text":"even if the operation was cancelled.  You should especially not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"attempt to interact with the pipes while the operation is in progress"},{"text":" ","type":"text"},{"type":"text","text":"(either from another thread or if using the asynchronous version)."}]}]}],"abstract":[{"text":"Communicate with the subprocess until it terminates, and all input","type":"text"},{"type":"text","text":" "},{"text":"and output has been completed.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Subprocess","doc:\/\/GIO\/documentation\/GIO\/Subprocess\/SubprocessProtocol-Implementations"]]},"metadata":{"extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"communicate"},{"text":"(","kind":"text"},{"text":"stdinBuf","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib8BytesRefV","text":"BytesRef","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s: