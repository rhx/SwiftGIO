:"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","text":"TLSCertificateFlags"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP","text":"CancellableProtocol","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"SocketConnectableT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:3GIO25SocketConnectableProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableProtocol","text":"SocketConnectableProtocol","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"TLSCertificateT"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol","text":"TLSCertificateProtocol","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"TLSInteractionT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"TLSInteractionProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionProtocol","preciseIdentifier":"s:3GIO22TLSInteractionProtocolP","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chain"},{"text":" is a chain of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"text":" objects each pointing to the next","type":"text"},{"text":" ","type":"text"},{"text":"certificate in the chain by its ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference","isActive":true},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"purpose"},{"text":" describes the purpose (or usage) for which the certificate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is being used. Typically "},{"code":"purpose","type":"codeVoice"},{"text":" will be set to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/tlsDatabasePurposeAuthenticateServer"},{"type":"text","text":" "},{"type":"text","text":"which means that the certificate is being used to authenticate a server"},{"type":"text","text":" "},{"text":"(and we are acting as the client).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"identity"},{"type":"text","text":" is used to ensure the server certificate is valid for"},{"text":" ","type":"text"},{"text":"the expected peer identity. If the identity does not match the","type":"text"},{"type":"text","text":" "},{"text":"certificate, ","type":"text"},{"type":"codeVoice","code":"badIdentity"},{"type":"text","text":" will be set in the"},{"type":"text","text":" "},{"type":"text","text":"return value. If "},{"code":"identity","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":", that bit will never be set in","type":"text"},{"text":" ","type":"text"},{"text":"the return value. The peer identity may also be used to check for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"pinned certificates (trust exceptions) in the database. These may"},{"text":" ","type":"text"},{"type":"text","text":"override the normal verification process on a host-by-host basis."}]},{"type":"paragraph","inlineContent":[{"text":"Currently there are no ","type":"text"},{"type":"codeVoice","code":"flags"},{"type":"text","text":", and "},{"type":"codeVoice","code":"none"},{"text":" should be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"used."}]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is found to be valid, then the return value will be 0. If"},{"text":" ","type":"text"},{"code":"chain","type":"codeVoice"},{"text":" is found to be invalid, then the return value will indicate at","type":"text"},{"type":"text","text":" "},{"text":"least one problem found. If the function is unable to determine","type":"text"},{"type":"text","text":" "},{"type":"text","text":"whether "},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is valid (for example, because "},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"triggered before it completes) then the return value will be"},{"text":" ","type":"text"},{"type":"codeVoice","code":"genericError"},{"text":" and ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" will be set accordingly."},{"type":"text","text":" "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is not set when "},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is successfully analyzed but found to"},{"type":"text","text":" "},{"text":"be invalid.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"type":"text","text":" "},{"text":"error will be set in the return value, but it does not guarantee","type":"text"},{"type":"text","text":" "},{"text":"that all possible errors will be set. Accordingly, you may not safely","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"decide to ignore any particular type of error. For example, it would"},{"text":" ","type":"text"},{"type":"text","text":"be incorrect to mask "},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow"},{"type":"text","text":" "},{"type":"text","text":"expired certificates, because this could potentially be the only"},{"type":"text","text":" "},{"type":"text","text":"error flag set even if other problems exist with the certificate."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Prior to GLib 2.48, GLib’s default TLS backend modified "},{"type":"codeVoice","code":"chain"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"represent the certification path built by ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","type":"reference","isActive":true},{"text":" during","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate verification by adjusting the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true},{"text":" ","type":"text"},{"text":"property of each certificate in ","type":"text"},{"type":"codeVoice","code":"chain"},{"text":". Since GLib 2.48, this no","type":"text"},{"text":" ","type":"text"},{"text":"longer occurs, so you cannot rely on ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"represent the actual certification path used during certificate"},{"type":"text","text":" "},{"text":"verification.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Because TLS session context is not used, "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","type":"reference","isActive":true},{"text":" may not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"perform as many checks on the certificates as "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":" would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For example, certificate constraints may not be honored, and"},{"text":" ","type":"text"},{"type":"text","text":"revocation checks may not be performed. The best way to verify TLS"},{"type":"text","text":" "},{"type":"text","text":"certificates used by a TLS connection is to let "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"handle the verification."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The TLS backend may attempt to look up and add missing certificates"},{"type":"text","text":" "},{"type":"text","text":"to the chain. This may involve HTTP requests to download missing"},{"text":" ","type":"text"},{"type":"text","text":"certificates."}]},{"type":"paragraph","inlineContent":[{"text":"This function can block. Use ","type":"text"},{"type":"codeVoice","code":"g_tls_database_verify_chain_async()"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"text":"perform the verification operation asynchronously.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"verify","kind":"identifier"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"SocketConnectableT"},{"text":", ","kind":"text"},{"text":"TLSCertificateT","kind":"genericParameter"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"TLSInteractionT"},{"text":">(","kind":"text"},{"text":"chain","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"purpose","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"identity","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SocketConnectableT","kind":"typeIdentifier"},{"kind":"text","tex