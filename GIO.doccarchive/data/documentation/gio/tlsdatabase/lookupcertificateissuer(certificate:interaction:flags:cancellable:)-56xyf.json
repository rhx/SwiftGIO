{"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"lookupCertificateIssuer","kind":"identifier"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"TLSCertificateT","kind":"genericParameter"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"TLSInteractionT"},{"kind":"text","text":">("},{"text":"certificate","kind":"externalParam"},{"kind":"text","text":": "},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"interaction"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"TLSInteractionT"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"GTlsDatabaseLookupFlags","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GTlsDatabaseLookupFlags"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV"},{"kind":"text","text":"! "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"CancellableProtocol","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"TLSCertificateT"},{"kind":"text","text":" : "},{"text":"TLSCertificateProtocol","kind":"typeIdentifier","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/T