te. Accordingly, this function cannot be used to make"},{"type":"text","text":" "},{"type":"text","text":"security-related decisions. Only GLib itself should make security"},{"type":"text","text":" "},{"text":"decisions about TLS certificates.","type":"text"}],"type":"paragraph"}]}],"metadata":{"extendedModule":"GIO","symbolKind":"method","title":"lookupCertificateIssuer(certificate:interaction:flags:cancellable:)","roleHeading":"Instance Method","role":"symbol","externalID":"s:3GIO19TLSDatabaseProtocolPAAE23lookupCertificateIssuer11certificate11interaction5flags11cancellableAA17TLSCertificateRefVSgqd_0__qd_1_SgSo23GTlsDatabaseLookupFlagsaqd__SgtKAA011CancellableC0Rd__AA0kC0Rd_0_AA014TLSInteractionC0Rd_1_r1_lF::SYNTHESIZED::s:3GIO11TLSDatabaseC","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"lookupCertificateIssuer","kind":"identifier"},{"text":"<","kind":"text"},{"text":"CancellableT","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"TLSCertificateT","kind":"genericParameter"},{"text":", ","kind":"text"},{"kind":"genericParameter","text":"TLSInteractionT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"certificate"},{"kind":"text","text":": "},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"interaction","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TLSInteractionT"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"GTlsDatabaseLookupFlags","preciseIdentifier":"c:@EA@GTlsDatabaseLookupFlags","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableT"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:3GIO17TLSCertificateRefV","kind":"typeIdentifier","text":"TLSCertifi