ificate","type":"text"},{"text":" ","type":"text"},{"text":"received by a client from a server), or the combination of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a certificate and a private key (which is needed when acting as a"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference","isActive":true},{"type":"text","text":"])."}]},"doc://GIO/documentation/GIO/TLSDatabase/TLSDatabaseProtocol-Implementations":{"kind":"article","url":"\/documentation\/gio\/tlsdatabase\/tlsdatabaseprotocol-implementations","abstract":[],"role":"collectionGroup","type":"topic","title":"TLSDatabaseProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase\/TLSDatabaseProtocol-Implementations"},"doc://GIO/documentation/GIO/SocketConnectableRef":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableRef","type":"topic","abstract":[{"text":"Objects that describe one or more potential socket endpoints","type":"text"},{"type":"text","text":" "},{"text":"implement ","type":"text"},{"code":"GSocketConnectable","type":"codeVoice"},{"type":"text","text":". Callers can then use"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.SocketConnectable.enumerate"},{"type":"text","text":"] to get a"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddressEnumerator","type":"reference","isActive":true},{"type":"text","text":"] to try out each socket address in turn"},{"text":" ","type":"text"},{"type":"text","text":"until one succeeds, as shown in the sample code below."}],"url":"\/documentation\/gio\/socketconnectableref","title":"SocketConnectableRef","kind":"symbol","navigatorTitle":[{"text":"SocketConnectableRef","kind":"identifier"}],"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"SocketConnectabl