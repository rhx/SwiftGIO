er":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSCertificate":{"role":"symbol","kind":"symbol","title":"TLSCertificate","abstract":[{"type":"text","text":"A certificate used for TLS authentication and encryption."},{"type":"text","text":" "},{"text":"This can represent either a certificate only (eg, the certificate","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"received by a client from a server), or the combination of"},{"text":" ","type":"text"},{"text":"a certificate and a private key (which is needed when acting as a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"])."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificate","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"topic","navigatorTitle":[{"text":"TLSCertificate","kind":"identifier"}],"url":"\/documentation\/gio\/tlscertificate"},"doc://GIO/documentation/GIO/TLSDatabase":{"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","role":"symbol","url":"\/documentation\/gio\/tlsdatabase","abstract":[{"type":"codeVoice","code":"GTlsDatabase"},{"type":"text","text":" is used to look up certificates and other information"},{"type":"text","text":" "},{"type":"text","text":"from a certificate or key store. It is an abstract base class which"},{"text":" ","type":"text"},{"type":"text","text":"TLS library specific subtypes override."}],"navigatorTitle":[{"text":"TLSDatabase","kind":"identifier"}],"title":"TLSDatabase","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TLSDatabase"}],"kind":"symbol"},"doc://GIO/documentation/GIO/SocketAddressEnumerator":{"type":"topic","title":"SocketAddressEnumerator","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketAddressEnumerator","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GSocketAddressEnumerator"},{"type":"text","text":" is an enumerator type for"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddress","type":"reference","isActive":true},{"type":"text","text":"] instances. It is returned by enumeration functions"},{"text":" ","type":"text"},{"type":"text","text":"such as [method"},{"code":"Gio.SocketConnectable.enumerate","type":"codeVoice"},{"type":"text","text":"], which returns a"},{"type":"text","text":" "},{"code":"GSocketAddressEnumerator","type":"codeVoice"},{"type":"text","text":" to list each [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddress","isActive":true},{"text":"] which could","type":"text"},{"type":"text","text":" "},{"text":"be used to connect to that [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectable","isActive":true},{"type":"text","text":"]."}],"navigatorTitle":[{"text":"SocketAddressEnumerator","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketAddressEnumerator","url":"\/documentation\/gio\/socketaddressenumerator","role":"symbol"},"doc://GIO/documentation/GIO/TLSCertificateFlags":{"url":"\/documentation\/gio\/tlscertificateflags","abstract":[{"type":"text","text":"A set of flags describing TLS certification validation. This can be"},{"type":"text","text":" "},{"type":"text","text":"used to describe why a particular certificate was rejected (for"},{"type":"text","text":" "},{"text":"example, in ","type":"text"},{"type":"reference","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","isActive":true},{"text":".","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateFlags","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateFlags"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","title":"TLSCertificateFlags","kind":"symbol"}}}