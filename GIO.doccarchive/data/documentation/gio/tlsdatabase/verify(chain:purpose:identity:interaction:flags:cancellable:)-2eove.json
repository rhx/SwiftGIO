","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionRef","kind":"typeIdentifier","text":"TLSInteractionRef","preciseIdentifier":"s:3GIO17TLSInteractionRefV"},{"text":"? = nil, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO22TLSDatabaseVerifyFlagsV","text":"TLSDatabaseVerifyFlags","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabaseVerifyFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","text":"TLSCertificateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV"},{"kind":"text","text":" "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"TLSCertificateProtocol","preciseIdentifier":"s:3GIO22TLSCertificateProtocolP","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateProtocol"}]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"chain"},{"type":"text","text":" is a chain of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true,"type":"reference"},{"text":" objects each pointing to the next","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificate in the chain by its "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","isActive":true,"type":"reference"},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"purpose"},{"type":"text","text":" describes the purpose (or usage) for which the certificate"},{"text":" ","type":"text"},{"text":"is being used. Typically ","type":"text"},{"code":"purpose","type":"codeVoice"},{"text":" will be set to ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/tlsDatabasePurposeAuthenticateServer","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"which means that the certificate is being used to authenticate a server"},{"text":" ","type":"text"},{"text":"(and we are acting as the client).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"identity"},{"text":" is used to ensure the server certificate is valid for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the expected peer identity. If the identity does not match the"},{"text":" ","type":"text"},{"text":"certificate, ","type":"text"},{"type":"codeVoice","code":"badIdentity"},{"type":"text","text":" will be set in the"},{"type":"text","text":" "},{"text":"return value. If ","type":"text"},{"code":"identity","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", that bit will never be set in"},{"type":"text","text":" "},{"type":"text","text":"the return value. The peer identity may also be used to check for"},{"type":"text","text":" "},{"type":"text","text":"pinned certificates (trust exceptions) in the database. These may"},{"type":"text","text":" "},{"text":"override the normal verification process on a host-by-host basis.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Currently there are no "},{"type":"codeVoice","code":"flags"},{"text":", and ","type":"text"},{"code":"none","type":"codeVoice"},{"type":"text","text":" should be"},{"type":"text","text":" "},{"type":"text","text":"used."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"chain"},{"type":"text","text":" is found to be valid, then the return value will be 0. If"},{"type":"text","text":" "},{"code":"chain","type":"codeVoice"},{"type":"text","text":" is found to be invalid, then the return value will indicate at"},{"text":" ","type":"text"},{"type":"text","text":"least one problem found. If the function is unable to determine"},{"type":"text","text":" "},{"type":"text","text":"whether "},{"type":"codeVoice","code":"chain"},{"text":" is valid (for example, because ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"triggered before it completes) then the return value will be"},{"type":"text","text":" "},{"type":"codeVoice","code":"genericError"},{"type":"text","text":" and "},{"type":"codeVoice","code":"error"},{"text":" will be set accordingly.","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is not set when "},{"code":"chain","type":"codeVoice"},{"text":" is successfully analyzed but found to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be invalid."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, at least one"},{"type":"text","text":" "},{"text":"error will be set in the return value, but it does not guarantee","type":"text"},{"type":"text","text":" "},{"text":"that all possible errors will be set. Accordingly, you may not safely","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"decide to ignore any particular type of error. For example, it would"},{"text":" ","type":"text"},{"text":"be incorrect to mask ","type":"text"},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow"},{"text":" ","type":"text"},{"type":"text","text":"expired certificates, because this could potentially be the only"},{"type":"text","text":" "},{"text":"error flag set even if other problems exist with the certificate.","type":"text"}]},{"inlineContent":[{"text":"Prior to GLib 2.48, GLib’s default TLS backend modified ","type":"text"},{"type":"codeVoice","code":"chain"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"represent the certification path built by ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","isActive":true},{"text":" during","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate verification by adjusting the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate"},{"text":" ","type":"text"},{"text":"property of each certificate in ","type":"text"},{"code":"chain","type":"codeVoice"},{"type":"text","text":". Since GLib 2.48, this no"},{"type":"text","text":" "},{"type":"text","text":"longer occurs, so you cannot rely on "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificate","type":"reference","isActive":true},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"represent the actual certification path used during certificate"},{"text":" ","type":"text"},{"text":"verification.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Because TLS session context is not used, "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSDatabase","type":"reference","isActive":true},{"text":" may not","type":"text"},{"text":" ","type":"text"},{"text":"perform as many checks on the certificates as ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true,"type":"reference"},{"text":" would.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For example, certificate constraints may not be honored, and"},{"text":" ","type":"text"},{"text":"revocation checks may not be performed. The best way to verify TLS","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificates used by a TLS connection is to let "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" "},{"type":"text","text":"handle the verification."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The TLS backend may attempt to look up and add missing certificates","type":"text"},{"type":"text","text":" "},{"text":"to the chain. This may involve HTTP requests to download missing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"certificates."}]},{"type":"paragraph","inlineContent":[{"text":"This function can block. Use ","type":"text"},{"code":"g_tls_database_verify_chain_async()","type":"codeVoice"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"type":"text","text":"perform the verification operation asynchronously."}]}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/TLSInteractionRef":{"url":"\/documentation\/gio\/tlsinteractionref","abstract":[{"type":"codeVoice","code":"GTlsInteraction"},{"text":" provides a mechanism for the TLS connection and database","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"code to interact with the user. It can be used to ask the user for passwords."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TLSInteractionRef"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSInteractionRef"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSInteractionRef","title":"TLSInteractionRef","kind":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"