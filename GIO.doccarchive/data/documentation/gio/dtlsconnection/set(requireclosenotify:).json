{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Sets whether or not "},{"type":"codeVoice","code":"conn"},{"text":" expects a proper TLS close notification","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"before the connection is closed. If this is "},{"type":"codeVoice","code":"true"},{"type":"text","text":" (the default),"},{"text":" ","type":"text"},{"text":"then ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":" will expect to receive a TLS close notification from its"},{"type":"text","text":" "},{"type":"text","text":"peer before the connection is closed, and will return a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"eof"},{"type":"text","text":" error if the connection is closed without proper"},{"text":" ","type":"text"},{"type":"text","text":"notification (since this may indicate a network error, or"},{"text":" ","type":"text"},{"type":"text","text":"man-in-the-middle attack)."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","doc:\/\/GIO\/documentation\/GIO\/DtlsConnection\/DtlsConnectionProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"requireCloseNotify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":")"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"In some protocols, the application will know whether or not the"},{"text":" ","type":"text"},{"text":"connection was closed cleanly based on application-level data","type":"text"},{"text":" ","type":"text"},{"text":"(because the application-level data includes a length field, or is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"somehow self-delimiting); in this case, the close notify is"},{"text":" ","type":"text"},{"text":"redundant and may be omitted. You","type":"text"},{"type":"text","text":" "},{"text":"can use ","type":"text"},{"type":"codeVoice","code":"g_dtls_connection_set_require_close_notify()"},{"text":" to tell ","type":"text"},{"code":"conn","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to allow an “unannounced” connection close, in which case the close"},{"type":"text","text":" "},{"text":"will show up as a 0-length read, as in a non-TLS","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true,"type":"reference"},{"type":"text","text":", and it is up to the application to check that"},{"text":" ","type":"text"},{"text":"the data has been fully received.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this only affects the behavior when the peer closes the"},{"text":" ","type":"text"},{"text":"connection; when the application calls ","type":"text"},{"type":"codeVoice","code":"g_dtls_connection_close_async()"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"codeVoice","code":"conn"},{"text":" itself, this will send a close notification regardless of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"setting of this property. If you explicitly want to do an unclean"},{"text":" ","type":"text"},{"type":"text","text":"close, you can close "},{"code":"conn","type":"codeVoice"},{"text":"’s ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection"},{"text":" rather","type":"text"},{"text":" ","type":"text"},{"text":"than closing ","type":"text"},{"code":"conn","type":"codeVoice"},{"type":"text","text":" itself."}]}],"kind":"content"}],"sections":