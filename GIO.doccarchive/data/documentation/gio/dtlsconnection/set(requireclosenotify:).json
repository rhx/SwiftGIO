 expects a proper TLS close notification","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"before the connection is closed. If this is "},{"type":"codeVoice","code":"true"},{"type":"text","text":" (the default),"},{"type":"text","text":" "},{"text":"then ","type":"text"},{"code":"conn","type":"codeVoice"},{"type":"text","text":" will expect to receive a TLS close notification from its"},{"text":" ","type":"text"},{"text":"peer before the connection is closed, and will return a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"eof"},{"text":" error if the connection is closed without proper","type":"text"},{"type":"text","text":" "},{"type":"text","text":"notification (since this may indicate a network error, or"},{"type":"text","text":" "},{"text":"man-in-the-middle attack).","type":"text"}],"url":"\/documentation\/gio\/dtlsconnection\/set(requireclosenotify:)","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DatagramBased":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/datagrambased","abstract":[{"type":"text","text":"Interface for socket-like objects with datagram semantics."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBased"}],"title":"DatagramBased","navigatorTitle":[{"text":"DatagramBased","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsClientConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsclientconnection","abstract":[{"code":"GDtlsClientConnection","type":"codeVoice"},{"text":" is the client-side subclass of","type":"text"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"isActive":true,"type":"reference","identifier":"d