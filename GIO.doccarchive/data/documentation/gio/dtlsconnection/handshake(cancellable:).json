d","type":"text"},{"type":"text","text":" "},{"text":"[iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","isActive":true,"type":"reference"},{"text":"], implement client-side and server-side DTLS,","type":"text"},{"text":" ","type":"text"},{"text":"respectively.","type":"text"}],"title":"DtlsConnection","url":"\/documentation\/gio\/dtlsconnection"},"doc://GIO/documentation/GIO/DtlsServerConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsserverconnection","abstract":[{"type":"codeVoice","code":"GDtlsServerConnection"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","isActive":true},{"type":"text","text":"], representing a server-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsServerConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DtlsServerConnection","kind":"identifier"}],"title":"DtlsServerConnection","navigatorTitle":[{"text":"DtlsServerConnection","kind":"identifier"}]},"doc://GIO/documentation/GIO/DtlsConnection/DtlsConnectionProtocol-Implementations":{"type":"topic","kind":"article","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection\/DtlsConnectionProtocol-Implementations","url":"\/documentation\/gio\/dtlsconnection\/dtlsconnectionprotocol-implementations","title":"DtlsConnectionProtocol Implementations","abstract":[]},"doc://GIO/documentation/GIO/DtlsClientConnection":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/dtlsclientconnection","abstract":[{"code":"GDtlsClientConnection","type":"codeVoice"},{"text":" is the client-side subclass of","type":"text"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection"},{"type":"text","text":"], representing a client-side DTLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DtlsClientConnection"}],"title":"DtlsClientConnection","navigatorTitle":[{"kind":"identifier","text":"DtlsClientConnection"}]}}}