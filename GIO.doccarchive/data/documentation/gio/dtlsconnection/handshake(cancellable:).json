{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","doc:\/\/GIO\/documentation\/GIO\/DtlsConnection\/DtlsConnectionProtocol-Implementations"]]},"kind":"symbol","abstract":[{"text":"Attempts a TLS handshake on ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsconnection\/handshake(cancellable:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection\/handshake(cancellable:)","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"handshake(cancellable:)","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"handshake","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"extendedModule":"GIO","symbolKind":"method","role":"symbol","externalID":"s:3GIO22DtlsConnectionProtocolPAAE9handshake11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO14DtlsConnectionC"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"handshake","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"On the client side, it is never necessary to call this method;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"although the connection needs to perform a handshake after"},{"type":"text","text":" "},{"type":"text","text":"connecting, "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection","type":"reference"},{"type":"text","text":" will handle this for you automatically"},{"type":"text","text":" "},{"type":"text","text":"when you try to send or receive data on the connection. You can call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_dtls_connection_handshake()"},{"text":" manually if you want to know whether","type":"text"},{"type":"text","text":" "},{"text":"the initial handshake succeeded or failed (as opposed to just","type":"text"},{"type":"text","text":" "},{"text":"immediately trying to use ","type":"text"},{"code":"conn","type":"codeVoice"},{"text":" to read or write, in which case,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if it fails, it may not be possible to tell if it failed before"},{"type":"text","text":" "},{"text":"or after completing the handshake), but beware that servers may reject","type":"text"},{"text":" ","type":"text"},{"text":"client authentication after the handshake has completed, so a","type":"text"},{"text":" ","type":"text"},{"text":"successful handshake does not indicate the connection will be usable.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Likewise, on the server side, although a handshake is necessary at"},{"type":"text","text":" "},{"type":"text","text":"the beginning of the communication, you do not need to call this"},{"text":" ","type":"text"},{"type":"text","text":"function explicitly unless you want clearer error reporting."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Previously, calling "},{"code":"g_dtls_connection_handshake()","type":"codeVoice"},{"text":" after the initial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"type":"text","text":" "},{"text":"deprecated in GLib 2.60 because rehandshaking was removed from the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake will no longer do anything."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the"},{"text":" ","type":"text"},{"type":"text","text":"handshake."}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/DtlsConnection/handshake(cancellable:)":{"abstract":[{"text":"Attempts a TLS handshake on ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":"."}],"kind":"symbol","title":"handshake(cancellable:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"handshake","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"type":"topic","url":"\/documentation\/gio\/dtlsconnection\/handshake(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsConnection\/handshake(cancellable:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","ur