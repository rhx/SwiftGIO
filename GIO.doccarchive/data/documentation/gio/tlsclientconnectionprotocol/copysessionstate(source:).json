{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionProtocol\/copySessionState(source:)"},"abstract":[{"type":"text","text":"Possibly copies session state from one connection to another, for use"},{"type":"text","text":" "},{"type":"text","text":"in TLS session resumption. This is not normally needed, but may be"},{"text":" ","type":"text"},{"text":"used when the same session needs to be used between different","type":"text"},{"text":" ","type":"text"},{"text":"endpoints, as is required by some protocols, such as FTP over TLS.","type":"text"},{"text":" ","type":"text"},{"code":"source","type":"codeVoice"},{"type":"text","text":" should have already completed a handshake and, since TLS 1.3,"},{"type":"text","text":" "},{"text":"it should have been used to read data at least once. ","type":"text"},{"type":"codeVoice","code":"conn"},{"text":" should not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have completed a handshake."}],"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/gio\/tlsclientconnectionprotocol\/copysessionstate(source:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionProtocol"]]},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"copySessionState","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"TLSClientConnectionT"},{"text":">(","kind":"text"},{"text":"source","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TLSClientConnectionT"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"TLSClientConnectionT"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO27TLSClientConnectionProtocolP","text":"TLSClientConnectionProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionProtocol"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is not possible to know whether a call to this function will"},{"text":" ","type":"text"},{"text":"actually do anything. Because session resumption is normally used","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"only for performance benefit, the TLS backend might not implement"},{"type":"text","text":" "},{"text":"this function. Even if implemented, it may not actually succeed in","type":"text"},{"type":"text","text":" "},{"text":"allowing ","type":"text"},{"type":"codeVoice","code":"conn"},{"text":" to resume ","type":"text"},{"code":"source","type":"codeVoice"},{"type":"text","text":"’s TLS session, because the server"},{"text":" ","type":"text"},{"type":"text","text":"may not have sent a session resumption token to "},{"type":"codeVoice","code":"source"},{"type":"text","text":", or it may"},{"text":" ","type":"text"},{"type":"text","text":"refuse to accept the token from "},{"type":"codeVoice","code":"conn"},{"text":". There is no way to know","type":"text"},{"text":" ","type":"text"},{"text":"whether a call to this function is actually successful.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Using this function is not required to benefit from session"},{"type":"text","text":" "},{"type":"text","text":"resumption. If the TLS backend supports session resumption, the"},{"text":" ","type":"text"},{"text":"session will be resumed automatically if it is possible to do so","type":"text"},{"type":"text","text":" "},{"text":"without weakening the privacy guarantees normally provided by TLS,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without need to call this function. For example, with TLS 1.3,"},{"type":"text","text":" "},{"text":"a session ticket will be automatically copied from any","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection"},{"type":"text","text":" that has previously received session tickets"},{"text":" ","type":"text"},{"type":"text","text":"from the server, provided a ticket is available that has not"},{"type":"text","text":" "},{"text":"previously been used for session resumption, since session ticket","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reuse would be a privacy weakness. Using this function causes the"},{"type":"text","text":" "},{"text":"ticket to be copied without regard for privacy considerations.","type":"text"}],"type":"paragraph"}]}],"metadata":{"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"copySessionState","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"TLSClientConnectionT"},{"text":">(","kind":"text"},{"text":"source","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSClientConnectionT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"extendedModule":"GIO","externalID":"s:3GIO27TLSClientConnectionProtocolPAAE16copySessionState6sourceyqd___tAaBRd__lF","roleHeading":"Instance Method","role":"symbol","title":"copySessionState(source:)","modules":[{"name":"GIO"}]},"references":{"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnectionProtocol/copySessionState(source:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionProtocol\/copySessionState(source:)","abstract":[{"type":"text","text":"Possibly copies session state from one connection to another, for use"},{"text":" ","type":"text"},{"text":"in TLS session resumption. This is not normally needed, but may be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"used when the same session needs to be used between different"},{"type":"text","text":" "},{"text":"endpoints, as is required by some protocols, such as FTP over TLS.","type":"text"},{"type":"text","text":" "},{"code":"source","type":"codeVoice"},{"text":" should have already completed a handshake and, since TLS 1.3,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it should have been used to read data at least once. "},{"code":"conn","type":"codeVoice"},{"text":" should not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have completed a handshake."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"copySessionState"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"TLSClientConnectionT"},{"text":">(","kind":"text"},{"text":"source","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSClientConnectionT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"type":"topic","kind":"symbol","title":"copySessionState(source:)","role":"symbol","url":"\/documentation\/gio\/tlsclientconnectionprotocol\/copysessionstate(source:)"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSClientConnectionProtocol":{"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TLSClientConnectionProtocol"}],"title":"TLSClientConnectionProtocol","navigatorTitle":[{"text":"TLSClientConnectionProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/tlsclientconnectionprotocol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"text":" is the client-side subclass of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"type":"text","text":"], representing a client-side TLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionProtocol","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}