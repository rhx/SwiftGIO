{"sections":[],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Stop the debug controller, unregistering its object from the bus."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol\/stop()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"stop","kind":"identifier"},{"text":"()","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any pending method calls to the object will complete successfully, but new"},{"text":" ","type":"text"},{"type":"text","text":"ones will return an error. This method will block until all pending"},{"type":"text","text":" "},{"type":"text","text":"[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:) signals have been handled. This is expected"},{"type":"text","text":" "},{"text":"to not take long, as it will just be waiting for threads to join. If any","type":"text"},{"text":" ","type":"text"},{"text":"[DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:) signal handlers are still executing in other","type":"text"},{"type":"text","text":" "},{"type":"text","text":"threads, this will block until after they have returned."}]},{"type":"paragraph","inlineContent":[{"text":"This method will be called automatically when the final reference to the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","type":"reference","isActive":true},{"type":"text","text":" is dropped. You may want to call it explicitly to know"},{"text":" ","type":"text"},{"type":"text","text":"when the controller has been fully removed from the bus, or to break"},{"type":"text","text":" "},{"type":"text","text":"reference count cycles."}]},{"type":"paragraph","inlineContent":[{"text":"Calling this method from within a [DebugControllerDBus](\/\/documentation\/gio\/debugcontrollerdbus\/onauthorize(flags:handler:) signal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handler will cause a deadlock and must not be done."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/debugcontrollerdbusprotocol\/stop()"]}],"metadata":{"externalID":"s:3GIO27DebugControllerDBusProtocolPAAE4stopyyF","role":"symbol","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stop"},{"text":"()","kind":"text"}],"roleHeading":"Instance Method","title":"stop()","extendedModule":"GIO"},"references":{"doc://GIO/documentation/GIO/DebugController":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"DebugController"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","url":"\/documentation\/gio\/debugcontroller","title":"DebugController","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DebugController","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDebugController"},{"type":"text","text":" is an interface to expose control of debugging features and"},{"type":"text","text":" "},{"text":"debug output.","type":"text"}]},"doc://GIO/documentation/GIO/DebugControllerDBusProtocol":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol","title":"DebugControllerDBusProtocol","url":"\/documentation\/gio\/debugcontrollerdbusprotocol","abstract":[{"type":"codeVoice","code":"GDebugControllerDBus"},{"type":"text","text":" is an implementation of [iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController","isActive":true,"type":"reference"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"which exposes debug settings as a D-Bus object."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DebugControllerDBusProtocol","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"DebugControllerDBusProtocol","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DebugControllerDBus":{"kind":"symbol","abstract":[{"type":"codeVoice","code":"GDebugControllerDBus"},{"type":"text","text":" is an implementation of [iface"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugController"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"which exposes debug settings as a D-Bus object.","type":"text"}],"url":"\/documentation\/gio\/debugcontrollerdbus","type":"topic","navigatorTitle":[{"kind":"identifier","text":"DebugControllerDBus"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBus","title":"DebugControllerDBus","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DebugControllerDBus"}]},"doc://GIO/documentation/GIO/DebugControllerDBusProtocol/stop()":{"url":"\/documentation\/gio\/debugcontrollerdbusprotocol\/stop()","abstract":[{"text":"Stop the debug controller, unregistering its object from the bus.","type":"text"}],"role":"symbol","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DebugControllerDBusProtocol\/stop()","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stop"},{"text":"()","kind":"text"}],"title":"stop()"}}}