{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dtlsclientconnectionsignalname\/notifyvalidationflags"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionSignalName"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionSignalName\/notifyValidationFlags"},"metadata":{"roleHeading":"Case","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notifyValidationFlags"}],"externalID":"s:3GIO30DtlsClientConnectionSignalNameO21notifyValidationFlagsyA2CmF","title":"DtlsClientConnectionSignalName.notifyValidationFlags","symbolKind":"case"},"abstract":[{"type":"text","text":"What steps to perform when validating a certificate received from"},{"type":"text","text":" "},{"text":"a server. Server certificates that fail to validate in any of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ways indicated here will be rejected unless the application"},{"text":" ","type":"text"},{"type":"text","text":"overrides the default via [DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:)."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notifyValidationFlags","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"GLib guarantees that if certificate verification fails, at least one","type":"text"},{"text":" ","type":"text"},{"text":"flag will be set, but it does not guarantee that all possible flags","type":"text"},{"type":"text","text":" "},{"text":"will be set. Accordingly, you may not safely decide to ignore any","type":"text"},{"type":"text","text":" "},{"type":"text","text":"particular type of error. For example, it would be incorrect to mask"},{"text":" ","type":"text"},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow expired certificates,"},{"text":" ","type":"text"},{"text":"because this could potentially be the only error flag set even if","type":"text"},{"type":"text","text":" "},{"text":"other problems exist with the certificate. Therefore, there is no","type":"text"},{"type":"text","text":" "},{"text":"safe way to use this property. This is not a horrible problem,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"though, because you should not be attempting to ignore validation"},{"type":"text","text":" "},{"text":"errors anyway. If you really must ignore TLS certificate errors,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connect to [DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:)."}]},{"inlineContent":[{"inlineContent":[{"text":"validation-flags is deprecated:","type":"text"}],"type":"strong"},{"type":"text","text":" "},{"type":"text","text":"Do not attempt to ignore validation errors."}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/DtlsClientConnectionSignalName":{"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"DtlsClientConnectionSignalName","kind":"identifier"}],"abstract":[],"kind":"symbol","title":"DtlsClientConnectionSignalName","url":"\/documentation\/gio\/dtlsclientconnectionsignalname","navigatorTitle":[{"text":"DtlsClientConnectionSignalName","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionSignalName","role":"symbol"},"doc://GIO/documentation/GIO/DtlsClientConnectionSignalName/notifyValidationFlags":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DtlsClientConnectionSignalName\/notifyValidationFlags","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notifyValidationFlags","kind":"identifier"}],"type":"topic","title":"DtlsClientConnectionSignalName.notifyValidationFlags","url":"\/documentation\/gio\/dtlsclientconnectionsignalname\/notifyvalidationflags","abstract":[{"type":"text","text":"What steps to perform when validating a certificate received from"},{"type":"text","text":" "},{"type":"text","text":"a server. Server certificates that fail to validate in any of the"},{"type":"text","text":" "},{"type":"text","text":"ways indicated here will be rejected unless the application"},{"text":" ","type":"text"},{"type":"text","text":"overrides the default via [DtlsConnection](\/\/documentation\/gio\/dtlsconnection\/onacceptcertificate(flags:handler:)."}],"kind":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}