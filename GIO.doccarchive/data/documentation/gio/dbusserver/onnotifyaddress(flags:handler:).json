dableResult"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyAddress","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"text":"DBusServerRef","preciseIdentifier":"s:3GIO13DBusServerRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServerRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"The signal handler to call","type":"text"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"code":"notifyAddress","type":"codeVoice"},{"text":" signal is emitted","type":"text"}]}]}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"text":" ","type":"text"},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"code":"g_object_set_property()","type":"codeVoice"},{"type":"text","text":" results"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":","},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference"},{"text":" as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::address"},{"type":"text","text":" signal"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusserver\/onnotifyaddress(flags:handler:)"]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DBusServer":{"title":"DBusServer","kind":"symbol","url":"\/documentation\/gio\/dbusserver","abstract":[{"type":"codeVoice","code":"GDBusServer"},{"type":"text","text":" is a helper for listening to and accepting D-Bus"},{"type":"text","text":" "},{"text":"connections. This can be used to create a new D-Bus server, allowing two","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"peers to use the D-Bus protocol for their own specialized communication."},{"text":" ","type":"text"},{"type":"text","text":"A server instance provided in this way will not perform message routing or"},{"type":"text","text":" "},{"text":"implement the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#message-bus-messages","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusServer","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServer","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"DBusServer"}]},"doc://GIO/documentation/GIO/DBusServer/DBusServerProtocol-Implementations":{"url":"\/documentation\/gio\/dbusserver\/dbusserverprotocol-implementations","title":"DBusServerProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusServer\/DBusServerProtocol-Implementations","abstract":[],"k