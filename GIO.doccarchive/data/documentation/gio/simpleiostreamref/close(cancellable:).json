{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SimpleIOStreamRef\/close(cancellable:)"},"metadata":{"modules":[{"name":"GIO"}],"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"symbolKind":"method","externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO17SimpleIOStreamRefV","role":"symbol","roleHeading":"Instance Method","title":"close(cancellable:)"},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return"},{"text":" ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":". Closing a stream multiple times will not"},{"text":" ","type":"text"},{"type":"text","text":"return an error."}]},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the stream."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file"},{"text":" ","type":"text"},{"text":"descriptor) open after the stream is closed. See the documentation for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the individual stream for details."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the"},{"text":" ","type":"text"},{"text":"close operation will finish as much as possible. A stream that failed","type":"text"},{"text":" ","type":"text"},{"text":"to close will still return ","type":"text"},{"type":"codeVoice","code":"closed"},{"text":" for all operations.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Still, it is important to check and report the error to the user,"},{"text":" ","type":"text"},{"text":"otherwise there might be a loss of data as all data might not be written.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not NULL, then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned.","type":"text"},{"text":" ","type":"text"},{"text":"Cancelling a close will still leave the stream closed, but some streams","type":"text"},{"text":" ","type":"text"},{"text":"can use a faster close that doesn’t block to e.g. check errors.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default implementation of this method just calls close on the"},{"type":"text","text":" "},{"text":"individual input\/output streams.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/simpleiostreamref\/close(cancellable:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"text":" ","type":"text"},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"type":"text","text":" "},{"type":"text","text":"closed."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleIOStreamRef","doc:\/\/GIO\/documentation\/GIO\/SimpleIOStreamRef\/IOStreamProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SimpleIOStreamRef/IOStreamProtocol-Implementations":{"kind":"article","type":"topic","url":"\/documentation\/gio\/simpleiostreamref\/iostreamprotocol-implementations","title":"IOStreamProtocol Implementations","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleIOStreamRef\/IOStreamProtocol-Implementations"},"doc://GIO/documentation/GIO/OutputStream":{"kind":"symbol","type":"topic","title":"OutputStream","role":"symbol","abstract":[{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" is a base class for implementing streaming output."}],"url":"\/documentation\/gio\/outputstream","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OutputStream","kind":"identifier"}],"navigatorTitle":[{"text":"OutputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/InputStream":{"kind":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","abstract":[{"type":"codeVoice","code":"GInputStream"},{"type":"text","text":" is a base class for implementing streaming input."}],"title":"InputStream","url":"\/documentation\/gio\/inputstream","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"InputStream","kind":"identifier"}],"navigatorTitle":[{"text":"InputStream","kind":"identifier"}]},"doc://GIO/documentation/GIO/SimpleIOStreamRef":{"url":"\/documentation\/gio\/simpleiostreamref","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SimpleIOStreamRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimpleIOStreamRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GSimpleIOStream"},{"text":" creates a [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"text":"] from an arbitrary","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream"},{"text":"] and [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","type":"reference"},{"text":"]. This allows any pair of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"input and output streams to be used with [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","type":"reference","isActive":true},{"type":"text","text":"] methods."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleIOStreamRef","role":"symbol","type":"topic","title":"SimpleIOStreamRef"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/SimpleIOStreamRef/close(cancellable:)":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"title":"close(cancellable:)","ty