{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"s:3GIO22SocketListenerProtocolPAAE14addAnyInetPort12sourceObjects6UInt16Vqd__Sg_tK04GLibJ00jD0Rd__lF","symbolKind":"method","roleHeading":"Instance Method","title":"addAnyInetPort(sourceObject:)","modules":[{"name":"GIO"}],"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"addAnyInetPort","kind":"identifier"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"GObjectObjectT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"sourceObject"},{"text":": ","kind":"text"},{"text":"GObjectObjectT","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@guint16","text":"guint16"}],"role":"symbol"},"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketListenerProtocol\/addAnyInetPort(sourceObject:)-2ewl1","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketListenerProtocol"]]},"abstract":[{"type":"text","text":"Listens for TCP connections on any available port number for both"},{"type":"text","text":" "},{"text":"IPv6 and IPv4 (if each is available).","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addAnyInetPort"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GObjectObjectT"},{"kind":"text","text":">("},{"text":"sourceObject","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GObjectObjectT"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"guint16","preciseIdentifier":"c:@T@guint16"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GObjectObjectT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:10GLibObject0B8ProtocolP","text":"ObjectProtocol","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"This is useful if you need to have a socket for incoming connections","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but don’t care about the specific port number."}],"type":"paragraph"},{"inlineContent":[{"text":"If possible, the [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener"},{"text":"] will listen on both IPv4 and","type":"text"},{"type":"text","text":" "},{"text":"IPv6 (listening on the same port on both). If listening on one of the socket","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"families fails, the [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","isActive":true},{"text":"] will only listen on the other.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If listening on both fails, an error will be returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to distinguish whether listening on IPv4 or IPv6 or both was"},{"type":"text","text":" "},{"type":"text","text":"successful, connect to [signal[SocketListener](\/\/documentation\/gio\/socketlistener\/onevent(flags:handler:)]."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceObject"},{"type":"text","text":" will be passed out in the various calls"},{"type":"text","text":" "},{"type":"text","text":"to accept to identify this particular source, which is"},{"type":"text","text":" "},{"text":"useful if you’re listening on multiple addresses and do","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"different things depending on what address is connected to."}]}]}],"variants":[{"paths":["\/documentation\/gio\/socketlistenerprotocol\/addanyinetport(sourceobject:)-2ewl1"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/SocketListenerProtocol":{"abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GSocketListener"},{"text":" is an object that keeps track of a set","type":"text"},{"text":" ","type":"text"},{"text":"of server sockets and helps you accept sockets from any of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"socket, either sync or async."}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"SocketListenerProtocol"}],"url":"\/documentation\/gio\/socketlistenerprotocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SocketListenerProtocol"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListenerProtocol","title":"SocketListenerProtocol","role":"symbol"},"doc://GIO/documentation/GIO/SocketListener":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"topic","url":"\/documentation\/gio\/socketlistener","kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GSocketListener","type":"codeVoice"},{"text":" is an object that keeps track of a set","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of server sockets and helps you accept sockets from any of the"},{"text":" ","type":"text"},{"type":"text","text":"socket, either sync or async."}],"title":"SocketListener","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketListener"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketListener"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol