{"topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(_:)-1rxby","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(_:)-5jln1","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(_:)-6jq77","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(_:)-7hnq3","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(_:)-84gtk","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(opaquePointer:)"],"anchor":"Initializers","title":"Initializers","generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/ptr"]},{"title":"Type Methods","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/unowned(_:)"],"anchor":"Type-Methods"},{"title":"Default Implementations","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/GWeakCapturing-Implementations","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/IOStreamProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/ObjectProtocol-Implementations"],"anchor":"Default-Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IOStreamRef","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Examples of "},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" objects are [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference"},{"text":"], which represents","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a two-way network connection; and [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileIOStream","isActive":true},{"text":"], which represents a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"file handle opened in read-write mode."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"To do the actual reading and writing you need to get the substreams","type":"text"},{"type":"text","text":" "},{"text":"with [method","type":"text"},{"type":"codeVoice","code":"Gio.IOStream.get_input_stream"},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.IOStream.get_output_stream"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" object owns the input and the output streams, not the other"},{"text":" ","type":"text"},{"type":"text","text":"way around, so keeping the substreams alive will not keep the "},{"code":"GIOStream","type":"codeVoice"},{"text":" ","type":"text"},{"text":"object alive. If the ","type":"text"},{"type":"codeVoice","code":"GIOStream"},{"text":" object is freed it will be closed, thus","type":"text"},{"text":" ","type":"text"},{"text":"closing the substreams, so even if the substreams stay alive they will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always return "},{"type":"codeVoice","code":"G_IO_ERROR_CLOSED"},{"type":"text","text":" for all operations."}]},{"type":"paragraph","inlineContent":[{"text":"To close a stream use [method","type":"text"},{"type":"codeVoice","code":"Gio.IOStream.close"},{"text":"] which will close the common","type":"text"},{"type":"text","text":" "},{"text":"stream object and also the individual substreams. You can also close","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the substreams themselves. In most cases this only marks the"},{"type":"text","text":" "},{"text":"substream as closed, so further I\/O on it fails but common state in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" may still be open. However, some streams may support"},{"type":"text","text":" "},{"text":"‘half-closed’ states where one direction of the stream is actually shut down.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Operations on ","type":"text"},{"type":"codeVoice","code":"GIOStream"},{"text":"s cannot be started while another operation on the","type":"text"},{"text":" ","type":"text"},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":" or its substreams is in progress. Specifically, an application can"},{"type":"text","text":" "},{"text":"read from the [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"type":"text","text":"] and write to the"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","type":"reference"},{"type":"text","text":"] simultaneously (either in separate threads, or as"},{"type":"text","text":" "},{"type":"text","text":"asynchronous operations in the same thread), but an application cannot start"},{"text":" ","type":"text"},{"text":"any ","type":"text"},{"code":"GIOStream","type":"codeVoice"},{"text":" operation while there is a ","type":"text"},{"code":"GIOStream","type":"codeVoice"},{"type":"text","text":", "},{"code":"GInputStream","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"GOutputStream"},{"text":" operation in progress, and an application can’t start any","type":"text"},{"type":"text","text":" "},{"code":"GInputStream","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"GOutputStream","type":"codeVoice"},{"type":"text","text":" operation while there is a "},{"type":"codeVoice","code":"GIOStream"},{"text":" ","type":"text"},{"type":"text","text":"operation in progress."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is a product of individual stream operations being associated with a"},{"text":" ","type":"text"},{"type":"text","text":"given [type[MainContext](\/\/documentation\/glib\/maincontext] (the thread-default context at the time the"},{"type":"text","text":" "},{"text":"operation was started), rather than entire streams being associated with a","type":"text"},{"type":"text","text":" "},{"text":"single ","type":"text"},{"type":"codeVoice","code":"GMainContext"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"GIO may run operations on ","type":"text"},{"code":"GIOStream","type":"codeVoice"},{"text":"s from other (worker) threads, and this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"may be exposed to application code in the behaviour of wrapper streams, such"},{"text":" ","type":"text"},{"text":"as [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStream","type":"reference"},{"text":"] or [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"text":"]. With such","type":"text"},{"type":"text","text":" "},{"type":"text","text":"wrapper APIs, application code may only run operations on the base (wrapped)"},{"type":"text","text":" "},{"type":"text","text":"stream when the wrapper stream is idle. Note that the semantics of such"},{"type":"text","text":" "},{"type":"text","text":"operations may not be well-defined due to the state the wrapper stream leaves"},{"type":"text","text":" "},{"text":"the base stream in (though they are guaranteed not to crash).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GIOStream","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol","type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef"},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GIOStream","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GIOStream"},{"text":" instance.","type":"text"}],"type":"paragraph"}]}]}],"sections":[],"metadata":{"title":"IOStreamRef","externalID":"s:3GIO11IOStreamRefV","symbolKind":"struct","navigatorTitle":[{"text":"IOStreamRef","kind":"identifier"}],"roleHeading":"Structure","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IOStreamRef","kind":"identifier"}]},"variants":[{"paths":["\/documentation\/gio\/iostreamref"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"type":"codeVoice","code":"GIOStream"},{"text":" represents an object that has both read and write streams.","type":"text"},{"type":"text","text":" "},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"text":" ","type":"text"},{"type":"text","text":"seekable streams, both streams may use the same position."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol"],"title":"Conforms To"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef"},"kind":"symbol","references":{"doc://GIO/documentation/GIO/IOStreamRef/init(constPointer:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamRef\/init(constPointer:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"text":"T","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"constPointer","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":">)","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Unsafe typed initialiser."},{"type":"text","text":" "},{"inlineContent":[{"text":"Do not use unless you know the underlying data type the pointer points to conforms to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStreamProtocol"},{"type":"text","text":"."}],"type":"strong"}],"type":"topic","url":"\/documentation\/gio\/iostreamref\/init(constpointer:)","title":"init(constPointer:)","role":"symbol"},"doc://GIO/documentation/GIO/IOStreamProtocol/io_stream_ptr-90l27":{"type":"topic","required":true,"