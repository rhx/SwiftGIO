rotocol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"text":" represents an object that has both read and write streams.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Generally the two streams act as separate input and output streams,"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"title":"IOStreamProtocol","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/FilterInputStream":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStream","role":"symbol","url":"\/documentation\/gio\/filterinputstream","abstract":[{"type":"text","text":"Base class for input stream implementations that perform some"},{"text":" ","type":"text"},{"text":"kind of filtering operation on a base stream. Typical examples","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of filtering operations are character set conversion, compression"},{"type":"text","text":" "},{"text":"and byte order flipping.","type":"text"}],"navigatorTitle":[{"text":"FilterInputStream","kind":"identifier"}],"title":"FilterInputStream","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"FilterInputStream"}],"type":"topic"},"doc://GIO/documentation/GIO/BufferedInputStream":{"abstract":[{"type":"text","text":"Buffered input stream implements [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FilterInputStream"},{"text":"] and provides","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for buffered reads."}],"navigatorTitle":[{"text":"BufferedInputStream","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/BufferedInputStream","url":"\/documentation\/gio\/bufferedinputstream","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"key