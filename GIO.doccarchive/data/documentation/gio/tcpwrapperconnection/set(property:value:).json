l","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/SocketClient":{"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketClient"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","abstract":[{"type":"codeVoice","code":"GSocketClient"},{"type":"text","text":" is a lightweight high-level utility class for connecting to"},{"type":"text","text":" "},{"type":"text","text":"a network host using a connection oriented socket type."}],"title":"SocketClient","role":"symbol","url":"\/documentation\/gio\/socketclient","navigatorTitle":[{"kind":"identifier","text":"SocketClient"}]},"doc://GIO/documentation/GIO/TcpWrapperConnection/TcpWrapperConnectionProtocol-Implementations":{"url":"\/documentation\/gio\/tcpwrapperconnection\/tcpwrapperconnectionprotocol-implementations","title":"TcpWrapperConnectionProtocol Implementations","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpWrapperConnection\/TcpWrapperConnectionProtocol-Implementations","type":"topic","kind":"article"},"doc://GIO/documentation/GIO/TcpWrapperConnectionPropertyName":{"navigatorTitle":[{"text":"TcpWrapperConnectionPropertyName","kind":"identifier"}],"url":"\/documentation\/gio\/tcpwrapperconnectionpropertyname","type":"topic","title":"TcpWrapperConnectionPropertyName","abstract":[],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpWrapperConnectionPropertyName","fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"TcpWrapperConnectionPropertyName","kind":"identifier"}]},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TcpWrapperConnection":{"kind":"symbol","navigatorTitle":[{"text":"TcpWrapperConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TcpWrapperConnection","kind":"identifier"}],"url":"\/documentation\/gio\/tcpwrapperconnection","title":"TcpWrapperConnection","abstract":[{"text":"A ","type":"text"},{"code":"GTcpWrapperConnection","type":"codeVoice"},{"text":" can be used to wrap a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] that is","type":"text"},{"type":"text","text":" "},{"text":"based on a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true,"type":"reference"},{"text":"], but which is not actually a","type":"text"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference","isActive":true},{"text":"]. This is used by [class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient"},{"text":"] so","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that it can always return a [class"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference"},{"type":"text","text":"], even when the"},{"type":"text","text":" "},{"type":"text","text":"connection it has actually created is not directly a"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection"},{"type":"text","text":"]."}],"type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpWrapperConnection"},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","url":"\/documentation\/gio\/socketconnection","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"type":"text","text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"}}}