{"abstract":[{"type":"text","text":"What steps to perform when validating a certificate received from"},{"text":" ","type":"text"},{"text":"a server. Server certificates that fail to validate in any of the","type":"text"},{"type":"text","text":" "},{"text":"ways indicated here will be rejected unless the application","type":"text"},{"text":" ","type":"text"},{"text":"overrides the default via [TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:).","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsclientconnectionsignalname\/notifyvalidationflags"]}],"metadata":{"externalID":"s:3GIO29TLSClientConnectionSignalNameO21notifyValidationFlagsyA2CmF","role":"symbol","modules":[{"name":"GIO"}],"symbolKind":"case","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notifyValidationFlags","kind":"identifier"}],"roleHeading":"Case","title":"TLSClientConnectionSignalName.notifyValidationFlags"},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName\/notifyValidationFlags","interfaceLanguage":"swift"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notifyValidationFlags"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"GLib guarantees that if certificate verification fails, at least one","type":"text"},{"text":" ","type":"text"},{"text":"flag will be set, but it does not guarantee that all possible flags","type":"text"},{"type":"text","text":" "},{"text":"will be set. Accordingly, you may not safely decide to ignore any","type":"text"},{"type":"text","text":" "},{"type":"text","text":"particular type of error. For example, it would be incorrect to mask"},{"type":"text","text":" "},{"type":"codeVoice","code":"expired"},{"text":" if you want to allow expired certificates,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"because this could potentially be the only error flag set even if"},{"text":" ","type":"text"},{"text":"other problems exist with the certificate. Therefore, there is no","type":"text"},{"text":" ","type":"text"},{"text":"safe way to use this property. This is not a horrible problem,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"though, because you should not be attempting to ignore validation"},{"text":" ","type":"text"},{"text":"errors anyway. If you really must ignore TLS certificate errors,","type":"text"},{"type":"text","text":" "},{"text":"connect to [TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"validation-flags is deprecated:"}],"type":"strong"},{"text":" ","type":"text"},{"type":"text","text":"Do not attempt to ignore validation errors."}]}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnectionSignalName/notifyValidationFlags":{"title":"TLSClientConnectionSignalName.notifyValidationFlags","type":"topic","url":"\/documentation\/gio\/tlsclientconnectionsignalname\/notifyvalidationflags","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName\/notifyValidationFlags","abstract":[{"type":"text","text":"What steps to perform when validating a certificate received from"},{"type":"text","text":" "},{"text":"a server. Server certificates that fail to validate in any of the","type":"text"},{"type":"text","text":" "},{"text":"ways indicated here will be rejected unless the application","type":"text"},{"type":"text","text":" "},{"type":"text","text":"overrides the default via [TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"notifyValidationFlags"}],"role":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnectionSignalName":{"navigatorTitle":[{"kind":"identifier","text":"TLSClientConnectionSignalName"}],"title":"TLSClientConnectionSignalName","abstract":[],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSClientConnectionSignalName","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName","url":"\/documentation\/gio\/tlsclientconnectionsignalname"}}}