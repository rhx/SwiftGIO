{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName\/acceptCertificate","interfaceLanguage":"swift"},"sections":[],"metadata":{"role":"symbol","title":"TLSClientConnectionSignalName.acceptCertificate","roleHeading":"Case","externalID":"s:3GIO29TLSClientConnectionSignalNameO17acceptCertificateyA2CmF","modules":[{"name":"GIO"}],"fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"acceptCertificate","kind":"identifier"}],"symbolKind":"case"},"abstract":[{"type":"text","text":"Emitted during the TLS handshake after the peer certificate has"},{"type":"text","text":" "},{"text":"been received. You can examine ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":"’s certification path by"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"code":"g_tls_certificate_get_issuer()","type":"codeVoice"},{"type":"text","text":" on it."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsclientconnectionsignalname\/acceptcertificate"]}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"acceptCertificate","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"For a client-side connection, "},{"type":"codeVoice","code":"peerCert"},{"type":"text","text":" is the server’s"},{"type":"text","text":" "},{"type":"text","text":"certificate, and the signal will only be emitted if the"},{"type":"text","text":" "},{"type":"text","text":"certificate was not acceptable according to "},{"code":"conn","type":"codeVoice"},{"text":"’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","type":"reference"},{"type":"text","text":". If you would like the"},{"text":" ","type":"text"},{"text":"certificate to be accepted despite ","type":"text"},{"code":"errors","type":"codeVoice"},{"type":"text","text":", return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the"},{"type":"text","text":" "},{"text":"signal handler. Otherwise, if no handler accepts the certificate,","type":"text"},{"text":" ","type":"text"},{"text":"the handshake will fail with ","type":"text"},{"type":"codeVoice","code":"badCertificate"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"GLib guarantees that if certificate verification fails, this signal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"will be emitted with at least one error will be set in "},{"code":"errors","type":"codeVoice"},{"type":"text","text":", but"},{"text":" ","type":"text"},{"text":"it does not guarantee that all possible errors will be set.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Accordingly, you may not safely decide to ignore any particular"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"text":" ","type":"text"},{"type":"codeVoice","code":"expired"},{"type":"text","text":" if you want to allow expired"},{"type":"text","text":" "},{"type":"text","text":"certificates, because this could potentially be the only error flag"},{"text":" ","type":"text"},{"type":"text","text":"set even if other problems exist with the certificate."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For a server-side connection, ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"text":" is the certificate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"presented by the client, if this was requested via the server’s"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection"},{"text":". On the server side,","type":"text"},{"type":"text","text":" "},{"text":"the signal is always emitted when the client presents a","type":"text"},{"text":" ","type":"text"},{"text":"certificate, and the certificate will only be accepted if a","type":"text"},{"text":" ","type":"text"},{"text":"handler returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"type":"text","text":" "},{"type":"text","text":"in the main thread, then you should not attempt to interact with"},{"text":" ","type":"text"},{"type":"text","text":"the user before returning from the signal handler. If you want to"},{"type":"text","text":" "},{"type":"text","text":"let the user decide whether or not to accept the certificate, you"},{"type":"text","text":" "},{"type":"text","text":"would have to return "},{"type":"codeVoice","code":"false"},{"type":"text","text":" from the signal handler on the first"},{"text":" ","type":"text"},{"text":"attempt, and then after the connection attempt returns a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"badCertificate"},{"type":"text","text":", you can interact with the user, and"},{"text":" ","type":"text"},{"type":"text","text":"if the user decides to accept the certificate, remember that fact,"},{"type":"text","text":" "},{"type":"text","text":"create a new connection, and return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the signal handler"},{"type":"text","text":" "},{"text":"the next time.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If you are doing I\/O in another thread, you do not","type":"text"},{"type":"text","text":" "},{"text":"need to worry about this, and can simply block in the signal","type":"text"},{"type":"text","text":" "},{"text":"handler until the UI thread returns an answer.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a server-side TLS connection.","type":"text"}]},"doc://GIO/documentation/GIO/TLSClientConnectionSignalName":{"navigatorTitle":[{"kind":"identifier","text":"TLSClientConnectionSignalName"}],"title":"TLSClientConnectionSignalName","abstract":[],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSClientConnectionSignalName","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName","url":"\/documentation\/gio\/tlsclientconnectionsignalname"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnectionSignalName/acceptCertificate":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionSignalName\/acceptCertificate","abstract":[{"text":"Emitted during the TLS handshake after the peer certificate has","type":"text"},{"type":"text","text":" "},{"text":"been received. You can examine ","type":"text"},{"type":"codeVoice","code":"peerCert"},{"text":"’s certification path by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_tls_certificate_get_issuer()"},{"type":"text","text":" on it."}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"acceptCertificate","kind":"identifier"}],"url":"\/documentation\/gio\/tlsclientconnectionsignalname\/acceptcertificate","type":"topic","kind":"symbol","role":"symbol","title":"TLSClientConnectionSignalName.acceptCertificate"}}}