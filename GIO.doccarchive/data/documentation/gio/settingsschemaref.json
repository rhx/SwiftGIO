{"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(_:)-137p7","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(_:)-58rlb","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(_:)-6q3sb","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(_:)-7w5nu","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(_:)-tvs8","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/init(opaquePointer:)"]},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/ptr"],"anchor":"Instance-Properties"},{"title":"Default Implementations","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/PointerWrapper-Implementations","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef\/SettingsSchemaProtocol-Implementations"],"anchor":"Default-Implementations","generated":true}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef","interfaceLanguage":"swift"},"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaProtocol"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"SettingsSchemaRef","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"Plugin loading systems that wish to provide plugins a way to access"},{"text":" ","type":"text"},{"text":"settings face the problem of how to make the schemas for these","type":"text"},{"type":"text","text":" "},{"text":"settings visible to GSettings.  Typically, a plugin will want to ship","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the schema along with itself and it won’t be installed into the"},{"type":"text","text":" "},{"type":"text","text":"standard system directories for schemas."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"[struct"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSource","type":"reference"},{"type":"text","text":"] provides a mechanism for dealing with this"},{"text":" ","type":"text"},{"type":"text","text":"by allowing the creation of a new ‘schema source’ from which schemas can"},{"text":" ","type":"text"},{"text":"be acquired.  This schema source can then become part of the metadata","type":"text"},{"type":"text","text":" "},{"text":"associated with the plugin and queried whenever the plugin requires","type":"text"},{"type":"text","text":" "},{"type":"text","text":"access to some settings."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Consider the following example:"}]},{"type":"codeListing","syntax":"c","code":["typedef struct","{","   …","   GSettingsSchemaSource *schema_source;","   …","} Plugin;","","Plugin *","initialise_plugin (const gchar *dir)","{","  Plugin *plugin;","","  …","","  plugin->schema_source =","    g_settings_schema_source_new_from_directory (dir,","      g_settings_schema_source_get_default (), FALSE, NULL);","","  …","","  return plugin;","}","","…","","GSettings *","plugin_get_settings (Plugin      *plugin,","                     const gchar *schema_id)","{","  GSettingsSchema *schema;","","  if (schema_id == NULL)","    schema_id = plugin->identifier;","","  schema = g_settings_schema_source_lookup (plugin->schema_source,","                                            schema_id, FALSE);","","  if (schema == NULL)","    {","      … disable the plugin or abort, etc …","    }","","  return g_settings_new_full (schema, NULL, NULL);","}"]},{"type":"paragraph","inlineContent":[{"text":"The code above shows how hooks should be added to the code that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initialises (or enables) the plugin to create the schema source and"},{"type":"text","text":" "},{"type":"text","text":"how an API can be added to the plugin system to provide a convenient"},{"type":"text","text":" "},{"text":"way for the plugin to access its settings, using the schemas that it","type":"text"},{"type":"text","text":" "},{"text":"ships.","type":"text"}]},{"inlineContent":[{"text":"From the standpoint of the plugin, it would need to ensure that it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"ships a gschemas.compiled file as part of itself, and then simply do"},{"text":" ","type":"text"},{"type":"text","text":"the following:"}],"type":"paragraph"},{"code":["{","  GSettings *settings;","  gint some_value;","","  settings = plugin_get_settings (self, NULL);","  some_value = g_settings_get_int (settings, \"some-value\");","  …","}"],"type":"codeListing","syntax":"c"},{"type":"paragraph","inlineContent":[{"text":"It’s also possible that the plugin system expects the schema source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"files (ie: "},{"type":"codeVoice","code":".gschema.xml"},{"type":"text","text":" files) instead of a "},{"type":"codeVoice","code":"gschemas.compiled"},{"text":" file.","type":"text"},{"text":" ","type":"text"},{"text":"In that case, the plugin loading system must compile the schemas for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"itself before attempting to create the settings source."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef","isActive":true,"type":"reference"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GSettingsSchema"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaProtocol"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GSettingsSchema"},{"type":"text","text":" instance."}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchema","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaRef"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GSettingsSchema"},{"type":"text","text":" instance."}],"type":"paragraph"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"metadata":{"symbolKind":"struct","externalID":"s:3GIO17SettingsSchemaRefV","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SettingsSchemaRef"}],"title":"SettingsSchemaRef","roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"SettingsSchemaRef","kind":"identifier"}],"modules":[{"name":"GIO"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/settingsschemaref"],"traits