{"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"metadata":{"symbolKind":"method","title":"onNotifyParameterType(flags:handler:)","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"role":"symbol","externalID":"s:3GIO20SimpleActionProtocolPAAE21onNotifyParameterType5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecO0VtctF::SYNTHESIZED::s:3GIO15SimpleActionRefV","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onNotifyParameterType","kind":"identifier"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"text":": (","kind":"text"},{"text":"SimpleActionRef","preciseIdentifier":"s:3GIO15SimpleActionRefV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef\/SimpleActionProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef\/onNotifyParameterType(flags:handler:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/gio\/simpleactionref\/onnotifyparametertype(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyParameterType","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef","text":"SimpleActionRef","preciseIdentifier":"s:3GIO15SimpleActionRefV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}],"name":"flags"},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"code":"notifyParameterType","type":"codeVoice"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"type":"text","text":" "},{"text":"derived GObject class. If the implementor did not create the property with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"code":"g_object_notify()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"type":"text","text":" "},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"text":" call, like this:","type":"text"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true,"type":"reference"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"notify::parameter-type"},{"type":"text","text":" signal"}]}],"type":"aside","style":"note"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/Action":{"url":"\/documentation\/gio\/action","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action"}],"navigatorTitle":[{"text":"Action","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","title":"Action","role":"symbol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO/SimpleActionRef":{"title":"SimpleActionRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef","role":"symbol","type":"topic","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GSimpleAction"},{"type":"text","text":" is the obvious simple implementation of the"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true,"type":"reference"},{"text":"] interface. This is the easiest way to create an action for","type":"text"},{"text":" ","type":"text"},{"text":"purposes of adding it to a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroup","isActive":true,"type":"reference"},{"type":"text","text":"]."}],"url":"\/documentation\/gio\/simpleactionref","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimpleActionRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SimpleActionRef","kind":"identifier"}]},"#class@GObject.ParamSpec#parameter-names":{"identifie