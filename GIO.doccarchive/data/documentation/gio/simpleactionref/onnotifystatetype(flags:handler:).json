rings for the notify signal."}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"notify::state-type"},{"type":"text","text":" signal"}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef\/onNotifyStateType(flags:handler:)"},"metadata":{"role":"symbol","roleHeading":"Instance Method","externalID":"s:3GIO20SimpleActionProtocolPAAE17onNotifyStateType5flags7handlerSi10GLibObject12ConnectFlagsV_yAA0bC3RefV_AG09ParamSpecO0VtctF::SYNTHESIZED::s:3GIO15SimpleActionRefV","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"onNotifyStateType","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"kind":"text","text":", "},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"text":"SimpleActionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO15SimpleActionRefV"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ParamSpecRefV","text":"ParamSpecRef","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"symbolKind":"method","title":"onNotifyStateType(flags:handler:)","extendedModule":"GIO"},"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef\/SimpleActionProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/gio\/simpleactionref\/onnotifystatetype(flags:handler:)"],"traits":