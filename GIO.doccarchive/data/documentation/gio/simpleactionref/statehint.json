{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef\/ActionProtocol-Implementations"]]},"metadata":{"roleHeading":"Instance Property","externalID":"s:3GIO14ActionProtocolPAAE9stateHint4GLib10VariantRefVSgvp::SYNTHESIZED::s:3GIO15SimpleActionRefV","title":"stateHint","symbolKind":"property","modules":[{"name":"GIO"}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"stateHint"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"role":"symbol","extendedModule":"GIO"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"stateHint","kind":"identifier"},{"text":": ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"! { ","kind":"text"},{"kind":"keyword","text":"get"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" is returned it either means that the action is not stateful"},{"type":"text","text":" "},{"type":"text","text":"or that there is no hint about the valid range of values for the"},{"type":"text","text":" "},{"type":"text","text":"state of the action."}],"type":"paragraph"},{"inlineContent":[{"text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"type":"text","text":" "},{"type":"text","text":"returned