"keyword"},{"text":" ","kind":"text"},{"text":"SimpleActionGroup","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SimpleActionGroup"}]},"doc://GIO/documentation/GIO/SimpleActionRef":{"title":"SimpleActionRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef","role":"symbol","type":"topic","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GSimpleAction"},{"type":"text","text":" is the obvious simple implementation of the"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true,"type":"reference"},{"text":"] interface. This is the easiest way to create an action for","type":"text"},{"text":" ","type":"text"},{"text":"purposes of adding it to a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionGroup","isActive":true,"type":"reference"},{"type":"text","text":"]."}],"url":"\/documentation\/gio\/simpleactionref","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimpleActionRef","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SimpleActionRef","kind":"identifier"}]}}}