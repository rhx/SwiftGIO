{"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"text":" ","type":"text"},{"type":"text","text":"its value set through "},{"code":"g_object_set_property()","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"text":", et al.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyState","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:3GIO15SimpleActionRefV","text":"SimpleActionRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef"},{"text":", ","kind":"text"},{"text":"ParamSpecRef","preciseIdentifier":"s:10GLibObject12ParamSpecRefV","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}]},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The signal handler to call"},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"notifyState"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}],"na