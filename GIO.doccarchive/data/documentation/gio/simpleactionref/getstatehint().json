{"abstract":[{"text":"Requests a hint about the valid range of values for the state of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"action"},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef","doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef\/ActionProtocol-Implementations"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getStateHint","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"!"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" is returned it either means that the action is not stateful"},{"type":"text","text":" "},{"type":"text","text":"or that there is no hint about the valid range of values for the"},{"type":"text","text":" "},{"type":"text","text":"state of the action."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a"},{"type":"text","text":" "},{"text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned then the tuple specifies the inclusive lower and upper bound"},{"text":" ","type":"text"},{"text":"of valid values for the state.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In any case, the information is merely a hint.  It may be possible to"},{"text":" ","type":"text"},{"type":"text","text":"have a state value outside of the hinted range and setting a value"},{"type":"text","text":" "},{"type":"text","text":"within the range may fail."}]},{"inlineContent":[{"type":"text","text":"The return value (if non-"},{"type":"codeVoice","code":"NULL"},{"text":") should be freed with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"type":"text","text":"] when it is no longer required."}],"type":"paragraph"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/simpleactionref\/getstatehint()"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SimpleActionRef\/getStateHint()"},"metadata":{"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getStateHint","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"externalID":"s:3GIO14ActionProtocolPAAE12getStateHint4GLib10VariantRefVSgyF::SYNTHESIZED::s:3GIO15SimpleActionRefV","role":"symbol","title":"getStateHint()","roleHeading":"Instance Method","extendedModule":"GIO","modules":[{"name":"GIO"}]},"references":{"doc://GIO/documentation/GIO/SimpleActionRef/getStateHint()":{"abstract":[{"text":"Requests a hint about the valid range of values for the state of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"action"},{"type":"text","text":"."}],"url":"\/documentation\/gio\/simpleactionref\/getstatehint()","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getStateHint"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"type":"topic","title":"getStateHint()","identifier":"doc:\