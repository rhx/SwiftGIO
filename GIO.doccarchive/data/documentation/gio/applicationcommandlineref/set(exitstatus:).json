{"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationcommandlineref\/set(exitstatus:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/set(exitStatus:)"},"metadata":{"modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"exitStatus"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"externalID":"s:3GIO30ApplicationCommandLineProtocolPAAE3set10exitStatusySi_tF::SYNTHESIZED::s:3GIO25ApplicationCommandLineRefV","symbolKind":"method","roleHeading":"Instance Method","role":"symbol","extendedModule":"GIO","title":"set(exitStatus:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/ApplicationCommandLineProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"exitStatus","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":")"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"The return value of the [Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:) signal is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"passed to this function when the handler returns.  This is the usual"},{"text":" ","type":"text"},{"type":"text","text":"way of setting the exit status."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that you want the remote invocation to continue running"},{"text":" ","type":"text"},{"text":"and want to decide on the exit status in the future, you can use this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call.  For the case of a remote invocation, the remote process will"},{"type":"text","text":" "},{"type":"text","text":"typically exit when the last reference is dropped on "},{"type":"codeVoice","code":"cmdline"},{"text":".  The","type":"text"},{"text":" ","type":"text"},{"text":"exit status of the remote process will be equal to the last value","type":"text"},{"text":" ","type":"text"},{"text":"that was set with this function.","type":"text"}]},{"inlineContent":[{"text":"In the case that the commandline invocation is local, the situation","type":"text"},{"type":"text","text":" "},{"text":"is slightly more complicated.  If the commandline invocation results","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the mainloop running (ie: because the use-count of the application"},{"text":" ","type":"text"},{"type":"text","text":"increased to a non-zero value) then the application is considered to"},{"text":" ","type":"text"},{"text":"have been ‘successful’ in a certain sense, and the exit status is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"always zero.  If the application use count is zero, though, the exit"},{"type":"text","text":" "},{"type":"text","text":"status of the local "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","isActive":true},{"text":" is used.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This method is a no-op if ","type":"text"},{"code":"g_application_command_line_done()","type":"codeVoice"},{"type":"text","text":" has"},{"text":" ","type":"text"},{"type":"text","text":"been called."}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Sets the exit status that will be used when the invoking process"},{"type":"text","text":" "},{"type":"text","text":"exits."}],"references":{"doc://GIO/documentation/GIO/ApplicationCommandLineRef/ApplicationCommandLineProtocol-Implementations":{"title":"ApplicationCommandLineProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/ApplicationCommandLineProtocol-Implementations","url":"\/documentation\/gio\/applicationcommandlineref\/applicationcommandlineprotocol-implementations","type":"topic","kind":"article","role":"collectionGroup","abstract":[]},"doc://GIO/documentation/GIO/ApplicationCommandLineRef/set(exitStatus:)":{"url":"\/documentation\/gio\/applicationcommandlineref\/set(exitstatus:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"exitStatus"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":")"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/set(exitStatus:)","role":"symbol","title":"set(exitStatus:)","type":"topic","kind":"symbol","abstract":[{"text":"Sets the exit status that will be used when the invoking process","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"exits."}]},"doc://GIO/documentation/GIO/ApplicationCommandLineRef":{"title":"ApplicationCommandLineRef","kind":"symbol","url":"\/documentation\/gio\/applicationcommandlineref","abstract":[{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" represents a command-line invocation of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"an application."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ApplicationCommandLineRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef","role":"symbol","navigatorTitle":[{"text":"ApplicationCommandLineRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/ApplicationCommandLine":{"title":"ApplicationCommandLine","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApplicationCommandLine","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"ApplicationCommandLine"}],"url":"\/documentation\/gio\/applicationcommandline","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","abstract":[{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" represents a command-line invocation of","type":"text"},{"type":"text","text":" "},{"text":"an application.","type":"text"}],"role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}