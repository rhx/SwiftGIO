{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Queries the type of the state of "},{"code":"action","type":"codeVoice"},{"type":"text","text":"."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Action","doc:\/\/GIO\/documentation\/GIO\/Action\/ActionProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getStateType"},{"kind":"text","text":"() -> "},{"text":"VariantTypeRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14VariantTypeRefV"},{"kind":"text","text":"!"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the action is stateful (e.g. created with"},{"type":"text","text":" "},{"text":"[ctor","type":"text"},{"code":"Gio.SimpleAction.new_stateful","type":"codeVoice"},{"text":"]) then this function returns the","type":"text"},{"type":"text","text":" "},{"text":"[type[VariantType](\/\/documentation\/glib\/varianttype] of the state.  This is the type of the initial value","type":"text"},{"type":"text","text":" "},{"text":"given as the state. All calls to [method","type":"text"},{"type":"codeVoice","code":"Gio.Action.change_state"},{"text":"] must give a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[type[Variant](\/\/documentation\/glib\/variant] of this type and [method"},{"code":"Gio.Action.get_state","type":"codeVoice"},{"type":"text","text":"] will return a"},{"type":"text","text":" "},{"text":"[type[Variant](\/\/documentation\/glib\/variant] of the same type.","type":"text"}]},{"inlineContent":[{"text":"If the action is not stateful (e.g. created with [ctor","type":"text"},{"code":"Gio.SimpleAction.new","type":"codeVoice"},{"type":"text","text":"])"},{"type":"text","text":" "},{"type":"text","text":"then this function will return "},{"code":"NULL","type":"codeVoice"},{"text":". In that case, [method","type":"text"},{"code":"Gio.Action.get_state","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"will return "},{"type":"codeVoice","code":"NULL"},{"text":" and you must not call [method","type":"text"},{"type":"codeVoice","code":"Gio.Action.change_state"},{"type":"text","text":"]."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/action\/getstatetype()"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Action\/getStateType()","interfaceLanguage":"swift"},"metadata":{"title":"getStateType()","roleHeading":"Instance Method","role":"symbol","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","externalID":"s:3GIO14ActionProtocolPAAE12getStateType4GLib07VariantF3RefVSgyF::SYNTHESIZED::s:3GIO6ActionC","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getStateType"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib14VariantTypeRefV","text":"VariantTypeRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}]},"references":{"doc://GIO/documentation/GIO/Action/ActionProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action\/ActionProtocol-Implementations","url":"\/documentation\/gio\/action\/actionprotocol-implementations","title":"ActionProtocol Implementations","type":"topic","role":"collectionGroup","kind":"article","abstract":[]},"doc://GIO/documentation/GIO/Action/getStateType()":{"url":"\/documentation\/gio\/action\/getstatetype()","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Queries the type of the state of "},{"code":"action","type":"codeVoice"},{"type":"text","text":"."}],"title":"getStateType()","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action\/get