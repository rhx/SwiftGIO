{"metadata":{"extendedModule":"GIO","externalID":"s:3GIO14ActionProtocolPAAE9stateHint4GLib10VariantRefVSgvp::SYNTHESIZED::s:3GIO6ActionC","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"stateHint","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"kind":"text","text":"!"}],"roleHeading":"Instance Property","modules":[{"name":"GIO"}],"role":"symbol","title":"stateHint"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"stateHint"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"! { "},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":" is returned it either means that the action is not stateful","type":"text"},{"type":"text","text":" "},{"text":"or that there is no hint about the valid range of values for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state of the action."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a"},{"type":"text","text":" "},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"type":"text","text":" "},{"type":"text","text":"returned then the tuple specifies the inclusive lower and upper bound"},{"text":" ","type":"text"},{"type":"text","text":"of valid values for the state."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In any case, the information is merely a hint.  It may be possible to"},{"text":" ","type":"text"},{"text":"have a state value outside of the hinted range and setting a value","type":"text"},{"text":" ","type":"text"},{"text":"within the range may fail.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The return value (if non-","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":") should be freed with"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"type":"text","text":"] when it is no longer required."}]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/action\/statehint"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Action","doc:\/\/GIO\/documentation\/GIO\/Action\/ActionProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of"},{"text":" ","type":"text"},{"type":"codeVoice","code":"action"},{"type":"text","text":"."}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/Action\/stateHint"},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GIO/documentation/GIO/Action/stateHint":{"title":"stateHint","url":"\/documentation\/gio\/action\/statehint","kind":"symbol","abstract":[{"text":"Requests a hint about the valid range of values for the state of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"action"},{"type":"text","text":"."}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"stateHint","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action\/stateHint","role":"symbol"},"doc://