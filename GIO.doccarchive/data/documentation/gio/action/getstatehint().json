{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Action\/getStateHint()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Requests a hint about the valid range of values for the state of"},{"type":"text","text":" "},{"type":"codeVoice","code":"action"},{"text":".","type":"text"}],"metadata":{"extendedModule":"GIO","externalID":"s:3GIO14ActionProtocolPAAE12getStateHint4GLib10VariantRefVSgyF::SYNTHESIZED::s:3GIO6ActionC","symbolKind":"method","modules":[{"name":"GIO"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getStateHint"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"roleHeading":"Instance Method","role":"symbol","title":"getStateHint()"},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/action\/getstatehint()"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/Action","doc:\/\/GIO\/documentation\/GIO\/Action\/ActionProtocol-Implementations"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getStateHint"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":" is returned it either means that the action is not stateful","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or that there is no hint about the valid range of values for the"},{"type":"text","text":" "},{"type":"text","text":"state of the action."}]},{"inlineContent":[{"text":"If a [type[Variant](\/\/documentation\/glib\/variant] array is returned then each item in the array is a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"possible value for the state.  If a [type[Variant](\/\/documentation\/glib\/variant] pair (ie: two-tuple) is"},{"type":"text","text":" "},{"text":"returned then the tuple specifies the inclusive lower and upper bound","type":"text"},{"type":"text","text":" "},{"text":"of valid values for the state.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In any case, the information is merely a hint.  It may be possible to"},{"type":"text","text":" "},{"text":"have a state value outside of the hinted range and setting a value","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within the range may fail."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The return value (if non-"},{"type":"codeVoice","code":"NULL"},{"text":") should be freed with","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"text":"] when it is no longer required.","type":"text"}]}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/Action":{"url":"\/documentation\/gio\/action","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action"}],"navigatorTitle":[{"text":"Action","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","title":"Action","role":"symbol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/Action/ActionProtocol-Impleme