{"kind":"symbol","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"text":" ","type":"text"},{"text":"close the individual input and output streams, if they are not already","type":"text"},{"type":"text","text":" "},{"text":"closed.","type":"text"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/close(cancellable:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/IOStreamProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return"},{"type":"text","text":" "},{"type":"codeVoice","code":"closed"},{"type":"text","text":". Closing a stream multiple times will not"},{"text":" ","type":"text"},{"text":"return an error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers"},{"type":"text","text":" "},{"text":"in the stream.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is dropped, but you might want to call this function to make sure"},{"text":" ","type":"text"},{"text":"resources are released as early as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file"},{"text":" ","type":"text"},{"type":"text","text":"descriptor) open after the stream is closed. See the documentation for"},{"type":"text","text":" "},{"type":"text","text":"the individual stream for details."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the"},{"type":"text","text":" "},{"type":"text","text":"close operation will finish as much as possible. A stream that failed"},{"text":" ","type":"text"},{"text":"to close will still return ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":" for all operations."},{"text":" ","type":"text"},{"type":"text","text":"Still, it is important to check and report the error to the user,"},{"text":" ","type":"text"},{"text":"otherwise there might be a loss of data as all data might not be written.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not NULL, then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"text":"Cancelling a close will still leave the stream closed, but some streams","type":"text"},{"text":" ","type":"text"},{"text":"can use a faster close that doesn’t block to e.g. check errors.","type":"text"}]},{"inlineContent":[{"text":"The default implementation of this method just calls close on the","type":"text"},{"type":"text","text":" "},{"text":"individual input\/output streams.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsserverconnectionref\/close(cancellable:)"]}],"metadata":{"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO22TLSServerConnectionRefV","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","title":"close(cancellable:)","extendedModule":"GIO","role":"symbol"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/TLSServerConnectionRef/close(cancellable:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/close(cancellable:)","role":"symbol","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"type":"text","text":" "},{"text":"close the individual input and output streams, if they are not already","type":"text"},{"type":"text","text":" "},{"type":"text","text":"closed."}],"type":"topic","kind":"symbol","url":"\/documentation\/gio\/tlsserverconnectionref\/close(cancellable:)","title":"close(cancellable:)"},"doc://GIO/documentation/GIO/TLSServerConnectionRef/IOStreamProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/IOStreamProtocol-Implementations","url":"\/documentation\/gio\/tlsserverconnectionref\/iostreamprotocol-implementations","abstract":[],"title":"IOStreamProtocol Implementations","type":"topic","role":"collectionGroup","kind":"article"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSServerConnectionRef":{"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"text":" is the server-side subclass of","type":"text"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","type":"reference","isActive":true},{"type":"text","text":"], representing a server-side TLS connection."}],"title":"TLSServerConnectionRef","type":"topic","kind":"symbol","url":"\/documentation\/gio\/tlsserverconnectionref","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSServerConnectionRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"TLSServerConnectionRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef"}}}