{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/TLSConnectionProtocol-Implementations"]]},"sections":[],"variants":[{"paths":["\/documentation\/gio\/tlsserverconnectionref\/onacceptcertificate(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Emitted during the TLS handshake after the peer certificate has"},{"type":"text","text":" "},{"text":"been received. You can examine ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"text":"’s certification path by","type":"text"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"g_tls_certificate_get_issuer()"},{"text":" on it.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"externalID":"s:3GIO21TLSConnectionProtocolPAAE19onAcceptCertificate5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0B3RefV_AA014TLSCertificateM0VAA0nL0VtctF::SYNTHESIZED::s:3GIO22TLSServerConnectionRefV","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"title":"onAcceptCertificate(flags:handler:)","symbolKind":"method","role":"symbol","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onAcceptCertificate","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO16TLSConnectionRefV","text":"TLSConnectionRef"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSCertificateRefV","text":"TLSCertificateRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","text":"TLSCertificateFlags","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/onAcceptCertificate(flags:handler:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onAcceptCertificate","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"text":" (","kind":"text"},{"kind":"typeIdentifier","text":"TLSConnectionRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"kind":"text","text":", "},{"text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef"},{"kind":"text","text":", "},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","text":"TLSCertificateFlags","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"platforms":["macOS"],"languages":["swift"]}]},{"parameters":[{"content":[{"inlineContent":[{"text":"Flags","type":"text"}],"type":"paragraph"}],"name":"flags"},{"content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" to accept "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" (which will also immediately end the signal emission). "},{"code":"false","type":"codeVoice"},{"type":"text","text":" to allow the signal emission to continue, which will cause the handshake to fail if no one else overrides it."},{"type":"text","text":" "},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"acceptCertificate"},{"text":" signal is emitted","type":"text"}]}],"name":"handler"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a client-side connection, "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" is the server’s"},{"type":"text","text":" "},{"text":"certificate, and the signal will only be emitted if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"certificate was not acceptable according to "},{"type":"codeVoice","code":"conn"},{"type":"text","text":"’s"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection"},{"type":"text","text":". If you would like the"},{"text":" ","type":"text"},{"type":"text","text":"certificate to be accepted despite "},{"type":"codeVoice","code":"errors"},{"type":"text","text":", return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the"},{"text":" ","type":"text"},{"type":"text","text":"signal handler. Otherwise, if no handler accepts the certificate,"},{"type":"text","text":" "},{"type":"text","text":"the handshake will fail with "},{"code":"badCertificate","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"GLib guarantees that if certificate verification fails, this signal","type":"text"},{"type":"text","text":" "},{"text":"will be emitted with at least one error will be set in ","type":"text"},{"code":"errors","type":"codeVoice"},{"type":"text","text":", but"},{"type":"text","text":" "},{"type":"text","text":"it does not guarantee that all possible errors will be set."},{"type":"text","text":" "},{"text":"Accordingly, you may not safely decide to ignore any particular","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"text":" ","type":"text"},{"type":"codeVoice","code":"expired"},{"type":"text","text":" if you want to allow expired"},{"type":"text","text":" "},{"text":"certificates, because this could potentially be the only error flag","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"set even if other problems exist with the certificate."}]},{"type":"paragraph","inlineContent":[{"text":"For a server-side connection, ","type":"text"},{"type":"codeVoice","code":"peerCert"},{"text":" is the certificate","type":"text"},{"text":" ","type":"text"},{"text":"presented by the client, if this was requested via the server’s","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true},{"text":". On the server side,","type":"text"},{"type":"text","text":" "},{"text":"the signal is always emitted when the client presents a","type":"text"},{"text":" ","type":"text"},{"text":"certificate, and the certificate will only be accepted if a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handler returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Note that if this signal is emitted as part of asynchronous I\/O","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in the main thread, then you should not attempt to interact with"},{"type":"text","text":" "},{"text":"the user before returning from the signal handler. If you want to","type":"text"},{"text":" ","type":"text"},{"text":"let the user decide whether or not to accept the certificate, you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"would have to return "},{"type":"codeVoice","code":"false"},{"text":" from the signal handler on the first","type":"text"},{"type":"text","text":" "},{"type":"text","text":"attempt, and then after the connection attempt returns a"},{"text":" ","type":"text"},{"code":"badCertificate","type":"codeVoice"},{"text":", you can interact with the user, and","type":"text"},{"text":" ","type":"text"},{"text":"if the user decides to accept the certificate, remember that fact,","type":"text"},{"text":" ","type":"text"},{"text":"create a new connection, and return ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" from the signal handler"},{"type":"text","text":" "},{"type":"text","text":"the next time."}]},{"inlineContent":[{"text":"If you are doing I\/O in another thread, you do not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"need to worry about this, and can simply block in the signal"},{"text":" ","type":"text"},{"type":"text","text":"handler until the UI thread returns an answer."}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"code":"accept-certificate","type":"codeVoice"},{"text":" signal","type":"text"}],"type":"paragraph"}]}]}],"references":{"doc://GIO/documentation/GIO/TLSCertificateRef":{"abstract":[{"text":"A certificate used for TLS authentication and encryption.","type":"text"},{"text":" ","type":"text"},{"text":"This can represent either a certificate only (eg, the certificate","type":"text"},{"type":"text","text":" "},{"text":"received by a client from a server), or the combination of","type":"text"},{"type":"text","text":" "},{"text":"a certificate and a private key (which is needed when acting as a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference"},{"type":"text","text":"])."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateRef"}],"title":"TLSCertificateRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TLSCertificateRef","kind":"identifier"}],"url":"\/documentation\/gio\/tlscertificateref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef"},"doc://GIO/documentation/GIO/TLSCertificateFlags":{"url":"\/documentation\/gio\/tlscertificateflags","abstract":[{"type":"text","text":"A set of flags describing TLS certification validation. This can be"},{"type":"text","text":" "},{"type":"text","text":"used to describe why a particular certificate was rejected (for"},{"type":"text","text":" "},{"text":"example, in ","type":"text"},{"type":"reference","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","isActive":true},{"text":".","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSCertificateFlags","kind":"identifier"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateFlags"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","title":"TLSCertificateFlags","kind":"symbol"},"//documentation/gio/tlsconnection/onacceptcertificate(flags:handler:)":{"type":"link","title":"TLSConnection","identifier":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)","titleInlineContent":[{"text":"TLSConnection","type":"text"}],"url":"\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)"},"doc://GIO/documentation/GIO/TLSServerConnectionRef":{"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"text":" is the server-side subclass of","type":"text"},{"type":"text","text":" "},{"text":