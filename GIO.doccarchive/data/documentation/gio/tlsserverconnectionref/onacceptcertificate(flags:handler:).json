n\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSConnectionRef":{"type":"topic","url":"\/documentation\/gio\/tlsconnectionref","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TLSConnectionRef"}],"abstract":[{"type":"codeVoice","code":"GTlsConnection"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"type":"text","text":" "},{"text":"a [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"type":"text","text":"] and provides TLS encryption on top of it. Its"},{"type":"text","text":" "},{"text":"subclasses, [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true,"type":"reference"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference","isActive":true},{"type":"text","text":"], implement client-side and server-side TLS,"},{"text":" ","type":"text"},{"type":"text","text":"respectively."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","title":"TLSConnectionRef","navigatorTitle":[{"text":"TLSConnectionRef","kind