{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/set(requireCloseNotify:)"},"abstract":[{"type":"text","text":"Sets whether or not "},{"code":"conn","type":"codeVoice"},{"text":" expects a proper TLS close notification","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"before the connection is closed. If this is "},{"code":"true","type":"codeVoice"},{"text":" (the default),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then "},{"type":"codeVoice","code":"conn"},{"text":" will expect to receive a TLS close notification from its","type":"text"},{"type":"text","text":" "},{"text":"peer before the connection is closed, and will return a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"eof"},{"type":"text","text":" error if the connection is closed without proper"},{"text":" ","type":"text"},{"text":"notification (since this may indicate a network error, or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"man-in-the-middle attack)."}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsserverconnectionref\/set(requireclosenotify:)"]}],"metadata":{"externalID":"s:3GIO21TLSConnectionProtocolPAAE3set18requireCloseNotifyySb_tF::SYNTHESIZED::s:3GIO22TLSServerConnectionRefV","role":"symbol","title":"set(requireCloseNotify:)","roleHeading":"Instance Method","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"set"},{"kind":"text","text":"("},{"text":"requireCloseNotify","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}]},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/TLSConnectionProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"requireCloseNotify","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"In some protocols, the application will know whether or not the"},{"text":" ","type":"text"},{"text":"connection was closed cleanly based on application-level data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(because the application-level data includes a length field, or is"},{"type":"text","text":" "},{"type":"text","text":"somehow self-delimiting); in this case, the close notify is"},{"text":" ","type":"text"},{"type":"text","text":"redundant and sometimes omitted. (TLS 1.1 explicitly allows this;"},{"type":"text","text":" "},{"type":"text","text":"in TLS 1.0 it is technically an error, but often done anyway.) You"},{"type":"text","text":" "},{"text":"can use ","type":"text"},{"type":"codeVoice","code":"g_tls_connection_set_require_close_notify()"},{"text":" to tell ","type":"text"},{"code":"conn","type":"codeVoice"},{"type":"text","text":" "},{"text":"to allow an “unannounced” connection close, in which case the close","type":"text"},{"text":" ","type":"text"},{"text":"will show up as a 0-length read, as in a non-TLS","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","type":"reference","isActive":true},{"type":"text","text":", and it is up to the application to check that"},{"type":"text","text":" "},{"text":"the data has been fully received.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that this only affects the behavior when the peer closes the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"connection; when the application calls "},{"code":"g_io_stream_close()","type":"codeVoice"},{"type":"text","text":" itself"},{"type":"text","text":" "},{"text":"on ","type":"text"},{"type":"codeVoice","code":"conn"},{"text":", this will send a close notification regardless of the","type":"text"},{"type":"text","text":" "},{"text":"setting of this property. If you explicitly want to do an unclean","type":"text"},{"type":"text","text":" "},{"type":"text","text":"close, you can close "},{"code":"conn","type":"codeVoice"},{"text":"’s ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":" rather","type":"text"},{"type":"text","text":" "},{"text":"than closing ","type":"text"},{"type":"codeVoice","code":"conn"},{"text":" itself, but note that this may only be done when no other","type":"text"},{"type":"text","text":" "},{"text":"operations are pending on ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":" or the base I\/O stream."}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSServerConnectionRef":{"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"text":" is the server-side subclass of","type":"text"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","type":"reference","isActive":true},{"type":"text","text":"], representing a server-side TLS connection."}],"title":"TLSServerConnectionRef","type":"topic","kind":"symbol","url":"\/documentation\/gio\/tlsserverconnectionref","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSServerConnectionRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"TLSServerConnectionRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef"},"doc://GIO/documentation/GIO/SocketListener":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"topic","url":"\/documentation\/gio\/socketlistener","kind":"symbol","abstract":[{"type":"text","text":"A "},{"code":"GSocketListener","type":"codeVoice"},{"text":" is an object that keeps track of a set","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of server sockets and helps you accept sockets from any of the"},{"text":" ","type":"text"},{"type":"text","text":"socket, either sync or async."}],"title":"SocketListener","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"SocketListener"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SocketListener"}]},"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a server-side TLS connection.","type":"text"}]},"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"id