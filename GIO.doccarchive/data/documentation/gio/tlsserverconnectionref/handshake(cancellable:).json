{"metadata":{"modules":[{"name":"GIO"}],"externalID":"s:3GIO21TLSConnectionProtocolPAAE9handshake11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO22TLSServerConnectionRefV","role":"symbol","extendedModule":"GIO","title":"handshake(cancellable:)","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"handshake","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"symbolKind":"method"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/handshake(cancellable:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsserverconnectionref\/handshake(cancellable:)"]}],"sections":[],"abstract":[{"type":"text","text":"Attempts a TLS handshake on "},{"code":"conn","type":"codeVoice"},{"text":".","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/TLSConnectionProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"handshake"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On the client side, it is never necessary to call this method;"},{"type":"text","text":" "},{"text":"although the connection needs to perform a handshake after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"connecting (or after sending a “STARTTLS”-type command),"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" will handle this for you automatically when you try"},{"text":" ","type":"text"},{"type":"text","text":"to send or receive data on the connection. You can call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" manually if you want to know whether"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake succeeded or failed (as opposed to just"},{"type":"text","text":" "},{"type":"text","text":"immediately trying to use "},{"code":"conn","type":"codeVoice"},{"type":"text","text":" to read or write, in which case,"},{"type":"text","text":" "},{"type":"text","text":"if it fails, it may not be possible to tell if it failed before or"},{"type":"text","text":" "},{"type":"text","text":"after completing the handshake), but beware that servers may reject"},{"text":" ","type":"text"},{"type":"text","text":"client authentication after the handshake has completed, so a"},{"text":" ","type":"text"},{"type":"text","text":"successful handshake does not indicate the connection will be usable."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Likewise, on the server side, although a handshake is necessary at"},{"type":"text","text":" "},{"text":"the beginning of the communication, you do not need to call this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"function explicitly unless you want clearer error reporting."}]},{"inlineContent":[{"text":"Previously, calling ","type":"text"},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" after the initial"},{"type":"text","text":" "},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"text":" ","type":"text"},{"type":"text","text":"deprecated in GLib 2.60 because rehandshaking was removed from the"},{"type":"text","text":" "},{"text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake will no longer do anything."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using a "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"type":"text","text":" created by "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true},{"type":"text","text":", the"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true},{"type":"text","text":" performs the initial handshake, so calling this"},{"type":"text","text":" "},{"text":"function manually is not recommended.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the"},{"type":"text","text":" "},{"text":"handshake.","type":"text"}]}],"kind":"content"}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection","kind":"identifier"}],"abstract":[{"code":"GTlsServerConnection","type":"codeVoice"},{"type":"text","text":" is the server-side subclass of"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a server-side TLS connection.","type":"text"}]},"doc://GIO/documentation/GIO/IOStream":{"url":"\/documentation\/gio\/iostream","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","title":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSServerConnectionRef/TLSConnectionProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnectionRef\/TLSConnectionProtocol-Implementations","kind":"article","abstract":[],"url":"\/documentation\/gio\/tlsserverconnectionref\/tlsconnectionprotocol-implementations","role":"collectionGroup","type":"topic","title":"TLSConnecti