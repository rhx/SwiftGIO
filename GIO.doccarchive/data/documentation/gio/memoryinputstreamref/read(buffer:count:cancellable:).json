{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef\/InputStreamProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"read"},{"kind":"text","text":"("},{"text":"buffer","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If count is zero returns zero and does nothing. A value of "},{"type":"codeVoice","code":"count"},{"type":"text","text":" "},{"text":"larger than ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"text":" will cause a ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"On success, the number of bytes read into the buffer is returned.","type":"text"},{"type":"text","text":" "},{"text":"It is not an error if this is not the same as the requested size, as it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can happen e.g. near the end of a file. Zero is returned on end of file"},{"type":"text","text":" "},{"text":"(or if ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" is zero),  but never otherwise.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The returned "},{"code":"buffer","type":"codeVoice"},{"text":" is not a nul-terminated string, it can contain nul bytes","type":"text"},{"text":" ","type":"text"},{"text":"at any position, and this function doesn’t nul-terminate the ","type":"text"},{"type":"codeVoice","code":"buffer"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"text":" will be returned. If an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"text":"partial result will be returned, without an error.","type":"text"}]},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/memoryinputstreamref\/read(buffer:count:cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Tries to read "},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from the stream into the buffer starting at"},{"type":"text","text":" "},{"code":"buffer","type":"codeVoice"},{"text":