{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Closing a stream multiple times will not return an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"text":" ","type":"text"},{"type":"text","text":"open after the stream is closed. See the documentation for the individual"},{"type":"text","text":" "},{"text":"stream for details.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations. Still, it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important to check and report the error to the user."}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"type":"text","text":" is not "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"type":"text","text":" "},{"text":"can use a faster close that doesn’t block to e.g. check errors.","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/memoryinputstreamref\/close(cancellable:)"]}],"sections":[],"kind":"symbol","metadata":{"roleHeading":"Instance Method","externalID":"s:3GIO19InputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO20MemoryInputStreamRefV","symbolKind":"method","role":"symbol","modules":[{"name":"GIO"}],"title":"close(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"extendedModule":"GIO"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef","doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef\/InputStreamProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/MemoryInputStreamRef":{"url":"\/documentation\/gio\/memoryinputstreamref","title":"MemoryInputStreamRef","abstract":[{"type":"codeVoice","code":"GMemoryInputStream"},{"text":" is a class for using arbitrary","type":"text"},{"type":"text","text":" "},{"text":"memory chunks as input for GIO streaming input operations.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"MemoryInputStreamRef","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef","navigatorTitle":[{"kind":"identifier","text":"MemoryInputStreamRef"}],"kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/MemoryInputStreamRef/InputStreamProtocol-Implementations":{"url":"\/documentation\/gio\/memoryinputstreamref\/inputstreamprotocol-implementations","kind":"article","title":"InputStreamProtocol Implementations","abstract":[],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef\/InputStreamProtocol-Implementations"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MemoryInputStreamRef/close(cancellable:)":{"type":"topic","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef\/close(cancellable:)","role":"symbol","url":"\/documentation\/gio\/memoryinputstreamref\/close(cancellable:)","title":"close(cancellable:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"}}}