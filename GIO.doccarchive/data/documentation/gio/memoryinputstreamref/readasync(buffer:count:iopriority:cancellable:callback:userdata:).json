","text":"be executed before an outstanding request with lower priority. Default"},{"type":"text","text":" "},{"type":"text","text":"priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}]},{"type":"paragraph","inlineContent":[{"text":"The asynchronous methods have a default fallback that uses threads to implement","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"asynchronicity, so they are optional for inheriting classes. However, if you"},{"text":" ","type":"text"},{"type":"text","text":"override one you must override all."}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/MemoryInputStreamRef/InputStreamProtocol-Implementations":{"url":"\/documentation\/gio\/memoryinputstreamref\/inputstreamprotocol-implementations","kind":"article","title":"InputStreamProtocol Implementations","abstract":[],"type":"topic","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef\/InputStreamProtocol-Implementations"},"doc://GIO/documentation/GIO/MemoryInputStreamRef/readAsync(buffer:count:ioPriority:cancellable:callback:userData:)":{"url":"\/documentation\/gio\/memoryinputstreamref\/readasync(buffer:count:iopriority:cancellable:callback:userdata:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/MemoryInputStreamRef\/readAsync(buffer:count:ioPriority:cancellable:callback:userData:)","type":"topic","title":"readAsync(buffer:count:ioPriority:cancellable:callback:userData:)",