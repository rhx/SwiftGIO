{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"run","kind":"identifier"},{"text":"(","kind":"text"},{"text":"argc","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"argv","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"CChar","preciseIdentifier":"s:s5CChara","kind":"typeIdentifier"},{"text":">?>! = nil) -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This function is intended to be run from ","type":"text"},{"code":"main()","type":"codeVoice"},{"text":" and its return value","type":"text"},{"text":" ","type":"text"},{"text":"is intended to be returned by ","type":"text"},{"code":"main()","type":"codeVoice"},{"text":". Although you are expected to pass","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"argc"},{"type":"text","text":", "},{"type":"codeVoice","code":"argv"},{"type":"text","text":" parameters from "},{"code":"main()","type":"codeVoice"},{"text":" to this function, it is possible","type":"text"},{"text":" ","type":"text"},{"text":"to pass ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if "},{"type":"codeVoice","code":"argv"},{"type":"text","text":" is not available or commandline handling is not"},{"type":"text","text":" "},{"type":"text","text":"required.  Note that on Windows, "},{"type":"codeVoice","code":"argc"},{"text":" and ","type":"text"},{"code":"argv","type":"codeVoice"},{"type":"text","text":" are ignored, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_win32_get_command_line()"},{"type":"text","text":" is called internally (for proper support"},{"type":"text","text":" "},{"text":"of Unicode commandline arguments).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","isActive":true},{"text":" will attempt to parse the commandline arguments.  You","type":"text"},{"text":" ","type":"text"},{"text":"can add commandline flags to the list of recognised options by way of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_application_add_main_option_entries()"},{"type":"text","text":".  After this, the"},{"type":"text","text":" "},{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) signal is emitted, from which the"},{"text":" ","type":"text"},{"type":"text","text":"application can inspect the values of its "},{"type":"codeVoice","code":"GOptionEntrys"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) is a good place to handle options"},{"type":"text","text":" "},{"text":"such as ","type":"text"},{"type":"codeVoice","code":"--version"},{"type":"text","text":", where an immediate reply from the local process is"},{"type":"text","text":" "},{"type":"text","text":"desired (instead of communicating with an already-running instance)."},{"type":"text","text":" "},{"type":"text","text":"A [Application](\/\/documentation\/gio\/application\/onhandlelocaloptions(flags:handler:) handler can stop further processing"},{"text":" ","type":"text"},{"type":"text","text":"by returning a non-negative value, which then becomes the exit status of"},{"text":" ","type":"text"},{"text":"the process.","type":"text"}]},{"inlineContent":[{"type":"text","text":"What happens next depends on the flags: if"},{"text":" ","type":"text"},{"type":"codeVoice","code":"handlesCommandLine"},{"type":"text","text":" was specified then the remaining"},{"text":" ","type":"text"},{"type":"text","text":"commandline arguments are sent to the primary instance, where a"},{"text":" ","type":"text"},{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:) signal is emitted.  Otherwise, the"},{"type":"text","text":" "},{"type":"text","text":"remaining commandline arguments are assumed to be a list of files."},{"text":" ","type":"text"},{"type":"text","text":"If there are no files listed, the application is activated via the"},{"type":"text","text":" "},{"type":"text","text":"[Application](\/\/documentation\/gio\/application\/onactivate(flags:handler:) signal.  If there are one or more files, and"},{"type":"text","text":" "},{"type":"codeVoice","code":"handlesOpen"},{"type":"text","text":" was specified then the files are opened"},{"type":"text","text":" "},{"text":"via the [Application](\/\/documentation\/gio\/application\/onopen(flags:handler:) signal.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you are interested in doing more complicated local handling of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"commandline then you should implement your own "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","isActive":true,"type":"reference"},{"type":"text","text":" subclass"},{"type":"text","text":" "},{"text":"and override ","type":"text"},{"code":"local_command_line()","type":"codeVoice"},{"type":"text","text":". In this case, you most likely want"},{"text":" ","type":"text"},{"type":"text","text":"to return "},{"type":"codeVoice","code":"true"},{"text":" from your ","type":"text"},{"code":"local_command_line()","type":"codeVoice"},{"type":"text","text":" implementation to"},{"text":" ","type":"text"},{"type":"text","text":"suppress the default handling. See"},{"type":"text","text":" "},{"type":"reference","identifier":"#https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c","isActive":true},{"text":" ","type":"text"},{"text":"for an example.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If, after the above is done, the use count of the application is zero"},{"type":"text","text":" "},{"text":"then the exit status is returned immediately.  If the use count is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"non-zero then the default main context is iterated until the use count"},{"text":" ","type":"text"},{"text":"falls to zero, at which point 0 is returned.","type":"text"}]},{"inlineContent":[{"text":"If the ","type":"text"},{"type":"codeVoice","code":"isService"},{"type":"text","text":" flag is set, then the service will"},{"text":" ","type":"text"},{"type":"text","text":"run for as much as 10 seconds with a use count of zero while waiting"},{"text":" ","type":"text"},{"type":"text","text":"for the message that caused the activation to arrive.  After that,"},{"text":" ","type":"text"},{"type":"text","text":"if the use count falls to zero the application will exit immediately,"},{"type":"text","text":" "},{"text":"except in the case that ","type":"text"},{"type":"codeVoice","code":"g_application_set_inactivity_timeout()"},{"type":"text","text":" is in"},{"text":" ","type":"text"},{"text":"use.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function sets the prgname (","type":"text"},{"type":"codeVoice","code":"g_set_prgname()"},{"type":"text","text":"), if not already set,"},{"text":" ","type":"text"},{"text":"to the basename of argv[0].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Much like "},{"type":"codeVoice","code":"g_main_loop_run()"},{"text":", this function will acquire the main context","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for the duration that the application is running."}]},{"inlineContent":[{"text":"Since 2.40, applications that are not explicitly flagged as services","type":"text"},{"type":"text","text":" "},{"text":"or launchers (ie: neither ","type":"text"},{"type":"codeVoice","code":"isService"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"isLauncher"},{"text":" are given as flags) will check (from the","type":"text"},{"type":"text","text":" "},{"text":"default handler for local_command_line) if “–gapplication-service”","type":"text"},{"type":"text","text":" "},{"text":"was given in the command line.  If this flag is present then normal","type":"text"},{"text":" ","type":"text"},{"text":"commandline processing is interrupted and the","type":"text"},{"type":"text","text":" "},{"code":"isService","type":"codeVoice"},{"type":"text","text":" flag is set.  This provides a “compromise”"},{"type":"text","text":" "},{"text":"solution whereby running an application directly from the commandline","type":"text"},{"type":"text","text":" "},{"text":"will invoke it in the normal way (which can be useful for debugging)","type":"text"},{"type":"text","text":" "},{"type":"text","text":"while still allowing applications to be D-Bus activated in service"},{"type":"text","text":" "},{"type":"text","text":"mode.  The D-Bus service file should invoke the executable with"},{"text":" ","type":"text"},{"type":"text","text":"“–gapplication-service” as the sole commandline argument.  This"},{"type":"text","text":" "},{"type":"text","text":"approach is suitable for use by most graphical applications but"},{"text":" ","type":"text"},{"type":"text","text":"should not be used from applications like editors that need precise"},{"text":" ","type":"text"},{"type":"text","text":"control over when processes invoked via the commandline will exit and"},{"type":"text","text":" "},{"type":"text","text":"what their exit status will be."}],"type":"paragraph"}]}],"sections":[],"variants":[{"paths":["\/documentation\/gio\/applicationref\/run(argc:argv:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Runs the application.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/run(argc:argv:)"},"metadata":{"title":"run(argc:argv:)","modules":[{"name":"GIO"}],"externalID":"s:3GIO19ApplicationProtocolPAAE3run4argc4argvS2i_SpySpys4Int8VGSgGSgtF::SYNTHESIZED::s:3GIO14ApplicationRefV","extendedModule":"GIO","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"run"},{"kind":"text","text":"("},{"text":"argc","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"argv"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:s5CChara","text":"CChar","kind":"typeIdentifier"},{"kind":"text","text":">?>!) -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"role":"symbol","roleHeading":"Instance Method"},"references":{"doc://GIO/documentation/GIO/ApplicationRef/ApplicationProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations","url":"\/documentation\/gio\/applicationref\/applicationprotocol-implementations","type":"topic","title":"ApplicationProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ApplicationRef":{"type":"topic","navigatorTitle":[{"text":"ApplicationRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","url":"\/documentation\/gio\/applicationref","title":"ApplicationRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ApplicationRef"}],"abstract":[{"type":"codeVoice","code":"GApplication"},{"text":" is the core class for application support.","type":"text"}]},"doc://GIO/documentation/GIO/Application":{"navigatorTitle":[{"kind":"identifier","text":"Application"}],"title":"Application","abstract":[{"type":"codeVoice","code":"GApplication"},{"type":"text","text":" is the core class for application support."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Application","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","url":"\/documentation\/gio\/application"},"#https://gitlab.gnome.org/GNOME/glib/-/blob/HEAD/gio/tests/gapplication-example-cmdline2.c":{"titleInlineContent":[{"text":"gapplication-example-cmdline2.c","type":"text"}],"title":"gapplication-example-cmdline2.c","type":"link","url":"#https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c","identifier":"#https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c"},"doc://GIO/documentation/GIO/ApplicationRef/run(argc:argv:)":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/run(argc:argv:)","abstract":[{"type":"text","text":"Runs the application."}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"run","kind":"identifier"},{"kind":"text","text":"("},{"text":"argc","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"argv"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"CChar","kind":"typeIdentifier","preciseIdentifier":"s:s5CChara"},{"kind":"text","text":">?>!) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"type":"topic","kind":"symbol","title":"run(argc:argv:)","url":"\/documentation\/gio\/applicationref\/run(argc:argv:)"}}}