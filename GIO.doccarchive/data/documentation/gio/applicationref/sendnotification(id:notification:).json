{"abstract":[{"text":"Sends a notification on behalf of ","type":"text"},{"code":"application","type":"codeVoice"},{"text":" to the desktop shell.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"There is no guarantee that the notification is displayed immediately,"},{"type":"text","text":" "},{"type":"text","text":"or even at all."}],"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/sendNotification(id:notification:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationref\/sendnotification(id:notification:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sendNotification"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"NotificationT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"id"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">? = nil, "},{"text":"notification","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"NotificationT"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"text":"NotificationT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/NotificationProtocol","preciseIdentifier":"s:3GIO20NotificationProtocolP","kind":"typeIdentifier","text":"NotificationProtocol"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Notifications may persist after the application exits. It will be"},{"type":"text","text":" "},{"type":"text","text":"D-Bus-activated when the notification or one of its actions is"},{"type":"text","text":" "},{"type":"text","text":"activated."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Modifying ","type":"text"},{"type":"codeVoice","code":"notification"},{"text":" after this call has no effect. However, the","type":"text"},{"type":"text","text":" "},{"text":"object can be reused for a later call to this function.","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"id"},{"text":" may be any string that uniquely identifies the event for the","type":"text"},{"type":"text","text":" "},{"text":"application. It does not need to be in any special format. For","type":"text"},{"type":"text","text":" "},{"text":"example, “new-message” might be appropriate for a notification about","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"new messages."}],"type":"paragraph"},{"inlineContent":[{"text":"If a previous notification was sent with the same ","type":"text"},{"code":"id","type":"codeVoice"},{"type":"text","text":", it will be"},{"text":" ","type":"text"},{"type":"text","text":"replaced with "},{"type":"codeVoice","code":"notification"},{"text":" and shown again as if it was a new","type":"text"},{"type":"text","text":" "},{"type":"text","text":"notification. This works even for notifications sent from a previous"},{"type":"text","text":" "},{"type":"text","text":"execution of the application, as long as "},{"type":"codeVoice","code":"id"},{"type":"text","text":" is the same string."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"id"},{"text":" may be ","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":", but it is impossible to replace or withdraw"},{"type":"text","text":" "},{"text":"notifications without an id.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"notification","type":"codeVoice"},{"type":"text","text":" is no longer relevant, it can be withdrawn with"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.Application.withdraw_notification"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is an error to call this function if "},{"code":"application","type":"codeVoice"},{"type":"text","text":" has no"},{"type":"text","text":" "},{"type":"text","text":"application ID."}]}]}],"metadata":{"symbolKind":"method","title":"sendNotification(id:notification:)","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sendNotification"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"NotificationT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"id"},{"text":": ","kind":"text"},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?, "},{"kind":"externalParam","text":"notification"},{"text":": ","kind":"text"},{"text":"NotificationT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol","externalID":"s:3GIO19ApplicationProtocolPAAE16sendNotification2id12notificationySPys4Int8VGSg_qd__tAA0eC0Rd__lF::SYNTHESIZED::s:3GIO14ApplicationRefV","extendedModule":"GIO","modules":[{"name":"GIO"}]},"references":{"doc://GIO/documentation/GIO/ApplicationRef/sendNotification(id:notification:)":{"title":"sendNotification(id:notification:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/sendNotification(id:notification:)","abstract":[{"text":"Sends a notification on behalf of ","type":"text"},{"