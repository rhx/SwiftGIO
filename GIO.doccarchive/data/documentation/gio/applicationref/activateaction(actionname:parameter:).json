entifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"parameter"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If the action is expecting a parameter, then the correct type of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameter must be given as "},{"type":"codeVoice","code":"parameter"},{"text":".  If the action is expecting no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parameters then "},{"type":"codeVoice","code":"parameter"},{"text":" must be ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":".  See","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.ActionGroup.get_action_parameter_type","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the [type","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","isActive":true},{"type":"text","text":"] implementation supports asynchronous remote"},{"text":" ","type":"text"},{"type":"text","text":"activation over D-Bus, this call may return before the relevant"},{"type":"text","text":" "},{"text":"D-Bus traffic has been sent, or any replies have been received. In","type":"text"},{"type":"text","text":" "},{"text":"order to block on such asynchronous activation calls,","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.DBusConnection.flush","type":"codeVoice"},{"text":"] should be called prior to the code, which","type":"text"},{"type":"text","text":" "},{"text":"depends on the result of the action activation. Without flushing","type":"text"},{"text":" ","type":"text"},{"text":"the D-Bus connection, there is no guarantee that the action would","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have been activated."}]},{"inlineContent":[{"text":"The following code which runs in a remote app instance, shows an","type":"text"},{"text":" ","type":"text"},{"text":"example of a ‘quit’ action being activated on the primary app","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance over D-Bus. Here [method"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"type":"text","text":"] is called"},{"type":"text","text":" "},{"text":"before ","type":"text"},{"type":"codeVoice","code":"exit()"},{"type":"text","text":". Without "},{"type":"codeVoice","code":"g_dbus_connection_flush()"},{"text":", the ‘quit’ action","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"may fail to be activated on the primary instance."}],"type":"paragraph"},{"code":["\/\/ call ‘quit’ action on primary instance","g_action_group_activate_action (G_ACTION_GROUP (app), \"quit\", NULL);","","\/\/ make sure the action is activated now","g_dbus_connection_flush (…);","","g_debug (\"Application has been terminated. Exiting.\");","","exit (0);"],"syntax":"c","type":"codeListing"}]}],"references":{"doc://GIO/documentation/GIO/ApplicationRef":{"type":"topic","navigatorTitle":[{"text":"ApplicationRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","url":"\/documentation\/gio\/applicationref","title":"ApplicationRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ApplicationRef"}],"abstract":[{"type":"codeVoice","code":"GApplication"},{"text":" is the core class for application support.","type":"text"}]},"doc://GIO/documentation/GIO/ApplicationRef/ActionGroupProtocol-Implementations":{"title":"ActionGroupProtocol 