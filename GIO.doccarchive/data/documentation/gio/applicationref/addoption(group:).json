{"variants":[{"paths":["\/documentation\/gio\/applicationref\/addoption(group:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Adds a [OptionGroup](\/\/documentation\/glib\/optiongroup to the commandline handling of "},{"type":"codeVoice","code":"application"},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addOption"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"GLibOptionGroupT"},{"text":">(","kind":"text"},{"text":"group","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GLibOptionGroupT"},{"text":") ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"GLibOptionGroupT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4GLib19OptionGroupProtocolP","text":"OptionGroupProtocol","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"This function is comparable to ","type":"text"},{"type":"codeVoice","code":"g_option_context_add_group()"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Unlike "},{"code":"g_application_add_main_option_entries()","type":"codeVoice"},{"text":", this function does","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not deal with "},{"type":"codeVoice","code":"nil"},{"text":" ","type":"text"},{"code":"arg_data","type":"codeVoice"},{"text":" and never transmits options to the","type":"text"},{"type":"text","text":" "},{"text":"primary instance.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The reason for that is because, by the time the options arrive at the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"primary instance, it is typically too late to do anything with them."},{"type":"text","text":" "},{"type":"text","text":"Taking the GTK option group as an example: GTK will already have been"},{"type":"text","text":" "},{"type":"text","text":"initialised by the time the [Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:) handler runs."},{"text":" ","type":"text"},{"text":"In the case that this is not the first-running instance of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"application, the existing instance may already have been running for"},{"type":"text","text":" "},{"type":"text","text":"a very long time."}]},{"inlineContent":[{"type":"text","text":"This means that the options from [OptionGroup](\/\/documentation\/glib\/optiongroup are only really usable"},{"text":" ","type":"text"},{"text":"in the case that the instance of the application being run is the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"first instance.  Passing options like "},{"type":"codeVoice","code":"--display="},{"type":"text","text":" or "},{"type":"codeVoice","code":"--gdk-debug="},{"text":" ","type":"text"},{"type":"text","text":"on future runs will have no effect on the existing primary instance."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calling this function will cause the options in the supplied option"},{"text":" ","type":"text"},{"text":"group to be parsed, but it does not cause you to be “opted in” to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"new functionality whereby unrecognized options are rejected even if"},{"type":"text","text":" "},{"type":"codeVoice","code":"handlesCommandLine"},{"type":"text","text":" was given."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/addOption(group:)"},"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations"]]},"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"title":"addOption(group:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addOption","kind":"identifier"},{"kind":"text","text":"<"},{"text":"GLibOptionGroupT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"group"},{"kind":"text","text":": "},{"text":"GLibOptionGroupT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","externalID":"s:3GIO19ApplicationProtocolPAAE9addOption5groupyqd___t4GLib0e5GroupC0Rd__lF::SYNTHESIZED::s:3GIO14ApplicationRefV","symbolKind":"method","extendedModule":"GIO"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ApplicationRef/addOption(group:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/addOption(group:)","url":"\/documentation\/gio\/applicationref\/addoption(group:)","title":"addOption(group:)","kind":"symbol","role":"symbol","abstract":[{"text":"Adds a [OptionGroup](\/\/documentation\/glib\/optiongroup to the commandline handling of ","type":"text"},{"type":"codeVoice","code":"application"},{"type":"text","text":"."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addOption","kind":"identifier"},{"text":"<","kind":"text"},{"text":"GLibOptionGroupT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"group","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GLibOptionGroupT","kind":"typeIdentifier"},{"text":")","kind":"text"}],"type":"topic"},"doc://GIO/documentation/GIO/ApplicationRef/ApplicationProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations","url":"\/documentation\/gio\/applicationref\/applicationprotocol-implementations","type":"topic","title":"ApplicationProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[]},"doc://GIO/documentation/GIO/ApplicationRef":{"type":"topic","navigatorTitle":[{"text":"ApplicationRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","url":"\/documentation\/gio\/applicationref","title":"ApplicationRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ApplicationRef"}],"abstract":[{"type":"codeVoice","code":"GApplication"},{"text":" is the core class for application support.","type":"text"}]}}}