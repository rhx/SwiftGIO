{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations"]]},"metadata":{"title":"onHandleLocalOptions(flags:handler:)","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onHandleLocalOptions","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14ApplicationRefV","text":"ApplicationRef"},{"text":", ","kind":"text"},{"text":"VariantDictRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14VariantDictRefV"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"extendedModule":"GIO","symbolKind":"method","externalID":"s:3GIO19ApplicationProtocolPAAE20onHandleLocalOptions5flags7handlerSi10GLibObject12ConnectFlagsV_SiAA0B3RefV_0J0011VariantDictN0VtctF::SYNTHESIZED::s:3GIO14ApplicationRefV","role":"symbol","modules":[{"name":"GIO"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/onHandleLocalOptions(flags:handler:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The "},{"code":"handle-local-options","type":"codeVoice"},{"text":" signal is emitted on the local instance","type":"text"},{"text":" ","type":"text"},{"text":"after the parsing of the commandline options has occurred.","type":"text"}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationref\/onhandlelocaloptions(flags:handler:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@discardableResult"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onHandleLocalOptions"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","text":"ApplicationRef","preciseIdentifier":"s:3GIO14ApplicationRefV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"VariantDictRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14VariantDictRefV"},{"text":") -> ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"flags","content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"An exit code. If you have handled your options and want to exit the process, return a non-negative option, 0 for success, and a positive value for failure. To continue, return -1 to let the default option processing continue.","type":"text"},{"text":" ","type":"text"},{"text":"Run the given callback whenever the ","type":"text"},{"type":"codeVoice","code":"handleLocalOptions"},{"text":" signal is emitted","type":"text"}]}],"name":"handler"}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"You can add options to be recognised during commandline option","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parsing using "},{"code":"g_application_add_main_option_entries()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_application_add_option_group()"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Signal handlers can inspect "},{"type":"codeVoice","code":"options"},{"type":"text","text":" (along with values pointed to"},{"type":"text","text":" "},{"type":"text","text":"from the "},{"code":"arg_data","type":"codeVoice"},{"text":" of an installed ","type":"text"},{"code":"GOptionEntrys","type":"codeVoice"},{"type":"text","text":") in order to"},{"type":"text","text":" "},{"type":"text","text":"decide to perform certain actions, including direct local handling"},{"type":"text","text":" "},{"type":"text","text":"(which may be useful for options like –version)."}]},{"type":"paragraph","inlineContent":[{"text":"In the event that the application is marked","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"handlesCommandLine"},{"text":" the “normal processing” will","type":"text"},{"text":" ","type":"text"},{"text":"send the ","type":"text"},{"code":"options","type":"codeVoice"},{"type":"text","text":" dictionary to the primary instance where it can be"},{"type":"text","text":" "},{"text":"read with ","type":"text"},{"type":"codeVoice","code":"g_application_command_line_get_options_dict()"},{"text":".  The signal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handler can modify the dictionary before returning, and the"},{"type":"text","text":" "},{"text":"modified dictionary will be sent.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that "},{"code":"handlesCommandLine","type":"codeVoice"},{"text":" is not set,","type":"text"},{"text":" ","type":"text"},{"text":"“normal processing” will treat the remaining uncollected command","type":"text"},{"text":" ","type":"text"},{"text":"line arguments as filenames or URIs.  If there are no arguments,","type":"text"},{"type":"text","text":" "},{"text":"the application is activated by ","type":"text"},{"code":"g_application_activate()","type":"codeVoice"},{"type":"text","text":".  One or"},{"text":" ","type":"text"},{"type":"text","text":"more arguments results in a call to "},{"code":"g_application_open()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to handle the local commandline arguments for yourself"},{"type":"text","text":" "},{"type":"text","text":"by converting them to calls to "},{"code":"g_application_open()","type":"codeVoice"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"g_action_group_activate_action()","type":"codeVoice"},{"text":" then you must be sure to register","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the application first.  You should probably not call"},{"type":"text","text":" "},{"code":"g_application_activate()","type":"codeVoice"},{"text":" for yourself, however: just return -1 and","type":"text"},{"text":" ","type":"text"},{"text":"allow the default handler to do it for you.  This will ensure that","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"--gapplication-service"},{"text":" switch works properly (i.e. no activation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in that case)."}]},{"inlineContent":[{"text":"Note that this signal is emitted from the default implementation of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"local_command_line()"},{"type":"text","text":".  If you override that function and don’t"},{"text":" ","type":"text"},{"text":"chain up then this signal will never be emitted.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can override "},{"code":"local_command_line()","type":"codeVoice"},{"type":"text","text":" if you need more powerful"},{"type":"text","text":" "},{"text":"capabilities than what is provided here, but this should not","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"normally be required."}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"handle-local-options"},{"type":"text","text":" signal"}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/ApplicationRef":{"type":"topic","navigatorTitle":[{"text":"ApplicationRef","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","url":"\/documentation\/gio\/applicationref","title":"ApplicationRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ApplicationRef"}],"abstract":[{"type":"codeVoice","code":"GApplication"},{"text":" is the core class for application support.","type":"text"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ApplicationRef/ApplicationProtocol-Implementations":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations","url":"\/documentation\/gio\/applicationref\/applicationprotocol-implementations","type":"topic","title":"ApplicationProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[]},"doc://GIO/documentation/GIO/ApplicationRef/onHandleLocalOptions(flags:handler:)":{"type":"topic","title":"onHandleLocalOptions(flags:handler:)","url":"\/documentation\/gio\/applicationref\/onhandlelocaloptions(flags:handler:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onHandleLocalOptions","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"ApplicationRef","preciseIdentifier":"s:3GIO14ApplicationRefV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"preciseIdentifier":"s:4GLib14VariantDictRefV","kind":"typeIdentifier","text":"VariantDictRef"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":") -> "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"}],"kind":"symbol","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"handle-local-options"},{"type":"text","text":" signal is emitted on the local instance"},{"text":" ","type":"text"},{"type":"text","text":"after the parsing of the commandline options has occurred."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/onHandleLocalOptions(flags:handler:)"}}}