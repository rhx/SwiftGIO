stance initialization. Alternatively, you"},{"type":"text","text":" "},{"text":"can call this function in the ","type":"text"},{"type":"codeVoice","code":"GApplicationClass.startup"},{"type":"text","text":" virtual function,"},{"type":"text","text":" "},{"text":"before chaining up to the parent implementation.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/setResourceBasePath(resourcePath:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationref\/setresourcebasepath(resourcepath:)"]}],"kind":"symbol","metadata":{"role":"symbol","title":"setResourceBasePath(resourcePath:)","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setResourceBasePath","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"resourcePath"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">?)"}],"symbolKind":"method","externalID":"s:3GIO19ApplicationProtocolPAAE19setResourceBasePath08resourceG0ySPys4Int8VGSg_tF::SYNTHESIZED::s:3GIO14ApplicationRefV","modules":[{"name":"GIO"}],"roleHeading":"Instance Method"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef","doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/ApplicationProtocol-Implementations"]]},"sections":[],"references":{"doc://GIO/documentation/GIO/ApplicationRef/setResourceBasePath(resourcePath:)":{"role":"symbol","abstract":[{"text":"Sets (or unsets) the base resource path of ","type":"text"},{"code":"application","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationRef\/set