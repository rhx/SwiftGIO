{"abstract":[{"text":"Sets (or unsets) the base resource path of ","type":"text"},{"type":"codeVoice","code":"application"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setResourceBasePath","kind":"identifier"},{"kind":"text","text":"("},{"text":"resourcePath","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">? = nil)","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"The path is used to automatically load various"},{"type":"text","text":" "},{"isActive":true,"identifier":"#struct@Gio.Resource","type":"reference"},{"type":"text","text":" such as menu layouts and"},{"type":"text","text":" "},{"type":"text","text":"action descriptions. The various types of resources will be found at"},{"type":"text","text":" "},{"text":"fixed names relative to the given base path.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, the resource base path is determined from the application"},{"type":"text","text":" "},{"type":"text","text":"ID by prefixing ‘\/’ and replacing each ‘.’ with ‘\/’.  This is done at"},{"text":" ","type":"text"},{"text":"the time that the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application"},{"type":"text","text":" object is constructed.  Changes to"},{"text":" ","type":"text"},{"type":"text","text":"the application ID after that point will not have an impact on the"},{"type":"text","text":" "},{"type":"text","text":"resource base path."}]},{"inlineContent":[{"type":"text",