{"abstract":[{"code":"GAsyncResult","type":"codeVoice"},{"text":" provides a base class for implementing asynchronous function results.","type":"text"}],"topicSections":[{"title":"Initializers","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(_:)-2shqt","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(_:)-8qmwb","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(_:)-9u7g6","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(_:)-aill","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(_:)-w8gk","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(opaquePointer:)"],"anchor":"Initializers"},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/ptr"]},{"title":"Default Implementations","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/AsyncResultProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/PointerWrapper-Implementations"],"generated":true,"anchor":"Default-Implementations"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"metadata":{"roleHeading":"Structure","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AsyncResultRef"}],"navigatorTitle":[{"text":"AsyncResultRef","kind":"identifier"}],"role":"symbol","title":"AsyncResultRef","modules":[{"name":"GIO"}],"symbolKind":"struct","externalID":"s:3GIO14AsyncResultRefV"},"relationshipsSections":[{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AsyncResultProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef"},"variants":[{"paths":["\/documentation\/gio\/asyncresultref"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AsyncResultRef"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Asynchronous operations are broken up into two separate operations","type":"text"},{"text":" ","type":"text"},{"text":"which are chained together by a ","type":"text"},{"type":"codeVoice","code":"GAsyncReadyCallback"},{"type":"text","text":". To begin"},{"type":"text","text":" "},{"type":"text","text":"an asynchronous operation, provide a "},{"code":"GAsyncReadyCallback","type":"codeVoice"},{"type":"text","text":" to the"},{"text":" ","type":"text"},{"type":"text","text":"asynchronous function. This callback will be triggered when the"},{"text":" ","type":"text"},{"type":"text","text":"operation has completed, and must be run in a later iteration of"},{"type":"text","text":" "},{"type":"text","text":"the thread-default main context (see"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"]) from where the operation was","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"initiated. It will be passed a "},{"code":"GAsyncResult","type":"codeVoice"},{"type":"text","text":" instance filled with the"},{"type":"text","text":" "},{"type":"text","text":"details of the operation’s success or failure, the object the asynchronous"},{"type":"text","text":" "},{"type":"text","text":"function was started for and any error codes returned. The asynchronous"},{"type":"text","text":" "},{"type":"text","text":"callback function is then expected to call the corresponding "},{"type":"codeVoice","code":"_finish()"},{"type":"text","text":" "},{"type":"text","text":"function, passing the object the function was called for, the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GAsyncResult"},{"type":"text","text":" instance, and (optionally) an "},{"type":"codeVoice","code":"error"},{"type":"text","text":" to grab any"},{"type":"text","text":" "},{"type":"text","text":"error conditions that may have occurred."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"_finish()","type":"codeVoice"},{"type":"text","text":" function for an operation takes the generic result"},{"text":" ","type":"text"},{"type":"text","text":"(of type "},{"code":"GAsyncResult","type":"codeVoice"},{"type":"text","text":") and returns the specific result that the"},{"text":" ","type":"text"},{"text":"operation in question yields (e.g. a [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator","type":"reference","isActive":true},{"type":"text","text":"] for a"},{"text":" ","type":"text"},{"type":"text","text":"“enumerate children” operation). If the result or error status of the"},{"text":" ","type":"text"},{"type":"text","text":"operation is not needed, there is no need to call the "},{"code":"_finish()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"function; GIO will take care of cleaning up the result and error"},{"type":"text","text":" "},{"text":"information after the ","type":"text"},{"type":"codeVoice","code":"GAsyncReadyCallback"},{"text":" returns. You can pass","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"NULL"},{"text":" for the ","type":"text"},{"code":"GAsyncReadyCallback","type":"codeVoice"},{"text":" if you don’t need to take any","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"action at all after the operation completes. Applications may also"},{"text":" ","type":"text"},{"text":"take a reference to the ","type":"text"},{"type":"codeVoice","code":"GAsyncResult"},{"type":"text","text":" and call "},{"type":"codeVoice","code":"_finish()"},{"type":"text","text":" later;"},{"type":"text","text":" "},{"text":"however, the ","type":"text"},{"code":"_finish()","type":"codeVoice"},{"text":" function may be called at most once.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Example of a typical asynchronous operation flow:"}]},{"type":"codeListing","syntax":"c","code":["void _theoretical_frobnitz_async (Theoretical         *t,","                                  GCancellable        *c,","                                  GAsyncReadyCallback  cb,","                                  gpointer             u);","","gboolean _theoretical_frobnitz_finish (Theoretical   *t,","                                       GAsyncResult  *res,","                                       GError       **e);","","static void","frobnitz_result_func (GObject      *source_object,","\t\t GAsyncResult *res,","\t\t gpointer      user_data)","{","  gboolean success = FALSE;","","  success = _theoretical_frobnitz_finish (source_object, res, NULL);","","  if (success)","    g_printf (\"Hurray!\\n\");","  else","    g_printf (\"Uh oh!\\n\");","","  ...","","}","","int main (int argc, void *argv[])","{","   ...","","   _theoretical_frobnitz_async (theoretical_data,","                                NULL,","                                frobnitz_result_func,","                                NULL);","","   ...","}"]},{"inlineContent":[{"text":"The callback for an asynchronous operation is called only once, and is","type":"text"},{"text":" ","type":"text"},{"text":"always called, even in the case of a cancelled operation. On cancellation","type":"text"},{"text":" ","type":"text"},{"text":"the result is a ","type":"text"},{"type":"codeVoice","code":"G_IO_ERROR_CANCELLED"},{"text":" error.","type":"text"}],"type":"paragraph"},{"anchor":"IO-Priority","text":"I\/O Priority","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Many I\/O-related asynchronous operations have a priority parameter,"},{"type":"text","text":" "},{"text":"which is used in certain cases to determine the order in which","type":"text"},{"text":" ","type":"text"},{"text":"operations are executed. They are not used to determine system-wide","type":"text"},{"type":"text","text":" "},{"type":"text","text":"I\/O scheduling. Priorities are integers, with lower numbers indicating"},{"type":"text","text":" "},{"type":"text","text":"higher priority. It is recommended to choose priorities between"},{"type":"text","text":" "},{"code":"G_PRIORITY_LOW","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"G_PRIORITY_HIGH"},{"text":", with ","type":"text"},{"type":"codeVoice","code":"G_PRIORITY_DEFAULT"},{"type":"text","text":" "},{"type":"text","text":"as a default."}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GAsyncResult","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultProtocol"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef","isActive":true},{"text":" only as an ","type":"text"},{"type":"codeVoice","code":"unowned"},{"text":" reference to an existing ","type":"text"},{"code":"GAsyncResult","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef","isActive":true,"type":"reference"},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GAsyncResult"},{"type":"text","text":" instance."}],"type":"paragraph"}],"style":"note","name":"Note"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/AsyncResultRef/init(constPointer:)":{"title":"init(constPointer:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultRef\/init(constPointer:)","kind":"symbol","role":"symbol","type":"topic","abstract":[{"text":"Unsafe typed initialiser.","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"type":"text","text":"Do not use unless you know the underlying data type the pointer points to conforms to "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResultProtocol","isActive":true},{"text":".","type":"text"}],"type":"strong"}],"url":"\/documentation\/gio\/asyncresultref\/init(constpointer:)","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"<"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"constPointer"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"T","kind":"typeIdentifier"},{"kind":"text","text":">)"}]},"doc://GIO/documentation/GIO/AsyncResultRef/init(cPointer:)":{"fragments":[{"kind":"identifier","text":"init"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"cPointer"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"Unsafe