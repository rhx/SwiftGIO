{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher\/takeStdout(fd:)"},"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeStdout"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"fd"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"title":"takeStdout(fd:)","role":"symbol","externalID":"s:3GIO26SubprocessLauncherProtocolPAAE10takeStdout2fdySi_tF::SYNTHESIZED::s:3GIO18SubprocessLauncherC","symbolKind":"method","extendedModule":"GIO"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeStdout"},{"kind":"text","text":"("},{"kind":"externalParam","text":"fd"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"fd"},{"type":"text","text":" is -1 then any previously given fd is unset."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the default behaviour is to pass stdout through to the"},{"type":"text","text":" "},{"type":"text","text":"stdout of the parent process."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The passed "},{"type":"codeVoice","code":"fd"},{"type":"text","text":" is noted but will not be touched in the current"},{"type":"text","text":" "},{"type":"text","text":"process.  It is therefore necessary that it be kept open by the"},{"text":" ","type":"text"},{"type":"text","text":"caller until the subprocess is spawned.  The file descriptor will"},{"text":" ","type":"text"},{"type":"text","text":"also not be explicitly closed on the child side, so it must be marked"},{"type":"text","text":" "},{"text":"O_CLOEXEC if that’s what you want.","type":"text"}]},{"inlineContent":[{"type":"text","text":"You may not set a stdout fd if a stdout file path is already set or"},{"type":"text","text":" "},{"type":"text","text":"if the launcher flags contain any flags directing stdout elsewhere."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This feature is only available on UNIX."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/subprocesslauncher\/takestdout(fd:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Sets the file descriptor to use as the stdout for spawned processes.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher","doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher\/SubprocessLauncherProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/SubprocessLauncher/SubprocessLauncherProtocol-Implementations":{"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher\/SubprocessLauncherProtocol-Implementations","url":"\/documentation\/gio\/subprocesslauncher\/subprocesslauncherprotocol-implementations","title":"SubprocessLauncherProtocol Implementations","abstract":[],"kind":"article","role":"collectionGroup"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SubprocessLauncher/takeStdout(fd:)":{"role":"symbol","abstract":[{"text":"Sets the file descriptor to use as the stdout for spawned processes.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher\/takeStdout(fd:)","title":"takeStdout(fd:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeStdout"},{"kind":"text","text":"("},{"text":"fd","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":")"}],"type":"topic","url":"\/documentation\/gio\/subprocesslauncher\/takestdout(fd:)"},"doc://GIO/documentation/GIO/SubprocessLauncher":{"navigatorTitle":[{"text":"SubprocessLauncher","kind":"identifier"}],"title":"SubprocessLauncher","type":"topic","abstract":[{"type":"text","text":"This class contains a set of options for launching child processes,"},{"type":"text","text":" "},{"type":"text","text":"such as where its standard input and output will be directed, the"},{"type":"text","text":" "},{"type":"text","text":"argument list, the environment, and more."}],"kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SubprocessLauncher","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher","url":"\/documentation\/gio\/subprocesslauncher"}}}