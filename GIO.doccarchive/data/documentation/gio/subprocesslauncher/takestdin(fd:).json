{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher","doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher\/SubprocessLauncherProtocol-Implementations"]]},"variants":[{"paths":["\/documentation\/gio\/subprocesslauncher\/takestdin(fd:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher\/takeStdin(fd:)"},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeStdin","kind":"identifier"},{"text":"(","kind":"text"},{"text":"fd","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"extendedModule":"GIO","roleHeading":"Instance Method","symbolKind":"method","modules":[{"name":"GIO"}],"role":"symbol","externalID":"s:3GIO26SubprocessLauncherProtocolPAAE9takeStdin2fdySi_tF::SYNTHESIZED::s:3GIO18SubprocessLauncherC","title":"takeStdin(fd:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeStdin"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"fd"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"If "},{"code":"fd","type":"codeVoice"},{"type":"text","text":" is -1 then any previously given fd is unset."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that if your intention is to have the stdin of the calling"},{"type":"text","text":" "},{"type":"text","text":"process inherited by the child then "},{"type":"codeVoice","code":"stdinInherit"},{"type":"text","text":" "},{"type":"text","text":"is a better way to go about doing that."}],"type":"paragraph"},{"inlineContent":[{"text":"The passed ","type":"text"},{"type":"codeVoice","code":"fd"},{"type":"text","text":" is noted but will not be touched in the current"},{"text":" ","type":"text"},{"type":"text","text":"process.  It is therefore necessary that it be kept open by the"},{"type":"text","text":" "},{"type":"text","text":"caller until the subprocess is spawned.  The file descriptor will"},{"type":"text","text":" "},{"type":"text","text":"also not be explicitly closed on the child side, so it must be marked"},{"type":"text","text":" "},{"text":"O_CLOEXEC if that’s what you want.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You may not set a stdin fd if a stdin file path is already set or if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the launcher flags contain any flags directing stdin elsewhere."}]},{"inlineContent":[{"type":"text","text":"This feature is only available on UNIX."}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Sets the file descriptor to use as the stdin for spawned processes.","type":"text"}],"references":{"doc://GIO/documentation/GIO/SubprocessLauncher":{"navigatorTitle":[{"text":"SubprocessLauncher","kind":"identifier"}],"title":"SubprocessLauncher","type":"topic","abstract":[{"type":"text","text":"This class contains a set of options for launching child processes,"},{"type":"text","text":" "},{"type":"text","text":"such as where its standard input and output will be directed, the"},{"type":"text","text":" "},{"type":"text","text":"argument list, the environment, and more."}],"kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SubprocessLauncher","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher","url":"\/documentation\/gio\/subprocesslauncher"},"