{"variants":[{"paths":["\/documentation\/gio\/dbusinterfaceskeleton\/ongauthorizemethod(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Emitted when a method is invoked by a remote caller and used to"},{"type":"text","text":" "},{"type":"text","text":"determine if the method call is authorized."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onGAuthorizeMethod"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeletonRef","text":"DBusInterfaceSkeletonRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO24DBusInterfaceSkeletonRefV"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO23DBusMethodInvocationRefV","text":"DBusMethodInvocationRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocationRef"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the call is authorized, "},{"type":"codeVoice","code":"false"},{"text":" otherwise.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"code":"gAuthorizeMethod","type":"codeVoice"},{"text":" signal is emitted","type":"text"}],"type":"paragraph"}],"name":"handler"}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that this signal is emitted in a thread dedicated to","type":"text"},{"type":"text","text":" "},{"text":"handling the method call so handlers are allowed to perform","type":"text"},{"type":"text","text":" "},{"text":"blocking IO. This means that it is appropriate to call e.g.","type":"text"},{"text":" ","type":"text"},{"identifier":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#polkit-authority-check-authorization-sync","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"with the","type":"text"},{"type":"text","text":" "},{"identifier":"http:\/\/hal.freedesktop.org\/docs\/polkit\/PolkitAuthority.html#POLKIT-CHECK-AUTHORIZATION-FLAGS-ALLOW-USER-INTERACTION:CAPS","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"flag set."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned then no further handlers are run and the"},{"text":" ","type":"text"},{"type":"text","text":"signal handler must take a reference to "},{"type":"codeVoice","code":"invocation"},{"text":" and finish","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handling the call (e.g. return an error via"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_dbus_method_invocation_return_error()"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Otherwise, if "},{"type":"codeVoice","code":"true"},{"text":" is returned, signal emission continues. If no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handlers return "},{"code":"false","type":"codeVoice"},{"text":", then the method is dispatched. If","type":"text"},{"type":"text","text":" "},{"code":"interface","type":"codeVoice"},{"text":" has an enclosing ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeleton"},{"type":"text","text":", then the"},{"type":"text","text":" "},{"type":"text","text":"[DBusObjectSkeleton](\/\/documentation\/gio\/dbusobjectskeleton\/onauthorizemethod(flags:handler:) signal handlers run before"},{"text":" ","type":"text"},{"type":"text","text":"the handlers for this signal."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The default class handler just returns "},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Please note that the common case is optimized: if no signals","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handlers are connected and the default class handler isn’t"},{"type":"text","text":" "},{"type":"text","text":"overridden (for both "},{"code":"interface","type":"codeVoice"},{"text":" and the enclosing","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusObjectSkeleton","isActive":true,"type":"reference"},{"text":", if any) and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeleton"},{"type":"text","text":" does"},{"type":"text","text":" "},{"text":"not have the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"handleMethodInvocationsInThread"},{"text":" ","type":"text"},{"text":"flags set, no dedicated thread is ever used and the call will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handled in the same thread as the object that "},{"type":"codeVoice","code":"interface"},{"type":"text","text":" belongs"},{"type":"text","text":" "},{"text":"to was exported in.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"g-authorize-method","type":"codeVoice"},{"text":" signal","type":"text"}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeleton\/onGAuthorizeMethod(flags:handler:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","role":"symbol","externalID":"s:3GIO29DBusInterfaceSkeletonProtocolPAAE18onGAuthorizeMethod5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0bcD3RefV_AA0bh10InvocationO0VtctF::SYNTHESIZED::s:3GIO21DBusInterfaceSkeletonC","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onGAuthorizeMethod","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO24DBusInterfaceSkeletonRefV","text":"DBusInterfaceSkeletonRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:3GIO23DBusMethodInvocationRefV","text":"DBusMethodInvocationRef","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"symbolKind":"method","title":"onGAuthorizeMethod(flags:handler:)","extendedModule":"GIO","modules":[{"name":"GIO"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeleton","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceSkeleton\/DBusInterfaceSkeletonProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"http://hal.freedesktop.org/docs/polkit/PolkitAuthority.html#POL