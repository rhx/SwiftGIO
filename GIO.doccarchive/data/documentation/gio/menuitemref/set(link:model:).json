{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemRef","doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/MenuItemProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Creates a link from "},{"code":"menuItem","type":"codeVoice"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"model"},{"text":" if non-","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", or unsets it."}],"metadata":{"extendedModule":"GIO","role":"symbol","modules":[{"name":"GIO"}],"externalID":"s:3GIO16MenuItemProtocolPAAE3set4link5modelySPys4Int8VGSg_AA0B8ModelRefVSgtF::SYNTHESIZED::s:3GIO11MenuItemRefV","roleHeading":"Instance Method","title":"set(link:model:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"link"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"model","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO12MenuModelRefV","text":"MenuModelRef"},{"kind":"text","text":"?)"}],"symbolKind":"method"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"(","kind":"text"},{"text":"link","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"model"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO12MenuModelRefV","kind":"typeIdentifier","text":"MenuModelRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},{"text":"? = nil)","kind":"text"}]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Links are used to establish a relationship between a particular menu"},{"type":"text","text":" "},{"type":"text","text":"item and another menu.  For example, "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSubmenu","isActive":true,"type":"reference"},{"type":"text","text":" is used to"},{"type":"text","text":" "},{"text":"associate a submenu with a particular menu item, and ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSection","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"is used to create a section. Other types of link can be used, but there","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is no guarantee that clients will be able to make sense of them."},{"text":" ","type":"text"},{"type":"text","text":"Link types are restricted to lowercase characters, numbers"},{"type":"text","text":" "},{"type":"text","text":"and ‘-’. Furthermore, the names must begin with a lowercase character,"},{"text":" ","type":"text"},{"text":"must not end with a ‘-’, and must not contain consecutive dashes.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/gio\/menuitemref\/set(link:model:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/set(link:model:)"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuItemRef":{"url":"\/documentation\/gio\/menuitemref","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef","abstract":[{"type":"reference","identifier":"doc:\/\/GIO\/d