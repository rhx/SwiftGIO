ext":" ","type":"text"},{"type":"text","text":"as a header."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSection","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"menuLinkSection"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}]},"doc://GIO/documentation/GIO/MenuItemRef/MenuItemProtocol-Implementations":{"abstract":[],"type":"topic","role":"collectionGroup","title":"MenuItemProtocol Implementations","url":"\/documentation\/gio\/menuitemref\/menuitemprotocol-implementations","kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/MenuItemProtocol-Implementations"},"doc://GIO/documentation/GIO/menuLinkSubmenu":{"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"menuLinkSubmenu"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"kind":"symbol","url":"\/documentation\/gio\/menulinksubmenu","abstract":[{"type":"text","text":"The name of the link that associates a menu item with a submenu."}],"type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSubmenu","title":"menuLinkSubmenu"}}}