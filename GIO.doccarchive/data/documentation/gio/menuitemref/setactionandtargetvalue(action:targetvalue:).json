{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"extendedModule":"GIO","title":"setActionAndTargetValue(action:targetValue:)","externalID":"s:3GIO16MenuItemProtocolPAAE23setActionAndTargetValue6action06targetI0ySPys4Int8VGSg_4GLib10VariantRefVSgtF::SYNTHESIZED::s:3GIO11MenuItemRefV","role":"symbol","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"setActionAndTargetValue","kind":"identifier"},{"text":"(","kind":"text"},{"text":"action","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">?, "},{"text":"targetValue","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"?)","kind":"text"}],"roleHeading":"Instance Method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setActionAndTargetValue"},{"text":"(","kind":"text"},{"text":"action","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"text":">? = nil, ","kind":"text"},{"text":"targetValue","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"action","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then both the “action” and “target” attributes"},{"text":" ","type":"text"},{"type":"text","text":"are unset (and "},{"type":"codeVoice","code":"targetValue"},{"type":"text","text":" is ignored)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"action","type":"codeVoice"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" then the “action” attribute is set.  The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"“target” attribute is then set to the value of "},{"code":"targetValue","type":"codeVoice"},{"type":"text","text":" if it is"},{"type":"text","text":" "},{"text":"non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" or unset otherwise."}]},{"inlineContent":[{"text":"Normal menu items (ie: not submenu, section or other custom item","type":"text"},{"type":"text","text":" "},{"type":"text","text":"types) are expected to have the “action” attribute set to identify"},{"text":" ","type":"text"},{"type":"text","text":"the action that they are associated with.  The state type of the"},{"type":"text","text":" "},{"text":"action help to determine the disposition of the menu item.  See","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","type":"reference","isActive":true},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup"},{"text":" for an overview of actions.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In general, clicking on the menu item will result in activation of"},{"text":" ","type":"text"},{"text":"the named action with the “target” attribute given as the parameter","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to the action invocation.  If the “target” attribute is not set then"},{"type":"text","text":" "},{"type":"text","text":"the action is invoked with no parameter."}]},{"type":"paragraph","inlineContent":[{"text":"If the action has no state then the menu item is usually drawn as a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"plain menu item (ie: with no additional decoration)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the action has a boolean state then the menu item is usually drawn"},{"text":" ","type":"text"},{"type":"text","text":"as a toggle menu item (ie: with a checkmark or equivalent"},{"type":"text","text":" "},{"type":"text","text":"indication).  The item should be marked as ‘toggled’ or ‘checked’"},{"type":"text","text":" "},{"text":"when the boolean state is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If the action has a string state then the menu item is usually drawn","type":"text"},{"type":"text","text":" "},{"text":"as a radio menu item (ie: with a radio bullet or equivalent","type":"text"},{"type":"text","text":" "},{"type":"text","text":"indication).  The item should be marked as ‘selected’ when the string"},{"type":"text","text":" "},{"text":"state is equal to the value of the ","type":"text"},{"type":"codeVoice","code":"target"},{"text":" property.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"code":"g_menu_item_set_action_and_target()","type":"codeVoice"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_menu_item_set_detailed_action()"},{"text":" for two equivalent calls that are","type":"text"},{"type":"text","text":" "},{"text":"probably more convenient for most uses.","type":"text"}]}],"kind":"content"}],"sections":[],"abstract":[{"text":"Sets or unsets the “action” and “target” attributes of ","type":"text"},{"type":"codeVoice","code":"menuItem"},{"type":"text","text":"."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/setActionAndTargetValue(action:targetValue:)","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/menuitemref\/setactionandtargetvalue(action:targetvalue:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemRef","doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/MenuItemProtocol-Implementations"]]},"references":{"doc://GIO/documentation/GIO/ActionGroup":{"role":"symbol","title":"ActionGroup","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ActionGroup"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","navigatorTitle":[{"text":"ActionGroup","kind":"identifier"}],"type":"topic","url":"\/documentation\/gio\/actiongroup","abstract":[{"type":"codeVoice","code":"GActionGroup"},{"type":"text","text":" represents a group of actions."}]},"doc://GIO/documentation/GIO/MenuItemRef/setActionAndTargetValue(action:targetValue:)":{"url":"\/documentation\/gio\/menuitemref\/setactionandtargetvalue(action:targetvalue:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/setActionAndTargetValue(action:targetValue:)","abstract":[{"text":"Sets or unsets the “action” and “target” attributes of ","type":"text"},{"type":"codeVoice","code":"menuItem"},{"type":"text","text":"."}],"role":"symbol","type":"topic","title":"setActionAndTargetValue(action:targetValue:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setActionAndTargetValue"},{"text":"(","kind":"text"},{"text":"action","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">?, "},{"kind":"externalParam","text":"targetValue"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"kind":"symbol"},"doc://GIO/documentation/GIO/MenuItemRef":{"url":"\/documentation\/gio\/menuitemref","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef","abstract":[{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true},{"type":"text","text":" is an opaque structure type.  You must access it using the"},{"text":" ","type":"text"},{"text":"functions below.","type":"text"}],"title":"MenuItemRef","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MenuItemRef"}],"navigatorTitle":[{"text":"MenuItemRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/Action":{"url":"\/documentation\/gio\/action","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action"}],"navigatorTitle":[{"text":"Action","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","title":"Action","role":"symbol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuItemRef/MenuItemProtocol-Implementations":{"abstract":[],"type":"topic","role":"c