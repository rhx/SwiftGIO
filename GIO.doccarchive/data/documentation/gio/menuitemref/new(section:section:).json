{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemRef"]]},"metadata":{"role":"symbol","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"new","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuModelT"},{"text":">(","kind":"text"},{"text":"section","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">?, "},{"kind":"externalParam","text":"section"},{"kind":"text","text":": "},{"text":"MenuModelT","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO11MenuItemRefV","text":"MenuItemRef"},{"kind":"text","text":"!"}],"roleHeading":"Type Method","externalID":"s:3GIO11MenuItemRefV3new7sectionAeCSgSPys4Int8VGSg_xtAA0B13ModelProtocolRzlFZ","title":"new(section:section:)"},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menuitemref\/new(section:section:)"]}],"kind":"symbol","abstract":[{"text":"Creates a new ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true},{"type":"text","text":" representing a section."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/new(section:section:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"new"},{"kind":"text","text":"<"},{"text":"MenuModelT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"section","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"label","kind":"internalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">? = nil, "},{"kind":"externalParam","text":"section"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MenuModelT"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:3GIO11MenuItemRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef","kind":"typeIdentifier","text":"MenuItemRef"},{"text":"! ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"MenuModelT"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","text":"MenuModelProtocol","preciseIdentifier":"s:3GIO17MenuModelProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This is a convenience API around ","type":"text"},{"type":"codeVoice","code":"g_menu_item_new()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"code":"g_menu_item_set_section()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The effect of having one menu appear as a section of another is"},{"type":"text","text":" "},{"text":"exactly as it sounds: the items from ","type":"text"},{"type":"codeVoice","code":"section"},{"text":" become a direct part of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the menu that "},{"code":"menu_item","type":"codeVoice"},{"type":"text","text":" is added to."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Visual separation is typically displayed between two non-empty"},{"type":"text","text":" "},{"type":"text","text":"sections.  If "},{"code":"label","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"text":" then it will be incorporated into","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this visual indication.  This allows for labeled subsections of a"},{"type":"text","text":" "},{"text":"menu.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"As a simple example, consider a typical “Edit” menu from a simple","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"program.  It probably contains an “Undo” and “Redo” item, followed by"},{"type":"text","text":" "},{"type":"text","text":"a separator, followed by “Cut”, “Copy” and “Paste”."}]},{"inlineContent":[{"type":"text","text":"This would be accomplished by creating three "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu"},{"text":" instances.  The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"first would be populated with the “Undo” and “Redo” items, and the"},{"type":"text","text":" "},{"type":"text","text":"second with the “Cut”, “Copy” and “Paste” items.  The first and"},{"type":"text","text":" "},{"text":"second menus would then be added as submenus of the third.  In XML","type":"text"},{"type":"text","text":" "},{"type":"text","text":"format, this would look something like the following:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["<menu id='edit-menu'>","  <section>","    <item label='Undo'\/>","    <item label='Redo'\/>","  <\/section>","  <section>","    <item label='Cut'\/>","    <item label='Copy'\/>","    <item label='Paste'\/>","  <\/section>","<\/menu>"]},{"type":"paragraph","inlineContent":[{"text":"The following example is exactly equivalent.  It is more illustrative","type":"text"},{"text":" ","type":"text"},{"text":"of the exact relationship between the menus and items (keeping in","type":"text"},{"text":" ","type":"text"},{"text":"mind that the ‘link’ element defines a new menu that is linked to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"containing one).  The style of the second example is more verbose and"},{"text":" ","type":"text"},{"type":"text","text":"difficult to read (and therefore not recommended except for the"},{"type":"text","text":" "},{"text":"purpose of understanding what is really going on).","type":"text"}]},{"syntax":null,"code":["<menu id='edit-menu'>","  <item>","    <link name='section'>","      <item label='Undo'\/>","      <item label='Redo'\/>","    <\/link>","  <\/item>","  <item>","    <link name='section'>","      <item label='Cut'\/>","      <item label='Copy'\/>","      <item label='Paste'\/>","    <\/link>","  <\/item>","<\/menu>"],"type":"codeListing"}]}],"references":{"doc://GIO/documentation/GIO/MenuModelProtocol":{"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/menumodelprotocol","navigatorTitle":[{"text":"MenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuItemRef/new(section:section:)":{"type":"topic","title":"new(section:section:)","url":"\/documentation\/gio\/menuitemref\/new(section:section:)","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"new","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuModelT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"section"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">?, "},{"kind":"externalParam","text":"section"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MenuModelT"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"MenuItemRef","preciseIdentifier":"s:3GIO11MenuItemRefV"},{"text":"!","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Creates a new "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","type":"reference"},{"type":"text","text":" representing a section."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/new(section:section:)"},"doc://GIO/documentation/GIO/MenuItemRef":{"url":"\/documentation\/gio\/menuitemref","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef","abstract":[{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true},{"type":"text","text":" is an opaque structure type.  You must access it using the"},{"text":" ","type":"text"},{"text":"functions below.","type":"text"}],"title":"MenuItemRef","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MenuItemRef"}],"navigatorTitle":[{"text":"MenuItemRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/Menu":{"type":"topic","kind":"symbol","title":"Menu","navigatorTitle":[{"kind":"identifier","text":"Menu"}],"abstract":[{"type":"codeVoice","code":"GMenu"},{"type":"text","text":" is a simple implementation of [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true},{"type":"text","text":"]."},{"type":"text","text":" "},{"text":"You populate a ","type":"text"},{"type":"codeVoice","code":"GMenu"},{"type":"text","text":" by adding [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem"},{"type":"text","text":"] instances to it."}],"url":"\/documentation\/gio\/menu","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Menu","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu"}}}