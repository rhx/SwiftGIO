"type":"text","text":"] instances to it."}],"url":"\/documentation\/gio\/menu","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Menu","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu"}}}