{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/init(section:section:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Creates a new "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","type":"reference","isActive":true},{"text":" representing a section.","type":"text"}],"variants":[{"paths":["\/documentation\/gio\/menuitemref\/init(section:section:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemRef"]]},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"init","kind":"keyword"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"MenuModelT"},{"kind":"text","text":">("},{"text":"section","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"label","kind":"internalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">? = nil, "},{"kind":"externalParam","text":"section"},{"text":": ","kind":"text"},{"text":"MenuModelT","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17MenuModelProtocolP","text":"MenuModelProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is a convenience API around "},{"code":"g_menu_item_new()","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_menu_item_set_section()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The effect of having one menu appear as a section of another is"},{"type":"text","text":" "},{"type":"text","text":"exactly as it sounds: the items from "},{"type":"codeVoice","code":"section"},{"type":"text","text":" become a direct part of"},{"type":"text","text":" "},{"text":"the menu that ","type":"text"},{"type":"codeVoice","code":"menu_item"},{"type":"text","text":" is added to."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Visual separation is typically displayed between two non-empty"},{"text":" ","type":"text"},{"text":"sections.  If ","type":"text"},{"code":"label","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" then it will be incorporated into"},{"type":"text","text":" "},{"text":"this visual indication.  This allows for labeled subsections of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"menu."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As a simple example, consider a typical “Edit” menu from a simple"},{"text":" ","type":"text"},{"text":"program.  It probably contains an “Undo” and “Redo” item, followed by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a separator, followed by “Cut”, “Copy” and “Paste”."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This would be accomplished by creating three "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Menu","type":"reference","isActive":true},{"text":" instances.  The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"first would be populated with the “Undo” and “Redo” items, and the"},{"text":" ","type":"text"},{"text":"second with the “Cut”, “Copy” and “Paste” items.  The first and","type":"text"},{"text":" ","type":"text"},{"text":"second menus would then be added as submenus of the third.  In XML","type":"text"},{"text":" ","type":"text"},{"text":"format, this would look something like the following:","type":"text"}]},{"type":"codeListing","syntax":null,"code":["<menu id='edit-menu'>","  <section>","    <item label='Undo'\/>","    <item label='Redo'\/>","  <\/section>","  <section>","    <item label='Cut'\/>","    <item label='Copy'\/>","    <item label='Paste'\/>","  <\/section>","<\/menu>"]},{"type":"paragraph","inlineContent":[{"text":"The following example is exactly equivalent.  It is more illustrative","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the exact relationship between the menus and items (keeping in"},{"type":"text","text":" "},{"text":"mind that the ‘link’ element defines a new menu that is linked to the","type":"text"},{"text":" ","type":"text"},{"text":"containing one).  The style of the second example is more verbose and","type":"text"},{"text":" ","type":"text"},{"text":"difficult to read (and therefore not recommended except for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"purpose of understanding what is really going on)."}]},{"code":["<menu id='edit-menu'>","  <item>","    <link name='section'>","      <item label='Undo'\/>","      <item label='Redo'\/>","    <\/link>","  <\/item>","  <item>","    <link name='section'>","      <item label='Cut'\/>","      <item label='Copy'\/>","      <item label='Paste'\/>","    <\/link>","  <\/item>","<\/menu>"],"type":"codeListing","syntax":null}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"text":"MenuModelT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"section","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">?, "},{"kind":"externalParam","text":"section"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"MenuModelT"},{"text":")","kind":"text"}],"symbolKind":"init","extendedModule":"GIO","externalID":"s:3GIO11MenuItemRefV7sectionAdCSPys4Int8VGSg_xtcAA0B13ModelProtocolRzlufc","roleHeading":"Initializer","title":"init(section:section:)"},"references":{"doc://GIO/documentation/GIO/MenuItemRef":{"url":"\/documentation\/gio\/menuitemref","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef","abstract":[{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true},{"type":"text","text":" is an opaque structure type.  You must access it using the"},{"text":" ","type":"text"},{"text":"functions below.","type":"text"}],"title":"MenuItemRef","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MenuItemRef"}],"navigatorTitle":[{"text":"MenuItemRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuItemRef/init(section:section:)":{"url":"\/documentation\/gio\/menuitemref\/init(section:section:)","title":"init(section:section:)","abstract":[{"type":"text","text":"Creates a new "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"type":"text","text":" representing a section."}],"type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuModelT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"section"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">?, ","kind":"text"},{"kind":"externalParam","text":"section"},{"text":": ","kind":"text"},{"text":"MenuModelT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemRef\/init(section:section:)","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"