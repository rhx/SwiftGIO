{"metadata":{"roleHeading":"Class","role":"symbol","externalID":"s:3GIO14PropertyActionC","title":"PropertyAction","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"PropertyAction"}],"modules":[{"name":"GIO"}],"symbolKind":"class","navigatorTitle":[{"text":"PropertyAction","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/propertyaction"]}],"abstract":[{"type":"text","text":"A "},{"code":"GPropertyAction","type":"codeVoice"},{"type":"text","text":" is a way to get a [iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true,"type":"reference"},{"type":"text","text":"] with a state value"},{"type":"text","text":" "},{"type":"text","text":"reflecting and controlling the value of a [class[Object](\/\/documentation\/gobject\/object] property."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/PropertyAction"},"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(_:)-2yz5v","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(_:)-3plk5","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(_:)-4iljj","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(_:)-7uf8r","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(name:object:propertyName:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(propertyAction:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(raw:)-27r5c","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(raw:)-92csy","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(retainingRaw:)-2k5dp","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(retainingRaw:)-6ezxs"]},{"title":"Default Implementations","anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/ActionProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/PropertyActionProtocol-Implementations"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"PropertyAction","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"The state of the action will correspond to the value of the property.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Changing it will change the property (assuming the requested value"},{"type":"text","text":" "},{"type":"text","text":"matches the requirements as specified in the [type"},{"type":"reference","identifier":"\/\/documentation\/gobject\/paramspec]","isActive":true},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Only the most common types are presently supported.  Booleans are"},{"type":"text","text":" "},{"type":"text","text":"mapped to booleans, strings to strings, signed\/unsigned integers to"},{"text":" ","type":"text"},{"text":"int32\/uint32 and floats and doubles to doubles.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the property is an enum then the state will be string-typed and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"conversion will automatically be performed between the enum value and"},{"text":" ","type":"text"},{"type":"text","text":"‘nick’ string as per the [type[EnumValue](\/\/documentation\/gobject\/enumvalue] table."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Flags types are not currently supported."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Properties of object types, boxed types and pointer types are not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"supported and probably never will be."}]},{"inlineContent":[{"text":"Properties of [type[Variant](\/\/documentation\/glib\/variant] types are not currently supported.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the property is boolean-valued then the action will have a "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" "},{"text":"parameter type, and activating the action (with no parameter) will","type":"text"},{"text":" ","type":"text"},{"text":"toggle the value of the property.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In all other cases, the parameter type will correspond to the type of","type":"text"},{"text":" ","type":"text"},{"text":"the property.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The general idea here is to reduce the number of locations where a","type":"text"},{"type":"text","text":" "},{"text":"particular piece of state is kept (and therefore has to be synchronised","type":"text"},{"type":"text","text":" "},{"text":"between). ","type":"text"},{"code":"GPropertyAction","type":"codeVoice"},{"type":"text","text":" does not have a separate state that is kept"},{"text":" ","type":"text"},{"type":"text","text":"in sync with the property value — its state is the property value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, it might be useful to create a [iface"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action"},{"type":"text","text":"] corresponding"},{"text":" ","type":"text"},{"text":"to the ","type":"text"},{"code":"visible-child-name","type":"codeVoice"},{"type":"text","text":" property of a "},{"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Stack.html","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"so that the current page can be switched from a menu.  The active radio","type":"text"},{"type":"text","text":" "},{"type":"text","text":"indication in the menu is then directly determined from the active page of"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"GtkStack"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"An anti-example would be binding the ","type":"text"},{"code":"active-id","type":"codeVoice"},{"text":" property on a","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.ComboBox.html","isActive":true,"type":"reference"},{"type":"text","text":". This is"},{"type":"text","text":" "},{"text":"because the state of the combo box itself is probably uninteresting and is","type":"text"},{"text":" ","type":"text"},{"text":"actually being used to control something else.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Another anti-example would be to bind to the ","type":"text"},{"type":"codeVoice","code":"visible-child-name"},{"type":"text","text":" "},{"type":"text","text":"property of a "},{"overridingTitle":"GtkStack","identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Stack.html","isActive":true,"type":"reference","overridingTitleInlineContent":[{"type":"codeVoice","code":"GtkStack"}]},{"text":" if","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this value is actually stored in [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","type":"reference","isActive":true},{"text":"].  In that case, the","type":"text"},{"type":"text","text":" "},{"text":"real source of the value is* [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","isActive":true},{"type":"text","text":"].  If you want"},{"type":"text","text":" "},{"type":"text","text":"a [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true},{"type":"text","text":"] to control a setting stored in [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"see [method","type":"text"},{"type":"codeVoice","code":"Gio.Settings.create_action"},{"text":"] instead, and possibly combine its","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"use with [method"},{"type":"codeVoice","code":"Gio.Settings.bind"},{"text":"].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyAction","isActive":true,"type":"reference"},{"text":" type acts as a reference-counted owner of an underlying ","type":"text"},{"type":"codeVoice","code":"GPropertyAction"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyAction","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GPropertyAction"},{"text":" instance.","type":"text"}]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyActionRef"},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyAction","isActive":true,"type":"reference"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GPropertyAction","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"}],"kind":"content"}],"sections":[],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/GIO\/10GLibObject0B0C"],"type":"inheritsFrom"},{"kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ActionProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/PropertyActionProtocol"],"title":"Conforms To","type":"conformsTo"}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO/PropertyAction/init(_:)-3plk5":{"title":"init(_:)","url":"\/documentation\/gio\/propertyaction\/init(_:)-3plk5","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/PropertyAction\/init(_:)-3plk5","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GPropertyAction"},{"text":">)","kind":"text"}],"kind":"symbol","abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"type":"codeVoice","code":"C"},{"text":" data type.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"text":" ","type":"text"},{"text":"i.e., ownership is transferred to the ","type":"text"},{"type":"codeVoice","code":"PropertyAction"},{"type":"text","text":" instance."}],"type":"topic"},"doc://GIO/documentation/GIO/PropertyAction/init(retainingCPointer:)":{"abstract":[{"type":"text","text":"Unsafe typed, retaining initialiser."},{"type":"text","text":" "},{"inlineContent":[{"text":"Do not use unless you know the underlying data type the pointer points to con