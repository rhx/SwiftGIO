{"abstract":[{"type":"codeVoice","code":"GSubprocess"},{"text":" allows the creation of and interaction with child","type":"text"},{"type":"text","text":" "},{"text":"processes.","type":"text"}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/InitableProtocol","doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol"],"type":"conformsTo","kind":"relationships"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/subprocessref"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(_:)-410kv","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(_:)-4aszv","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(_:)-5zgjr","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(_:)-8q77w","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(_:)-9u5br","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(argv:flags:)","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/init(opaquePointer:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/ptr"],"generated":true},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/subprocessNewv(argv:flags:)","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/unowned(_:)"],"anchor":"Type-Methods","generated":true,"title":"Type Methods"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/GWeakCapturing-Implementations","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/InitableProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/ObjectProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/SubprocessRef\/SubprocessProtocol-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SubprocessRef","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Processes can be communicated with using standard GIO-style APIs (ie:"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream"},{"type":"text","text":"], [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream","isActive":true},{"text":"]). There are GIO-style APIs","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to wait for process termination (ie: cancellable and with an asynchronous"},{"text":" ","type":"text"},{"text":"variant).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"There is an API to force a process to terminate, as well as a","type":"text"},{"text":" ","type":"text"},{"text":"race-free API for sending UNIX signals to a subprocess.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"One major advantage that GIO brings over the core GLib library is"},{"type":"text","text":" "},{"type":"text","text":"comprehensive API for asynchronous I\/O, such"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.OutputStream.splice_async","type":"codeVoice"},{"text":"].  This makes ","type":"text"},{"type":"codeVoice","code":"GSubprocess"},{"text":" ","type":"text"},{"type":"text","text":"significantly more powerful and flexible than equivalent APIs in"},{"text":" ","type":"text"},{"type":"text","text":"some other languages such as the "},{"code":"subprocess.py","type":"codeVoice"},{"type":"text","text":" "},{"text":"included with Python.  For example, using ","type":"text"},{"type":"codeVoice","code":"GSubprocess"},{"type":"text","text":" one could"},{"text":" ","type":"text"},{"text":"create two child processes, reading standard output from the first,","type":"text"},{"type":"text","text":" "},{"text":"processing it, and writing to the input stream of the second, all","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"without blocking the main loop."}]},{"type":"paragraph","inlineContent":[{"text":"A powerful [method","type":"text"},{"type":"codeVoice","code":"Gio.Subprocess.communicate"},{"text":"] API is provided similar to the","type":"text"},{"text":" ","type":"text"},{"code":"communicate()","type":"codeVoice"},{"type":"text","text":" method of "},{"code":"subprocess.py","type":"codeVoice"},{"text":". This enables very easy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"interaction with a subprocess that has been opened with pipes."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GSubprocess"},{"type":"text","text":" defaults to tight control over the file descriptors open"},{"type":"text","text":" "},{"type":"text","text":"in the child process, avoiding dangling-FD issues that are caused by"},{"type":"text","text":" "},{"text":"a simple ","type":"text"},{"type":"codeVoice","code":"fork()```\/`exec()"},{"text":".  The only open file descriptors in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"spawned process are ones that were explicitly specified by the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GSubprocess"},{"text":" API (unless ","type":"text"},{"type":"codeVoice","code":"G_SUBPROCESS_FLAGS_INHERIT_FDS"},{"type":"text","text":" was"},{"type":"text","text":" "},{"type":"text","text":"specified)."}]},{"inlineContent":[{"code":"GSubprocess","type":"codeVoice"},{"text":" will quickly reap all child processes as they exit,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"avoiding ‘zombie processes’ remaining around for long periods of"},{"text":" ","type":"text"},{"type":"text","text":"time.  [method"},{"type":"codeVoice","code":"Gio.Subprocess.wait"},{"text":"] can be used to wait for this to happen,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"but it will happen even without the call being explicitly made."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As a matter of principle, "},{"type":"codeVoice","code":"GSubprocess"},{"text":" has no API that accepts","type":"text"},{"type":"text","text":" "},{"text":"shell-style space-separated strings.  It will, however, match the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"typical shell behaviour of searching the "},{"code":"PATH","type":"codeVoice"},{"type":"text","text":" for executables that do"},{"type":"text","text":" "},{"text":"not contain a directory separator in their name. By default, the ","type":"text"},{"code":"PATH","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"of the current process is used.  You can specify"},{"type":"text","text":" "},{"type":"codeVoice","code":"G_SUBPROCESS_FLAGS_SEARCH_PATH_FROM_ENVP"},{"text":" to use the ","type":"text"},{"type":"codeVoice","code":"PATH"},{"text":" of the","type":"text"},{"text":" ","type":"text"},{"text":"launcher environment instead.","type":"text"}]},{"inlineContent":[{"code":"GSubprocess","type":"codeVoice"},{"type":"text","text":" attempts to have a very simple API for most uses (ie:"},{"text":" ","type":"text"},{"text":"spawning a subprocess with arguments and support for most typical","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"kinds of input and output redirection).  See [ctor"},{"code":"Gio.Subprocess.new","type":"codeVoice"},{"type":"text","text":"]. The"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessLauncher","isActive":true},{"type":"text","text":"] API is provided for more complicated cases"},{"type":"text","text":" "},{"text":"(advanced types of redirection, environment variable manipulation,","type":"text"},{"type":"text","text":" "},{"text":"change of working directory, child setup functions, etc).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A typical use of "},{"type":"codeVoice","code":"GSubprocess"},{"text":" will involve calling","type":"text"},{"type":"text","text":" "},{"text":"[ctor","type":"text"},{"code":"Gio.Subprocess.new","type":"codeVoice"},{"type":"text","text":"], followed by [method"},{"code":"Gio.Subprocess.wait_async","type":"codeVoice"},{"type":"text","text":"] or"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.Subprocess.wait"},{"text":"].  After the process exits, the status can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"checked using functions such as [method"},{"code":"Gio.Subprocess.get_if_exited","type":"codeVoice"},{"type":"text","text":"] (which"},{"type":"text","text":" "},{"text":"are similar to the familiar ","type":"text"},{"type":"codeVoice","code":"WIFEXITED"},{"type":"text","text":"-style POSIX macros)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note that as of GLib 2.82, creating a ","type":"text"},{"type":"codeVoice","code":"GSubprocess"},{"type":"text","text":" causes the signal"},{"text":" ","type":"text"},{"type":"codeVoice","code":"SIGPIPE"},{"text":" to be ignored for the remainder of the program. If you are writing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a command-line utility that uses "},{"type":"codeVoice","code":"GSubprocess"},{"type":"text","text":", you may need to take into"},{"type":"text","text":" "},{"type":"text","text":"account the fact that your program will not automatically be killed"},{"type":"text","text":" "},{"type":"text","text":"if it tries to write to "},{"code":"stdout","type":"codeVoice"},{"type":"text","text":" after it has been closed."}]},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessRef"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"code":"GSubprocess","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol","isActive":true},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessRef","isActive":true},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GSubprocess","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Subprocess"},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessRef"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GSubprocess"},{"text":" instance.","type":"text"}]}]}]}],"schemaVersion":{