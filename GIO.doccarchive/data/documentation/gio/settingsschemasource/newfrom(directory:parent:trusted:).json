{"abstract":[{"text":"Attempts to create a new schema source corresponding to the contents","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the given directory."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSource"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSource\/newFrom(directory:parent:trusted:)"},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"newFrom","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SettingsSchemaSourceT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"directory","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"parent"},{"kind":"text","text":": "},{"text":"SettingsSchemaSourceT","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"trusted","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:3GIO20SettingsSchemaSourceC","text":"SettingsSchemaSource","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSource"},{"text":"! ","kind":"text"},{"kind":"keyword","text":"where"},{"text":" ","kind":"text"},{"text":"SettingsSchemaSourceT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"SettingsSchemaSourceProtocol","preciseIdentifier":"s:3GIO28SettingsSchemaSourceProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceProtocol","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"This function is not required for normal uses of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings"},{"type":"text","text":" but it"},{"text":" ","type":"text"},{"type":"text","text":"may be useful to authors of plugin management systems."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The directory should contain a file called "},{"type":"codeVoice","code":"gschemas.compiled"},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"produced by the "},{"identifier":"#glib-compile-schemas","isActive":true,"type":"reference"},{"text":" tool.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"trusted","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" then "},{"type":"codeVoice","code":"gschemas.compiled"},{"text":" is trusted not to be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"corrupted. This assumption has a performance advantage, but can result"},{"text":" ","type":"text"},{"type":"text","text":"in crashes or inconsistent behaviour in the case of a corrupted file."},{"text":" ","type":"text"},{"text":"Generally, you should set ","type":"text"},{"type":"codeVoice","code":"trusted"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" for files installed by the"},{"type":"text","text":" "},{"type":"text","text":"system and to "},{"type":"codeVoice","code":"false"},{"type":"text","text":" for files in the home directory."}]},{"inlineContent":[{"text":"In either case, an empty file or some types of corruption in the file will","type":"text"},{"type":"text","text":" "},{"text":"result in [inval](\/\/documentation\/glib\/inval being returned.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"parent","type":"codeVoice"},{"type":"text","text":" is non-"},{"type":"codeVoice","code":"nil"},{"text":" then there are two effects.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"First, if "},{"type":"codeVoice","code":"g_settings_schema_source_lookup()"},{"text":" is called with the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"recursive"},{"type":"text","text":" flag set to "},{"type":"codeVoice","code":"true"},{"text":" and the schema can not be found in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source, the lookup will recurse to the parent."}]},{"type":"paragraph","inlineContent":[{"text":"Second, any references to other schemas specified within this","type":"text"},{"type":"text","text":" "},{"text":"source (ie: ","type":"text"},{"type":"codeVoice","code":"child"},{"text":" or ","type":"text"},{"code":"extends","type":"codeVoice"},{"type":"text","text":") references may be resolved"},{"type":"text","text":" "},{"text":"from the ","type":"text"},{"type":"codeVoice","code":"parent"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For this second reason, except in very unusual situations, the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"parent"},{"text":" should probably be given as the default schema source, as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"returned by "},{"type":"codeVoice","code":"g_settings_schema_source_get_default()"},{"text":".","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingsschemasource\/newfrom(directory:parent:trusted:)"]}],"metadata":{"roleHeading":"Type Method","fragments":[{"text":"static","kind":"keyword"},{"