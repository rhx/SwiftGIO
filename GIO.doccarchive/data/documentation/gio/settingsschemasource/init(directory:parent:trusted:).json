{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSource\/init(directory:parent:trusted:)"},"abstract":[{"text":"Attempts to create a new schema source corresponding to the contents","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the given directory."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/settingsschemasource\/init(directory:parent:trusted:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"SettingsSchemaSourceT"},{"kind":"text","text":">("},{"text":"directory","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"parent"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"SettingsSchemaSourceT"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"trusted"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SettingsSchemaSourceT","kind":"typeIdentifier"},{"kind":"text","text":" : "},{"text":"SettingsSchemaSourceProtocol","preciseIdentifier":"s:3GIO28SettingsSchemaSourceProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaSourceProtocol","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function is not required for normal uses of "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","type":"reference"},{"type":"text","text":" but it"},{"text":" ","type":"text"},{"type":"text","text":"may be useful to authors of plugin management systems."}]},{"type":"paragraph","inlineContent":[{"text":"The directory should contain a file called ","type":"text"},{"code":"gschemas.compiled","type":"codeVoice"},{"text":" as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"produced by the "},{"identifier":"#glib-compile-schemas","type":"reference","isActive":true},{"text":" tool.","type":"text"}]},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"trusted"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" then ","type":"text"},{"code":"gschemas.compiled","type":"codeVoice"},{"type":"text","text":" is trusted not to be"},{"type":"text","text":" "},{"type":"text","text":"corrupted. This assumption has a performance advantage, but can result"},{"text":" ","type":"text"},{"type":"text","text":"in crashes or inconsistent behaviour in the case of a corrupted file."},{"type":"text","text":" "},{"type":"text","text":"Generally, you should set "},{"type":"codeVoice","code":"trusted"},{"type":"text","text":" to "},{"code":"true","type":"codeVoice"},{"type":"text","text":" for files installed by the"},{"text":" ","type":"text"},{"text":"system and to ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" for files in the home directory.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In either case, an empty file or some types of corruption in the file will"},{"type":"text","text":" "},{"text":"result in [inval](\/\/documentation\/glib\/inval being returned.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"parent"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"text":" then there are two effects.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"First, if "},{"type":"codeVoice","code":"g_settings_schema_source_lookup()"},{"type":"text","text":" is called with the"},{"text":" ","type":"text"},{"code":"recursive","type":"codeVoice"},{"type":"text","text":" flag set to "},{"code":"true","type":"codeVoice"},{"text":" and the schema can not be found in the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source, the lookup will recurse to the parent."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Second, any references to other schemas specified within this"},{"text":" ","type":"text"},{"text":"source (ie: ","type":"text"},{"type":"codeVoice","code":"child"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"extends"},{"type":"text","text":") references may be resolved"},{"text":" ","type":"text"},{"type":"text","text":"from the "},{"type":"codeVoice","code":"parent"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For this second reason, except in very unusual situations, the"},{"type":"text","text":" "},{"type":"codeVoice","code":"parent"},{"type":"text","text":" should probably be given as the default schema source, as"},{"type":"text","text":" "},{"type":"text","text":"returned by "},{"code":"g_settings_schema_source_get_default()","type":"codeVoice"},{"type":"text","text":"."}]}]}],"metadata":{"modules":[{"name":"GIO"}],"externalID":"s:3GIO20SettingsSchemaSourceC9directory6parent7trustedACSPys4Int8VGSg_xSgSbtKcAA0bcD8ProtocolRzlufc","role":"symbol","title":"init(directory:parent:trusted:)","roleHeading":"Initializer","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"<"},{"text":"SettingsSchemaSourceT","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"externalParam","text":"directory"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":