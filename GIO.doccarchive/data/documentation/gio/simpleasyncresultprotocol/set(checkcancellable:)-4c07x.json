","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"This function has one very specific purpose: the provided cancellable","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is checked at the time of "},{"type":"codeVoice","code":"g_simple_async_result_propagate_error()"},{"text":" If","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is cancelled, these functions will return an “Operation was"},{"type":"text","text":" "},{"type":"text","text":"cancelled” error ("},{"code":"cancelled","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Implementors of cancellable asynchronous functions should use this in","type":"text"},{"type":"text","text":" "},{"text":"order to provide a guarantee to their callers that cancelling an","type":"text"},{"type":"text","text":" "},{"text":"async operation will reliably result in an error being returned for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that operation (even if a positive result for the operation has"},{"text":" ","type":"text"},{"type":"text","text":"already been sent as an idle to the main context to be dispatched)."}],"type":"paragraph"},{"inlineContent":[{"text":"The checking described above is done regardless of any call to the","type":"text"},{"text":" ","type":"text"},{"text":"unrelated ","type":"text"},{"type":"codeVoice","code":"g_simple_async_result_set_handle_cancellation()"},{"type":"text","text":" function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"set_check_cancellable is deprecated:","type":"text"}]},{"text":" ","type":"text"},{"type":"text","text":"Use #GTask instead."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/simpleasyncresultprotocol\/set(checkcancellable:)-4c07x"]}],"references":{"doc://GIO/documentation/GIO/SimpleAsyncResultProtocol":{"url":