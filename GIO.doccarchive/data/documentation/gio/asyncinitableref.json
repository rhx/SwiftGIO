{"metadata":{"roleHeading":"Structure","title":"AsyncInitableRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncInitableRef"}],"modules":[{"name":"GIO"}],"externalID":"s:3GIO16AsyncInitableRefV","symbolKind":"struct","navigatorTitle":[{"text":"AsyncInitableRef","kind":"identifier"}]},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncInitableRef"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"This is the asynchronous version of [iface","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":"]; it behaves the same"},{"text":" ","type":"text"},{"type":"text","text":"in all ways except that initialization is asynchronous. For more details"},{"type":"text","text":" "},{"type":"text","text":"see the descriptions on "},{"type":"codeVoice","code":"GInitable"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A class may implement both the "},{"type":"codeVoice","code":"GInitable"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"GAsyncInitable"},{"text":" interfaces.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Users of objects implementing this are not intended to use the interface","type":"text"},{"type":"text","text":" "},{"type":"text","text":"method directly; instead it will be used automatically in various ways."},{"type":"text","text":" "},{"text":"For C applications you generally just call [func","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.new_async"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"directly, or indirectly via a "},{"code":"foo_thing_new_async()","type":"codeVoice"},{"type":"text","text":" wrapper. This will call"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"] under the covers, calling back with "},{"code":"NULL","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and a set ","type":"text"},{"type":"codeVoice","code":"GError"},{"type":"text","text":" on failure."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A typical implementation might look something like this:"}]},{"code":["enum {","   NOT_INITIALIZED,","   INITIALIZING,","   INITIALIZED","};","","static void","_foo_ready_cb (Foo *self)","{","  GList *l;","","  self->priv->state = INITIALIZED;","","  for (l = self->priv->init_results; l != NULL; l = l->next)","    {","      GTask *task = l->data;","","      if (self->priv->success)","        g_task_return_boolean (task, TRUE);","      else","        g_task_return_new_error (task, ...);","      g_object_unref (task);","    }","","  g_list_free (self->priv->init_results);","  self->priv->init_results = NULL;","}","","static void","foo_init_async (GAsyncInitable       *initable,","                int                   io_priority,","                GCancellable         *cancellable,","                GAsyncReadyCallback   callback,","                gpointer              user_data)","{","  Foo *self = FOO (initable);","  GTask *task;","","  task = g_task_new (initable, cancellable, callback, user_data);","  g_task_set_name (task, G_STRFUNC);","","  switch (self->priv->state)","    {","      case NOT_INITIALIZED:","        _foo_get_ready (self);","        self->priv->init_results = g_list_append (self->priv->init_results,","                                                  task);","        self->priv->state = INITIALIZING;","        break;","      case INITIALIZING:","        self->priv->init_results = g_list_append (self->priv->init_results,","                                                  task);","        break;","      case INITIALIZED:","        if (!self->priv->success)","          g_task_return_new_error (task, ...);","        else","          g_task_return_boolean (task, TRUE);","        g_object_unref (task);","        break;","    }","}","","static gboolean","foo_init_finish (GAsyncInitable       *initable,","                 GAsyncResult         *result,","                 GError              **error)","{","  g_return_val_if_fail (g_task_is_valid (result, initable), FALSE);","","  return g_task_propagate_boolean (G_TASK (result), error);","}","","static void","foo_async_initable_iface_init (gpointer g_iface,","                               gpointer data)","{","  GAsyncInitableIface *iface = g_iface;","","  iface->init_async = foo_init_async;","  iface->init_finish = foo_init_finish;","}"],"type":"codeListing","syntax":"c"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitableRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitableProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitableRef"},{"text":" only as an ","type":"text"},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"ide