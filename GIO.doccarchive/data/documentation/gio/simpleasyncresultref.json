{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"As of GLib 2.46, "},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":" is deprecated in favor of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Task","isActive":true,"type":"reference"},{"type":"text","text":"], which provides a simpler API."}],"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(_:)-1b96p","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(_:)-2vgaz","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(_:)-3azhl","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(_:)-907xv","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(_:)-vqg6","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(error:callback:userData:error:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(sourceObject:callback:userData:sourceTag:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(take_error:callback:userData:error:)"]},{"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/ptr"],"generated":true},{"generated":true,"title":"Type Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/newFrom(error:callback:userData:error:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/newTakeError(take_error:callback:userData:error:)","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/unowned(_:)"],"anchor":"Type-Methods"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/AsyncResultProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/GWeakCapturing-Implementations","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/ObjectProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/SimpleAsyncResultProtocol-Implementations"],"title":"Default Implementations"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef"},"variants":[{"paths":["\/documentation\/gio\/simpleasyncresultref"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"externalID":"s:3GIO20SimpleAsyncResultRefV","roleHeading":"Structure","symbolKind":"struct","title":"SimpleAsyncResultRef","navigatorTitle":[{"kind":"identifier","text":"SimpleAsyncResultRef"}],"modules":[{"name":"GIO"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SimpleAsyncResultRef","kind":"identifier"}],"role":"symbol"},"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/GIO\/documentation\/GIO\/AsyncResultProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol"],"kind":"relationships","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SimpleAsyncResultRef"}],"platforms":["macOS"]}]},{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":" implements [iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","type":"reference"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":" handles [type"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","isActive":true},{"text":"]s, error","type":"text"},{"text":" ","type":"text"},{"text":"reporting, operation cancellation and the final state of an operation,","type":"text"},{"text":" ","type":"text"},{"text":"completely transparent to the application. Results can be returned","type":"text"},{"type":"text","text":" "},{"text":"as a pointer e.g. for functions that return data that is collected","type":"text"},{"type":"text","text":" "},{"type":"text","text":"asynchronously, a boolean value for checking the success or failure"},{"type":"text","text":" "},{"text":"of an operation, or a ","type":"text"},{"code":"gssize","type":"codeVoice"},{"type":"text","text":" for operations which return the number"},{"type":"text","text":" "},{"type":"text","text":"of bytes modified by the operation; all of the simple return cases"},{"text":" ","type":"text"},{"type":"text","text":"are covered."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Most of the time, an application will not need to know of the details"},{"type":"text","text":" "},{"text":"of this API; it is handled transparently, and any necessary operations","type":"text"},{"text":" ","type":"text"},{"text":"are handled by [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","isActive":true,"type":"reference"},{"text":"]’s interface. However, if implementing","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a new GIO module, for writing language bindings, or for complex"},{"text":" ","type":"text"},{"text":"applications that need better control of how asynchronous operations","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are completed, it is important to understand this functionality."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":"s are tagged with the calling function to ensure"},{"text":" ","type":"text"},{"type":"text","text":"that asynchronous functions and their finishing functions are used"},{"text":" ","type":"text"},{"type":"text","text":"together correctly."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a new "},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":", call [ctor"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.new"},{"text":"].","type":"text"},{"type":"text","text":" "},{"type":"text","text":"If the result needs to be created for a "},{"code":"GError","type":"codeVoice"},{"text":", use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[ctor"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.new_from_error"},{"type":"text","text":"] or"},{"type":"text","text":" "},{"type":"text","text":"[ctor"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.new_take_error"},{"type":"text","text":"]. If a "},{"type":"codeVoice","code":"GError"},{"type":"text","text":" is not available"},{"type":"text","text":" "},{"type":"text","text":"(e.g. the asynchronous operation doesn’t take a "},{"type":"codeVoice","code":"GError"},{"text":" argument),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but the result still needs to be created for an error condition, use"},{"type":"text","text":" "},{"type":"text","text":"[ctor"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.new_error"},{"text":"] (or","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.set_error_va"},{"text":"] if your application or binding","type":"text"},{"type":"text","text":" "},{"type":"text","text":"requires passing a variable argument list directly), and the error can then"},{"type":"text","text":" "},{"text":"be propagated through the use of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.SimpleAsyncResult.propagate_error","type":"codeVoice"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"An asynchronous operation can be made to ignore a cancellation event by"},{"type":"text","text":" "},{"text":"calling [method","type":"text"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.set_handle_cancellation"},{"text":"] with a","type":"text"},{"type":"text","text":" "},{"code":"GSimpleAsyncResult","type":"codeVoice"},{"text":" for the operation and ","type":"text"},{"code":"FALSE","type":"codeVoice"},{"text":". This is useful for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operations that are dangerous to cancel, such as close (which would"},{"type":"text","text":" "},{"type":"text","text":"cause a leak if cancelled before being run)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"GSimpleAsyncResult","type":"codeVoice"},{"text":" can integrate into GLib’s event loop,","type":"text"},{"type":"text","text":" "},{"text":"[type[MainLoop](\/\/documentation\/glib\/mainloop], or it can use [type[Thread](\/\/documentation\/glib\/thread]s.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.complete"},{"type":"text","text":"] will finish an I\/O task directly"},{"type":"text","text":" "},{"text":"from the point where it is called.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.complete_in_idle"},{"type":"text","text":"] will finish it from an idle"},{"type":"text","text":" "},{"text":"handler in the  thread-default main context (see","type":"text"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"type":"text","text":"]) where the "},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":" "},{"type":"text","text":"was created. [method"},{"code":"Gio.SimpleAsyncResult.run_in_thread","type":"codeVoice"},{"text":"] will run the job in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a separate thread and then use"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.complete_in_idle"},{"type":"text","text":"] to deliver the result."}]},{"inlineContent":[{"type":"text","text":"To set the results of an asynchronous function,"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.SimpleAsyncResult.set_op_res_gpointer","type":"codeVoice"},{"type":"text","text":"],"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.set_op_res_gboolean"},{"text":"], and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.set_op_res_gssize"},{"text":"]","type":"text"},{"type":"text","text":" "},{"text":"are provided, setting the operation’s result to a ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"gboolean"},{"text":", or","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"gssize"},{"text":", respectively.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Likewise, to get the result of an asynchronous function,"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"Gio.SimpleAsyncResult.get_op_res_gpointer","type":"codeVoice"},{"text":"],","type":"text"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.SimpleAsyncResult.get_op_res_gboolean","type":"codeVoice"},{"text":"], and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.SimpleAsyncResult.get_op_res_gssize"},{"text":"] are","type":"text"},{"text":" ","type":"text"},{"text":"provided, getting the operation’s result as a ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"gboolean"},{"text":", and","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"gssize"},{"text":", respectively.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For the details of the requirements implementations must respect, see","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncResult","isActive":true,"type":"reference"},{"text":"].  A typical implementation of an asynchronous","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation using "},{"code":"GSimpleAsyncResult","type":"codeVoice"},{"text":" looks something like this:","type":"text"}]},{"code":["static void","baked_cb (Cake    *cake,","          gpointer user_data)","{","  \/\/ In this example, this callback is not given a reference to the cake,","  \/\/ so the GSimpleAsyncResult has to take a reference to it.","  GSimpleAsyncResult *result = user_data;","","  if (cake == NULL)","    g_simple_async_result_set_error (result,","                                     BAKER_ERRORS,","                                     BAKER_ERROR_NO_FLOUR,","                                     \"Go to the supermarket\");","  else","    g_simple_async_result_set_op_res_gpointer (result,","                                               g_object_ref (cake),","                                               g_object_unref);","","","  \/\/ In this example, we assume that baked_cb is called as a callback from","  \/\/ the mainloop, so it's safe to complete the operation synchronously here.","  \/\/ If, however, _baker_prepare_cake () might call its callback without","  \/\/ first returning to the mainloop — inadvisable, but some APIs do so —","  \/\/ we would need to use `g_simple_async_result_complete_in_idle()`.","  g_simple_async_result_complete (result);","  g_object_unref (result);","}","","void","baker_bake_cake_async (Baker              *self,","                       guint               radius,","                       GAsyncReadyCallback callback,","                       gpointer            user_data)","{","  GSimpleAsyncResult *simple;","  Cake               *cake;","","  if (radius < 3)","    {","      g_simple_async_report_error_in_idle (G_OBJECT (self),","                                           callback,","                                           user_data,","                                           BAKER_ERRORS,","                                           BAKER_ERROR_TOO_SMALL,","                                           \"`ucm` radius cakes are silly\",","                                           radius);","      return;","    }","","  simple = g_simple_async_result_new (G_OBJECT (self),","                                      callback,","                                      user_data,","                                      baker_bake_cake_async);","  cake = _baker_get_cached_cake (self, radius);","","  if (cake != NULL)","    {","      g_simple_async_result_set_op_res_gpointer (simple,","                                                 g_object_ref (cake),","                                                 g_object_unref);","      g_simple_async_result_complete_in_idle (simple);","      g_object_unref (simple);","      \/\/ Drop the reference returned by `_baker_get_cached_cake()`;","      \/\/ the GSimpleAsyncResult has taken its own reference.","      g_object_unref (cake);","      return;","    }","","  _baker_prepare_cake (self, radius, baked_cb, simple);","}","","Cake *","baker_bake_cake_finish (Baker        *self,","                        GAsyncResult *result,","                        GError      **error)","{","  GSimpleAsyncResult *simple;","  Cake               *cake;","","  g_return_val_if_fail (g_simple_async_result_is_valid (result,","                                                        G_OBJECT (self),","                                                        baker_bake_cake_async),","                        NULL);","","  simple = (GSimpleAsyncResult *) result;","","  if (g_simple_async_result_propagate_error (simple, error))","    return NULL;","","  cake = CAKE (g_simple_async_result_get_op_res_gpointer (simple));","  return g_object_ref (cake);","}"],"type":"codeListing","syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef","isActive":true,"type":"reference"},{"type":"text","text":" only as an "},{"code":"unowned","type":"codeVoice"},{"text":" reference to an existing ","type":"text"},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":" instance."}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResult","isActive":true},{"text":" (instead of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef","type":"reference"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GSimpleAsyncResult"},{"type":"text","text":" instance."}],"type":"paragraph"}]}],"kind":"content"}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/SimpleAsyncResultRef/newTakeError(take_error:callback:userData:error:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/newTakeError(take_error:callback:userData:error:)","kind":"symbol","url":"\/documentation\/gio\/simpleasyncresultref\/newtakeerror(take_error:callback:userdata:error:)","title":"newTakeError(take_error:callback:userData:error:)","type":"topic","abstract":[{"text":"Creates a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResult","type":"reference"},{"type":"text","text":" from an error condition, and takes over the"},{"type":"text","text":" "},{"type":"text","text":"caller’s ownership of "},{"type":"codeVoice","code":"error"},{"text":", so the caller does not need to free it anymore.","type":"text"}],"deprecated":true,"fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"newTakeError"},{"kind":"text","text":"<"},{"text":"GLibGLibErrorT","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"GObjectObjectT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"take_error"},{"kind":"text","text":": "},{"text":"GObjectObjectT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?, "},{"text":"error","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GLibGLibErrorT","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:3GIO20SimpleAsyncResultRefV","text":"SimpleAsyncResultRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"role":"symbol"},"doc://GIO/documentation/GIO/SimpleAsyncResultRef/init(_:)-907xv":{"title":"init(_:)","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(_:)-907xv","url":"\/documentation\/gio\/simpleasyncresultref\/init(_:)-907xv","fragments":[{"text":"init","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GSimpleAsyncResult"},{"kind":"text","text":">)"}],"role":"symbol","kind":"symbol","abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type"}]},"doc://GIO/documentation/GIO/SimpleAsyncResultRef/init(gconstpointer:)":{"url":"\/documentation\/gio\/simpleasyncresultref\/init(gconstpointer:)","type":"topic","role":"symbol","abstract":[{"text":"Conditional initialiser from an optional, non-mutable ","type":"text"},{"type":"codeVoice","code":"gconstpointer"}],"title":"init(gconstpointer:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/init(gconstpointer:)","fragments":[{"kind":"identifier","text":"init"},{"text":"!(","kind":"text"},{"text":"gconstpointer","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gconstpointer","preciseIdentifier":"c:gtypes.h@T@gconstpointer"},{"text":"?)","kind":"text"}],"kind":"symbol"},"doc://GIO/documentation/GIO/AsyncReadyCallback":{"navigatorTitle":[{"kind":"identifier","text":"AsyncReadyCallback"}],"title":"AsyncReadyCallback","abstract":[{"text":"Type definition for a function that will be called back when an asynchronous","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation within GIO has been completed. "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"callbacks from "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"text":" are guaranteed to be invoked in a later","type":"text"},{"type":"text","text":" "},{"text":"iteration of the thread-default main context","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(see [method"},{"code":"GLib.MainContext.push_thread_default","type":"codeVoice"},{"text":"])","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Task"},{"type":"text","text":" was created. All other users of"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","isActive":true,"type":"reference"},{"type":"text","text":" must likewise call it asynchronously in a"},{"text":" ","type":"text"},{"text":"later iteration of the main context.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AsyncReadyCallback"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncReadyCallback","url":"\/documentation\/gio\/asyncreadycallback"},"doc://GIO/documentation/GIO/SimpleAsyncResultRef/ptr":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultRef\/ptr","kind":"symbol","url":"\/documentation\/gio\/simpleasyncresultref\/ptr","title":"ptr","type":"topic","abstract":[{"text":"Untyped pointer to the underlying ","type":"text"},{"code":"GSimpleAsyncResult","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"For type-safe access, use the generated, typed pointer ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SimpleAsyncResultProtoco