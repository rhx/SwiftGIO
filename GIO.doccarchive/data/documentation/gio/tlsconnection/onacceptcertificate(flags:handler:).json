{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnection","doc:\/\/GIO\/documentation\/GIO\/TLSConnection\/TLSConnectionProtocol-Implementations"]]},"metadata":{"title":"onAcceptCertificate(flags:handler:)","externalID":"s:3GIO21TLSConnectionProtocolPAAE19onAcceptCertificate5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0B3RefV_AA014TLSCertificateM0VAA0nL0VtctF::SYNTHESIZED::s:3GIO13TLSConnectionC","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onAcceptCertificate","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"handler"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"TLSConnectionRef","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"kind":"text","text":", "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSCertificateRefV","text":"TLSCertificateRef"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","text":"TLSCertificateFlags","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"modules":[{"name":"GIO"}],"extendedModule":"GIO","symbolKind":"method","roleHeading":"Instance Method","role":"symbol"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:)"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection\/onAcceptCertificate(flags:handler:)","interfaceLanguage":"swift"},"abstract":[{"text":"Emitted during the TLS handshake after the peer certificate has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"been received. You can examine "},{"code":"peerCert","type":"codeVoice"},{"text":"’s certification path by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_tls_certificate_get_issuer()"},{"type":"text","text":" on it."}],"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onAcceptCertificate"},{"kind":"text","text":"("},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":" = ConnectFlags(0), "},{"kind":"externalParam","text":"handler"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:3GIO16TLSConnectionRefV","text":"TLSConnectionRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","kind":"typeIdentifier"},{"kind":"text","text":", "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","text":"TLSCertificateRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSCertificateRefV"},{"kind":"text","text":", "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","text":"TLSCertificateFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"true"},{"type":"text","text":" to accept "},{"type":"codeVoice","code":"peerCert"},{"text":" (which will also immediately end the signal emission). ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" to allow the signal emission to continue, which will cause the handshake to fail if no one else overrides it."},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"code":"acceptCertificate","type":"codeVoice"},{"type":"text","text":" signal is emitted"}],"type":"paragraph"}],"name":"handler"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"For a client-side connection, "},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" is the server’s"},{"type":"text","text":" "},{"type":"text","text":"certificate, and the signal will only be emitted if the"},{"text":" ","type":"text"},{"text":"certificate was not acceptable according to ","type":"text"},{"code":"conn","type":"codeVoice"},{"text":"’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","type":"reference"},{"type":"text","text":". If you would like the"},{"text":" ","type":"text"},{"text":"certificate to be accepted despite ","type":"text"},{"code":"errors","type":"codeVoice"},{"type":"text","text":", return "},{"code":"true","type":"codeVoice"},{"type":"text","text":" from the"},{"type":"text","text":" "},{"type":"text","text":"signal handler. Otherwise, if no handler accepts the certificate,"},{"type":"text","text":" "},{"type":"text","text":"the handshake will fail with "},{"code":"badCertificate","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"GLib guarantees that if certificate verification fails, this signal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be emitted with at least one error will be set in "},{"code":"errors","type":"codeVoice"},{"type":"text","text":", but"},{"type":"text","text":" "},{"text":"it does not guarantee that all possible errors will be set.","type":"text"},{"text":" ","type":"text"},{"text":"Accordingly, you may not safely decide to ignore any particular","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"text":" ","type":"text"},{"type":"codeVoice","code":"expired"},{"type":"text","text":" if you want to allow expired"},{"text":" ","type":"text"},{"text":"certificates, because this could potentially be the only error flag","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"set even if other problems exist with the certificate."}]},{"type":"paragraph","inlineContent":[{"text":"For a server-side connection, ","type":"text"},{"type":"codeVoice","code":"peerCert"},{"text":" is the certificate","type":"text"},{"type":"text","text":" "},{"type":"text","text":"presented by the client, if this was requested via the server’s"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference","isActive":true},{"text":". On the server side,","type":"text"},{"text":" ","type":"text"},{"text":"the signal is always emitted when the client presents a","type":"text"},{"text":" ","type":"text"},{"text":"certificate, and the certificate will only be accepted if a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handler returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"type":"text","text":" "},{"text":"in the main thread, then you should not attempt to interact with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the user before returning from the signal handler. If you want to"},{"text":" ","type":"text"},{"type":"text","text":"let the user decide whether or not to accept the certificate, you"},{"text":" ","type":"text"},{"type":"text","text":"would have to return "},{"code":"false","type":"codeVoice"},{"text":" from the signal handler on the first","type":"text"},{"type":"text","text":" "},{"type":"text","text":"attempt, and then after the connection attempt returns a"},{"type":"text","text":" "},{"code":"badCertificate","type":"codeVoice"},{"type":"text","text":", you can interact with the user, and"},{"type":"text","text":" "},{"text":"if the user decides to accept the certificate, remember that fact,","type":"text"},{"type":"text","text":" "},{"text":"create a new connection, and return ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the signal handler"},{"type":"text","text":" "},{"text":"the next time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you are doing I\/O in another thread, you do not"},{"type":"text","text":" "},{"text":"need to worry about this, and can simply block in the signal","type":"text"},{"type":"text","text":" "},{"text":"handler until the UI thread returns an answer.","type":"text"}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"accept-certificate"},{"type":"text","text":" signal"}],"type":"paragraph"}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO/TLSConnection/TLSConnectionProtocol-Implementations":{"role":"collectionGroup","url":"\/documentation\/gio\/tlsconnection\/tlsconnectionprotocol-implementations","title":"TLSConnectionProtocol Implementations","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection\/TLSConnectionProtocol-Implementations","type":"topic","kind":"article"},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSSe