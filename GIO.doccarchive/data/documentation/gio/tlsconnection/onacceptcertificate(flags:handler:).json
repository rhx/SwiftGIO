":"IOStream","navigatorTitle":[{"text":"IOStream","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOStream"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GIOStream"},{"type":"text","text":" represents an object that has both read and write streams."},{"text":" ","type":"text"},{"text":"Generally the two streams act as separate input and output streams,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"but they share some common resources and state. For instance, for"},{"type":"text","text":" "},{"type":"text","text":"seekable streams, both streams may use the same position."}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSCertificateRef":{"abstract":[{"text":"A certificate used for TLS authentication and encryption.","type":"text"},{"text":" ","type":"text"},{"text":"This can represent either a certificate only (eg, the certificate","type":"text"},{"type":"text","text":" "},{"text":"received by a client from a server), or the combination of","type":"text"},{"type":"text","text":" "},{"text":"a certificate and a private key (which is needed when acting as a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference"},{"type":"text","text":"])."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TLSCertificateRef"}],"title":"TLSCertificateRef","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"TLSCertificateRef","kind":"identifier"}],"url":"\/documentation\/gio\/tlscertificateref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef"},"doc://GIO/documentation/GIO/TLSConnectionRef":{"type":"topic","url":"\/documentation\/gio\/tlsconnectionref","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"i