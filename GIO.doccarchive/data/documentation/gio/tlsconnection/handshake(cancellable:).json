{"metadata":{"roleHeading":"Instance Method","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"handshake","kind":"identifier"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"externalID":"s:3GIO21TLSConnectionProtocolPAAE9handshake11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO13TLSConnectionC","title":"handshake(cancellable:)","symbolKind":"method","extendedModule":"GIO"},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"handshake"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"On the client side, it is never necessary to call this method;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"although the connection needs to perform a handshake after"},{"type":"text","text":" "},{"text":"connecting (or after sending a “STARTTLS”-type command),","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" will handle this for you automatically when you try"},{"text":" ","type":"text"},{"type":"text","text":"to send or receive data on the connection. You can call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" manually if you want to know whether"},{"text":" ","type":"text"},{"type":"text","text":"the initial handshake succeeded or failed (as opposed to just"},{"type":"text","text":" "},{"text":"immediately trying to use ","type":"text"},{"type":"codeVoice","code":"conn"},{"text":" to read or write, in which case,","type":"text"},{"type":"text","text":" "},{"text":"if it fails, it may not be possible to tell if it failed before or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"after completing the handshake), but beware that servers may reject"},{"text":" ","type":"text"},{"text":"client authentication after the handshake has completed, so a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"successful handshake does not indicate the connection will be usable."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Likewise, on the server side, although a handshake is necessary at"},{"type":"text","text":" "},{"type":"text","text":"the beginning of the communication, you do not need to call this"},{"type":"text","text":" "},{"text":"function explicitly unless you want clearer error reporting.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Previously, calling "},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"text":" after the initial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"type":"text","text":" "},{"type":"text","text":"deprecated in GLib 2.60 because rehandshaking was removed from the"},{"type":"text","text":" "},{"type":"text","text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after"},{"type":"text","text":" "},{"type":"text","text":"the initial handshake will no longer do anything."}],"type":"paragraph"},{"inlineContent":[{"text":"When using a ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","type":"reference","isActive":true},{"text":" created by ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","type":"reference","isActive":true},{"type":"text","text":", the"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true},{"text":" performs the initial handshake, so calling this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"function manually is not recommended."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"[TLSConnection](\/\/documentation\/gio\/tlsconnection\/onacceptcertificate(flags:handler:) may be emitted during the","type":"text"},{"text":" ","type":"text"},{"text":"handshake.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection\/handshake(cancellable:)"},"sections":[],"abstract":[{"text":"Attempts a TLS handshake on ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":"."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSConnection","doc:\/\/GIO\/documentation\/GIO\/TLSConnection\/TLSConnectionProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsconnection\/handshake(cancellable:)"]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSConnection/TLSConnectionProtocol-Implementations":{"role":"collectionGroup","url":"\/documentation\/gio\/tlsconnection\/tlsco