"type":"codeVoice","code":"nVectors"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"type":"codeVoice","code":"vectors"},{"text":" is 0, returns 0 and","type":"text"},{"type":"text","text":" "},{"text":"does nothing.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"text":" ","type":"text"},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"type":"text","text":" "},{"type":"text","text":"can happen e.g. on a partial I\/O error, or if there is not enough"},{"text":" ","type":"text"},{"text":"storage in the stream. All writes block until at least one byte","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is written or an error occurs; 0 is never returned (unless"},{"text":" ","type":"text"},{"type":"codeVoice","code":"nVectors"},{"type":"text","text":" is 0 or the sum of all bytes in "},{"code":"vectors","type":"codeVoice"},{"type":"text","text":" is 0)."}]},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", then the operation can be cancelled by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"type":"text","text":"partial result will be returned, without an error."}],"type":"paragraph"},{"inlineContent":[{"text":"Some implementations of ","type":"text"},{"type":"codeVoice","code":"g_output_stream_writev()"},{"text":" may have limitations on the","type":"text"},{"type":"text","text":" "},{"text":"aggregate buffer size, and will return ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"text":" if these","type":"text"},{"type":"text","text":" "},{"text":"are exceeded. For example, when writing to a local file on UNIX platforms,","type":"text"},{"type":"text","text":" "},{"text":"the aggregate buffer size must not exceed ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"type":"text","text":" bytes."}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/OutputStreamRef/writev(vectors:nVectors:bytesWritten:cancellable:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamRef\/writev(vectors:nVectors:bytesWritten:cancellable:)","type":"topic","kind":"symbol","url":"\/documentation\/gio\/outputstreamref\/writev(vectors:nvectors:byteswritten:cancellable:)","title":"writev(vectors:nVectors:bytesWritten:cancellable:)","abstract":[{"type":"text","text":"Tries to write the bytes contained in the "},{"type":"codeVoice","code":"nVectors"},{"type":"text","text":" "},{"code":"vectors","type":"codeVoice"},{"text":" into the","type":"text"},{"type":"text","text":" "},{"text":"stream. Will block during the operation.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"writev"},{"kind":"text","text":"("},{"text":"vectors","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputVector"},{"text":">!, ","kind":"text"},{"text":"nVectors","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"by