{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Once the stream is closed, all other operations will return "},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"},{"type":"text","text":" "},{"text":"Closing a stream multiple times will not return an error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers in the","type":"text"},{"text":" ","type":"text"},{"text":"stream.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"text":" ","type":"text"},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"text":" ","type":"text"},{"text":"resources are released as early as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"text":" ","type":"text"},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"stream for details."}]},{"inlineContent":[{"type":"text","text":"On failure the first error that happened will be reported, but the close"},{"type":"text","text":" "},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"code":"closed","type":"codeVoice"},{"type":"text","text":" for all operations. Still, it"},{"text":" ","type":"text"},{"text":"is important to check and report the error to the user, otherwise","type":"text"},{"type":"text","text":" "},{"type":"text","text":"there might be a loss of data as all data might not be written."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but there some streams"},{"type":"text","text":" "},{"text":"can use a faster close that doesn’t block to e.g. check errors. On","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"type":"text","text":"data will reach the target."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/OutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/OutputStreamRef\/OutputStreamProtocol-Implementations"]]},"metadata":{"extendedModule":"GIO","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"symbolKind":"method","title":"close(cancellable:)","externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO15OutputStreamRefV"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"variants":[{"paths":["\/documentation\/gio\/outputstreamref\/close(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/OutputStreamRef/close(cancellable:)":{"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it."}],"url":"\/documentation\/gio\/outputstreamref\/close(cancellable:)","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamRef\/close(cancellable:)","title":"close(cancellable:)","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]},"doc://GIO/documentation/GIO/OutputStreamRef":{"abstract":[{"type":"codeVoice","code":"GOutputStream"},{"type":"text","text":" is a base class for implementing streaming output."}],"title":"OutputStreamRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OutputStreamRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamRef","role":"symbol","navigatorTitle":[{"text":"OutputStreamRef","kind":"identifier"}],"kind":"symbol","type":"topic","url":"\/documentation\/gio\/outputstreamref"},"doc://GIO/documentation/GIO/OutputStreamRef/OutputStreamProtocol-Implementations":{"type":"topic","kind":"article","title":"OutputStreamProtocol Implementations","abstract":[],"url":"\/documentation\/gio\/outputstreamref\/outputstreamprotocol-implementations","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStreamRef\/OutputStreamProtocol-Implementations"}}}