":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In that case, [method"},{"type":"codeVoice","code":"Gio.ActionGroup.get_action_state"},{"type":"text","text":"] will return "},{"type":"codeVoice","code":"NULL"},{"text":" ","type":"text"},{"text":"and you must not call [method","type":"text"},{"type":"codeVoice","code":"Gio.ActionGroup.change_action_state"},{"text":"].","type":"text"}]},{"inlineContent":[{"type":"text","text":"The state type of a particular action will never change but it is"},{"text":" ","type":"text"},{"type":"text","text":"possible for an action to be removed and for a new action to be added"},{"type":"text","text":" "},{"type":"text","text":"with the same name but a different state type."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"externalID":"s:3GIO19ActionGroupProtocolPAAE03getB9StateType10actionName4GLib07VariantG3RefVSgSPys4Int8VGSg_tF","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getActionStateType"},{"text":"(","kind":"text"},{"text":"actionName","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!) -> ","kind":"text"},{"text":"VariantTypeRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14VariantTypeRefV"},{"text":"!","kind":"text"}],"title":"getActionStateType(actionName:)","extendedModule":"GIO","symbolKind":"method"},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ActionGroupProtocol\/getActionStateType(actionName:)","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/actiongroupprotocol\/getactionstatetype(actionname:)"],"traits":[{"interfaceLanguage":"swift"}]}],"re