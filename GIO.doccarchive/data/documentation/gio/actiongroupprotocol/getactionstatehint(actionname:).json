he hinted range and setting a value","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"within the range may fail."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The return value (if non-"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":") should be freed with"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GLib.Variant.unref"},{"text":"] when it is no longer required.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ActionGroupProtocol"]]},"sections":[],"abstract":[{"text":"Requests a hint about the valid range of values for the state of the","type":"text"},{"text":" ","type":"text"},{"text":"named action within ","type":"text"},{"code":"actionGroup","type":"codeVoice"},{"text":".","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/actiongroupprotocol\/getactionstatehint(actionname:)"]}],"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"title":"getActionStateHint(actionName:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getActionStateHint","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"actionName"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!) -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"text":"!","kind":"text"}],"extendedModule":"GIO","roleHeading":"Instance Method","externalID":"s:3GIO19ActionGroupProtocolPAAE03getB9StateHint10actionName4GLib10VariantRefVSgSPys4Int8VGSg_tF","symbolKind":"method"},"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GIO/documentation/GIO/ActionGroupProtocol":{"role":"sym