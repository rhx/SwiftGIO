{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketServiceRef","doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketServiceRef\/SocketServiceProtocol-Implementations"]]},"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketServiceRef\/stop()","interfaceLanguage":"swift"},"metadata":{"title":"stop()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"stop","kind":"identifier"},{"kind":"text","text":"()"}],"externalID":"s:3GIO21SocketServiceProtocolPAAE4stopyyF::SYNTHESIZED::s:3GIO24ThreadedSocketServiceRefV","extendedModule":"GIO","role":"symbol","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","symbolKind":"method"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/threadedsocketserviceref\/stop()"]}],"abstract":[{"type":"text","text":"Stops the service, i.e. stops accepting connections"},{"type":"text","text":" "},{"text":"from the added sockets when the mainloop runs.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"stop","kind":"identifier"},{"kind":"text","text":"()"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"This call is thread-safe, so it may be called from a thread","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handling an incoming client request."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that this only stops accepting new connections; it does not"},{"type":"text","text":" "},{"text":"close the listening sockets, and you can call","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_service_start()"},{"type":"text","text":" again later to begin listening again. To"},{"type":"text","text":" "},{"text":"close the listening sockets, call ","type":"text"},{"type":"codeVoice","code":"g_socket_listener_close()"},{"text":". (This","type":"text"},{"text":" ","type":"text"},{"text":"will happen automatically when the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketService"},{"text":" is finalized.)","type":"text"}]},{"inlineContent":[{"type":"text","text":"This must be called before calling "},{"type":"codeVoice","code":"g_socket_listener_close()"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"the socket service will start accepting connections immediately"},{"type":"text","text":" "},{"type":"text","text":"when a new socket is added."}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/ThreadedSocketServiceRef":{"url":"\/documentation\/gio\/threadedsocketserviceref","title":"ThreadedSocketServiceRef","abstract":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GThreadedSocketService"},{"text":" is a simple subclass of [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketService","isActive":true},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"that handles incoming connections by creating a worker thread and","type":"text"},{"type":"text","text":" "},{"text":"dispatching the connection to it by emitting the","type":"text"},{"type":"text","text":" "},{"text":"[signal[ThreadedSocketService](\/\/documentation\/gio\/threadedsocketservice\/onrun(flags:handler:) signal] in the new thread.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ThreadedSocketServiceRef"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ThreadedSocketServiceRef","navigatorTitle":[{"text":"ThreadedSocketServiceRef","kind":"identifier"}],"kind":"symbol","role":"s