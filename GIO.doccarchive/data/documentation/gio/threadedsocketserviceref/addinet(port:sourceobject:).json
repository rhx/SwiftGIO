xt","text":"If listening on both fails, an error will be returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to distinguish whether listening on IPv4 or IPv6 or both was"},{"text":" ","type":"text"},{"type":"text","text":"successful, connect to [signal[SocketListener](\/\/documentation\/gio\/socketlistener\/onevent(flags:handler:)]."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sourceObject"},{"type":"text","text":" will be passed out in the various calls"},{"type":"text","text":" "},{"type":"text","text":"to accept to identify this particular source, which is"},{"text":" ","type":"text"},{"type":"text","text":"useful if you’re listening on multiple addresses and do"},{"type":"text","text":" "},{"text":"different things depending on what address is connected to.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Call "},{"code":"g_socket_listener_close()","type":"codeVoice"},{"type":"text","text":" to stop listening on "},{"type":"codeVoice","code":"port"},{"type":"text","text":"; this will not"},{"type":"text","text":" "},{"text":"be done automatically when you drop your final reference to ","type":"text"},{"code":"listener","type":"codeVoice"},{"text":", as","type":"text"},{"text":" ","type":"text"},{"text":"references may be held internally.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"metadata":{"extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addInet"},{"kind":"text","text":"("},{"text":"port","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@guint16","text":"guint16"},{"kind":"text","text":", "},{"kind":"externalParam","text":"sourceObject"},{"text":": ","kind":"text"},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":