{"metadata":{"externalID":"s:3GIO14MenuSignalNameO12itemsChangedyA2CmF","symbolKind":"case","modules":[{"name":"GIO"}],"title":"MenuSignalName.itemsChanged","roleHeading":"Case","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"itemsChanged"}]},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"variants":[{"paths":["\/documentation\/gio\/menusignalname\/itemschanged"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuSignalName"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuSignalName\/itemsChanged"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"itemsChanged","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The only changes that can occur to a menu is that items are removed"},{"text":" ","type":"text"},{"type":"text","text":"or added.  Items may not change (except by being removed and added"},{"type":"text","text":" "},{"type":"text","text":"back in the same location).  This signal is capable of describing"},{"type":"text","text":" "},{"type":"text","text":"both of those changes (at the same time)."}]},{"inlineContent":[{"text":"The signal means that starting at the index ","type":"text"},{"type":"codeVoice","code":"position"},{"text":", ","type":"text"},{"type":"codeVoice","code":"removed"},{"type":"text","text":" "},{"type":"text","text":"items were removed and "},{"type":"codeVoice","code":"added"},{"type":"text","text":" items were added in their place.  If"},{"text":" ","type":"text"},{"type":"codeVoice","code":"removed"},{"type":"text","text":" is zero then only items were added.  If "},{"code":"added","type":"codeVoice"},{"text":" is zero","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then only items were removed."}],"type":"paragraph"},{"inlineContent":[{"text":"As an example, if the menu contains items a, b, c, d (in that","type":"text"},{"text":" ","type":"text"},{"text":"order) and the signal (2, 1, 3) occurs then the new composition of","type":"text"},{"type":"text","text":" "},{"text":"the menu will be a, b, _, _, _, d (with each _ representing some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"new item)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Signal handlers may query the model (particularly the added items)","type":"text"},{"type":"text","text":" "},{"text":"and expect to see the results of the modification that is being","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reported.  The signal is emitted after the modification."}]}],"kind":"content"}],"abstract":[{"text":"Emitted when a change has occurred to the menu.","type":"text"}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuSignalName/itemsChanged":{"kind":"symbol","title":"MenuSignalName.itemsChanged","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuSignalName\/itemsChanged","abstract":[{"type":"text","text":"Emitted when a change has occurred to the menu."}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"itemsChanged"}],"role":"symbol","type":"topic","url":"\/documentation\/gio\/menusignalname\/itemschanged"},"doc://GIO/documentation/GIO/MenuSignalName":{"fragments":[{"text":"enum","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuSignalName","kind":"identifier"}],"role":"symbol","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuSignalName","kind":"symbol","url":"\/documentation\/gio\/menusignalname","title":"MenuSignalName","navigatorTitle":[{"text":"MenuSignalName","kind":"identifier"}],"type":"topic"}}}