{"metadata":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IOExtensionPointProtocol","kind":"identifier"}],"modules":[{"name":"GIO"}],"navigatorTitle":[{"kind":"identifier","text":"IOExtensionPointProtocol"}],"title":"IOExtensionPointProtocol","symbolKind":"protocol","roleHeading":"Protocol","externalID":"s:3GIO24IOExtensionPointProtocolP","role":"symbol"},"relationshipsSections":[{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP"],"title":"Inherits From","kind":"relationships","type":"inheritsFrom"},{"kind":"relationships","title":"Conforming Types","type":"conformingTypes","identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointRef"]}],"abstract":[{"type":"codeVoice","code":"GIOExtensionPoint"},{"text":" provides a mechanism for modules to extend the","type":"text"},{"type":"text","text":" "},{"text":"functionality of the library or application that loaded it in an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"organized fashion."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol\/extensions","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol\/requiredType"],"generated":true,"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"title":"Instance Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol\/getExtensionBy(name:)","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol\/getExtensions()","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol\/getRequiredType()","doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol\/setRequired(type:)"],"anchor":"Instance-Methods"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"IOExtensionPointProtocol"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:4GLib14PointerWrapperP","kind":"typeIdentifier","text":"PointerWrapper"}]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"inlineContent":[{"type":"text","text":"An extension point is identified by a name, and it may optionally"},{"text":" ","type":"text"},{"type":"text","text":"require that any implementation must be of a certain type (or derived"},{"text":" ","type":"text"},{"text":"thereof). Use [func","type":"text"},{"type":"codeVoice","code":"Gio.IOExtensionPoint.register"},{"type":"text","text":"] to register an"},{"text":" ","type":"text"},{"type":"text","text":"extension point, and [method"},{"type":"codeVoice","code":"Gio.IOExtensionPoint.set_required_type"},{"type":"text","text":"] to"},{"type":"text","text":" "},{"text":"set a required type.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A module can implement an extension point by specifying the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[type[Type_](\/\/documentation\/gobject\/type_] that implements the functionality. Additionally, each"},{"type":"text","text":" "},{"text":"implementation of an extension point has a name, and a priority. Use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"code":"Gio.IOExtensionPoint.implement","type":"codeVoice"},{"type":"text","text":"] to implement an extension point."}]},{"syntax":"c","code":["GIOExtensionPoint *ep;","","\/\/ Register an extension point","ep = g_io_extension_point_register (\"my-extension-point\");","g_io_extension_point_set_required_type (ep, MY_TYPE_EXAMPLE);"],"type":"codeListing"},{"type":"codeListing","syntax":"c","code":["\/\/ Implement an extension point","G_DEFINE_TYPE (MyExampleImpl, my_example_impl, MY_TYPE_EXAMPLE)","g_io_extension_point_implement (\"my-extension-point\",","                                my_example_impl_get_type (),","                                \"my-example\",","                                10);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is up to the code that registered the extension point how"},{"text":" ","type":"text"},{"type":"text","text":"it uses the implementations that have been associated with it."},{"type":"text","text":" "},{"text":"Depending on the use case, it may use all implementations, or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only the one with the highest priority, or pick a specific"},{"type":"text","text":" "},{"text":"one by name.","type":"text"}]},{"inlineContent":[{"text":"To avoid opening all modules just to find out what extension","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"points they implement, GIO makes use of a caching mechanism,"},{"text":" ","type":"text"},{"type":"text","text":"see "},{"isActive":true,"identifier":"gio-querymodules.html","type":"reference"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"You are expected to run this command after installing a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GIO module."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GIO_EXTRA_MODULES"},{"type":"text","text":" environment variable can be used to"},{"text":" ","type":"text"},{"type":"text","text":"specify additional directories to automatically load modules"},{"type":"text","text":" "},{"type":"text","text":"from. This environment variable has the same syntax as the"},{"type":"text","text":" "},{"type":"codeVoice","code":"PATH"},{"text":". If two modules have the same base name in different","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"directories, then the latter one will be ignored. If additional"},{"text":" ","type":"text"},{"text":"directories are specified GIO will load modules from the built-in","type":"text"},{"text":" ","type":"text"},{"text":"directory last.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"type":"codeVoice","code":"GIOExtensionPoint"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPoint"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointRef","isActive":true,"type":"reference"},{"type":"text","text":" as a lighweight, "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/ioextensionpointprotocol"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://GIO/documentation/GIO/IOExtensionPointProtocol/getExtensions()":{"url":"\/documentation\/gio\/ioextensionpointprotocol\/getextensions()","title":"getExtensions()","abstract":[{"type":"text","text":"Gets a list of all extensions that implement this extension point."},{"text":" ","type":"text"},{"text":"The list is sorted by priority, beginning with the highest priority.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOExtensionPointProtocol\/getExtensions()","kind":"symbol","role":"symbol","type":"topic","