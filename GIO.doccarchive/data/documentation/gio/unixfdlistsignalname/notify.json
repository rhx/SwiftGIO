e","code":"notify"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"text":"when they explicitly call ","type":"text"},{"type":"codeVoice","code":"g_object_notify()"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and common practice is to do that only when the value has actually changed."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This signal is typically used to obtain change notification for a"},{"text":" ","type":"text"},{"text":"single property, by specifying the property name as a detail in the","type":"text"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"text":" call, like this:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"detail strings for the notify signal."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"#class@GObject.ParamSpec#parameter-names":{"title":"canonical parameter names","url":"#class@GObject.ParamSpec#parameter-names","type":"link","titleInlineContent":[{"text":"canonical parameter names","type":"text"}],"identifier":"#class@GObje