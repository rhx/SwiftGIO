{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuRef","doc:\/\/GIO\/documentation\/GIO\/MenuRef\/MenuModelProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"itemsChanged","kind":"identifier"},{"kind":"text","text":"("},{"text":"position","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"removed","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"added"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This function should never be called except by ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel"},{"text":" ","type":"text"},{"text":"subclasses.  Any other calls to this function will very likely lead","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to a violation of the interface of the model."}]},{"inlineContent":[{"text":"The implementation should update its internal representation of the","type":"text"},{"type":"text","text":" "},{"text":"menu before emitting the signal.  The implementation should further","type":"text"},{"type":"text","text":" "},{"type":"text","text":"expect to receive queries about the new state of the menu (and"},{"type":"text","text":" "},{"text":"particularly added menu items) while signal handlers are running.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The implementation must dispatch this call directly from a mainloop"},{"type":"text","text":" "},{"text":"entry and not in response to calls – particularly those from the","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"type":"text","text":" API.  Said another way: the menu must not change while"},{"type":"text","text":" "},{"type":"text","text":"user code is running without returning to the mainloop."}]}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuRef\/itemsChanged(position:removed:added:)"},"abstract":[{"text":"Requests emission of the [MenuModel](\/\/documentation\/gio\/menumodel\/onitemschanged(flags:handler:) signal on ","type":"text"},{"type":"codeVoice","code":"model"},{"text":".","type":"text"}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/menuref\/itemschanged(position:removed:added:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","title":"itemsChanged(position:removed:added:)","extendedModule":"GIO","symbolKind":"method","roleHeading":"Instance Method","externalID":"s:3GIO17MenuModelProtocolPAAE12itemsChanged8position7removed5addedySi_S2itF::SYNTHESIZED::s:3GIO7MenuRefV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"itemsChanged"},{"text":"(","kind":"text"},{"text":"position","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"removed"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"added","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"modules":[{"name":"GIO"}]},"r