{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"remove"},{"kind":"text","text":"("},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":")"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"code":"position","type":"codeVoice"},{"text":" gives the index of the item to remove.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is an error if position is not in range the range from 0 to one"},{"text":" ","type":"text"},{"text":"less than the number of items in the menu.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is not possible to remove items by identity since items are added"},{"type":"text","text":" "},{"text":"to the menu simply by copying their links and attributes (ie:","type":"text"},{"type":"text","text":" "},{"type":"text","text":"identity of the item itself is not preserved)."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuRef\/remove(position:)"},"sections":[],"abstract":[{"type":"text","text":"Removes an item from the menu."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuRef","doc:\/\/GIO\/documentation\/GIO\/MenuRef\/MenuProtocol-Implementations"]]},"metadata":{"title":"remove(position:)","role":"symbol","externalID":"s:3GIO12MenuProtocolPAAE6remove8positionySi_tF::SYNTHESIZED::s:3GIO7MenuRefV","modules":[{"name":"GIO"}],"extendedModule":"GIO","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"remove"},{"kind":"text","text":"("},{"text":"position","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":")","kind":"text"}],"symbolKind":"method"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menuref\/remove(position:)"]}],"references":{"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]},"doc://GIO/documentation/GIO/MenuRef":{"role":"symbol","url":"\/documentation\/gio\/menuref","abstract":[{"code":"GMenu","type":"codeVoice"},{"type":"text","text":" is a simple implementation of [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference","isActive":true},{"type":"text","text":"]."},{"text":" ","type":"text"},{"text":"You populate a ","type":"text"},{"code":"GMenu","type":"codeVoice"},{"text":" by adding [class","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true},{"text":"] instances to it.","type":"text"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"MenuRef","kind":"identifier"}],"title":"MenuRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuRef","navigatorTitle":[{"text":"MenuRef","kind":"identifier"}],"type":"topic"},"doc://GIO/documentation/GIO/MenuRef/MenuProtocol-Implementations":{"title":"MenuProtocol Implementations","type":"topic","kind":"article","role":"collectionGroup","url":"\/documentation\/gio\/menuref\/menuprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuRef\/MenuProtocol-Implementations","abstract":[]},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuRef/remove(position:)":{"abstract":[{"text":"Removes an item from the menu.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"remove","kind":"identifier"},{"kind":"text","text":"("},{"text":"position","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":")"}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/menuref\/remove(position:)","type":"topic","identifier":"doc:\/\/GIO\/d