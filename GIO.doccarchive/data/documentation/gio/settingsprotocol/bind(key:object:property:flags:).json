":"codeVoice","code":"flags"},{"text":" include [flags","type":"text"},{"type":"codeVoice","code":"Gio.SettingsBindFlags.NO_SENSITIVITY"},{"text":"], this","type":"text"},{"text":" ","type":"text"},{"text":"function also establishes a binding between the writability of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"key"},{"text":" and the ","type":"text"},{"type":"codeVoice","code":"sensitive"},{"type":"text","text":" property of "},{"code":"object","type":"codeVoice"},{"type":"text","text":" (if "},{"type":"codeVoice","code":"object"},{"text":" has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"a boolean property by that name). See [method"},{"code":"Gio.Settings.bind_writable","type":"codeVoice"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"for more details about writable bindings."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that the lifecycle of the binding is tied to "},{"type":"codeVoice","code":"object"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"and that you can have only one binding per object property."},{"text":" ","type":"text"},{"text":"If you bind the same property twice on the same object, the second","type":"text"},{"type":"text","text":" "},{"text":"binding overrides the first one.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsProtocol"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingsprotocol\/bind(key:object:property:flags:)"]}],"kind":"symbol","abstract":[{"type":"text","text":"Create a binding between the "},{"code":"key","type":"codeVoice"},{"type":"text","text":" in the "},{"type":"codeVoice","code":"settings"},{"text":" object","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"and the property "},{"code":"property","type":"codeVoice"},{"type":"t