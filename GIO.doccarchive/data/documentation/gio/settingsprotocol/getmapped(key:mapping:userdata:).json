{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsProtocol\/getMapped(key:mapping:userData:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Gets the value that is stored at "},{"type":"codeVoice","code":"key"},{"type":"text","text":" in "},{"code":"settings","type":"codeVoice"},{"type":"text","text":", subject to"},{"type":"text","text":" "},{"text":"application-level validation\/mapping.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/settingsprotocol\/getmapped(key:mapping:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"role":"symbol","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getMapped","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"key"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"text":"mapping","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@GSettingsGetMapping","text":"GSettingsGetMapping","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?"}],"title":"getMapped(key:mapping:userData:)","extendedModule":"GIO","externalID":"s:3GIO16SettingsProtocolPAAE9getMapped3key7mapping8userDataSvSgSPys4Int8VGSg_s5Int32VSpySo9_GVariantVGSg_SpyAHGSgAHtXCAHtF","modules":[{"name":"GIO"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsProtocol"]]},"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getMapped","kind":"identifier"},{"kind":"text","text":"("},{"text":"key","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"text":"mapping","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSettingsGetMapping","text":"GSettingsGetMapping"},{"text":", ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil) -> "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"text":"You should use this function when the application needs to perform","type":"text"},{"type":"text","text":" "},{"type":"text","text":"some processing on the value of the key (for example, parsing).  The"},{"type":"text","text":" "},{"type":"codeVoice","code":"mapping"},{"type":"text","text":" function performs that processing.  If the function"},{"text":" ","type":"text"},{"text":"indicates that the processing was unsuccessful (due to a parse error,","type":"text"},{"text":" ","type":"text"},{"text":"for example) then the mapping is tried again with another value.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This allows a robust ‘fall back to defaults’ behaviour to be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"implemented somewhat automatically."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first value that is tried is the user’s setting for the key.  If"},{"type":"text","text":" "},{"text":"the mapping function fails to map this value, other values may be","type":"text"},{"text":" ","type":"text"},{"text":"tried in an unspecified order (system or site defaults, translated","type":"text"},{"text":" ","type":"text"},{"text":"schema default values, untranslated schema default values, etc).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the mapping function fails for all possible values, one additional"},{"type":"text","text":" "},{"type":"text","text":"attempt is made: the mapping function is called with a "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" value."},{"type":"text","text":" "},{"text":"If the mapping function still indicates failure at this point then","type":"text"},{"type":"text","text":" "},{"text":"the application will be aborted.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The result parameter for the "},{"code":"mapping","type":"codeVoice"},{"text":" function is pointed to a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"gpointer"},{"type":"text","text":" which is initially set to "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":".  The same pointer is given"},{"text":" ","type":"text"},{"text":"to each invocation of ","type":"text"},{"code":"mapping","type":"codeVoice"},{"text":".  The final value of that ","type":"text"},{"code":"gpointer","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"what is returned by this function.  "},{"code":"NULL","type":"codeVoice"},{"type":"text","text":" is valid; it is returned"},{"type":"text","text":" "},{"text":"just as any other value would be.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SettingsProtocol":{"navigatorTitle":[{"text":"SettingsProtocol","kind":"identifier"}],"title":"SettingsProtocol","abstract":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"GSettings"},{"text":" class provides a convenient API for storing and retrieving","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"application settings."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SettingsProtocol"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsProtocol","url":"\/documentation\/gio\/settingsprotocol"},"doc://GIO/documentation/GIO/SettingsProtocol/getMapped(key:mapping:userData:)":{"url":"\/documentation\/gio\/settingsprotocol\/getmapped(key:mapping:userdata:)","abstract":[{"type":"text","text":"Gets the value that is stored at "},{"type":"codeVoice","code":"key"},{"type":"text","text":" in "},{"code":"settings","type":"codeVoice"},{"type":"text","text":", subject to"},{"type":"text","text":" "},{"text":"application-level validation\/mapping.","type":"text"}],"kind":"symbol","title":"getMapped(key:mapping:userData:)","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getMapped","kind":"identifier"},{"text":"(","kind":"text"},{"text":"key","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"mapping"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSettingsGetMapping","text":"GSettingsGetMapping"},{"text":", ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?) -> "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsProtocol\/getMapped(key:mapping:userData:)"}}}