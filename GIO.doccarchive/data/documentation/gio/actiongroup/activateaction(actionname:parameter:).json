{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ActionGroup","doc:\/\/GIO\/documentation\/GIO\/ActionGroup\/ActionGroupProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup\/activateAction(actionName:parameter:)","interfaceLanguage":"swift"},"sections":[],"abstract":[{"text":"Activate the named action within ","type":"text"},{"code":"actionGroup","type":"codeVoice"},{"text":".","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/actiongroup\/activateaction(actionname:parameter:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"activateAction"},{"kind":"text","text":"("},{"text":"actionName","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"parameter"},{"kind":"text","text":": "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"kind":"text","text":"? = nil)"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"If the action is expecting a parameter, then the correct type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"parameter must be given as "},{"type":"codeVoice","code":"parameter"},{"type":"text","text":".  If the action is expecting no"},{"type":"text","text":" "},{"text":"parameters then ","type":"text"},{"type":"codeVoice","code":"parameter"},{"text":" must be ","type":"text"},{"code":"NULL","type":"codeVoice"},{"type":"text","text":".  See"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.ActionGroup.get_action_parameter_type"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the [type"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","isActive":true,"type":"reference"},{"type":"text","text":"] implementation supports asynchronous remote"},{"type":"text","text":" "},{"type":"text","text":"activation over D-Bus, this call may return before the relevant"},{"type":"text","text":" "},{"text":"D-Bus traffic has been sent, or any replies have been received. In","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"order to block on such asynchronous activation calls,"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"text":"] should be called prior to the code, which","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"depends on the result of the action activation. Without flushing"},{"type":"text","text":" "},{"text":"the D-Bus connection, there is no guarantee that the action would","type":"text"},{"type":"text","text":" "},{"text":"have been activated.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following code which runs in a remote app instance, shows an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example of a ‘quit’ action being activated on the primary app"},{"text":" ","type":"text"},{"type":"text","text":"instance over D-Bus. Here [method"},{"type":"codeVoice","code":"Gio.DBusConnection.flush"},{"text":"] is called","type":"text"},{"type":"text","text":" "},{"text":"before ","type":"text"},{"type":"codeVoice","code":"exit()"},{"text":". Without ","type":"text"},{"type":"codeVoice","code":"g_dbus_connection_flush()"},{"text":", the ‘quit’ action","type":"text"},{"type":"text","text":" "},{"type":"text","text":"may fail to be activated on the primary instance."}]},{"type":"codeListing","syntax":"c","code":["\/\/ call ‘quit’ action on primary instance","g_action_group_activate_action (G_ACTION_GROUP (app), \"quit\", NULL);","","\/\/ make sure the action is activated now","g_dbus_connection_flush (…);","","g_debug (\"Application has been terminated. Exiting.\");","","exit (0);"]}],"kind":"content"}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"activateAction"},{"text":"(","kind":"text"},{"text":"actionName","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"text":"parameter","kind":"externalParam"},{"kind":"text","text":": "},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"title":"activateAction(actionName:parameter:)","role":"symbol","roleHeading":"Instance Method","extendedModule":"GIO","externalID":"s:3GIO19ActionGroupProtocolPAAE08activateB010actionName9parameterySPys4Int8VGSg_4GLib10VariantRefVSgtF::SYNTHESIZED::s:3GIO11ActionGroupC"},"references":{"doc://GIO/documentation/GIO/ActionGroup":{"role":"symbol","title":"ActionGroup","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ActionGroup"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","navigatorTitle":[{"text":"ActionGroup","kind":"identifier"}],"type":"topic","url":"\/documentation\/gio\/actiongroup","abstract":[{"type":"codeVoice","code":"GActionGroup"},{"type":"text","text":" represents a group of actions."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":