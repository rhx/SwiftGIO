{"kind":"symbol","relationshipsSections":[{"title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/GIO\/10GLibObject0B0C"],"type":"inheritsFrom"},{"identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/TestDBusProtocol"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"metadata":{"title":"TestDBus","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TestDBus"}],"navigatorTitle":[{"text":"TestDBus","kind":"identifier"}],"roleHeading":"Class","externalID":"s:3GIO8TestDBusC","symbolKind":"class","modules":[{"name":"GIO"}]},"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TestDBus","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"A helper class for testing code which uses D-Bus without touching the user’s"},{"type":"text","text":" "},{"text":"session bus.","type":"text"}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(_:)-7r4dp","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(_:)-8iygx","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(_:)-9gw26","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(_:)-jlk6","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(flags:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(raw:)-4y0np","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(raw:)-kq4q","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(retainingRaw:)-437kw","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(retainingRaw:)-7y25n","doc:\/\/GIO\/documentation\/GIO\/TestDBus\/init(testDBus:)"],"anchor":"Initializers","generated":true},{"generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/TestDBus\/TestDBusProtocol-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"TestDBus"}]}]},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that "},{"type":"codeVoice","code":"GTestDBus"},{"type":"text","text":" modifies the user’s environment, calling"},{"text":" ","type":"text"},{"isActive":true,"identifier":"man:setenv(3)","type":"reference"},{"type":"text","text":". This is not thread-safe, so all "},{"code":"GTestDBus","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"calls should be completed before threads are spawned, or should have"},{"type":"text","text":" "},{"text":"appropriate locking to ensure no access conflicts to environment variables","type":"text"},{"type":"text","text":" "},{"type":"text","text":"shared between "},{"type":"codeVoice","code":"GTestDBus"},{"type":"text","text":" and other threads."}]},{"level":2,"text":"Creating unit tests using `GTestDBus`","type":"heading","anchor":"Creating-unit-tests-using-GTestDBus"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Testing of D-Bus services can be tricky because normally we only ever run"},{"text":" ","type":"text"},{"type":"text","text":"D-Bus services over an existing instance of the D-Bus daemon thus we"},{"text":" ","type":"text"},{"type":"text","text":"usually don’t activate D-Bus services that are not yet installed into the"},{"type":"text","text":" "},{"type":"text","text":"target system. The "},{"code":"GTestDBus","type":"codeVoice"},{"type":"text","text":" object makes this easier for us by taking care"},{"text":" ","type":"text"},{"type":"text","text":"of the lower level tasks such as running a private D-Bus daemon and looking"},{"type":"text","text":" "},{"text":"up uninstalled services in customizable locations, typically in your source","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"code tree."}]},{"type":"paragraph","inlineContent":[{"text":"The first thing you will need is a separate service description file for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"D-Bus daemon. Typically a "},{"code":"services","type":"codeVoice"},{"text":" subdirectory of your ","type":"text"},{"type":"codeVoice","code":"tests"},{"type":"text","text":" directory"},{"text":" ","type":"text"},{"text":"is a good place to put this file.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The service file should list your service along with an absolute path to the"},{"text":" ","type":"text"},{"text":"uninstalled service executable in your source tree. Using autotools we would","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"achieve this by adding a file such as "},{"type":"codeVoice","code":"my-server.service.in"},{"type":"text","text":" in the services"},{"text":" ","type":"text"},{"text":"directory and have it processed by configure.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["[D-BUS Service]","Name=org.gtk.GDBus.Examples.ObjectManager","Exec=`abs_top_builddir`@\/gio\/tests\/gdbus-example-objectmanager-server"]},{"inlineContent":[{"type":"text","text":"You will also need to indicate this service directory in your test"},{"text":" ","type":"text"},{"text":"fixtures, so you will need to pass the path while compiling your","type":"text"},{"text":" ","type":"text"},{"text":"test cases. Typically this is done with autotools with an added","type":"text"},{"text":" ","type":"text"},{"text":"preprocessor flag specified to compile your tests such as:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["-DTEST_SERVICES=\\\"\"$(abs_top_builddir)\/tests\/services\"\\\""],"syntax":null},{"inlineContent":[{"text":"Once you have a service definition file which is local to your source tree,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"you can proceed to set up a GTest fixture using the "},{"type":"codeVoice","code":"GTestDBus"},{"text":" scaffolding.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"An example of a test fixture for D-Bus services can be found"},{"type":"text","text":" "},{"text":"here:","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gdbus-test-fixture.c","isActive":true}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that these examples only deal with isolating the D-Bus aspect of your"},{"text":" ","type":"text"},{"text":"service. To successfully run isolated unit tests on your service you may need","type":"text"},{"type":"text","text":" "},{"type":"text","text":"some additional modifications to your test case fixture. For example; if your"},{"text":" ","type":"text"},{"type":"text","text":"service uses [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings"},{"text":"] and installs a schema then it is important","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that your test service not load the schema in the ordinary installed location"},{"type":"text","text":" "},{"type":"text","text":"(chances are that your service and schema files are not yet installed, or"},{"text":" ","type":"text"},{"text":"worse; there is an older version of the schema file sitting in the install","type":"text"},{"type":"text","text":" "},{"type":"text","text":"location)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Most of the time we can work around these obstacles using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"environment. Since the environment is inherited by the D-Bus daemon"},{"text":" ","type":"text"},{"text":"created by ","type":"text"},{"code":"GTestDBus","type":"codeVoice"},{"type":"text","text":" and then in turn inherited by any services the"},{"type":"text","text":" "},{"text":"D-Bus daemon activates, using the setup routine for your fixture is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a practical place to help sandbox your runtime environment. For the"},{"type":"text","text":" "},{"type":"text","text":"rather typical GSettings case we can work around this by setting"},{"type":"text","text":" "},{"code":"GSETTINGS_SCHEMA_DIR","type":"codeVoice"},{"type":"text","text":" to the in tree directory holding your schemas"},{"text":" ","type":"text"},{"text":"in the above ","type":"text"},{"type":"codeVoice","code":"fixture_setup()"},{"text":" routine.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The GSettings schemas need to be locally pre-compiled for this to work. This","type":"text"},{"type":"text","text":" "},{"text":"can be achieved by compiling the schemas locally as a step before running","type":"text"},{"text":" ","type":"text"},{"text":"test cases, an autotools setup might do the following in the directory","type":"text"},{"type":"text","text":" "},{"type":"text","text":"holding schemas:"}]},{"type":"codeListing","syntax":null,"code":["    all-am:","            $(GLIB_COMPILE_SCHEMAS) .","","    CLEANFILES += gschemas.compiled"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBus","type":"reference","isActive":true},{"text":" type acts as a reference-counted owner of an underlying ","type":"text"},{"code":"GTestDBus","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBus","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GTestDBus"},{"type":"text","text":" instance."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBusRef"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBus","type":"reference","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GTestDBus","type":"codeVoice"},{"type":"text","text":" instance."}]}],"style":"note","type":"aside","name":"Note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/testdbus"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/TestDBus/init(retaining:)":{"title":"init(retaining:)","kind":"symbol","url":"\/documentation\/gio\/testdbus\/init(retaining:)","abstract":[{"type":"text","text":"Designated initialiser from the underlying "},{"type":"codeVoice","code":"C"},{"type":"text","text":" data type."},{"type":"text","text":" "},{"type":"text","text":"Will retain "},{"code":"GTestDBus","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"i.e., ownership is transferred to the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TestDBus","isActive":true},{"type":"text","text":" instance."}],"type":"topic","fragments":[{"text":"init","kind