{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Request information for a number of files from the enumerator asynchronously."},{"type":"text","text":" "},{"type":"text","text":"When all I\/O for the operation is finished the "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called with"},{"type":"text","text":" "},{"text":"the requested information.","type":"text"}],"kind":"symbol","metadata":{"roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"nextFilesAsync"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"kind":"text","text":">("},{"kind":"externalParam","text":"numFiles"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"kind":"text","text":"?, "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"extendedModule":"GIO","role":"symbol","title":"nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)","modules":[{"name":"GIO"}],"symbolKind":"method","externalID":"s:3GIO22FileEnumeratorProtocolPAAE14nextFilesAsync03numF010ioPriority11cancellable8callback8userDataySi_Siqd__SgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgAStAA011CancellableD0Rd__lF"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorProtocol"]]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"nextFilesAsync","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"CancellableT"},{"kind":"text","text":">("},{"text":"numFiles","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableT","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback","text":"GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"? = nil) ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"See the documentation of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator","type":"reference"},{"text":" for information about the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"order of returned files."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Once the end of the enumerator is reached, or if an error occurs, the","type":"text"},{"text":" ","type":"text"},{"code":"callback","type":"codeVoice"},{"text":" will be called with an empty list. In this case, the previous call","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to "},{"code":"g_file_enumerator_next_files_async()","type":"codeVoice"},{"text":" will typically have returned fewer","type":"text"},{"text":" ","type":"text"},{"text":"than ","type":"text"},{"type":"codeVoice","code":"numFiles"},{"type":"text","text":" items."}]},{"type":"paragraph","inlineContent":[{"text":"If a request is cancelled the callback will be called with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"This leads to the following pseudo-code usage:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["g_autoptr(GFile) dir = get_directory ();","g_autoptr(GFileEnumerator) enumerator = NULL;","g_autolist(GFileInfo) files = NULL;","g_autoptr(GError) local_error = NULL;","","enumerator = yield g_file_enumerate_children_async (dir,","                                                    G_FILE_ATTRIBUTE_STANDARD_NAME \",\"","                                                    G_FILE_ATTRIBUTE_STANDARD_TYPE,","                                                    G_FILE_QUERY_INFO_NONE,","                                                    G_PRIORITY_DEFAULT,","                                                    cancellable,","                                                    …,","                                                    &local_error);","if (enumerator == NULL)","  g_error (\"Error enumerating: %s\", local_error->message);","","\/\/ Loop until no files are returned, either because the end of the enumerator","\/\/ has been reached, or an error was returned.","do","  {","    files = yield g_file_enumerator_next_files_async (enumerator,","                                                      5,  \/\/ number of files to request","                                                      G_PRIORITY_DEFAULT,","                                                      cancellable,","                                                      …,","                                                      &local_error);","","    \/\/ Process the returned files, but don’t assume that exactly 5 were returned.","    for (GList *l = files; l != NULL; l = l->next)","      {","        GFileInfo *info = l->data;","        handle_file_info (info);","      }","  }","while (files != NULL);","","if (local_error != NULL &&","    !g_error_matches (local_error, G_IO_ERROR, G_IO_ERROR_CANCELLED))","  g_error (\"Error while enumerating: %s\", local_error->message);"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"During an async request no other sync and async calls are allowed, and will"},{"text":" ","type":"text"},{"type":"text","text":"result in "},{"type":"codeVoice","code":"pending"},{"type":"text","text":" errors."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical value) will"},{"type":"text","text":" "},{"type":"text","text":"be executed before an outstanding request with lower priority. Default"},{"text":" ","type":"text"},{"type":"text","text":"priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}]}]}],"variants":[{"paths":["\/documentation\/gio\/fileenumeratorprotocol\/nextfilesasync(numfiles:iopriority:cancellable:callback:userdata:)-9unww"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorProtocol\/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)-9unww"},"references":{"doc://GIO/documentation/GIO/File":{"abstract":[{"type":"codeVoice","code":"GFile"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"type":"text","text":"that do no I\/O upon creation. It is necessary to understand that"},{"type":"text","text":" "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"text":" ","type":"text"},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"text":"(see [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"text":"] and [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","url":"\/documentation\/gio\/file","title":"File","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"File","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"File"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},"doc://GIO/documentation/GIO/CancellableProtocol":{"role":"symbol","title":"CancellableProtocol","navigatorTitle":[{"text":"CancellableProtocol","kind":"identifier"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CancellableProtocol"}],"abstract":[{"code":"GCancellable","type":"codeVoice"},{"type":"text","text":" allows operations to be cancelled."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableProtocol","url":"\/documentation\/gio\/cancellableprotocol"},"doc://GIO/documentation/GIO/FileEnumeratorProtocol/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)-9unww":{"abs