{"metadata":{"symbolKind":"method","role":"symbol","modules":[{"name":"GIO"}],"externalID":"s:3GIO22FileEnumeratorProtocolPAAE14nextFilesAsync03numF010ioPriority11cancellable8callback8userDataySi_SiAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgSvSgtXCSgAUtF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"nextFilesAsync"},{"text":"(","kind":"text"},{"text":"numFiles","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"?)","kind":"text"}],"title":"nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)","extendedModule":"GIO","roleHeading":"Instance Method"},"abstract":[{"type":"text","text":"Request information for a number of files from the enumerator asynchronously."},{"type":"text","text":" "},{"type":"text","text":"When all I\/O for the operation is finished the "},{"code":"callback","type":"codeVoice"},{"text":" will be called with","type":"text"},{"type":"text","text":" "},{"text":"the requested information.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorProtocol"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileEnumeratorProtocol\/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)-55wg2","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"nextFilesAsync","kind":"identifier"},{"kind":"text","text":"("},{"text":"numFiles","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","preciseIdentifier":"c:@T@GAsyncReadyCallback","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"? = nil)"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"See the documentation of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator"},{"text":" for information about the","type":"text"},{"text":" ","type":"text"},{"text":"order of returned files.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once the end of the enumerator is reached, or if an error occurs, the"},{"type":"text","text":" "},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called with an empty list. In this case, the previous call"},{"text":" ","type":"text"},{"type":"text","text":"to "},{"code":"g_file_enumerator_next_files_async()","type":"codeVoice"},{"text":" will typically have returned fewer","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"than "},{"code":"numFiles","type":"codeVoice"},{"type":"text","text":" items."}]},{"type":"paragraph","inlineContent":[{"text":"If a request is cancelled the callback will be called with","type":"text"},{"type":"text","text":" "},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"This leads to the following pseudo-code usage:","type":"text"}]},{"syntax":null,"code":["g_autoptr(GFile) dir = get_directory ();","g_autoptr(GFileEnumerator) enumerator = NULL;","g_autolist(GFileInfo) files = NULL;","g_autoptr(GError) local_error = NULL;","","enumerator = yield g_file_enumerate_children_async (dir,","                                                    G_FILE_ATTRIBUTE_STANDARD_NAME \",\"","                                                    G_FILE_ATTRIBUTE_STANDARD_TYPE,","                                                    G_FILE_QUERY_INFO_NONE,","                                                    G_PRIORITY_DEFAULT,","                                                    cancellable,","                                                    …,","                                                    &local_error);","if (enumerator == NULL)","  g_error (\"Error enumerating: %s\", local_error->message);","","\/\/ Loop until no files are returned, either because the end of the enumerator","\/\/ has been reached, or an error was returned.","do","  {","    files = yield g_file_enumerator_next_files_async (enumerator,","                                                      5,  \/\/ number of files to request","                                                      G_PRIORITY_DEFAULT,","                                                      cancellable,","                                                      …,","                                                      &local_error);","","    \/\/ Process the returned files, but don’t assume that exactly 5 were returned.","    for (GList *l = files; l != NULL; l = l->next)","      {","        GFileInfo *info = l->data;","        handle_file_info (info);","      }","  }","while (files != NULL);","","if (local_error != NULL &&","    !g_error_matches (local_error, G_IO_ERROR, G_IO_ERROR_CANCELLED))","  g_error (\"Error while enumerating: %s\", local_error->message);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"During an async request no other sync and async calls are allowed, and will"},{"type":"text","text":" "},{"text":"result in ","type":"text"},{"type":"codeVoice","code":"pending"},{"text":" errors.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Any outstanding I\/O request with higher priority (lower numerical value) will"},{"text":" ","type":"text"},{"text":"be executed before an outstanding request with lower priority. Default","type":"text"},{"type":"text","text":" "},{"type":"text","text":"priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileenumeratorprotocol\/nextfilesasync(numfiles:iopriority:cancellable:callback:userdata:)-55wg2"]}],"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileEnumerator":{"kind":"symbol","url":"\/documentation\/gio\/fileenumerator","role":"symbol","abstract":[{"type":"codeVoice","code":"GFileEnumerator"},{"text":" allows you to operate on a set of [iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/File","isActive":true},{"type":"text","text":"] objects,"},{"text":" ","type":"text"},{"type":"text","text":"returning a [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileInfo"},{"type":"text","text":"] structure for each file enumerated (e.g."},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.File.enumerate_children"},{"type":"text","text":"] will return a "},{"type":"codeVoice","code":"GFileEnumerator"},{"text":" for each","type":"text"},{"type":"text","text":" "},{"text":"of the children within a directory).","type":"text"}],"title":"FileEnumerator","navigatorTitle":[{"text":"FileEnumerator","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileEnumerator","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"FileEnumerator","kind":"identifier"}]},"doc://GIO/documentation/GIO/File":{"abstract":[{"type":"codeVoice","code":"GFile"},{"type":"text","text":" is a high level abstraction for manipulating files on a"},{"text":" ","type":"text"},{"type":"text","text":"virtual file system. "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":"s are lightweight, immutable objects"},{"type":"text","text":" "},{"type":"text","text":"that do no I\/O upon creation. It is necessary to understand that"},{"type":"text","text":" "},{"type":"codeVoice","code":"GFile"},{"type":"text","text":" objects do not represent files, merely an identifier for a"},{"text":" ","type":"text"},{"type":"text","text":"file. All file content I\/O is implemented as streaming operations"},{"type":"text","text":" "},{"text":"(see [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputStream","isActive":true,"type":"reference"},{"text":"] and [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputStream"},{"type":"text","text":"])."}],"type":"topic","url":"\/documentation\/gio\/file","title":"File","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"File","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"File"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/File"},"doc://GIO/documentation/GIO/FileEnumeratorProtocol/nextFilesAsync(numFiles:ioPriority:cancellable:callback:userData:)-55wg2":{"role":"symbol","abstract":[{"type":"text","text":"Request information for a number of files from the enumerator asynchronously."},{"text":" ","type":"text"},{"type":"text","text":"When all I\/O for the operation is finished the "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called with"},{"type":"text","text":" "},{"text":"the requested information.","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"nextFilesAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"numFiles"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"ioPriority"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?, ","kind":"text"},{"text":"callback","kind":"externalParam"},{"t