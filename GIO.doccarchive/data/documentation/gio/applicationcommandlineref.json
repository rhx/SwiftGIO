{"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(_:)-18w9b","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(_:)-8jds","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(_:)-8ybzc","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(_:)-96ovv","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(_:)-kcl7","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(opaquePointer:)"],"generated":true,"title":"Initializers"},{"generated":true,"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/ptr"]},{"title":"Type Methods","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/unowned(_:)"],"generated":true,"anchor":"Type-Methods"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/ApplicationCommandLineProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/GWeakCapturing-Implementations","doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/ObjectProtocol-Implementations"],"title":"Default Implementations"}],"abstract":[{"code":"GApplicationCommandLine","type":"codeVoice"},{"type":"text","text":" represents a command-line invocation of"},{"type":"text","text":" "},{"type":"text","text":"an application."}],"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject14GWeakCapturingP","doc:\/\/GIO\/10GLibObject0B8ProtocolP"],"kind":"relationships","type":"conformsTo"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ApplicationCommandLineRef","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is created by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","type":"reference","isActive":true},{"type":"text","text":"] and emitted"},{"type":"text","text":" "},{"type":"text","text":"in the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] signal and virtual function."}]},{"inlineContent":[{"type":"text","text":"The class contains the list of arguments that the program was invoked"},{"text":" ","type":"text"},{"text":"with. It is also possible to query if the commandline invocation was","type":"text"},{"type":"text","text":" "},{"text":"local (ie: the current process is running in direct response to the","type":"text"},{"type":"text","text":" "},{"text":"invocation) or remote (ie: some other process forwarded the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"commandline to this process)."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"GApplicationCommandLine","type":"codeVoice"},{"type":"text","text":" object can provide the "},{"type":"codeVoice","code":"argc"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"argv"},{"type":"text","text":" "},{"type":"text","text":"parameters for use with the [struct[OptionContext](\/\/documentation\/glib\/optioncontext] command-line parsing API,"},{"type":"text","text":" "},{"text":"with the [method","type":"text"},{"type":"codeVoice","code":"Gio.ApplicationCommandLine.get_arguments"},{"text":"] function. See","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c","isActive":true},{"type":"text","text":" "},{"type":"text","text":"for an example."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The exit status of the originally-invoked process may be set and"},{"type":"text","text":" "},{"type":"text","text":"messages can be printed to stdout or stderr of that process."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For remote invocation, the originally-invoked process exits when"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.ApplicationCommandLine.done","type":"codeVoice"},{"type":"text","text":"] method is called. This method is"},{"type":"text","text":" "},{"text":"also automatically called when the object is disposed.","type":"text"}]},{"inlineContent":[{"text":"The main use for ","type":"text"},{"type":"codeVoice","code":"GApplicationCommandLine"},{"text":" (and the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] signal) is ‘Emacs server’ like use cases:"},{"type":"text","text":" "},{"text":"You can set the ","type":"text"},{"type":"codeVoice","code":"EDITOR"},{"type":"text","text":" environment variable to have e.g. git use"},{"type":"text","text":" "},{"type":"text","text":"your favourite editor to edit commit messages, and if you already"},{"text":" ","type":"text"},{"type":"text","text":"have an instance of the editor running, the editing will happen"},{"type":"text","text":" "},{"type":"text","text":"in the running instance, instead of opening a new one. An important"},{"text":" ","type":"text"},{"text":"aspect of this use case is that the process that gets started by git","type":"text"},{"type":"text","text":" "},{"text":"does not return until the editing is done.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Normally, the commandline is completely handled in the"},{"type":"text","text":" "},{"type":"text","text":"[signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler. The launching instance exits"},{"text":" ","type":"text"},{"text":"once the signal handler in the primary instance has returned, and","type":"text"},{"text":" ","type":"text"},{"text":"the return value of the signal handler becomes the exit status","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the launching instance."}],"type":"paragraph"},{"code":["static int","command_line (GApplication            *application,","              GApplicationCommandLine *cmdline)","{","  gchar **argv;","  gint argc;","  gint i;","","  argv = g_application_command_line_get_arguments (cmdline, &argc);","","  g_application_command_line_print (cmdline,","                                    \"This text is written back\\n\"","                                    \"to stdout of the caller\\n\");","","  for (i = 0; i < argc; i++)","    g_print (\"argument `d:` `s`\\n\", i, argv[i]);","","  g_strfreev (argv);","","  return 0;","}"],"type":"codeListing","syntax":"c"},{"type":"paragraph","inlineContent":[{"text":"The complete example can be found here:","type":"text"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline.c"}]},{"inlineContent":[{"text":"In more complicated cases, the handling of the commandline can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"split between the launcher and the primary instance."}],"type":"paragraph"},{"type":"codeListing","code":["static gboolean"," test_local_cmdline (GApplication   *application,","                     gchar        ***arguments,","                     gint           *exit_status)","{","  gint i, j;","  gchar **argv;","","  argv = *arguments;","","  if (argv[0] == NULL)","    {","      *exit_status = 0;","      return FALSE;","    }","","  i = 1;","  while (argv[i])","    {","      if (g_str_has_prefix (argv[i], \"--local-\"))","        {","          g_print (\"handling argument `s` locally\\n\", argv[i]);","          g_free (argv[i]);","          for (j = i; argv[j]; j++)","            argv[j] = argv[j + 1];","        }","      else","        {","          g_print (\"not handling argument `s` locally\\n\", argv[i]);","          i++;","        }","    }","","  *exit_status = 0;","","  return FALSE;","}","","static void","test_application_class_init (TestApplicationClass *class)","{","  G_APPLICATION_CLASS (class)->local_command_line = test_local_cmdline;","","  ...","}"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In this example of split commandline handling, options that start"},{"text":" ","type":"text"},{"text":"with ","type":"text"},{"code":"--local-","type":"codeVoice"},{"type":"text","text":" are handled locally, all other options are passed"},{"text":" ","type":"text"},{"type":"text","text":"to the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler which runs in the primary"},{"type":"text","text":" "},{"type":"text","text":"instance."}]},{"inlineContent":[{"type":"text","text":"The complete example can be found here:"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline2.c"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If handling the commandline requires a lot of work, it may be better to defer it."}]},{"syntax":"c","code":["static gboolean","my_cmdline_handler (gpointer data)","{","  GApplicationCommandLine *cmdline = data;","","  \/\/ do the heavy lifting in an idle","","  g_application_command_line_set_exit_status (cmdline, 0);","  g_object_unref (cmdline); \/\/ this releases the application","","  return G_SOURCE_REMOVE;","}","","static int","command_line (GApplication            *application,","              GApplicationCommandLine *cmdline)","{","  \/\/ keep the application running until we are done with this commandline","  g_application_hold (application);","","  g_object_set_data_full (G_OBJECT (cmdline),","                          \"application\", application,","                          (GDestroyNotify)g_application_release);","","  g_object_ref (cmdline);","  g_idle_add (my_cmdline_handler, cmdline);","","  return 0;","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"In this example the commandline is not completely handled before"},{"text":" ","type":"text"},{"type":"text","text":"the [signal[Application](\/\/documentation\/gio\/application\/oncommandline(flags:handler:)] handler returns. Instead, we keep"},{"text":" ","type":"text"},{"type":"text","text":"a reference to the "},{"type":"codeVoice","code":"GApplicationCommandLine"},{"type":"text","text":" object and handle it"},{"type":"text","text":" "},{"type":"text","text":"later (in this example, in an idle). Note that it is necessary to"},{"type":"text","text":" "},{"type":"text","text":"hold the application until you are done with the commandline."}],"type":"paragraph"},{"inlineContent":[{"text":"The complete example can be found here:","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c","isActive":true,"overridingTitle":"gapplication-example-cmdline3.c","type":"reference","overridingTitleInlineContent":[{"text":"gapplication-example-cmdline3.c","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef","type":"reference","isActive":true},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GApplicationCommandLine"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It exposes methods that can operate on this data type through ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineProtocol"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef","isActive":true},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GApplicationCommandLine","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLine","type":"reference"},{"type":"text","text":" (instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef"},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"type":"codeVoice","code":"GApplicationCommandLine"},{"type":"text","text":" instance."}]}],"name":"Note","type":"aside"}],"kind":"content"}],"metadata":{"title":"ApplicationCommandLineRef","role":"symbol","modules":[{"name":"GIO"}],"navigatorTitle":[{"text":"ApplicationCommandLineRef","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApplicationCommandLineRef","kind":"identifier"}],"roleHeading":"Structure","externalID":"s:3GIO25ApplicationCommandLineRefV","symbolKind":"struct"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef"},"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/applicationcommandlineref"]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/Application":{"navigatorTitle":[{"kind":"identifier","text":"Application"}],"title":"Application","abstract":[{"type":"codeVoice","code":"GApplication"},{"type":"text","text":" is the core class for application support."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Application","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/Application","url":"\/documentation\/gio\/application"},"https://gitlab.gnome.org/GNOME/glib/-/blob/HEAD/gio/tests/gapplication-example-cmdline3.c":{"type":"link","identifier":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c","url":"https:\/\/gitlab.gnome.org\/GNOME\/glib\/-\/blob\/HEAD\/gio\/tests\/gapplication-example-cmdline3.c","titleInlineContent":[{"type":"text","text":"gapplication-example-cmdline3.c"}],"title":"gapplication-example-cmdline3.c"},"doc://GIO/documentation/GIO/ApplicationCommandLineRef/init(_:)-kcl7":{"title":"init(_:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/ApplicationCommandLineRef\/init(_:)-kcl7","url":"\/documentation\/gio\/applicationcommandlineref\/init(_:)-kcl7","kind":"symbol","role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"GApplicationCommandLine","kind":"typeIdentifier"},{"kind":"text","text":">)"}],"type":"topic","abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"text":" data type","type":"text"}]},"doc://GIO/documentation/GIO/ApplicationCommandLineRef/i