{"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/gio\/applaunchcontextsignalname\/launched"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"launched","kind":"identifier"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because a launch operation may involve spawning multiple instances of the"},{"type":"text","text":" "},{"type":"text","text":"target application, you should expect this signal to be emitted multiple"},{"text":" ","type":"text"},{"type":"text","text":"times, one time for each spawned instance."}]},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"platformData"},{"type":"text","text":" is an GVariant dictionary mapping"},{"text":" ","type":"text"},{"type":"text","text":"strings to variants (ie "},{"type":"codeVoice","code":"a{sv}"},{"type":"text","text":"), which contains additional,"},{"text":" ","type":"text"},{"text":"platform-specific data about this launch. On UNIX, at least the","type":"text"},{"type":"text","text":" "},{"code":"pid","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"startup-notification-id","type":"codeVoice"},{"text":" keys will be present.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since 2.72 the "},{"type":"codeVoice","code":"pid"},{"type":"text","text":" may be 0 if the process id wasn’t known (for"},{"text":" ","type":"text"},{"type":"text","text":"example if the process was launched via D-Bus). The "},{"type":"codeVoice","code":"pid"},{"text":" may not be","type":"text"},{"text":" ","type":"text"},{"text":"set at all in subsequent releases.","type":"text"}]},{"inlineContent":[{"text":"On Windows, ","type":"text"},{"type":"codeVoice","code":"pid"},{"type":"text","text":" is guaranteed to be valid only for the duration of the"},{"text":" ","type":"text"},{"type":"text","text":"[signal[AppLaunchContext](\/\/documentation\/gio\/applaunchcontext\/onlaunched(flags:handler:)] signal emission; after the signal"},{"type":"text","text":" "},{"text":"is emitted, GLib will call [func","type":"text"},{"code":"GLib.spawn_close_pid","type":"codeVoice"},{"text":"]. If you need to","type":"text"},{"type":"text","text":" "},{"text":"keep the [alias[Pid](\/\/documentation\/glib\/pid] after the signal has been emitted, then you can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"duplicate "},{"type":"codeVoice","code":"pid"},{"type":"text","text":" using "},{"type":"codeVoice","code":"DuplicateHandle()"},{"text":".","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/AppLaunchContextSignalName\/launched"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/AppLaunchContextSignalName"]]},"kind":"symbol","metadata":{"title":"AppLaunchContextSignalName.launched","symbolKind":"case","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"launched"}],"modules":[{"name":"GIO"}],"role":"symbol","roleHeading":"Case","externalID":"s:3GIO26AppLaunchContextSignalNameO8launchedyA2CmF"},"sections":[],"abstract":[{"type":"text","text":"The [signal[AppLaunchContext](\/\/documentation\/gio\/applaunchcontext\/onlaunched(flags:handler:)] signal is emitted when a"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfo","isActive":true,"type":"reference"},{"type":"text","text":"] is successfully launched."}],"references":{"doc://GIO/documentation/GIO/AppLaunchContextSignalName":{"type":"topic","navigatorTitle":[{"text":"AppLaunchContextSignalName","kind":"identifier"}],"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AppLaunchContextSignalName","kind":"identifier"}],"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/applaunchcontextsignalname","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppLaunchContextSignalName","title":"AppLaunchContextSignalName","abstract":[]},"doc://GIO/documentation/GIO/AppLaunchContextSignalName/launched":{"title":"AppLaunchContextSignalName.launched","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"launched","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppLaunchContextSignalName\/launched","url":"\/documentation\/gio\/applaunchcontextsignalname\/launched","role":"symbol","abstract":[{"type":"text","text":"The [signal[AppLaunchContext](\/\/documentation\/gio\/applaunchcontext\/onlaunched(flags:handler:)] signal is emitted when a"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfo","isActive":true},{"type":"text","text":"] is successfully launched."}],"kind":"symbol"},"doc://GIO/documentation/GIO/AppInfo":{"type":"topic","navigatorTitle":[{"text":"AppInfo","kind":"identifier"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AppInfo","url":"\/documentation\/gio\/appinfo","title":"AppInfo","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AppInfo","kind":"identifier"}],"abstract":[{"type":"text","text":"Information about an installed application and methods to launch"},{"text":" ","type":"text"},{"type":"text","text":"it (with file arguments)."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}