{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/InetAddressMaskRef","doc:\/\/GIO\/documentation\/GIO\/InetAddressMaskRef\/InitableProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This method is intended for language bindings. If writing in C,"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_initable_new()"},{"text":" should typically be used instead.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"construction, either with this function or "},{"type":"codeVoice","code":"g_async_initable_init_async()"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"then initialization can be cancelled by triggering the cancellable object"},{"type":"text","text":" "},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"type":"text","text":" "},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If ","type":"text"},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the object is not initialized, or initialization returns with an"},{"text":" ","type":"text"},{"type":"text","text":"error, then all operations on the object except "},{"type":"codeVoice","code":"g_object_ref()"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_unref()"},{"text":" are considered to be invalid, and have undefined","type":"text"},{"type":"text","text":" "},{"text":"behaviour. See the ","type":"text"},{"type":"reference","identifier":"#iface@Gio.Initable#description","isActive":true},{"text":" for more details.","type":"text"}]},{"inlineContent":[{"text":"Callers should not assume that a class which implements ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","type":"reference","isActive":true},{"type":"text","text":" can be"},{"text":" ","type":"text"},{"type":"text","text":"initialized multiple times, unless the class explicitly documents itself as"},{"type":"text","text":" "},{"text":"supporting this. Generally, a class’ implementation of ","type":"text"},{"type":"codeVoice","code":"init()"},{"text":" can assume","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"type":"text","text":" "},{"text":"recommended all ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"type":"text","text":" implementations should be idempotent; that"},{"type":"text","text":" "},{"text":"recommendation was relaxed in GLib 2.54.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If a class explicitly supports being initialized multiple times, it is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"text":" ","type":"text"},{"type":"text","text":"arguments should return the same results. Only the first call initializes"},{"text":" ","type":"text"},{"type":"text","text":"the object; further calls return the result of the first call."}]},{"type":"paragraph","inlineContent":[{"text":"One reason why a class might need to support idempotent initialization is if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"type":"text","text":" "},{"type":"codeVoice","code":"GObjectClass.constructor"},{"text":" that sometimes returns an existing instance.","type":"text"},{"type":"text","text":" "},{"text":"In this pattern, a caller would expect to be able to call ","type":"text"},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"type":"text","text":"on the result of "},{"code":"g_object_new()","type":"codeVoice"},{"type":"text","text":", regardless of whether it is in fact a new"},{"type":"text","text":" "},{"type":"text","text":"instance."}]}]}],"metadata":{"role":"symbol","externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO18InetAddressMaskRefV","title":"init_(cancellable:)","roleHeading":"Instance Method","extendedModule":"GIO","modules":[{"name":"GIO"}],"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"init_"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMaskRef\/init_(cancellable:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/gio\/inetaddressmaskref\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/InetAddressMaskRef":{"url":"\/documentation\/gio\/inetaddressmaskref","type":"topic","title":"InetAddressMaskRef","kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMaskRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InetAddressMaskRef"}],"navigatorTitle":[{"text":"InetAddressMaskRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GInetAddressMask"},{"text":" represents a range of IPv4 or IPv6 addresses","type":"text"},{"type":"text","text":" "},{"text":"described by a base address and a length indicating how many bits","type":"text"},{"text":" ","type":"text"},{"text":"of the base address are relevant for matching purposes. These are","type":"text"},{"type":"text","text":" "},{"text":"often given in string form. For example, ","type":"text"},{"code":"10.0.0.0\/8","type":"codeVoice"},{"text":", or ","type":"text"},{"type":"codeVoice","code":"fe80``\/10"},{"text":".","type":"text"}]},"doc://GIO/documentation/GIO/InetAddressMaskRef/init_(cancellable:)":{"role":"symbol","url":"\/documentation\/gio\/inetaddressmaskref\/init_(cancellable:)","abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"kind":"symbol","title":"init_(cancellable:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMaskRef\/init_(cancellable:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/InetAddressMaskRef/InitableProtocol-Implementations":{"title":"InitableProtocol Implementations","kind":"article","abstract":[],"role":"collectionGroup","type":"topic","url":"\/documentation\/gio\/inetaddressmaskref\/initableprotocol-implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddressMaskRef\/InitableProtocol-Implementations"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"#iface@Gio.Initable#description":{"title":"description","titleInlineContent":[{"type":"text","text":"description"}],"type":"link","identifier":"#iface@Gio.Initable#description","url":"#iface@Gio.Initable#description"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}