{"abstract":[{"text":"This verifies ","type":"text"},{"type":"codeVoice","code":"cert"},{"text":" and returns a set of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"indicating any problems found with it. This can be used to verify a"},{"type":"text","text":" "},{"type":"text","text":"certificate outside the context of making a connection, or to"},{"type":"text","text":" "},{"type":"text","text":"check a certificate against a CA that is not part of the system"},{"type":"text","text":" "},{"type":"text","text":"CA database."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"verify"},{"kind":"text","text":"("},{"kind":"externalParam","text":"identity"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnectableRef","preciseIdentifier":"s:3GIO20SocketConnectableRefV","text":"SocketConnectableRef"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"trustedCa"},{"text":": ","kind":"text"},{"text":"TLSCertificateRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17TLSCertificateRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef"},{"text":"? = nil) -> ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags","kind":"typeIdentifier","text":"TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"cert"},{"type":"text","text":" is valid, "},{"type":"codeVoice","code":"noFlags"},{"text":" is returned.","type":"tex