{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"variants":[{"paths":["\/documentation\/gio\/notification"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Notification","kind":"identifier"}]}]},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"text":"The key difference between ","type":"text"},{"type":"codeVoice","code":"GNotification"},{"text":" and other similar APIs is","type":"text"},{"type":"text","text":" "},{"text":"that, if supported by the desktop environment, notifications sent","type":"text"},{"type":"text","text":" "},{"text":"with ","type":"text"},{"type":"codeVoice","code":"GNotification"},{"text":" will persist after the application has exited,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and even across system reboots."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since the user may click on a notification while the application is","type":"text"},{"type":"text","text":" "},{"text":"not running, applications using ","type":"text"},{"code":"GNotification","type":"codeVoice"},{"type":"text","text":" should be able to be"},{"type":"text","text":" "},{"type":"text","text":"started as a D-Bus service, using [class"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Application"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"text":"In order for ","type":"text"},{"type":"codeVoice","code":"GNotification"},{"type":"text","text":" to work, the application must have installed"},{"type":"text","text":" "},{"text":"a ","type":"text"},{"code":".desktop","type":"codeVoice"},{"type":"text","text":" file. For example:"}]},{"syntax":null,"code":["[Desktop Entry]","Name=Test Application","Comment=Description of what Test Application does","Exec=gnome-test-application","Icon=org.gnome.TestApplication","Terminal=false","Type=Application","Categories=GNOME;GTK;TestApplication Category;","StartupNotify=true","DBusActivatable=true","X-GNOME-UsesNotifications=true"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"X-GNOME-UsesNotifications"},{"text":" key indicates to GNOME Control Center","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that this application uses notifications, so it can be listed in the"},{"text":" ","type":"text"},{"text":"Control Center’s ‘Notifications’ panel.","type":"text"}]},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":".desktop"},{"text":" file must be named as ","type":"text"},{"code":"org.gnome.TestApplication.desktop","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"where "},{"code":"org.gnome.TestApplication","type":"codeVoice"},{"text":" is the ID passed to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[ctor"},{"type":"codeVoice","code":"Gio.Application.new"},{"type":"text","text":"]."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"User interaction with a notification (either the default action, or"},{"type":"text","text":" "},{"type":"text","text":"buttons) must be associated with actions on the application (ie:"},{"type":"text","text":" "},{"type":"codeVoice","code":"app."},{"type":"text","text":" actions).  It is not possible to route user interaction"},{"text":" ","type":"text"},{"text":"through the notification itself, because the object will not exist if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the application is autostarted as a result of a notification being"},{"type":"text","text":" "},{"type":"text","text":"clicked."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A notification can be sent with [method","type":"text"},{"code":"Gio.Application.send_notification","type":"codeVoice"},{"type":"text","text":"]."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Notification","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GNotification","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/NotificationProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Notification"},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GNotification","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/NotificationRef","isActive":true,"type":"reference"},{"text":" (instead of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Notification","isActive":true,"type":"reference"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GNotification"},{"type":"text","text":" instance."}],"type":"paragraph"}]}],"kind":"content"}],"metadata":{"role":"symbol","title":"Notification","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Notification"}],"roleHeading":"Class","navigatorTitle":[{"text":"Notification","kind":"identifier"}],"modules":[{"name":"GIO"}],"symbolKind":"class","externalID":"s:3GIO12NotificationC"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/Notifica