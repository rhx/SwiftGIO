{"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","kind":"relationships","identifiers":["doc:\/\/GIO\/10GLibObject0B0C"]},{"kind":"relationships","type":"inheritedBy","title":"Inherited By","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel","doc:\/\/GIO\/documentation\/GIO\/Menu"]},{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GIO\/4GLib14PointerWrapperP","doc:\/\/GIO\/10GLibObject0B8ProtocolP","doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol"]}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menumodel"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"type":"text","text":" "},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"state it has) can influence the representation of the item."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"metadata":{"title":"MenuModel","externalID":"s:3GIO9MenuModelC","symbolKind":"class","roleHeading":"Class","navigatorTitle":[{"text":"MenuModel","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"MenuModel","kind":"identifier"}],"role":"symbol","modules":[{"name":"GIO"}]},"kind":"symbol","topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(_:)-12h8r","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(_:)-5fjbh","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(_:)-5h2kr","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(_:)-6o442","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(menuModel:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(raw:)-2yytl","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(raw:)-3a5y8","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(retainingRaw:)-16inu","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(retainingRaw:)-1fi1v"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","generated":true,"anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/MenuModel\/metatypeReferenceForMenuModel","doc:\/\/GIO\/documentation\/GIO\/MenuModel\/wrapperForMenuModel"]},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/MenuModel\/metatypeForMenuModel"],"anchor":"Type-Properties","generated":true,"title":"Type Properties"},{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/MenuModel\/MenuModelProtocol-Implementations"],"generated":true,"anchor":"Default-Implementations","title":"Default Implementations"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModel"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"The conceptual model of menus in "},{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" is hierarchical:"},{"type":"text","text":" "},{"text":"sections and submenus are again represented by ","type":"text"},{"type":"codeVoice","code":"GMenuModel"},{"text":"s.","type":"text"},{"type":"text","text":" "},{"text":"Menus themselves do not define their own roles. Rather, the role","type":"text"},{"type":"text","text":" "},{"text":"of a particular ","type":"text"},{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" is defined by the item that references"},{"text":" ","type":"text"},{"text":"it (or, in the case of the ‘root’ menu, is defined by the context","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"in which it is used)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an example, consider the visible portions of this menu:"}]},{"level":2,"type":"heading","anchor":"An-example-menu","text":"An example menu"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"While this kind of deeply nested menu is no longer considered good UI"},{"type":"text","text":" "},{"text":"practice, it serves as a good example of the concepts in ","type":"text"},{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"There are 8 ‘menus’ visible in the screenshot: one menubar, two"},{"type":"text","text":" "},{"type":"text","text":"submenus and 5 sections:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"the toplevel menubar (containing 4 items)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"the View submenu (containing 3 sections)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the first section of the View submenu (containing 2 items)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the second section of the View submenu (containing 1 item)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the final section of the View submenu (containing 1 item)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the Highlight Mode submenu (containing 2 sections)"}]}]},{"content":[{"inlineContent":[{"text":"the Sources section (containing 2 items)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"the Markup section (containing 2 items)","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"#a-menu-example","type":"reference","isActive":true},{"text":" illustrates the conceptual connection between","type":"text"},{"text":" ","type":"text"},{"text":"these 8 menus. Each large block in the figure represents a menu and the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"smaller blocks within the large block represent items in that menu. Some"},{"text":" ","type":"text"},{"text":"items contain references to other menus.","type":"text"}]},{"type":"heading","anchor":"A-menu-example","text":"A menu example","level":2},{"inlineContent":[{"type":"text","text":"Notice that the separators visible in the "},{"isActive":true,"type":"reference","identifier":"#an-example-menu"},{"type":"text","text":" "},{"type":"text","text":"appear nowhere in the "},{"type":"reference","isActive":true,"identifier":"#a-menu-example","overridingTitle":"menu model","overridingTitleInlineContent":[{"type":"text","text":"menu model"}]},{"text":". This is because","type":"text"},{"text":" ","type":"text"},{"text":"separators are not explicitly represented in the menu model. Instead,","type":"text"},{"text":" ","type":"text"},{"text":"a separator is inserted between any two non-empty sections of a menu.","type":"text"},{"text":" ","type":"text"},{"text":"Section items can have labels just like any other item. In that case,","type":"text"},{"type":"text","text":" "},{"text":"a display system may show a section header instead of a separator.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The motivation for this abstract model of application controls is"},{"type":"text","text":" "},{"type":"text","text":"that modern user interfaces tend to make these controls available"},{"type":"text","text":" "},{"text":"outside the application. Examples include global menus, jumplists,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dash boards, etc. To support such uses, it is necessary to ‘export’"},{"type":"text","text":" "},{"type":"text","text":"information about actions and their representation in menus, which"},{"type":"text","text":" "},{"type":"text","text":"is exactly what the action group exporter and the menu model exporter do for"},{"type":"text","text":" "},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","type":"reference","isActive":true},{"text":"] and [class","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","type":"reference","isActive":true},{"type":"text","text":"]. The client-side"},{"text":" ","type":"text"},{"type":"text","text":"counterparts to make use of the exported information are"},{"text":" ","type":"text"},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusActionGroup"},{"type":"text","text":"] and [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel","type":"reference","isActive":true},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The API of ","type":"text"},{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" is very generic, with iterators for the"},{"text":" ","type":"text"},{"type":"text","text":"attributes and links of an item, see"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.MenuModel.iterate_item_attributes"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"Gio.MenuModel.iterate_item_links"},{"type":"text","text":"]. The ‘standard’ attributes and"},{"type":"text","text":" "},{"text":"link types have predefined names: ","type":"text"},{"type":"codeVoice","code":"G_MENU_ATTRIBUTE_LABEL"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"G_MENU_ATTRIBUTE_ACTION","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"G_MENU_ATTRIBUTE_TARGET"},{"text":", ","type":"text"},{"type":"codeVoice","code":"G_MENU_LINK_SECTION"},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"codeVoice","code":"G_MENU_LINK_SUBMENU"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Items in a "},{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represent active controls if they refer to"},{"type":"text","text":" "},{"text":"an action that can get activated when the user interacts with the","type":"text"},{"type":"text","text":" "},{"text":"menu item. The reference to the action is encoded by the string ID","type":"text"},{"type":"text","text":" "},{"text":"in the ","type":"text"},{"type":"codeVoice","code":"G_MENU_ATTRIBUTE_ACTION"},{"text":" attribute. An action ID uniquely","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"identifies an action in an action group. Which action "},{"code":"group(s)","type":"codeVoice"},{"type":"text","text":" provide"},{"text":" ","type":"text"},{"type":"text","text":"actions depends on the context in which the menu model is used."},{"text":" ","type":"text"},{"text":"E.g. when the model is exported as the application menu of a","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"https:\/\/docs.gtk.org\/gtk4\/class.Application.html","type":"reference"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"text","text":"actions can be application-wide or window-specific (and thus come from"},{"type":"text","text":" "},{"text":"two different action groups). By convention, the application-wide actions","type":"text"},{"type":"text","text":" "},{"text":"have names that start with ","type":"text"},{"type":"codeVoice","code":"app."},{"text":", while the names of window-specific","type":"text"},{"text":" ","type":"text"},{"text":"actions start with ","type":"text"},{"type":"codeVoice","code":"win."},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"While a wide variety of stateful actions is possible, the following","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is the minimum that is expected to be supported by all users of exported"},{"text":" ","type":"text"},{"type":"text","text":"menu information:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"an action with no parameter type and no state","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"an action with no parameter type and boolean state"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"an action with string parameter type and string state","type":"text"}]}]}]},{"type":"heading","text":"Stateless","anchor":"Stateless","level":2},{"inlineContent":[{"type":"text","text":"A stateless action typically corresponds to an ordinary menu item."}],"type":"paragraph"},{"inlineContent":[{"text":"Selecting such a menu item will activate the action (with no parameter).","type":"text"}],"type":"paragraph"},{"text":"Boolean State","type":"heading","anchor":"Boolean-State","level":2},{"inlineContent":[{"type":"text","text":"An action with a boolean state will most typically be used with a ‘toggle’"},{"type":"text","text":" "},{"type":"text","text":"or ‘switch’ menu item. The state can be set directly, but activating the"},{"type":"text","text":" "},{"type":"text","text":"action (with no parameter) results in the state being toggled."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Selecting a toggle menu item will activate the action. The menu item should","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be rendered as ‘checked’ when the state is true."}]},{"text":"String Parameter and State","anchor":"String-Parameter-and-State","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Actions with string parameters and state will most typically be used to"},{"type":"text","text":" "},{"type":"text","text":"represent an enumerated choice over the items available for a group of"},{"type":"text","text":" "},{"type":"text","text":"radio menu items. Activating the action with a string parameter is"},{"type":"text","text":" "},{"type":"text","text":"equivalent to setting that parameter as the state."}]},{"type":"paragraph","inlineContent":[{"text":"Radio menu items, in addition to being associated with the action, will","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have a target value. Selecting that menu item will result in activation"},{"text":" ","type":"text"},{"type":"text","text":"of the action with the target value as the parameter. The menu item should"},{"text":" ","type":"text"},{"text":"be rendered as ‘selected’ when the state of the action is equal to the","type":"text"},{"type":"text","text":" "},{"text":"target value of the menu item.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"code":"GMenuModel","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" instance."}]}],"name":"Note","type":"aside","style":"note"}]}],"references":{"doc://GIO/documentation/GIO/MenuModel/metatypeReferenceForMenuModel":{"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"metatypeReferenceForMenuModel","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GType","text":"GType"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/metatypeReferenceForMenuModel","type":"topic","title":"metatypeReferenceForMenuModel","abstract":[{"type":"text","text":"This getter returns the GLib type identifier registered for "},{"code":"MenuModel","type":"codeVoice"}],"role":"symbol","kind":"symbol","url":"\/documentation\/gio\/menumodel\/metatypereferenceformenumodel"},"doc://GIO/documentation/GIO/MenuModel/init(retainingRaw:)-1fi1v":{"title":"init(retainingRaw:)","url":"\/documentation\/gio\/menumodel\/init(retainingraw:)-1fi1v","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel\/init(retainingRaw:)-1fi1v","typ