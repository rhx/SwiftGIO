{"abstract":[{"text":"Checks on the readiness of ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" to perform operations. The"},{"type":"text","text":" "},{"text":"operations specified in ","type":"text"},{"code":"condition","type":"codeVoice"},{"text":" are checked for and masked against the","type":"text"},{"text":" ","type":"text"},{"text":"currently-satisfied conditions on ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":". The result is returned."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/conditionCheck(condition:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datagrambased\/conditioncheck(condition:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DatagramBased","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/DatagramBasedProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"conditionCheck"},{"text":"(","kind":"text"},{"text":"condition","kind":"externalParam"},{"kind":"text","text":": "},{"text":"IOCondition","kind":"typeIdentifier","preciseIdentifier":"s:4GLib11IOConditionV"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:4GLib11IOConditionV","kind":"typeIdentifier","text":"IOCondition"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"[In_](\/\/Documentation\/Gobject\/In_ will be set in the return value if data is available to read with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":", or if the connection is closed remotely"},{"text":" ","type":"text"},{"text":"(EOS); and if the datagram_based has not been closed locally using some","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"implementation-specific method (such as "},{"type":"codeVoice","code":"g_socket_close()"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"type":"codeVoice","code":"shutdown_read"},{"type":"text","text":" set, if it’s a "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference"},{"type":"text","text":")."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_shutdown()"},{"type":"text","text":" with "},{"code":"shutdown_read","type":"codeVoice"},{"text":" set, if it’s a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"text":", for","type":"text"},{"type":"text","text":" "},{"text":"example), all calls to this function will return ","type":"text"},{"code":"closed","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"[out](\/\/documentation\/gobject\/out will be set if it is expected that at least one byte can be sent","type":"text"},{"text":" ","type":"text"},{"text":"using ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_send_messages()"},{"text":" without blocking. It will not be set","type":"text"},{"type":"text","text":" "},{"type":"text","text":"if the datagram_based has been closed locally."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"[hup](\/\/documentation\/gobject\/hup will be set if the connection has been closed locally."}]},{"type":"paragraph","inlineContent":[{"text":"[err](\/\/documentation\/gobject\/err will be set if there was an asynchronous error in transmitting data","type":"text"},{"text":" ","type":"text"},{"text":"previously enqueued using ","type":"text"},{"code":"g_datagram_based_send_messages()","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that on Windows, it is possible for an operation to return"},{"text":" ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" even immediately after"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_datagram_based_condition_check()"},{"text":" has claimed that the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"text","text":"ready for writing. Rather than calling "},{"code":"g_datagram_based_condition_check()","type":"codeVoice"},{"text":" and","type":"text"},{"type":"text","text":" "},{"text":"then writing to the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","isActive":true,"type":"reference"},{"text":" if it succeeds, it is generally better to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"simply try writing right away, and try again later if the initial attempt"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"It is meaningless to specify [err](\/\/documentation\/gobject\/err or [hup](\/\/documentation\/gobject\/hup in "},{"type":"codeVoice","code":"condition"},{"type":"text","text":"; these"},{"text":" ","type":"text"},{"type":"text","text":"conditions will always be set in the output if they are true. Apart from"},{"type":"text","text":" "},{"type":"text","text":"these flags, the output is guaranteed to be masked by "},{"type":"codeVoice","code":"condition"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This call never blocks."}]}]}],"kind":"symbol","sections":[],"metadata":{"modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"conditionCheck","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"condition"},{"text":": ","kind":"text"},{"text":"IOCondition","kind":"typeIdentifier","preciseIdentifier":"s:4GLib11IOConditionV"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"IOCondition","preciseIdentifier":"s:4GLib11IOConditionV"}],"symbolKind":"method","externalID":"s:3GIO21DatagramBasedProtocolPAAE14conditionCheck0E04GLib11IOConditionVAH_tF::SYNTHESIZED::s:3GIO13DatagramBasedC","extendedModule":"GIO","title":"conditionCheck(condition:)","roleHeading":"Instance Method","role":"symbol"},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://GIO/documentation/GIO/DatagramBased/conditionCheck(condition:)":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"conditionCheck"},{"text":"(","kind":"text"},{"text":"condition","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"IOCondition","kind":"typeIdentifier","preciseIdentifier":"s:4GLib11IOConditionV"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"IOCondition","preciseIdentifier":"s:4GLib11IOConditionV"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/conditionCheck(condition:)","title":"conditionCheck(condition:)","abstract":[{"type":"text","text":"Checks on the readiness of "},{"code":"datagramBased","type":"codeVoice"},{"type":"text","text":" to perform operations. The"},{"text":" ","type":"text"},{"text":"operations specified in ","type":"text"},{"type":"codeVoice","code":"condition"},{"type":"text","text":" are checked for and masked against the"},{"type":"text","text":" "},{"type":"text","text":"currently-satisfied conditions on "},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":". The result is returned."}],"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/gio\/datagrambased\/conditioncheck(condition:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DatagramBased":{"role":"symbol","type":"topic","kind":"symbol","url":"\/documentation\/gio\/datagrambased","abstract":[{"type":"text","text":"Interface for socket-like objects with datagram semantics."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DatagramBased"}],"title":"DatagramBased","navigatorTitle":[{"text":"DatagramBased","kind":"identifier"}]},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"type":"text","text":" "},{"type":"text","text":"direct mapping of the BSD socket API in a portable GObject based API."},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"title":"Socket","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Socket","kind":"identifier"}]},"doc://GIO/documentation/GIO/DatagramBased/DatagramBasedProtocol-Implementations":{"type":"topic","kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/DatagramBasedProtocol-Implementations","url":"\/documentation\/gio\/datagrambased\/datagrambasedprotocol-implementations","role":"collectionGroup","abstract":[],"title":"DatagramBasedProtocol Implementations"}}}