{"sections":[],"abstract":[{"text":"Receive one or more data messages from ","type":"text"},{"type":"codeVoice","code":"datagramBased"},{"type":"text","text":" in one go."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"receive","kind":"identifier"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GInputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true,"type":"reference"},{"text":" structs and","type":"text"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" must be the length of this array. Each "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"contains a pointer to an array of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true},{"type":"text","text":" structs describing the"},{"type":"text","text":" "},{"text":"buffers that the data received in each message will be written to.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"flags","type":"codeVoice"},{"text":" modify how all messages are received. The commonly available","type":"text"},{"type":"text","text":" "},{"type":"text","text":"arguments for this are available in the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"text":" enum, but the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"values there are the same as the system values, and the flags"},{"type":"text","text":" "},{"text":"are passed in as-is, so you can pass in system-specific flags too. These","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"flags affect the overall receive operation. Flags affecting individual"},{"type":"text","text":" "},{"text":"messages are returned in ","type":"text"},{"type":"codeVoice","code":"GInputMessage.flags"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The other members of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true},{"type":"text","text":" are treated as described in its"},{"text":" ","type":"text"},{"text":"documentation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" is negative the call will block until "},{"type":"codeVoice","code":"numMessages"},{"text":" have been","type":"text"},{"type":"text","text":" "},{"type":"text","text":"received, the connection is closed remotely (EOS), "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is cancelled,"},{"type":"text","text":" "},{"text":"or an error occurs.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is 0 the call will return up to "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" without blocking,"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"wouldBlock"},{"text":" if no messages are queued in the operating system","type":"text"},{"type":"text","text":" "},{"text":"to be received.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is positive the call will block on the same conditions as if"},{"type":"text","text":" "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" were negative. If the timeout is reached"},{"type":"text","text":" "},{"text":"before any messages are received, ","type":"text"},{"code":"timedOut","type":"codeVoice"},{"text":" is returned,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"otherwise it will return the number of messages received before timing out."},{"type":"text","text":" "},{"text":"(Note: This is effectively the behaviour of ","type":"text"},{"code":"MSG_WAITFORONE","type":"codeVoice"},{"type":"text","text":" with"},{"text":" ","type":"text"},{"code":"recvmmsg()","type":"codeVoice"},{"text":".)","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To be notified when messages are available, wait for the [in_](\/\/documentation\/gobject\/in_ condition.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Note though that you may still receive "},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" from"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_datagram_based_receive_messages()"},{"type":"text","text":" even if you were previously notified of a"},{"text":" ","type":"text"},{"type":"text","text":"[in_](\/\/documentation\/gobject\/in_ condition."}]},{"type":"paragraph","inlineContent":[{"text":"If the remote peer closes the connection, any messages queued in the","type":"text"},{"type":"text","text":" "},{"text":"underlying receive buffer will be returned, and subsequent calls to","type":"text"},{"text":" ","type":"text"},{"code":"g_datagram_based_receive_messages()","type":"codeVoice"},{"text":" will return 0 (with no error set).","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the connection is shut down or closed (by calling "},{"code":"g_socket_close()","type":"codeVoice"},{"text":" or","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_shutdown()"},{"type":"text","text":" with "},{"code":"shutdown_read","type":"codeVoice"},{"text":" set, if it’s a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"text":", for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example), all calls to this function will return "},{"type":"codeVoice","code":"closed"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"text":" is set accordingly. An error will only","type":"text"},{"type":"text","text":" "},{"text":"be returned if zero messages could be received; otherwise the number of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages successfully received before the error will be returned. If"},{"text":" ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is cancelled, "},{"type":"codeVoice","code":"cancelled"},{"text":" is returned as with any","type":"text"},{"type":"text","text":" "},{"text":"other error.","type":"text"}]}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/datagrambased\/receive(messages:nummessages:flags:timeout:cancellable:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/receive(messages:numMessages:flags:timeout:cancellable:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DatagramBased","doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/DatagramBasedProtocol-Implementations"]]},"metadata":{"modules":[{"name":"GIO"}],"symbolKind":"method","extendedModule":"GIO","roleHeading":"Instance Method","externalID":"s:3GIO21DatagramBasedProtocolPAAE7receive8messages11numMessages5flags7timeout11cancellableSiSpySo14_GInputMessageVGSg_S2is5Int64VAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO13DatagramBasedC","role":"symbol","title":"receive(messages:numMessages:flags:timeout:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"receive","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"messages"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GInputMessage"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"timeout","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gint64","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gint64"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]},"references":{"doc://GIO/documentation/GIO/InputVector":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","title":"InputVector","url":"\/documentation\/gio\/inputvector","abstract":[{"type":"text","text":"Structure used for scatter\/gather data input."},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GInputVectors"},{"text":" ","type":"text"},{"text":"and the operation will store the read data starting in the","type":"text"},{"type":"text","text":" "},{"text":"first buffer, switching to the next as needed.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InputVector"}],"kind":"symbol","navigatorTitle":[{"text":"InputVector","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/InputMessage":{"navigatorTitle":[{"text":"InputMessage","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","url":"\/documentation\/gio\/inputmessage","title":"InputMessage","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"InputMessage","kind":"identifier"}],"abstract":[{"type":"text","text":"Structure used for scatter\/gather data input when receiving multiple"},{"type":"text","text":" "},{"text":"messages or packets in one go. You generally pass in an array of empty","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"text":" and the operation will use all the buffers as if they","type":"text"},{"type":"text","text":" "},{"type":"text","text":"were one buffer, and will set "},{"type":"codeVoice","code":"bytes_received"},{"type":"text","text":" to the total number of bytes"},{"type":"text","text":" "},{"text":"received across all ","type":"text"},{"type":"codeVoice","code":"GInputVectors"},{"type":"text","text":"."}],"role":"symbol","kind":"symbol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/DatagramBased/DatagramBasedProtocol-Implementations":{"type":"topic","kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/DatagramBasedProtocol-Implementations","url":"\/documentation\/gio\/datagrambased\/datagrambasedprotocol-implementations","role":"collectionGroup","abstract":[],"title":"DatagramBasedProtocol Implementations"},"doc://GIO/documentation/GIO/DatagramBased/receive(messages:numMessages:flags:timeout:cancellable:)":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DatagramBased\/receive(messages:numMessages:flags:timeout:cancellable:)","abstract":[{"type":"text","text":"Receive one or more data messages from "},{"code":"datagramBased","type":"codeVoice"},{"type":"text","text":" in one go."}],"type":"topic","role":"symbol","title":"receive(messages:numMessages:flags:timeout:cancellable:)","url":"\/documentation\/gio\/datagrambased\/receive(messages:nummessages:flags:timeout:cancellable:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"receive"},{"kind":"text","text":"("},{"kind":"externalParam","text":"messages"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"GInputMessage","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"numMessages"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},