{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Send one or more data messages from "},{"type":"codeVoice","code":"datagramBased"},{"text":" in one go.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"send","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GOutputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"timeout"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gint64","kind":"typeIdentifier","text":"gint64"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"kind":"text","text":": "},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage"},{"type":"text","text":" structs and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" must be the length of this array. Each "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"contains an address to send the data to, and a pointer to an array of"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true},{"type":"text","text":" structs to describe the buffers that the data to be sent"},{"text":" ","type":"text"},{"text":"for each message will be gathered from.","type":"text"}]},{"inlineContent":[{"code":"flags","type":"codeVoice"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"text":"for this are available in the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true,"type":"reference"},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The other members of "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputMessage","type":"reference"},{"text":" are treated as described in its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"documentation."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is negative the call will block until "},{"type":"codeVoice","code":"numMessages"},{"text":" have been","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"sent, "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is cancelled, or an error occurs."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"timeout","type":"codeVoice"},{"type":"text","text":" is 0 the call will send up to "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" without blocking,"},{"type":"text","text":" "},{"type":"text","text":"or will return "},{"code":"wouldBlock","type":"codeVoice"},{"text":" if there is no space to send messages.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"timeout"},{"text":" is positive the call will block on the same conditions as if","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"timeout"},{"type":"text","text":" were negative. If the timeout is reached before any messages are"},{"text":" ","type":"text"},{"text":"sent, ","type":"text"},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned, otherwise it will return the number"},{"type":"text","text":" "},{"text":"of messages sent before timing out.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To be notified when messages can be sent, wait for the [out](\/\/documentation\/gobject\/out condition.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Note though that you may still receive "},{"type":"codeVoice","code":"wouldBlock"},{"text":" from","type":"text"},{"text":" ","type":"text"},{"code":"g_datagram_based_send_messages()","type":"codeVoice"},{"type":"text","text":" even if you were previously notified of a"},{"type":"text","text":" "},{"text":"[out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is very common due to","type":"text"},{"type":"text","text":" "},{"text":"the way the underlying APIs work.)","type":"text"}]},{"inlineContent":[{"text":"If the connection is shut down or closed (by calling ","type":"text"},{"type":"codeVoice","code":"g_socket_close()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"g_socket_shutdown()","type":"codeVoice"},{"type":"text","text":" with "},{"code":"shutdown_write","type":"codeVoice"},{"text":" set, if it’s a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"text":", for","type":"text"},{"type":"text","text":" "},{"text":"example), all calls to this function will return ","type":"text"},{"code":"closed","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"text":" is set accordingly. An error will only","type":"text"},{"type":"text","text":" "},{"type":"text","text":"be returned if zero messages could be sent; otherwise the number of messages"},{"type":"text","text":" "},{"type":"text","text":"successfully sent before the error will be returned. If "},{"code":"cancellable","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"text":"cancelled, ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" is returned as with any other error."}]}]}],"kind":"symbol","metadata":{"externalID":"s:3GIO21DatagramBasedProtocolPAAE4send8messages11numMessages5flags7timeout11cancellableSiSpySo15_GOutputMessageVGSg_S2is5Int64VAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO13DatagramBasedC","modules":[{"name":"GIO"}],"symbolKind":"method","roleHeading":"Instance Method","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"send","kind":"identifier"},{"text":"(","kind":"text"},{"text":"messages","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GOutputMessage","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","ki