{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingssignalname\/writablechangeevent"]}],"sections":[],"metadata":{"role":"symbol","title":"SettingsSignalName.writableChangeEvent","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"writableChangeEvent"}],"symbolKind":"case","modules":[{"name":"GIO"}],"externalID":"s:3GIO18SettingsSignalNameO19writableChangeEventyA2CmF","roleHeading":"Case"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSignalName\/writableChangeEvent","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"writableChangeEvent","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should connect"},{"type":"text","text":" "},{"text":"to this signal if you are interested in viewing groups of changes","type":"text"},{"type":"text","text":" "},{"text":"before they are split out into multiple emissions of the","type":"text"},{"text":" ","type":"text"},{"text":"[signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)] signal.  For most use cases it is more","type":"text"},{"type":"text","text":" "},{"text":"appropriate to use the [signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)] signal.","type":"text"}]},{"inlineContent":[{"text":"In the event that the writability change applies only to a single","type":"text"},{"type":"text","text":" "},{"text":"key, ","type":"text"},{"type":"codeVoice","code":"key"},{"text":" will be set to the [alias[Quark](\/\/documentation\/glib\/quark] for that key.  In the event","type":"text"},{"type":"text","text":" "},{"text":"that the writability change affects the entire settings object,","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"key"},{"type":"text","text":" will be "},{"type":"codeVoice","code":"0"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The default handler for this signal invokes the [signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and [signal[Settings](\/\/documentation\/gio\/settings\/onchanged(flags:handler:)] signals for each affected key.  This is done because"},{"type":"text","text":" "},{"text":"changes in writability might also imply changes in value (if for","type":"text"},{"type":"text","text":" "},{"text":"example, a new mandatory setting is introduced).  If any other","type":"text"},{"type":"text","text":" "},{"text":"connected handler returns true then this default functionality","type":"text"},{"type":"text","text":" "},{"type":"text","text":"will be suppressed."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSignalName"]]},"abstract":[{"type":"text","text":"Emitted once per writability change event that affects this settings object."}],"kind":"symbol","references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SettingsSignalName/writableChangeEvent":{"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSignalName\/writableChangeEvent","title":"SettingsSignalName.writableChangeEvent","url":"\/documentation\/gio\/settingssignalname\/writablechangeevent","type":"topic","role":"symbol","abstract":[{"text":"Emitted once per writability change event that affects this settings object.","type":"text"}],"fragments":[{"text":"case","kind":"keyword