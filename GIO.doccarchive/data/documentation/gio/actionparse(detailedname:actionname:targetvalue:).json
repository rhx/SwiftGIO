ns":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/actionparse(detailedname:actionname:targetvalue:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"actionParse"},{"text":"(","kind":"text"},{"text":"detailedName","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"actionName"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">?>! = nil, ","kind":"text"},{"text":"targetValue","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GVariant","kind":"typeIdentifier"},{"text":">?>? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Detailed action names can have three formats."}]},{"inlineContent":[{"type":"text","text":"The first format is used to represent an action name with no target"},{"text":" ","type":"text"},{"type":"text","text":"value and consists of just an action name containing no whitespace"},{"type":"text","text":" "},{"text":"nor the characters ","type":"text"},{"type":"codeVoice","code":":"},{"type":"text","text":", "},{"type":"codeVoice","code":"("},{"text":" or ","type":"text"},{"code":")","type":"codeVoice"},{"type":"text","text":".  For example: "},{"type":"codeVoice","code":"app.action"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The second format is used to represent an action with a target value"},{"text":" ","type":"text"},{"type":"text","text":"that is a non-empty string consisting only of alphanumerics, plus "},{"type":"codeVoice","code":"-"},{"type":"text","text":" "},{"type":"text","text":"and "},{"code":".","type":"codeVoice"},{"type":"text","text":".  In that case, the action name and target value are"},{"type":"text","text":" "},{"type":"text","text":"separated by a double colon (````).  For example:"},{"type":"text","text":" "},{"code":"app.action","type":"codeVoice"},{"text":"target``.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The third format is used to represent an action with any type of"},{"text":" ","type":"text"},{"type":"text","text":"target value, including strings.  The target value follows the action"},{"text":" ","type":"text"},{"text":"name, surrounded in parens.  For example: ","type":"text"},{"type":"codeVoice","code":"app.action(42)"},{"type":"text","text":".  The"},{"type":"text","text":" "},{"text":"target value is parsed using [func","type":"text"},{"type":"codeVoice","code":"GLib.Variant.parse"},{"type":"text","text":"].  If a tuple-typed"},{"text":" ","type":"text"},{"text":"value is desired, it must be specified in the same way, resulting in","type":"text"},{"text":" ","type":"text"},{"text":"two sets of parens, for example: ","type":"text"},{"type":"codeVoice","code":"app.action((1,2,3)`)`.  A string target can be specified this way as well: "},{"text":"app.action(‘target’)``.","type":"text"},{"type":"text","text":" "},{"text":"For strings, this third format must be used if target value is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"empty or contains characters other than alphanumerics, "},{"code":"-","type":"codeVoice"},{"type":"text","text":" and `.`."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this function returns "},{"type":"codeVoice","code":"TRUE"},{"text":", a non-","type":"text"},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" value is guaranteed to be returned"},{"type":"text","text":" "},{"text":"in ","type":"text"},{"type":"codeVoice","code":"actionName"},{"type":"text","text":" (if a pointer is passed in). A "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" value may still be"},{"type":"text","text":" "},{"text":"returned in ","type":"text"},{"code":"targetValue","type":"codeVoice"},{"type":"text","text":", as the "},{"code":"detailedName","type":"codeVoice"},{"text":" may not contain a target.","type":"text"}]},{"inlineContent":[{"text":"If returned, the [type[Variant](\/\/documentation\/glib\/variant] in ","type":"text"},{"code":"targetValue","type":"codeVoice"},{"text":" is guaranteed to not be floating.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/actionParse(detailedName:actionName:targetValue:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"actionParse","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"detailedName"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"actionName"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp