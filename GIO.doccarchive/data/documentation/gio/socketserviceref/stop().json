{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"stop"},{"kind":"text","text":"()"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This call is thread-safe, so it may be called from a thread","type":"text"},{"text":" ","type":"text"},{"text":"handling an incoming client request.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Note that this only stops accepting new connections; it does not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"close the listening sockets, and you can call"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_service_start()"},{"type":"text","text":" again later to begin listening again. To"},{"type":"text","text":" "},{"type":"text","text":"close the listening sockets, call "},{"type":"codeVoice","code":"g_socket_listener_close()"},{"type":"text","text":". (This"},{"type":"text","text":" "},{"type":"text","text":"will happen automatically when the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketService"},{"text":" is finalized.)","type":"text"}]},{"inlineContent":[{"type":"text","text":"This must be called before calling "},{"type":"codeVoice","code":"g_socket_listener_close()"},{"text":" as","type":"text"},{"type":"text","text":" "},{"text":"the socket service will start accepting connections immediately","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when a new socket is added."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef","doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef\/SocketServiceProtocol-Implementations"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/