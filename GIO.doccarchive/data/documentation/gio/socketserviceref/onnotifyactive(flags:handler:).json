odule":"GIO","modules":[{"name":"GIO"}],"title":"onNotifyActive(flags:handler:)"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"onNotifyActive","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags","kind":"typeIdentifier"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"kind":"text","text":" ("},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketServiceRef","text":"SocketServiceRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO16SocketServiceRefV"},{"kind":"text","text":", "},{"text":"ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"languages":["swift"],"platforms":["macOS"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}],"name":"flags"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The signal handler to call"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"notifyActive"},{"type":"text","text":" signal is emitted"}]}],"name":"handler"}],"kind":"parameters"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that getting this signal doesn’t itself guarantee that the value of"},{"type":"text","text":" "},{"type":"text","text":"the property has actually changed. When it is emitted is determined by the"},{"type":"text","text":" "},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"text":" ","type":"text"},{"type":"text","text":"[explicit_notify](\/\/documentation\/gobject\/explicit_notify, then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"text":" being emitted, even if the new value is the same as the old.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If they did pass [explicit_notify](\/\/documentation\/gobject\/explicit_notify, then this signal is emitted only"},{"type":"text","text":" "},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"code":"g_signal_connect()","type":"codeVoice"},{"type":"text","text":" call, like this:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"#class@GObject.Pa