{"sections":[],"variants":[{"paths":["\/documentation\/gio\/charsetconverter\/init_(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/CharsetConverter","doc:\/\/GIO\/documentation\/GIO\/CharsetConverter\/InitableProtocol-Implementations"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Instance Method","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"externalID":"s:3GIO16InitableProtocolPAAE5init_11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO16CharsetConverterC","title":"init_(cancellable:)","symbolKind":"method","extendedModule":"GIO"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverter\/init_(cancellable:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Initializes the object implementing the interface."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"init_"},{"kind":"text","text":"("},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This method is intended for language bindings. If writing in C,","type":"text"},{"text":" ","type":"text"},{"code":"g_initable_new()","type":"codeVoice"},{"text":" should typically be used instead.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The object must be initialized before any real use after initial","type":"text"},{"type":"text","text":" "},{"type":"text","text":"construction, either with this function or "},{"code":"g_async_initable_init_async()","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"Implementations may also support cancellation. If "},{"type":"codeVoice","code":"cancellable"},{"text":" is not ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"then initialization can be cancelled by triggering the cancellable object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from another thread. If the operation was cancelled, the error"},{"text":" ","type":"text"},{"type":"codeVoice","code":"cancelled"},{"text":" will be returned. If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"the object doesn’t support cancellable initialization the error"},{"type":"text","text":" "},{"type":"codeVoice","code":"notSupported"},{"type":"text","text":" will be returned."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the object is not initialized, or initialization returns with an"},{"type":"text","text":" "},{"text":"error, then all operations on the object except ","type":"text"},{"type":"codeVoice","code":"g_object_ref()"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" are considered to be invalid, and have undefined"},{"type":"text","text":" "},{"type":"text","text":"behaviour. See the "},{"type":"reference","identifier":"#iface@Gio.Initable#description","isActive":true},{"type":"text","text":" for more details."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Callers should not assume that a class which implements "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","isActive":true},{"type":"text","text":" can be"},{"text":" ","type":"text"},{"text":"initialized multiple times, unless the class explicitly documents itself as","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"supporting this. Generally, a class’ implementation of "},{"code":"init()","type":"codeVoice"},{"type":"text","text":" can assume"},{"text":" ","type":"text"},{"type":"text","text":"(and assert) that it will only be called once. Previously, this documentation"},{"type":"text","text":" "},{"text":"recommended all ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable"},{"text":" implementations should be idempotent; that","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"recommendation was relaxed in GLib 2.54."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a class explicitly supports being initialized multiple times, it is"},{"text":" ","type":"text"},{"type":"text","text":"recommended that the method is idempotent: multiple calls with the same"},{"type":"text","text":" "},{"text":"arguments should return the same results. Only the first call initializes","type":"text"},{"type":"text","text":" "},{"text":"the object; further calls return the result of the first call.","type":"text"}]},{"inlineContent":[{"type":"text","text":"One reason why a class might need to support idempotent initialization is if"},{"text":" ","type":"text"},{"type":"text","text":"it is designed to be used via the singleton pattern, with a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GObjectClass.constructor"},{"type":"text","text":" that sometimes returns an existing instance."},{"type":"text","text":" "},{"type":"text","text":"In this pattern, a caller would expect to be able to call "},{"type":"codeVoice","code":"g_initable_init()"},{"type":"text","text":" "},{"text":"on the result of ","type":"text"},{"type":"codeVoice","code":"g_object_new()"},{"type":"text","text":", regardless of whether it is in fact a new"},{"type":"text","text":" "},{"text":"instance.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CharsetConverter/InitableProtocol-Implementations":{"abstract":[],"title":"InitableProtocol Implementations","identifier":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverter\/InitableProtocol-Implementations","url":"\/documentation\/gio\/charsetconverter\/initableprotocol-implementations","type":"topic","kind":"article","role":"collectionGroup"},"doc://GIO/documentation/GIO/Converter":{"kind":"symbol","type":"topic","title":"Converter","role":"symbol","abstract":[{"type":"codeVoice","code":"GConverter"},{"type":"text","text":" is an interface for streaming conversions."}],"url":"\/documentation\/gio\/converter","identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Converter","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Converter"}]},"doc://GIO/documentation/GIO/CharsetConverter":{"kind":"symbol","type":"topic","title":"CharsetConverter","role":"symbol","abstract":[{"type":"codeVoice","code":"GCharsetConverter"},{"type":"text","text":" is an implementation of [iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter","isActive":true,"type":"reference"},{"text":"] based on","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[struct[IConv](\/\/documentation\/glib\/iconv]."}],"url":"\/documentation\/gio\/charsetconverter","identifier":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverter","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CharsetConverter"}],"navigatorTitle":[{"text":"CharsetConverter","kind":"identifier"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"#iface@Gio.Initable#description":{"url":"#iface@Gio.Initable#description","title":"description","titleInlineContent":[{"text":"description","type":"text"}],"type":"link","identifier":"#iface@Gio.Initable#description"},"doc://GIO/documentation/GIO/AsyncInitable":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","title":"AsyncInitable","url":"\/documentation\/gio\/asyncinitable","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncInitable","kind":"identifier"}],"navigatorTitle":[{"text":"AsyncInitable","kind":"identifier"}],"type":"topic","abstract":[{"code":"GAsyncInitable","type":"codeVoice"},{"type":"text","text":" is an interface for asynchronously initializable objects."}]},"doc://GIO/documentation/GIO/Initable":{"kind":"symbol","type":"topic","url":"\/documentation\/gio\/initable","navigatorTitle":[{"text":"Initable","kind":"identifier"}],"title":"Initable","identifier":"doc:\/\/GIO\/documentation\/GIO\/Initable","role":"symbol","abstract":[{"type":"codeVoice","code":"GInitable"},{"type":"text","text":" is implemented by objects that can fail during"},{"type":"text","text":" "},{"text":"initialization. If an object implements this interface then","type":"text"},{"type":"text","text":" "},{"text":"it must be initialized as the first thing after construction,","type":"text"},{"text":" ","type":"text"},{"text":"either via [method","type":"text"},{"type":"codeVoice","code":"Gio.Initable.init"},{"text":"] or [method","type":"text"},{"type":"codeVoice","code":"Gio.AsyncInitable.init_async"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"text":"(the latter is only available if it also implements [iface","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/AsyncInitable","type":"reference"},{"type":"text","text":"])."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Initable"}]},"doc://GIO/documentation/GIO/CharsetConverter/init_(cancellable:)":{"role":"symbol","type":"topic","url":"\/documentation\/gio\/charsetconverter\/init_(cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"init_","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CharsetConverter\/init_(cancellable:)","abstract":[{"text":"Initializes the object implementing the interface.","type":"text"}],"title":"init_(cancellable:)","kind":"symbol"}}}