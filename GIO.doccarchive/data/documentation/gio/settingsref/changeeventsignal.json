{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"symbolKind":"property","extendedModule":"GIO","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"changeEventSignal","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO18SettingsSignalNameO","kind":"typeIdentifier","text":"SettingsSignalName"}],"roleHeading":"Type Property","title":"changeEventSignal","externalID":"s:3GIO16SettingsProtocolPAAE17changeEventSignalAA0bF4NameOvpZ::SYNTHESIZED::s:3GIO11SettingsRefV","role":"symbol","modules":[{"name":"GIO"}]},"sections":[],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"changeEventSignal","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSignalName","text":"SettingsSignalName","preciseIdentifier":"s:3GIO18SettingsSignalNameO"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"flags","content":[{"inlineContent":[{"type":"text","text":"Flags"}],"type":"paragraph"}]},{"name":"unownedSelf","content":[{"inlineContent":[{"type":"text","text":"Reference to instance of self"}],"type":"paragraph"}]},{"name":"keys","content":[{"inlineContent":[{"type":"text","text":"Array of the   keys which have changed"}],"type":"paragraph"}]},{"name":"nKeys","content":[{"inlineContent":[{"type":"text","text":"The length of the "},{"code":"keys","type":"codeVoice"},{"type":"text","text":" array, or "},{"type":"codeVoice","code":"0"}],"type":"paragraph"}]},{"name":"handler","content":[{"inlineContent":[{"type":"text","text":"True to stop other handlers from being invoked for the   event, false to propagate the event further"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"You should connect to this signal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"only if you are interested in viewing groups of changes before they"},{"text":" ","type":"text"},{"type":"text","text":"are split out into multiple emissions of the [signal[Settings](\/\/documentation\/gio\/settings\/onchanged(flags:handler:)] signal."},{"type":"text","text":" "},{"text":"For most use cases it is more appropriate to use the [signal[Settings](\/\/documentation\/gio\/settings\/onchanged(flags:handler:)] signal.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In the event that the change event applies to one or more specified","type":"text"},{"type":"text","text":" "},{"type":"text","text":"keys, "},{"code":"keys","type":"codeVoice"},{"type":"text","text":" will be an array of [alias[Quark](\/\/documentation\/glib\/quark]s of length "},{"code":"nKeys","type":"codeVoice"},{"type":"text","text":".  In the"},{"text":" ","type":"text"},{"type":"text","text":"event that the change event applies to the [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Settings","isActive":true,"type":"reference"},{"type":"text","text":"] object as a"},{"text":" ","type":"text"},{"text":"whole (ie: potentially every key has been changed) then ","type":"text"},{"type":"codeVoice","code":"keys"},{"type":"text","text":" will"},{"text":" ","type":"text"},{"type":"text","text":"be "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":" and "},{"code":"nKeys","type":"codeVoice"},{"text":" will be ","type":"text"},{"code":"0","type":"codeVoice"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"The default handler for this signal invokes the [signal[Settings](\/\/documentation\/gio\/settings\/onchanged(flags:handler:)] signal","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for each affected key.  If any other connected handler returns"},{"text":" ","type":"text"},{"text":"true then this default functionality will be suppressed.","type":"text"}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"text":"This represents the underlying ","type":"text"},{"type":"codeVoice","code":"change-event"},{"type":"text","text":" signal"}],"type":"paragraph"}],"style":"note","type":"aside"},{"type":"aside","style":"warning","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"onChangeEvent","type":"codeVoice"},{"text":" wrapper for this signal could not be generated because it contains unimplemented features: { (4)  gpointer argument is not yet supported, (7)  array argument or return type is not allowed }","type":"text"}]}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Instead, you can connect ","type":"text"},{"code":"changeEventSignal","type":"codeVoice"},{"text":" using the ","type":"text"},{"type":"codeVoice","code":"connect(signal:)"},{"text":" methods","type":"text"}]}],"type":"aside"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/changeEventSignal","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/gio\/settingsref\/changeeventsignal"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsRef","doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/SettingsProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Emitted once per change event that affects this settings object."}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/Settings":{"title":"Settings","kind":"symbol","url":"\/documentation\/gio\/settings","abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"GSettings"},{"type":"text","text":" class provides a convenient API for storing and retrieving"},{"t