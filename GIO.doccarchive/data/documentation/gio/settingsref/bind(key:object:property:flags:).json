ype":"text","text":" of "},{"type":"codeVoice","code":"object"},{"type":"text","text":"."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"bind","kind":"identifier"},{"text":"<","kind":"text"},{"text":"GObjectObjectT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"key"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"object","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GObjectObjectT","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"property","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"SettingsBindFlags","kind":"typeIdentifier","preciseIdentifier":"s:3GIO17SettingsBindFlagsV","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsBindFlags"},{"kind":"text","text":") "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"GObjectObjectT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B8ProtocolP","text":"ObjectProtocol"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The binding uses the default GIO mapping functions to map"},{"type":"text","text":" "},{"type":"text","text":"between the settings and property values. These functions"},{"text":" ","type":"text"},{"type"