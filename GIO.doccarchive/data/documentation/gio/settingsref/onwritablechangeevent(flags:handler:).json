{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"onWritableChangeEvent"},{"text":"(","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef","text":"SettingsRef","preciseIdentifier":"s:3GIO11SettingsRefV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"UInt","preciseIdentifier":"s:Su"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") -> "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}]}]},{"kind":"parameters","parameters":[{"name":"flags","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Flags"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"True to stop other handlers from being invoked for the   event, false to propagate the event further"},{"text":" ","type":"text"},{"type":"text","text":"Run the given callback whenever the "},{"code":"writableChangeEvent","type":"codeVoice"},{"type":"text","text":" signal is emitted"}]}],"name":"handler"}]},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should connect"},{"type":"text","text":" "},{"text":"to this signal if you are interested in viewing groups of changes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"before they are split out into multiple emissions of the"},{"type":"text","text":" "},{"text":"[signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)] signal.  For most use cases it is more","type":"text"},{"type":"text","text":" "},{"text":"appropriate to use the [signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)] signal.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the event that the writability change applies only to a single"},{"text":" ","type":"text"},{"text":"key, ","type":"text"},{"code":"key","type":"codeVoice"},{"text":" will be set to the [alias[Quark](\/\/documentation\/glib\/quark] for that key.  In the event","type":"text"},{"type":"text","text":" "},{"text":"that the writability change affects the entire settings object,","type":"text"},{"text":" ","type":"text"},{"code":"key","type":"codeVoice"},{"text":" will be ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default handler for this signal invokes the [signal[Settings](\/\/documentation\/gio\/settings\/onwritablechanged(flags:handler:)]"},{"text":" ","type":"text"},{"text":"and [signal[Settings](\/\/documentation\/gio\/settings\/onchanged(flags:handler:)] signals for each affected key.  This is done because","type":"text"},{"text":" ","type":"text"},{"text":"changes in writability might also imply changes in value (if for","type":"text"},{"type":"text","text":" "},{"text":"example, a new mandatory setting is introduced).  If any other","type":"text"},{"type":"text","text":" "},{"text":"connected handler returns true then this default functionality","type":"text"},{"type":"text","text":" "},{"text":"will be suppressed.","type":"text"}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"type":"codeVoice","code":"writable-change-event"},{"type":"text","text":" signal"}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/SettingsRef/SettingsProtocol-Implementations":{"kind":"article","role":"collectionGroup","