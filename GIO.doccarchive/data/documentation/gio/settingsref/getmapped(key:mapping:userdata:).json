{"abstract":[{"text":"Gets the value that is stored at ","type":"text"},{"type":"codeVoice","code":"key"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"settings"},{"text":", subject to","type":"text"},{"type":"text","text":" "},{"text":"application-level validation\/mapping.","type":"text"}],"variants":[{"paths":["\/documentation\/gio\/settingsref\/getmapped(key:mapping:userdata:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/getMapped(key:mapping:userData:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"role":"symbol","extendedModule":"GIO","externalID":"s:3GIO16SettingsProtocolPAAE9getMapped3key7mapping8userDataSvSgSPys4Int8VGSg_s5Int32VSpySo9_GVariantVGSg_SpyAHGSgAHtXCAHtF::SYNTHESIZED::s:3GIO11SettingsRefV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getMapped"},{"text":"(","kind":"text"},{"text":"key","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"mapping"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@GSettingsGetMapping","text":"GSettingsGetMapping"},{"kind":"text","text":", "},{"kind":"externalParam","text":"userData"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?) -> "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"?","kind":"text"}],"symbolKind":"method","title":"getMapped(key:mapping:userData:)","roleHeading":"Instance Method","modules":[{"name":"GIO"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsRef","doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/SettingsProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getMapped"},{"kind":"text","text":"("},{"text":"key","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"mapping"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSettingsGetMapping","text":"GSettingsGetMapping","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"? = nil) -> ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"?","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"You should use this function when the application needs to perform","type":"text"},{"type":"text","text":" "},{"text":"some processing on the value of the key (for example, parsing).  The","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"mapping"},{"type":"text","text":" function performs that processing.  If the function"},{"type":"text","text":" "},{"text":"indicates that the processing was unsuccessful (due to a parse error,","type":"text"},{"type":"text","text":" "},{"text":"for example) then the mapping is tried again with another value.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This allows a robust ‘fall back to defaults’ behaviour to be","type":"text"},{"type":"text","text":" "},{"text":"implemented somewhat automatically.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first value that is tried is the user’s setting for the key.  If"},{"type":"text","text":" "},{"text":"the mapping function fails to map this value, other values may be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"tried in an unspecified order (system or site defaults, translated"},{"type":"text","text":" "},{"text":"schema default values, untranslated schema default values, etc).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the mapping function fails for all possible values, one additional","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"attempt is made: the mapping function is called with a "},{"code":"NULL","type":"codeVoice"},{"text":" value.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"If the mapping function still indicates failure at this point then"},{"text":" ","type":"text"},{"type":"text","text":"the application will be aborted."}]},{"inlineContent":[{"type":"text","text":"The result parameter for the "},{"code":"mapping","type":"codeVoice"},{"text":" function is pointed to a","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"gpointer"},{"type":"text","text":" which is initially set to "},{"code":"NULL","type":"codeVoice"},{"text":".  The same pointer is given","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to each invocation of "},{"code":"mapping","type":"codeVoice"},{"type":"text","text":".  The final value of that "},{"code":"gpointer","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"what is returned by this function.  ","type":"text"},{"code":"NULL","type":"codeVoice"},{"text":" is valid; it is returned","type":"text"},{"type":"text","text":" "},{"text":"just as any other value would be.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://GIO/documentation/GIO/SettingsRef/SettingsProtocol-Implementations":{"kind":"article","role":"collectionGroup","type":"topic","title":"SettingsProtocol Implementations","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/SettingsProtocol-Implementations","url":"\/documentation\/gio\/settingsref\/settingsprotocol-implementations"},"doc://GIO/documentation/GIO/SettingsRef/getMapped(key:mapping:userData:)":{"type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/getMapped(key:mapping:userData:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getMapped"},{"text":"(","kind":"text"},{"text":"key","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","preciseIdentifier":"s:SP","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"text":"mapping","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GSettingsGetMapping","kind":"typeIdentifier","text":"GSettingsGetMapping"},{"kind":"text","text":", "},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"kind":"text","text":"?) -> "},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?"}],"title":"getMapped(key:mapping:userData:)","url":"\/documentation\/gio\/settingsref\/getmapped(key:mapping:userdata:)","abstract":[{"type":"text","text":"Gets the value that is stored at "},{"type":"codeVoice","code":"key"},{"text":" in ","type":"text"},{"type":"codeVoice","code":"settings"},{"type":"text","text":", subject to"},{"text":" ","type":"text"},{"text":"application-level validation\/mapping.","type":"text"}],"role":"symbol"},"doc://GIO/documentation/GIO/SettingsRef":{"abstract":[{"type":"text","text":"The "},{"code":"GSettings","type":"codeVoice"},{"type":"text","text":" class provides a convenient API for storing and retrieving"},{"type":"text","text":" "},{"text":"application settings.","type":"text"}],"url":"\/documentation\/gio\/settingsref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef","type":"topic","title":"SettingsRef","navigatorTitle":[{"text":"SettingsRef","kind":"identifier"}],"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsRef"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}