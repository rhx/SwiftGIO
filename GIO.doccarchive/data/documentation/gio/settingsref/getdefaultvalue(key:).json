{"abstract":[{"type":"text","text":"Gets the ‘default value’ of a key."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsRef","doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/SettingsProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getDefaultValue"},{"kind":"text","text":"("},{"kind":"externalParam","text":"key"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"text":"!","kind":"text"}],"title":"getDefaultValue(key:)","role":"symbol","extendedModule":"GIO","externalID":"s:3GIO16SettingsProtocolPAAE15getDefaultValue3key4GLib10VariantRefVSgSPys4Int8VGSg_tF::SYNTHESIZED::s:3GIO11SettingsRefV","roleHeading":"Instance Method","modules":[{"name":"GIO"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/getDefaultValue(key:)","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"variants":[{"paths":["\/documentation\/gio\/settingsref\/getdefaultvalue(key:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getDefaultValue","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"key"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"kind":"text","text":">!) -> "},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This is the value that would be read if [method","type":"text"},{"type":"codeVoice","code":"Gio.Settings.reset"},{"type":"text","text":"] were to be"},{"type":"text","text":" "},{"type":"text","text":"called on the key."}]},{"inlineContent":[{"type":"text","text":"Note that this may be a different value than returned by"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"type":"codeVoice","code":"Gio.SettingsSchemaKey.get_default_value"},{"type":"text","text":"] if the system administrator"},{"text":" ","type":"text"},{"type":"text","text":"has provided a default value."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Comparing the return values of [method"},{"code":"Gio.Settings.get_default_value","type":"codeVoice"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"Gio.Settings.get_value","type":"codeVoice"},{"type":"text","text":"] is not sufficient for determining if a value"},{"type":"text","text":" "},{"type":"text","text":"has been set because the user may have explicitly set the value to"},{"text":" ","type":"text"},{"type":"text","text":"something that happens to be equal to the default.  The difference"},{"type":"text","text":" "},{"type":"text","text":"here is that if the default changes in the future, the user’s key"},{"text":" ","type":"text"},{"type":"text","text":"will still be set."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function may be useful for adding an indication to a UI of what","type":"text"},{"text":" ","type":"text"},{"text":"the default value was before the user set it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is a programmer error to give a ","type":"text"},{"code":"key","type":"codeVoice"},{"type":"text","text":" that isn’t contained in the"},{"type":"text","text":" "},{"type":"text","text":"schema for "},{"type":"codeVoice","code":"settings"},{"type":"text","text":"."}]}]}],"references":{"doc://GIO/documentation/GIO/SettingsRef/getDefaultValue(key:)":{"abstract":[{"type":"text","text":"Gets the ‘default value’ of a key."}],"url":"\/documentation\/gio\/settingsref\/getdefaultvalue(key:)","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/getDefaultValue(key:)","type":"topic","title":"getDefaultValue(key:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getDefaultValue"},{"kind":"text","text":"("},{"text":"key","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier","text":"gchar"},{"kind":"text","text":">!) -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"text":"!","kind":"text"}]},"doc://GIO/documentation/GIO/SettingsRef/SettingsProtocol-Implementations":{"kind":"article","role":"collectionGroup","type":"topic","title":"SettingsProtocol Implementations","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef\/SettingsProtocol-Implementations","url":"\/documentation\/gio\/settingsref\/settingsprotocol-implementations"},"doc://GIO/documentation/GIO/SettingsRef":{"abstract":[{"type":"text","text":"The "},{"code":"GSettings","type":"codeVoice"},{"type":"text","text":" class provides a convenient API for storing and retrieving"},{"type":"text","text":" "},{"text":"application settings.","type":"text"}],"url":"\/documentation\/gio\/settingsref","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsRef","type":"topic","title":"SettingsRef","navigatorTitle":[{"text":"SettingsRef","kind":"identifier"}],"