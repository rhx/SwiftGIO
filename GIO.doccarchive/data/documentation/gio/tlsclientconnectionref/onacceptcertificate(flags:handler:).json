{"abstract":[{"type":"text","text":"Emitted during the TLS handshake after the peer certificate has"},{"text":" ","type":"text"},{"type":"text","text":"been received. You can examine "},{"code":"peerCert","type":"codeVoice"},{"text":"’s certification path by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_tls_certificate_get_issuer()"},{"text":" on it.","type":"text"}],"metadata":{"title":"onAcceptCertificate(flags:handler:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onAcceptCertificate","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"ConnectFlags","preciseIdentifier":"s:10GLibObject12ConnectFlagsV"},{"kind":"text","text":", "},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"TLSConnectionRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"kind":"text","text":", "},{"text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"TLSCertificateFlags","preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"modules":[{"name":"GIO"}],"extendedModule":"GIO","symbolKind":"method","role":"symbol","externalID":"s:3GIO21TLSConnectionProtocolPAAE19onAcceptCertificate5flags7handlerSi10GLibObject12ConnectFlagsV_SbAA0B3RefV_AA014TLSCertificateM0VAA0nL0VtctF::SYNTHESIZED::s:3GIO22TLSClientConnectionRefV","roleHeading":"Instance Method"},"kind":"symbol","identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/onAcceptCertificate(flags:handler:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/TLSConnectionProtocol-Implementations"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/tlsclientconnectionref\/onacceptcertificate(flags:handler:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"onAcceptCertificate"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","text":"ConnectFlags"},{"kind":"text","text":" = ConnectFlags(0), "},{"text":"handler","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"text":"TLSConnectionRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","preciseIdentifier":"s:3GIO16TLSConnectionRefV"},{"kind":"text","text":", "},{"text":"TLSCertificateRef","preciseIdentifier":"s:3GIO17TLSCertificateRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateRef","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"preciseIdentifier":"s:3GIO19TLSCertificateFlagsV","kind":"typeIdentifier","text":"TLSCertificateFlags","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSCertificateFlags"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"platforms":["macOS"],"languages":["swift"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Flags","type":"text"}]}],"name":"flags"},{"name":"handler","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"true","type":"codeVoice"},{"text":" to accept ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" (which will also immediately end the signal emission). "},{"type":"codeVoice","code":"false"},{"text":" to allow the signal emission to continue, which will cause the handshake to fail if no one else overrides it.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Run the given callback whenever the "},{"type":"codeVoice","code":"acceptCertificate"},{"type":"text","text":" signal is emitted"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"For a client-side connection, ","type":"text"},{"type":"codeVoice","code":"peerCert"},{"type":"text","text":" is the server’s"},{"text":" ","type":"text"},{"type":"text","text":"certificate, and the signal will only be emitted if the"},{"text":" ","type":"text"},{"type":"text","text":"certificate was not acceptable according to "},{"code":"conn","type":"codeVoice"},{"type":"text","text":"’s"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"type":"text","text":". If you would like the"},{"text":" ","type":"text"},{"type":"text","text":"certificate to be accepted despite "},{"code":"errors","type":"codeVoice"},{"type":"text","text":", return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" from the"},{"type":"text","text":" "},{"type":"text","text":"signal handler. Otherwise, if no handler accepts the certificate,"},{"type":"text","text":" "},{"text":"the handshake will fail with ","type":"text"},{"code":"badCertificate","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"GLib guarantees that if certificate verification fails, this signal"},{"type":"text","text":" "},{"type":"text","text":"will be emitted with at least one error will be set in "},{"type":"codeVoice","code":"errors"},{"text":", but","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it does not guarantee that all possible errors will be set."},{"type":"text","text":" "},{"text":"Accordingly, you may not safely decide to ignore any particular","type":"text"},{"type":"text","text":" "},{"type":"text","text":"type of error. For example, it would be incorrect to ignore"},{"text":" ","type":"text"},{"code":"expired","type":"codeVoice"},{"type":"text","text":" if you want to allow expired"},{"type":"text","text":" "},{"text":"certificates, because this could potentially be the only error flag","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"set even if other problems exist with the certificate."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For a server-side connection, ","type":"text"},{"code":"peerCert","type":"codeVoice"},{"type":"text","text":" is the certificate"},{"text":" ","type":"text"},{"type":"text","text":"presented by the client, if this was requested via the server’s"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":". On the server side,"},{"type":"text","text":" "},{"type":"text","text":"the signal is always emitted when the client presents a"},{"text":" ","type":"text"},{"text":"certificate, and the certificate will only be accepted if a","type":"text"},{"text":" ","type":"text"},{"text":"handler returns ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that if this signal is emitted as part of asynchronous I\/O"},{"type":"text","text":" "},{"text":"in the main thread, then you should not attempt to interact with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the user before returning from the signal handler. If you want to"},{"type":"text","text":" "},{"type":"text","text":"let the user decide whether or not to accept the certificate, you"},{"text":" ","type":"text"},{"text":"would have to return ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" from the signal handler on the first"},{"text":" ","type":"text"},{"type":"text","text":"attempt, and then after the connection attempt returns a"},{"text":" ","type":"text"},{"code":"badCertificate","type":"codeVoice"},{"type":"text","text":", you can interact with the user, and"},{"text":" ","type":"text"},{"text":"if the user decides to accept the certificate, remember that fact,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"create a new connection, and return "},{"code":"true","type":"codeVoice"},{"type":"text","text":" from the signal handler"},{"text":" ","type":"text"},{"text":"the next time.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If you are doing I\/O in another thread, you do not"},{"type":"text","text":" "},{"text":"need to worry about this, and can simply block in the signal","type":"text"},{"type":"text","text":" "},{"type":"text","text":"handler until the UI thread returns an answer."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"accept-certificate","type":"codeVoice"},{"type":"text","text":" signal"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}]}],"references":{"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO/TLSConnectionRef":{"type":"topic","url":"\/documentation\/gio\/tlsconnectionref","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TLSConnectionRef"}],"abstract":[{"type":"codeVoice","code":"GTlsConnection"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"type":"text","text":" "},{"text":"a [class","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream"},{"type":"text","text":"] and provides TLS encryption on top of it. Its"},{"type":"text","text":" "},{"text":"subclasses, [iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true,"type":"reference"},{"type":"text","text":"] and"},{"text":" ","type":"text"},{"text":"[iface","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","type":"reference","isActive":true},{"type":"text","text":"], implement client-side and server-side TLS,"},{"text":" ","type":"text"},{"type":"text","text":"respectively."}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnectionRef","title":"TLSConnectionRef","navigatorTitle":[{"text":"TLSConnectionRef","kind":"identifier"}]},"doc://GIO/documentation/GIO/TLSServerConnection":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","navigatorTitle":[{"text":"TLSServerConnection","kind":"identifier"}],"kind":"symbol","type":"topic","title":"TLSServerConnection","url":"\/documentation\/gio\/tlsserverconnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSServerConnection"