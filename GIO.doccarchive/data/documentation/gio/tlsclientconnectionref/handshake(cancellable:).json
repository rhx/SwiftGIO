{"abstract":[{"type":"text","text":"Attempts a TLS handshake on "},{"type":"codeVoice","code":"conn"},{"text":".","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/handshake(cancellable:)"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/TLSConnectionProtocol-Implementations"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/tlsclientconnectionref\/handshake(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"handshake","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"On the client side, it is never necessary to call this method;","type":"text"},{"type":"text","text":" "},{"type":"text","text":"although the connection needs to perform a handshake after"},{"text":" ","type":"text"},{"type":"text","text":"connecting (or after sending a “STARTTLS”-type command),"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"type":"text","text":" will handle this for you automatically when you try"},{"type":"text","text":" "},{"text":"to send or receive data on the connection. You can call","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"type":"text","text":" manually if you want to know whether"},{"type":"text","text":" "},{"type":"text","text":"the initial handshake succeeded or failed (as opposed to just"},{"text":" ","type":"text"},{"text":"immediately trying to use ","type":"text"},{"code":"conn","type":"codeVoice"},{"text":" to read or write, in which case,","type":"text"},{"text":" ","type":"text"},{"text":"if it fails, it may not be possible to tell if it failed before or","type":"text"},{"text":" ","type":"text"},{"text":"after completing the handshake), but beware that servers may reject","type":"text"},{"type":"text","text":" "},{"type":"text","text":"client authentication after the handshake has completed, so a"},{"type":"text","text":" "},{"type":"text","text":"successful handshake does not indicate the connection will be usable."}]},{"inlineContent":[{"type":"text","text":"Likewise, on the server side, although a handshake is necessary at"},{"type":"text","text":" "},{"text":"the beginning of the communication, you do not need to call this","type":"text"},{"type":"text","text":" "},{"text":"function explicitly unless you want clearer error reporting.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Previously, calling "},{"type":"codeVoice","code":"g_tls_connection_handshake()"},{"text":" after the initial","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"handshake would trigger a rehandshake; however, this usage was"},{"text":" ","type":"text"},{"type":"text","text":"deprecated in GLib 2.60 because rehandshaking was removed from the"},{"type":"text","text":" "},{"text":"TLS protocol in TLS 1.3. Since GLib 2.64, calling this function after","type":"text"},{"type":"text","text":" "},{"text":"the initial handshake will no longer do anything.","type":"text"}]},{"type":"paragraph","inlineContent":[{"t