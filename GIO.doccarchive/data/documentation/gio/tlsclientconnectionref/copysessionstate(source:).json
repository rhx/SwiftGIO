{"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/TLSClientConnectionProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/copySessionState(source:)","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","symbolKind":"method","role":"symbol","extendedModule":"GIO","title":"copySessionState(source:)","externalID":"s:3GIO27TLSClientConnectionProtocolPAAE16copySessionState6sourceyqd___tAaBRd__lF::SYNTHESIZED::s:3GIO22TLSClientConnectionRefV","modules":[{"name":"GIO"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"copySessionState","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"TLSClientConnectionT"},{"text":">(","kind":"text"},{"text":"source","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TLSClientConnectionT"},{"text":")","kind":"text"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Possibly copies session state from one connection to another, for use","type":"text"},{"text":" ","type":"text"},{"text":"in TLS session resumption. This is not normally needed, but may be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"used when the same session needs to be used between different"},{"type":"text","text":" "},{"type":"text","text":"endpoints, as is required by some protocols, such as FTP over TLS."},{"text":" ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" should have already completed a handshake and, since TLS 1.3,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"it should have been used to read data at least once. "},{"type":"codeVoice","code":"conn"},{"type":"text","text":" should not"},{"type":"text","text":" "},{"type":"text","text":"have completed a handshake."}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"copySessionState"},{"text":"<","kind":"text"},{"text":"TLSClientConnectionT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"source","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSClientConnectionT","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"TLSClientConnectionT"},{"kind":"text","text":" : "},{"text":"TLSClientConnectionProtocol","preciseIdentifier":"s:3GIO27TLSClientConnectionProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionProtocol","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is not possible to know whether a call to this function will"},{"text":" ","type":"text"},{"text":"actually do anything. Because session resumption is normally used","type":"text"},{"type":"text","text":" "},{"text":"only for performance benefit, the TLS backend might not implement","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this function. Even if implemented, it may not actually succeed in"},{"text":" ","type":"text"},{"type":"text","text":"allowing "},{"code":"conn","type":"codeVoice"},{"text":" to resume ","type":"text"},{"code":"source","type":"codeVoice"},{"text":"’s TLS session, because the server","type":"text"},{"type":"text","text":" "},{"type":"text","text":"may not have sent a session resumption token to "},{"code":"source","type":"codeVoice"},{"type":"text","text":", or it may"},{"text":" ","type":"text"},{"text":"refuse to accept the token from ","type":"text"},{"type":"codeVoice","code":"conn"},{"type":"text","text":". There is no way to know"},{"text":" ","type":"text"},{"text":"whether a call to this function is actually successful.","type":"text"}]},{"inlineContent":[{"text":"Using this function is not required to benefit from session","type":"text"},{"type":"text","text":" "},{"text":"resumption. If the TLS backend supports session resumption, the","type":"text"},{"type":"text","text":" "},{"text":"session will be resumed automatically if it is possible to do so","type":"text"},{"type":"text","text":" "},{"type":"text","text":"without weakening the privacy guarantees normally provided by TLS,"},{"type":"text","text":" "},{"type":"text","text":"without need to call this function. For example, with TLS 1.3,"},{"type":"text","text":" "},{"text":"a session ticket will be automatically copied from any","type":"text"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection"},{"text":" that has previously received session tickets","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"from the server, provided a ticket is available that has not"},{"text":" ","type":"text"},{"text":"previously been used for session resumption, since session ticket","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"reuse would be a privacy weakness. Using this function causes the"},{"type":"text","text":" "},{"type":"text","text":"ticket to be copied without regard for privacy considerations."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/tlsclientconnectionref\/copysessionstate(source:)"]}],"kind":"symbol","references":{"doc://GIO/documentation/GIO/TLSClientConnection":{"url":"\/documentation\/gio\/tlsclientconnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","title":"TLSClientConnection","navigatorTitle":[{"text":"TLSClientConnection","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TLSClientConnection","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"type":"text","text":" "},{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection"},{"text":"], representing a client-side TLS connection.","type":"text"}],"type":"topic","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnectionRef":{"role":"symbol","title":"TLSClientConnectionRef","navigatorTitle":[{"kind":"identifier","text":"TLSClientConnectionRef"}],"type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSClientConnectionRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","type":"reference","isActive":true},{"type":"text","text":"], representing a client-side TLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef","url":"\/documentation\/gio\/tlsclientconnectionref"},"doc://GIO/documentation/GIO/TLSClientConnectionProtocol":{"type":"topic","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TLSClientConnectionProtocol"}],"title":"TLSClientConnectionProtocol","navigatorTitle":[{"text":"TLSClientConnectionProtocol","kind":"identifier"}],"url":"\/documentation\/gio\/tlsclientconnectionprotocol","abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"text":" is the client-side subclass of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","isActive":true},{"type":"text","text":"], representing a client-side TLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionProtocol","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnectionRef/copySessionState(source:)":{"abstract":[{"text":"Possibly copies session state from one connection to another, for use","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in TLS session resumption. This is not normally needed, but may be"},{"type":"text","text":" "},{"type":"text","text":"used when the same session needs to be used between different"},{"type":"text","text":" "},{"text":"endpoints, as is required by some protocols, such as FTP over TLS.","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"source"},{"text":" should have already completed a handshake and, since TLS 1.3,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"it should have been used to read data at least once. "},{"type":"codeVoice","code":"conn"},{"type":"text","text":" should not"},{"text":" ","type":"text"},{"type":"text","text":"have completed a handshake."}],"title":"copySessionState(source:)","type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/copySessionState(source:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"copySessionState"},{"text":"<","kind":"text"},{"text":"TLSClientConnectionT","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"source","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TLSClientConnectionT","kind":"typeIdentifier"},{"kind":"text","text":")"}],"url":"\/documentation\/gio\/tlsclientconnectionref\/copysessionstate(source:)"},"doc://GIO/documentation/GIO/TLSClientConnectionRef/TLSClientConnectionProtocol-Implementations":{"role":"collectionGroup","kind":"