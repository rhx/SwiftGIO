{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/tlsclientconnectionref\/close(cancellable:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"metadata":{"symbolKind":"method","title":"close(cancellable:)","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"kind":"text","text":"("},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"extendedModule":"GIO","modules":[{"name":"GIO"}],"externalID":"s:3GIO16IOStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO22TLSClientConnectionRefV","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef","doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/IOStreamProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"type":"text","text":" "},{"type":"text","text":"close the individual input and output streams, if they are not already"},{"text":" ","type":"text"},{"type":"text","text":"closed."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/close(cancellable:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Once the stream is closed, all other operations will return","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":". Closing a stream multiple times will not"},{"text":" ","type":"text"},{"text":"return an error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Closing a stream will automatically flush any outstanding buffers","type":"text"},{"type":"text","text":" "},{"text":"in the stream.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Streams will be automatically closed when the last reference"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file"},{"type":"text","text":" "},{"type":"text","text":"descriptor) open after the stream is closed. See the documentation for"},{"text":" ","type":"text"},{"type":"text","text":"the individual stream for details."}]},{"type":"paragraph","inlineContent":[{"text":"On failure the first error that happened will be reported, but the","type":"text"},{"type":"text","text":" "},{"text":"close operation will finish as much as possible. A stream that failed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations.","type":"text"},{"type":"text","text":" "},{"text":"Still, it is important to check and report the error to the user,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"otherwise there might be a loss of data as all data might not be written."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"type":"text","text":" is not NULL, then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"type":"text","text":"Cancelling a close will still leave the stream closed, but some streams"},{"text":" ","type":"text"},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors."}]},{"inlineContent":[{"text":"The default implementation of this method just calls close on the","type":"text"},{"type":"text","text":" "},{"text":"individual input\/output streams.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/TLSConnection":{"role":"symbol","url":"\/documentation\/gio\/tlsconnection","abstract":[{"code":"GTlsConnection","type":"codeVoice"},{"type":"text","text":" is the base TLS connection class type, which wraps"},{"text":" ","type":"text"},{"type":"text","text":"a [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true,"type":"reference"},{"text":"] and provides TLS encryption on top of it. Its","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subclasses, [iface"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnection","isActive":true},{"text":"] and","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[iface"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSServerConnection","isActive":true,"type":"reference"},{"type":"text","text":"], implement client-side and server-side TLS,"},{"type":"text","text":" "},{"type":"text","text":"respectively."}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSConnection","kind":"identifier"}],"title":"TLSConnection","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","navigatorTitle":[{"kind":"identifier","text":"TLSConnection"}],"type":"topic"},"doc://GIO/documentation/GIO/TLSClientConnectionRef":{"role":"symbol","title":"TLSClientConnectionRef","navigatorTitle":[{"kind":"identifier","text":"TLSClientConnectionRef"}],"type":"topic","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TLSClientConnectionRef","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GTlsClientConnection"},{"type":"text","text":" is the client-side subclass of"},{"text":" ","type":"text"},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSConnection","type":"reference","isActive":true},{"type":"text","text":"], representing a client-side TLS connection."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef","url":"\/documentation\/gio\/tlsclientconnectionref"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TLSClientConnectionRef/IOStreamProtocol-Implementations":{"title":"IOStreamProtocol Implementations","kind":"article","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/IOStreamProtocol-Implementations","abstract":[],"type":"topic","role":"collectionGroup","url":"\/documentation\/gio\/tlsclientconnectionref\/iostreamprotocol-implementations"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/TLSClientConnectionRef/close(cancellable:)":{"title":"close(cancellable:)","role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Closes the stream, releasing resources related to it. This will also"},{"text":" ","type":"text"},{"text":"close the individual input and output streams, if they are not already","type":"text"},{"type":"text","text":" "},{"text":"closed.","type":"text"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/TLSClientConnectionRef\/close(cancellable:)","url":"\/documentation\/gio\/tlsclientconnectionref\/close(cancellable:)"}}}