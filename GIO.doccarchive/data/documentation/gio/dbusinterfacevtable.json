{"metadata":{"title":"DBusInterfaceVTable","externalID":"s:3GIO19DBusInterfaceVTableC","symbolKind":"class","roleHeading":"Class","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"DBusInterfaceVTable","kind":"identifier"}],"navigatorTitle":[{"text":"DBusInterfaceVTable","kind":"identifier"}],"modules":[{"name":"GIO"}]},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP"],"kind":"relationships","type":"conformsTo"}],"sections":[],"topicSections":[{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(_:)-2bql4","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(_:)-57xyy","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(_:)-6lrfn","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(_:)-772y9","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(_:)-7r8jc","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(opaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(raw:)-618sc","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(raw:)-9w3jr","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(retaining:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(retainingCPointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(retainingOpaquePointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(retainingRaw:)-7vf64","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/init(retainingRaw:)-idr0"]},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/ptr"],"generated":true},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable\/DBusInterfaceVTableProtocol-Implementations"],"title":"Default Implementations"}],"abstract":[{"type":"text","text":"Virtual table for handling properties and method calls for a D-Bus"},{"type":"text","text":" "},{"type":"text","text":"interface."}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"DBusInterfaceVTable","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since 2.38, if you want to handle getting\/setting D-Bus properties"},{"text":" ","type":"text"},{"type":"text","text":"asynchronously, give "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" as your "},{"type":"codeVoice","code":"get_property()"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"set_property()"},{"text":" ","type":"text"},{"type":"text","text":"function. The D-Bus call will be directed to your "},{"code":"method_call","type":"codeVoice"},{"type":"text","text":" function,"},{"text":" ","type":"text"},{"type":"text","text":"with the provided "},{"code":"interface_name","type":"codeVoice"},{"type":"text","text":" set to “org.freedesktop.DBus.Properties”."}]},{"inlineContent":[{"type":"text","text":"Ownership of the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","isActive":true},{"type":"text","text":" object passed to the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"method_call()"},{"type":"text","text":" function is transferred to your handler; you must"},{"type":"text","text":" "},{"text":"call one of the methods of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","isActive":true},{"text":" to return a reply","type":"text"},{"type":"text","text":" "},{"text":"(possibly empty), or an error. These functions also take ownership","type":"text"},{"type":"text","text":" "},{"text":"of the passed-in invocation object, so unless the invocation","type":"text"},{"text":" ","type":"text"},{"text":"object has otherwise been referenced, it will be then be freed.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Calling one of these functions may be done within your"},{"text":" ","type":"text"},{"type":"codeVoice","code":"method_call()"},{"type":"text","text":" implementation but it also can be done at a later"},{"text":" ","type":"text"},{"text":"point to handle the method asynchronously.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The usual checks on the validity of the calls is performed. For","type":"text"},{"type":"text","text":" "},{"code":"Get","type":"codeVoice"},{"type":"text","text":" calls, an error is automatically returned if the property does"},{"type":"text","text":" "},{"type":"text","text":"not exist or the permissions do not allow access. The same checks are"},{"text":" ","type":"text"},{"text":"performed for ","type":"text"},{"code":"Set","type":"codeVoice"},{"type":"text","text":" calls, and the provided value is also checked for"},{"type":"text","text":" "},{"text":"being the correct type.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For both "},{"code":"Get","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Set"},{"type":"text","text":" calls, the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation"},{"type":"text","text":" "},{"type":"text","text":"passed to the "},{"type":"codeVoice","code":"method_call"},{"text":" handler can be queried with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_dbus_method_invocation_get_property_info()"},{"type":"text","text":" to get a pointer"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusPropertyInfo","type":"reference"},{"type":"text","text":" of the property."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have readable properties specified in your interface info,"},{"type":"text","text":" "},{"text":"you must ensure that you either provide a non-","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" "},{"code":"get_property``()","type":"codeVoice"},{"type":"text","text":" "},{"text":"function or provide implementations of both the ","type":"text"},{"type":"codeVoice","code":"Get"},{"text":" and ","type":"text"},{"code":"GetAll","type":"codeVoice"},{"type":"text","text":" "},{"text":"methods on org.freedesktop.DBus.Properties interface in your ","type":"text"},{"code":"method_call","type":"codeVoice"},{"text":" ","type":"text"},{"text":"function. Note that the required return type of the ","type":"text"},{"code":"Get","type":"codeVoice"},{"type":"text","text":" call is"},{"type":"text","text":" "},{"type":"codeVoice","code":"(v)"},{"type":"text","text":", not the type of the property. "},{"type":"codeVoice","code":"GetAll"},{"type":"text","text":" expects a return value"},{"type":"text","text":" "},{"text":"of type ","type":"text"},{"type":"codeVoice","code":"a{sv}"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If you have writable properties specified in your interface info,","type":"text"},{"type":"text","text":" "},{"text":"you must ensure that you either provide a non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" ","type":"text"},{"type":"codeVoice","code":"set_property``()"},{"text":" ","type":"text"},{"text":"function or provide an implementation of the ","type":"text"},{"type":"codeVoice","code":"Set"},{"type":"text","text":" call. If implementing"},{"text":" ","type":"text"},{"text":"the call, you must return the value of type ","type":"text"},{"type":"codeVoice","code":"G_VARIANT_TYPE_UNIT"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","isActive":true,"type":"reference"},{"type":"text","text":" type acts as an owner of an underlying "},{"code":"GDBusInterfaceVTable","type":"codeVoice"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","type":"reference"},{"text":" as a strong reference or owner of a ","type":"text"},{"type":"codeVoice","code":"GDBusInterfaceVTable"},{"text":" instance.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef","type":"reference"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GDBusInterfaceVTable","type":"codeVoice"},{"type":"text","text":" instance."}]}],"type":"aside","name":"Note","style":"note"}],"kind":"content"}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/gio\/dbusinterfacevtable"],"traits":[{"interfaceLanguage":"swift"}]}],"refer