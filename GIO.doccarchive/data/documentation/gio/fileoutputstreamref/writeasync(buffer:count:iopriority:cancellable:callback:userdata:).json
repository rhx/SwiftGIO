{"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"writeAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffer"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","kind":"typeIdentifier","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"ioPriority","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil, "},{"kind":"externalParam","text":"callback"},{"kind":"text","text":": "},{"text":"GAsyncReadyCallback","kind":"typeIdentifier","preciseIdentifier":"c:@T@GAsyncReadyCallback"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"userData"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"? = nil)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"During an async request no other sync and async calls are allowed,","type":"text"},{"text":" ","type":"text"},{"text":"and will result in ","type":"text"},{"type":"codeVoice","code":"pending"},{"type":"text","text":" errors."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A value of "},{"code":"count","type":"codeVoice"},{"type":"text","text":" larger than "},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":" will cause a"},{"text":" ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"type":"text","text":" error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written will be passed to the"},{"type":"text","text":" "},{"code":"callback","type":"codeVoice"},{"text":". It is not an error if this is not the same as the","type":"text"},{"type":"text","text":" "},{"text":"requested size, as it can happen e.g. on a partial I\/O error,","type":"text"},{"text":" ","type":"text"},{"text":"but generally we try to write as many bytes as requested.","type":"text"}]},{"inlineContent":[{"text":"You are guaranteed that this method will never fail with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"text":" - if ","type":"text"},{"type":"codeVoice","code":"stream"},{"type":"text","text":" can’t accept more data, the"},{"text":" ","type":"text"},{"type":"text","text":"method will just wait until this changes."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Any outstanding I\/O request with higher priority (lower numerical","type":"text"},{"type":"text","text":" "},{"text":"value) will be executed before an outstanding request with lower","type":"text"},{"text":" ","type":"text"},{"text":"priority. Default priority is [PRIORITY_DEFAULT](\/\/documentation\/glib\/priority_default.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The asynchronous methods have a default fallback that uses threads"},{"text":" ","type":"text"},{"type":"text","text":"to implement asynchronicity, so they are optional for inheriting"},{"text":" ","type":"text"},{"type":"text","text":"classes. However, if you override one you must override all."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the synchronous, blocking version of this function, see"},{"text":" ","type":"text"},{"code":"g_output_stream_write()","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Note that no copy of ","type":"text"},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" will be made, so it must stay valid"},{"type":"text","text":" "},{"text":"until ","type":"text"},{"code":"callback","type":"codeVoice"},{"type":"text","text":" is called. See "},{"type":"codeVoice","code":"g_output_stream_write_bytes_async()"},{"text":" ","type":"text"},{"text":"for a [Bytes](\/\/documentation\/glib\/bytes version that will automatically hold a reference to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the contents (without copying) for the duration of the call."}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Request an asynchronous write of ","type":"text"},{"code":"count","type":"codeVoice"},{"type":"text","text":" bytes from "},{"code":"buffer","type":"codeVoice"},{"type":"text","text":" into"},{"type":"text","text":" "},{"type":"text","text":"the stream. When the operation is finished "},{"code":"callback","type":"codeVoice"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"text":"You can then call ","type":"text"},{"code":"g_output_stream_write_finish()","type":"codeVoice"},{"type":"text","text":" to get the result of the"},{"type":"text","text":" "},{"type":"text","text":"operation."}],"metadata":{"symbolKind":"method","externalID":"s:3GIO20OutputStreamProtocolPAAE10writeAsync6buffer5count10ioPriority11cancellable8callback8userDataySvSg_S2iAA14CancellableRefVSgySpySo8_GObjectVGSg_SpySo13_GAsyncResultVGSgAKtXCSgAKtF::SYNTHESIZED::s:3GIO19FileOutputStreamRefV","role":"symbol","extendedModule":"GIO","title":"writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","modules":[{"name":"GIO"