)","abstract":[{"type":"text","text":"Request an asynchronous write of "},{"type":"codeVoice","code":"count"},{"text":" bytes from ","type":"text"},{"type":"codeVoice","code":"buffer"},{"type":"text","text":" into"},{"text":" ","type":"text"},{"text":"the stream. When the operation is finished ","type":"text"},{"type":"codeVoice","code":"callback"},{"type":"text","text":" will be called."},{"text":" ","type":"text"},{"text":"You can then call ","type":"text"},{"type":"codeVoice","code":"g_output_stream_write_finish()"},{"type":"text","text":" to get the result of the"},{"text":" ","type":"text"},{"text":"operation.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/writeAsync(buffer:count:ioPriority:cancellable:callback:userData:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"writeAsync"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"buffer"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","kind":"typeIdentifier","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"ioPriority","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"callback"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GAsyncReadyCallback","kind":"typeIdentifier","text":"GAsyncReadyCallback"},{"text":"?, ","kind":"text"},{"text":"userData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"text":"