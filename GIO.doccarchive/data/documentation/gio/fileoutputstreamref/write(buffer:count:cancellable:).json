{"metadata":{"symbolKind":"method","modules":[{"name":"GIO"}],"role":"symbol","extendedModule":"GIO","externalID":"s:3GIO20OutputStreamProtocolPAAE5write6buffer5count11cancellableSiSvSg_SiAA14CancellableRefVSgtKF::SYNTHESIZED::s:3GIO19FileOutputStreamRefV","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"write"},{"text":"(","kind":"text"},{"text":"buffer","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"count"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"kind":"text","text":": "},{"preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"}],"title":"write(buffer:count:cancellable:)"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/write(buffer:count:cancellable:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileoutputstreamref\/write(buffer:count:cancellable:)"]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"Tries to write "},{"type":"codeVoice","code":"count"},{"type":"text","text":" bytes from "},{"code":"buffer","type":"codeVoice"},{"text":" into the stream. Will block","type":"text"},{"type":"text","text":" "},{"text":"during the operation.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"write","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"buffer"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"text":"!, ","kind":"text"},{"text":"count","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:3GIO14CancellableRefV","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier"},{"kind":"text","text":"? = nil) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If count is 0, returns 0 and does nothing. A value of ","type":"text"},{"type":"codeVoice","code":"count"},{"text":" ","type":"text"},{"text":"larger than ","type":"text"},{"code":"G_MAXSSIZE","type":"codeVoice"},{"text":" will cause a ","type":"text"},{"type":"codeVoice","code":"invalidArgument"},{"text":" error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On success, the number of bytes written to the stream is returned."},{"type":"text","text":" "},{"type":"text","text":"It is not an error if this is not the same as the requested size, as it"},{"type":"text","text":" "},{"type":"text","text":"can happen e.g. on a partial I\/O error, or if there is not enough"},{"type":"text","text":" "},{"type":"text","text":"storage in the stream. All writes block until at least one byte"},{"type":"text","text":" "},{"text":"is written or an error occurs; 0 is never returned (unless","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"count"},{"type":"text","text":" is 0)."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"text":" ","type":"text"},{"text":"triggering the cancellable object from another thread. If the operation","type":"text"},{"type":"text","text":" "},{"text":"was cancelled, the error ","type":"text"},{"code":"cancelled","type":"codeVoice"},{"type":"text","text":" will be returned. If an"},{"type":"text","text":" "},{"type":"text","text":"operation was partially finished when the operation was cancelled the"},{"type":"text","text":" "},{"text":"partial result will be returned, without an error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"text":" is set accordingly.","type":"text"}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileOutputStreamRef":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileOutputStreamRef"}],"url":"\/documentation\/gio\/fileoutputstreamref","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","role":"symbol","fragments":[{"kind":"ke