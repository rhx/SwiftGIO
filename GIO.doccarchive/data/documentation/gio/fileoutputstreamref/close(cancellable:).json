{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"text":"? = nil) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Once the stream is closed, all other operations will return ","type":"text"},{"type":"codeVoice","code":"closed"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Closing a stream multiple times will not return an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Closing a stream will automatically flush any outstanding buffers in the"},{"type":"text","text":" "},{"text":"stream.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Streams will be automatically closed when the last reference","type":"text"},{"type":"text","text":" "},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"type":"text","text":" "},{"text":"resources are released as early as possible.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some streams might keep the backing store of the stream (e.g. a file descriptor)"},{"type":"text","text":" "},{"text":"open after the stream is closed. See the documentation for the individual","type":"text"},{"text":" ","type":"text"},{"text":"stream for details.","type":"text"}]},{"inlineContent":[{"text":"On failure the first error that happened will be reported, but the close","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operation will finish as much as possible. A stream that failed to"},{"type":"text","text":" "},{"type":"text","text":"close will still return "},{"type":"codeVoice","code":"closed"},{"text":" for all operations. Still, it","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is important to check and report the error to the user, otherwise"},{"text":" ","type":"text"},{"text":"there might be a loss of data as all data might not be written.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"cancellable","type":"codeVoice"},{"text":" is not ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":", then the operation can be cancelled by"},{"type":"text","text":" "},{"type":"text","text":"triggering the cancellable object from another thread. If the operation"},{"text":" ","type":"text"},{"type":"text","text":"was cancelled, the error "},{"type":"codeVoice","code":"cancelled"},{"type":"text","text":" will be returned."},{"type":"text","text":" "},{"text":"Cancelling a close will still leave the stream closed, but there some streams","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can use a faster close that doesn’t block to e.g. check errors. On"},{"text":" ","type":"text"},{"type":"text","text":"cancellation (as with any error) there is no guarantee that all written"},{"type":"text","text":" "},{"type":"text","text":"data will reach the target."}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/OutputStreamProtocol-Implementations"]]},"abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef"},{"text":"?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"symbolKind":"method","externalID":"s:3GIO20OutputStreamProtocolPAAE5close11cancellableSbAA14CancellableRefVSg_tKF::SYNTHESIZED::s:3GIO19FileOutputStreamRefV","title":"close(cancellable:)","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/fileoutputstreamref\/close(cancellable:)"]}],"sections":[],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/close(cancellable:)","interfaceLanguage":"swift"},"kind":"symbol","references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/FileOutputStreamRef/close(cancellable:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"close"},{"text":"(","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"?) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"url":"\/documentation\/gio\/fileoutputstreamref\/close(cancellable:)","title":"close(cancellable:)","type":"topic","kind":"symbol","abstract":[{"text":"Closes the stream, releasing resources related to it.","type":"text"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/close(cancellable:)"},"doc://GIO/documentation/GIO/FileOutputStreamRef":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"FileOutputStreamRef"}],"url":"\/documentation\/gio\/fileoutputstreamref","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"FileOutputStreamRef"}],"title":"FileOutputStreamRef","kind":"symbol","abstract":[{"type":"codeVoice","code":"GFileOutputStream"},{"text":" provides output streams that write their","type":"text"},{"type":"text","text":" "},{"type":"text","text":"content to a file."}]},"doc://GIO/documentation/GIO/FileOutputStreamRef/OutputStreamProtocol-Implementations":{"title":"OutputStreamProtocol Implementations","role":"collectionGroup","identifier":"doc:\/\/GIO\/documentation\/GIO\/FileOutputStreamRef\/OutputStreamProtocol-Implementations","type":"topic","url":"\/documentation\/gio\/fileoutputstreamref\/outputstreamprotocol-implementations","abstract":[],"kind":"article"}}}