{"variants":[{"paths":["\/documentation\/gio\/networkmonitorpropertyname\/networkavailable"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"Whether the network is considered available. That is, whether the"},{"text":" ","type":"text"},{"type":"text","text":"system has a default route for at least one of IPv4 or IPv6."}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"networkAvailable","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Real-world networks are of course much more complicated than","type":"text"},{"type":"text","text":" "},{"type":"text","text":"this; the machine may be connected to a wifi hotspot that"},{"text":" ","type":"text"},{"type":"text","text":"requires payment before allowing traffic through, or may be"},{"type":"text","text":" "},{"type":"text","text":"connected to a functioning router that has lost its own upstream"},{"text":" ","type":"text"},{"text":"connectivity. Some hosts might only be accessible when a VPN is","type":"text"},{"text":" ","type":"text"},{"text":"active. Other hosts might only be accessible when the VPN is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not active. Thus, it is best to use "},{"code":"g_network_monitor_can_reach()","type":"codeVoice"},{"type":"text","text":" "},{"text":"or ","type":"text"},{"code":"g_network_monitor_can_reach_async()","type":"codeVoice"},{"type":"text","text":" to test for reachability"},{"text":" ","type":"text"},{"type":"text","text":"on a host-by-host basis. (On the other hand, when the property is"},{"type":"text","text":" "},{"type":"codeVoice","code":"false"},{"type":"text","text":", the application can reasonably expect that no remote"},{"text":" ","type":"text"},{"text":"hosts at all are reachable, and should indicate this to the user","type":"text"},{"type":"text","text":" "},{"text":"in its UI.)","type":"text"}]},{"inlineContent":[{"type":"text","text":"See also [NetworkMonitor](\/\/documentation\/gio\/networkmonitor\/onnetworkchanged(flags:handler:)."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName\/networkAvailable"},"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"networkAvailable","kind":"identifier"}],"symbolKind":"case","title":"NetworkMonitorPropertyName.networkAvailable","modules":[{"name":"GIO"}],"role":"symbol","roleHeading":"Case","externalID":"s:3GIO26NetworkMonitorPropertyNameO16networkAvailableyA2CmF"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName"]]},"references":{"doc://GIO/documentation/GIO/NetworkMonitorPropertyName":{"url":"\/documentation\/gio\/networkmonitorpropertyname","abstract":[],"kind":"symbol","role":"symbol","type":"topic","navigatorTitle":[{"text":"NetworkMonitorPropertyName","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"NetworkMonitorPropertyName"}],"title":"NetworkMonitorPropertyName"},"doc://GIO/documentation/GIO/NetworkMonitorPropertyName/networkAvailable":{"url":"\/documentation\/gio\/networkmonitorpropertyname\/networkavailable","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"networkAvailable"}],"kind":"symbol","title":"NetworkMonitorPropertyName.networkAvailable","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName\/networkAvailable","abstract":[{"text":"Whether the network is considered available. That is, whether the","type":"text"},{"text":" ","type":"text"},{"text":"system has a default route for at least one of IPv4 or IPv6.","type":"text"}],"type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}