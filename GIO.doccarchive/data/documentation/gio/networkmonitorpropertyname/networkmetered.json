{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName\/networkMetered","interfaceLanguage":"swift"},"sections":[],"metadata":{"role":"symbol","title":"NetworkMonitorPropertyName.networkMetered","roleHeading":"Case","externalID":"s:3GIO26NetworkMonitorPropertyNameO14networkMeteredyA2CmF","modules":[{"name":"GIO"}],"fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"networkMetered","kind":"identifier"}],"symbolKind":"case"},"abstract":[{"text":"Whether the network is considered metered.","type":"text"}],"variants":[{"paths":["\/documentation\/gio\/networkmonitorpropertyname\/networkmetered"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"networkMetered","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"That is, whether the"},{"type":"text","text":" "},{"type":"text","text":"system has traffic flowing through the default connection that is"},{"type":"text","text":" "},{"type":"text","text":"subject to limitations set by service providers. For example, traffic"},{"type":"text","text":" "},{"text":"might be billed by the amount of data transmitted, or there might be a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"quota on the amount of traffic per month. This is typical with tethered"},{"type":"text","text":" "},{"text":"connections (3G and 4G) and in such situations, bandwidth intensive","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"applications may wish to avoid network activity where possible if it will"},{"text":" ","type":"text"},{"type":"text","text":"cost the user money or use up their limited quota. Anything more than a"},{"text":" ","type":"text"},{"type":"text","text":"few hundreds of kilobytes of data usage per hour should be avoided without"},{"type":"text","text":" "},{"type":"text","text":"asking permission from the user."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If more information is required about specific devices then the"},{"type":"text","text":" "},{"type":"text","text":"system network management API should be used instead (for example,"},{"type":"text","text":" "},{"type":"text","text":"NetworkManager or ConnMan)."}],"type":"paragraph"},{"inlineContent":[{"text":"If this information is not available then no networks will be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"marked as metered."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See also "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitor"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://GIO/documentation/GIO/NetworkMonitor":{"type":"topic","url":"\/documentation\/gio\/networkmonitor","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"NetworkMonitor","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GNetworkMonitor"},{"text":" provides an easy-to-use cross-platform API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for monitoring network connectivity. On Linux, the available"},{"type":"text","text":" "},{"type":"text","text":"implementations are based on the kernel’s netlink interface and"},{"type":"text","text":" "},{"type":"text","text":"on NetworkManager."}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitor","navigatorTitle":[{"text":"NetworkMonitor","kind":"identifier"}],"title":"NetworkMonitor","kind":"symbol"},"doc://GIO/documentation/GIO/NetworkMonitorPropertyName/networkMetered":{"role":"symbol","abstract":[{"type":"text","text":"Whether the network is considered metered."}],"kind":"symbol","type":"topic","url":"\/documentation\/gio\/networkmonitorpropertyname\/networkmetered","title":"NetworkMonitorPropertyName.networkMetered","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"networkMetered","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName\/networkMetered"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/NetworkMonitorPropertyName":{"url":"\/documentation\/gio\/networkmonitorpropertyname","abstract":[],"kind":"symbol","role":"symbol","type":"topic","navigatorTitle":[{"text":"NetworkMonitorPropertyName","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/NetworkMonitorPropertyName","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"NetworkMonitorPropertyName"}],"title":"NetworkMonitorPropertyName"}}}