{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO"]]},"sections":[],"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DBusInterfaceVTableRef"}],"symbolKind":"struct","title":"DBusInterfaceVTableRef","role":"symbol","modules":[{"name":"GIO"}],"roleHeading":"Structure","externalID":"s:3GIO22DBusInterfaceVTableRefV","navigatorTitle":[{"text":"DBusInterfaceVTableRef","kind":"identifier"}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"topicSections":[{"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(_:)-2a4n","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(_:)-4hta3","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(_:)-7si8","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(_:)-882vh","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(_:)-8s8hg","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(cPointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(constPointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(gconstpointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(gpointer:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(mutating:)","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/init(opaquePointer:)"],"anchor":"Initializers","generated":true,"title":"Initializers"},{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/ptr"],"anchor":"Instance-Properties"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/DBusInterfaceVTableProtocol-Implementations","doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef\/PointerWrapper-Implementations"],"title":"Default Implementations"}],"relationshipsSections":[{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol","doc:\/\/GIO\/4GLib14PointerWrapperP"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/dbusinterfacevtableref"]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Virtual table for handling properties and method calls for a D-Bus"},{"text":" ","type":"text"},{"type":"text","text":"interface."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"DBusInterfaceVTableRef","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since 2.38, if you want to handle getting\/setting D-Bus properties"},{"text":" ","type":"text"},{"text":"asynchronously, give ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" as your ","type":"text"},{"code":"get_property()","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"set_property()"},{"type":"text","text":" "},{"type":"text","text":"function. The D-Bus call will be directed to your "},{"type":"codeVoice","code":"method_call"},{"text":" function,","type":"text"},{"text":" ","type":"text"},{"text":"with the provided ","type":"text"},{"type":"codeVoice","code":"interface_name"},{"type":"text","text":" set to “org.freedesktop.DBus.Properties”."}]},{"type":"paragraph","inlineContent":[{"text":"Ownership of the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","type":"reference","isActive":true},{"text":" object passed to the","type":"text"},{"text":" ","type":"text"},{"code":"method_call()","type":"codeVoice"},{"text":" function is transferred to your handler; you must","type":"text"},{"type":"text","text":" "},{"text":"call one of the methods of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","type":"reference","isActive":true},{"text":" to return a reply","type":"text"},{"type":"text","text":" "},{"text":"(possibly empty), or an error. These functions also take ownership","type":"text"},{"type":"text","text":" "},{"text":"of the passed-in invocation object, so unless the invocation","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"object has otherwise been referenced, it will be then be freed."},{"type":"text","text":" "},{"text":"Calling one of these functions may be done within your","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"method_call()"},{"text":" implementation but it also can be done at a later","type":"text"},{"type":"text","text":" "},{"text":"point to handle the method asynchronously.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The usual checks on the validity of the calls is performed. For"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Get"},{"type":"text","text":" calls, an error is automatically returned if the property does"},{"text":" ","type":"text"},{"type":"text","text":"not exist or the permissions do not allow access. The same checks are"},{"type":"text","text":" "},{"text":"performed for ","type":"text"},{"type":"codeVoice","code":"Set"},{"text":" calls, and the provided value is also checked for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"being the correct type."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For both "},{"type":"codeVoice","code":"Get"},{"text":" and ","type":"text"},{"code":"Set","type":"codeVoice"},{"type":"text","text":" calls, the "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMethodInvocation","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"passed to the "},{"code":"method_call","type":"codeVoice"},{"type":"text","text":" handler can be queried with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_dbus_method_invocation_get_property_info()"},{"type":"text","text":" to get a pointer"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusPropertyInfo"},{"text":" of the property.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If you have readable properties specified in your interface info,"},{"text":" ","type":"text"},{"type":"text","text":"you must ensure that you either provide a non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" "},{"type":"codeVoice","code":"get_property``()"},{"type":"text","text":" "},{"text":"function or provide implementations of both the ","type":"text"},{"type":"codeVoice","code":"Get"},{"type":"text","text":" and "},{"code":"GetAll","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"methods on org.freedesktop.DBus.Properties interface in your "},{"type":"codeVoice","code":"method_call"},{"text":" ","type":"text"},{"text":"function. Note that the required return type of the ","type":"text"},{"code":"Get","type":"codeVoice"},{"text":" call is","type":"text"},{"type":"text","text":" "},{"code":"(v)","type":"codeVoice"},{"text":", not the type of the property. ","type":"text"},{"type":"codeVoice","code":"GetAll"},{"type":"text","text":" expects a return value"},{"text":" ","type":"text"},{"text":"of type ","type":"text"},{"type":"codeVoice","code":"a{sv}"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you have writable properties specified in your interface info,"},{"text":" ","type":"text"},{"text":"you must ensure that you either provide a non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" ","type":"text"},{"type":"codeVoice","code":"set_property``()"},{"type":"text","text":" "},{"text":"function or provide an implementation of the ","type":"text"},{"type":"codeVoice","code":"Set"},{"text":" call. If implementing","type":"text"},{"type":"text","text":" "},{"text":"the call, you must return the value of type ","type":"text"},{"code":"G_VARIANT_TYPE_UNIT","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef","isActive":true,"type":"reference"},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GDBusInterfaceVTable"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"text":" ","type":"text"},{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef","type":"reference","isActive":true},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GDBusInterfaceVTable","type":"codeVoice"},{"type":"text","text":" instance."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTable","type":"reference","isActive":true},{"text":" (instead of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceVTableRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"code":"GDBusInterfaceVTable","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/DBusInterfaceVTableRef/PointerWrapper-Implementations":{"kind":"article","title":"Poi