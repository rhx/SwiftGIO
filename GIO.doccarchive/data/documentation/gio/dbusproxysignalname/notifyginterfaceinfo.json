{"abstract":[{"text":"Ensure that interactions with this proxy conform to the given","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"interface. This is mainly to ensure that malformed data received"},{"text":" ","type":"text"},{"text":"from the other peer is ignored. The given ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceInfo","isActive":true,"type":"reference"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"type":"text","text":"said to be the “expected interface”."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"notifyGInterfaceInfo"}],"platforms":["macOS"]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The checks performed are:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"When completing a method call, if the type signature of"},{"text":" ","type":"text"},{"type":"text","text":"the reply message isn’t what’s expected, the reply is"},{"text":" ","type":"text"},{"type":"text","text":"discarded and the [GLibError](\/\/documentation\/glib\/gliberror is set to "},{"code":"invalidArgument","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Received signals that have a type signature mismatch are dropped and"},{"text":" ","type":"text"},{"type":"text","text":"a warning is logged via "},{"type":"codeVoice","code":"g_warning()"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Properties received via the initial "},{"code":"GetAll()","type":"codeVoice"},{"text":" call or via the","type":"text"},{"type":"text","text":" "},{"code":"PropertiesChanged","type":"codeVoice"},{"type":"text","text":" signal (on the"},{"type":"text","text":" "},{"identifier":"http:\/\/dbus.freedesktop.org\/doc\/dbus-specification.html#standard-interfaces-properties","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"interface) or set using "},{"code":"g_dbus_proxy_set_cached_property()","type":"codeVoice"},{"text":" ","type":"text"},{"text":"with a type signature mismatch are ignored and a warning is","type":"text"},{"type":"text","text":" "},{"type":"text","text":"logged via "},{"code":"g_warning()","type":"codeVoice"},{"text":".","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"Note that these checks are never done on methods, signals and"},{"type":"text","text":" "},{"text":"properties that are not referenced in the given","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusInterfaceInfo","isActive":true},{"text":", since extending a D-Bus interface on the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"service-side is not considered an ABI break."}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/DBusProxySignalName\/notifyGInterfaceInfo"},"kind":"symbol","metadata":{"title":"DBusProxySignalName.notifyGInterfaceInfo","externalID":"s:3GIO19DBusProxySignalNameO20notifyGInterfaceInfoyA2CmF","roleHeading":"Case","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"notifyGInterfaceInfo","kind":"identifier"}],"role":"symbol","symbolKind":"case","modules":[{"name":"GIO"}]},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/DBusProxySignalName"]]},"sections":[],"variants":[{"paths":["\/documentation\/gio\/dbusproxysignalname\/notifyginterfaceinfo"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/DBusProxySignalName/notifyGInterfaceIn