{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"<","kind":"text"},{"text":"MenuModelT","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"section"},{"kind":"text","text":": "},{"text":"MenuModelT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"where","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:3GIO17MenuModelProtocolP","kind":"typeIdentifier","text":"MenuModelProtocol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"The effect of having one menu appear as a section of another is"},{"type":"text","text":" "},{"text":"exactly as it sounds: the items from ","type":"text"},{"code":"section","type":"codeVoice"},{"type":"text","text":" become a direct part of"},{"type":"text","text":" "},{"text":"the menu that ","type":"text"},{"type":"codeVoice","code":"menuItem"},{"type":"text","text":" is added to.  See "},{"type":"codeVoice","code":"g_menu_item_new_section()"},{"type":"text","text":" "},{"text":"for more information about what it means for a menu item to be a","type":"text"},{"text":" ","type":"text"},{"text":"section.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/gio\/menuitemprotocol\/set(section:)-2i07i"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol"]]},"abstract":[{"text":"Sets or unsets the “section” link of ","type":"text"},{"type":"codeVoice","code":"menuItem"},{"text":" to ","type":"text"},{"code":"section","type":"codeVoice"},{"text":".","type":"text"}],"metadata":{"roleHeading":"Instance Method","externalID":"s:3GIO16MenuItemProtocolPAAE3set7sectionyqd__Sg_tAA0b5ModelD0Rd__lF","role":"symbol","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuModelT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"section"},{"kind":"text","text":": "},{"text":"MenuModelT","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"extendedModule":"GIO","title":"set(section:)","modules":[{"name":"GIO"}]},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/set(section:)-2i07i","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuItemProtocol/set(section:)-2i07i":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"set","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuModelT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"section"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"MenuModelT"},{"text":"?)","kind":"text"}],"title":"set(section:)","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/set(section:)-2i07i","url":"\/documentation\/gio\/menuitemprotocol\/set(section:)-2i07i","abstract":[{"type":"text","text":"Sets or unsets the “section” link of "},{"type":"codeVoice","code":"menuItem"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"section"},{"text":".","type":"text"}],"type":"topic"},"doc://GIO/documentation/GIO/MenuModelProtocol":{"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/menumodelprotocol","navigatorTitle":[{"text":"MenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuItemProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MenuItemProtocol","kind":"identifier"}],"title":"MenuItemProtocol"