{"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/setActionAndTargetValue(action:targetValue:)-9wt21","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"extendedModule":"GIO","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"setActionAndTargetValue","kind":"identifier"},{"kind":"text","text":"("},{"text":"action","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafePointer","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?, "},{"text":"targetValue","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"symbolKind":"method","externalID":"s:3GIO16MenuItemProtocolPAAE23setActionAndTargetValue6action06targetI0ySPys4Int8VGSg_4GLib10VariantRefVSgtF","title":"setActionAndTargetValue(action:targetValue:)","modules":[{"name":"GIO"}],"roleHeading":"Instance Method","role":"symbol"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"setActionAndTargetValue","kind":"identifier"},{"kind":"text","text":"("},{"text":"action","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"text":">? = nil, ","kind":"text"},{"text":"targetValue","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef","kind":"typeIdentifier"},{"text":"? = nil)","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"action","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"text":" then both the “action” and “target” attributes","type":"text"},{"type":"text","text":" "},{"text":"are unset (and ","type":"text"},{"code":"targetValue","type":"codeVoice"},{"type":"text","text":" is ignored)."}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"action"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then the “action” attribute is set.  The"},{"text":" ","type":"text"},{"type":"text","text":"“target” attribute is then set to the value of "},{"code":"targetValue","type":"codeVoice"},{"type":"text","text":" if it is"},{"text":" ","type":"text"},{"type":"text","text":"non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" or unset otherwise."}]},{"inlineContent":[{"type":"text","text":"Normal menu items (ie: not submenu, section or other custom item"},{"text":" ","type":"text"},{"type":"text","text":"types) are expected to have the “action” attribute set to identify"},{"type":"text","text":" "},{"text":"the action that they are associated with.  The state type of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"action help to determine the disposition of the menu item.  See"},{"type":"text","text":" "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","isActive":true,"type":"reference"},{"type":"text","text":" for an overview of actions."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In general, clicking on the menu item will result in activation of"},{"type":"text","text":" "},{"type":"text","text":"the named action with the “target” attribute given as the parameter"},{"text":" ","type":"text"},{"type":"text","text":"to the action invocation.  If the “target” attribute is not set then"},{"type":"text","text":" "},{"type":"text","text":"the action is invoked with no parameter."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the action has no state then the menu item is usually drawn as a"},{"text":" ","type":"text"},{"type":"text","text":"plain menu item (ie: with no additional decoration)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the action has a boolean state then the menu item is usually drawn"},{"type":"text","text":" "},{"type":"text","text":"as a toggle menu item (ie: with a checkmark or equivalent"},{"text":" ","type":"text"},{"text":"indication).  The item should be marked as ‘toggled’ or ‘checked’","type":"text"},{"type":"text","text":" "},{"text":"when the boolean state is ","type":"text"},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the action has a string state then the menu item is usually drawn","type":"text"},{"text":" ","type":"text"},{"text":"as a radio menu item (ie: with a radio bullet or equivalent","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"indication).  The item should be marked as ‘selected’ when the string"},{"type":"text","text":" "},{"text":"state is equal to the value of the ","type":"text"},{"code":"target","type":"codeVoice"},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"codeVoice","code":"g_menu_item_set_action_and_target()"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"g_menu_item_set_detailed_action()","type":"codeVoice"},{"text":" for two equivalent calls that are","type":"text"},{"type":"text","text":" "},{"text":"probably more convenient for most uses.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/gio\/menuitemprotocol\/setactionandtargetvalue(action:targetvalue:)-9wt21"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Sets or unsets the “action” and “target” attributes of ","type":"text"},{"type":"codeVoice","code":"menuItem"},{"type":"text","text":"."}],"references":{"doc://GIO/documentation/GIO/Action":{"url":"\/documentation\/gio\/action","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Action"}],"navigatorTitle":[{"text":"Action","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","title":"Action","role":"symbol","abstract":[{"type":"codeVoice","code":"GAction"},{"type":"text","text":" represents a single named action."}]},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ActionGroup":{"role":"symbol","title":"ActionGroup","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ActionGroup"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","navigatorTitle":[{"text":"ActionGroup","kind":"identifier"}],"type":"topic","url":"\/documentation\/gio\/actiongroup","abstract":[{"type":"codeVoice","code":"GActionGroup"},{"type":"text","text":" represents a group of actions."}]},"doc://GIO/documentation/GIO/MenuItemProtocol/setActionAndTargetValue(action:targetValue:)-9wt21":{"kind":"symbol","title":"setActionAndTargetValue(action:targetValue:)","url":"\/documentation\/gio\/menuitemprotocol\/setactionandtargetvalue(action:targetvalue:)-9wt21","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/setActionAndTargetValue(action:targetValue:)-9wt21","abstract":[{"type":"text","text":"Sets or unsets the “action” and “target” attributes of "},{"code":"menuItem","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"setActionAndTargetValue","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"action"},{"text":": ","kind":"text"},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gchar"},{"kind":"text","text":">?, "},{"text":"targetValue","kind":"externalParam"},{"kind":"text","text":": "},{"text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier"},{"kind":"text","text":"?)"}]},"doc://GIO/documentation/GIO/MenuItemProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MenuItemProtocol","kind":"identifier"}],"title":"MenuItemProtocol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem"},{"type":"text","text":" is an opaque structure type.  You must access it using the"},{"type":"text","text":" "},{"text":"functions below.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol","kind":"symbol","url":"\/documentation\/gio\/menuitemprotocol","role":"symbol","navigatorTitle":[{