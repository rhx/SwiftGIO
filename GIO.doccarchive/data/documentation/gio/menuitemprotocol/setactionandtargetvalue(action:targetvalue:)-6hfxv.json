{"abstract":[{"type":"text","text":"Sets or unsets the “action” and “target” attributes of "},{"code":"menuItem","type":"codeVoice"},{"type":"text","text":"."}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/setActionAndTargetValue(action:targetValue:)-6hfxv","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"symbolKind":"method","externalID":"s:3GIO16MenuItemProtocolPAAE23setActionAndTargetValue6action06targetI0ySPys4Int8VGSg_qd__Sgt4GLib07VariantD0Rd__lF","extendedModule":"GIO","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setActionAndTargetValue"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GLibVariantT"},{"kind":"text","text":">("},{"text":"action","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"kind":"text","text":">?, "},{"text":"targetValue","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GLibVariantT","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"modules":[{"name":"GIO"}],"title":"setActionAndTargetValue(action:targetValue:)","roleHeading":"Instance Method"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setActionAndTargetValue"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"GLibVariantT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"action"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gchar","text":"gchar","kind":"typeIdentifier"},{"text":">? = nil, ","kind":"text"},{"text":"targetValue","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"GLibVariantT","kind":"typeIdentifier"},{"text":"?) ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"typeIdentifier","text":"GLibVariantT"},{"kind":"text","text":" : "},{"text":"VariantProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib15VariantProtocolP"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"action"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then both the “action” and “target” attributes"},{"text":" ","type":"text"},{"text":"are unset (and ","type":"text"},{"type":"codeVoice","code":"targetValue"},{"type":"text","text":" is ignored)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"action"},{"text":" is non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" then the “action” attribute is set.  The","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“target” attribute is then set to the value of "},{"code":"targetValue","type":"codeVoice"},{"text":" if it is","type":"text"},{"type":"text","text":" "},{"text":"non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" or unset otherwise.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Normal menu items (ie: not submenu, section or other custom item","type":"text"},{"type":"text","text":" "},{"text":"types) are expected to have the “action” attribute set to identify","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the action that they are associated with.  The state type of the"},{"type":"text","text":" "},{"text":"action help to determine the disposition of the menu item.  See","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/Action","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","type":"reference","isActive":true},{"type":"text","text":" for an overview of actions."}]},{"type":"paragraph","inlineContent":[{"text":"In general, clicking on the menu item will result in activation of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the named action with the “target” attribute given as the parameter"},{"type":"text","text":" "},{"type":"text","text":"to the action invocation.  If the “target” attribute is not set then"},{"text":" ","type":"text"},{"type":"text","text":"the action is invoked with no parameter."}]},{"inlineContent":[{"type":"text","text":"If the action has no state then the menu item is usually drawn as a"},{"type":"text","text":" "},{"type":"text","text":"plain menu item (ie: with no additional decoration)."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the action has a boolean state then the menu item is usually drawn"},{"text":" ","type":"text"},{"type":"text","text":"as a toggle menu item (ie: with a checkmark or equivalent"},{"text":" ","type":"text"},{"type":"text","text":"indication).  The item should be marked as ‘toggled’ or ‘checked’"},{"text":" ","type":"text"},{"text":"when the boolean state is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the action has a string state then the menu item is usually drawn","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as a radio menu item (ie: with a radio bullet or equivalent"},{"type":"text","text":" "},{"type":"text","text":"indication).  The item should be marked as ‘selected’ when the string"},{"text":" ","type":"text"},{"text":"state is equal to the value of the ","type":"text"},{"type":"codeVoice","code":"target"},{"type":"text","text":" property."}],"type":"paragraph"},{"inlineContent":[{"text":"See ","type":"text"},{"code":"g_menu_item_set_action_and_target()","type":"codeVoice"},{"text":" or","type":"text"},{"type":"text","text":" "},{"code":"g_menu_item_set_detailed_action()","type":"codeVoice"},{"type":"text","text":" for two equivalent calls that are"},{"type":"text","text":" "},{"text":"probably more convenient for most uses.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/menuitemprotocol\/setactionandtargetvalue(action:targetvalue:)-6hfxv"]}],"sections":[],"references":{"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ActionGroup":{"role":"symbol","title":"ActionGroup","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ActionGroup"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ActionGroup","navigatorTitle":[{"text":"ActionGroup","kind":"identifier"}],"type":"topic","url":"\/documentation\/gio\/actiongroup","abstract":[{"type":"codeVoice","code":"GActionGroup"},{"type":"text","text":" represents a group of actions."}]},"doc://GIO/d