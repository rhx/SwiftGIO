nd":"text","text":": "},{"kind":"typeIdentifier","text":"MenuModelT"},{"text":"?) ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"MenuModelT"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:3GIO17MenuModelProtocolP","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","text":"MenuModelProtocol","kind":"typeIdentifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Links are used to establish a relationship between a particular menu","type":"text"},{"text":" ","type":"text"},{"text":"item and another menu.  For example, ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSubmenu","isActive":true,"type":"reference"},{"type":"text","text":" is used to"},{"text":" ","type":"text"},{"type":"text","text":"associate a submenu with a particular menu item, and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSection"},{"text":" ","type":"text"},{"text":"is used to create a section. Other types of link can be used, but there","type":"text"},{"text":" ","type":"text"},{"text":"is no guarantee that clients will be able to make sense of them.","type":"text"},{"type":"text","text":" "},{"text":"Link types are restricted to lowercase characters, numbers","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and ‘-’. Furthermore, the names must begin with a lowercase character,"},{"type":"text","text":" "},{"text":"must not end with a ‘-’, and must not contain consecutive dashes.","type":"text"}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/set(link:model:)-8mcu4"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol"]]},"references":{"doc://GIO/documentation/GIO/MenuItemProtocol/set(link:model:)-8mcu4":{"kind":"symbol","abstract":[{"text":"Creates a link from ","type":"text"},{"type":"codeVoice","code":"menuItem"},{"type":"text","text":" to "},{"type":"codeVoice","code":"model"},{"type":"text","text":" if non-"},{"type":"codeVoice","code":"nil"},{"text":", or unsets it.","type":"text"}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/set(link:model:)-8mcu4","url":"\/documentation\/gio\/menuitemprotocol\/set(link:model:)-8mcu4","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"MenuModelT"},{"text":">(","kind":"text"},{"kind":"externalParam","text":"link"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SP","text":"UnsafePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"model"},{"text":": ","kind":"text"},{"text":"MenuModelT","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"title":"set(link:model:)"},"doc://GIO/documentation/GIO/MenuModelProtocol":{"kind":"symbol","role":"symbol","url":"\/documentation\/gio\/menumodelprotocol","navigatorTitle":[{"text":"MenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GMenuModel","type":"codeVoice"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"type":"text","text":" "},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"text":" ","type":"text"},{"text":"the associated action (ie whether it is stateful, and what kind of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}],"title":"MenuModelProtocol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"MenuModelProtocol"}]},"doc://GIO/documentation/GIO/menuLinkSection":{"kind":"symbol","title":"menuLinkSection","url":"\/documentation\/gio\/menulinksection","type":"topic","abstract":[{"type":"text","text":"The name of the link that associates a menu item with a section.  The linked"},{"text":" ","type":"text"},{"type":"text","text":"menu will usually be shown in place of the menu item, using the item’s label"},{"text":" ","type":"text"},{"type":"text","text":"as a header."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSection","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"menuLinkSection"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}]},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuItemProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MenuItemProtocol","kind":"identifier"}],"title":"MenuItemProtocol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem"},{"type":"text","text":" is an opaque structure type.  You must access it using the"},{"type":"text","text":" "},{"text":"functions below.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol","kind":"symbol","url":"\/documentation\/gio\/menuitemprotocol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MenuItemProtocol"}]},"doc://GIO/documentation/GIO/menuLinkSubmenu":{"fragments":[{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"menuLinkSubmenu"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}],"kind":"symbol","url":"\/documentation\/gio\/menulinksubmenu","abstract":[{"type":"text","text":"The name of the link that associates a menu item with a submenu."}],"type":"topic","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSubmenu","title":"menuLinkSubmenu"}}}