 item, using the item’s label"},{"text":" ","type":"text"},{"type":"text","text":"as a header."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/menuLinkSection","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"text":" ","kind":"text"},{"kind":"identifier","text":"menuLinkSection"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}]},"doc://GIO/documentation/GIO/MenuItemProtocol":{"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MenuItemProtocol","kind":"identifier"}],"title":"MenuItemProtocol","abstract":[{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem"},{"type":"text","text":" is an opaque structure type.  You must access it using the"},{"type":"text","text":" "},{"text":"functions below.","type":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol","kind":"symbol","url":"\/documentation\/gio\/menuitemprotocol","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"MenuItemProtocol"}]},"doc://GIO/documentation/GIO/MenuItem":{"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuItem","kind":"identifier"}],"kind":"symbol","type":"topic","title":"MenuItem","navigatorTitle":[{"text":"MenuItem","kind":"identifier"}],"url":"\/documentation\/gio\/menuitem","abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItem","isActive":true,"type":"reference"},{"text":" is an opaque structure type.  You must access it using the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"functions below."}]},"doc://GIO/documentation/GIO/MenuModelRef":{"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"text":" represents the contents of a menu — an ordered list of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"menu items. The items are associated with actions, which can be"},{"type":"text","text":" "},{"type":"text","text":"activated through them. Items can be grouped in sections, and may"},{"text":" ","type":"text"},{"type":"text","text":"have submenus associated with them. Both items and sections usually"},{"text":" ","type":"text"},{"text":"have some representation data, such as labels or icons. The type of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"text":" ","type":"text"},{"text":"state it has) can influence the representation of the item.","type":"text"}],"url":"\/documentation\/gio\/menumodelref","type":"topic","title":"MenuModelRef","kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModelRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"MenuModelRef"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModelRef"},"doc://GIO/documentation/GIO/MenuItemProtocol/set(link:model:)-8lryf":{"kind":"symbol","abstract":[{"type":"text","text":"Creates a link from "},{"type":"codeVoice","code":"menuItem"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"model"},{"type":"text","text":" if non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", or unsets it."}],"type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuItemProtocol\/set(link:model:)-8lryf","url":"\/documentation\/gio\/menuitemprotocol\/set(link:model:)-8lryf","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"set"},{"text":"(","kind":"text"},{"text":"link","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:SP","text":"UnsafePointer"},{"kind":"text","text":"<"},{"text":"gchar","preciseIdentifier":"c:gtypes.h@T@gchar","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"model"},{"kind":"text","text":": "}