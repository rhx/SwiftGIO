umentation/GIO/DBusMenuModel/init(_:)-1q4ep":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel\/init(_:)-1q4ep","abstract":[{"text":"Designated initialiser from the underlying ","type":"text"},{"code":"C","type":"codeVoice"},{"type":"text","text":" data type."},{"text":" ","type":"text"},{"type":"text","text":"This creates an instance without performing an unbalanced retain"},{"text":" ","type":"text"},{"type":"text","text":"i.e., ownership is transferred to the "},{"type":"codeVoice","code":"DBusMenuModel"},{"text":" instance.","type":"text"}],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GDBusMenuModel","kind":"typeIdentifier"},{"kind":"text","text":">)"}],"url":"\/documentation\/gio\/dbusmenumodel\/init(_:)-1q4ep","title":"init(_:)","type":"topic","kind":"symbol","role":"symbol"},"doc://GIO/documentation/GIO/DBusMenuModel":{"title":"DBusMenuModel","type":"topic","navigatorTitle":[{"text":"DBusMenuModel","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusMenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GDBusMenuModel"},{"type":"text","text":" is an implementation of [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","isActive":true,"type":"reference"},{"type":"text","text":"] that can be"},{"type":"text","text":" "},{"text":"used as a proxy for a menu model that is exported over D-Bus with","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"Gio.DBusConnection.export_menu_model","type":"codeVoice"},{"text":"].","type":"text"}],"url":"\/documentation\/gio\/dbusmenumodel","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModel","role":"symbol"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"