t":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DBusMenuModelProtocol","kind":"identifier"}],"navigatorTitle":[{"text":"DBusMenuModelProtocol","kind":"identifier"}],"abstract":[{"code":"GDBusMenuModel","type":"codeVoice"},{"type":"text","text":" is an implementation of [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel"},{"text":"] that can be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"used as a proxy for a menu model that is exported over D-Bus with"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"code":"Gio.DBusConnection.export_menu_model","type":"codeVoice"},{"type":"text","text":"]."}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/DBusMenuModelProtocol","role":"symbol","title":"DBusMenuModelProtocol","type":"topic","url":"\/documentation\/gio\/dbusmenumodelprotocol","kind":"symbol"},"doc://GIO/documentation/GIO/MenuModel":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"MenuModel"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/MenuModel","url":"\/documentation\/gio\/menumodel","title":"MenuModel","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"MenuModel","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"GMenuModel"},{"type":"text","text":" represents the contents of a menu — an ordered list of"},{"text":" ","type":"text"},{"text":"menu items. The items are associated with actions, which can be","type":"text"},{"text":" ","type":"text"},{"text":"activated through them. Items can be grouped in sections, and may","type":"text"},{"type":"text","text":" "},{"text":"have submenus associated with them. Both items and sections usually","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have some representation data, such as labels or icons. The type of"},{"type":"text","text":" "},{"type":"text","text":"the associated action (ie whether it is stateful, and what kind of"},{"type":"text","text":" "},{"type":"text","text":"state it has) can influence the representation of the item."}]}}}