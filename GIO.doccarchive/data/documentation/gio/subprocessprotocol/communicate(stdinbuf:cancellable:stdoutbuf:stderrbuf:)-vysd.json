bleProtocol","text":"CancellableProtocol","preciseIdentifier":"s:3GIO19CancellableProtocolP"},{"kind":"text","text":", "},{"text":"GLibBytesT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"BytesProtocol","kind":"typeIdentifier","preciseIdentifier":"s:4GLib13BytesProtocolP"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"stdinBuf"},{"text":" is given, the subprocess must have been created with","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdinPipe","type":"reference"},{"type":"text","text":".  The given data is fed to the"},{"type":"text","text":" "},{"text":"stdin of the subprocess and the pipe is closed (ie: EOF).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time (as not to cause blocking when dealing with large"},{"type":"text","text":" "},{"type":"text","text":"amounts of data), if "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe"},{"type":"text","text":" or"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stderrPipe"},{"type":"text","text":" were used, reads from those"},{"type":"text","text":" "},{"text":"streams.  The data that was read is returned in ","type":"text"},{"code":"stdout","type":"codeVoice"},{"type":"text","text":" and\/or"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"stderr"},{"text":".","type":"text"}]},{"inlineContent":[{"text":"If the subprocess was created with ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe","type":"reference","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"stdoutBuf"},{"type":"text","text":" will contain the data read from stdout.  Otherwise, for"},{"type":"text","text":" "},{"type":"text","text":"subprocesses not created with "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stdoutBuf"},{"type":"text","text":" will be set to "},{"code":"nil","type":"codeVoice"},{"text":".  Similar provisions apply to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stderrBuf"},{"type":"text","text":" and "},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stderrPipe","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As usual, any output variable may be given as "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to ignore it."}]},{"inlineContent":[{"type":"text","text":"If you desire the stdout and stderr data to be interleaved, create"},{"text":" ","type":"text"},{"type":"text","text":"the subprocess with "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe","isActive":true},{"type":"text","text":" and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stderrMerge"},{"type":"text","text":".  The merged result will be returned"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"stdoutBuf","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"stderrBuf"},{"text":" will be set to ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"In case of any error (including cancellation), ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"type":"text","text":"returned with "},{"type":"codeVoice","code":"error"},{"type":"text","text":" set.  Some or all of the stdin data may have"},{"text":" ","type":"text"},{"text":"been written.  Any stdout or stderr data that has been read will be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"discarded. None of the out variables (aside from "},{"type":"codeVoice","code":"error"},{"type":"text","text":") will have"},{"text":" ","type":"text"},{"type":"text","text":"been set to anything in particular and should not be inspected."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the case that "},{"type":"codeVoice","code":"true"},{"type":"text","text":" is returned, the subprocess has exited and the"},{"type":"text","text":" "},{"type":"text","text":"exit status inspection APIs (eg: "},{"code":"g_subprocess_get_if_exited()","type":"codeVoice"},{"type":"text","text":","},{"text":" ","type":"text"},{"code":"g_subprocess_get_exit_status()","type":"codeVoice"},{"type":"text","text":") may be used."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You should not attempt to use any of the subprocess pipes after"},{"text":" ","type":"text"},{"type":"text","text":"starting this function, since they may be left in strange states,"},{"text":" ","type":"text"},{"text":"even if the operation was cancelled.  You should especially not","type":"text"},{"type":"text","text":" "},{"text":"attempt to interact with the pipes while the operation is in progress","type":"text"},{"type":"text","text":" "},{"type":"text","text":"(either from another thread or if using the asynchronous version)."}]}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/communicate(stdinBuf:cancellable:stdoutBuf:stderrBuf:)-vysd"},"references":{"doc://GIO/do