eIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GBytes","kind":"typeIdentifier"},{"text":">?>?) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"roleHeading":"Instance Method"},"abstract":[{"type":"text","text":"Communicate with the subprocess until it terminates, and all input"},{"text":" ","type":"text"},{"type":"text","text":"and output has been completed."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"communicate","kind":"identifier"},{"kind":"text","text":"("},{"text":"stdinBuf","kind":"externalParam"},{"kind":"text","text":": "},{"text":"BytesRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib8BytesRefV"},{"kind":"text","text":"? = nil, "},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CancellableRef","kind":"typeIdentifier","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV"},{"kind":"text","text":"? = nil, "},{"text":"stdoutBuf","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GBytes"},{"text":">?>? = nil, ","kind":"text"},{"kind":"externalParam","text":"stderrBuf"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GBytes"},{"text":">?>? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"If "},{"code":"stdinBuf","type":"codeVoice"},{"text":" is given, the subprocess must have been created with","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdinPipe","type":"reference"},{"type":"text","text":".  The given data is fed to the"},{"type":"text","text":" "},{"type":"text","text":"stdin of the subprocess and the pipe is closed (ie: EOF)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time (as not to cause blocking when dealing with large"},{"text":" ","type":"text"},{"text":"amounts of data), if ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe","isActive":true},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stderrPipe","type":"reference","isActive":true},{"text":" were used, reads from those","type":"text"},{"text":" ","type":"text"},{"text":"streams.  The data that was read is returned in ","type":"text"},{"code":"stdout","type":"codeVoice"},{"text":" and\/or","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"code":"stderr","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the subprocess was created with "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe","type":"reference","isActive":true},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stdoutBuf"},{"text":" will contain the data read from stdout.  Otherwise, for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"subprocesses not created with "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe","isActive":true},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"stdoutBuf","type":"codeVoice"},{"text":" will be set to ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".  Similar provisions apply to","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stderrBuf"},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stderrPipe","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"As usual, any output variable may be given as "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to ignore it."}]},{"type":"paragraph","inlineContent":[{"text":"If you desire the stdout and stderr data to be interleaved, create","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the subprocess with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol\/stdoutPipe"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"stderrMerge"},{"type":"text","text":".  The merged result will be returned"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"stdoutBuf","type":"codeVoice"},{"type":"text","text":" and "},{"code":"stderrBuf","type":"codeVoice"},{"text":" will be set to ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"In case of any error (including cancellation), ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" will be"},{"text":" ","type":"text"},{"text":"returned with ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" set.  Some or all of the stdin data may have"},{"type":"text","text":" "},{"type":"text","text":"been written.  Any stdout or stderr data that has been read will be"},{"text":" ","type":"text"},{"text":"discarded. None of the out variables (aside from ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":") will have"},{"type":"text","text":" "},{"type":"text","text":"been set to anything in particular and should not be inspected."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the case that "},{"code":"true","type":"codeVoice"},{"text":" is returned, the subprocess has exited and the","type":"text"},{"text":" ","type":"text"},{"text":"exit status inspection APIs (eg: ","type":"text"},{"type":"codeVoice","code":"g_subprocess_get_if_exited()"},{"text":",","type":"text"},{"type":"text","text":" "},{"code":"g_subprocess_get_exit_status()","type":"codeVoice"},{"type":"text","text":") may be used."}]},{"inlineContent":[{"type":"text","text":"You should not attempt to use any of the subprocess pipes after"},{"text":" ","type":"text"},{"type":"text","text":"starting this function, since they may be left in strange states,"},{"text":" ","type":"text"},{"type":"text","text":"even if the operation was cancelled.  You should especially not"},{"text":" ","type":"text"},{"type":"text","text":"attempt to interact with the pipes while the operation is in progress"},{"text":" ","type":"text"},{"text":"(either from another thread or if using the asynchronous version).","type":"text"}],"type":"paragraph"}]}],"references":{"doc://GIO/documentation/GIO/SubprocessProtocol":{"navigatorTitle":[{"text":"SubprocessProtocol","kind":"identifier"}],"title":"SubprocessProtocol","abstract":[{"code":"GSubprocess","type":"codeVoice"},{"type":"text","text":" allows the creation of and interaction with child"},{"type":"text","text":" "},{"type":"text","text":"processes."}],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"SubprocessProtocol"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SubprocessProtocol","url":"\/documentation\/gio\/subprocessprotoc