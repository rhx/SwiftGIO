{"sections":[],"abstract":[{"type":"text","text":"This is the main operation used when converting data. It is to be called"},{"type":"text","text":" "},{"type":"text","text":"multiple times in a loop, and each time it will do some work, i.e."},{"type":"text","text":" "},{"text":"producing some output (in ","type":"text"},{"code":"outbuf","type":"codeVoice"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":") or"},{"type":"text","text":" "},{"type":"text","text":"both. If its not possible to do any work an error is returned."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressorRef\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)"},"metadata":{"title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","externalID":"s:3GIO17ConverterProtocolPAAE7convert5inbuf0E4Size6outbuf0gF05flags9bytesRead0I7WrittenSo16GConverterResultaSvSg_SiANSiAA0B5FlagsVSpySuGSgARtKF::SYNTHESIZED::s:3GIO19ZlibDecompressorRefV","modules":[{"name":"GIO"}],"role":"symbol","extendedModule":"GIO","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"convert"},{"kind":"text","text":"("},{"kind":"externalParam","text":"inbuf"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"inbufSize"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"outbuf"},{"kind":"text","text":": "},{"text":"UnsafeMutableRawPointer","kind":"typeIdentifier","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"outbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"bytesRead"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"bytesWritten"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"text":">!) ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"GConverterResult","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult"}],"roleHeading":"Instance Method","symbolKind":"method"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressorRef","doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressorRef\/ConverterProtocol-Implementations"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"convert"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"inbuf"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","kind":"typeIdentifier","text":"UnsafeMutableRawPointer"},{"kind":"text","text":"!, "},{"kind":"externalParam","text":"inbufSize"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"outbuf"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"kind":"externalParam","text":"outbufSize"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"bytesRead","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"bytesWritten"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"text":"gsize","kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"text":"GConverterResult","kind":"typeIdentifier","preciseIdentifier":"c:@EA@GConverterResult"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Note that a single call may not consume all input (or any input at all).","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Also a call may produce output even if given no input, due to state stored"},{"text":" ","type":"text"},{"type":"text","text":"in the converter producing output."}]},{"inlineContent":[{"type":"text","text":"If any data was either produced or consumed, and then an error happens, then"},{"type":"text","text":" "},{"text":"only the successful conversion is reported and the error is returned on the","type":"text"},{"type":"text","text":" "},{"text":"next call.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A full conversion loop involves calling this method repeatedly, each time"},{"type":"text","text":" "},{"type":"text","text":"giving it new input and space output space. When there is no more input"},{"type":"text","text":" "},{"text":"data after the data in ","type":"text"},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", the flag "},{"type":"codeVoice","code":"inputAtEnd"},{"text":" must be set.","type":"text"},{"type":"text","text":" "},{"text":"The loop will be (unless some error happens) returning ","type":"text"},{"type":"codeVoice","code":"converted"},{"text":" ","type":"text"},{"text":"each time until all data is consumed and all output is produced, then","type":"text"},{"type":"text","text":" "},{"code":"finished","type":"codeVoice"},{"type":"text","text":" is returned instead. Note, that "},{"code":"finished","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"may be returned even if "},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" is not set, for instance"},{"type":"text","text":" "},{"type":"text","text":"in a decompression converter where the end of data is detectable from the"},{"type":"text","text":" "},{"text":"data (and there might even be other data after the end of the compressed data).","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When some data has successfully been converted ","type":"text"},{"type":"codeVoice","code":"bytesRead"},{"text":" and is set to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the number of bytes read from "},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":", and "},{"type":"codeVoice","code":"bytesWritten"},{"type":"text","text":" is set to indicate"},{"text":" ","type":"text"},{"text":"how many bytes was written to ","type":"text"},{"type":"codeVoice","code":"outbuf"},{"text":". If there are more data to output","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or consume (i.e. unless the "},{"code":"inputAtEnd","type":"codeVoice"},{"type":"text","text":" is specified) then"},{"text":" ","type":"text"},{"type":"codeVoice","code":"converted"},{"type":"text","text":" is returned, and if no more data is to be output"},{"text":" ","type":"text"},{"type":"text","text":"then "},{"type":"codeVoice","code":"finished"},{"type":"text","text":" is returned."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error "},{"type":"codeVoice","code":"error"},{"text":" is returned and ","type":"text"},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."},{"type":"text","text":" "},{"type":"text","text":"Some errors need special handling:"}]},{"inlineContent":[{"type":"codeVoice","code":"noSpace"},{"text":" is returned if there is not enough space","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to write the resulting converted data, the application should"},{"text":" ","type":"text"},{"type":"text","text":"call the function again with a larger "},{"type":"codeVoice","code":"outbuf"},{"type":"text","text":" to continue."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"partialInput"},{"text":" is returned if there is not enough","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"input to fully determine what the conversion should produce,"},{"type":"text","text":" "},{"type":"text","text":"and the "},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" flag is not set. This happens for"},{"type":"text","text":" "},{"type":"text","text":"example with an incomplete multibyte sequence when converting text,"},{"text":" ","type":"text"},{"type":"text","text":"or when a regexp matches up to the end of the input (and may match"},{"text":" ","type":"text"},{"text":"further input). It may also happen when ","type":"text"},{"type":"codeVoice","code":"inbufSize"},{"type":"text","text":" is zero and"},{"text":" ","type":"text"},{"text":"there is no more data to produce.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When this happens the application should read more input and then"},{"type":"text","text":" "},{"text":"call the function again. If further input shows that there is no","type":"text"},{"type":"text","text":" "},{"type":"text","text":"more data call the function again with the same data but with"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"type":"codeVoice","code":"inputAtEnd"},{"type":"text","text":" flag set. This may cause the conversion"},{"text":" ","type":"text"},{"text":"to finish as e.g. in the regexp match case (or, to fail again with","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"partialInput"},{"type":"text","text":" in e.g. a charset conversion where the"},{"type":"text","text":" "},{"text":"input is actually partial).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After "},{"type":"codeVoice","code":"g_converter_convert()"},{"type":"text","text":" has returned "},{"code":"finished","type":"codeVoice"},{"text":" the","type":"text"},{"text":" ","type":"text"},{"text":"converter object is in an invalid state where its not allowed","type":"text"},{"type":"text","text":" "},{"text":"to call ","type":"text"},{"type":"codeVoice","code":"g_converter_convert()"},{"text":" anymore. At this time you can only","type":"text"},{"type":"text","text":" "},{"text":"free the object or call ","type":"text"},{"type":"codeVoice","code":"g_converter_reset()"},{"type":"text","text":" to reset it to the"},{"type":"text","text":" "},{"text":"initial state.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the flag "},{"type":"codeVoice","code":"flush"},{"type":"text","text":" is set then conversion is modified"},{"type":"text","text":" "},{"text":"to try to write out all internal state to the output. The application","type":"text"},{"type":"text","text":" "},{"text":"has to call the function multiple times with the flag set, and when","type":"text"},{"type":"text","text":" "},{"text":"the available input has been consumed and all internal state has","type":"text"},{"text":" ","type":"text"},{"text":"been produced then ","type":"text"},{"code":"flushed","type":"codeVoice"},{"text":" (or ","type":"text"},{"code":"finished","type":"codeVoice"},{"type":"text","text":" if"},{"text":" ","type":"text"},{"type":"text","text":"really at the end) is returned instead of "},{"type":"codeVoice","code":"converted"},{"text":".","type":"text"},{"type":"text","text":" "},{"type":"text","text":"This is somewhat similar to what happens at the end of the input stream,"},{"type":"text","text":" "},{"text":"but done in the middle of the data.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This has different meanings for different conversions. For instance"},{"type":"text","text":" "},{"text":"in a compression converter it would mean that we flush all the","type":"text"},{"text":" ","type":"text"},{"text":"compression state into output such that if you uncompress the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"compressed data you get back all the input data. Doing this may"},{"type":"text","text":" "},{"type":"text","text":"make the final file larger due to padding though. Another example"},{"text":" ","type":"text"},{"text":"is a regexp conversion, where if you at the end of the flushed data","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"have a match, but there is also a potential longer match. In the"},{"type":"text","text":" "},{"text":"non-flushed case we would ask for more input, but when flushing we","type":"text"},{"text":" ","type":"text"},{"text":"treat this as the end of input and do the match.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Flushing is not always possible (like if a charset converter flushes"},{"type":"text","text":" "},{"text":"at a partial multibyte sequence). Converters are supposed to try","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to produce as much output as possible and then return an error"},{"type":"text","text":" "},{"text":"(typically ","type":"text"},{"code":"partialInput","type":"codeVoice"},{"type":"text","text":")."}]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/gio\/zlibdecompressorref\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GIO/documentation/GIO/ZlibDecompressorRef/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)":{"url":"\/documentation\/gio\/zlibdecompressorref\/convert(inbuf:inbufsize:outbuf:outbufsize:flags:bytesread:byteswritten:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"convert","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"inbuf"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UnsafeMutableRawPointer","preciseIdentifier":"s:Sv"},{"text":"!, ","kind":"text"},{"text":"inbufSize","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"outbuf"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sv","text":"UnsafeMutableRawPointer","kind":"typeIdentifier"},{"kind":"text","text":"!, "},{"text":"outbufSize","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":", ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ConverterFlags","preciseIdentifier":"s:3GIO14ConverterFlagsV"},{"text":", ","kind":"text"},{"text":"bytesRead","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"c:@T@gsize","text":"gsize","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"kind":"externalParam","text":"bytesWritten"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@gsize","text":"gsize"},{"kind":"text","text":">!) "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"GConverterResult","preciseIdentifier":"c:@EA@GConverterResult","kind":"typeIdentifier"}],"role":"symbol","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"This is the main operation used when converting data. It is to be called"},{"type":"text","text":" "},{"type":"text","text":"multiple times in a loop, and each time it will do some work, i.e."},{"type":"text","text":" "},{"text":"producing some output (in ","type":"text"},{"code":"outbuf","type":"codeVoice"},{"type":"text","text":") or consuming some input (from "},{"type":"codeVoice","code":"inbuf"},{"type":"text","text":") or"},{"text":" ","type":"text"},{"type":"text","text":"both. If its not possible to do any work an error is returned."}],"title":"convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)","identifier":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressorRef\/convert(inbuf:inbufSize:outbuf:outbufSize:flags:bytesRead:bytesWritten:)"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/ZlibDecompressorRef/ConverterProtocol-Implementations":{"title":"ConverterProtocol Implementations","role":"collectionGroup","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressorRef\/ConverterProtocol-Implementations","kind":"article","type":"topic","url":"\/documentation\/gio\/zlibdecompressorref\/converterprotocol-implementations"},"doc://GIO/documentation/GIO/ZlibDecompressorRef":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/ZlibDecompressorRef","url":"\/documentation\/gio\/zlibdecompressorref","title":"ZlibDecompressorRef","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ZlibDecompressorRef","kind":"identifier"}],"navigatorTitle":[{"text":"ZlibDecompressorRef","kind":"identifier"}],"type":"topic","abstract":[{"code":"GZlibDecompressor","type":"codeVoice"},{"type":"text","text":" is an implementation of [iface"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter","type":"reference"},{"type":"text","text":"] that"},{"type":"text","text":" "},{"type":"text","text":"decompresses data compressed with zlib."}]},"doc://GIO/documentation/GIO/ConverterFlags":{"abstract":[{"type":"text","text":"Flags used when calling a "},{"type":"codeVoice","code":"g_converter_convert()"},{"text":".","type":"text"}],"title":"ConverterFlags","url":"\/documentation\/gio\/converterflags","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConverterFlags"}],"role":"symbol","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/ConverterFlags","kind":"symbol","navigatorTitle":[{"text":"ConverterFlags","kind":"identifier"}]},"doc://GIO/documentation/GIO/Converter":{"kind":"symbol","type":"topic","title":"Converter","role":"symbol","abstract":[{"type":"codeVoice","code":"GConverter"},{"type":"text","text":" is an interface for streaming conversions."}],"url":"\/documentation\/gio\/converter","identifier":"doc:\/\/GIO\/documentation\/GIO\/Converter","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Converter","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"Converter"}]}}}