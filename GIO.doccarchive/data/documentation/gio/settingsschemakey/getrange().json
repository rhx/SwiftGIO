{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/settingsschemakey\/getrange()"]}],"abstract":[{"text":"Queries the range of a key.","type":"text"}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"getRange"},{"text":"() -> ","kind":"text"},{"text":"VariantRef","kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function will return a [Variant](\/\/documentation\/glib\/variant that fully describes the range"},{"text":" ","type":"text"},{"text":"of values that are valid for ","type":"text"},{"type":"codeVoice","code":"key"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"The type of [Variant](\/\/documentation\/glib\/variant returned is "},{"code":"(sv)","type":"codeVoice"},{"type":"text","text":". The string describes"},{"type":"text","text":" "},{"type":"text","text":"the type of range restriction in effect. The type and meaning of"},{"text":" ","type":"text"},{"type":"text","text":"the value contained in the variant depends on the string."}],"type":"paragraph"},{"inlineContent":[{"text":"If the string is ","type":"text"},{"code":"'type'","type":"codeVoice"},{"text":" then the variant contains an empty array.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The element type of that empty array is the expected type of value"},{"type":"text","text":" "},{"type":"text","text":"and all values of that type are valid."}],"type":"paragraph"},{"inlineContent":[{"text":"If the string is ","type":"text"},{"type":"codeVoice","code":"'enum'"},{"type":"text","text":" then the variant contains an array"},{"text":" ","type":"text"},{"type":"text","text":"enumerating the possible values. Each item in the array is"},{"text":" ","type":"text"},{"text":"a possible valid value and no other values are valid.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If the string is ","type":"text"},{"code":"'flags'","type":"codeVoice"},{"type":"text","text":" then the variant contains an array. Each"},{"text":" ","type":"text"},{"type":"text","text":"item in the array is a value that may appear zero or one times in an"},{"text":" ","type":"text"},{"text":"array to be used as the value for this key. For example, if the","type":"text"},{"type":"text","text":" "},{"text":"variant contained the array ","type":"text"},{"code":"['x', 'y']","type":"codeVoice"},{"type":"text","text":" then the valid values for"},{"type":"text","text":" "},{"text":"the key would be ","type":"text"},{"code":"[]","type":"codeVoice"},{"text":", ","type":"text"},{"code":"['x']","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"['y']"},{"text":", ","type":"text"},{"code":"['x', 'y']","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"['y', 'x']"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Finally, if the string is "},{"type":"codeVoice","code":"'range'"},{"text":" then the variant contains a pair","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of like-typed values – the minimum and maximum permissible values"},{"type":"text","text":" "},{"text":"for this key.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This information should not be used by normal programs.  It is"},{"text":" ","type":"text"},{"type":"text","text":"considered to be a hint for introspection purposes.  Normal programs"},{"type":"text","text":" "},{"text":"should already know what is permitted by their own schema.  The","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"format may change in any way in the future – but particularly, new"},{"text":" ","type":"text"},{"type":"text","text":"forms may be added to the possibilities described above."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"You should free the returned value with ","type":"text"},{"type":"codeVoice","code":"g_variant_unref()"},{"type":"text","text":" when it is"},{"type":"text","text":" "},{"text":"no longer needed.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/getRange()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/SettingsSchemaKeyProtocol-Implementations"]]},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getRange"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:4GLib10VariantRefV","kind":"typeIdentifier","text":"VariantRef"},{"text":"!","kind":"text"}],"role":"symbol","modules":[{"name":"GIO"}],"symbolKind":"method","externalID":"s:3GIO25SettingsSchemaKeyProtocolPAAE8getRange4GLib10VariantRefVSgyF::SYNTHESIZED::s:3GIO17SettingsSchemaKeyC","title":"getRange()","roleHeading":"Instance Method","extendedModule":"GIO"},"references":{"doc://GIO/documentation/GIO/SettingsSchemaKey/SettingsSchemaKeyProtocol-Implementations":{"url":"\/documentation\/gio\/settingsschemakey\/settingsschemakeyprotocol-implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/SettingsSchemaKeyProtocol-Implementations","title":"SettingsSchemaKeyProtocol Implementations"},"doc://GIO/documentation/GIO/SettingsSchemaKey":{"abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","isActive":true,"type":"reference"},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"text":" ","type":"text"},{"type":"text","text":"using the following functions."}],"url":"\/documentation\/gio\/settingsschemakey","type":"topic","kind":"symbol","title":"SettingsSchemaKey","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchemaKey"}],"navigatorTitle":[{"text":"SettingsSchemaKey","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey"},"doc://GIO/documentation/GIO/SettingsSchemaKey/getRange()":{"abstract":[{"type":"text","text":"Queries the range of a key."}],"type":"topic","kind":"symbol","title":"getRange()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getRange","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/getRange()","role":"symbol","url":"\/documentation\/gio\/settingsschemakey\/getrange()"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"}}}