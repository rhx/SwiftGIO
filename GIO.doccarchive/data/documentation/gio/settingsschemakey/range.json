{"abstract":[{"type":"text","text":"Queries the range of a key."}],"variants":[{"paths":["\/documentation\/gio\/settingsschemakey\/range"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"range"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:4GLib10VariantRefV","text":"VariantRef"},{"kind":"text","text":"! { "},{"text":"get","kind":"keyword"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function will return a [Variant](\/\/documentation\/glib\/variant that fully describes the range"},{"text":" ","type":"text"},{"type":"text","text":"of values that are valid for "},{"type":"codeVoice","code":"key"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The type of [Variant](\/\/documentation\/glib\/variant returned is ","type":"text"},{"code":"(sv)","type":"codeVoice"},{"text":". The string describes","type":"text"},{"text":" ","type":"text"},{"text":"the type of range restriction in effect. The type and meaning of","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the value contained in the variant depends on the string."}]},{"inlineContent":[{"type":"text","text":"If the string is "},{"type":"codeVoice","code":"'type'"},{"text":" then the variant contains an empty array.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"The element type of that empty array is the expected type of value"},{"type":"text","text":" "},{"type":"text","text":"and all values of that type are valid."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the string is "},{"type":"codeVoice","code":"'enum'"},{"text":" then the variant contains an array","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"enumerating the possible values. Each item in the array is"},{"text":" ","type":"text"},{"type":"text","text":"a possible valid value and no other values are valid."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the string is "},{"type":"codeVoice","code":"'flags'"},{"text":" then the variant contains an array. Each","type":"text"},{"type":"text","text":" "},{"text":"item in the array is a value that may appear zero or one times in an","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"array to be used as the value for this key. For example, if the"},{"text":" ","type":"text"},{"text":"variant contained the array ","type":"text"},{"type":"codeVoice","code":"['x', 'y']"},{"text":" then the valid values for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the key would be "},{"type":"codeVoice","code":"[]"},{"text":", ","type":"text"},{"type":"codeVoice","code":"['x']"},{"type":"text","text":", "},{"type":"codeVoice","code":"['y']"},{"type":"text","text":", "},{"code":"['x', 'y']","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"['y', 'x']"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, if the string is "},{"type":"codeVoice","code":"'range'"},{"text":" then the variant contains a pair","type":"text"},{"text":" ","type":"text"},{"text":"of like-typed values – the minimum and maximum permissible values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"for this key."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This information should not be used by normal programs.  It is"},{"type":"text","text":" "},{"text":"considered to be a hint for introspection purposes.  Normal programs","type":"text"},{"type":"text","text":" "},{"type":"text","text":"should already know what is permitted by their own schema.  The"},{"text":" ","type":"text"},{"type":"text","text":"format may change in any way in the future – but particularly, new"},{"text":" ","type":"text"},{"text":"forms may be added to the possibilities described above.","type":"text"}]},{"inlineContent":[{"text":"You should free the returned value with ","type":"text"},{"type":"codeVoice","code":"g_variant_unref()"},{"type":"text","text":" when it is"},{"text":" ","type":"text"},{"type":"text","text":"no longer needed."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/SettingsSchemaKeyProtocol-Implementations"]]},"kind":"symbol","metadata":{"modules":[{"name":"GIO"}],"role":"symbol","externalID":"s:3GIO25SettingsSchemaKeyProtocolPAAE5range4GLib10VariantRefVSgvp::SYNTHESIZED::s:3GIO17SettingsSchemaKeyC","extendedModule":"GIO","roleHeading":"Instance Property","symbolKind":"property","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"range","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"title":"range"},"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/range","interfaceLanguage":"swift"},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SettingsSchemaKey/range":{"abstract":[{"type":"text","text":"Queries the range of a key."}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"range","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"VariantRef","preciseIdentifier":"s:4GLib10VariantRefV"},{"text":"!","kind":"text"}],"title":"range","role":"symbol","type":"topic","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/range","url":"\/documentation\/gio\/settingsschemakey\/range"},"doc://GIO/documentation/GIO/SettingsSchemaKey":{"abstract":[{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey","isActive":true,"type":"reference"},{"type":"text","text":" is an opaque data structure and can only be accessed"},{"text":" ","type":"text"},{"type":"text","text":"using the following functions."}],"url":"\/documentation\/gio\/settingsschemakey","type":"topic","kind":"symbol","title":"SettingsSchemaKey","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SettingsSchemaKey"}],"navigatorTitle":[{"text":"SettingsSchemaKey","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey"},"doc://GIO/documentation/GIO/SettingsSchemaKey/SettingsSchemaKeyProtocol-Implementations":{"url":"\/documentation\/gio\/settingsschemakey\/settingsschemakeyprotocol-implementations","abstract":[],"kind":"article","role":"collectionGroup","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SettingsSchemaKey\/SettingsSchemaKeyProtocol-Implementations","title":"SettingsSchemaKeyProtocol Implementations"}}}