{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketprotocol\/receive(messages:nummessages:flags:cancellable:)-81kz2"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"receive","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"GInputMessage"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"numMessages"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","preciseIdentifier":"s:3GIO14CancellableRefV","kind":"typeIdentifier","text":"CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"platforms":["macOS"]}]},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true,"type":"reference"},{"type":"text","text":" structs and"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"text":" must be the length of this array. Each ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"contains a pointer to an array of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true},{"text":" structs describing the","type":"text"},{"text":" ","type":"text"},{"text":"buffers that the data received in each message will be written to. Using","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"multiple "},{"type":"codeVoice","code":"GInputVectors"},{"text":" is more memory-efficient than manually copying data","type":"text"},{"type":"text","text":" "},{"type":"text","text":"out of a single buffer to multiple sources, and more system-call-efficient"},{"text":" ","type":"text"},{"type":"text","text":"than making multiple calls to "},{"type":"codeVoice","code":"g_socket_receive()"},{"text":", such as in scenarios where","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a lot of data packets need to be received (e.g. high-bandwidth video"},{"type":"text","text":" "},{"type":"text","text":"streaming over RTP\/UDP)."}]},{"type":"paragraph","inlineContent":[{"code":"flags","type":"codeVoice"},{"type":"text","text":" modify how all messages are received. The commonly available"},{"type":"text","text":" "},{"text":"arguments for this are available in the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"text":" enum, but the","type":"text"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too. These"},{"type":"text","text":" "},{"type":"text","text":"flags affect the overall receive operation. Flags affecting individual"},{"type":"text","text":" "},{"type":"text","text":"messages are returned in "},{"type":"codeVoice","code":"GInputMessage.flags"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The other members of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true},{"type":"text","text":" are treated as described in its"},{"text":" ","type":"text"},{"type":"text","text":"documentation."}]},{"inlineContent":[{"type":"text","text":"If "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","isActive":true,"type":"reference"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" the call will block until ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" have","type":"text"},{"type":"text","text":" "},{"type":"text","text":"been received, or the end of the stream is reached."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"type":"text","text":" is "},{"type":"codeVoice","code":"false"},{"text":" the call will return up to ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" ","type":"text"},{"type":"text","text":"without blocking, or "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" if no messages are queued in the"},{"type":"text","text":" "},{"text":"operating system to be received.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In blocking mode, if ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference"},{"type":"text","text":" is positive and is reached before any"},{"text":" ","type":"text"},{"text":"messages are received, ","type":"text"},{"type":"codeVoice","code":"timedOut"},{"type":"text","text":" is returned, otherwise up to"},{"type":"text","text":" "},{"type":"codeVoice","code":"numMessages"},{"text":" are returned. (Note: This is effectively the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"behaviour of "},{"code":"MSG_WAITFORONE","type":"codeVoice"},{"type":"text","text":" with "},{"code":"recvmmsg()","type":"codeVoice"},{"text":".)","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To be notified when messages are available, wait for the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[in_](\/\/documentation\/gobject\/in_ condition. Note though that you may still receive"},{"text":" ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"text":" from ","type":"text"},{"code":"g_socket_receive_messages()","type":"codeVoice"},{"text":" even if you were","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"previously notified of a [in_](\/\/documentation\/gobject\/in_ condition."}]},{"type":"paragraph","inlineContent":[{"text":"If the remote peer closes the connection, any messages queued in the","type":"text"},{"type":"text","text":" "},{"text":"operating system will be returned, and subsequent calls to","type":"text"},{"type":"text","text":" "},{"code":"g_socket_receive_messages()","type":"codeVoice"},{"text":" will return 0 (with no error set).","type":"text"}]},{"inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly. An error will only"},{"type":"text","text":" "},{"type":"text","text":"be returned if zero messages could be received; otherwise the number of"},{"text":" ","type":"text"},{"type":"text","text":"messages successfully received before the error will be returned."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol\/receive(messages:numMessages:flags:cancellable:)-81kz2","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketProtocol"]]},"kind":"symbol","sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"modules":[{"name":"GIO"}],"roleHeading":"Instance Method","title":"receive(messages:numMessages:flags:cancellable:)","extendedModule":"GIO","externalID