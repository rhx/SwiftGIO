ier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GOutputVector","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"text":"numVectors","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"messages","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"text":"GSocketControlMessage","kind":"typeIdentifier"},{"kind":"text","text":">?>! = nil, "},{"text":"numMessages","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":", ","kind":"text"},{"text":"cancellable","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","text":"CancellableRef","kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV"},{"text":"? = nil) ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"gssize","kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"address"},{"type":"text","text":" is "},{"type":"codeVoice","code":"nil"},{"text":" then the message is sent to the default receiver","type":"text"},{"type":"text","text":" "},{"text":"(set by ","type":"text"},{"type":"codeVoice","code":"g_socket_connect()"},{"type":"text","text":")."}]},{"inlineContent":[{"code":"vectors","type":"codeVoice"},{"text":" must point to an array of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","type":"reference","isActive":true},{"type":"text","text":" structs and"},{"text":" ","type":"text"},{"code":"numVectors","type":"codeVoice"},{"type":"text","text":" must be the length of this array. (If "},{"type":"codeVoice","code":"numVectors"},{"type":"text","text":" is -1,"},{"text":" ","type":"text"},{"text":"then ","type":"text"},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is assumed to be terminated by a "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","type":"reference","isActive":true},{"type":"text","text":" with a"},{"type":"text","text":" "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" buffer pointer.) The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector"},{"text":" structs describe the buffers","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the sent data will be gathered from. Using multiple"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GOutputVectors"},{"type":"text","text":" is more memory-efficient than manually copying"},{"text":" ","type":"text"},{"type":"text","text":"data from multiple sources into a single buffer, and more"},{"text":" ","type":"text"},{"text":"network-efficient than making multiple calls to ","type":"text"},{"type":"codeVoice","code":"g_socket_send()"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"messages"},{"type":"text","text":", if non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", is taken to point to an array of "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage"},{"text":" instances. These correspond to the control","type":"text"},{"type":"text","text":" "},{"text":"messages to be sent on the socket.","type":"text"},{"type":"text","text":" "},{"text":"If ","type":"text"},{"code":"numMessages","type":"codeVoice"},{"text":" is -1 then ","type":"text"},{"code":"messages","type":"codeVoice"},{"text":" is treated as a ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":"-terminated"},{"type":"text","text":" "},{"text":"array.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"flags","type":"codeVoice"},{"text":" modify how the message is sent. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"type":"text","text":"for this are available in the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too."}],"type":"paragraph"},{"inlineContent":[{"text":"If the socket is in blocking mode the call will block until there is","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"space for the data in the socket queue. If there is no space available"},{"type":"text","text":" "},{"type":"text","text":"and the socket is in non-blocking mode a "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" error"},{"text":" ","type":"text"},{"text":"will be returned. To be notified when space is available, wait for the","type":"text"},{"type":"text","text":" "},{"text":"[out](\/\/documentation\/gobject\/out condition. Note though that you may still receive","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"wouldBlock"},{"text":" from ","type":"text"},{"code":"g_socket_send()","type":"codeVoice"},{"type":"text","text":" even if you were previously"},{"type":"text","text":" "},{"type":"text","text":"notified of a [out](\/\/documentation\/gobject\/out condition. (On Windows in particular, this is"},{"type":"text","text":" "},{"type":"text","text":"very common due to the way the underlying APIs work.)"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The sum of the sizes of each "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/OutputVector","isActive":true,"type":"reference"},{"type":"text","text":" in vectors must not be"},{"type":"text","text":" "},{"text":"greater than ","type":"text"},{"type":"codeVoice","code":"G_MAXSSIZE"},{"type":"text","text":". If the message can be larger than this,"},{"text":" ","type":"text"},{"type":"text","text":"then it is mandatory to use the "},{"type":"codeVoice","code":"g_socket_send_message_with_timeout()"},{"type":"text","text":" "},{"type":"text","text":"function."}]},{"type":"paragraph","inlineContent":[{"text":"On error -1 is returned and ","type":"text"},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly."}]}],"kind":"content"}],"references":{"doc://GIO/documentation/GIO/InetSocketAddress":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InetSocketAddress"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetSocketAddress","abstract":[{"text":"An IPv4 or IPv6 socket address. That is, the combination of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InetAddress","isActive":true,"type":"reference"},{"type":"text","text":"] and a port number."}],"url":"\/documentation\/gio\/inetsocketaddress","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"InetSocketAddress","kind":"identifier"}],"type":"topic","title":"InetSocketAddress"},"doc://GIO/documentation/GIO/Socket":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Socket"}],"kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","url":"\/documentation\/gio\/socket","abstract":[{"text":"A ","type":"text"},{"code":"GSocket","type":