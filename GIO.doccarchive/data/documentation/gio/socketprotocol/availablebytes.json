{"sections":[],"abstract":[{"text":"Get the amount of data pending in the OS input buffer, without blocking.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketprotocol\/availablebytes"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol\/availableBytes"},"kind":"symbol","metadata":{"extendedModule":"GIO","externalID":"s:3GIO14SocketProtocolPAAE14availableBytesSivp","symbolKind":"property","modules":[{"name":"GIO"}],"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"availableBytes"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize"}],"roleHeading":"Instance Property","title":"availableBytes"},"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketProtocol"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"availableBytes","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","text":"gssize","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"socket","type":"codeVoice"},{"type":"text","text":" is a UDP or SCTP socket, this will return the size of"},{"type":"text","text":" "},{"type":"text","text":"just the next packet, even if additional packets are buffered after"},{"text":" ","type":"text"},{"type":"text","text":"that one."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that on Windows, this function is rather inefficient in the"},{"type":"text","text":" "},{"type":"text","text":"UDP case, and so if you know any plausible upper bound on the size"},{"type":"text","text":" "},{"type":"text","text":"of the incoming packet, it is better to just do a"},{"type":"text","text":" "},{"code":"g_socket_receive()","type":"codeVoice"},{"type":"text","text":" with a buffer of that size, rather than calling"},{"text":" ","type":"text"},{"code":"g_socket_get_available_bytes()","type":"codeVoice"},{"type":"text","text":" first and then doing a receive of"},{"type":"text","text":" "},{"type":"text","text":"exactly the right size."}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/SocketProtocol/availableBytes":{"role":"symbol","kind":"symbol","title":"availableBytes","type":"topic","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol\/availableBytes","url":"\/documentation\/gio\/socketprotocol\/availablebytes","abstract":[{"type":"text","text":"Get the amount of data pending in the OS input buffer, without blocking."}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"availableBytes"},{"kind":"text","text":": "},{"preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier","text":"gssize"}]},"doc://GIO/documentation/GIO/SocketProtocol":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol","title":"SocketProtocol","url":"\/documentation\/gio\/socketprotocol","abstract":[{"type":"text","text":"A "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"text":" ","type":"text"},{"text":"direct mapping of the BSD socket API in a portable GObject based API.","type":"text"},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"SocketProtocol","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SocketProtocol","kind":"identifier"}],"role":"symbol","type":"topic"}}}