{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol\/close()"},"kind":"symbol","abstract":[{"text":"Closes the socket, shutting down any active connection.","type":"text"}],"sections":[],"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"kind":"text","text":"() "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"role":"symbol","extendedModule":"GIO","symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"GIO"}],"title":"close()","externalID":"s:3GIO14SocketProtocolPAAE5closeSbyKF"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"kind":"text","text":"() "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Closing a socket does not wait for all outstanding I\/O operations"},{"type":"text","text":" "},{"type":"text","text":"to finish, so the caller should not rely on them to be guaranteed"},{"text":" ","type":"text"},{"text":"to complete even if the close returns with no error.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Once the socket is closed, all other operations will return","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"closed"},{"type":"text","text":". Closing a socket multiple times will not"},{"text":" ","type":"text"},{"type":"text","text":"return an error."}]},{"inlineContent":[{"type":"text","text":"Sockets will be automatically closed when the last reference"},{"text":" ","type":"text"},{"text":"is dropped, but you might want to call this function to make sure","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"resources are released as early as possible."}],"type":"paragraph"},{"inlineContent":[{"text":"Beware that due to the way that TCP works, it is possible for","type":"text"},{"type":"text","text":" "},{"text":"recently-sent data to be lost if either you close a socket while the","type":"text"},{"type":"text","text":" "},{"text":"[in_](\/\/documentation\/gobject\/in_ condition is set, or else if the remote connection tries to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"send something to you after you close the socket but before it has"},{"type":"text","text":" "},{"type":"text","text":"finished reading all of the data you sent. There is no easy generic"},{"text":" ","type":"text"},{"type":"text","text":"way to avoid this problem; the easiest fix is to design the network"},{"type":"text","text":" "},{"text":"protocol such that the client will never send data “out of turn”.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Another solution is for the server to half-close the connection by"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"g_socket_shutdown()"},{"type":"text","text":" with only the "},{"type":"codeVoice","code":"shutdown_write"},{"type":"text","text":" flag set,"},{"type":"text","text":" "},{"type":"text","text":"and then wait for the client to notice this and close its side of the"},{"type":"text","text":" "},{"text":"connection, after which the server can safely call ","type":"text"},{"type":"codeVoice","code":"g_socket_close()"},{"type":"text","text":"."},{"text":" ","type":"text"},{"text":"(This is what ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnection"},{"text":" does if you call","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_tcp_connection_set_graceful_disconnect()"},{"type":"text","text":". But of course, this"},{"type":"text","text":" "},{"type":"text","text":"only works if the client will close its connection after the server"},{"text":" ","type":"text"},{"type":"text","text":"does.)"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketprotocol\/close()"]}],"references":{"doc://GIO/documentation/GIO/SocketConnection":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"SocketConnection","kind":"identifier"}],"type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SocketConnection","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection","url":"\/documentation\/gio\/socketconnection","abstract":[{"type":"codeVoice","code":"GSocketConnection"},{"type":"text","text":" is a [class"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/IOStream","isActive":true},{"text":"] for a connected socket. They","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"can be created either by [class"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketClient","isActive":true,"type":"reference"},{"type":"text","text":"] when connecting to a host,"},{"type":"text","text":" "},{"text":"or by [class","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketListener","type":"reference"},{"text":"] when accepting a new client.","type":"text"}],"title":"SocketConnection"},"doc://GIO/documentation/GIO/SocketProtocol":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol","title":"SocketProtocol","url":"\/documentation\/gio\/socketprotocol","abstract":[{"type":"text","text":"A "},{"code":"GSocket","type":"codeVoice"},{"type":"text","text":" is a low-level networking primitive. It is a more or less"},{"text":" ","type":"text"},{"text":"direct mapping of the BSD socket API in a portable GObject based API.","type":"text"},{"type":"text","text":" "},{"text":"It supports both the UNIX socket implementations and winsock2 on Windows.","type":"text"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"text":"SocketProtocol","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"SocketProtocol","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO":{"type":"topic","abstract":[],"identifier":"doc:\/\/GIO\/documentation\/GIO","title":"GIO","url":"\/documentation\/gio","role":"collection","kind":"symbol"},"doc://GIO/documentation/GIO/TcpConnection":{"abstract":[{"type":"text","text":"This is the subclass of [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketConnection"},{"type":"text","text":"] that is created"},{"text":" ","type":"text"},{"type":"text","text":"for TCP\/IP sockets."}],"navigatorTitle":[{"kind":"identifier","text":"TcpConnection"}],"title":"TcpConnection","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"TcpConnection","kind":"identifier"}],"role":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/TcpConnection","kind":"symbol","url":"\/documentation\/gio\/tcpconnection"},"doc://GIO/documentation/GIO/SocketProtocol/close()":{"role":"symbol","abstract":[{"text":"Closes the socket, shutting down any active connection.","type":"text"}],"title":"close()","url":"\/documentation\/gio\/socketprotocol\/close()","kind":"symbol","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketProtocol\/close()","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"text":"() ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]}}}