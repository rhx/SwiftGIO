{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Receive data from a socket.  For receiving multiple messages, see"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_receive_messages()"},{"type":"text","text":"; for easier use, see"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_socket_receive()"},{"text":" and ","type":"text"},{"code":"g_socket_receive_from()","type":"codeVoice"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"receiveMessage"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"address"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GSocketAddress","kind":"typeIdentifier"},{"text":">?>! = nil, ","kind":"text"},{"kind":"externalParam","text":"vectors"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GInputVector"},{"kind":"text","text":">!, "},{"text":"numVectors","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"messages"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"text":"GSocketControlMessage","kind":"typeIdentifier"},{"kind":"text","text":">?>?>! = nil, "},{"kind":"externalParam","text":"numMessages"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gint","text":"gint","kind":"typeIdentifier"},{"text":">!, ","kind":"text"},{"text":"flags","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gint","text":"gint","kind":"typeIdentifier"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"cancellable"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:3GIO14CancellableRefV","text":"CancellableRef","identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef"},{"kind":"text","text":"? = nil) "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"c:glibconfig.h@T@gssize","kind":"typeIdentifier","text":"gssize"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"address"},{"type":"text","text":" is non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":" then "},{"type":"codeVoice","code":"address"},{"text":" will be set equal to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"source address of the received packet."},{"text":" ","type":"text"},{"type":"codeVoice","code":"address"},{"text":" is owned by the caller.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"vector","type":"codeVoice"},{"type":"text","text":" must point to an array of "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true,"type":"reference"},{"text":" structs and","type":"text"},{"type":"text","text":" "},{"code":"numVectors","type":"codeVoice"},{"type":"text","text":" must be the length of this array.  These structs"},{"type":"text","text":" "},{"text":"describe the buffers that received data will be scattered into.","type":"text"},{"type":"text","text":" "},{"text":"If ","type":"text"},{"type":"codeVoice","code":"numVectors"},{"type":"text","text":" is -1, then "},{"type":"codeVoice","code":"vectors"},{"text":" is assumed to be terminated","type":"text"},{"text":" ","type":"text"},{"text":"by a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true},{"type":"text","text":" with a "},{"type":"codeVoice","code":"nil"},{"text":" buffer pointer.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"As a special case, if ","type":"text"},{"type":"codeVoice","code":"numVectors"},{"type":"text","text":" is 0 (in which case, "},{"type":"codeVoice","code":"vectors"},{"text":" ","type":"text"},{"type":"text","text":"may of course be "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"), then a single byte is received and"},{"text":" ","type":"text"},{"type":"text","text":"discarded. This is to facilitate the common practice of sending a"},{"type":"text","text":" "},{"type":"text","text":"single ‘\\0’ byte for the purposes of transferring ancillary data."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"messages"},{"type":"text","text":", if non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", will be set to point to a newly-allocated"},{"text":" ","type":"text"},{"text":"array of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","isActive":true,"type":"reference"},{"text":" instances or ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if no such","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages was received. These correspond to the control messages"},{"type":"text","text":" "},{"type":"text","text":"received from the kernel, one "},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","isActive":true,"type":"reference"},{"text":" per message","type":"text"},{"type":"text","text":" "},{"type":"text","text":"from the kernel. This array is "},{"code":"nil","type":"codeVoice"},{"text":"-terminated and must be freed","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"by the caller using "},{"type":"codeVoice","code":"g_free()"},{"type":"text","text":" after calling "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" on each"},{"text":" ","type":"text"},{"text":"element. If ","type":"text"},{"code":"messages","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", any control messages received will"},{"type":"text","text":" "},{"type":"text","text":"be discarded."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"numMessages"},{"type":"text","text":", if non-"},{"code":"nil","type":"codeVoice"},{"text":", will be set to the number of control","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messages received."}]},{"inlineContent":[{"text":"If both ","type":"text"},{"code":"messages","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" are non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", then","type":"text"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" gives the number of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage"},{"type":"text","text":" instances"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"messages","type":"codeVoice"},{"type":"text","text":" (ie: not including the "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" terminator)."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" is an in\/out parameter. The commonly available arguments","type":"text"},{"type":"text","text":" "},{"text":"for this are available in the ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true},{"type":"text","text":" enum, but the"},{"text":" ","type":"text"},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are passed in as-is, so you can pass in system-specific flags too"},{"text":" ","type":"text"},{"text":"(and ","type":"text"},{"code":"g_socket_receive_message()","type":"codeVoice"},{"type":"text","text":" may pass system-specific flags out)."},{"type":"text","text":" "},{"text":"Flags passed in to the parameter affect the receive operation; flags returned","type":"text"},{"type":"text","text":" "},{"type":"text","text":"out of it are relevant to the specific returned message."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As with "},{"code":"g_socket_receive()","type":"codeVoice"},{"text":", data may be discarded if ","type":"text"},{"code":"socket","type":"codeVoice"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"code":"datagram","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"seqpacket"},{"text":" and you do not","type":"text"},{"type":"text","text":" "},{"text":"provide enough buffer space to read a complete message. You can pass","type":"text"},{"type":"text","text":" "},{"code":"peek","type":"codeVoice"},{"type":"text","text":" in "},{"type":"codeVoice","code":"flags"},{"text":" to peek at the current message without","type":"text"},{"type":"text","text":" "},{"type":"text","text":"removing it from the receive queue, but there is no portable way to find"},{"text":" ","type":"text"},{"type":"text","text":"out the length of the message other than by reading it into a"},{"text":" ","type":"text"},{"text":"sufficiently-large buffer.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the socket is in blocking mode the call will block until there"},{"text":" ","type":"text"},{"type":"text","text":"is some data to receive, the connection is closed, or there is an"},{"type":"text","text":" "},{"type":"text","text":"error. If there is no data available and the socket is in"},{"text":" ","type":"text"},{"type":"text","text":"non-blocking mode, a "},{"type":"codeVoice","code":"wouldBlock"},{"text":" error will be","type":"text"},{"type":"text","text":" "},{"text":"returned. To be notified when data is available, wait for the","type":"text"},{"type":"text","text":" "},{"text":"[in_](\/\/documentation\/gobject\/in_ condition.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketProtocol"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/gio\/socketprotocol\/receivemessage(address:vectors:numvectors:messages:nummessages:flags:cancellable:)-98b24"]}],"metadata":{"role":"symbol","modules":[{"name":"GIO"}],"title":"receiveMessage(address:vectors:numVectors:messages:numMessages:flags:cancellable:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"receiveMessage","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"address"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"UnsafeMutablePointer","preciseIdentifier":"s:Sp"},{"kind":"text","text":"<"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"text":"GSocketAddress","kind":"typeIdentifier"},{"text":">?>!, ","kind":"text"},{"text":"vectors","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"kind":"text","text":"<"},{"tex