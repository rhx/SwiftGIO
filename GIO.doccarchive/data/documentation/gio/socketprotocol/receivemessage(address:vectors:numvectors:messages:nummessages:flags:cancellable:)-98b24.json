:"SocketControlMessage","kind":"identifier"}],"abstract":[{"type":"text","text":"A "},{"code":"GSocketControlMessage","type":"codeVoice"},{"text":" is a special-purpose utility message that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be sent to or received from a [class"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket"},{"text":"]. These types of","type":"text"},{"type":"text","text":" "},{"text":"messages are often called ‘ancillary data’.","type":"text"}]},"doc://GIO/documentation/GIO/CancellableRef":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"CancellableRef","kind":"identifier"}],"type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"CancellableRef","kind":"identifier"}],"identifier":"doc:\/\/GIO\/documentation\/GIO\/CancellableRef","url":"\/documentation\/gio\/cancellableref","abstract":[{"type":"codeVoice","code":"GCancellable"},{"type":"text","text":" allows operations to be cancelled."}],"title":"CancellableRef"},"doc://GIO/documentation/GIO/InputVector":{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","title":"InputVector","url":"\/documentation\/gio\/inputvector","abstract":[{"type":"text","text":"Structure used for scatter\/gather data input."},{"type":"text","text":" "},{"type":"text","text":"You generally pass in an array of "},{"type":"codeVoice","code":"GInputVectors"},{"text":" ","type":"text"},{"text":"and the operation will store the read data starting in the","type":"text"},{"type":"text","text":" "},{"text":"first buffer, switching to the next as needed.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"InputVector"}],"kind":"symbol","navigatorTitle":[{"text":"InputVector","kind":"identifier"}],"role":"symbol","type":"topic"},"doc://GIO/documentation/GIO/SocketMsgFlags":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/GIO\/documentati