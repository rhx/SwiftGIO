tent":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"address","type":"codeVoice"},{"text":" is non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" then ","type":"text"},{"code":"address","type":"codeVoice"},{"text":" will be set equal to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"source address of the received packet."},{"type":"text","text":" "},{"type":"codeVoice","code":"address"},{"type":"text","text":" is owned by the caller."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"vector"},{"text":" must point to an array of ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector","isActive":true,"type":"reference"},{"type":"text","text":" structs and"},{"type":"text","text":" "},{"code":"numVectors","type":"codeVoice"},{"text":" must be the length of this array.  These structs","type":"text"},{"type":"text","text":" "},{"text":"describe the buffers that received data will be scattered into.","type":"text"},{"type":"text","text":" "},{"text":"If ","type":"text"},{"code":"numVectors","type":"codeVoice"},{"type":"text","text":" is -1, then "},{"type":"codeVoice","code":"vectors"},{"type":"text","text":" is assumed to be terminated"},{"text":" ","type":"text"},{"text":"by a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputVector"},{"type":"text","text":" with a "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" buffer pointer."}]},{"type":"paragraph","inlineContent":[{"text":"As a special case, if ","type":"text"},{"code":"numVectors","type":"codeVoice"},{"type":"text","text":" is 0 (in which case, "},{"code":"vectors","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"may of course be "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"), then a single byte is received and"},{"text":" ","type":"text"},{"type":"text","text":"discarded. This is to facilitate the common practice of sending a"},{"text":" ","type":"text"},{"type":"text","text":"single ‘\\0’ byte for the purposes of transferring ancillary data."}]},{"type":"paragraph","inlineContent":[{"code":"messages","type":"codeVoice"},{"type":"text","text":", if non-"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", will be set to point to a newly-allocated"},{"type":"text","text":" "},{"type":"text","text":"array of "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","isActive":true},{"type":"text","text":" instances or "},{"code":"nil","type":"codeVoice"},{"text":" if no such","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages was received. These correspond to the control messages"},{"type":"text","text":" "},{"type":"text","text":"received from the kernel, one "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage"},{"text":" per message","type":"text"},{"text":" ","type":"text"},{"text":"from the kernel. This array is ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":"-terminated and must be freed"},{"type":"text","text":" "},{"text":"by the caller using ","type":"text"},{"type":"codeVoice","code":"g_free()"},{"text":" after calling ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"text":" on each","type":"text"},{"text":" ","type":"text"},{"text":"element. If ","type":"text"},{"code":"messages","type":"codeVoice"},{"type":"text","text":" is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", any control messages received will"},{"text":" ","type":"text"},{"type":"text","text":"be discarded."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"numMessages"},{"text":", if non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", will be set to the number of control","type":"text"},{"text":" ","type":"text"},{"text":"messages received.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If both "},{"code":"messages","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" are non-"},{"type":"codeVoice","code":"nil"},{"text":", then","type":"text"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" gives the number of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage"},{"text":" instances","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"type":"codeVoice","code":"messages"},{"type":"text","text":" (ie: not including the "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" terminator)."}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"flags"},{"text":" is an in\/out parameter. The commonly available arguments","type":"text"},{"text":" ","type":"text"},{"text":"for this are available in the ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","type":"reference","isActive":true},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"type":"text","text":"values there are the same as the system values, and the flags"},{"text":" ","type":"text"},{"text":"are passed in as-is, so you can pass in system-specific flags too","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"(and "},{"type":"codeVoice","code":"g_socket_receive_message()"},{"type":"text","text":" may pass system-specific flags out)."},{"text":" ","type":"text"},{"type":"text","text":"Flags passed in to the parameter affect the receive operation; flags returned"},{"text":" ","type":"text"},{"type":"text","text":"out of it are relevant to the specific returned message."}]},{"inlineContent":[{"text":"As with ","type":"text"},{"type":"codeVoice","code":"g_socket_receive()"},{"text":", data may be discarded if ","type":"text"},{"type":"codeVoice","code":"socket"},{"type":"text","text":" is"},{"type":"text","text":" "},{"code":"datagram","type":"codeVoice"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"seqpacket"},{"type":"text","text":" and you do not"},{"type":"text","text":" "},{"text":"provide enough buffer space to read a complete message. You can pass","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"peek"},{"type":"text","text":" in "},{"type":"codeVoice","code":"flags"},{"type":"text","text":" to peek at the current message without"},{"type":"text","text":" "},{"type":"text","text":"removing it from the receive queue, but there is no portable way to find"},{"type":"text","text":" "},{"type":"text","text":"out the length of the message other than by reading it into a"},{"text":" ","type":"text"},{"text":"sufficiently-large buffer.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the socket is in blocking mode the call will block until there","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is some data to receive, the connection is closed, or there is an"},{"type":"text","text":" "},{"type":"text","text":"error. If there is no data available and the socket is in"},{"text":" ","type":"text"},{"text":"non-blocking mode, a ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" error will be"},{"type":"text","text":" "},{"type":"text","text":"returned. To be notified when data is available, wait for the"},{"text":" ","type":"text"},{"text":"[in_](\/\/documentation\/gobject\/in_ condition.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly."}]}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GIO\/documentation\/GIO","doc:\/\/GIO\/documentation\/GIO\/SocketProtocol"]]},"abstract":[{"text":"Receive data from a socket.  For receiving multipl