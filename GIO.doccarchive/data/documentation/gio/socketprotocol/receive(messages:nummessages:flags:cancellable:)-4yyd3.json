"},{"type":"text","text":"buffers that the data received in each message will be written to. Using"},{"type":"text","text":" "},{"type":"text","text":"multiple "},{"type":"codeVoice","code":"GInputVectors"},{"text":" is more memory-efficient than manually copying data","type":"text"},{"text":" ","type":"text"},{"text":"out of a single buffer to multiple sources, and more system-call-efficient","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"than making multiple calls to "},{"type":"codeVoice","code":"g_socket_receive()"},{"type":"text","text":", such as in scenarios where"},{"type":"text","text":" "},{"text":"a lot of data packets need to be received (e.g. high-bandwidth video","type":"text"},{"type":"text","text":" "},{"text":"streaming over RTP\/UDP).","type":"text"}]},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" modify how all messages are received. The commonly available"},{"type":"text","text":" "},{"text":"arguments for this are available in the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags"},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"text":"values there are the same as the system values, and the flags","type":"text"},{"type":"text","text":" "},{"text":"are passed in as-is, so you can pass in system-specific flags too. These","type":"text"},{"type":"text","text":" "},{"type":"text","text":"flags affect the overall receive operation. Flags affecting individual"},{"type":"text","text":" "},{"text":"messages are returned in ","type":"text"},{"type":"codeVoice","code":"GInputMessage.flags"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The other members of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/InputMessage","isActive":true},{"text":" are treated as described in its","type":"text"},{"text":" ","type":"text"},{"text":"documentation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference","isActive":true},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" the call will block until "},{"type":"codeVoice","code":"numMessages"},{"type":"text","text":" have"},{"text":" ","type":"text"},{"type":"text","text":"been received, or the end of the stream is reached."}]},{"inlineContent":[{"text":"If ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" the call will return up to "},{"code":"numMessages","type":"codeVoice"},{"type":"text","text":" "},{"text":"without blocking, or ","type":"text"},{"type":"codeVoice","code":"wouldBlock"},{"type":"text","text":" if no messages are queued in the"},{"text":" ","type":"text"},{"type":"text","text":"operating system to be received."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In blocking mode, if ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/Socket","type":"reference"},{"type":"text","text":" is positive and is reached before any"},{"type":"text","text":" "},{"type":"text","text":"messages are received, "},{"code":"timedOut","type":"codeVoice"},{"type":"text","text":" is returned, otherwise up to"},{"type":"text","text":" "},{"code":"numMessages","type":"codeVoice"},{"text":" are returned. (Note: This is effectively the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"behaviour of "},{"code":"MSG_WAITFORONE","type":"codeVoice"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"recvmmsg()"},{"type":"text","text":".)"}]},{"inlineContent":[{"text":"To be notified when messages are available, wait for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[in_](\/\/documentation\/gobject\/in_ condition. Note though that you may still receive"},{"type":"text","text":" "},{"code":"wouldBlock","type":"codeVoice"},{"type":"text","text":" from "},{"code":"g_socket_receive_messages()","type":"codeVoice"},{"type":"text","text":" even if you were"},{"text":" ","type":"text"},{"type":"text","text":"previously notified of a [in_](\/\/documentation\/gobject\/in_ condition."}],"type":"paragraph"},{"inlineContent":[{"text":"If the remote peer closes the connection, any messages queued in the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"operating system will be returned, and subsequent calls to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_receive_messages()"},{"text":" will return 0 (with no error set).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On error -1 is returned and "},{"type":"codeVoice","code":"error"},{"type":"text","text":" is set accordingly. An error will only"},{"text":" ","type":"text"},{"text":"be returned if zero messages could be received; otherwise the number of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"messages successfully received before the error will be returned."}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","abstract":[{"type":"text","text":"Receive multiple data messages from "},{"type":"codeVoice","code":"socket"},{"type":"text","text":" in one go.  This is the most"},{"text":" ","type":"text"},{"text":"complicated and fully-featured version of this call. For easier use, see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_socket_receive()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_socket_receive_from()"},{"type":"text","text":", and "},{"code":"g_socket_receive_message()","type":"codeVoice"},{"type":"text","text":"."}],"variants":[{"paths":["\/documentation\/gio\/socketprotocol\/receive(messages:nummessages:flags:cancellable:)-4yyd3"],"traits":[{"int