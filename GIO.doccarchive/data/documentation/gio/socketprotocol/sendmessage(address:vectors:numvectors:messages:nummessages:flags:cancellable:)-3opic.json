":"text","text":"On error -1 is returned and "},{"code":"error","type":"codeVoice"},{"type":"text","text":" is set accordingly."}]}]}],"variants":[{"paths":["\/documentation\/gio\/socketprotocol\/sendmessage(address:vectors:numvectors:messages:nummessages:flags:cancellable:)-3opic"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Instance Method","modules":[{"name":"GIO"}],"title":"sendMessage(address:vectors:numVectors:messages:numMessages:flags:cancellable:)","role":"symbol","externalID":"s:3GIO14SocketProtocolPAAE11sendMessage7address7vectors10numVectors8messages0H8Messages5flags11cancellableSiqd_0_Sg_SpySo14_GOutputVectorVGSgSiSpySpySo015_GSocketControlE0VGSgGSgS2iqd__SgtKAA011CancellableC0Rd__AA0b7AddressC0Rd_0_r0_lF","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"sendMessage"},{"kind":"text","text":"<"},{"text":"CancellableT","kind":"genericParameter"},{"kind":"text","text":", "},{"text":"SocketAddressT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"address","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"SocketAddressT","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"text":"vectors","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"UnsafeMutablePointer","kind":"typeIdentifier","preciseIdentifier":"s:Sp"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GOutputVector"},{"kind":"text","text":">!, "},{"text":"numVectors","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"messages"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:Sp","kind":"typeIdentifier","text":"UnsafeMutablePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"GSocketControlMessage"},{"kind":"text","text"