oc:\/\/GIO\/documentation\/GIO\/OutputVector","type":"reference","isActive":true},{"text":" structs describe the buffers","type":"text"},{"type":"text","text":" "},{"text":"that the sent data will be gathered from. Using multiple","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"GOutputVectors"},{"type":"text","text":" is more memory-efficient than manually copying"},{"type":"text","text":" "},{"type":"text","text":"data from multiple sources into a single buffer, and more"},{"type":"text","text":" "},{"type":"text","text":"network-efficient than making multiple calls to "},{"type":"codeVoice","code":"g_socket_send()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"messages"},{"text":", if non-","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", is taken to point to an array of ","type":"text"},{"type":"codeVoice","code":"numMessages"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketControlMessage","type":"reference"},{"text":" instances. These correspond to the control","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"messages to be sent on the socket."},{"text":" ","type":"text"},{"type":"text","text":"If "},{"code":"numMessages","type":"codeVoice"},{"text":" is -1 then ","type":"text"},{"type":"codeVoice","code":"messages"},{"text":" is treated as a ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":"-terminated"},{"text":" ","type":"text"},{"type":"text","text":"array."}]},{"inlineContent":[{"type":"codeVoice","code":"flags"},{"type":"text","text":" modify how the message is sent. The commonly available arguments"},{"type":"text","text":" "},{"type":"text","text":"for this are available in the "},{"type":"reference","identifier":"doc:\/\/GIO\/documentation\/GIO\/SocketMsgFlags","isActive":true},{"type":"text","text":" enum, but the"},{"type":"text","text":" "},{"type":"text","text":"values there are t