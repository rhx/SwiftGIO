{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingSignalName\/notify"},"metadata":{"title":"BindingSignalName.notify","role":"symbol","symbolKind":"case","modules":[{"name":"GLibObject"}],"fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"notify","kind":"identifier"}],"externalID":"s:10GLibObject17BindingSignalNameO6notifyyA2CmF","roleHeading":"Case"},"sections":[],"variants":[{"paths":["\/documentation\/glibobject\/bindingsignalname\/notify"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"text":"its value set through ","type":"text"},{"type":"codeVoice","code":"g_object_set_property()"},{"text":", ","type":"text"},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"notify","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Note that getting this signal doesn’t itself guarantee that the value of","type":"text"},{"type":"text","text":" "},{"text":"the property has actually changed. When it is emitted is determined by the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"derived GObject class. If the implementor did not create the property with"},{"type":"text","text":" "},{"code":"explicitNotify","type":"codeVoice"},{"type":"text","text":", then any call to "},{"type":"codeVoice","code":"g_object_set_property()"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"notify","type":"codeVoice"},{"type":"text","text":" being emitted, even if the new value is the same as the old."},{"type":"text","text":" "},{"type":"text","text":"If they did pass "},{"type":"codeVoice","code":"explicitNotify"},{"text":", then this signal is emitted only","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"when they explicitly call "},{"code":"g_object_notify()","type":"codeVoice"},{"type":"text","text":" or "},{"code":"g_object_notify_by_pspec()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"and common practice is to do that only when the value has actually changed.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This signal is typically used to obtain change notification for a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"single property, by specifying the property name as a detail in the"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect()"},{"type":"text","text":" call, like this:"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["g_signal_connect (text_view->buffer, \"notify::paste-target-list\",","                  G_CALLBACK (gtk_text_view_target_list_notify),","                  text_view)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"It is important to note that you must use"},{"type":"text","text":" "},{"identifier":"#class@GObject.ParamSpec#parameter-names","type":"reference","isActive":true},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingSignalName"]]},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"#class@GObject.ParamSpec#parameter-names":{"titleInlineContent":[{"type":"text","text":"canonical parameter names"}],"title":"canonical parameter names","url":"#class@GObject.ParamSpec#parameter-name