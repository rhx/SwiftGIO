{"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass\/TypeClassProtocol-Implementations"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass\/addPrivate(privateSize:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"addPrivate"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"privateSize"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When an object is allocated, the private structures for"},{"type":"text","text":" "},{"type":"text","text":"the type and all of its parent types are allocated"},{"text":" ","type":"text"},{"text":"sequentially in the same memory block as the public","type":"text"},{"type":"text","text":" "},{"type":"text","text":"structures, and are zero-filled."}]},{"type":"paragraph","inlineContent":[{"text":"Note that the accumulated size of the private structures of","type":"text"},{"type":"text","text":" "},{"text":"a type and all its parent types cannot exceed 64 KiB.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This function should be called in the type’s ","type":"text"},{"code":"class_init()","type":"codeVoice"},{"type":"text","text":" function."},{"type":"text","text":" "},{"text":"The private structure can be retrieved using the","type":"text"},{"text":" ","type":"text"},{"code":"G_TYPE_INSTANCE_GET_PRIVATE()","type":"codeVoice"},{"text":" macro.","type":"text"}]},{"inlineContent":[{"text":"The following example shows attaching a private structure","type":"text"},{"type":"text","text":" "},{"text":"MyObjectPrivate to an object MyObject defined in the standard","type":"text"},{"type":"text","text":" "},{"text":"GObject fashion in the type’s ","type":"text"},{"code":"class_init()","type":"codeVoice"},{"text":" function.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note the use of a structure member “priv” to avoid the overhead"},{"type":"text","text":" "},{"text":"of repeatedly calling ","type":"text"},{"type":"codeVoice","code":"MY_OBJECT_GET_PRIVATE()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","code":["typedef struct _MyObject        MyObject;","typedef struct _MyObjectPrivate MyObjectPrivate;","","struct _MyObject {"," GObject parent;",""," MyObjectPrivate *priv;","};","","struct _MyObjectPrivate {","  int some_field;","};","","static void","my_object_class_init (MyObjectClass *klass)","{","  g_type_class_add_private (klass, sizeof (MyObjectPrivate));","}","","static void","my_object_init (MyObject *my_object)","{","  my_object->priv = G_TYPE_INSTANCE_GET_PRIVATE (my_object,","                                                 MY_TYPE_OBJECT,","                                                 MyObjectPrivate);","  \/\/ my_object->priv->some_field will be automatically initialised to 0","}","","static int","my_object_get_some_field (MyObject *my_object)","{","  MyObjectPrivate *priv;","","  g_return_val_if_fail (MY_IS_OBJECT (my_object), 0);","","  priv = my_object->priv;","","  return priv->some_field;","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"add_private is deprecated:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"type":"text","text":"Use the G_ADD_PRIVATE() macro with the "},{"type":"codeVoice","code":"G_DEFINE_*"},{"type":"text","text":" "},{"type":"text","text":"family of macros to add instance private data to a type"}]}]}],"kind":"symbol","metadata":{"externalID":"s:10GLibObject17TypeClassProtocolPAAE10addPrivate11privateSizeySi_tF::SYNTHESIZED::s:10GLibObject9TypeClassC","roleHeading":"Instance Method","title":"addPrivate(privateSize:)","extendedModule":"GLibObject","symbolKind":"method","platforms":[],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"text":"(","kind":"text"},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"text":")","kind":"text"}],"modules":[{"name":"GLibObject"}],"role":"symbol"},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"variants":[{"paths":["\/documentation\/glibobject\/typeclass\/addprivate(privatesize:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://GLibObject/documentation/GLibObject/TypeClass":{"role":"symbol","navigatorTitle":[{"text":"TypeClass","kind":"identifier"}],"title":"TypeClass","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass","abstract":[{"type":"text","text":"An opaque structure used as the base of all classes."}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypeClass","kind":"identifier"}],"type":"topic","url":"\/documentation\/glibobject\/typeclass"},"doc://GLibObject/documentation/GLibObject/TypeClass/addPrivate(privateSize:)":{"role":"symbol","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClass\/addPrivate(privateSize:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"kind":"text","text":"("},{"text":"privateSize","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"text