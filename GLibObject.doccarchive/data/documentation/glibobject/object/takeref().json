{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/takeRef()","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","text":"ObjectRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"In other words, this function will convert a floating reference (if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"text":" ","type":"text"},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"text":"where the object that is being returned already exists).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"type":"text","text":" "},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"text":" ","type":"text"},{"text":"instances, the user can be saved some typing if they are allowed to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a floating reference."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"type":"text","text":" "},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"text":" ","type":"text"},{"type":"text","text":"always receives exactly one full reference to the value: either the"},{"text":" ","type":"text"},{"text":"one that was returned in the first place, or a floating reference","type":"text"},{"text":" ","type":"text"},{"text":"that has been converted to a full reference.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" running at the same time in another thread on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the same "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference"},{"type":"text","text":" instance. If "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" runs first then","type":"text"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference. If "},{"type":"codeVoice","code":"g_object_take_ref()"},{"type":"text","text":" runs first then the result will be"},{"text":" ","type":"text"},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"text":" ","type":"text"},{"text":"this situation.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/object\/takeref()"]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Object","doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations"]]},"metadata":{"title":"takeRef()","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject0B0C"},"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://GLibObject/documentation/GLibObject/Object/ObjectProtocol-Implementations":{"kind":"article","title":"ObjectProtocol Implementations","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/ObjectProtocol-Implementations","abstract":[],"url":"\/documentation\/glibobject\/object\/objectprotocol-implementations","role":"collectionGroup"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"text":"The base object type.","type":"text"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","kind":"symbol","role":"symbol"},"doc://GLibObject/documentation/GLibObject/Object/takeRef()":{"url":"\/documentation\/glibobject\/object\/takeref()","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object\/takeRef()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}],"type":"topic","title":"takeRef()","role":"symbol","abstract":[{"type":"text","text":"If "},{"code":"object","type":"codeVoice"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}]},"doc://GLibObject/documentation/GLibObject/Object":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"title":"Object","kind":"symbol","abstract":[{"text":"The base object type.","type":"text"}],"url":"\/documentation\/glibobject\/object","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"}}}