rties"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/TypeModuleProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/TypePluginProtocol-Implementations"],"anchor":"Default-Implementations","generated":true,"title":"Default Implementations"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","interfaceLanguage":"swift"},"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Object"],"kind":"relationships","title":"Inherits From"},{"identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"abstract":[{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" provides a simple implementation of the "},{"type":"codeVoice","code":"GTypePlugin"},{"type":"text","text":" "},{"type":"text","text":"interface."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeModule"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"The model of "},{"type":"codeVoice","code":"GTypeModule"},{"text":" is a dynamically loaded module which","type":"text"},{"type":"text","text":" "},{"text":"implements some number of types and interface implementations.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When the module is loaded, it registers its types and interfaces","type":"text"},{"text":" ","type":"text"},{"text":"using [method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.register_type"},{"type":"text","text":"] and"},{"type":"text","text":" "},{"text":"[method","type":"text"},{"type":"codeVoice","code":"GObject.TypeModule.add_interface"},{"text":"].","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"As long as any instances of these types and interface implementations"},{"type":"text","text":" "},{"type":"text","text":"are in use, the module is kept loaded. When the types and interfaces"},{"type":"text","text":" "},{"type":"text","text":"are gone, the module may be unloaded. If the types and interfaces"},{"text":" ","type":"text"},{"text":"become used again, the module will be reloaded. Note that the last","type":"text"},{"type":"text","text":" "},{"type":"text","text":"reference cannot be released from within the module code, since that"},{"type":"text","text":" "},{"text":"would lead to the caller’s code being unloaded before ","type":"text"},{"type":"codeVoice","code":"g_object_unref()"},{"text":" ","type":"text"},{"type":"text","text":"returns to it."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Keeping track of whether the module should be loaded or not is done by","type":"text"},{"type":"text","text":" "},{"type":"text","text":"using a use count - it starts at zero, and whenever it is greater than"},{"type":"text","text":" "},{"text":"zero, the module is loaded. The use count is maintained internally by","type":"text"},{"text":" ","type":"text"},{"text":"the type system, but also can be explicitly controlled by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"code":"GObject.TypeModule.use","type":"codeVoice"},{"text":"] and [method","type":"text"},{"code":"GObject.TypeModule.unuse","type":"codeVoice"},{"type":"text","text":"]."},{"type":"text","text":" "},{"type":"text","text":"Typically, when loading a module for the first type, "},{"type":"codeVoice","code":"g_type_module_use()"},{"type":"text","text":" "},{"type":"text","text":"will be used to load it so that it can initialize its types. At some later"},{"type":"text","text":" "},{"type":"text","text":"point, when the module no longer needs to be loaded except for the type"},{"text":" ","type":"text"},{"type":"text","text":"implementations it contains, "},{"code":"g_type_module_unuse()","type":"codeVoice"},{"type":"text","text":" is called."}]},{"type":"paragraph","inlineContent":[{"code":"GTypeModule","type":"codeVoice"},{"type":"text","text":" does not actually provide any implementation of module"},{"type":"text","text":" "},{"type":"text","text":"loading and unloading. To create a particular module type you must"},{"type":"text","text":" "},{"text":"derive from ","type":"text"},{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" and implement the load and unload functions"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"GTypeModuleClass"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule","type":"reference","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GTypeModule","type":"codeVoice"},{"text":" instance.","type":"text"},{"type":"text","text":" "},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"type":"text","text":" as a strong reference or owner of a "},{"code":"GTypeModule","type":"codeVoice"},{"text":" instance.","type":"text"}]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef"},{"type":"text","text":" (instead of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GTypeModule"},{"type":"text","text":" instance."}]}]}],"kind":"content"}],"metadata":{"externalID":"s:10GLibObject10TypeModuleC","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypeModule","kind":"identifier"}],"symbolKind":"class","navigatorTitle":[{"text":"TypeModule","kind":"identifier"}],"roleHeading":"Class","title":"TypeModule","modules":[{"name":"GLibObject"}],"role":"symbol"},"kind":"symbol","sections":[],"references":{"doc://GLibObject/documentation/GLibObject/TypeModule/init(raw:)-3beng":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule\/init(raw:)-3beng","abstract":[{"text":"Unsafe untyped initialiser.","type":"text"},{"type":"text","text":" "},{"type":"strong","inlineContent":[{"type":"text","text":"Do not use unless you know the underlying data type the pointer points to conforms to "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleProtocol","isActive":true},{"text":".","type":"text"}]}],"role":"symbol","type":"topic","url":"\/documentation\/glibobject\/typemodule\/init(raw:)-3beng","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"text":"raw","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SV","kind":"typeIdentifier","text":"UnsafeRawPointer"},{"text":")","kind":"text"}],"title":"init(raw:)"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLib