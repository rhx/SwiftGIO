{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}]}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" to a proxy"},{"text":" ","type":"text"},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"type":"text","text":"paired references: the strong reference added by"},{"text":" ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":" and a reverse reference to the proxy","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"code":"object","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"text":", a strong reference is held. The ","type":"text"},{"code":"notify","type":"codeVoice"},{"type":"text","text":" callback is called"},{"text":" ","type":"text"},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"text":"“toggled” from strong to weak (","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"text":" true) or weak to strong","type":"text"},{"type":"text","text":" "},{"type":"text","text":"("},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" false)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"type":"text","text":"link is always strong."}]},{"inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}],"type":"paragraph"},{"inlineContent":[{"text":"Note that if you unref the object on another thread, then ","type":"text"},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"text":" ","type":"text"},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":", and the object argument","type":"text"},{"type":"text","text":" "},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"text":" ","type":"text"},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" must be released with "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":".","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"metadata":{"extendedModule":"GLibObject","title":"addToggleRef(notify:data:)","role":"symbol","modules":[{"name":"GLibObject"}],"symbolKind":"method","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject19InitiallyUnownedRefV","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}]},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations"]]},"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations","abstract":[],"url":"\/documentation\/glibobject\/initiallyunownedref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","type":"topic","role":"collectionGroup","kind":"article"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/addToggleRef(notify:data:)":{"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"text":" ","type":"text"},{"text":"callback to be called when all other references to the object are","type":"text"},{"text":" ","type":"text"},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"title":"addToggleRef(notify:data:)","url":"\/documentation\/glibobject\/initiallyunownedref\/addtoggleref(notify:data:)","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/addToggleRef(notify:data:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"kind":"symbol","type":"topic"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"InitiallyUnownedRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"InitiallyUnownedRef"}],"title":"InitiallyUnownedRef","kind":"symbol","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","abstract":[{"text":"A type for objects that have an initially floating reference.","type":"text"}],"type":"topic","url":"\/documentation\/glibobject\/initiallyunownedref"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"}}}