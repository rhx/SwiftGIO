{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"takeRef"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","text":"ObjectRef","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"inlineContent":[{"text":"In other words, this function will convert a floating reference (if","type":"text"},{"type":"text","text":" "},{"text":"present) into a full reference.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Typically you want to use "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"type":"text","text":" "},{"text":"non-floating references, but there is one specific scenario where","type":"text"},{"type":"text","text":" "},{"text":"this function is helpful.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"text":" ","type":"text"},{"type":"text","text":"GObject. We certainly want to allow the user the flexibility to"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"text":"where the object that is being returned already exists).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"text":" ","type":"text"},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"type":"text","text":" "},{"text":"instances, the user can be saved some typing if they are allowed to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a floating reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"text":" ","type":"text"},{"text":"always receives exactly one full reference to the value: either the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" running at the same time in another thread on","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the same "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true,"type":"reference"},{"type":"text","text":" instance. If "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" runs first then","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"type":"text","text":" "},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"text":" runs first then the result will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the floating reference is converted to a hard reference and an"},{"type":"text","text":" "},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"type":"text","text":" "},{"type":"text","text":"this situation."}],"type":"paragraph"}]}],"metadata":{"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"title":"takeRef()","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject19InitiallyUnownedRefV"},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/takeRef()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"If "},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"variants":[{"paths":["\/documentation\/glibobject\/initiallyunownedref\/takeref()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations"]]},"references":{"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/ObjectProtocol-Implementations","abstract":[],"url":"\/documentation\/glibobject\/initiallyunownedref\/objectprotocol-implementations","title":"ObjectProtocol Implementations","type":"topic","role":"collectionGroup","kind":"article"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef/takeRef()":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef\/takeRef()","title":"takeRef()","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef"},{"text":"!","kind":"text"}],"role":"symbol","url":"\/documentation\/glibobject\/initiallyunownedref\/takeref()","abstract":[{"type":"text","text":"If "},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject/InitiallyUnownedRef":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"InitiallyUnownedRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"InitiallyUnownedRef"}],"title":"InitiallyUnownedRef","kind":"symbol","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/InitiallyUnownedRef","abstract":[{"text":"A type for objects that have an initially floating reference.","type":"text"}],"type":"topic","url":"\/documentation\/glibobject\/initiallyunownedref"},"doc://GLibObject/documentation/GLibObject/Object":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"title":"Object","kind":"symbol","abstract":[{"text":"The base object type.","type":"text"}],"url":"\/documentation\/glibobject\/object","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"text":"The base object type.","type":"text"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","kind":"symbol","role":"symbol"}}}