{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closure"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Closure"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It will generally comprise a function of some kind and a marshaller"},{"type":"text","text":" "},{"type":"text","text":"used to call it. It is the responsibility of the marshaller to"},{"type":"text","text":" "},{"text":"convert the arguments for the invocation from ","type":"text"},{"type":"codeVoice","code":"GValues"},{"text":" into","type":"text"},{"type":"text","text":" "},{"text":"a suitable form, perform the callback on the converted arguments,","type":"text"},{"type":"text","text":" "},{"text":"and transform the return value back into a ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the case of C programs, a closure usually just holds a pointer"},{"type":"text","text":" "},{"text":"to a function and maybe a data argument, and the marshaller","type":"text"},{"type":"text","text":" "},{"text":"converts between ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference","isActive":true},{"type":"text","text":" and native C types. The GObject"},{"text":" ","type":"text"},{"text":"library provides the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/CClosure"},{"text":" type for this purpose. Bindings for","type":"text"},{"text":" ","type":"text"},{"text":"other languages need marshallers which convert between ","type":"text"},{"type":"codeVoice","code":"GValues"},{"text":" ","type":"text"},{"type":"text","text":"and suitable representations in the runtime of the language in"},{"type":"text","text":" "},{"type":"text","text":"order to use functions written in that language as callbacks. Use"},{"type":"text","text":" "},{"code":"g_closure_set_marshal()","type":"codeVoice"},{"type":"text","text":" to set the marshaller on such a custom"},{"type":"text","text":" "},{"type":"text","text":"closure implementation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Within GObject, closures play an important role in the"},{"text":" ","type":"text"},{"type":"text","text":"implementation of signals. When a signal is registered, the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"c_marshaller"},{"type":"text","text":" argument to "},{"code":"g_signal_new()","type":"codeVoice"},{"text":" specifies the default C","type":"text"},{"type":"text","text":" "},{"type":"text","text":"marshaller for any closure which is connected to this"},{"type":"text","text":" "},{"text":"signal. GObject provides a number of C marshallers for this","type":"text"},{"type":"text","text":" "},{"type":"text","text":"purpose, see the g_cclosure_marshal_"},{"type":"emphasis","inlineContent":[{"type":"text","text":"() functions. Additional C"},{"type":"text","text":" "},{"type":"text","text":"marshallers can be generated with the "},{"identifier":"#glib-genmarshal","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"utility.  Closures can be explicitly connected to signals with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_connect_closure()"},{"type":"text","text":", but it usually more convenient to let"},{"text":" ","type":"text"},{"type":"text","text":"GObject create a closure automatically by using one of the"},{"text":" ","type":"text"},{"type":"text","text":"g_signal_connect_"}]},{"type":"text","text":"() functions which take a callback function\/user"},{"text":" ","type":"text"},{"text":"data pair.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Using closures has a number of important advantages over a simple"},{"text":" ","type":"text"},{"type":"text","text":"callback function\/data pointer combination:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Closures allow the callee to get the types of the callback parameters,"},{"text":" ","type":"text"},{"type":"text","text":"which means that language bindings don’t have to write individual glue"},{"type":"text","text":" "},{"text":"for each callback type.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The reference counting of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure"},{"type":"text","text":" makes it easy to handle reentrancy"},{"type":"text","text":" "},{"type":"text","text":"right; if a callback is removed while it is being invoked, the closure"},{"type":"text","text":" "},{"type":"text","text":"and its parameters won’t be freed until the invocation finishes."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"g_closure_invalidate()","type":"codeVoice"},{"type":"text","text":" and invalidation notifiers allow callbacks to be"},{"text":" ","type":"text"},{"type":"text","text":"automatically removed when the objects they point to go away."}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure"},{"text":" type acts as a reference-counted owner of an underlying ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"type":"text","text":" instance."},{"text":" ","type":"text"},{"type":"text","text":"It provides the methods that can operate on this data type through "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","type":"reference","isActive":true},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"Use ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","isActive":true},{"text":" (instead of ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","isActive":true},{"text":") for a lightweight Swift reference to an underlying ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"metadata":{"role":"symbol","symbolKind":"class","externalID":"s:10GLibObject7ClosureC","navigatorTitle":[{"text":"Closure","kind":"identifier"}],"modules":[{"name":"GLibObject"}],"roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Closure"}],"title":"Closure"},"abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" represents a callback supplied by the programmer."}],"topicSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-3dal7","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-3g7pp","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-3sg1w","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/init(_:)-6iibg","doc:\