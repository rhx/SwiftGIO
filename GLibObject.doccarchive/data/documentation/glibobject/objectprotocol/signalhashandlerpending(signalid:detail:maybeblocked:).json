{"abstract":[{"text":"Returns whether there are any handlers connected to ","type":"text"},{"code":"instance","type":"codeVoice"},{"text":" for the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"given signal id and detail."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/objectprotocol\/signalhashandlerpending(signalid:detail:maybeblocked:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"signalHasHandlerPending"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"signalID"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"detail","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@T@GQuark","kind":"typeIdentifier","text":"GQuark"},{"kind":"text","text":", "},{"kind":"externalParam","text":"mayBeBlocked"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"detail","type":"codeVoice"},{"type":"text","text":" is 0 then it will only match handlers that were connected"},{"text":" ","type":"text"},{"text":"without detail.  If ","type":"text"},{"type":"codeVoice","code":"detail"},{"text":" is non-zero then it will match handlers","type":"text"},{"type":"text","text":" "},{"type":"text","text":"connected both without detail and with the given detail.  This is"},{"text":" ","type":"text"},{"type":"text","text":"consistent with how a signal emitted with "},{"type":"codeVoice","code":"detail"},{"type":"text","text":" would be delivered"},{"