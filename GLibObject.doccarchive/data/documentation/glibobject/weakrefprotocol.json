{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"symbolKind":"protocol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"WeakRefProtocol","kind":"identifier"}],"title":"WeakRefProtocol","modules":[{"name":"GLibObject"}],"roleHeading":"Protocol","externalID":"s:10GLibObject15WeakRefProtocolP","navigatorTitle":[{"text":"WeakRefProtocol","kind":"identifier"}],"role":"symbol"},"topicSections":[{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/clear()","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/get()","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/init_(object:)-4v5ku","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/init_(object:)-56kyl","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/set(object:)-3cppk","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/set(object:)-94gtr"],"anchor":"Instance-Methods","generated":true,"title":"Instance Methods"}],"relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP"],"type":"inheritsFrom","title":"Inherits From","kind":"relationships"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef"],"type":"conformingTypes","kind":"relationships","title":"Conforming Types"}],"sections":[],"abstract":[{"text":"A structure containing a weak reference to a ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"WeakRefProtocol"},{"text":" : ","kind":"text"},{"text":"PointerWrapper","kind":"typeIdentifier","preciseIdentifier":"s:4GLib14PointerWrapperP"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GWeakRef"},{"type":"text","text":" can either be empty (i.e. point to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"), or point to an"},{"type":"text","text":" "},{"text":"object for as long as at least one “strong” reference to that object","type":"text"},{"type":"text","text":" "},{"type":"text","text":"exists. Before the object’s "},{"type":"codeVoice","code":"GObjectClass.dispose"},{"type":"text","text":" method is called,"},{"type":"text","text":" "},{"type":"text","text":"every "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","isActive":true},{"text":" associated with becomes empty (i.e. points to ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"text":"Like ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference","isActive":true},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef"},{"type":"text","text":" can be statically allocated, stack- or"},{"text":" ","type":"text"},{"type":"text","text":"heap-allocated, or embedded in larger structures."}]},{"inlineContent":[{"text":"Unlike ","type":"text"},{"type":"codeVoice","code":"g_object_weak_ref()"},{"text":" and ","type":"text"},{"code":"g_object_add_weak_pointer()","type":"codeVoice"},{"type":"text","text":", this weak"},{"type":"text","text":" "},{"type":"text","text":"reference is thread-safe: converting a weak pointer to a reference is"},{"type":"text","text":" "},{"type":"text","text":"atomic with respect to invalidation of weak pointers to destroyed"},{"text":" ","type":"text"},{"type":"text","text":"objects."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the object’s "},{"code":"GObjectClass.dispose","type":"codeVoice"},{"text":" method results in additional","type":"text"},{"type":"text","text":" "},{"type":"text","text":"references to the object being held (‘re-referencing’), any "},{"code":"GWeakRefs","type":"codeVoice"},{"type":"text","text":" taken"},{"type":"text","text":" "},{"text":"before it was disposed will continue to point to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".  Any ","type":"text"},{"code":"GWeakRefs","type":"codeVoice"},{"type":"text","text":" taken"},{"type":"text","text":" "},{"type":"text","text":"during disposal and after re-referencing, or after disposal has returned due"},{"type":"text","text":" "},{"type":"text","text":"to the re-referencing, will continue to point to the object until its refcount"},{"text":" ","type":"text"},{"type":"text","text":"goes back to zero, at which point they too will be invalidated."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is invalid to take a "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","type":"reference","isActive":true},{"type":"text","text":" on an object during "},{"type":"codeVoice","code":"GObjectClass.dispose"},{"type":"text","text":" "},{"type":"text","text":"without first having or creating a strong reference to the object."}]},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol","type":"reference"},{"type":"text","text":" protocol exposes the methods and properties of an underlying "},{"code":"GWeakRef","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"The default implementation of these can be found in the protocol extension below.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"For a concrete class that implements these methods and properties, see "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRef","type":"reference","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, use "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefRef","isActive":true,"type":"reference"},{"text":" as a lighweight, ","type":"text"},{"code":"unowned","type":"codeVoice"},{"type":"text","text":" reference if you already have an instance you just want to use."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/glibobject\/weakrefprotocol"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol","interfaceLanguage":"swift"},"references":{"doc://GLibObject/documentation/GLibObject/WeakRefProtocol/set(object:)-94gtr":{"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol\/set(object:)-94gtr","url":"\/documentation\/glibobject\/weakrefprotocol\/set(object:)-94gtr","type":"topic","title":"set(object:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"set","kind":"identifier"},{"kind":"text","text":"("},{"text":"object","kind":"externalParam"},{"kind":"text","text":": "},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"kind":"text","text":"?)"}],"abstract":[{"type":"text","text":"Change the object to which "},{"code":"weakRef","type":"codeVoice"},{"type":"text","text":" points, or set it to"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]},"doc://GLibObject/documentation/GLibObject/WeakRefProtocol":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/WeakRefProtocol","abstract":[{"type":"text","text":"A structure containing a weak reference to a "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":"."