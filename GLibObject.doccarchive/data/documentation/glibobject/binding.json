{"abstract":[{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instance (or source) and another property on another "},{"code":"GObject","type":"codeVoice"},{"type":"text","text":" "},{"text":"instance (or target).","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Object"]},{"title":"Conforms To","kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Binding","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Whenever the source property changes, the same value is applied to the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"target property; for instance, the following binding:"}]},{"type":"codeListing","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_DEFAULT);"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"will cause the property named “property-b” of "},{"code":"object2","type":"codeVoice"},{"text":" to be updated","type":"text"},{"type":"text","text":" "},{"type":"text","text":"every time [method"},{"code":"GObject.set","type":"codeVoice"},{"text":"] or the specific accessor changes the value of","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the property “property-a” of "},{"type":"codeVoice","code":"object1"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"It is possible to create a bidirectional binding between two properties"},{"type":"text","text":" "},{"type":"text","text":"of two "},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" instances, so that if either property changes, the"},{"text":" ","type":"text"},{"text":"other is updated as well, for instance:","type":"text"}],"type":"paragraph"},{"syntax":"c","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_BIDIRECTIONAL);"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"will keep the two properties in sync."}]},{"type":"paragraph","inlineContent":[{"text":"It is also possible to set a custom transformation function (in both","type":"text"},{"type":"text","text":" "},{"type":"text","text":"directions, in case of a bidirectional binding) to apply a custom"},{"text":" ","type":"text"},{"text":"transformation from the source value to the target value before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"applying it; for instance, the following binding:"}]},{"type":"codeListing","code":["  g_object_bind_property_full (adjustment1, \"value\",","                               adjustment2, \"value\",","                               G_BINDING_BIDIRECTIONAL,","                               celsius_to_fahrenheit,","                               fahrenheit_to_celsius,","                               NULL, NULL);"],"syntax":"c"},{"inlineContent":[{"type":"text","text":"will keep the “value” property of the two adjustments in sync; the"},{"type":"text","text":" "},{"code":"celsius_to_fahrenheit","type":"codeVoice"},{"type":"text","text":" function will be called whenever the “value”"},{"type":"text","text":" "},{"type":"text","text":"property of "},{"type":"codeVoice","code":"adjustment1"},{"text":" changes and will transform the current value","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of the property before applying it to the “value” property of "},{"type":"codeVoice","code":"adjustment2"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Vice versa, the "},{"code":"fahrenheit_to_celsius","type":"codeVoice"},{"text":" function will be called whenever","type":"text"},{"type":"text","text":" "},{"text":"the “value” property of ","type":"text"},{"code":"adjustment2","type":"codeVoice"},{"type":"text","text":" changes, and will transform the"},{"type":"text","text":" "},{"type":"text","text":"current value of the property before applying it to the “value” property"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"code":"adjustment1","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true,"type":"reference"},{"type":"text","text":" does not resolve cycles by itself; a cycle like"}]},{"syntax":null,"code":["  object1:propertyA -> object2:propertyB","  object2:propertyB -> object3:propertyC","  object3:propertyC -> object1:propertyA"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"might lead to an infinite loop. The loop, in this particular case,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be avoided if the objects emit the "},{"code":"GObject","type":"codeVoice"},{"type":"text","text":"notify"},{"type":"codeVoice","code":" signal only if the value has effectively been changed. A binding is implemented using the `GObject`notify"},{"type":"text","text":" signal, so it is susceptible to all the"},{"text":" ","type":"text"},{"text":"various ways of blocking a signal emission, like [func","type":"text"},{"type":"codeVoice","code":"GObject.signal_stop_emission"},{"type":"text","text":"]"},{"text":" ","type":"text"},{"type":"text","text":"or [func"},{"code":"GObject.signal_handler_block","type":"codeVoice"},{"text":"].","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A binding will be severed, and the resources it allocates freed, whenever"},{"type":"text","text":" "},{"type":"text","text":"either one of the "},{"code":"GObject","type":"codeVoice"},{"text":" instances it refers to are finalized, or when","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},{"type":"text","text":" instance loses its last reference."}]},{"inlineContent":[{"text":"Bindings for languages with garbage collection can use","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.Binding.unbind"},{"text":"] to explicitly release a binding between the source","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and target properties, instead of relying on the last reference on the"},{"type":"text","text":" "},{"text":"binding, source, and target instances to drop.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" type acts as a reference-counted owner of an underlying "},{"code":"GBinding","type":"codeVoice"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"text":"It provides the methods that can operate on this data type through ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","isActive":true,"type":"reference"},{"text":" conformance.","type":"text"},{"type":"text","text":" "},{"text":"Use ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true,"type":"reference"},{"type":"text","text":" as a strong reference or owner of a "},{"type":"codeVoice","code":"GBinding"},{"type":"text","text":" instance."}]},{"content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef"},{"type":"text","text":" (instead of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},{"type":"text","text":") for a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GBinding"},{"type":"text","text":" instance."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"metadata":{"title":"Binding","navigatorTitle":[{"text":"Binding","kind":"identifier"}],"role":"symbol","symbolKind":"class","modules":[{"name":"GLibObject"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Binding","kind":"identifier"}],"externalID":"s:10GLibObject7BindingC","roleHeading":"Class"},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-2gjer","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-6ihlv","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-9ejwo","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(_:)-c2ks","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(binding:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(opaquePointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(raw:)-6d9mu","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/init(raw:)-8xm6p","doc:\/\/GLibObject\/documentation\/GLibObject\/Binding\/i