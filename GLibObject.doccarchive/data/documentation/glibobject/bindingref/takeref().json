{"kind":"symbol","metadata":{"symbolKind":"method","roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"extendedModule":"GLibObject","title":"takeRef()","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject10BindingRefV","role":"symbol"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/takeRef()"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"If ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef"},{"kind":"text","text":"!"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"In other words, this function will convert a floating reference (if","type":"text"},{"type":"text","text":" "},{"type":"text","text":"present) into a full reference."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" in order to"},{"type":"text","text":" "},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"type":"text","text":" "},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"text":" ","type":"text"},{"type":"text","text":"this function is helpful."}]},{"inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"text":"that allows the user to provide a callback function that returns a","type":"text"},{"text":" ","type":"text"},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"text":"where the object that is being returned already exists).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"text":" ","type":"text"},{"type":"text","text":"libraries (such as Gtk) make it likely that for newly-created GObject"},{"text":" ","type":"text"},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"text":" ","type":"text"},{"text":"return a floating reference.","type":"text"}]},{"inlineContent":[{"text":"Using this function on the return value of the user’s callback allows","type":"text"},{"type":"text","text":" "},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"always receives exactly one full reference to the value: either the"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"type":"text","text":"that has been converted to a full reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"This function has an odd interaction when combined with","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"text":" ","type":"text"},{"text":"the same ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference","isActive":true},{"type":"text","text":" instance. If "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" runs first then","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"text":" ","type":"text"},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will be"},{"text":" ","type":"text"},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"type":"text","text":" "},{"text":"additional reference on top of that one is added. It is best to avoid","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this situation."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindingref\/takeref()"]}],"references":{"doc://GLibObject/documentation/GLibObject/BindingRef":{"title":"BindingRef","type":"topic","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","url":"\/documentation\/glibobject\/bindingref","kind":"symbol","abstract":[{"type":"codeVoice","code":"GObject"},{"text":" instance (or source) and another property on another ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" "},{"text":"instance (or target).","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"BindingRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BindingRef","kind":"identifier"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/BindingRef/takeRef()":{"title":"takeRef()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/takeRef()","type":"topic","role":"symbol","kind":"symbol","url":"\/documentation\/glibobject\/bindingref\/takeref()","abstract":[{"type":"text","text":"If "},{"code":"object","type":"codeVoice"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}]},"doc://GLibObject/documentation/GLibObject/Object":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"title":"Object","kind":"symbol","abstract":[{"text":"The base object type.","type":"text"}],"url":"\/documentation\/glibobject\/object","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/BindingRef/ObjectProtocol-Implementations":{"type":"topic","abstract":[],"url":"\/documentation\/glibobject\/bindingref\/objectprotocol-implementations","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"text":"The base object type.","type":"text"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","kind":"symbol","role":"symbol"}}}