{"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"code":"object","type":"codeVoice"},{"text":" to a proxy","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" and a reverse reference to the proxy"},{"text":" ","type":"text"},{"text":"object which is either a strong reference or weak reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"type":"codeVoice","code":"object"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"code":"object","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"to the proxy object, but when there are other references held to"},{"text":" ","type":"text"},{"code":"object","type":"codeVoice"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"text":" ","type":"text"},{"type":"text","text":"when the reference from "},{"code":"object","type":"codeVoice"},{"text":" to the proxy object should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"is_last_ref"},{"text":" false).","type":"text"}]},{"inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":", the initial state of the reverse","type":"text"},{"text":" ","type":"text"},{"text":"link is always strong.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"text":" ","type":"text"},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"type":"text","text":" "},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"text":"is important state in the proxy object.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"type":"text","text":" "},{"type":"text","text":"still be invoked after "},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"text":", and the object argument","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"type":"text","text":" must be released with "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)"]}],"metadata":{"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject10BindingRefV","roleHeading":"Instance Method","title":"addToggleRef(notify:data:)","extendedModule":"GLibObject","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"role":"symbol","modules":[{"name":"GLibObject"}]},"kind":"symbol","references":{"doc://GLibObject/documentation/GLibObject/BindingRef":{"title":"BindingRef","type":"topic","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","url":"\/documentation\/glibobject\/bindingref","kind":"symbol","abstract":[{"type":"codeVoice","code":"GObject"},{"text":" instance (or source) and another property on another ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":" "},{"text":"instance (or target).","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"BindingRef"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"BindingRef","kind":"identifier"}]},"doc://GLibObject/documentation/GLibObject/BindingRef/ObjectProtocol-Implementations":{"type":"topic","abstract":[],"url":"\/documentation\/glibobject\/bindingref\/objectprotocol-implementations","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","kind":"article","title":"ObjectProtocol Implementations","role":"collectionGroup"},"doc://GLibObject/documentation/GLibObject/BindingRef/addToggleRef(notify:data:)":{"type":"topic","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"url":"\/documentation\/glibobject\/bindingref\/addtoggleref(notify:data:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"text":"GToggleNotify","kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}],"kind":"symbol","title":"addToggleRef(notify:data:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/addToggleRef(notify:data:)","role":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"}}}