{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/onNotifyTarget(flags:handler:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"The notify signal is emitted on an object when one of its properties has"},{"type":"text","text":" "},{"type":"text","text":"its value set through "},{"type":"codeVoice","code":"g_object_set_property()"},{"type":"text","text":", "},{"type":"codeVoice","code":"g_object_set()"},{"type":"text","text":", et al."}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/signalgroupref\/onnotifytarget(flags:handler:)"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@discardableResult","kind":"attribute"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"onNotifyTarget","kind":"identifier"},{"kind":"text","text":"("},{"text":"flags","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ConnectFlags","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ConnectFlagsV","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ConnectFlags"},{"text":" = ConnectFlags(0), ","kind":"text"},{"text":"handler","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"preciseIdentifier":"s:10GLibObject14SignalGroupRefV","text":"SignalGroupRef","kind":"typeIdentifier","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef"},{"kind":"text","text":", "},{"text":"ParamSpecRef","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ParamSpecRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12ParamSpecRefV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s: