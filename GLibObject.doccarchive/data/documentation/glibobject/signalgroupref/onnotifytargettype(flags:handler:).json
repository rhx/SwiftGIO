xt_view_target_list_notify),","                  text_view)"]},{"inlineContent":[{"text":"It is important to note that you must use","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"#class@GObject.ParamSpec#parameter-names","isActive":true},{"text":" as","type":"text"},{"type":"text","text":" "},{"text":"detail strings for the notify signal.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This represents the underlying "},{"code":"notify::target-type","type":"codeVoice"},{"type":"text","text":" signal"}]}],"type":"aside","name":"Note","style":"note"}]}],"references":{"#class@GObject.ParamSpec#parameter-names":{"identifier":"#class@GObject.ParamSpec#parameter-names","title":"canonical parameter names","url":"#class@GObject.ParamSpec#parameter-names","type":"link","titleInlineContent":[{"text":"canonical parameter names","type":"text"}]},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/SignalGroupProtocol-Implementations":{"kind":"article","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/SignalGroupProtocol-Implementations","title":"SignalGroupProtocol Implementations","role":"collectionGroup","abstract":[],"url":"\/documentation\/glibobject\/signalgroupref\/signalgroupprotocol-implementations"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SignalGroupRef"}],"url":"\/documentation\/glibobject\/signalgroupref","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SignalGroupRef"}],"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","title":"SignalGroupRef","type":"topic","abstract":[{"code":"GSignalGroup","type":"codeVoice"},{"text":" manages a collection of signals on a ","type":"text"},{"type":"codeVoice","code":"GObject"},{"text":".","type":"text"}]},"doc://GLibOb