{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/signalgroupref\/takeref()"]}],"sections":[],"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()"},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations"]]},"metadata":{"roleHeading":"Instance Method","title":"takeRef()","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"text":"!","kind":"text"}],"externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject14SignalGroupRefV","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef"},{"text":"!","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"In other words, this function will convert a floating reference (if","type":"text"},{"type":"text","text":" "},{"text":"present) into a full reference.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Typically you want to use "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" in order to"},{"type":"text","text":" "},{"type":"text","text":"automatically do the correct thing with respect to floating or"},{"type":"text","text":" "},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"type":"text","text":" "},{"type":"text","text":"this function is helpful."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The situation where this function is helpful is when creating an API","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"type":"text","text":" "},{"type":"text","text":"where the object that is being returned already exists)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"At the same time, the API style of some popular GObject-based"},{"text":" ","type":"text"},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"text":" ","type":"text"},{"text":"return a floating reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"type":"text","text":" "},{"type":"text","text":"the user to do whichever is more convenient for them. The caller will"},{"type":"text","text":" "},{"type":"text","text":"always receives exactly one full reference to the value: either the"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"text":" ","type":"text"},{"text":"that has been converted to a full reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"text":" running at the same time in another thread on","type":"text"},{"type":"text","text":" "},{"text":"the same ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" instance. If ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" runs first then"},{"type":"text","text":" "},{"text":"the result will be that the floating reference is converted to a hard","type":"text"},{"type":"text","text":" "},{"text":"reference. If ","type":"text"},{"code":"g_object_take_ref()","type":"codeVoice"},{"text":" runs first then the result will be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"that the floating reference is converted to a hard reference and an"},{"type":"text","text":" "},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"type":"text","text":" "},{"type":"text","text":"this situation."}],"type":"paragraph"}]}],"references":{"doc://GLibObject/documentation/GLibObject/SignalGroupRef/takeRef()":{"role":"symbol","abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"type":"topic","kind":"symbol","title":"takeRef()","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/takeRef()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"text":"!","kind":"text"}],"url":"\/documentation\/glibobject\/signalgroupref\/takeref()"},"doc://GLibObject/documentation/GLibObject/Object":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"title":"Object","kind":"symbol","abstract":[{"text":"The base object type.","type":"text"}],"url":"\/documentation\/glibobject\/object","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef/ObjectProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef\/ObjectProtocol-Implementations","abstract":[],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/glibobject\/signalgroupref\/objectprotocol-implementations","title":"ObjectProtocol Implementations"},"doc://GLibObject/documentation/GLibObject/SignalGroupRef":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"SignalGroupRef"}],"url":"\/documentation\/glibobject\/signalgroupref","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"SignalGroupRef"}],"role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/SignalGroupRef","title":"SignalGroupRef","type":"topic","abstract":[{"code":"GSignalGroup","type":"codeVoice"},{"text":" manages a collection of signals on a ","type":"text"},{"type":"codeVoice","code":"GObject"},{"text":".","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"text":"The base object type.","type":"text"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","kind":"symbol","role":"symbol"}}}