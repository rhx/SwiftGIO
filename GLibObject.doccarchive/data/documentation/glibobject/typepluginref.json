{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","relationshipsSections":[{"identifiers":["doc:\/\/GLibObject\/4GLib14PointerWrapperP","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"abstract":[{"type":"text","text":"An interface that handles the lifecycle of dynamically loaded types."}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-2mf3j","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-47vjm","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-5hv9g","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-75qw1","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(_:)-9532m","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(opaquePointer:)"],"title":"Initializers","generated":true},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/ptr"],"anchor":"Instance-Properties","generated":true,"title":"Instance Properties"},{"generated":true,"anchor":"Default-Implementations","title":"Default Implementations","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/PointerWrapper-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/TypePluginProtocol-Implementations"]}],"metadata":{"externalID":"s:10GLibObject13TypePluginRefV","symbolKind":"struct","roleHeading":"Structure","role":"symbol","modules":[{"name":"GLibObject"}],"title":"TypePluginRef","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypePluginRef","kind":"identifier"}],"navigatorTitle":[{"text":"TypePluginRef","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypePluginRef"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"The GObject type system supports dynamic loading of types.","type":"text"},{"type":"text","text":" "},{"text":"It goes as follows:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"text":"The type is initially introduced (usually upon loading the module","type":"text"},{"type":"text","text":" "},{"text":"the first time, or by your main application that knows what modules","type":"text"},{"text":" ","type":"text"},{"text":"introduces what types), like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"c","code":["new_type_id = g_type_register_dynamic (parent_type_id,","                                       \"TypeName\",","                                       new_type_plugin,","                                       type_flags);"]},{"inlineContent":[{"type":"text","text":"where "},{"type":"codeVoice","code":"new_type_plugin"},{"type":"text","text":" is an implementation of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" interface.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The type’s implementation is referenced, e.g. through","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[func"},{"type":"codeVoice","code":"GObject.TypeClass.ref"},{"text":"] or through [func","type":"text"},{"code":"GObject.type_create_instance","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"(this is being called by [ctor","type":"text"},{"type":"codeVoice","code":"GObject.Object.new"},{"text":"]) or through one of the above","type":"text"},{"type":"text","text":" "},{"text":"done on a type derived from ","type":"text"},{"code":"new_type_id","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes the type system to load the type’s implementation by calling"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"type":"text","text":"] and [method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"on ","type":"text"},{"type":"codeVoice","code":"new_type_plugin"},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"At some point the type’s implementation isn’t required anymore, e.g. after"},{"text":" ","type":"text"},{"text":"[method","type":"text"},{"code":"GObject.TypeClass.unref","type":"codeVoice"},{"text":"] or [func","type":"text"},{"type":"codeVoice","code":"GObject.type_free_instance"},{"type":"text","text":"]"},{"type":"text","text":" "},{"type":"text","text":"(called when the reference count of an instance drops to zero)."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"This causes the type system to throw away the information retrieved","type":"text"},{"type":"text","text":" "},{"text":"from [method","type":"text"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"] and then it calls","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.unuse"},{"type":"text","text":"] on "},{"type":"codeVoice","code":"new_type_plugin"},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"text":"Things may repeat from the second step.","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"So basically, you need to implement a "},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" type that"},{"type":"text","text":" "},{"type":"text","text":"carries a use_count, once use_count goes from zero to one, you need"},{"type":"text","text":" "},{"type":"text","text":"to load the implementation to successfully handle the upcoming"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"type":"codeVoice","code":"GObject.TypePlugin.complete_type_info"},{"text":"] call. Later, maybe after","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"succeeding use\/unuse calls, once use_count drops to zero, you can"},{"text":" ","type":"text"},{"text":"unload the implementation again. The type system makes sure to call","type":"text"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.TypePlugin.use","type":"codeVoice"},{"text":"] and [method","type":"text"},{"code":"GObject.TypePlugin.complete_type_info","type":"codeVoice"},{"text":"]","type":"text"},{"text":" ","type":"text"},{"text":"again when the type is needed again.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"[class","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModule"},{"text":"] is an implementation of ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"type":"text","text":" that"},{"type":"text","text":" "},{"type":"text","text":"already implements most of this except for the actual module loading and"},{"text":" ","type":"text"},{"type":"text","text":"unloading. It even handles multiple registered types per module."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true,"type":"reference"},{"type":"text","text":" type acts as a lightweight Swift reference to an underlying "},{"type":"codeVoice","code":"GTypePlugin"},{"text":" instance.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginProtocol","isActive":true,"type":"reference"},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"code":"GTypePlugin","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePlugin"},{"type":"text","text":" (instead of "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef","isActive":true},{"type":"text","text":") if you want to use Automatic Reference Counting for memory management of the underlying "},{"code":"GTypePlugin","type":"codeVoice"},{"text":" instance.","type":"text"}],"type":"paragraph"}],"style":"note"}]}],"variants":[{"paths":["\/documentation\/glibobject\/typepluginref"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/TypePluginRef/init(mutating:)":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypePluginRef\/init(mutating:)","kind":"symbol","fragments":[{"kind":"identifier","text":"init"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"mutating"},{"text":