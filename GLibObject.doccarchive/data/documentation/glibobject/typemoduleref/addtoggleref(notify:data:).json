{"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations"]]},"kind":"symbol","identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Increases the reference count of the object by one and sets a"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"metadata":{"modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject13TypeModuleRefV","extendedModule":"GLibObject","role":"symbol","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","kind":"typeIdentifier","text":"GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"roleHeading":"Instance Method","title":"addToggleRef(notify:data:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"kind":"text","text":"? = nil)"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This functionality is intended for binding "},{"type":"codeVoice","code":"object"},{"text":" to a proxy","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"object managed by another memory manager. This is done with two"},{"text":" ","type":"text"},{"type":"text","text":"paired references: the strong reference added by"},{"type":"text","text":" "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":" and a reverse reference to the proxy"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}]},{"inlineContent":[{"type":"text","text":"The setup is that when there are no other references to "},{"type":"codeVoice","code":"object"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"text":" callback is called","type":"text"},{"text":" ","type":"text"},{"text":"when the reference from ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" to the proxy object should be"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"text":" false).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Since a (normal) reference must be held to the object before","type":"text"},{"type":"text","text":" "},{"text":"calling ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"type":"text","text":", the initial state of the reverse"},{"type":"text","text":" "},{"text":"link is always strong.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"text":"however if there are multiple toggle references to an object, none","type":"text"},{"type":"text","text":" "},{"text":"of them will ever be notified until all but one are removed.  For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"this reason, you should only ever use a toggle reference if there"},{"type":"text","text":" "},{"text":"is important state in the proxy object.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"code":"notify","type":"codeVoice"},{"type":"text","text":" might"},{"text":" ","type":"text"},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":", and the object argument"},{"type":"text","text":" "},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"type":"text","text":" "},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":" must be released with ","type":"text"},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"type":"text","text":"."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)"]}],"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/TypeModuleRef/ObjectProtocol-Implementations":{"type":"topic","url":"\/documentation\/glibobject\/typemoduleref\/objectprotocol-implementations","abstract":[],"kind":"article","role":"collectionGroup","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef/addToggleRef(notify:data:)":{"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"kind":"text","text":"?)"}],"kind":"symbol","type":"topic","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"text":" ","type":"text"},{"type":"text","text":"and another reference is established."}],"url":"\/documentation\/glibobject\/typemoduleref\/addtoggleref(notify:data:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef\/addToggleRef(notify:data:)","title":"addToggleRef(notify:data:)"},"doc://GLibObject/documentation/GLibObject/TypeModuleRef":{"type":"topic","url":"\/documentation\/glibobject\/typemoduleref","abstract":[{"type":"codeVoice","code":"GTypeModule"},{"text":" provides a simple implementation of the ","type":"text"},{"code":"GTypePlugin","type":"codeVoice"},{"text":" ","type":"text"},{"text":"interface.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"TypeModuleRef"}],"navigatorTitle":[{"kind":"identifier","text":"TypeModuleRef"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeModuleRef","title":"TypeModuleRef"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"}}}