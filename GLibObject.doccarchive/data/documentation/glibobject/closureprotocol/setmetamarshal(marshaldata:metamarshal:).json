{"sections":[],"metadata":{"title":"setMetaMarshal(marshalData:metaMarshal:)","roleHeading":"Instance Method","externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"marshalData"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"?, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GClosureMarshal","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"kind":"text","text":")"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","text":"GClosureMarshal"},{"kind":"text","text":")"}]}]},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A meta marshaller wraps the "},{"code":"closure","type":"codeVoice"},{"type":"text","text":"’s marshal and modifies the way"},{"type":"text","text":" "},{"text":"it is called in some fashion. The most common use of this facility","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"is for C callbacks."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The same marshallers (generated by "},{"type":"reference","identifier":"#glib-genmarshal","isActive":true},{"text":"),","type":"text"},{"type":"text","text":" "},{"type":"text","text":"are used everywhere, but the way that we get the callback function"},{"text":" ","type":"text"},{"text":"differs. In most cases we want to use the ","type":"text"},{"type":"codeVoice","code":"closure"},{"text":"’s callback, but in","type":"text"},{"type":"text","text":" "},{"text":"other cases we want to use some different technique to retrieve the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"callback function."}]},{"inlineContent":[{"text":"For example, class closures for signals (see","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"g_signal_type_cclosure_new()"},{"type":"text","text":") retrieve the callback function from a"},{"text":" ","type":"text"},{"type":"text","text":"fixed offset in the class structure.  The meta marshaller retrieves"},{"text":" ","type":"text"},{"type":"text","text":"the right callback and passes it to the marshaller as the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"marshalData"},{"type":"text","text":" argument."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"]]},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closureprotocol\/setmetamarshal(marshaldata:metamarshal:)"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/setMetaMarshal(marshalData:metaMarshal:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"code":"closure","type":"codeVoice"},{"type":"text","text":"."}],"references":{"doc://GLibObject/documentation/GLibObject/ClosureProtocol":{"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"ClosureProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol","url":"\/documentation\/glibobject\/closureprotocol","navigatorTitle":[{"kind":"identifier","text":"ClosureProtocol"}],"kind":"symbol","abstract":[{"text":"A ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"type":"text","text":" represents a callback supplied by the programmer."}],"type":"topic","title":"ClosureProtocol","role":"symbol"},"#glib-genmarshal":{"identifier":"#glib-genmarshal","title":"glib-genmarshal","url":"#glib-genmarshal","type":"link","titleInlineContent":[{"text":"glib-genmarshal","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/ClosureProtocol/setMetaMarshal(marshalData:metaMarshal:)":{"title":"setMetaMarshal(marshalData:metaMarshal:)","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/setMetaMarshal(marshalData:metaMarshal:)","url":"\/documentation\/glibobject\/closureprotocol\/setmetamarshal(marshaldata:metamarshal:)","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"code":"closure","type":"codeVoice"},{"type":"text","text":"."}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setMetaMarshal"},{"kind":"text","text":"("},{"text":"marshalData","kind":"externalParam"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c: