{"abstract":[{"type":"text","text":"Takes over the initial ownership of a closure."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closureprotocol\/sink()"]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/sink()","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","title":"sink()","symbolKind":"method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sink"},{"kind":"text","text":"()"}],"externalID":"s:10GLibObject15ClosureProtocolPAAE4sinkyyF","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sink","kind":"identifier"},{"text":"()","kind":"text"}]}],"kind":"declarations"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each closure is initially created in a “floating” state, which means"},{"text":" ","type":"text"},{"type":"text","text":"that the initial reference count is not owned by any caller."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function checks to see if the object is still floating, and if so,"},{"type":"text","text":" "},{"text":"unsets the floating state and decreases the reference count. If the","type":"text"},{"type":"text","text":" "},{"text":"closure is not floating, ","type":"text"},{"type":"codeVoice","code":"g_closure_sink()"},{"text":" does nothing.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The reason for the existence of the floating state is to prevent"},{"type":"text","text":" "},{"type":"text","text":"cumbersome code sequences like:"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"code":["closure = g_cclosure_new (cb_func, cb_data);","g_source_set_closure (source, closure);","g_closure_unref (closure); \/\/ GObject doesn't really need this"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"type":"text","text":"Because "},{"code":"g_source_set_closure()","type":"codeVoice"},{"text":" (and similar functions) take ownership of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initial reference count, if it is unowned, we instead can write:"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"syntax":"C","code":["g_source_set_closure (source, g_cclosure_new (cb_func, cb_data));"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Generally, this function is used together with "},{"type":"codeVoice","code":"g_closure_ref()"},{"type":"text","text":". An example"},{"type":"text","text":" "},{"text":"of storing a closure for later notification looks like:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"code":["static GClosure *notify_closure = NULL;","void","foo_notify_set_closure (GClosure *closure)","{","  if (notify_closure)","    g_closure_unref (notify_closure);","  notify_closure = closure;","  if (notify_closure)","    {","      g_closure_ref (notify_closure);","      g_closure_sink (notify_closure);","    }","}"],"type":"codeListing","syntax":"C"},{"inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"g_closure_sink()"},{"type":"text","text":" may decrement the reference count of a closure"},{"type":"text","text":" "},{"text":"(if it hasn’t been called on ","type":"text"},{"type":"codeVoice","code":"closure"},{"type":"text","text":" yet) just like "},{"code":"g_closure_unref()","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_closure_ref()"},{"text":" should be called prior to this function.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol"]]},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/ClosureProtocol/sink()":{"type":"topic","url":"\/documentation\/glibobject\/closureprotocol\/sink()","title":"sink()","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol\/sink()","abstract":[{"text":"Takes over the initial ownership of a closure.","type":"text"}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sink"},{"kind":"text","text":"()"}],"kind":"symbol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/ClosureProtocol":{"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"ClosureProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureProtocol","url":"\/documentation\/glibobject\/closureprotocol","navigatorTitle":[{"kind":"identifier","text":"ClosureProtocol"}],"kind":"symbol","abstract":[{"text":"A ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"type":"text","text":" represents a callback supplied by the programmer."}],"type":"topic","title":"ClosureProtocol","role":"symbol"}}}