s:Sp"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:Sp","text":"UnsafeMutablePointer","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"GParamSpec","kind":"typeIdentifier"},{"kind":"text","text":">?>!)"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"All properties should be installed during the class initializer.  It"},{"type":"text","text":" "},{"type":"text","text":"is possible to install properties after that, but doing so is not"},{"text":" ","type":"text"},{"type":"text","text":"recommend, and specifically, is not guaranteed to be thread-safe vs."},{"text":" ","type":"text"},{"type":"text","text":"use of properties on the same type on other threads."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The property id of each property is the index of each "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ParamSpec","isActive":true,"type":"reference"},{"type":"text","text":" in"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"code":"pspecs","type":"codeVoice"},{"text":" array.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The property id of 0 is treated specially by ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object"},{"type":"text","text":" and it should not"},{"text":" ","type":"text"},{"type":"text","text":"be used to store a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ParamSpec"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This function should be used if you plan to use a static array of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"GParamSpecs"},{"type":"text","text":" and "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":". For instance, this"},{"type":"text","text":" "},{"type":"text","text":"class initialization:"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["typedef enum {","  PROP_FOO = 1,","  PROP_BAR,","  N_PROPERTIES","} MyObjectProperty;","","static GParamSpec *obj_properties[N_PROPERTIES] = { NULL, };","","static void","my_object_class_init (MyObjectClass *klass)","{","  GObjectClass *gobject_class = G_OBJECT_CLASS (klass);","","  obj_properties[PROP_FOO] =","    g_param_spec_int (\"foo\", NULL, NULL,","                      -1, G_MAXINT,","                      0,","                      G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS);","","  obj_properties[PROP_BAR] =","    g_param_spec_string (\"bar\", NULL, NULL,","                         NULL,","                         G_PARAM_READWRITE | G_PARAM_STATIC_STRINGS);","","  gobject_class->set_property = my_object_set_property;","  gobject_class->get_property = my_object_get_property;","  g_object_class_install_properties (gobject_class,","                                     G_N_ELEMENTS (obj_properties),","                                     obj_properties);","}"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"allows calling "},{"type":"codeVoice","code":"g_object_notify_by_pspec()"},{"type":"text","text":" to notify of property changes:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"syntax":"C","type":"codeListing","code":["void","my_object_set_foo (MyObject *self, gint foo)","{","  if (self->foo != foo)","    {","      self->foo = foo;","      g_object_notify_by_pspec (G_OBJECT (self), obj_properties[PROP_FOO]);","    }"," }"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectClassRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectClassRef\/ObjectClassProtocol-Implementations"]]},"kind":