{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"sink"},{"text":"()","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each closure is initially created in a “floating” state, which means"},{"type":"text","text":" "},{"text":"that the initial reference count is not owned by any caller.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function checks to see if the object is still floating, and if so,"},{"text":" ","type":"text"},{"text":"unsets the floating state and decreases the reference count. If the","type":"text"},{"type":"text","text":" "},{"text":"closure is not floating, ","type":"text"},{"type":"codeVoice","code":"g_closure_sink()"},{"text":" does nothing.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The reason for the existence of the floating state is to prevent"},{"type":"text","text":" "},{"type":"text","text":"cumbersome code sequences like:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["closure = g_cclosure_new (cb_func, cb_data);","g_source_set_closure (source, closure);","g_closure_unref (closure); \/\/ GObject doesn't really need this"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because "},{"type":"codeVoice","code":"g_source_set_closure()"},{"type":"text","text":" (and similar functions) take ownership of the"},{"text":" ","type":"text"},{"type":"text","text":"initial reference count, if it is unowned, we instead can write:"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["g_source_set_closure (source, g_cclosure_new (cb_func, cb_data));"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"text":"Generally, this function is used together with ","type":"text"},{"type":"codeVoice","code":"g_closure_ref()"},{"type":"text","text":". An example"},{"type":"text","text":" "},{"type":"text","text":"of storing a closure for later notification looks like:"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"type":"codeListing","syntax":"C","code":["static GClosure *notify_closure = NULL;","void","foo_notify_set_closure (GClosure *closure)","{","  if (notify_closure)","    g_closure_unref (notify_closure);","  notify_closure = closure;","  if (notify_closure)","    {","      g_closure_ref (notify_closure);","      g_closure_sink (notify_closure);","    }","}"]},{"inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"g_closure_sink()"},{"type":"text","text":" may decrement the reference count of a closure"},{"text":" ","type":"text"},{"text":"(if it hasn’t been called on ","type":"text"},{"type":"codeVoice","code":"closure"},{"type":"text","text":" yet) just like "},{"code":"g_closure_unref()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"codeVoice","code":"g_closure_ref()"},{"text":" should be called prior to this function.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/sink()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/closureref\/sink()"]}],"kind":"symbol","metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sink","kind":"identifier"},{"kind":"text","text":"()"}],"roleHeading":"Instance Method","extendedModule":"GLibObject","modules":[{"name":"GLibObject"}],"role":"symbol","externalID":"s:10GLibObject15ClosureProtocolPAAE4sinkyyF::SYNTHESIZED::s:10GLibObject10ClosureRefV","title":"sink()","symbolKind":"method"},"sections":[],"abstract":[{"type":"text","text":"Takes over the initial ownership of a closure."}],"references":{"doc://GLibObject/documentation/GLibObject/ClosureRef":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"ClosureRef","kind":"identifier"}],"role":"symbol","url":"\/documentation\/glibobject\/closureref","abstract":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"GClosure"},{"type":"text","text":" represents a callback supplied by the programmer."}],"title":"ClosureRef","navigatorTitle":[{"kind":"identifier","text":"ClosureRef"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject/ClosureRef/ClosureProtocol-Implementations":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/ClosureProtocol-Implementations","abstract":[],"role":"collectionGroup","type":"topic","kind":"article","url":"\/documentation\/glibobject\/closureref\/closureprotocol-implementations","title":"ClosureProtocol Implementations"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/ClosureRef/sink()":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/sink()","title":"sink()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sink"},{"kind":"text","text":"()"}],"abstract":[{"type":"text","text":"Takes over the initial ownership of a closure."}],"kind"