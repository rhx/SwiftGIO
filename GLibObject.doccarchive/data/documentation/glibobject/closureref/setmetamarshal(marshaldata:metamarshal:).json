{"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setMetaMarshal"},{"kind":"text","text":"("},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"? = nil, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","kind":"typeIdentifier","text":"GClosureMarshal"},{"kind":"text","text":")"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"A meta marshaller wraps the "},{"type":"codeVoice","code":"closure"},{"text":"’s marshal and modifies the way","type":"text"},{"type":"text","text":" "},{"text":"it is called in some fashion. The most common use of this facility","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is for C callbacks."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The same marshallers (generated by ","type":"text"},{"isActive":true,"type":"reference","identifier":"#glib-genmarshal"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"text":"are used everywhere, but the way that we get the callback function","type":"text"},{"text":" ","type":"text"},{"text":"differs. In most cases we want to use the ","type":"text"},{"code":"closure","type":"codeVoice"},{"text":"’s callback, but in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"other cases we want to use some different technique to retrieve the"},{"text":" ","type":"text"},{"type":"text","text":"callback function."}]},{"type":"paragraph","inlineContent":[{"text":"For example, class closures for signals (see","type":"text"},{"type":"text","text":" "},{"code":"g_signal_type_cclosure_new()","type":"codeVoice"},{"type":"text","text":") retrieve the callback function from a"},{"text":" ","type":"text"},{"text":"fixed offset in the class structure.  The meta marshaller retrieves","type":"text"},{"text":" ","type":"text"},{"text":"the right callback and passes it to the marshaller as the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"marshalData"},{"type":"text","text":" argument."}]}]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"text":"GClosureMarshal","kind":"typeIdentifier","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"text":")","kind":"text"}],"title":"setMetaMarshal(marshalData:metaMarshal:)","symbolKind":"method","role":"symbol","externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF::SYNTHESIZED::s:10GLibObject10ClosureRefV","modules":[{"name":"GLibObject"}],"roleHeading":"Instance Method","extendedModule":"GLibObject"},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureRef\/setMetaMarshal(marshalData:metaMarshal:)"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"type":"codeVoice","code":"closure"},{"text":".","type":"text"}],"variants":[{"paths":["\/documentation\/glibobject\/closureref\/setmetamarshal(marshaldata:metamarshal:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/ClosureR