BindingRef","text":"BindingRef","kind":"typeIdentifier"},{"kind":"text","text":"! "},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObjectT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B8ProtocolP","text":"ObjectProtocol"}]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Whenever the ","type":"text"},{"type":"codeVoice","code":"sourceProperty"},{"type":"text","text":" is changed the "},{"type":"codeVoice","code":"targetProperty"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"updated using the same value. For instance:","type":"text"}]},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"]},{"inlineContent":[{"type":"text","text":"Will result in the “sensitive” property of the widget "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" instance to be","type":"text"},{"type":"text","text":" "},{"text":"updated with the same value of the “active” property of the action ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true,"type":"reference"},{"type":"text","text":" "},{"text":"instance.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"flags"},{"text":" contains ","type":"text"},{"type":"codeVoice","code":"bidirectional"},{"type":"text","text":" then the binding will be mutual:"},{"type":"text","text":" "},{"text":"if ","type":"text"},{"code":"targetProperty","type":"codeVoice"},{"type":"text","text":" on "},{"code":"target","type":"codeVoice"},{"type":"text","text":" changes then the "},{"code":"sourceProperty","type":"codeVoice"},{"text":" on ","type":"text"},{"code":"source","type":"codeVoice"},{"text":" ","type":"text"},{"text":"will be updated as well.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The binding will automatically be removed when either the "},{"type":"codeVoice","code":"source"},{"text":" or the","type":"text"},{"text":" ","type":"text"},{"code":"target","type":"codeVoice"},{"type":"text","text":" instances are finalized. To remove the binding without affecting the"},{"type":"text","text":" "},{"type":"codeVoice","code":"source"},{"type":"text","text":" and the "},{"type":"codeVoice","code":"target"},{"type":"text","text":" you can just call "},{"code":"g_object_unref()","type":"codeVoice"},{"type":"text","text":" on the returned"},{"type":"text","text":" "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","type":"reference","isActive":true},{"type":"text","text":" instance."}],"type":"paragraph"},{"inlineContent":[{"text":"Removing the binding by calling ","type":"text"},{"code":"g_object_unref()","type":"codeVoice"},{"text":" on it must only be done if","type":"text"},{"text":" ","type":"text"},{"text":"the binding, ","type":"text"},{"code":"source","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"target"},{"text":" are only used from a single thread and it","type":"text"},{"text":" ","type":"text"},{"text":"is clear that both ","type":"text"},{"type":"codeVoice","code":"source"},{"type":"text","text":" and "},{"code":"target","type":"codeVoice"},{"text":" outlive the binding. Especially it","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is not safe to rely on this if the binding, "},{"type":"codeVoice","code":"source"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"target"},{"type":"text","text":" can be"},{"type":"text","text":" "},{"text":"finalized from different t