{"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"TypeValueCollectFunc"}],"title":"TypeValueCollectFunc","modules":[{"name":"GLibObject"}],"externalID":"s:10GLibObject20TypeValueCollectFunca","roleHeading":"Type Alias","navigatorTitle":[{"kind":"identifier","text":"TypeValueCollectFunc"}],"symbolKind":"typealias"},"variants":[{"paths":["\/documentation\/glibobject\/typevaluecollectfunc"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"abstract":[{"type":"text","text":"This function is responsible for converting the values collected from"},{"type":"text","text":" "},{"text":"a variadic argument list into contents suitable for storage in a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value"},{"text":".","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypeValueCollectFunc","kind":"identifier"},{"text":" = ","kind":"text"},{"text":"GTypeValueCollectFunc","kind":"typeIdentifier","preciseIdentifier":"c:@T@GTypeValueCollectFunc"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This function should setup "},{"type":"codeVoice","code":"value"},{"text":" similar to ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","isActive":true,"type":"reference"},{"text":"; e.g.","type":"text"},{"text":" ","type":"text"},{"text":"for a string value that does not allow ","type":"text"},{"type":"codeVoice","code":"NULL"},{"text":" pointers, it needs to either","type":"text"},{"text":" ","type":"text"},{"text":"emit an error, or do an implicit conversion by storing an empty string.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" passed in to this function has a zero-filled data array, so"},{"type":"text","text":" "},{"text":"just like for ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","type":"reference","isActive":true},{"text":" it is guaranteed to not contain any old","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"contents that might need freeing."}]},{"inlineContent":[{"type":"text","text":"The "},{"code":"nCollectValues","type":"codeVoice"},{"text":" argument is the string length of the ","type":"text"},{"code":"collect_format","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"field of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueTable"},{"type":"text","text":", and "},{"code":"collect_values","type":"codeVoice"},{"type":"text","text":" is an array of "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeCValue","isActive":true},{"text":" ","type":"text"},{"text":"with length of ","type":"text"},{"code":"nCollectValues","type":"codeVoice"},{"type":"text","text":", containing the collected values according"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"code":"collect_format","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"collectFlags"},{"text":" argument provided as a hint by the caller. It may","type":"text"},{"text":" ","type":"text"},{"text":"contain the flag ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","type":"reference","isActive":true},{"text":" indicating that the collected","type":"text"},{"type":"text","text":" "},{"text":"value contents may be considered ‘static’ for the duration of the ","type":"text"},{"type":"codeVoice","code":"value"},{"text":" ","type":"text"},{"type":"text","text":"lifetime. Thus an extra copy of the contents stored in "},{"type":"codeVoice","code":"collectValues"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"text":"not required for assignment to ","type":"text"},{"code":"value","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"For our above string example, we continue with:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"type":"codeListing","syntax":"C","code":["if (!collect_values[0].v_pointer)","  value->data[0].v_pointer = g_strdup (\"\");","else if (collect_flags & G_VALUE_NOCOPY_CONTENTS)","  {","    value->data[0].v_pointer = collect_values[0].v_pointer;","    \/\/ keep a flag for the value_free() implementation to not free this string","    value->data[1].v_uint = G_VALUE_NOCOPY_CONTENTS;","  }","else","  value->data[0].v_pointer = g_strdup (collect_values[0].v_pointer);","return NULL;"]},{"type":"paragraph","inlineContent":[{"text":"It should be noted, that it is generally a bad idea to follow the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","isActive":true},{"text":" hint for reference counted types. Due to","type":"text"},{"type":"text","text":" "},{"text":"reentrancy requirements and reference count assertions performed","type":"text"},{"type":"text","text":" "},{"text":"by the signal emission code, reference counts should always be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"incremented for reference counted contents stored in the "},{"code":"value->data","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"array. To deviate from our string example for a moment, and taking"},{"type":"text","text":" "},{"text":"a look at an exemplary implementation for ","type":"text"},{"type":"codeVoice","code":"GTypeValueTable.collect_value()"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"type":"codeVoice","code":"GObject"},{"type":"text","text":":"}]},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"syntax":"C","code":["GObject *object = G_OBJECT (collect_values[0].v_pointer);","g_return_val_if_fail (object != NULL,","   g_strdup_printf (\"Object %p passed as invalid NULL pointer\", object));","\/\/ never honour G_VALUE_NOCOPY_CONTENTS for ref-counted types","value->data[0].v_pointer = g_object_ref (object);","return NULL;"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The reference count for valid objects is always incremented, regardless"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"type":"codeVoice","code":"collect_flags"},{"text":". For invalid objects, the example returns a newly","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"allocated string without altering "},{"type":"codeVoice","code":"value"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Upon success, "},{"type":"codeVoice","code":"collect_value()"},{"type":"text","text":" needs to return "},{"type":"codeVoice","code":"NULL"},{"type":"text","text":". If, however,"},{"type":"text","text":" "},{"type":"text","text":"an error condition occurred, "},{"code":"collect_value()","type":"codeVoice"},{"type":"text","text":" should return a newly"},{"type":"text","text":" "},{"type":"text","text":"allocated string containing an error diagnostic."}]},{"inlineContent":[{"type":"text","text":"The calling code makes no assumptions about the "},{"code":"value","type":"codeVoice"},{"text":" contents being","type":"text"},{"type":"text","text":" "},{"text":"valid upon error returns, ","type":"text"},{"type":"codeVoice","code":"value"},{"type":"text","text":" is simply thrown away without further"},{"type":"text","text":" "},{"type":"text","text":"freeing. As such, it is a good idea to not allocate "},{"code":"GValue","type":"codeVoice"},{"type":"text","text":" contents"},{"type":"text","text":" "},{"type":"text","text":"prior to returning an error; however, "},{"type":"codeVoice","code":"collect_values()"},{"text":" is not obliged","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to return a correctly setup "},{"type":"codeVoice","code":"value"},{"type":"text","text":" for error returns, simply because"},{"type":"text","text":" "},{"text":"any non-","type":"text"},{"code":"NULL","type":"codeVoice"},{"text":" return is considered a fatal programming error, and","type":"text"},{"type":"text","text":" "},{"text":"further program behaviour is undefined.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueCollectFunc"},"references":{"doc://GLibObject/documentation/GLibObject/TypeCValue":{"url":"\/documentation\/glibobject\/typecvalue","type":"topic","navigatorTitle":[{"kind":"identifier","text":"TypeCValue"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeCValue","title":"TypeCValue","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"TypeCValue","kind":"identifier"}],"abstract":[{"type":"text","text":"A union holding one collected value."}]},"doc://GLibObject/documentation/GLibObject/valueNocopyContents":{"type":"topic","abstract":[{"type":"text","text":"Flag to indicate that allocated data in a [struct"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference","isActive":true},{"text":"] shouldn’t be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"copied."}],"title":"valueNocopyContents","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/valueNocopyContents","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"valueNocopyContents"},{"text":": ","kind":"text"},{"text":"Int32","preciseIdentifier":"s:s5Int32V","kind":"typeIdentifier"}],"kind":"symbol","url":"\/documentation\/glibobject\/valuenocopycontents"},"doc://GLibObject/documentation/GLibObject/TypeValueCollectFunc":{"type":"topic","abstract":[{"type":"text","text":"This function is responsible for converting the values collected from"},{"type":"text","text":" "},{"text":"a variadic argument list into contents suitable for storage in a ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","type":"reference","isActive":true},{"text":".","type":"text"}],"title":"TypeValueCollectFunc","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueCollectFunc","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TypeValueCollectFunc","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"TypeValueCollectFunc"}],"url":"\/documentation\/glibobject\/typevaluecollectfunc"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/TypeValueInitFunc":{"role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeValueInitFunc","kind":"identifier"}],"kind":"symbol","title":"TypeValueInitFunc","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueInitFunc","type":"topic","url":"\/documentation\/glibobject\/typevalueinitfunc","abstract":[{"type":"text","text":"Initializes the value contents by setting the fields of the "},{"type":"codeVoice","code":"value->data"},{"type":"text","text":" "},{"text":"array.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"TypeValueInitFunc"}]},"doc://GLibObject/documentation/GLibObject/Value":{"kind":"symbol","type":"topic","url":"\/documentation\/glibobject\/value","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Value","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Value"}],"navigatorTitle":[{"kind":"identifier","text":"Value"}],"title":"Value","abstract":[{"text":"This class is the main Swift wrapper with memory management","type":"text"},{"text":" ","type":"text"},{"text":"for underlying ","type":"text"},{"code":"GValues","type":"codeVoice"},{"type":"text","text":" (the opaque GLib structure used to"},{"type":"text","text":" "},{"text":"hold different types of values.","type":"text"}]},"doc://GLibObject/documentation/GLibObject/TypeValueTable":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeValueTable","type":"topic","kind":"symbol","title":"TypeValueTable","role":"symbol","abstract":[],"navigatorTitle":[{"text":"TypeValueTable","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeValueTable","kind":"identifier"}],"url":"\/documentation\/glibobject\/typevaluetable"}}}