{"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/typeclassprotocol\/addprivate(privatesize:)"]}],"metadata":{"symbolKind":"method","title":"addPrivate(privateSize:)","roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"role":"symbol","extendedModule":"GLibObject","externalID":"s:10GLibObject17TypeClassProtocolPAAE10addPrivate11privateSizeySi_tF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addPrivate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"},{"kind":"text","text":")"}],"platforms":[]},"abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addPrivate"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"privateSize"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}]}]},{"content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"When an object is allocated, the private structures for"},{"text":" ","type":"text"},{"type":"text","text":"the type and all of its parent types are allocated"},{"text":" ","type":"text"},{"text":"sequentially in the same memory block as the public","type":"text"},{"type":"text","text":" "},{"type":"text","text":"structures, and are zero-filled."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that the accumulated size of the private structures of"},{"text":" ","type":"text"},{"type":"text","text":"a type and all its parent types cannot exceed 64 KiB."}]},{"inlineContent":[{"text":"This function should be called in the type’s ","type":"text"},{"code":"class_init()","type":"codeVoice"},{"type":"text","text":" function."},{"type":"text","text":" "},{"type":"text","text":"The private structure can be retrieved using the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"G_TYPE_INSTANCE_GET_PRIVATE()"},{"type":"text","text":" macro."}],"type":"paragraph"},{"inlineContent":[{"text":"The following example shows attaching a private structure","type":"text"},{"text":" ","type":"text"},{"text":"MyObjectPrivate to an object MyObject defined in the standard","type":"text"},{"type":"text","text":" "},{"text":"GObject fashion in the type’s ","type":"text"},{"code":"class_init()","type":"codeVoice"},{"type":"text","text":" function."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Note the use of a structure member “priv” to avoid the overhead","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of repeatedly calling "},{"type":"codeVoice","code":"MY_OBJECT_GET_PRIVATE()"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["typedef struct _MyObject        MyObject;","typedef struct _MyObjectPrivate MyObjectPrivate;","","struct _MyObject {"," GObject parent;",""," MyObjectPrivate *priv;","};","","struct _MyObjectPrivate {","  int some_field;","};","","static void","my_object_class_init (MyObjectClass *klass)","{","  g_type_class_add_private (klass, sizeof (MyObjectPrivate));","}","","static void","my_object_init (MyObject *my_object)","{","  my_object->priv = G_TYPE_INSTANCE_GET_PRIVATE (my_object,","                                                 MY_TYPE_OBJECT,","                                                 MyObjectPrivate);","  \/\/ my_object->priv->some_field will be automatically initialised to 0","}","","static int","my_object_get_some_field (MyObject *my_object)","{","  MyObjectPrivate *priv;","","  g_return_val_if_fail (MY_IS_OBJECT (my_object), 0);","","  priv = my_object->priv;","","  return priv->some_field;","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"add_private is deprecated:"}]},{"type":"text","text":" "},{"type":"text","text":"Use the G_ADD_PRIVATE() macro with the "},{"type":"codeVoice","code":"G_DEFINE_*"},{"type":"text","text":" "},{"type":"text","text":"family of macros to add instance private data to a type"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassProtocol"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassProtocol\/addPrivate(privateSize:)"},"references":{"doc://GLibObject/documentation/GLibObject/TypeClassProtocol":{"role":"symbol","navigatorTitle":[{"text":"TypeClassProtocol","kind":"identifier"}],"title":"TypeClassProtocol","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassProtocol","abstract":[{"type":"text","text":"An opaque structure used as the base of all classes."}],"fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"TypeClassProtocol","kind":"identifier"}],"type":"topic","url":"\/documentation\/glibobject\/typeclassprotocol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/TypeClassProtocol/addPrivate(privateSize:)":{"role":"symbol","title":"addPrivate(privateSize:)","abstract":[{"type":"text","text":"Registers a private structure for an instantiatable type."}],"kind":"symbol","url":"\/documentation\/glibobject\/typeclassprotocol\/addprivate(privatesize:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/TypeClassProtocol\/addPrivate(privateSize:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addPrivate","kind":"identifier"},{"text":"(","kind":"text"},{"text":"privateSize","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"text":")","kind":"text"}],"type":"topic","deprecated":true}}}