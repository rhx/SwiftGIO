{"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"BindingRef"}]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"text":"Whenever the source property changes, the same value is applied to the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"target property; for instance, the following binding:"}],"type":"paragraph"},{"code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_DEFAULT);"],"syntax":"c","type":"codeListing"},{"inlineContent":[{"text":"will cause the property named “property-b” of ","type":"text"},{"type":"codeVoice","code":"object2"},{"type":"text","text":" to be updated"},{"text":" ","type":"text"},{"type":"text","text":"every time [method"},{"type":"codeVoice","code":"GObject.set"},{"type":"text","text":"] or the specific accessor changes the value of"},{"type":"text","text":" "},{"type":"text","text":"the property “property-a” of "},{"type":"codeVoice","code":"object1"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is possible to create a bidirectional binding between two properties"},{"text":" ","type":"text"},{"text":"of two ","type":"text"},{"code":"GObject","type":"codeVoice"},{"text":" instances, so that if either property changes, the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"other is updated as well, for instance:"}]},{"syntax":"c","code":["  g_object_bind_property (object1, \"property-a\",","                          object2, \"property-b\",","                          G_BINDING_BIDIRECTIONAL);"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"will keep the two properties in sync."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is also possible to set a custom transformation function (in both"},{"text":" ","type":"text"},{"type":"text","text":"directions, in case of a bidirectional binding) to apply a custom"},{"type":"text","text":" "},{"text":"transformation from the source value to the target value before","type":"text"},{"type":"text","text":" "},{"type":"text","text":"applying it; for instance, the following binding:"}]},{"type":"codeListing","code":["  g_object_bind_property_full (adjustment1, \"value\",","                               adjustment2, \"value\",","                               G_BINDING_BIDIRECTIONAL,","                               celsius_to_fahrenheit,","                               fahrenheit_to_celsius,","                               NULL, NULL);"],"syntax":"c"},{"type":"paragraph","inlineContent":[{"type":"text","text":"will keep the “value” property of the two adjustments in sync; the"},{"text":" ","type":"text"},{"code":"celsius_to_fahrenheit","type":"codeVoice"},{"text":" function will be called whenever the “value”","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"property of "},{"type":"codeVoice","code":"adjustment1"},{"type":"text","text":" changes and will transform the current value"},{"type":"text","text":" "},{"text":"of the property before applying it to the “value” property of ","type":"text"},{"type":"codeVoice","code":"adjustment2"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Vice versa, the "},{"code":"fahrenheit_to_celsius","type":"codeVoice"},{"type":"text","text":" function will be called whenever"},{"text":" ","type":"text"},{"text":"the “value” property of ","type":"text"},{"type":"codeVoice","code":"adjustment2"},{"type":"text","text":" changes, and will transform the"},{"type":"text","text":" "},{"type":"text","text":"current value of the property before applying it to the “value” property"},{"type":"text","text":" "},{"text":"of ","type":"text"},{"type":"codeVoice","code":"adjustment1"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Note that "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","isActive":true},{"type":"text","text":" does not resolve cycles by itself; a cycle like"}]},{"syntax":null,"type":"codeListing","code":["  object1:propertyA -> object2:propertyB","  object2:propertyB -> object3:propertyC","  object3:propertyC -> object1:propertyA"]},{"inlineContent":[{"type":"text","text":"might lead to an infinite loop. The loop, in this particular case,"},{"type":"text","text":" "},{"type":"text","text":"can be avoided if the objects emit the "},{"type":"codeVoice","code":"GObject"},{"type":"text","text":"notify"},{"code":" signal only if the value has effectively been changed. A binding is implemented using the `GObject`notify","type":"codeVoice"},{"type":"text","text":" signal, so it is susceptible to all the"},{"text":" ","type":"text"},{"text":"various ways of blocking a signal emission, like [func","type":"text"},{"code":"GObject.signal_stop_emission","type":"codeVoice"},{"text":"]","type":"text"},{"type":"text","text":" "},{"type":"text","text":"or [func"},{"type":"codeVoice","code":"GObject.signal_handler_block"},{"type":"text","text":"]."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A binding will be severed, and the resources it allocates freed, whenever"},{"type":"text","text":" "},{"type":"text","text":"either one of the "},{"code":"GObject","type":"codeVoice"},{"text":" instances it refers to are finalized, or when","type":"text"},{"type":"text","text":" "},{"text":"the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding"},{"text":" instance loses its last reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Bindings for languages with garbage collection can use"},{"type":"text","text":" "},{"type":"text","text":"[method"},{"code":"GObject.Binding.unbind","type":"codeVoice"},{"text":"] to explicitly release a binding between the source","type":"text"},{"text":" ","type":"text"},{"text":"and target properties, instead of relying on the last reference on the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"binding, source, and target instances to drop."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","isActive":true},{"text":" type acts as a lightweight Swift reference to an underlying ","type":"text"},{"type":"codeVoice","code":"GBinding"},{"type":"text","text":" instance."},{"type":"text","text":" "},{"type":"text","text":"It exposes methods that can operate on this data type through "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingProtocol","isActive":true},{"type":"text","text":" conformance."},{"type":"text","text":" "},{"type":"text","text":"Use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef"},{"type":"text","text":" only as an "},{"type":"codeVoice","code":"unowned"},{"type":"text","text":" reference to an existing "},{"type":"codeVoice","code":"GBinding"},{"text":" instance.","type":"text"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","type":"reference","isActive":true},{"type":"text","text":" (instead of "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","type":"reference","isActive":true},{"text":") if you want to use Automatic Reference Counting for memory management of the underlying ","type":"text"},{"type":"codeVoice","code":"GBinding"},{"type":"text","text":" instance."}],"type":"paragraph"}]}]}],"variants":[{"paths":["\/documentation\/glibobject\/bindingref"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject"]]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","interfaceLanguage":"swift"},"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(_:)-4t7wl","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(_:)-76590","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(_:)-791e9","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(_:)-7vk9n","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(_:)-9r2ew","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(cPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(constPointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(gconstpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(gpointer:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(mutating:)","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/init(opaquePointer:)"],"generated":true,"anchor":"Initializers"},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ptr"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/unowned(_:)"],"title":"Type Methods","anchor":"Type-Methods","generated":true},{"anchor":"Default-Implementations","generated":true,"title":"Default Implementations","identifiers":["doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/BindingProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/ObjectProtocol-Implementations","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef\/PointerWrapper-Implementations"]}],"rel