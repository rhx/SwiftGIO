{"abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"type":"text","text":" "},{"type":"text","text":"dropped, or when this is already the last reference to the object"},{"type":"text","text":" "},{"type":"text","text":"and another reference is established."}],"kind":"symbol","sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindinggroupref\/addtoggleref(notify:data:)"]}],"metadata":{"roleHeading":"Instance Method","externalID":"s:10GLibObject0B8ProtocolPAAE12addToggleRef6notify4datayySvSg_SpySo8_GObjectVGSgs5Int32VtXCSg_AGtF::SYNTHESIZED::s:10GLibObject15BindingGroupRefV","title":"addToggleRef(notify:data:)","role":"symbol","symbolKind":"method","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"text":"?, ","kind":"text"},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gtypes.h@T@gpointer","text":"gpointer","kind":"typeIdentifier"},{"kind":"text","text":"?)"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"addToggleRef","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"notify"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:gobject.h@T@GToggleNotify","text":"GToggleNotify","kind":"typeIdentifier"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"data"},{"kind":"text","text":": "},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil)","kind":"text"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"This functionality is intended for binding ","type":"text"},{"type":"codeVoice","code":"object"},{"text":" to a proxy","type":"text"},{"type":"text","text":" "},{"text":"object managed by another memory manager. This is done with two","type":"text"},{"type":"text","text":" "},{"text":"paired references: the strong reference added by","type":"text"},{"type":"text","text":" "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":" and a reverse reference to the proxy","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"object which is either a strong reference or weak reference."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The setup is that when there are no other references to ","type":"text"},{"code":"object","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"only a weak reference is held in the reverse direction from "},{"type":"codeVoice","code":"object"},{"type":"text","text":" "},{"text":"to the proxy object, but when there are other references held to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"object"},{"type":"text","text":", a strong reference is held. The "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" callback is called"},{"type":"text","text":" "},{"type":"text","text":"when the reference from "},{"type":"codeVoice","code":"object"},{"text":" to the proxy object should be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“toggled” from strong to weak ("},{"code":"is_last_ref","type":"codeVoice"},{"type":"text","text":" true) or weak to strong"},{"type":"text","text":" "},{"text":"(","type":"text"},{"type":"codeVoice","code":"is_last_ref"},{"type":"text","text":" false)."}]},{"inlineContent":[{"type":"text","text":"Since a (normal) reference must be held to the object before"},{"type":"text","text":" "},{"type":"text","text":"calling "},{"type":"codeVoice","code":"g_object_add_toggle_ref()"},{"text":", the initial state of the reverse","type":"text"},{"type":"text","text":" "},{"type":"text","text":"link is always strong."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Multiple toggle references may be added to the same gobject,"},{"type":"text","text":" "},{"type":"text","text":"however if there are multiple toggle references to an object, none"},{"type":"text","text":" "},{"type":"text","text":"of them will ever be notified until all but one are removed.  For"},{"type":"text","text":" "},{"text":"this reason, you should only ever use a toggle reference if there","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is important state in the proxy object."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Note that if you unref the object on another thread, then "},{"type":"codeVoice","code":"notify"},{"type":"text","text":" might"},{"text":" ","type":"text"},{"type":"text","text":"still be invoked after "},{"type":"codeVoice","code":"g_object_remove_toggle_ref()"},{"text":", and the object argument","type":"text"},{"type":"text","text":" "},{"type":"text","text":"might be a dangling pointer. If the object is destroyed on other threads,"},{"text":" ","type":"text"},{"type":"text","text":"you must take care of that yourself."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"code":"g_object_add_toggle_ref()","type":"codeVoice"},{"text":" must be released with ","type":"text"},{"code":"g_object_remove_toggle_ref()","type":"codeVoice"},{"type":"text","text":"."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/addToggleRef(notify:data:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations"]]},"references":{"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/BindingGroupRef/addToggleRef(notify:data:)":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/addToggleRef(notify:data:)","url":"\/documentation\/glibobject\/bindinggroupref\/addtoggleref(notify:data:)","title":"addToggleRef(notify:data:)","role":"symbol","abstract":[{"text":"Increases the reference count of the object by one and sets a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"callback to be called when all other references to the object are"},{"text":" ","type":"text"},{"text":"dropped, or when this is already the last reference to the object","type":"text"},{"text":" ","type":"text"},{"text":"and another reference is established.","type":"text"}],"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addToggleRef"},{"text":"(","kind":"text"},{"text":"notify","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"GToggleNotify","preciseIdentifier":"c:gobject.h@T@GToggleNotify"},{"kind":"text","text":"?, "},{"text":"data","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?)","kind":"text"}]},"doc://GLibObject/documentation/GLibObject/BindingGroupRef":{"kind":"symbol","type":"topic","url":"\/documentation\/glibobject\/bindinggroupref","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"BindingGroupRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"BindingGroupRef"}],"title":"BindingGroupRef","abstract":[{"code":"GBindingGroup","type":"codeVoice"},{"type":"text","text":" can be used to bind multiple properties"},{"type":"text","text":" "},{"text":"from an object collectively.","type":"text"}]},"doc://GLibObject/documentation/GLibObject/BindingGroupRef/ObjectProtocol-Implementations":{"url":"\/documentation\/glibobject\/bindinggroupref\/objectprotocol-implementations","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[]}}}