ingRefV"},{"text":"!","kind":"text"}],"roleHeading":"Instance Method","externalID":"s:10GLibObject0B8ProtocolPAAE12bindProperty06sourceE06target0gE05flagsAA10BindingRefVSgSPys4Int8VGSg_qd__AoA0I5FlagsVtAaBRd__lF::SYNTHESIZED::s:10GLibObject15BindingGroupRefV","role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"bindProperty"},{"text":"<","kind":"text"},{"text":"ObjectT","kind":"genericParameter"},{"kind":"text","text":">("},{"text":"sourceProperty","kind":"externalParam"},{"kind":"text","text":": "},{"text":"UnsafePointer","kind":"typeIdentifier","preciseIdentifier":"s:SP"},{"text":"<","kind":"text"},{"text":"gchar","kind":"typeIdentifier","preciseIdentifier":"c:@T@gchar"},{"text":">!, ","kind":"text"},{"text":"target","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ObjectT","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"targetProperty"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SP","kind":"typeIdentifier","text":"UnsafePointer"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"gchar","preciseIdentifier":"c:@T@gchar"},{"kind":"text","text":">!, "},{"kind":"externalParam","text":"flags"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject12BindingFlagsV","text":"BindingFlags","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingFlags"},{"text":") -> ","kind":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingRef","text":"BindingRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject10BindingRefV"},{"text":"! ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ObjectT","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"ObjectProtocol","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B8ProtocolP","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Whenever the "},{"code":"sourceProperty","type":"codeVoice"},{"type":"text","text":" is changed the "},{"type":"codeVoice","code":"targetProperty"},{"type":"text","text":" is"},{"type":"text","text":" "},{"text":"updated using the same value. For instance:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"(C Language Example):","type":"text"}],"type":"paragraph"},{"code":["  g_object_bind_property (action, \"active\", widget, \"sensitive\", 0);"],"syntax":"C","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Will result in the “sensitive” property of the widget "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference","isActive":true},{"type":"text","text":" instance to be"},{"type":"text","text":" "},{"text":"updated with the same value of the “active” property of the action ","type":"text"},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"text":" ","type":"text"},{"text":"instance.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"flags","type":"codeVoice"},{"text":" contains ","type":"text"},{"code":"bidirectional","type":"codeVoice"},{"text":" then the binding will be mutual:","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"if "},{"type":"codeVoice","code":"targetProperty"},{"type":"text","text":" on "},{"code":"target","type":"codeVoice"},{"type":"text","text":" changes then the "},{"type":"codeVoice","code":"sourceProperty"},{"type":"text","text":" on "},{"code":"source","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"will be updated as well."}],"type":"paragraph"},{"inlineContent":[{"text":"The binding will automatically be removed when either the ","type":"text"},{"type":"codeVoice","code":"source"},{"text":" or the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"target"},{"type":"text","text":" instances are finalized. To remove the binding without affecting the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"source"},{"type":"text","text":" and the "},{"type":"codeVoice","code":"target"},{"type":"text","text":" you can just call "},{"type":"codeVoice","code":"g_object_unref()"},{"text":" on the returned","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Binding","type":"reference","isActive":true},{"type":"text","text":" instance."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Removing the binding by calling "},{"type":"codeVoice","code":"g_object_unref()"},{"type":"text","text":" on it must only be done if"},{"type":"text","text":" "},{"type":"text","text":"the binding, "},{"code":"source","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"target"},{"type":"text","text":" are only used from a single thread and it"},{"text":" ","type":"text"},{"text":"is clear that both ","type":"text"},{"code":"source","type":"codeVoice"},{"type":"text","text":" and "},{"code":"target","type":"codeVoice"},{"type":"text","text":" outlive the binding. Especially it"},{"text":" ","type":"text"},{"text":"is not safe to rely on this if the binding, ","type":"text"},{"code":"source","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"target"},{"type":"text","text":" can be"},{"type":"text","text":" "},{"type":"text","text":"finalized from different threads. Keep another reference to the binding and"},{"type":"text","text":" "},{"type":"text","text":"use "},{"type":"codeVoice","code":"g_binding_unbind()"},{"type":"text","text":" instead to be on the safe side."}]},{"inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","type":"reference","isActive":true},{"type":"text","text":" can have multiple bindings."}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/bindProperty(sourceProperty:target:targetProperty:flags:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations"]]},"references":{"doc://GLibObject/documentation/GLibObject/ObjectProtocol":{"navigatorTitle":[{"text":"ObjectProtocol","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The base object type."}],"url":"\/documentation\/glibobject\/objectprotocol","title":"ObjectProtocol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"ObjectProtocol","kind":"identifier"}],"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectProtocol"},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/BindingGroupRef/ObjectProtocol-Implementations":{"url":"\/documentation\/glibobject\/bindinggroupref\/objectprotocol-implementations","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[]},"doc://GLibObject/documentation/GLibObject/BindingGroupRef":{"kind":"symbol","type":"topic","url":"\/documentation\/glibobject\/bindinggroupref","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","role":"symbol","fragments":[{"kind":"keyword","text":"struc