{"abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"object"},{"type":"text","text":" is floating, sink it.  Otherwise, do nothing."}],"metadata":{"role":"symbol","title":"takeRef()","roleHeading":"Instance Method","modules":[{"name":"GLibObject"}],"symbolKind":"method","extendedModule":"GLibObject","externalID":"s:10GLibObject0B8ProtocolPAAE7takeRefAA0bE0VSgyF::SYNTHESIZED::s:10GLibObject15BindingGroupRefV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","preciseIdentifier":"s:10GLibObject0B3RefV","kind":"typeIdentifier"},{"kind":"text","text":"!"}]},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/takeRef()","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"takeRef","kind":"identifier"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10GLibObject0B3RefV","text":"ObjectRef","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","kind":"typeIdentifier"},{"kind":"text","text":"!"}],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"In other words, this function will convert a floating reference (if"},{"type":"text","text":" "},{"text":"present) into a full reference.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Typically you want to use ","type":"text"},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" in order to"},{"text":" ","type":"text"},{"text":"automatically do the correct thing with respect to floating or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"non-floating references, but there is one specific scenario where"},{"type":"text","text":" "},{"text":"this function is helpful.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The situation where this function is helpful is when creating an API"},{"type":"text","text":" "},{"type":"text","text":"that allows the user to provide a callback function that returns a"},{"type":"text","text":" "},{"text":"GObject. We certainly want to allow the user the flexibility to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"return a non-floating reference from this callback (for the case"},{"text":" ","type":"text"},{"type":"text","text":"where the object that is being returned already exists)."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"At the same time, the API style of some popular GObject-based","type":"text"},{"text":" ","type":"text"},{"text":"libraries (such as Gtk) make it likely that for newly-created GObject","type":"text"},{"type":"text","text":" "},{"type":"text","text":"instances, the user can be saved some typing if they are allowed to"},{"text":" ","type":"text"},{"text":"return a floating reference.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using this function on the return value of the user’s callback allows"},{"text":" ","type":"text"},{"text":"the user to do whichever is more convenient for them. The caller will","type":"text"},{"text":" ","type":"text"},{"text":"always receives exactly one full reference to the value: either the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"one that was returned in the first place, or a floating reference"},{"type":"text","text":" "},{"text":"that has been converted to a full reference.","type":"text"}]},{"inlineContent":[{"type":"text","text":"This function has an odd interaction when combined with"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_object_ref_sink()"},{"type":"text","text":" running at the same time in another thread on"},{"type":"text","text":" "},{"type":"text","text":"the same "},{"type":"reference","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","isActive":true},{"type":"text","text":" instance. If "},{"code":"g_object_ref_sink()","type":"codeVoice"},{"text":" runs first then","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the result will be that the floating reference is converted to a hard"},{"type":"text","text":" "},{"type":"text","text":"reference. If "},{"code":"g_object_take_ref()","type":"codeVoice"},{"type":"text","text":" runs first then the result will be"},{"text":" ","type":"text"},{"text":"that the floating reference is converted to a hard reference and an","type":"text"},{"type":"text","text":" "},{"type":"text","text":"additional reference on top of that one is added. It is best to avoid"},{"type":"text","text":" "},{"text":"this situation.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/glibobject\/bindinggroupref\/takeref()"]}],"kind":"symbol","references":{"doc://GLibObject/documentation/GLibObject/BindingGroupRef/ObjectProtocol-Implementations":{"url":"\/documentation\/glibobject\/bindinggroupref\/objectprotocol-implementations","type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/ObjectProtocol-Implementations","title":"ObjectProtocol Implementations","role":"collectionGroup","kind":"article","abstract":[]},"doc://GLibObject/documentation/GLibObject/Object":{"identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Object","navigatorTitle":[{"text":"Object","kind":"identifier"}],"title":"Object","kind":"symbol","abstract":[{"text":"The base object type.","type":"text"}],"url":"\/documentation\/glibobject\/object","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Object"}],"role":"symbol"},"doc://GLibObject/documentation/GLibObject/BindingGroupRef/takeRef()":{"abstract":[{"text":"If ","type":"text"},{"code":"object","type":"codeVoice"},{"text":" is floating, sink it.  Otherwise, do nothing.","type":"text"}],"kind":"symbol","type":"topic","title":"takeRef()","role":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef\/takeRef()","url":"\/documentation\/glibobject\/bindinggroupref\/takeref()","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"takeRef"},{"kind":"text","text":"() -> "},{"text":"ObjectRef","kind":"typeIdentifier","preciseIdentifier":"s:10GLibObject0B3RefV"},{"kind":"text","text":"!"}]},"doc://GLibObject/documentation/GLibObject/ObjectRef":{"navigatorTitle":[{"text":"ObjectRef","kind":"identifier"}],"abstract":[{"text":"The base object type.","type":"text"}],"title":"ObjectRef","url":"\/documentation\/glibobject\/objectref","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"ObjectRef","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/ObjectRef","kind":"symbol","role":"symbol"},"doc://GLibObject/documentation/GLibObject/BindingGroupRef":{"kind":"symbol","type":"topic","url":"\/documentation\/glibobject\/bindinggroupref","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/BindingGroupRef","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"BindingGroupRef","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"BindingGroupRef"}],"title":"BindingGroupRef","abstract":[{"code":"GBindingGroup","type":"codeVoice"},{"type":"text","text":" can be used to bind multiple properties"},{"type":"text","text":" "},{"text":"from an object collectively.","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"}}}