{"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"sink"},{"kind":"text","text":"()"}],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each closure is initially created in a “floating” state, which means"},{"text":" ","type":"text"},{"type":"text","text":"that the initial reference count is not owned by any caller."}]},{"type":"paragraph","inlineContent":[{"text":"This function checks to see if the object is still floating, and if so,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"unsets the floating state and decreases the reference count. If the"},{"type":"text","text":" "},{"type":"text","text":"closure is not floating, "},{"type":"codeVoice","code":"g_closure_sink()"},{"type":"text","text":" does nothing."}]},{"type":"paragraph","inlineContent":[{"text":"The reason for the existence of the floating state is to prevent","type":"text"},{"text":" ","type":"text"},{"text":"cumbersome code sequences like:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"(C Language Example):"}]},{"type":"codeListing","syntax":"C","code":["closure = g_cclosure_new (cb_func, cb_data);","g_source_set_closure (source, closure);","g_closure_unref (closure); \/\/ GObject doesn't really need this"]},{"inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"g_source_set_closure()"},{"type":"text","text":" (and similar functions) take ownership of the"},{"text":" ","type":"text"},{"type":"text","text":"initial reference count, if it is unowned, we instead can write:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"(C Language Example):"}],"type":"paragraph"},{"code":["g_source_set_closure (source, g_cclosure_new (cb_func, cb_data));"],"type":"codeListing","syntax":"C"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Generally, this function is used together with "},{"type":"codeVoice","code":"g_closure_ref()"},{"type":"text","text":". An example"},{"type":"text","text":" "},{"type":"text","text":"of storing a closure for later notification looks like:"}]},{"type":"paragraph","inlineContent":[{"text":"(C Language Example):","type":"text"}]},{"syntax":"C","code":["static GClosure *notify_closure = NULL;","void","foo_notify_set_closure (GClosure *closure)","{","  if (notify_closure)","    g_closure_unref (notify_closure);","  notify_closure = closure;","  if (notify_closure)","    {","      g_closure_ref (notify_closure);","      g_closure_sink (notify_closure);","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Because ","type":"text"},{"type":"codeVoice","code":"g_closure_sink()"},{"text":" may decrement the reference count of a closure","type":"text"},{"type":"text","text":" "},{"text":"(if it hasn’t been called on ","type":"text"},{"code":"closure","type":"codeVoice"},{"text":" yet) just like ","type":"text"},{"code":"g_closure_unref()","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"code":"g_closure_ref()","type":"codeVoice"},{"text":" should be called prior to this function.","type":"text"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Takes over the initial ownership of a closure."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ClosureProtocol-Implementations"]]},"metadata":{"symbolKind":"method","title":"sink()","externalID":"s:10GLibObject15ClosureProtocolPAAE4sinkyyF::SYNTHESIZED::s:10GLibObject7ClosureC","modules":[{"name":"GLibObject"}],"extendedModule":"GLibObject","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"sink","kind":"identifier"},{"text":"()","kind":"text"}],"roleHeading":"Instance Method"},"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/sink()","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/glibobject\/closure\/sink()"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","references":{"doc://GLibObject/documentation/GLibObject/Closure/ClosureProtocol-Implementations":{"kind":"article","type":"topic","title":"ClosureProtocol Implementations","url":"\/documentation\/glibobject\/closure\/closureprotocol-implementations","role":"collectionGroup","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ClosureProtocol-Implementations","abstract":[]},"doc://GLibObject/documentation/GLibObject/Closure/sink()":{"kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/sink()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"sink","kind":"identifier"},{"kind":"text","text":"()"}],"url":"\/documentation\/glibobject\/closure\/sink()","role":"symbol","type":"topic","title":"sink()","abstract":[{"text":"Takes over the initial ownership of a closure.","type":"text"}]},"doc://GLibObject/documentation/GLibObject":{"abstract":[],"title":"GLibObject","url":"\/documentation\/glibobject","type":"topic","role":"collection","kind":"symbol","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject"},"doc://GLibObject/documentation/GLibObject/Closure":{"navigatorTitle":[{"text":"Closure","kind":"identifier"}],"url":"\/documentation\/glibobject\/closure","title":"Closure","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","role":"symbol","abstract":[{"text":"A ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"text":" represents a callback supplied by the programmer.","type":"text"}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Closure","kind":"identifier"}],"type":"topic"}}}