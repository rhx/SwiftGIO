{"identifier":{"url":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/setMetaMarshal(marshalData:metaMarshal:)","interfaceLanguage":"swift"},"abstract":[{"text":"Sets the meta marshaller of ","type":"text"},{"code":"closure","type":"codeVoice"},{"text":".","type":"text"}],"variants":[{"paths":["\/documentation\/glibobject\/closure\/setmetamarshal(marshaldata:metamarshal:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/GLibObject\/documentation\/GLibObject","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/ClosureProtocol-Implementations"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","metadata":{"extendedModule":"GLibObject","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"gpointer","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"?, ","kind":"text"},{"text":"metaMarshal","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","text":"GClosureMarshal","kind":"typeIdentifier"},{"text":")","kind":"text"}],"externalID":"s:10GLibObject15ClosureProtocolPAAE14setMetaMarshal11marshalData04metaG0ySvSg_ySpySo9_GClosureVGSg_SpySo7_GValueVGSgs6UInt32VSPyAMGSgA2GtXCtF::SYNTHESIZED::s:10GLibObject7ClosureC","roleHeading":"Instance Method","title":"setMetaMarshal(marshalData:metaMarshal:)","modules":[{"name":"GLibObject"}],"symbolKind":"method","role":"symbol"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setMetaMarshal"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"gpointer","kind":"typeIdentifier","preciseIdentifier":"c:gtypes.h@T@gpointer"},{"text":"? = nil, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"text":"GClosureMarshal","kind":"typeIdentifier","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"A meta marshaller wraps the "},{"type":"codeVoice","code":"closure"},{"type":"text","text":"’s marshal and modifies the way"},{"type":"text","text":" "},{"type":"text","text":"it is called in some fashion. The most common use of this facility"},{"type":"text","text":" "},{"type":"text","text":"is for C callbacks."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The same marshallers (generated by "},{"identifier":"#glib-genmarshal","isActive":true,"type":"reference"},{"type":"text","text":"),"},{"text":" ","type":"text"},{"type":"text","text":"are used everywhere, but the way that we get the callback function"},{"text":" ","type":"text"},{"text":"differs. In most cases we want to use the ","type":"text"},{"code":"closure","type":"codeVoice"},{"text":"’s callback, but in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"other cases we want to use some different technique to retrieve the"},{"type":"text","text":" "},{"type":"text","text":"callback function."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, class closures for signals (see"},{"type":"text","text":" "},{"type":"codeVoice","code":"g_signal_type_cclosure_new()"},{"type":"text","text":") retrieve the callback function from a"},{"text":" ","type":"text"},{"text":"fixed offset in the class structure.  The meta marshaller retrieves","type":"text"},{"type":"text","text":" "},{"text":"the right callback and passes it to the marshaller as the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"marshalData"},{"type":"text","text":" argument."}]}]}],"sections":[],"references":{"doc://GLibObject/documentation/GLibObject/Closure":{"navigatorTitle":[{"text":"Closure","kind":"identifier"}],"url":"\/documentation\/glibobject\/closure","title":"Closure","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure","role":"symbol","abstract":[{"text":"A ","type":"text"},{"code":"GClosure","type":"codeVoice"},{"text":" represents a callback supplied by the programmer.","type":"text"}],"kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Closure","kind":"identifier"}],"type":"topic"},"doc://GLibObject/documentation/GLibObject/Closure/setMetaMarshal(marshalData:metaMarshal:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setMetaMarshal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"marshalData","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"c:gtypes.h@T@gpointer","kind":"typeIdentifier","text":"gpointer"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"metaMarshal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:gclosure.h@T@GClosureMarshal","text":"GClosureMarshal"},{"text":")","kind":"text"}],"abstract":[{"type":"text","text":"Sets the meta marshaller of "},{"code":"closure","type":"codeVoice"},{"text":".","type":"text"}],"kind":"symbol","title":"setMetaMarshal(marshalData:metaMarshal:)","identifier":"doc:\/\/GLibObject\/documentation\/GLibObject\/Closure\/setMetaMarshal(marshalData:metaMarshal:)","url":"\/documentation\/glibobject\/closure\/setmetamarshal(marshaldata:metamarshal:)","type":"topic","role":"symbol"},"doc://GLibObject/documentation/GLibObject/Closure/ClosureProtocol-Implementations":{"kind":"article","type":"topic","title":"ClosureProtocol Implementations","url":"\/documentation\/glibobject\/closure\/closureprotocol-implementations","role":"collectionGroup","identifier